{"tag":"section","attrib":{"id":"id79a453ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904"},"text":null,"children":[{"tag":"num","attrib":{"value":"2904"},"text":"§ 2904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of conservation plans and certain nongame fish and wildlife conservation actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a453bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval by Secretary of plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a453bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any State may apply to the Secretary for approval of a conservation plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a453bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Applications for the approval of conservation plans shall be made and reviewed by the Secretary in such manner as the Secretary shall by regulation prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a453be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As soon as practicable, but not later than 180 days, after the date on which a State submits (or resubmits in the case of prior disapproval) an application for the approval of a conservation plan the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a453bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" approve the conservation plan, and designate it as an approved conservation plan, if he determines that the plan—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79a453c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2903"},"text":"section 2903 of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79a453c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is substantial in character and design; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a453c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" disapprove the conservation plan if he determines that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79a453c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan does not meet the requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2903"},"text":"section 2903 of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79a453c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement any part of the plan on the basis of the specifications, determinations, identifications, or priorities therein would threaten the natural stability and continued viability of any of the plan species concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If the Secretary disapproves a plan, he shall give the State concerned a written statement of the reasons for disapproval and provide the State opportunity for consultation with respect to deficiencies in the plan and the modifications required for approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a453c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of approval of plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary approves the conservation plan of any State under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a453c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that portion of such plan that pertains to wildlife conservation shall be deemed to be an approved plan for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-02/s6/a/1"},"text":"section 6(a)(1) of the Act of September 2, 1937","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s669e/a/1"},"text":"16 U.S.C. 669e(a)(1)","children":[],"tail":"), commonly referred to as the Pittman-Robertson Wildlife Restoration Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s669"},"text":"16 U.S.C. 669","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a453c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that portion of such plan that pertains to fish conservation shall be deemed to be an approved plan for the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-09/s6/a/1"},"text":"section 6(a)(1) of the Act of August 9, 1950","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s777e/a/1"},"text":"16 U.S.C. 777e(a)(1)","children":[],"tail":"] commonly referred to as the Dingell-Johnson Sport Fish Restoration Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s777"},"text":"16 U.S.C. 777","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a453c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary approves the conservation plan of any State under subsection (a), those conservation actions set forth in the plan which pertain to nongame fish and wildlife shall be deemed to be eligible as nongame fish and wildlife projects for which reimbursement is available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2905"},"text":"section 2905 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a453c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nongame conservation actions in the absence of an approved plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the absence of an approved conservation plan, and on a showing of need by the State, the Secretary may deem certain conservation actions to be nongame fish and wildlife projects for which reimbursement is available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2905/a/3"},"text":"section 2905(a)(3) of this title","children":[],"tail":" if they—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a453ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with such of the requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2903"},"text":"section 2903 of this title","children":[],"tail":" as may be appropriate, including, but not limited to, the requirements in paragraphs (3), (4), (5), and (7) of such section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a453cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2904/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are substantial in character and design.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a453cc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/366/s5"},"text":"Pub. L. 96–366, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-29"},"text":"Sept. 29, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1324"},"text":"94 Stat. 1324","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a453cd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a453ce-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79a453cf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Pittman-Robertson Wildlife Restoration Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-02/ch899"},"text":"act Sept. 2, 1937, ch. 899","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/917"},"text":"50 Stat. 917","children":[],"tail":", also known as the Federal Aid in Wildlife Restoration Act, which is classified generally to chapter 5B (§ 669 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s669"},"text":"section 669 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Dingell-Johnson Sport Fish Restoration Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-09/ch658"},"text":"act Aug. 9, 1950, ch. 658","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/430"},"text":"64 Stat. 430","children":[],"tail":", also known as the Federal Aid in Fish Restoration Act and the Fish Restoration and Management Projects Act, which is classified generally to chapter 10B (§ 777 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s777"},"text":"section 777 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
