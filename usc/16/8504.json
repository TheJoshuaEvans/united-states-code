{"tag":"section","attrib":{"id":"id7a3d112f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8504"},"text":null,"children":[{"tag":"num","attrib":{"value":"8504"},"text":"§ 8504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National strategy for military and veteran recreation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3d1130-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Federal Interagency Council on Outdoor Recreation established under section 113 "},{"tag":"ref","attrib":{"idref":"fn002879"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002879"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall develop and make public a strategy to increase visits to Federal recreational lands and waters by members of the Armed Forces, veterans, and Gold Star Family members."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d1131-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A strategy developed under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3d1132-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3d1133-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8504/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish objectives and quantifiable targets for increasing visits to Federal recreational lands and waters by members of the Armed Forces, veterans, and Gold Star Family members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3d1134-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8504/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an opportunity for public notice and comment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3d1135-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8504/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emphasize increased recreation opportunities on Federal recreational lands and waters for members of the Armed Forces, veterans, and Gold Star Family members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3d1136-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8504/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the anticipated costs to achieve the objectives and meet the targets established under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d1137-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not establish any preference between similar recreation facilitated by noncommercial or commercial entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d1138-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Update to strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after the date of the publication of the strategy required under subsection (a), and every 5 years thereafter, the Federal Interagency Council on Outdoor Recreation shall update the strategy and make public the update.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3d1139-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tII/s224"},"text":"Pub. L. 118–234, title II, § 224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2888"},"text":"138 Stat. 2888","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3d113a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3d113b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a3d113c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 113, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s113"},"text":"section 113 of Pub. L. 118–234","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2839"},"text":"138 Stat. 2839","children":[],"tail":", which amended sections 200102 and 200104 of Title 54, National Park Service and Related Programs. As amended, "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s200104"},"text":"section 200104 of Title 54","children":[],"tail":" establishes the Federal Interagency Council on Outdoor Recreation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
