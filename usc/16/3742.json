{"tag":"section","attrib":{"id":"id79c374cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3742"},"text":null,"children":[{"tag":"num","attrib":{"value":"3742"},"text":"§ 3742.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are to establish a partnership among the United States Fish and Wildlife Service, designated State agencies, and private organizations and individuals—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c374cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3742/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out wildlife conservation and appreciation projects to conserve the entire array of diverse fish and wildlife species in the United States and to provide opportunities for the public to use and enjoy these fish and wildlife species through nonconsumptive activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c374cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3742/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable designated State agencies to respond more fully and utilize their statutory and administrative authorities by carrying out wildlife conservation and appreciation projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c374ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3742/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage private donations, under the leadership of the States and of the National Fish and Wildlife Foundation, to carry out wildlife conservation and appreciation projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c374cf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/tVII/s7103"},"text":"Pub. L. 102–587, title VII, § 7103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5095"},"text":"106 Stat. 5095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/375/s6/1"},"text":"Pub. L. 103–375, § 6(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-19"},"text":"Oct. 19, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3495"},"text":"108 Stat. 3495","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c374d0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c374d1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79c374d2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/375"},"text":"Pub. L. 103–375","children":[],"tail":" inserted “the States and of” after “under the leadership of”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
