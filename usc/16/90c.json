{"tag":"section","attrib":{"id":"id77019515-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s90c"},"text":null,"children":[{"tag":"num","attrib":{"value":"90c"},"text":"§ 90c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer the park in accordance with the Act of ","children":[{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1–4"},"text":"16 U.S.C. 1–4","children":[],"tail":"),"},{"tag":"ref","attrib":{"idref":"fn002021"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002021"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" as amended and supplemented."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77019516-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/544/tIV/s401"},"text":"Pub. L. 90–544, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-02"},"text":"Oct. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/928"},"text":"82 Stat. 928","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77019517-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77019518-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77019519-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1–4"},"text":"16 U.S.C. 1–4","children":[],"tail":"), referred to in text, is "},{"tag":"ref","attrib":{"href":"/us/act/1916-08-25/ch408"},"text":"act Aug. 25, 1916, ch. 408","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":", known as the National Park Service Organic Act, which enacted sections 1, 2, 3, and 4 of this title and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":", National Park Service and Related Programs. Sections 1 to 4 of the Act were repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1865/a"},"text":"section 1865(a) of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and section 100101(a), chapter 1003, and sections 100751(a), 100752, 100753, and 102101 of Title 54 by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 4(a)(1), 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3260, 3272. For complete classification of this Act to the Code, see Tables. For disposition of former sections of this title, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7701951a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7701951b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"North Cascades National Park Service Complex Fish Stocking","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/137"},"text":"Pub. L. 113–137","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-25"},"text":"July 25, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1741"},"text":"128 Stat. 1741","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/137"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘North Cascades National Park Service Complex Fish Stocking Act’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DEFINITIONS.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“In this Act:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"North cascades national park service complex","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘North Cascades National Park Service Complex’ means collectively the North Cascades National Park, Ross Lake National Recreation Area, and Lake Chelan National Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘plan’ means the document entitled ‘North Cascades National Park Service Complex Mountain Lakes Fishery Management Plan and Environmental Impact Statement’ and dated June 2008.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“SEC. 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" STOCKING OF CERTAIN LAKES IN THE NORTH CASCADES NATIONAL PARK SERVICE COMPLEX.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (b), the Secretary shall authorize the stocking of fish in lakes in the North Cascades National Park Service Complex.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary is authorized to allow stocking of fish in not more than 42 of the 91 lakes in the North Cascades National Park Service Complex that have historically been stocked with fish.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Native nonreproducing fish","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall only stock fish that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" native to the slope of the Cascade Range on which the lake to be stocked is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonreproducing, as identified in management alternative B of the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In making fish stocking decisions under this Act, the Secretary shall consider relevant scientific information, including the plan and information gathered under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall coordinate the stocking of fish under this Act with the State of Washington.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research and Monitoring","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue a program of research and monitoring of the impacts of fish stocking on the resources of the applicable unit of the North Cascades National Park Service Complex; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning on the date that is 5 years after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2014-07-25"},"text":"July 25, 2014","children":[],"tail":"] and every 5 years thereafter, submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives a report that describes the results of the research and monitoring under paragraph (1).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
