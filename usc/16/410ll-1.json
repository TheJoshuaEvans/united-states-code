{"tag":"section","attrib":{"id":"id7759c7e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ll–1"},"text":"§ 410ll–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Votes for Women Trail","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7759c7ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7759c7eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Park” means the Women’s Rights National Historical Park established by section 410","children":[{"tag":"i","attrib":{},"text":"ll","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior, acting through the Director of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the State of New York.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trail","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Trail” means the Votes for Women History Trail Route designated under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7759c7ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Trail Route","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, with concurrence of the agency having jurisdiction over the relevant roads, may designate a vehicular tour route, to be known as the “Votes for Women History Trail Route”, to link properties in the State that are historically and thematically associated with the struggle for women’s suffrage in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7759c7f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Trail shall be administered by the National Park Service through the Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7759c7f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To facilitate the establishment of the Trail and the dissemination of information regarding the Trail, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7759c7f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce and disseminate appropriate educational materials regarding the Trail, such as handbooks, maps, exhibits, signs, interpretive guides, and electronic information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the management, planning, and standards of the Trail in partnership with participating properties, other Federal agencies, and State and local governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create and adopt an official, uniform symbol or device to mark the Trail; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue guidelines for the use of the symbol or device adopted under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7759c7f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of Trail Route","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the consent of the owner of the property, the Secretary may designate as an official stop on the Trail—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7759c7f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all units and programs of the Park relating to the struggle for women’s suffrage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal, State, local, and privately owned properties that the Secretary determines have a verifiable connection to the struggle for women’s suffrage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other governmental and nongovernmental facilities and programs of an educational, commemorative, research, or interpretive nature that the Secretary determines to be directly related to the struggle for women’s suffrage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7759c7fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements and memoranda of understanding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7759c7fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To facilitate the establishment of the Trail and to ensure effective coordination of the Federal and non-Federal properties designated as stops along the Trail, the Secretary may enter into cooperative agreements and memoranda of understanding with, and provide technical and financial assistance to, other Federal agencies, the State, localities, regional governmental bodies, and private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll–1/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary such sums as are necessary for the period of fiscal years 2009 through 2013 to provide financial assistance to cooperating entities pursuant to agreements or memoranda entered into under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7759c7fd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/607/tXVI/s1602"},"text":"Pub. L. 96–607, title XVI, § 1602","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7111/a"},"text":"Pub. L. 111–11, title VII, § 7111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1199"},"text":"123 Stat. 1199","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
