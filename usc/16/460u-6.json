{"tag":"section","attrib":{"id":"id77cc37bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"460u–6"},"text":"§ 460u–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77cc37be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of authorities for conservation and management of natural resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the administration of the Park the Secretary may utilize such statutory authorities relating to areas of the national park system and such statutory authority otherwise available to him for the conservation and management of natural resources as he deems appropriate to carry out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77cc37bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of Park; incompatible visitor conveniences restricted; provisions for public enjoyment and understanding; developments for public uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order that the Park shall be permanently preserved in its present state, no development or plan for the convenience of visitors shall be undertaken therein which would be incompatible with the preservation of the unique flora and fauna or the physiographic conditions now prevailing or with the preservation of such historic sites and structures as the Secretary may designate: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the Secretary may provide for the public enjoyment and understanding of the unique natural, historic, and scientific features within the Park by establishing such trails, observation points, and exhibits and providing such services as he may deem desirable for such public enjoyment and understanding: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That the Secretary may develop for appropriate public uses such portions of the Park as he deems especially adaptable for such uses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77cc37c0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/761/s6"},"text":"Pub. L. 89–761, § 6","children":[],"tail":", formerly § 7, "},{"tag":"date","attrib":{"date":"1966-11-05"},"text":"Nov. 5, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1311"},"text":"80 Stat. 1311","children":[],"tail":"; renumbered § 6, "},{"tag":"ref","attrib":{"href":"/us/pl/94/549/s1/9"},"text":"Pub. L. 94–549, § 1(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2533"},"text":"90 Stat. 2533","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/6/dE/tI/s115/a/1/B"},"text":"Pub. L. 116–6, div. E, title I, § 115(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-02-15"},"text":"Feb. 15, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/232"},"text":"133 Stat. 232","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77cc37c1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77cc37c2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id77cc37c3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/761/s6"},"text":"section 6 of Pub. L. 89–761","children":[],"tail":" was renumbered section 5 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460u–5"},"text":"section 460u–5 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77cc37c4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/6"},"text":"Pub. L. 116–6","children":[],"tail":" substituted “Park” for “lakeshore” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
