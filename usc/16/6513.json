{"tag":"section","attrib":{"id":"id7a0d4f56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513"},"text":null,"children":[{"tag":"num","attrib":{"value":"6513"},"text":"§ 6513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0d4f57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with the Implementation Plan, the Secretary shall develop an annual program of work for Federal land that gives priority to authorized hazardous fuel reduction projects that provide for the protection of at-risk communities or watersheds or that implement community wildfire protection plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0d4f58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0d4f59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consider recommendations under subsection (a) that are made by at-risk communities that have developed community wildfire protection plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4f5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to the planning process and recommendations concerning community wildfire protection plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0d4f5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0d4f5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal agency involvement in developing a community wildfire protection plan, or a recommendation made in a community wildfire protection plan, shall not be considered a Federal agency action under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4f5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In implementing authorized hazardous fuel reduction projects on Federal land, the Secretary shall, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6514"},"text":"section 6514 of this title","children":[],"tail":", comply with the National Environmental Policy Act of 1969 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0d4f5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding allocation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0d4f5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal land","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0d4f60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the Secretary shall use not less than 50 percent of the funds allocated for authorized hazardous fuel reduction projects in the wildland-urban interface.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0d4f61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability and allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funding allocation in subparagraph (A) shall apply at the national level. The Secretary may allocate the proportion of funds differently than is required under subparagraph (A) within individual management units as appropriate, in particular to conduct authorized hazardous fuel reduction projects on land described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6512/a/4"},"text":"section 6512(a)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0d4f62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildland-urban interface","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an authorized hazardous fuel reduction project for which a decision notice is issued during the 1-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2003-12-03"},"text":"December 3, 2003","children":[],"tail":", the Secretary shall use existing definitions of the term “wildland-urban interface” rather than the definition of that term provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6511"},"text":"section 6511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4f63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal land","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0d4f64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing financial assistance under any provision of law for hazardous fuel reduction projects on non-Federal land, the Secretary shall consider recommendations made by at-risk communities that have developed community wildfire protection plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0d4f65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In allocating funding under this paragraph, the Secretary should, to the maximum extent practicable, give priority to communities that have adopted a community wildfire protection plan or have taken proactive measures to encourage willing property owners to reduce fire risk on private property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0d4f66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross-boundary hazardous fuel reduction projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0d4f67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0d4f68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hazardous fuel reduction project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “hazardous fuel reduction project” means a hazardous fuel reduction project described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0d4f69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “non-Federal land” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a0d4f6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0d4f6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" county land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0d4f6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tribal land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0d4f6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/e/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0d4f6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/e/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other non-Federal land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4f6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to State foresters to support hazardous fuel reduction projects that incorporate treatments in landscapes across ownership boundaries on Federal and non-Federal land, particularly in areas identified as priorities in applicable State-wide forest resource assessments or strategies under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2101a/a"},"text":"section 2101a(a) of this title","children":[],"tail":", as mutually agreed to by the State forester and the Regional Forester."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4f70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land treatments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To conduct and fund treatments for hazardous fuel reduction projects carried out by State foresters using grants under paragraph (2), the Secretary may use the authorities of the Secretary relating to cooperation and technical and financial assistance, including the good neighbor authority under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fbf71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2113a"},"text":"section 2113a of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbf72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 331 of the Department of the Interior and Related Agencies Appropriations Act, 2001 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1011"},"text":"16 U.S.C. 1011","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/106/291"},"text":"Public Law 106–291","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbf73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out a hazardous fuel reduction project using a grant under paragraph (2) on non-Federal land, the State forester, in consultation with the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fbf74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consult with any applicable owners of the non-Federal land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbf75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not implement the hazardous fuel reduction project on non-Federal land without the consent of the owner of the non-Federal land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbf76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6513/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection $20,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0fbf77-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tI/s103"},"text":"Pub. L. 108–148, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1896"},"text":"117 Stat. 1896","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8401"},"text":"Pub. L. 115–334, title VIII, § 8401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4840"},"text":"132 Stat. 4840","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/130"},"text":"Pub. L. 117–286, § 4(a)(130)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4319"},"text":"136 Stat. 4319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0fbf78-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0fbf79-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a0fbf7a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a0fbf7b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
