{"tag":"section","attrib":{"id":"id79ab7f6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3146"},"text":null,"children":[{"tag":"num","attrib":{"value":"3146"},"text":"§ 3146.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation alternatives portion of study","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In studying oil and gas alternative transportation systems, the Secretary shall consult with the Secretary of Transportation and shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ab7f6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3146/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which environmentally and economically feasible alternative routes could be established;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ab7f6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3146/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prospective oil and gas production potential of this area of Alaska for each alternative transportation route; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ab7f70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3146/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the environmental and economic costs and other values associated with such alternative routes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ab7f71-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487/tX/s1006"},"text":"Pub. L. 96–487, title X, § 1006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2453"},"text":"94 Stat. 2453","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
