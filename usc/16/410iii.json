{"tag":"section","attrib":{"id":"id777405f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"410iii"},"text":"§ 410iii.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this subchapter is to establish the Cedar Creek and Belle Grove National Historical Park in order to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777405f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help preserve, protect, and interpret a nationally significant Civil War landscape and antebellum plantation for the education, inspiration, and benefit of present and future generations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777405f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tell the rich story of Shenandoah Valley history from early settlement through the Civil War and beyond, and the Battle of Cedar Creek and its significance in the conduct of the war in the Shenandoah Valley;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777405fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserve the significant historic, natural, cultural, military, and scenic resources found in the Cedar Creek Battlefield and Belle Grove Plantation areas through partnerships with local landowners and the community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777405fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a focal point to recognize and interpret important events and geographic locations within the Shenandoah Valley Battlefields National Historic District representing key Civil War battles in the Shenandoah Valley, including those battlefields associated with the Thomas J. (Stonewall) Jackson campaign of 1862 and the decisive campaigns of 1864.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777405fc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/373/s2"},"text":"Pub. L. 107–373, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3104"},"text":"116 Stat. 3104","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777405fd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id777405fe-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id777405ff-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/373/s1"},"text":"Pub. L. 107–373, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3104"},"text":"116 Stat. 3104","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/373/s1"},"text":"“This Act [enacting this subchapter] may be cited as the ‘Cedar Creek and Belle Grove National Historical Park Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
