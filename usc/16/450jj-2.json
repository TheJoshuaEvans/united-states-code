{"tag":"section","attrib":{"id":"id77a3c88c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"450jj–2"},"text":"§ 450jj–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Railroad agreement as condition precedent to undertaking memorial project","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The memorial project authorized herein shall not be undertaken until there shall have been reached an agreement satisfactory to the Secretary of the Interior providing for the relocation of the railroad tracks and structures now situated on lands adjacent to the Jefferson National Expansion Memorial National Historic Site,","children":[{"tag":"ref","attrib":{"idref":"fn002264"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002264"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" between the boundary of the site and the river. Such agreement shall contain such terms as may be deemed desirable by the Secretary but shall contain a provision limiting the Federal expenditure of funds in connection with such relocation of the tracks and structures to work undertaken within the historic site area."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a3c88d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-05-17/ch204/s3"},"text":"May 17, 1954, ch. 204, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/99"},"text":"68 Stat. 99","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77a3c88e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77a3c88f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77a3c890-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Herein, referred to in text, means act ","children":[{"tag":"date","attrib":{"date":"1954-05-17"},"text":"May 17, 1954","children":[],"tail":", which is generally classified to sections 450jj to 450jj–9 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77a3c891-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77a3c892-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Jefferson National Expansion Memorial redesignated Gateway Arch National Park by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/128/s2"},"text":"Pub. L. 115–128, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-22"},"text":"Feb. 22, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/328"},"text":"132 Stat. 328","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s450jj–10"},"text":"section 450jj–10 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
