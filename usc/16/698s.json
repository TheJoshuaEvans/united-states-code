{"tag":"section","attrib":{"id":"id787cc411-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698s"},"text":null,"children":[{"tag":"num","attrib":{"value":"698s"},"text":"§ 698s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id787cc412-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id787cc413-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698s/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (2) and (3), the Secretary is authorized to acquire lands, waters, and interests in lands and waters within the boundaries of the Preserve by donation, purchase with donated or appropriated funds, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc414-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698s/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent of the owner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not acquire lands, waters, or interests in lands and waters for the Preserve without the consent of the owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc415-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698s/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Lands, waters, and interests in lands and waters within the boundaries of the Preserve that are owned by the State of Alabama, or any political subdivision of the State, may be acquired only by donation or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787cc416-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiations for acquisition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id787cc417-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698s/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of negotiations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Immediately after publication of a description of the boundaries of the Preserve in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s698q/d"},"text":"section 698q(d) of this title","children":[],"tail":", the Secretary shall commence negotiations for the acquisition of the lands, waters, and interests in lands and waters within the boundaries of the Preserve."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc418-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698s/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1992-10-21"},"text":"October 21, 1992","children":[],"tail":", the Secretary shall submit, in writing, a detailed schedule of actions and a progress report regarding the acquisition to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id787cc419-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698s/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Natural Resources of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id787cc41a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698s/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Natural Resources of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id787cc41b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698s/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Appropriations of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc41c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698s/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall substantially complete the acquisition of the lands, waters, and interests in lands and waters within the Preserve, in accordance with the purposes of sections 698q to 698t of this title, not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"1992-10-21"},"text":"October 21, 1992","children":[],"tail":", subject to the availability of funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787cc41d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698s/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental audits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id787cc41e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698s/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to owner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Promptly following completion of any environmental audit performed by or on behalf of the Secretary with respect to any property proposed to be acquired for the purposes of sections 698q to 698t of this title, the Secretary shall make available to the owner of the property a copy of the audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc41f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698s/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion in documents transferring title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any audit described in paragraph (1), and any environmental audit performed by the owner of the property and submitted to the Secretary prior to the date of the acquisition, shall be included as part of the documents transferring title to the property to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787cc420-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698s/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Future additions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No lands or interest in lands may be added to the Preserve after ","children":[{"tag":"date","attrib":{"date":"1992-10-21"},"text":"October 21, 1992","children":[],"tail":", without specific authorization by Congress and the consent of the owner of the lands or interest."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id787cc421-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/427/s4"},"text":"Pub. L. 102–427, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-21"},"text":"Oct. 21, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2181"},"text":"106 Stat. 2181","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s6/d/36"},"text":"Pub. L. 103–437, § 6(d)(36)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4585"},"text":"108 Stat. 4585","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787cc422-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id787cc423-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id787cc424-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Natural Resources” for “Interior and Insular Affairs”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
