{"tag":"section","attrib":{"id":"id7807e1a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"460qqq–4"},"text":"§ 460qqq–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of Federal parcel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7807e1a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding sections 1712 and 1713 of title 43 and subject to valid existing rights, not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2002-11-06"},"text":"November 6, 2002","children":[],"tail":", the Secretary shall convey to the highest qualified bidder all right, title, and interest of the United States in and to the Federal parcel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e1aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of proceeds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the gross proceeds from the conveyance of land under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e1ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 percent shall be available to the State for use in the general education program of the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e1ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the remainder shall be deposited in the special account established under the Southern Nevada Public Lands Management Act of 1998 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/263"},"text":"Public Law 105–263","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/112/2345"},"text":"112 Stat. 2345","children":[],"tail":"), to be available to the Secretary, without further appropriation for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7807e1ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–4/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction and operation of facilities to support the management of the Conservation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e1ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–4/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction and repair of trails and roads in the Conservation Area authorized under the management plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e1af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–4/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on and interpretation of the archaeological and geological resources of the Conservation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e1b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–4/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conservation and research relating to the Conservation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e1b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–4/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other purpose that the Secretary determines to be consistent with the purpose described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460qqq"},"text":"section 460qqq of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7807e1b2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/282/tVI/s606"},"text":"Pub. L. 107–282, title VI, § 606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-06"},"text":"Nov. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2012"},"text":"116 Stat. 2012","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7807e1b3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7807e1b4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7807e1b5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Southern Nevada Public Lands Management Act of 1998, referred to in subsec. (b)(2), probably means the Southern Nevada Public Land Management Act of 1998, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/263"},"text":"Pub. L. 105–263","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2343"},"text":"112 Stat. 2343","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460ccc–1"},"text":"section 460ccc–1 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s6901"},"text":"section 6901 of Title 31","children":[],"tail":", Money and Finance, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s6901"},"text":"section 6901 of Title 31","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1998 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s6901"},"text":"section 6901 of Title 31","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
