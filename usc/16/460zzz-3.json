{"tag":"section","attrib":{"id":"id780c9c80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"460zzz–3"},"text":"§ 460zzz–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maps and legal descriptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id780c9c81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", the Secretary shall file a map and a legal description of the Conservation Area and the Wilderness with—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9c82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Natural Resources of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9c83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Natural Resources of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9c84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Force and effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Map and legal descriptions filed under subsection (a) shall have the same force and effect as if included in this subchapter, except that the Secretary may correct clerical and typographical errors in the Map and legal descriptions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9c85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Map and legal descriptions filed under subsection (a) shall be available for public inspection in the appropriate offices of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id780c9c86-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tII/s2404"},"text":"Pub. L. 111–11, title II, § 2404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1103"},"text":"123 Stat. 1103","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
