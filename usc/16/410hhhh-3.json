{"tag":"section","attrib":{"id":"id7784a8c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhhh–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410hhhh–3"},"text":"§ 410hhhh–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7784a8c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhhh–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an advisory commission to provide advice on achieving balanced and accurate interpretation of the historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7784a8c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhhh–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7784a8c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhhh–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The commission shall consist of a group of five nationally recognized scholars with collective expertise on the life and Presidency of Jimmy Carter, the 20th century rural south, historic preservation, and the American Presidency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7784a8c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhhh–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The commission members shall be appointed by the Secretary for staggered terms of 3 years each. Any vacancy on the commission shall be filled in the same manner in which the original appointment was made. Any member of the Commission appointed for a definite term may serve after the expiration of such term until a successor is appointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7784a8c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhhh–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Meetings of the Commission shall be called twice annually by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7784a8c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhhh–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to pay, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":", the expenses reasonably incurred by the members of the Commission in carrying out their responsibilities under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7784a8c7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/206/s4"},"text":"Pub. L. 100–206, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-23"},"text":"Dec. 23, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1436"},"text":"101 Stat. 1436","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/341/s2/b/4"},"text":"Pub. L. 116–341, § 2(b)(4)","children":[],"tail":", (5), "},{"tag":"date","attrib":{"date":"2021-01-13"},"text":"Jan. 13, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5132"},"text":"134 Stat. 5132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7784a8c8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7784a8c9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7784a8ca-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/341/s2/b/4"},"text":"Pub. L. 116–341, § 2(b)(4)","children":[],"tail":", (5), made identical amendments, substituting “historical park” for “historic site”. See Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410hhhh"},"text":"section 410hhhh of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
