{"tag":"section","attrib":{"id":"id76f33cf4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s45d"},"text":null,"children":[{"tag":"num","attrib":{"value":"45d"},"text":"§ 45d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive privileges within park prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No exclusive privilege shall be granted within said park, or on or over the roads and trails therein, except upon ground leased for the erection of buildings or camps thereon.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76f33cf5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-07-03/ch744/s4"},"text":"July 3, 1926, ch. 744, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/820"},"text":"44 Stat. 820","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
