{"tag":"section","attrib":{"id":"id7875980f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s677"},"text":null,"children":[{"tag":"num","attrib":{"value":"677"},"text":"§ 677.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclosure of Norbeck Wildlife Preserve","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The State of South Dakota is authorized and permitted to erect and maintain a good substantial fence, inclosing in whole or in part Norbeck Wildlife Preserve. The State shall erect and maintain such gates in this fence as may be required by the authorized agents of the Federal Government in administering this wildlife preserve and the adjoining national forest lands, and may erect and maintain such additional inclosures as may be agreed upon with the Secretary of Agriculture. The right of the State to maintain this fence shall continue so long as Norbeck Wildlife Preserve is also given similar protection by the laws of the State of South Dakota.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78759810-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-05/ch247/s4"},"text":"June 5, 1920, ch. 247, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/986"},"text":"41 Stat. 986","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-06/ch620/s1"},"text":"Oct. 6, 1949, ch. 620, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/708"},"text":"63 Stat. 708","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78759811-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78759812-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id78759813-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Custer State Park Game Sanctuary” changed to “Norbeck Wildlife Preserve” by act ","children":[{"tag":"date","attrib":{"date":"1949-10-06"},"text":"Oct. 6, 1949","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
