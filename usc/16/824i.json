{"tag":"section","attrib":{"id":"id78ac5f40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i"},"text":null,"children":[{"tag":"num","attrib":{"value":"824i"},"text":"§ 824i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interconnection authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78ac5f41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Commission; application by State regulatory authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78ac5f42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon application of any electric utility, Federal power marketing agency, geothermal power producer (including a producer which is not an electric utility), qualifying cogenerator, or qualifying small power producer, the Commission may issue an order requiring—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78ac5f43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the physical connection of any cogeneration facility, any small power production facility, or the transmission facilities of any electric utility, with the facilities of such applicant,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78ac5f44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such action as may be necessary to make effective any physical connection described in subparagraph (A), which physical connection is ineffective for any reason, such as inadequate size, poor maintenance, or physical unreliability,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78ac5f45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sale or exchange of electric energy or other coordination, as may be necessary to carry out the purposes of any order under subparagraph (A) or (B), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78ac5f46-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such increase in transmission capacity as may be necessary to carry out the purposes of any order under subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ac5f47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any State regulatory authority may apply to the Commission for an order for any action referred to in subparagraph (A), (B), (C), or (D) of paragraph (1). No such order may be issued by the Commission with respect to a Federal power marketing agency upon application of a State regulatory authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ac5f48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice, hearing and determination by Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon receipt of an application under subsection (a), the Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78ac5f49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue notice to each affected State regulatory authority, each affected electric utility, each affected Federal power marketing agency, each affected owner or operator of a cogeneration facility or of a small power production facility, and to the public.","children":[{"tag":"ref","attrib":{"idref":"fn002535"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002535"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a comma."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ac5f4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" afford an opportunity for an evidentiary hearing, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ac5f4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a determination with respect to the matters referred to in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ac5f4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Necessary findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No order may be issued by the Commission under subsection (a) unless the Commission determines that such order—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78ac5f4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the public interest,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ac5f4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78ac5f4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage overall conservation of energy or capital,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78ac5f50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" optimize the efficiency of use of facilities and resources, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78ac5f51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the reliability of any electric utility system or Federal power marketing agency to which the order applies, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ac5f52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s824k"},"text":"section 824k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ac5f53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motion of Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may, on its own motion, after compliance with the requirements of paragraphs (1) and (2) of subsection (b), issue an order requiring any action described in subsection (a)(1) if the Commission determines that such order meets the requirements of subsection (c). No such order may be issued upon the Commission’s own motion with respect to a Federal power marketing agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ac5f54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78ac5f55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this section, the term “facilities” means only facilities used for the generation or transmission of electric energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ac5f56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824i/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to an order issued pursuant to an application of a qualifying cogenerator or qualifying small power producer under subsection (a)(1), the term “facilities of such applicant” means the qualifying cogeneration facilities or qualifying small power production facilities of the applicant, as specified in the application. With respect to an order issued pursuant to an application under subsection (a)(2), the term “facilities of such applicant” means the qualifying cogeneration facilities, qualifying small power production facilities, or the transmission facilities of an electric utility, as specified in the application. With respect to an order issued by the Commission on its own motion under subsection (d), such term means the qualifying cogeneration facilities, qualifying small power production facilities, or the transmission facilities of an electric utility, as specified in the proposed order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78ac5f57-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"June 10, 1920, ch. 285","children":[],"tail":", pt. II, § 210, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/617/tII/s202"},"text":"Pub. L. 95–617, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3135"},"text":"92 Stat. 3135","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/294/tVI/s643/a/2"},"text":"Pub. L. 96–294, title VI, § 643(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/770"},"text":"94 Stat. 770","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78ac5f58-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78ac5f59-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78ac5f5a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294"},"text":"Pub. L. 96–294","children":[],"tail":" added applicability to geothermal power producers."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78ac5f5b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78ac5f5c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study and Report to Congressional Committees on Application of Provisions Relating to Cogeneration, Small Power Production, and Interconnection Authority to Hydroelectric Power Facilities","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions requiring the Federal Energy Regulatory Commission to conduct a study and report to Congress on whether the benefits of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s824a–3"},"text":"section 824a–3 of this title","children":[],"tail":" should be applied to hydroelectric power facilities utilizing new dams or diversions, within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s824a–3/k"},"text":"section 824a–3(k) of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/495/s8/d"},"text":"section 8(d) of Pub. L. 99–495","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s824a–3"},"text":"section 824a–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
