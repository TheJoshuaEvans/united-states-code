{"tag":"section","attrib":{"id":"id796d8b95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1826f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1826f"},"text":"§ 1826f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall determine in writing prior to the signing or provisional application by the United States of any international agreement with respect to the conservation and management of living marine resources or the use of the high seas by fishing vessels that the prohibition contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1826d"},"text":"section 1826d of this title","children":[],"tail":" will not be violated if such agreement is signed or provisionally applied."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id796d8b96-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tVI/s605"},"text":"Pub. L. 104–43, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/392"},"text":"109 Stat. 392","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id796d8b97-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id796d8b98-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id796d8b99-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the High Seas Driftnet Fishing Moratorium Protection Act, and also as part of the Fisheries Act of 1995, and not as part of the Magnuson-Stevens Fishery Conservation and Management Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
