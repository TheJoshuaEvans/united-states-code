{"tag":"section","attrib":{"id":"id773612dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s397a"},"text":null,"children":[{"tag":"num","attrib":{"value":"397a"},"text":"§ 397a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; notice in Federal Register","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon the vesting of title in the United States to such lands as may be designated by the Secretary of the Interior as necessary and suitable for historical park purposes in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s397"},"text":"section 397 of this title","children":[],"tail":", the Puʻuhonua o Ho̅naunau National Historical Park shall be established by order of the said Secretary, which shall be published in the Federal Register. Any other lands within the area described above shall become a part of the national historical park upon the vesting of title thereto in the United States and upon publication of an appropriate supplemental order by the said Secretary in the Federal Register."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id773612de-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-26/ch385/s2"},"text":"July 26, 1955, ch. 385, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/379"},"text":"69 Stat. 379","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tIII/s305"},"text":"Pub. L. 95–625, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3477"},"text":"92 Stat. 3477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/510/s3/d/1"},"text":"Pub. L. 106–510, § 3(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2364"},"text":"114 Stat. 2364","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id773612df-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id773612e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id773612e1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/510"},"text":"Pub. L. 106–510","children":[],"tail":" substituted “Puʻuhonua o Ho̅naunau National Historical Park” for “Puuhonua o Honaunau National Historical Park”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Pub. L. 95–625","children":[],"tail":" redesignated as “Puuhonua o Honaunau National Historical Park” the park previously designated “City of Refuge National Historical Park”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
