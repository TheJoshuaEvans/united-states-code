{"tag":"section","attrib":{"id":"id79fef72e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5508"},"text":null,"children":[{"tag":"num","attrib":{"value":"5508"},"text":"§ 5508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal offenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79fef72f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person is guilty of an offense if the person commits any act prohibited by paragraph (6), (7), (8), or (9) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5505"},"text":"section 5505 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fef730-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Punishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any offense described in subsection (a) is a class A misdemeanor punishable by a fine under title 18, or imprisonment for not more than one year, or both; except that if in the commission of any offense the person uses a dangerous weapon, engages in conduct that causes bodily injury to any authorized officer, or places any such officer in fear of imminent bodily injury, the offense is a felony punishable by a fine under title 18, or imprisonment for not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fef731-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tI/s109"},"text":"Pub. L. 104–43, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/375"},"text":"109 Stat. 375","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fef732-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79fef733-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79fef734-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 120 days after ","children":[{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/43/s111"},"text":"section 111 of Pub. L. 104–43","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s5501"},"text":"section 5501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
