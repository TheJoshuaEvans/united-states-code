{"tag":"section","attrib":{"id":"id778719cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s422a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"422a–1"},"text":"§ 422a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized, in his discretion, to acquire by donation, purchase, or exchange lands, buildings, structures, and other property, or interests therein, which he may determine to be of historical interest in connection with the Moores Creek National Battlefield, the title to such property or interests to be satisfactory to the Secretary of the Interior: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the area acquired pursuant to this section shall not exceed one hundred acres. All such property and interests, upon acquisition by the Federal Government, shall be a part of the Moores Creek National Battlefield and shall be subject to all laws and regulations applicable thereto."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778719ce-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-09-27/ch417/s1"},"text":"Sept. 27, 1944, ch. 417, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/746"},"text":"58 Stat. 746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/477/tIV/s402"},"text":"Pub. L. 93–477, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-26"},"text":"Oct. 26, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1447"},"text":"88 Stat. 1447","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/344/s12"},"text":"Pub. L. 96–344, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1136"},"text":"94 Stat. 1136","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778719cf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id778719d0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id778719d1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/477"},"text":"Pub. L. 93–477","children":[],"tail":" substituted “acquire by donation, purchase, or exchange” for “accept in behalf of the United States donations of”, and “acquired” for “to be accepted”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id778719d2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id778719d3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Battlefield” substituted in text for “Military Park” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/344/s12"},"text":"Pub. L. 96–344, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1136"},"text":"94 Stat. 1136","children":[],"tail":", which redesignated Moores Creek National Military Park as Moores Creek National Battlefield."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
