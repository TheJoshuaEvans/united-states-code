{"tag":"section","attrib":{"id":"id7727ba70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s283e"},"text":null,"children":[{"tag":"num","attrib":{"value":"283e"},"text":"§ 283e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; expenditure for improvements limitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7727ba71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s283e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are hereby authorized to be appropriated such sums as may be necessary for the acquisition of lands and interest in lands, and not more than $24,715,000 as may be necessary for the development of the Guadalupe Mountains National Park. No funds appropriated for development purposes pursuant to this subchapter may be expended for improvements incompatible with wilderness management within the corridor of the park leading to the summit of Guadalupe Peak.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7727ba72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s283e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to amounts authorized to be appropriated under subsection (a), there is authorized to be appropriated such sums as may be necessary for the construction of a fence to protect the natural and cultural resources of the area added to Guadalupe Mountains National Park by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s283a/b"},"text":"section 283a(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7727ba73-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/667/s6"},"text":"Pub. L. 89–667, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/922"},"text":"80 Stat. 922","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tI/s101/12"},"text":"Pub. L. 95–625, title I, § 101(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3471"},"text":"92 Stat. 3471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/541/s2"},"text":"Pub. L. 100–541, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-28"},"text":"Oct. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2720"},"text":"102 Stat. 2720","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7727ba74-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7727ba75-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7727ba76-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/541"},"text":"Pub. L. 100–541","children":[],"tail":" designated existing provisions as subsec. (a), substituted “sums” for “sums, but not more than $1,800,000 in all,”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Pub. L. 95–625","children":[],"tail":" increased development appropriations authorization to $24,715,000 from $10,362,000 and prohibited expenditure of funds for improvements incompatible with wilderness management within the corridor of the park leading to the summit of Guadalupe Peak."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
