{"tag":"section","attrib":{"id":"id77aacd34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459b–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"459b–7"},"text":"§ 459b–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cape Cod National Seashore Advisory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77aacd35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459b–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a Cape Cod National Seashore Advisory Commission (hereinafter referred to as the “Commission”). The Commission shall terminate ","children":[{"tag":"date","attrib":{"date":"2029-09-26"},"text":"September 26, 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77aacd36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459b–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership; term","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall be composed of ten members each appointed for a term of two years by the Secretary as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77aacd37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459b–7/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Six members to be appointed from recommendations made by each of the boards of selectmen of the towns referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s459b"},"text":"section 459b of this title","children":[],"tail":", one member from the recommendations made by each such board;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77aacd38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459b–7/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member to be appointed from recommendations of the county commissioners of Barnstable County, Commonwealth of Massachusetts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77aacd39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459b–7/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members to be appointed from recommendations of the Governor of the Commonwealth of Massachusetts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77aacd3a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459b–7/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member to be designated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77aacd3b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459b–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman; vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate one member to be Chairman. Any vacancy in the Commission shall be filled in the same manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77aacd3c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459b–7/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Commission shall serve without compensation as such. The Secretary is authorized to pay the expenses reasonably incurred by the Commission in carrying out its responsibilities under sections 459b to 459b–8 of this title upon vouchers signed by the Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77aacd3d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459b–7/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Majority vote","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission established by this section shall act and advise by affirmative vote of a majority of the members thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77aacd3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459b–7/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation of Secretary with Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or his designee shall, from time to time, consult with the members of the Commission with respect to matters relating to the development of Cape Cod National Seashore and shall consult with the members with respect to carrying out the provisions of sections 459b–3 and 459b–4 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77aacd3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459b–7/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from other provisions of law","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77aacd40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459b–7/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any member of the Advisory Commission appointed under sections 459b to 459b–8 of this title shall be exempted, with respect to such appointment, from the operation of sections 281, 283, 284, and 1914 of title 18 and section 190 of the Revised Statutes (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s99"},"text":"5 U.S.C. 99","children":[],"tail":") "},{"tag":"ref","attrib":{"idref":"fn002277"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002277"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" except as otherwise specified in paragraph (2) of this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77aacd41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459b–7/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The exemption granted by paragraph (1) of this subsection shall not extend—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77aacd42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459b–7/g/2/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the receipt or payment of salary in connection with the appointee’s Government service from any sources other than the private employer of the appointee at the time of his appointment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77aacd43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459b–7/g/2/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the period of such appointment, and the further period of two years after the termination thereof, to the prosecution or participation in the prosecution, by any person so appointed, of any claim against the Government involving any matter concerning which the appointee had any responsibility arising out of his appointment during the period of such appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77aacd44-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/126/s8"},"text":"Pub. L. 87–126, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-07"},"text":"Aug. 7, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/292"},"text":"75 Stat. 292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/420/tII/s201"},"text":"Pub. L. 99–420, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-09-25"},"text":"Sept. 25, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/960"},"text":"100 Stat. 960","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/280/s1/b"},"text":"Pub. L. 105–280, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-26"},"text":"Oct. 26, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2694"},"text":"112 Stat. 2694","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7402"},"text":"Pub. L. 111–11, title VII, § 7402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1219"},"text":"123 Stat. 1219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tVI/s613"},"text":"Pub. L. 117–328, div. DD, title VI, § 613","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5604"},"text":"136 Stat. 5604","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77aacd45-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77aacd46-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77aacd47-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 281, 283, 284, and 1914 of title 18, referred to in subsec. (g)(1), were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/849/s2"},"text":"Pub. L. 87–849, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1126"},"text":"76 Stat. 1126","children":[],"tail":", “except as they [sections 281 and 283] may apply to retired officers of the armed forces of the United States”, and were supplanted by sections 203, 205, 207, and 209, respectively, of Title 18, Crimes and Criminal Procedure. For further details, see Exemptions note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s203"},"text":"section 203 of Title 18","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 190 of the Revised Statutes (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s99"},"text":"5 U.S.C. 99","children":[],"tail":"), referred to in subsec. (g)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/87/849/s3"},"text":"Pub. L. 87–849, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1126"},"text":"76 Stat. 1126","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s207"},"text":"section 207 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77aacd48-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s613/1"},"text":"Pub. L. 117–328, § 613(1)","children":[],"tail":", substituted “2029” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s613/2"},"text":"Pub. L. 117–328, § 613(2)","children":[],"tail":", (3), redesignated subsec. (h) as (g) and struck out former subsec. (g). Prior to amendment, text of subsec. (g) read as follows: “No permit for the commercial or industrial use of property located within the seashore shall be issued by the Secretary, nor shall any public use area for recreational activity be established by the Secretary within the seashore, without the advice of the Commission, if such advice is submitted within a reasonable time after it is sought.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":" substituted “2018” for “2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/280"},"text":"Pub. L. 105–280","children":[],"tail":" substituted “The Commission shall terminate "},{"tag":"date","attrib":{"date":"2008-09-26"},"text":"September 26, 2008","children":[],"tail":".” for “Said Commission shall terminate 30 years after the date the seashore is established under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s459b–2"},"text":"section 459b–2 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/420"},"text":"Pub. L. 99–420","children":[],"tail":" substituted “30 years” for “ten years”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77aacd49-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77aacd4a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tVI/s613"},"text":"Pub. L. 117–328, div. DD, title VI, § 613","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5604"},"text":"136 Stat. 5604","children":[],"tail":", provided that the amendment made by section 613 is effective "},{"tag":"date","attrib":{"date":"2018-09-26"},"text":"Sept. 26, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77aacd4b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7402"},"text":"Pub. L. 111–11, title VII, § 7402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1219"},"text":"123 Stat. 1219","children":[],"tail":", provided that the amendment made by section 7402 is effective "},{"tag":"date","attrib":{"date":"2008-09-26"},"text":"Sept. 26, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77aacd4c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reestablishment and Extension of Commission","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/349/tI"},"text":"Pub. L. 99–349, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-07-02"},"text":"July 2, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/731"},"text":"100 Stat. 731","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/349/tI"},"text":"“That the Cape Cod National Seashore Advisory Commission established under ","children":[{"tag":"ref","attrib":{"href":"/us/act/1961-08-07/s8/a"},"text":"section 8(a) of the Act of August 7, 1961","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/87/126"},"text":"Public Law 87–126","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/75/292"},"text":"75 Stat. 292","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s459b–7/a"},"text":"16 U.S.C. 459b–7(a)","children":[],"tail":"] is reestablished and extended through "},{"tag":"date","attrib":{"date":"1996-02-28"},"text":"February 28, 1996","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
