{"tag":"section","attrib":{"id":"id7797ba89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430rr"},"text":null,"children":[{"tag":"num","attrib":{"value":"430rr"},"text":"§ 430rr.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change in name to Fort Necessity National Battlefield","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Fort Necessity National Battlefield site is redesignated as the Fort Necessity National Battlefield and any remaining balance of funds appropriated for the purposes of the site shall be available for the purposes of the Fort Necessity National Battlefield.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7797ba8a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/134/s3"},"text":"Pub. L. 87–134, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-10"},"text":"Aug. 10, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/336"},"text":"75 Stat. 336","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
