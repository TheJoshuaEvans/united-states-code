{"tag":"section","attrib":{"id":"id79f581e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730"},"text":null,"children":[{"tag":"num","attrib":{"value":"4730"},"text":"§ 4730.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes and Lake Champlain Invasive Species Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f581e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f581e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aquatic nuisance species","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “aquatic nuisance species” has the meaning given that term in subsection (p)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1322"},"text":"section 1322 of title 33","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Great Lakes National Program Office established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1268/b"},"text":"section 1268(b) of title 33","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes and Lake Champlain Systems","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Great Lakes and Lake Champlain Systems” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f581e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lake Champlain; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" all bodies of water (including wetlands) within—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79f581e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/1/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Great Lakes System (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1268/a/3"},"text":"section 1268(a)(3) of title 33","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79f581ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/1/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Lake Champlain drainage basin (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1270/g"},"text":"section 1270(g) of title 33","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the Great Lakes and Lake Champlain Invasive Species Program established under paragraph (2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f581ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f581ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall establish within the Great Lakes National Program Office a program, to be known as the “Great Lakes and Lake Champlain Invasive Species Program”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f581ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in collaboration with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79f581ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the United States Fish and Wildlife Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79f581f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the National Oceanic and Atmospheric Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79f581f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the United States Geological Survey; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79f581f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the department in which the Coast Guard is operating; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in consultation with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79f581f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of Great Lakes Aquatic Nonindigenous Species Information System of the National Oceanic and Atmospheric Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79f581f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of Great Lakes Environmental Research Laboratory of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Program shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f581f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to monitor for the introduction and spread of aquatic nuisance species into or within the Great Lakes and Lake Champlain Systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to detect newly introduced aquatic nuisance species prior to the establishment of the aquatic nuisance species in the Great Lakes and Lake Champlain Systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to inform, and assist with, management and response actions to prevent or stop the establishment or spread of an aquatic nuisance species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a watch list of candidate aquatic nuisance species that may be introduced or spread, and that may survive and establish, within the Great Lakes and Lake Champlain Systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to monitor vectors likely to be contributing to the introduction or spread of aquatic nuisance species, including ballast water operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to work collaboratively with the Federal, State, local, and Tribal agencies to develop criteria for prioritizing and distributing monitoring efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop, achieve type approval for, and pilot shipboard or land-based ballast water management systems installed on, or available for use by, commercial vessels operating solely within the Great Lakes and Lake Champlain Systems to prevent the spread of aquatic nuisance species populations within the Great Lakes and Lake Champlain Systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate meaningful Federal and State implementation of the regulatory framework in this section, including monitoring, shipboard education, inspection, and compliance conducted by States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f581ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methodology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Program shall seek—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f58200-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to build on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f58201-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing aquatic nuisance species monitoring efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f58202-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to develop criteria for prioritizing and distributing monitoring efforts, geographically and among taxa, in the Great Lakes and Lake Champlain Systems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f58203-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advance early detection and monitoring, and capacity to control the establishment and spread, of aquatic nuisance species within the Great Lakes and Lake Champlain Systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f58204-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify opportunities to interdict the introduction and spread of aquatic nuisance species through sound science and technological advancements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f58205-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assess the risk of aquatic nuisance species introduction and spread via the range of vectors active within the Great Lakes and Lake Champlain Systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f58206-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advance the development of type-approved ballast water management system (as defined in subsection (p)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1322"},"text":"section 1322 of title 33","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002799"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002799"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a closing parenthesis."}],"tail":" equipment for commercial, non-seagoing vessels that operate solely within the Great Lakes System (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1268/a/3"},"text":"section 1268(a)(3) of title 33","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f58207-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to immediately make available to the public information regarding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f58208-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/3/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the detection of new aquatic nuisance species within the Great Lakes and Lake Champlain Systems; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f58209-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/3/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the spread of aquatic nuisance species within the Great Lakes and Lake Champlain Systems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f5820a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to annually submit to appropriate individuals and entities in each affected region a report describing the findings and activities of the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f5820b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify roles and responsibilities of Federal agencies in aquatic nuisance species monitoring and response; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f5820c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide resource assistance to States implementing State-level programs to enter into partnerships with Federal agencies in enforcing the requirements under subsection (p) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1322"},"text":"section 1322 of title 33","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f5820d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out and developing the Program, the Director shall collaborate with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f5820e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable Federal, State, local, and Tribal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f5820f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other research entities or stakeholders as the Director determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f58210-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f58211-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the data collected under the Program available on a publicly accessible internet website, including in an annual summary report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f58212-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in coordination with the entities identified under paragraph (4), develop communication and notification protocols for the purpose of communicating the range of aquatic nuisance species and any identification of a new aquatic nuisance species introduced to the Great Lakes and Lake Champlain Systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f58213-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f58214-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2019-12-31"},"text":"December 31, 2019","children":[],"tail":", the Director shall submit to Congress a report summarizing the outcomes of activities carried out under the Program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f58215-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under subparagraph (A) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f58216-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of activities carried out under the Program, including an explanation of how those activities help to achieve the purposes described in paragraph (2)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f58217-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of Federal, State, and local efforts to enhance multidisciplinary approaches to achieve the purposes described in paragraph (2)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f58218-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations relating to activities that would contribute to achievement of the purposes described in paragraph (2)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f58219-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/6/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations to improve the efficiency and effectiveness of the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4730/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out the Program $50,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f7cb0b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIX/s903/g"},"text":"Pub. L. 115–282, title IX, § 903(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4359"},"text":"132 Stat. 4359","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f7cb0c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f7cb0d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79f7cb0e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Vessel Incidental Discharge Act of 2018 and also as part of the Frank LoBiondo Coast Guard Authorization Act of 2018, and not as part of the Nonindigenous Aquatic Nuisance Prevention and Control Act of 1990 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsec. (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s903"},"text":"section 903 of Pub. L. 115–282","children":[],"tail":". For classification to the Code of other provisions of section 903, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
