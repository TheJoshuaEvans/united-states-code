{"tag":"section","attrib":{"id":"id79fef691-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502"},"text":null,"children":[{"tag":"num","attrib":{"value":"5502"},"text":"§ 5502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fef692-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Agreement” means the Agreement to Promote Compliance with International Conservation and Management Measures by Fishing Vessels on the High Seas, adopted by the Conference of the Food and Agriculture Organization of the United Nations on ","children":[{"tag":"date","attrib":{"date":"1993-11-24"},"text":"November 24, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef693-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “FAO” means the Food and Agriculture Organization of the United Nations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef694-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “high seas” means the waters beyond the territorial sea or exclusive economic zone (or the equivalent) of any nation, to the extent that such territorial sea or exclusive economic zone (or the equivalent) is recognized by the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef695-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “high seas fishing vessel” means any vessel of the United States or subject to the jurisdiction of the United States used or intended for use—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79fef696-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the high seas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fef697-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purpose of the commercial exploitation of living marine resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fef698-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a harvesting vessel, as a mother ship, or as any other support vessel directly engaged in a fishing operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef699-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “international conservation and management measures” means measures to conserve or manage one or more species of living marine resources that are adopted and applied in accordance with the relevant rules of international law, as reflected in the 1982 United Nations Convention on the Law of the Sea, and that are recognized by the United States. Such measures may be adopted by global, regional, or sub-regional fisheries organizations, subject to the rights and obligations of their members, or by treaties or other international agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef69a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “length” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79fef69b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any high seas fishing vessel built after ","children":[{"tag":"date","attrib":{"date":"1982-07-18"},"text":"July 18, 1982","children":[],"tail":", 96 percent of the total length on a waterline at 85 percent of the least molded depth measured from the top of the keel, or the length from the foreside of the stem to the axis of the rudder stock on that waterline, if that is greater, except that in ships designed with a rake of keel the waterline on which this length is measured shall be parallel to the designed waterline; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fef69c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any high seas fishing vessel built before ","children":[{"tag":"date","attrib":{"date":"1982-07-18"},"text":"July 18, 1982","children":[],"tail":", registered length as entered on the vessel’s documentation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef69d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” means any individual (whether or not a citizen or national of the United States), any corporation, partnership, association, or other entity (whether or not organized or existing under the laws of any State), and any Federal, State, local, or foreign government or any entity of any such government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef69e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef69f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “vessel of the United States” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79fef6a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel documented under chapter 121 of title 46 or numbered in accordance with chapter 123 of title 46;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fef6a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a vessel owned in whole or part by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79fef6a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States or a territory, commonwealth, or possession of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79fef6a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or political subdivision thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79fef6a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/9/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a citizen or national of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79fef6a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/9/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation created under the laws of the United States or any State, the District of Columbia, or any territory, commonwealth, or possession of the United States; unless the vessel has been granted the nationality of a foreign nation in accordance with article 92 of the 1982 United Nations Convention on the Law of the Sea and a claim of nationality or registry for the vessel is made by the master or individual in charge at the time of the enforcement action by an officer or employee of the United States authorized to enforce applicable provisions of the United States law; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fef6a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel that was once documented under the laws of the United States and, in violation of the laws of the United States, was either sold to a person not a citizen of the United States or placed under foreign registry or a foreign flag, whether or not the vessel has been granted the nationality of a foreign nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5502/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “vessel subject to the jurisdiction of the United States” and “vessel without nationality” have the same meaning as in subsections (c) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70502"},"text":"section 70502 of title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fef6a8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tI/s103"},"text":"Pub. L. 104–43, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/367"},"text":"109 Stat. 367","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/562/tIII/s305"},"text":"Pub. L. 106–562, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2807"},"text":"114 Stat. 2807","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fef6a9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79fef6aa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79fef6ab-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, and was translated as reading “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43"},"text":"Pub. L. 104–43","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79fef6ac-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In par. (10), “subsections (c) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70502"},"text":"section 70502 of title 46","children":[],"tail":"” substituted for “section 3(c) of the Maritime Drug Law Enforcement Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t46/s1903/c"},"text":"46 U.S.C. 1903(c)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/c"},"text":"Pub. L. 109–304, § 18(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1709"},"text":"120 Stat. 1709","children":[],"tail":", which Act enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s70502"},"text":"section 70502 of Title 46","children":[],"tail":", Shipping."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79fef6ad-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562"},"text":"Pub. L. 106–562","children":[],"tail":" inserted “or subject to the jurisdiction of the United States” after “United States” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79fef6ae-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79fef6af-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 120 days after ","children":[{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/43/s111"},"text":"section 111 of Pub. L. 104–43","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s5501"},"text":"section 5501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
