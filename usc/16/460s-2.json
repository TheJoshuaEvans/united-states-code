{"tag":"section","attrib":{"id":"id77c9ee25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460s–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"460s–2"},"text":"§ 460s–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; notice in Federal Register","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"1966-10-15"},"text":"October 15, 1966","children":[],"tail":", and following the acquisition by the Secretary of an acreage within the boundaries of the area which in his opinion is efficiently administrable for the purposes of this subchapter, he shall establish the Pictured Rocks National Lakeshore by publication of notice thereof in the Federal Register."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77c9ee26-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/668/s3"},"text":"Pub. L. 89–668, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/922"},"text":"80 Stat. 922","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
