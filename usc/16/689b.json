{"tag":"section","attrib":{"id":"id78759860-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s689b"},"text":null,"children":[{"tag":"num","attrib":{"value":"689b"},"text":"§ 689b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting, pursuing, capturing in Tahquitz National Game Preserve unlawful","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On lands within the game preserve established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s689a"},"text":"section 689a of this title","children":[],"tail":", hunting, pursuing, poisoning, killing, or capturing by trapping, netting, or any other means, or attempting to hunt, pursue, kill, or capture any wild animals or birds for any purpose whatever upon the lands of the United States within the limits of said game preserve shall be unlawful except as hereinafter provided."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78759861-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-07-03/ch776/s3"},"text":"July 3, 1926, ch. 776, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/889"},"text":"44 Stat. 889","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645/s14"},"text":"June 25, 1948, ch. 645, § 14","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/861"},"text":"62 Stat. 861","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78759862-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78759863-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78759864-6992