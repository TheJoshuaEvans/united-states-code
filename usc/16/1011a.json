{"tag":"section","attrib":{"id":"id78e34d4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1011a"},"text":"§ 1011a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Watershed agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78e34d50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Watershed restoration and enhancement agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For fiscal year 2006 and each fiscal year thereafter, to the extent funds are otherwise available, appropriations for the Forest Service may be used by the Secretary of Agriculture for the purpose of entering into cooperative agreements with willing Federal, tribal, State and local governments, private and nonprofit entities and landowners for the protection, restoration and enhancement of fish and wildlife habitat, and other resources on public or private land, the reduction of risk from natural disaster where public safety is threatened, or a combination thereof or both that benefit these resources within the watershed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e34d51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct and indirect watershed agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture may enter into a watershed restoration and enhancement agreement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e34d52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly with a willing private landowner; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34d53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indirectly through an agreement with a State, local or tribal government or other public entity, educational institution, or private nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e34d54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order for the Secretary to enter into a watershed restoration and enhancement agreement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e34d55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the agreement shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78e34d56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include such terms and conditions mutually agreed to by the Secretary and the landowner, state ","children":[{"tag":"ref","attrib":{"idref":"fn002570"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002570"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" or local government, or private or nonprofit entity;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34d57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the viability of and otherwise benefit the fish, wildlife, and other resources on national forests lands within the watershed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34d58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize the provision of technical assistance by the Secretary in the planning of management activities that will further the purposes of the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34d59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the sharing of costs of implementing the agreement among the Federal Government, the landowner(s), and other entities, as mutually agreed on by the affected interests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34d5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that any expenditure by the Secretary pursuant to the agreement is determined by the Secretary to be in the public interest; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34d5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may require such other terms and conditions as are necessary to protect the public investment on non-Federal lands, provided such terms and conditions are mutually agreed to by the Secretary and other landowners, State and local governments or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e34d5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Chapter 63 of title 31 shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e34d5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a watershed restoration and enhancement agreement entered into under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34d5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s565a–1"},"text":"section 565a–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e34d5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1999-12-31"},"text":"December 31, 1999","children":[],"tail":", the Secretary shall submit a report to the Committees on Appropriations of the House and Senate, which contains—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e34d60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A ","children":[{"tag":"ref","attrib":{"idref":"fn002571"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002571"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" concise description of each project, including the project purpose, location on federal "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and non-federal "},{"tag":"ref","attrib":{"idref":"fn002572"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002572"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “non-Federal”."}],"tail":" land, key activities, and all parties to the agreement."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34d61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1011a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding and/or other contributions provided by each party for each project agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78e34d62-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tIII/s323"},"text":"Pub. L. 105–277, div. A, § 101(e) [title III, § 323]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–290; "},{"tag":"ref","attrib":{"href":"/us/pl/107/63/tIII/s330"},"text":"Pub. L. 107–63, title III, § 330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-05"},"text":"Nov. 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/471"},"text":"115 Stat. 471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/54/tIV/s434"},"text":"Pub. L. 109–54, title IV, § 434","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/557"},"text":"119 Stat. 557","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIII/s3001"},"text":"Pub. L. 111–11, title III, § 3001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1126"},"text":"123 Stat. 1126","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78e34d63-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78e34d64-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78e34d65-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1011"},"text":"section 1011 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of the Interior and Related Agencies Appropriations Act, 1999, and also as part of the Omnibus Consolidated and Emergency Supplemental Appropriations Act, 1999, and not as part of the Watershed Protection and Flood Prevention Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78e34d66-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s3001/1"},"text":"Pub. L. 111–11, § 3001(1)","children":[],"tail":", substituted “fiscal year 2006 and each fiscal year thereafter” for “each of fiscal years 2006 through 2011”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s3001/2"},"text":"Pub. L. 111–11, § 3001(2)","children":[],"tail":", (3), added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/54"},"text":"Pub. L. 109–54","children":[],"tail":" substituted “each of fiscal years 2006 through 2011” for “fiscal year 1999, 2000 and 2001, and fiscal years 2002 through 2005”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/63"},"text":"Pub. L. 107–63","children":[],"tail":" inserted “and fiscal years 2002 through 2005,” before “to the extent funds are otherwise available”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78e34d67-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"similarProvisions","id":"id78e34d68-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Similar Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/83/tIII/s334"},"text":"Pub. L. 105–83, title III, § 334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-14"},"text":"Nov. 14, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1601"},"text":"111 Stat. 1601","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
