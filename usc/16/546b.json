{"tag":"section","attrib":{"id":"id78411a47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b"},"text":null,"children":[{"tag":"num","attrib":{"value":"546b"},"text":"§ 546b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seng Mountain and Bear Creek Scenic Areas, Jefferson National Forest, Virginia","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78411a48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are designated as National Scenic Areas—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78411a49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certain National Forest System land in the Jefferson National Forest, comprising approximately 5,192 acres, as generally depicted on the map entitled “Seng Mountain and Raccoon Branch” and dated ","children":[{"tag":"date","attrib":{"date":"2008-04-28"},"text":"April 28, 2008","children":[],"tail":", which shall be known as the “Seng Mountain National Scenic Area”; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certain National Forest System land in the Jefferson National Forest, comprising approximately 5,128 acres, as generally depicted on the map entitled “Bear Creek” and dated ","children":[{"tag":"date","attrib":{"date":"2008-04-28"},"text":"April 28, 2008","children":[],"tail":", which shall be known as the “Bear Creek National Scenic Area”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the scenic areas are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78411a4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure the protection and preservation of scenic quality, water quality, natural characteristics, and water resources of the scenic areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with paragraph (1), to protect wildlife and fish habitat in the scenic areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect areas in the scenic areas that may develop characteristics of old-growth forests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with paragraphs (1), (2), and (3), to provide a variety of recreation opportunities in the scenic areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78411a51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall administer the scenic areas in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78411a52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this subtitle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78411a53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the laws (including regulations) generally applicable to the National Forest System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall only allow uses of the scenic areas that the Secretary determines will further the purposes of the scenic areas, as described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78411a56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", the Secretary shall develop as an amendment to the land and resource management plan for the Jefferson National Forest a management plan for the scenic areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection requires the Secretary to revise the land and resource management plan for the Jefferson National Forest under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1604"},"text":"section 1604 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Roads","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78411a59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", no roads shall be established or constructed within the scenic areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection denies any owner of private land (or an interest in private land) that is located in a scenic area the right to access the private land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timber harvest","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78411a5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraphs (2) and (3), no harvesting of timber shall be allowed within the scenic areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may authorize harvesting of timber in the scenic areas if the Secretary determines that the harvesting is necessary to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78411a5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control fire;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78411a5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for public safety or trail access; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78411a60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control insect and disease outbreaks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Firewood for personal use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Firewood may be harvested for personal use along perimeter roads in the scenic areas, subject to any conditions that the Secretary may impose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insect and disease outbreaks","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may control insect and disease outbreaks—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78411a63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain scenic quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent tree mortality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce hazards to visitors; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect private land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vegetation management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may engage in vegetation manipulation practices in the scenic areas to maintain the visual quality and wildlife clearings in existence on ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motorized vehicles","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78411a69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), motorized vehicles shall not be allowed within the scenic areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may authorize the use of motorized vehicles—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78411a6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out administrative activities that further the purposes of the scenic areas, as described in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78411a6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist wildlife management projects in existence on ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78411a6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/i/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" during deer and bear hunting seasons—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78411a6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/i/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on Forest Development Roads 49410 and 84b; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78411a6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/i/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the portion of Forest Development Road 6261 designated on the map described in subsection (a)(2) as “open seasonally”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildfire suppression","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Wildfire suppression within the scenic areas shall be conducted—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78411a71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner consistent with the purposes of the scenic areas, as described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using such means as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer the scenic areas in a manner that maintains and enhances water quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, all Federal land in the scenic areas is withdrawn from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78411a75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation of the mineral leasing and geothermal leasing laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78411a77-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tI/s1104"},"text":"Pub. L. 111–11, title I, § 1104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1004"},"text":"123 Stat. 1004","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78411a78-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78411a79-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78411a7a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subtitle, referred to in subsec. (c)(1)(A), is subtitle B (§§ 1101–1107) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1002"},"text":"123 Stat. 1002","children":[],"tail":", which enacted this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s546b–1"},"text":"section 546b–1 of this title","children":[],"tail":", enacted provisions set out as a note below, and enacted and amended provisions listed in a table of Wilderness Areas set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"section 1132 of this title","children":[],"tail":". For complete classification of subtitle B to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78411a7b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id78411a7c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tI/s1101"},"text":"Pub. L. 111–11, title I, § 1101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1002"},"text":"123 Stat. 1002","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/11/tI/s1101"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this subtitle [subtitle B (§§ 1101–1107) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":", enacting this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s546b–1"},"text":"section 546b–1 of this title","children":[],"tail":" and enacting and amending provisions listed in a table of Wilderness Areas set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"section 1132 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scenic areas","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘scenic areas’ means the Seng Mountain National Scenic Area and the Bear Creek National Scenic Area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of Agriculture.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
