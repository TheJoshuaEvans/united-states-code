{"tag":"section","attrib":{"id":"id79b9d78f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451"},"text":null,"children":[{"tag":"num","attrib":{"value":"3451"},"text":"§ 3451.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b9d790-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “area plan” means a resource conservation and use plan developed through a locally led planning process by a council for a designated area of 1 or more States, or of land under the jurisdiction of an Indian tribe, that includes 1 or more of the following elements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b9d791-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A land conservation element, the purpose of which is to control erosion and sedimentation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b9d792-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A water management element that provides 1 or more clear environmental or conservation benefits, the purpose of which is to provide for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79b9d793-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conservation, use, and quality of water, including irrigation and rural water supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d794-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mitigation of floods and high water tables;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d795-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the repair and improvement of reservoirs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d796-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the improvement of agricultural water management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d797-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the improvement of water quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b9d798-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A community development element, the purpose of which is to improve—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79b9d799-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of resources-based industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d79a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of rural industries from natural resource hazards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d79b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of adequate rural water and waste disposal systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d79c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the improvement of recreation facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d79d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the improvement in the quality of rural housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d79e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of adequate health and education facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d79f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the satisfaction of essential transportation and communication needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d7a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the promotion of food security, economic development, and education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b9d7a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A land management element, the purpose of which is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79b9d7a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy conservation, including the production of energy crops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d7a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of agricultural land, as appropriate, from conversion to other uses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d7a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" farmland protection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d7a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of fish and wildlife habitats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the Resource Conservation and Development Policy Advisory Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3456/a"},"text":"section 3456(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “council” means a nonprofit entity (including an affiliate of the entity) operating in a State that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b9d7a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" established by volunteers or representatives of States, local units of government, Indian tribes, or local nonprofit organizations to carry out an area plan in a designated area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b9d7a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designated by the chief executive officer or legislature of the State to receive technical assistance and financial assistance under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “designated area” means a geographic area designated by the Secretary to receive technical assistance and financial assistance under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial assistance” means a grant or loan provided by the Secretary (or the Secretary and other Federal agencies) to, or a cooperative agreement entered into by the Secretary (or the Secretary and other Federal agencies) with, a council, or association of councils, to carry out an area plan in a designated area, including assistance provided for planning, analysis, feasibility studies, training, education, and other activities necessary to carry out the area plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local unit of government","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “local unit of government” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b9d7ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any county, city, town, township, parish, village, or other general-purpose subdivision of a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b9d7af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any local or regional special district or other limited political subdivision of a State, including any soil conservation district, school district, park authority, and water or sanitary district.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Locally led planning process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “planning process” means actions taken by a locally led council to develop and carry out an effective area plan in a designated area, including development of the area plan, goals, purposes, policies, implementation activities, evaluations and reviews, and the opportunity for public participation in the actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “nonprofit organization” means any organization that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b9d7b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c"},"text":"section 501(c) of title 26","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b9d7b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt from taxation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/a"},"text":"section 501(a) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “project” means a project that is carried out by a council to achieve any of the elements of an area plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b9d7b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b9d7b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b9d7b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “technical assistance” means any service provided by the Secretary or agent of the Secretary, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b9d7bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inventorying, evaluating, planning, designing, supervising, laying out, and inspecting projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b9d7bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing maps, reports, and other documents associated with the services provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b9d7bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3451/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provid