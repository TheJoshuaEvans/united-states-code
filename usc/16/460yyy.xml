<?xml version='1.0' encoding='UTF-8'?>
<section xmlns="http://xml.house.gov/schemas/uslm/1.0" style="-uslm-lc:I80" id="id780a532e-6992-11f1-ab3f-8b4c043f8cd5" identifier="/us/usc/t16/s460yyy"><num value="460yyy">§ 460yyy.</num><heading> Definitions</heading>
<chapeau style="-uslm-lc:I11" class="indent0">In this subchapter:</chapeau><paragraph style="-uslm-lc:I79" class="indent3 firstIndent-2" id="id780a532f-6992-11f1-ab3f-8b4c043f8cd5" identifier="/us/usc/t16/s460yyy/1"><num value="1" class="bold">(1)</num><heading class="bold"> Conservation Area</heading><content><p style="-uslm-lc:I12" class="indent1">The term “Conservation Area” means the Fort Stanton-Snowy River Cave National Conservation Area established by <ref href="/us/usc/t16/s460yyy–1/a">section 460yyy–1(a) of this title</ref>.</p>
</content>
</paragraph>
<paragraph style="-uslm-lc:I79" class="indent3 firstIndent-2" id="id780a5330-6992-11f1-ab3f-8b4c043f8cd5" identifier="/us/usc/t16/s460yyy/2"><num value="2" class="bold">(2)</num><heading class="bold"> Management plan</heading><content><p style="-uslm-lc:I12" class="indent1">The term “management plan” means the management plan developed for the Conservation Area under <ref href="/us/usc/t16/s460yyy–2/c">section 460yyy–2(c) of this title</ref>.</p>
</content>
</paragraph>
<paragraph style="-uslm-lc:I79" class="indent3 firstIndent-2" id="id780a5331-6992-11f1-ab3f-8b4c043f8cd5" identifier="/us/usc/t16/s460yyy/3"><num value="3" class="bold">(3)</num><heading class="bold"> Secretary</heading><content><p style="-uslm-lc:I12" class="indent1">The term “Secretary” means the Secretary of the Interior, acting through the Director of the Bureau of Land Management.</p>
</content>
</paragraph>
<sourceCredit id="id780a5332-6992-11f1-ab3f-8b4c043f8cd5">(<ref href="/us/pl/111/11/tII/s2201">Pub. L. 111–11, title II, § 2201</ref>, <date date="2009-03-30">Mar. 30, 2009</date>, <ref href="/us/stat/123/1099">123 Stat. 1099</ref>.)</sourceCredit>
</section>
