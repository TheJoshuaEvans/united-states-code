{"tag":"section","attrib":{"id":"id78438afd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s554b"},"text":null,"children":[{"tag":"num","attrib":{"value":"554b"},"text":"§ 554b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical care for employees engaged in hazardous work; notification and transportation of employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appropriations for the Forest Service shall be available for medical supplies and services and other assistance necessary for the immediate relief of artisans, laborers, and other employees engaged in any hazardous work under the Forest Service, and for expenses of notifying employees of the death or serious illness of close relatives and, in such cases where no public transportation is available, for transporting the employees to a point where public transportation is available.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78438afe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-09-21/ch412"},"text":"Sept. 21, 1944, ch. 412","children":[],"tail":", title II, § 202, "},{"tag":"ref","attrib":{"href":"/us/stat/58/736"},"text":"58 Stat. 736","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/464/s4"},"text":"Pub. L. 85–464, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-06-20"},"text":"June 20, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/217"},"text":"72 Stat. 217","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78438aff-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78438b00-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78438b01-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as a part of the Department of Agriculture Organic Act of 1944.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78438b02-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/464"},"text":"Pub. L. 85–464","children":[],"tail":" made appropriations available for expenses of notifying employees of the death or serious illness of close relatives, and for transportation of employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
