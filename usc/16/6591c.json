{"tag":"section","attrib":{"id":"id7a120a77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c"},"text":null,"children":[{"tag":"num","attrib":{"value":"6591c"},"text":"§ 6591c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stewardship end result contracting projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a120a78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Chief” means the Chief of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief and the Director, via agreement or contract as appropriate, may enter into stewardship contracting projects with private persons or other public or private entities to perform services to achieve land management goals for the national forests and the public lands that meet local and rural community needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land management goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The land management goals of a project under subsection (b) may include any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Road and trail maintenance or obliteration to restore or maintain water quality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Soil productivity, habitat for wildlife and fisheries, or other resource values.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Setting of prescribed fires to improve the composition, structure, condition, and health of stands or to improve wildlife habitat.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Removing vegetation or other activities to promote healthy forest stands, reduce fire hazards, or achieve other land management objectives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Watershed restoration and maintenance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Restoration and maintenance of wildlife and fish.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Control of noxious and exotic weeds and reestablishing native plant species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements or contracts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A source for performance of an agreement or contract under subsection (b) shall be selected on a best-value basis, including consideration of source under other public and private agreements or contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract for sale of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A contract entered into under this section may, at the discretion of the Secretary of Agriculture, be considered a contract for the sale of property under such terms as the Secretary may prescribe without regard to any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a120a88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the Chief and the Director may enter into a contract under subsection (b) in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3903"},"text":"section 3903 of title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120a89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The period of the contract under subsection (b) may exceed 5 years but may not exceed 10 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offsets","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a120a8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief and the Director may apply the value of timber or other forest products removed as an offset against the cost of services received under the agreement or contract described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120a8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods of appraisal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The value of timber or other forest products used as an offset under subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a120a8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be determined using appropriate methods of appraisal commensurate with the quantity of products to be removed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a120a8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a120a8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be determined using a unit of measure appropriate to the contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a120a90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include valuing products on a per-acre basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsections (d) and (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s472a"},"text":"section 472a of this title","children":[],"tail":", the Chief may enter into an agreement or contract under subsection (b). Notwithstanding the Materials Act of 1947 ("},{"tag":"ref","attrib":{"href":"/us/usc/t30/s602/a"},"text":"30 U.S.C. 602(a)","children":[],"tail":"),"},{"tag":"ref","attrib":{"idref":"fn002829"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002829"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the Director may enter into an agreement or contract under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary or the Secretary of the Interior may determine the appropriate contracting officer to enter into and administer an agreement or contract under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fire liability provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", the Chief shall issue for use in all contracts and agreements under this section fire liability provisions that are in substantially the same form as the fire liability provisions contained in—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a120a94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrated resource timber contracts, as described in the Forest Service contract numbered 2400–13, part H, section H.4; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120a95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" timber sale contracts conducted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s472a"},"text":"section 472a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief and the Director may collect monies from an agreement or contract under subsection (b) if the collection is a secondary objective of negotiating the contract that will best achieve the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Monies from an agreement or contract under subsection (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a120a99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be retained by the Chief and the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120a9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be available for expenditure without further appropriation at the project site from which the monies are collected or at another project site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other laws","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a120a9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the value of services received by the Chief or the Director under a stewardship contract project conducted under this section, and any payments made or resources provided by the contractor, Chief, or Director shall not be considered monies received from the National Forest System or the public lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120a9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Knutson-Vanderberg ","children":[{"tag":"ref","attrib":{"idref":"fn002830"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002830"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “Knutson-Vandenberg”."}],"tail":" Act"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1930-06-09"},"text":"June 9, 1930","children":[],"tail":" (commonly known as the “Knutson-Vanderberg "},{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" Act”) ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s576"},"text":"16 U.S.C. 576","children":[],"tail":" et seq.) shall not apply to any agreement or contract under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs of removal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the fact that a contractor did not harvest the timber, the Chief may collect deposits from a contractor covering the costs of removal of timber or other forest products under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s490"},"text":"section 490 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120aa0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s498"},"text":"section 498 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120aa1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance and payment guarantees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120aa2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief and the Director may require performance and payment bonds under sections 28.103–2 and 28.103–3 of the Federal Acquisition Regulation, in an amount that the contracting officer considers sufficient to protect the investment in receipts by the Federal Government generated by the contractor from the estimated value of the forest products to be removed under a contract under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120aa3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess offset value","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the offset value of the forest products exceeds the value of the resource improvement treatments, the Chief and the Director may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a120aa4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the excess to satisfy any outstanding liabilities for cancelled agreements or contracts; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120aa5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there are no outstanding liabilities described in subparagraph (A), apply the excess to other authorized stewardship projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120aa6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cancellation ceilings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120aa7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3903/b/1"},"text":"section 3903(b)(1) of title 41","children":[],"tail":", the Chief and the Director may obligate funds in stages that are economically or programmatically viable to cover any potential cancellation or termination costs for an agreement or contract under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120aa8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance notice to Congress of cancellation ceiling in excess of $25,000,000","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days before entering into a multiyear agreement or contract under subsection (b) that includes a cancellation ceiling in excess of $25,000,000, but does not include proposed funding for the costs of cancelling the agreement or contract up to that cancellation ceiling, the Chief or the Director, as applicable, shall submit to the Committee on Energy and Natural Resources and the Committee on Agriculture, Nutrition, and Forestry of the Senate and the Committee on Natural Resources and the Committee on Agriculture of the House of Representatives a written notice that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a120aa9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the cancellation ceiling amounts proposed for each program year in the agreement or contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120aaa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons why the cancellation ceiling amounts described under subparagraph (A) were selected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120aab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the extent to which the costs of contract cancellation are not included in the budget for the agreement or contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120aac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the financial risk of not including budgeting for the costs of agreement or contract cancellation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120aad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal of notice to OMB","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 14 days after the date on which written notice is provided under paragraph (2), the Chief or the Director, as appropriate, shall transmit a copy of the notice to the Director of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120aae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring and evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120aaf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief and the Director shall establish a multiparty monitoring and evaluation process that accesses the stewardship contracting projects conducted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120ab0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Other than the Chief and Director, participants in the process described in paragraph (1) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a120ab1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any cooperating governmental agencies, including tribal governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120ab2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other interested groups or individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120ab3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", and annually thereafter, the Chief and the Director shall submit to the congressional committees described in subsection (h)(2) a report on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120ab4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of development, execution, and administration of agreements or contracts under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120ab5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific accomplishments that have resulted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120ab6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591c/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role of local communities in the development of agreements or contract plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a147ab7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tVI/s604"},"text":"Pub. L. 108–148, title VI, § 604","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVIII/s8205/a"},"text":"Pub. L. 113–79, title VIII, § 8205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/918"},"text":"128 Stat. 918","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/31/dG/tIV/s422"},"text":"Pub. L. 115–31, div. G, title IV, § 422","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/499"},"text":"131 Stat. 499","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/tII"},"text":"Pub. L. 115–141, div. O, title II","children":[],"tail":", §§ 204–206, "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1064"},"text":"132 Stat. 1064","children":[],"tail":", 1065.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a147ab8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a147ab9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a147aba-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Materials Act of 1947, referred to in subsec. (d)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-31/ch406"},"text":"act July 31, 1947, ch. 406","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/681"},"text":"61 Stat. 681","children":[],"tail":", which is classified generally to subchapter I (§ 601 et seq.) of chapter 15 of Title 30, Mineral Lands and Mining. "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s602/a"},"text":"Section 602(a) of Title 30","children":[],"tail":" is section 2(a) of the Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s601"},"text":"section 601 of Title 30","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1930-06-09"},"text":"June 9, 1930","children":[],"tail":", referred to in subsec. (e)(3)(B), is "},{"tag":"ref","attrib":{"href":"/us/act/1930-06-09/ch416"},"text":"act June 9, 1930, ch. 416","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/527"},"text":"46 Stat. 527","children":[],"tail":", popularly known as the Knutson-Vandenberg Act, which is classified generally to sections 576, 576a, and 576b of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s576"},"text":"section 576 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s490"},"text":"Section 490 of this title","children":[],"tail":", referred to in subsec. (f)(1), was in the original “the Act of "},{"tag":"date","attrib":{"date":"1916-08-11"},"text":"August 11, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s490"},"text":"16 U.S.C. 490","children":[],"tail":")”, and was translated as referring to the undesignated provisions appearing in "},{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"act Aug. 11, 1916, ch. 313","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/462"},"text":"39 Stat. 462","children":[],"tail":", which are classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s490"},"text":"section 490 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s498"},"text":"Section 498 of this title","children":[],"tail":", referred to in subsec. (f)(2), was in the original “the Act of "},{"tag":"date","attrib":{"date":"1914-06-30"},"text":"June 30, 1914","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s498"},"text":"16 U.S.C. 498","children":[],"tail":")”, and was translated as referring to the undesignated provisions appearing in "},{"tag":"ref","attrib":{"href":"/us/act/1914-06-30/ch131"},"text":"act June 30, 1914, ch. 131","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/430"},"text":"38 Stat. 430","children":[],"tail":", which are classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s498"},"text":"section 498 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a147abb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s205"},"text":"Pub. L. 115–141, § 205","children":[],"tail":", added subpars. (A) and (B) and struck out former subpars. (A) and (B) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) collect any residual receipts under the Act of ","children":[{"tag":"date","attrib":{"date":"1930-06-09"},"text":"June 9, 1930","children":[],"tail":" (commonly known as the “Knutson-Vanderberg Act”) ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s576"},"text":"16 U.S.C. 576","children":[],"tail":" et seq.); and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) apply the excess to other authorized stewardship projects.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h), (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s204"},"text":"Pub. L. 115–141, § 204","children":[],"tail":", added subsec. (h) and redesignated former subsec. (h) as (i). Former subsec. (i) redesignated (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":", §§ 204(1), 206, redesignated subsec. (i) as (j) and substituted “submit to the congressional committees described in subsection (h)(2) a report” for “report to the Committee on Agriculture, Nutrition, and Forestry of the Senate and the Committee on Agriculture of the House of Representatives” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/s422/1"},"text":"Pub. L. 115–31, § 422(1)","children":[],"tail":", inserted at end “Notwithstanding the Materials Act of 1947 ("},{"tag":"ref","attrib":{"href":"/us/usc/t30/s602/a"},"text":"30 U.S.C. 602(a)","children":[],"tail":"), the Director may enter into an agreement or contract under subsection (b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/s422/2"},"text":"Pub. L. 115–31, § 422(2)","children":[],"tail":", struck out “and the Director” after “the Chief” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a147abc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a147abd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"20-Year Stewardship Contracting","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/tII/s207"},"text":"Pub. L. 115–141, div. O, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1065"},"text":"132 Stat. 1065","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/141/dO/tII/s207"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Agriculture and the Secretary of the Interior may award contracts or agreements under section 604 of the Healthy Forests Restoration Act of 2003 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6511"},"text":"16 U.S.C. 6511","children":[],"tail":" [6591c]), for terms not to exceed 20 years on areas where the majority of Federal lands are in Fire Regime Groups I, II, or III."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preference","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In awarding a contract under this section, the Secretary concerned [see Definitions note below] may, notwithstanding the Federal Acquisition Regulations, give a procurement preference to a contractor that would, as part of the contract, promote an innovative use of forest products, including cross-laminated timber.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7a147abe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/tII/s201"},"text":"Pub. L. 115–141, div. O, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1062"},"text":"132 Stat. 1062","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/141/dO/tII/s201"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this title [see Tables for classification]:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National forest system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘National Forest System’ has the meaning given the term in section 11(a) of the Forest and Rangeland Renewable Resources Planning Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1609/a"},"text":"16 U.S.C. 1609(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public land","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘public land’ has the meaning given the term ‘public lands’ in section 103 of the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1702"},"text":"43 U.S.C. 1702","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary concerned","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘Secretary concerned’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, with respect to National Forest System land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior, with respect to public land.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
