{"tag":"section","attrib":{"id":"id783051a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"539l–1"},"text":"§ 539l–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inholdings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id783051a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State Land Board lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Colorado State Land Board informs the Secretary that the Board is willing to transfer to the United States some or all of the lands owned by the Board located within the Protection Area, the Secretary shall promptly seek to reach agreement with the Board regarding terms and conditions for acquisition of such lands by the United States by purchase or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id783051a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jim Creek inholding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id783051a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into negotiations with the owner of lands located within the portion of the Jim Creek drainage within the Protection Area for the purpose of acquiring the lands by purchase or exchange, but the United States shall not acquire such lands without the consent of the owner of the lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783051a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Landowner rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this Act shall affect any rights of the owner of lands located within the Jim Creek drainage within the Protection Area, including any right to reasonable access to such lands by motorized or other means as determined by the Forest Service and the landowner consistent with applicable law and relevant and appropriate rules and regulations governing such access.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id783051a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id783051a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to the Committee on Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a report concerning any agreement or the status of negotiations conducted pursuant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id783051a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a), upon conclusion of an agreement for acquisition by the United States of lands referred to in subsection (a), or 1 year after ","children":[{"tag":"date","attrib":{"date":"2002-08-21"},"text":"August 21, 2002","children":[],"tail":", whichever occurs first; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id783051a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b), upon conclusion of an agreement for acquisition by the United States of lands referred to in subsection (b), or 1 year after ","children":[{"tag":"date","attrib":{"date":"2002-08-21"},"text":"August 21, 2002","children":[],"tail":", whichever occurs first."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783051aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required by this subsection shall indicate to what extent funds are available to the Secretary as of the date of the report for the acquisition of the relevant lands and whether additional funds need to be appropriated or otherwise made available to the Secretary for such purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id783051ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of acquisitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any lands within the James Peak Wilderness or the Protection Area acquired by the United States after ","children":[{"tag":"date","attrib":{"date":"2002-08-21"},"text":"August 21, 2002","children":[],"tail":", shall be added to the James Peak Wilderness or the Protection Area, respectively, and managed accordingly."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id783051ac-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/216/s4"},"text":"Pub. L. 107–216, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1059"},"text":"116 Stat. 1059","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id783051ad-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id783051ae-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id783051af-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/216"},"text":"Pub. L. 107–216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1055"},"text":"116 Stat. 1055","children":[],"tail":", which is classified principally to sections 539"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" to 539"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–5 of this title. For complete classification of this Act to the Code, see Short Title note set out under section 539"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id783051b0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id783051b1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
