{"tag":"section","attrib":{"id":"id772ee6d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s368"},"text":null,"children":[{"tag":"num","attrib":{"value":"368"},"text":"§ 368.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of bathhouse in connection with hotel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in sections 362 to 367 of this title shall be so construed as to prevent the stockholders of any hotel from operating a bathhouse in connection with such hotel as a part thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id772ee6d1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1891-03-03/ch533/s8"},"text":"Mar. 3, 1891, ch. 533, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/844"},"text":"26 Stat. 844","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
