{"tag":"section","attrib":{"id":"id76f7f898-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s62"},"text":null,"children":[{"tag":"num","attrib":{"value":"62"},"text":"§ 62.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Possession of dead bodies of birds or animals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Possession within said parks, or either of them, of the dead bodies or any part thereof of any wild bird or animal shall be prima facie evidence that person or persons having same are guilty of violating sections 60 to 63 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76f7f899-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-02/ch218/s5"},"text":"June 2, 1920, ch. 218, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/732"},"text":"41 Stat. 732","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
