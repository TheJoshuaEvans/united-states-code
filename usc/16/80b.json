{"tag":"section","attrib":{"id":"id76ff2464-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s80b"},"text":null,"children":[{"tag":"num","attrib":{"value":"80b"},"text":"§ 80b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration for public recreational purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The National Park Service shall, under the rules and regulations to be prescribed by the Secretary of the Interior, administer for public recreational purposes the lands withdrawn.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76ff2465-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-03-04/ch40/s3"},"text":"Mar. 4, 1940, ch. 40, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/44"},"text":"54 Stat. 44","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id76ff2466-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id76ff2467-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id76ff2468-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
