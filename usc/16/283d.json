{"tag":"section","attrib":{"id":"id7727ba6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s283d"},"text":null,"children":[{"tag":"num","attrib":{"value":"283d"},"text":"§ 283d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any funds available for the purpose of administering the five thousand six hundred and thirty-two acres of lands previously donated to the United States in Culberson County, Texas, shall upon establishment of the Guadalupe Mountains National Park pursuant to this subchapter be available to the Secretary for purposes of such park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7727ba6f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/667/s5"},"text":"Pub. L. 89–667, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/922"},"text":"80 Stat. 922","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
