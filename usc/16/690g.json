{"tag":"section","attrib":{"id":"id7875989b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s690g"},"text":null,"children":[{"tag":"num","attrib":{"value":"690g"},"text":"§ 690g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation of laws and regulations; penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who shall violate or fail to comply with any provision of, or any regulation made pursuant to sections 690d to 690i of this title shall be deemed guilty of a misdemeanor, and upon conviction thereof shall be fined not more than $500 or be imprisoned not more than six months, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7875989c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-04-23/ch413/s9"},"text":"Apr. 23, 1928, ch. 413, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/450"},"text":"45 Stat. 450","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7875989d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7875989e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7875989f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 690i, included within the reference to sections 690 to 690i, was omitted from the Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
