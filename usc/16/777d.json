{"tag":"section","attrib":{"id":"id78994ba3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777d"},"text":null,"children":[{"tag":"num","attrib":{"value":"777d"},"text":"§ 777d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of funds deducted for expenses and amounts apportioned to States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For each fiscal year beginning with the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1951-06-30"},"text":"June 30, 1951","children":[],"tail":", the Secretary of the Interior shall certify, at the time at which a deduction or apportionment is made, to the Secretary of the Treasury, and to each State fish and game department, the sum which he has estimated to be deducted for administering this chapter and the sum which he has apportioned to each State for such fiscal year."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78994ba4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-09/ch658/s5"},"text":"Aug. 9, 1950, ch. 658, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/432"},"text":"64 Stat. 432","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1014/a/4"},"text":"Pub. L. 98–369, div. A, title X, § 1014(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1015"},"text":"98 Stat. 1015","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/408/tI/s125"},"text":"Pub. L. 106–408, title I, § 125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1775"},"text":"114 Stat. 1775","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78994ba5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78994ba6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78994ba7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/408"},"text":"Pub. L. 106–408","children":[],"tail":" inserted “, at the time at which a deduction or apportionment is made,” after “certify” and struck out “and executing” after “administering”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" struck out provisions relating to notice by the State to the Secretary of intention to accept, and use of funds where the State fails to accept."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78994ba8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78994ba9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-10-01"},"text":"Oct. 1, 1984","children":[],"tail":",