{"tag":"section","attrib":{"id":"id79c103d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3642"},"text":null,"children":[{"tag":"num","attrib":{"value":"3642"},"text":"§ 3642.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of property of International Pacific Salmon Fisheries Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall dispose of any United States property held by the International Pacific Salmon Fisheries Commission on the date of its termination in a manner which would further the purposes of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79c103d3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/5/s13"},"text":"Pub. L. 99–5, § 13","children":[],"tail":" (part), "},{"tag":"date","attrib":{"date":"1985-03-15"},"text":"Mar. 15, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/15"},"text":"99 Stat. 15","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c103d4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c103d5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79c103d6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consists of a part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/5/s13"},"text":"section 13 of Pub. L. 99–5","children":[],"tail":". The remainder of "},{"tag":"ref","attrib":{"href":"/us/pl/99/5/s13"},"text":"section 13 of Pub. L. 99–5","children":[],"tail":" provided for the repeal, effective "},{"tag":"date","attrib":{"date":"1985-12-31"},"text":"Dec. 31, 1985","children":[],"tail":", of the Sockeye Salmon or Pink Salmon Fishing Act of 1947, "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-29/ch345"},"text":"act July 29, 1947, ch. 345","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/511"},"text":"61 Stat. 511","children":[],"tail":", as amended, which was classified to chapter 10A (§ 776 et seq.) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
