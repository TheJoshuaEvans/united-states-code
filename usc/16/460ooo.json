{"tag":"section","attrib":{"id":"id780326c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ooo"},"text":"§ 460ooo.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subchapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780326c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Conservation Area” means the Las Cienegas National Conservation Area established by section 460","children":[{"tag":"i","attrib":{},"text":"ooo","children":[],"tail":"–3(a) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780326c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition Planning District","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Acquisition Planning District” means the Sonoita Valley Acquisition Planning District established by section 460","children":[{"tag":"i","attrib":{},"text":"ooo","children":[],"tail":"–1(a) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780326c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “management plan” means the management plan for the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780326c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “public lands” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1702/e"},"text":"section 1702(e) of title 43","children":[],"tail":", except that such term shall not include interest in lands not owned by the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780326c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id780326c6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/538/s1"},"text":"Pub. L. 106–538, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-06"},"text":"Dec. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2563"},"text":"114 Stat. 2563","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
