{"tag":"section","attrib":{"id":"id7a251c69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124"},"text":null,"children":[{"tag":"num","attrib":{"value":"7124"},"text":"§ 7124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and approval of projects by Secretary concerned","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a251c6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for approval of proposed project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may make a decision to approve a project submitted by a resource advisory committee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7123"},"text":"section 7123 of this title","children":[],"tail":" only if the proposed project satisfies each of the following conditions:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a251c6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project complies with all applicable Federal laws (including regulations).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project is consistent with the applicable resource management plan and with any watershed or subsequent plan developed pursuant to the resource management plan and approved by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project has been approved by the resource advisory committee in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7125"},"text":"section 7125 of this title","children":[],"tail":", including the procedures issued under subsection (e) of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A project description has been submitted by the resource advisory committee to the Secretary concerned in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7123"},"text":"section 7123 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project will improve the maintenance of existing infrastructure, implement stewardship objectives that enhance forest ecosystems, and restore and improve land health and water quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a251c70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental reviews","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a251c71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for payment by county","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned may request the resource advisory committee submitting a proposed project to agree to the use of project funds to pay for any environmental review, consultation, or compliance with applicable environmental laws required in connection with the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of environmental review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a payment is requested under paragraph (1) and the resource advisory committee agrees to the expenditure of funds for this purpose, the Secretary concerned shall conduct environmental review, consultation, or other compliance responsibilities in accordance with Federal laws (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of refusal to pay","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a251c74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a resource advisory committee does not agree to the expenditure of funds under paragraph (1), the project shall be deemed withdrawn from further consideration by the Secretary concerned pursuant to this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a251c75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of withdrawal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A withdrawal under subparagraph (A) shall be deemed to be a rejection of the project for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7127/c"},"text":"section 7127(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a251c76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decisions of Secretary concerned","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a251c77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rejection of projects","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a251c78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A decision by the Secretary concerned to reject a proposed project shall be at the sole discretion of the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a251c79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No administrative appeal or judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, a decision by the Secretary concerned to reject a proposed project shall not be subject to administrative appeal or judicial review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a251c7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of rejection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date on which the Secretary concerned makes the rejection decision, the Secretary concerned shall notify in writing the resource advisory committee that submitted the proposed project of the rejection and the reasons for rejection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of project approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned shall publish in the Federal Register notice of each project approved under subsection (a) if the notice would be required had the project originated with the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a251c7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source and conduct of project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Once the Secretary concerned accepts a project for review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7123"},"text":"section 7123 of this title","children":[],"tail":", the acceptance shall be deemed a Federal action for all purposes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a251c7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of approved projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a251c7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding chapter 63 of title 31, using project funds the Secretary concerned may enter into contracts, grants, and cooperative agreements with States and local governments, private and nonprofit entities, and landowners and other persons to assist the Secretary in carrying out an approved project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best value contracting","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a251c80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any project involving a contract authorized by paragraph (1) the Secretary concerned may elect a source for performance of the contract on a best value basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a251c81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall determine best value based on such factors as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a251c82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technical demands and complexity of the work to be done;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a251c83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a251c84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/e/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ecological objectives of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a251c85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/e/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sensitivity of the resources being treated;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a251c86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the past experience by the contractor with the type of work being done, using the type of equipment proposed for the project, and meeting or exceeding desired ecological conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a251c87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/e/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commitment of the contractor to hiring highly qualified workers and local residents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a251c88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for project funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that at least 50 percent of all project funds be used for projects that are primarily dedicated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a251c89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to road maintenance, decommissioning, or obliteration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7124/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restoration of streams and watersheds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a251c8b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/393/tII/s204"},"text":"Pub. L. 106–393, title II, § 204","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tVI/s601/a"},"text":"Pub. L. 110–343, div. C, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3902"},"text":"122 Stat. 3902","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dF/tI/s100101/a/6"},"text":"Pub. L. 112–141, div. F, title I, § 100101(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/906"},"text":"126 Stat. 906","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/40/s10/a/2/B"},"text":"Pub. L. 113–40, § 10(a)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/545"},"text":"127 Stat. 545","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/10/tV/s524/c/2"},"text":"Pub. L. 114–10, title V, § 524(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-04-16"},"text":"Apr. 16, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/180"},"text":"129 Stat. 180","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/tIV/s401/b/1"},"text":"Pub. L. 115–141, div. O, title IV, § 401(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1079"},"text":"132 Stat. 1079","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a251c8c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a251c8d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a251c8e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/393/s204"},"text":"section 204 of Pub. L. 106–393","children":[],"tail":" was set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s500"},"text":"section 500 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tVI/s601/a"},"text":"Pub. L. 110–343, div. C, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3893"},"text":"122 Stat. 3893","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a251c8f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" struck out par. (3) which established a pilot program to implement projects involving the sale of merchantable timber."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (e)(3)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/10"},"text":"Pub. L. 114–10","children":[],"tail":" substituted “fiscal year 2010 and fiscal years thereafter” for “each of fiscal years 2010 through 2013”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (e)(3)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/40"},"text":"Pub. L. 113–40","children":[],"tail":" substituted “2013” for “2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (e)(3)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" substituted “through 2012” for “and 2011”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
