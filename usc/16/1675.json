{"tag":"section","attrib":{"id":"id795a79da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1675"},"text":null,"children":[{"tag":"num","attrib":{"value":"1675"},"text":"§ 1675.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; criteria for eligibility of States for funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subchapter $30,000,000 for each of fiscal years 2002 through 2023. Generally, States shall be eligible for funds appropriated under this subchapter according to the respective capabilities of their private forests and rangelands for yielding renewable resources and relative needs for such resources identified in the periodic Renewable Resource Assessment provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1601"},"text":"section 1601 of this title","children":[],"tail":" and the periodic appraisal of land and water resources provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2004"},"text":"section 2004 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id795a79db-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/306/s6"},"text":"Pub. L. 95–306, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-30"},"text":"June 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/352"},"text":"92 Stat. 352","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/231/s2/1"},"text":"Pub. L. 100–231, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-05"},"text":"Jan. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1565"},"text":"101 Stat. 1565","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tIII/s301/h"},"text":"Pub. L. 105