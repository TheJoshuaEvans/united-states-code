{"tag":"section","attrib":{"id":"id7a3f5b47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571"},"text":null,"children":[{"tag":"num","attrib":{"value":"8571"},"text":"§ 8571.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Good neighbor authority for recreation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3f5b48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3f5b49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized recreation services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “authorized recreation services” means similar and complementary recreation enhancement or improvement services carried out—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3f5b4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on Federal land, non-Federal land, or land owned by an Indian Tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3f5b4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by either the Secretary or a Governor, Indian Tribe, or county, as applicable, pursuant to a good neighbor agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3f5b4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" County","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “county” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3f5b4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate executive official of an affected county; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3f5b4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any case in which multiple counties are affected, the appropriate executive official of a compact of the affected counties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3f5b4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal land” means land that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3f5b50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" owned and administered by the United States as a part of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3f5b51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Forest System; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3f5b52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Park System; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3f5b53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public lands (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1702"},"text":"section 1702 of title 43","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3f5b54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreation enhancement or improvement services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “recreation enhancement or improvement services” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3f5b55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishing, repairing, restoring, improving, relocating, constructing, or reconstructing new or existing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3f5b56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trails or trailheads;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3f5b57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" campgrounds and camping areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3f5b58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cabins;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3f5b59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" picnic areas or other day use areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3f5b5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/4/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shooting ranges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3f5b5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/4/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restroom or shower facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3f5b5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/4/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paved or permanent roads or parking areas that serve existing recreation facilities or areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3f5b5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/4/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fishing piers, wildlife viewing platforms, docks, or other constructed features at a recreation site;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3f5b5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/4/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" boat landings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3f5b5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/4/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hunting or fishing sites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3f5b60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/4/A/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" infrastructure within ski areas; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3f5b61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/4/A/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" visitor centers or other interpretative sites; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3f5b62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities that create, improve, or restore access to existing recreation facilities or areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3f5b63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Good neighbor agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “good neighbor agreement” means a cooperative agreement or contract (including a sole source contract) entered into between the Secretary and a Governor, Indian Tribe, or county, as applicable, to carry out authorized recreation services under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3f5b64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Governor” means the Governor or any other appropriate executive official of an affected State or the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3f5b65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary concerned","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretary concerned” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3f5b66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, with respect to National Forest System land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3f5b67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior, with respect to National Park System land and public lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3f5b68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Good neighbor agreements for recreation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3f5b69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned may enter into a good neighbor agreement with a Governor, Indian Tribe, or county to carry out authorized recreation services in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3f5b6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned shall make each good neighbor agreement available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3f5b6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial and technical assistance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3f5b6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned may provide financial or technical assistance to a Governor, Indian Tribe, or county carrying out authorized recreation services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3f5b6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3f5b6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8571/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of NEPA responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any decision required to be made under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) with respect to any authorized recreation services to be provided under this section on Federal land shall not be delegated to a Governor, Indian Tribe, or county."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3f5b6f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tIII/s351"},"text":"Pub. L. 118–234, title III, § 351","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2915"},"text":"138 Stat. 2915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3f5b70-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3f5b71-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a3f5b72-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsecs. (a)(5) and (b)(1), was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234"},"text":"Pub. L. 118–234","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2891"},"text":"138 Stat. 2891","children":[],"tail":", which is classified principally to this subchapter. For complete classification of title III to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (b)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a3f5b73-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s351"},"text":"section 351 of Pub. L. 118–234","children":[],"tail":". Subsec. (b)(3)(B) of "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/s351"},"text":"section 351 of Pub. L. 118–234","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2113a"},"text":"section 2113a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
