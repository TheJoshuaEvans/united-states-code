{"tag":"section","attrib":{"id":"id7800b685-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–91"},"text":null,"children":[{"tag":"num","attrib":{"value":"460nnn–91"},"text":"§ 460nnn–91.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildlands Juniper Management Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7800b686-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–91/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To further the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn–23/c"},"text":"section 460nnn–23(c) of this title","children":[],"tail":", the Secretary shall establish a special management area consisting of certain Federal lands in the Cooperative Management and Protection Area, as depicted on the map referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn–11/a"},"text":"section 460nnn–11(a) of this title","children":[],"tail":", which shall be known as the Wildlands Juniper Management Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b687-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–91/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Special management practices shall be adopted for the Wildlands Juniper Management Area for the purposes of experimentation, education, interpretation, and demonstration of active and passive management intended to restore the historic fire regime and native vegetation communities on Steens Mountain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b688-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–91/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the authorization of appropriations in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn–121"},"text":"section 460nnn–121 of this title","children":[],"tail":", there is authorized to be appropriated $5,000,000 to carry out this part and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn–23/c"},"text":"section 460nnn–23(c) of this title","children":[],"tail":" regarding juniper management in the Cooperative Management and Protection Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7800b689-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399/tV/s501"},"text":"Pub. L. 106–399, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1670"},"text":"114 Stat. 1670","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
