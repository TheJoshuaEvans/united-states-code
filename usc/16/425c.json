{"tag":"section","attrib":{"id":"id778bd3dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s425c"},"text":null,"children":[{"tag":"num","attrib":{"value":"425c"},"text":"§ 425c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission; organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The affairs of the said Fredericksburg and Spotsylvania County Battle Fields Memorial shall, subject to the supervision and direction of the Secretary of the Interior, be in charge of three commissioners, consisting of Army officers, civilians, or both, to be appointed by the Secretary of the Interior, one of whom shall be designated as chairman and another as secretary of the commission.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778bd3dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-02-14/ch127/s4"},"text":"Feb. 14, 1927, ch. 127, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1093"},"text":"44 Stat. 1093","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778bd3de-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id778bd3df-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id778bd3e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","chil