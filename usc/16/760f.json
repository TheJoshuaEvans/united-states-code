{"tag":"section","attrib":{"id":"id78922042-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760f"},"text":null,"children":[{"tag":"num","attrib":{"value":"760f"},"text":"§ 760f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Migratory game fish study; authorization to acquire facilities, employ officers and employees, cooperate with State and other agencies, and to publish results","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out the provisions of sections 760e to 760g of this title, the Secretary of Commerce is authorized (1) to acquire lands, construct laboratory or other buildings, purchase boats, acquire such other equipment and apparatus, and to employ such officers and employees as he deems necessary; (2) to cooperate or contract with State and other institutions and agencies upon such terms and conditions as he determines to be appropriate; and (3) to make public the results of such research conducted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s760e"},"text":"section 760e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78922043-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/359/s2"},"text":"Pub. L. 86–359, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-22"},"text":"Sept. 22, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/642"},"text":"73 Stat. 642","children":[],"tail":"; 1970 Reorg. Plan No. 4, § 1(b), eff. "},{"tag":"date","attrib":{"date":"1970-10-03"},"text":"Oct. 3, 1970","children":[],"tail":", 35 F.R. 15627, "},{"tag":"ref","attrib":{"href":"/us/stat/84/2090"},"text":"84 Stat. 2090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78922044-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id78922045-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id78922046-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of functions to Secretary of Commerce from Secretary of the Interior by Reorg. Plan No. 4 of 1970, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s755"},"text":"section 755 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
