{"tag":"section","attrib":{"id":"id79fcac53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152"},"text":null,"children":[{"tag":"num","attrib":{"value":"5152"},"text":"§ 5152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fcac54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Magnuson Act” means the Magnuson-Stevens Fishery Conservation and Management Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"16 U.S.C. 1801","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcac55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Atlantic striped bass” means members of stocks or populations of the species Morone saxatilis, which ordinarily migrate seaward of the waters described in paragraph (3)(A)(i).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcac56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “coastal waters” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79fcac57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each coastal State referred to in paragraph (4)(A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79fcac58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all waters, whether salt or fresh, of the coastal State shoreward of the baseline from which the territorial sea of the United States is measured; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79fcac59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waters of the coastal State seaward from the baseline referred to in clause (i) to the inner boundary of the exclusive economic zone;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fcac5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the District of Columbia, those waters within its jurisdiction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fcac5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the Potomac River Fisheries Commission, those waters of the Potomac River within the boundaries established by the Potomac River Compact of 1958.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcac5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “coastal State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79fcac5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pennsylvania and each State of the United States bordering on the Atlantic Ocean north of the State of South Carolina;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fcac5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fcac5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Potomac River Fisheries Commission established by the Potomac River Compact of 1958.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcac60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Commission” means the Atlantic States Marine Fisheries Commission established under the interstate compact consented to and approved by the Congress in Public Laws 77–539 and 81–721.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcac61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “exclusive economic zone” has the meaning given such term in section 3(6) ","children":[{"tag":"ref","attrib":{"idref":"fn002809"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002809"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Magnuson Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1802/6"},"text":"16 U.S.C. 1802(6)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcac62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “fishing” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79fcac63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the catching, taking, or harvesting of Atlantic striped bass, except when incidental to harvesting that occurs in the course of commercial or recreational fish catching activities directed at a species other than Atlantic striped bass;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fcac64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the attempted catching, taking, or harvesting of Atlantic striped bass; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fcac65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any operation at sea in support of, or in preparation for, any activity described in subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The term does not include any scientific research authorized by the Federal Government or by any State government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcac66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “moratorium area” means the coastal waters with respect to which a declaration under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5154/a"},"text":"section 5154(a) of this title","children":[],"tail":" applies."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcac67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “moratorium period” means the period beginning on the day on which moratorium is declared under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5154/a"},"text":"section 5154(a) of this title","children":[],"tail":" regarding a coastal State and ending on the day on which the Commission notifies the Secretaries that that State has taken appropriate remedial action with respect to those matters that were the case of the moratorium being declared."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcac68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Plan” means a plan for managing Atlantic striped bass, or an amendment to such plan, that is prepared and adopted by the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcac69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Commerce or a designee of the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcac6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5152/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretaries” means the Secretary of Commerce and the Secretary of the Interior or their designees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fcac6b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/613/s3"},"text":"Pub. L. 98–613, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-31"},"text":"Oct. 31, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3187"},"text":"98 Stat. 3187","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/432/s1"},"text":"Pub. L. 99–432, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/989"},"text":"100 Stat. 989","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/589/s6/g/1"},"text":"Pub. L. 100–589, § 6(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-03"},"text":"Nov. 3, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2987"},"text":"102 Stat. 2987","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII/s211/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II, § 211(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–41; "},{"tag":"ref","attrib":{"href":"/us/pl/105/146/s2"},"text":"Pub. L. 105–146, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-16"},"text":"Dec. 16, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2673"},"text":"111 Stat. 2673","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fcac6c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79fcac6d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79fcac6e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Magnuson-Stevens Fishery Conservation and Management Act, referred to in par. (1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/331"},"text":"90 Stat. 331","children":[],"tail":", which is classified principally to chapter 38 (§ 1801 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/77/539"},"text":"Public Law 77–539","children":[],"tail":", referred to in par. (5), is "},{"tag":"ref","attrib":{"href":"/us/act/1942-05-04/ch283"},"text":"act May 4, 1942, ch. 283","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/267"},"text":"56 Stat. 267","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/81/721"},"text":"Public Law 81–721","children":[],"tail":", referred to in par. (5), is "},{"tag":"ref","attrib":{"href":"/us/act/1950-08-19/ch763"},"text":"act Aug. 19, 1950, ch. 763","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/467"},"text":"64 Stat. 467","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3(6) of the Magnuson Act, referred to in par. (6), was redesignated section 3(11) of that Act, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/297/tI/s102/1"},"text":"Pub. L. 104–297, title I, § 102(1)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3561"},"text":"110 Stat. 3561","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79fcac6f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/146"},"text":"Pub. L. 105–146","children":[],"tail":" amended section catchline and text generally, substituting present provisions for provisions which defined the terms “Magnuson Act” in par. (1), “Atlantic striped bass” in par. (2), “coastal waters” in par. (3), “coastal State” in par. (4), “Commission” in par. (5), “fishing” in par. (6), “Plan” in par. (7), “Secretary” in par. (8), and “Secretaries” in par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “Magnuson-Stevens Fishery” for “Magnuson Fishery”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/589"},"text":"Pub. L. 100–589","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “The term ‘Act of 1976’ means the Act entitled ‘An Act to provide for the conservation and management of the fisheries, and for other purposes’, approved "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"April 13, 1976","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"16 U.S.C. 1801","children":[],"tail":" et seq.).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Pars. (2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/432"},"text":"Pub. L. 99–432","children":[],"tail":" amended pars. (2) to (4) generally. Prior to amendment, pars. (2) to (4) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The term ‘Atlantic striped bass’ means members of stocks or populations of the species Morone saxatilis, which ordinarily migrate seaward of the waters described in paragraph (3)(A).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The term ‘coastal waters’ means—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) all waters, whether salt or fresh, of a coastal State shoreward of the baseline from which the territorial sea of the United States is measured; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the waters of a coastal State seaward from the baseline referred to in subparagraph (A) to the inner boundary of the exclusive economic zone.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) The term ‘coastal State’ means Pennsylvania and each State of the United States bordering on the Atlantic Ocean north of the State of South Carolina.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79fcac70-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79fcac71-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII/s211/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II, § 211(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–41, provided that the amendment made by that section is effective 15 days after "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
