{"tag":"section","attrib":{"id":"id799623a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2202"},"text":null,"children":[{"tag":"num","attrib":{"value":"2202"},"text":"§ 2202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to agricultural producers for carrying out water conservation or water enhancing measures; criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make payments to agricultural producers who carry out emergency water conservation or water enhancing measures (including measures carried out to assist confined livestock) during periods of severe drought as determined by the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id799623a5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/334/tIV/s402"},"text":"Pub. L. 95–334, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-04"},"text":"Aug. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/434"},"text":"92 Stat. 434","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/82/tV/s502"},"text":"Pub. L. 101–82, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-14"},"text":"Aug. 14, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/586"},"text":"103 Stat. 586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2403/a/2/A"},"text":"Pub. L. 115–334, title II, § 2403(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4571"},"text":"132 Stat. 4571","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799623a6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799623a7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id799623a8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “The Secretary is” for “The Secretary of Agriculture is”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/82/s502/1"},"text":"Pub. L. 101–82, § 502(1)","children":[],"tail":", inserted “(including measures carried out to assist confined livestock)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/82/s502/2"},"text":"Pub. L. 101–82, § 502(2)","children":[],"tail":", temporarily substituted “any fiscal year in which there is a period of severe drought” for “periods of severe drought”. See Effective and Termination Dates of 1989 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id799623a9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id799623aa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/82/tV/s502/2"},"text":"Pub. L. 101–82, title V, § 502(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-14"},"text":"Aug. 14, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/586"},"text":"103 Stat. 586","children":[],"tail":", provided in part that amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/101/82/s502/2"},"text":"section 502(2) of Pub. L. 101–82","children":[],"tail":" is effective only for fiscal year 1989."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id799623ab-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/334/s406"},"text":"section 406 of Pub. L. 95–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
