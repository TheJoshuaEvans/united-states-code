{"tag":"section","attrib":{"id":"id787cc479-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"698u–5"},"text":"§ 698u–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id787cc47a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established an advisory committee to be known as the “Tallgrass Prairie National Preserve Advisory Committee”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787cc47b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall advise the Secretary and the Director of the National Park Service concerning the development, management, and interpretation of the Preserve. In carrying out those duties, the Advisory Committee shall provide timely advice to the Secretary and the Director during the preparation of the general management plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s698u–3/g"},"text":"section 698u–3(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787cc47c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall consist of 13 members, who shall be appointed by the Secretary as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id787cc47d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members shall be representatives of the Trust.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc47e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members shall be representatives of local landowners, cattle ranchers, or other agricultural interests.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc47f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members shall be representatives of conservation or historic preservation interests.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc480-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id787cc481-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member shall be selected from a list of persons recommended by the Chase County Commission in the State of Kansas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id787cc482-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member shall be selected from a list of persons recommended by appropriate officials of Strong City, Kansas, and Cottonwood Falls, Kansas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id787cc483-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member shall be selected from a list of persons recommended by the Governor of the State of Kansas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc484-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member shall be a range management specialist representing institutions of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":") in the State of Kansas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787cc485-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id787cc486-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member of the Advisory Committee shall be appointed to serve for a term of 3 years, except that the initial members shall be appointed as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id787cc487-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four members shall be appointed, one each from paragraphs (1), (2), (3), and (4) of subsection (c), to serve for a term of 3 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id787cc488-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four members shall be appointed, one each from paragraphs (1), (2), (3), and (4) of subsection (c), to serve for a term of 4 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id787cc489-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Five members shall be appointed, one each from paragraphs (1) through (5) of subsection (c), to serve for a term of 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc48a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member may be reappointed to serve a subsequent term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc48b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member shall continue to serve after the expiration of the term of the member until a successor is appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc48c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy on the Advisory Committee shall be filled in the same manner as an original appointment is made. The member appointed to fill the vacancy shall serve until the expiration of the term in which the vacancy occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787cc48d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Advisory Committee shall select 1 of the members to serve as Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787cc48e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Meetings of the Advisory Committee shall be held at the call of the Chairperson or the majority of the Advisory Committee. Meetings shall be held at such locations and in such a manner as to ensure adequate opportunity for public involvement. In compliance with the requirements of chapter 10 of title 5, the Advisory Committee shall choose an appropriate means of providing interested members of the public advance notice of scheduled meetings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787cc48f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Advisory Committee shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787cc490-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Advisory Committee shall serve without compensation, except that while engaged in official business of the Advisory Committee, the member shall be entitled to travel expenses, including per diem in lieu of subsistence in the same manner as persons employed intermittently in Government service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787cc491-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–5/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rechartering provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/b"},"text":"section 1013(b) of title 5","children":[],"tail":" shall not apply to the Advisory Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id787cc492-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/333/dI/tX/s1007"},"text":"Pub. L. 104–333, div. I, title X, § 1007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-11-12"},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4208"},"text":"110 Stat. 4208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tI/s102/a/4"},"text":"Pub. L. 105–244, title I, § 102(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1618"},"text":"112 Stat. 1618","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/102"},"text":"Pub. L. 117–286, § 4(a)(102)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4317"},"text":"136 Stat. 4317","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787cc493-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id787cc494-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id787cc495-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/102/A"},"text":"Pub. L. 117–286, § 4(a)(102)(A)","children":[],"tail":", substituted “chapter 10 of title 5,” for “the Federal Advisory Committee Act (5 U.S.C. App.),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/102/B"},"text":"Pub. L. 117–286, § 4(a)(102)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/b"},"text":"section 1013(b) of title 5","children":[],"tail":"” for “section 14(b) of the Federal Advisory Committee Act (15 U.S.C. App.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":")” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1141/a"},"text":"section 1141(a) of title 20","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id787cc496-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id787cc497-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id787cc498-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory committees established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a committee established by the President or an officer of the Federal Government, such committee is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a committee established by the Congress, its duration is otherwise provided for by law. See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
