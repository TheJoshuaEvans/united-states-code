{"tag":"section","attrib":{"id":"id78411a43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546a–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"546a–5"},"text":"§ 546a–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78411a44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546a–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary for the acquisition of land, interests in land, or structures within the scenic area and on the mainland as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s546a–4"},"text":"section 546a–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546a–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the amounts authorized to be appropriated under subsection (a), there are authorized to be appropriated such sums as may be necessary for the development and implementation of the management plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s546a–1/b"},"text":"section 546a–1(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78411a46-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/431/s8"},"text":"Pub. L. 106–431, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-06"},"text":"Nov. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1907"},"text":"114 Stat. 1907","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
