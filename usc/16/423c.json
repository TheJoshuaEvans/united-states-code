{"tag":"section","attrib":{"id":"id77898a21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423c"},"text":null,"children":[{"tag":"num","attrib":{"value":"423c"},"text":"§ 423c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be the duties of the commissioners, under the direction of the Secretary of the Interior, to superintend the opening or repair of such roads as may be necessary to the purposes of the battlefield, and to ascertain and mark with historical tablets or otherwise, as the Secretary of the Interior may determine, all breastworks, earthworks, walls, or other defenses or shelters, lines of battle, location of troops, buildings, and other historical points of interest within the battlefield or in its vicinity, and the said commission in establishing the battlefield shall have authority, under the direction of the Secretary of the Interior, to employ such labor and service at rates to be fixed by the Secretary of the Interior, and to obtain such supplies and materials as may be necessary to carry out the provisions of sections 423, 423a, and 423b to 423h of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77898a22-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-07-03/ch746/s4"},"text":"July 3, 1926, ch. 746, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/822"},"text":"44 Stat. 822","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/603/s1"},"text":"Pub. L. 87–603, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-08-24"},"text":"Aug. 24, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/403"},"text":"76 Stat. 403","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77898a23-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77898a24-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77898a25-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Battlefield” substituted in text for “park” in view of redesignation of Petersburg National Military Park as Petersburg National Battlefield by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/603"},"text":"Pub. L. 87–603","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s423h–1"},"text":"section 423h–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id77898a26-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id77898a27-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of administrative functions of park, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s423"},"text":"section 423 of this title","children":[],"tail":"."}],"tail":"\n"}]