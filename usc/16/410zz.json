{"tag":"section","attrib":{"id":"id77636502-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410zz"},"text":null,"children":[{"tag":"num","attrib":{"value":"410zz"},"text":"§ 410zz.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77636503-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410zz/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Saguaro National Monument was established by Presidential Proclamation in 1933;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77636504-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410zz/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Tucson Mountain unit was established by Presidential Proclamation in 1961;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77636505-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410zz/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in recognition of the need to provide increased protection for the monument, the boundaries of Tucson Mountain unit were expanded in 1976, and the boundaries of Rincon unit were expanded in 1991;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77636506-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410zz/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Tucson Mountain unit continues to face threats to the integrity of its natural resources, scenic beauty, and habitat protection for which the unit was established;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77636507-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410zz/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" these threats impede opportunities for public enjoyment, education, and safety within the monument, as well as opportunities for solitude within the wilderness areas of the monument designated by Congress in 1976;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77636508-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410zz/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the residential and commercial growth of the greater Tucson, Arizona metropolitan area is causing increasing threats to the monument’s resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77636509-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410zz/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Tucson Mountain unit should be enlarged by the addition of adjacent lands of National Park caliber and Saguaro National Monument should be afforded full recognition and statutory protection as a National Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7763650a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/364/s2"},"text":"Pub. L. 103–364, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3467"},"text":"108 Stat. 3467","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7763650b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7763650c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7763650d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tII/s201/a"},"text":"Pub. L. 116–260, div. FF, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3088"},"text":"134 Stat. 3088","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dFF/tII/s201/a"},"text":"“This section [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410zz–2"},"text":"section 410zz–2 of this title","children":[],"tail":"] may be cited as the ‘Saguaro National Park Boundary Expansion Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7763650e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/364/s1"},"text":"Pub. L. 103–364, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3467"},"text":"108 Stat. 3467","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/364/s1"},"text":"“This Act [enacting this subchapter and amending provisions listed in a table of National Monuments Established Under Presidential Proclamation set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s431"},"text":"section 431 of this title","children":[],"tail":"] may be cited as the ‘Saguaro National Park Establishment Act of 1994’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
