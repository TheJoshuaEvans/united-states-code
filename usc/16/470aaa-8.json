{"tag":"section","attrib":{"id":"id78188323-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"470aaa–8"},"text":"§ 470aaa–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Information concerning the nature and specific location of a paleontological resource shall be exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" and any other law unless the Secretary determines that disclosure would—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78188324-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–8/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78188325-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–8/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not create risk of harm to or theft or destruction of the resource or the site containing the resource; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78188326-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–8/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in accordance with other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78188327-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVI/s6309"},"text":"Pub. L. 111–11, title VI, § 6309","children":[],"tail":", "},{"tag":"date","attri