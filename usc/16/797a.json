{"tag":"section","attrib":{"id":"id78a07847-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s797a"},"text":null,"children":[{"tag":"num","attrib":{"value":"797a"},"text":"§ 797a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional authorization for permits, licenses, leases, or authorizations for dams, conduits, reservoirs, etc., within national parks or monuments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1921-03-03"},"text":"March 3, 1921","children":[],"tail":", no permit, license, lease, or authorization for dams, conduits, reservoirs, power houses, transmission lines, or other works for storage or carriage of water, or for the development, transmission, or utilization of power within the limits as constituted, "},{"tag":"date","attrib":{"date":"1921-03-03"},"text":"March 3, 1921","children":[],"tail":", of any national park or national monument shall be granted or made without specific authority of Congress."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78a07848-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-03-03/ch129"},"text":"Mar. 3, 1921, ch. 129","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1353"},"text":"41 Stat. 1353","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78a07849-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78a0784a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78a0784b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions repealing so much of this chapter “as authorizes licensing such uses of existing national parks and national monuments by the Federal Power Commission” have been omitted.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Federal Power Act which generally comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78a0784c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78a0784d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-26/ch687/tII/s212"},"text":"Act Aug. 26, 1935, ch. 687, title II, § 212","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/847"},"text":"49 Stat. 847","children":[],"tail":", provided that nothing in this chapter should be construed to repeal or amend the provisions of the act approved "},{"tag":"date","attrib":{"date":"1921-03-03"},"text":"Mar. 3, 1921","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/41/1353"},"text":"41 Stat. 1353","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s797a"},"text":"16 U.S.C. 797a","children":[],"tail":"] or the provisions of any other Act relating to national parks and national monuments. See note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s791"},"text":"section 791 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
