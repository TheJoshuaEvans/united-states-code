{"tag":"section","attrib":{"id":"id78032704-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ooo–6"},"text":"§ 460ooo–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78032705-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78032706-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority to conservation easements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In acquiring lands or interest in lands under this section, the Secretary shall give priority to such acquisitions in the form of conservation easements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78032707-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to acquire privately held lands or interest in lands within the boundaries of the Acquisition Planning District only from a willing seller through donation, exchange, or purchase.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78032708-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo–6/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" County lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to acquire county lands or interest in lands within the boundaries of the Acquisition Planning District only with the consent of the county through donation, exchange, or purchase.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78032709-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo–6/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State lands","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7803270a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo–6/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to acquire lands or interest in lands owned by the State of Arizona located within the boundaries of the Acquisition Planning District only with the consent of the State and in accordance with State law, by donation, exchange, or purchase.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7803270b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo–6/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As consideration for the acquisitions by the United States of lands or interest in lands under this paragraph, the Secretary shall pay fair market value for such lands or shall convey to the State of Arizona all or some interest in Federal lands (including buildings and other improvements on such lands or other Federal property other than real property) or any other asset of equal value within the State of Arizona.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7803270c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo–6/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All Federal agencies are authorized to transfer jurisdiction of Federal lands or interest in lands (including buildings and other improvements on such lands or other Federal property other than real property) or any other asset within the State of Arizona to the Bureau of Land Management for the purpose of acquiring lands or interest in lands as provided for in this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7803270d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of acquired lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Lands acquired under this section shall, upon acquisition, become part of the Conservation Area and shall be administered as part of the Conservation Area. These lands shall be managed in accordance with this subchapter, other applicable laws, and the management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7803270e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/538/s7"},"text":"Pub. L. 106–538, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-06"},"text":"Dec. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2567"},"text":"114 Stat. 2567","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7803270f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78032710-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78032711-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Land Exchange and Conservation in Arizona","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to land exchange and conservation in southeastern Arizona, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539p"},"text":"section 539p of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
