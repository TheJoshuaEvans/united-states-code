{"tag":"section","attrib":{"id":"id772549c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g"},"text":null,"children":[{"tag":"num","attrib":{"value":"272g"},"text":"§ 272g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land exchange involving school trust land","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id772549c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id772549ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1998-10-30"},"text":"October 30, 1998","children":[],"tail":", and in accordance with this section, the State of Utah offers to transfer all right, title, and interest of the State in and to the school trust land described in subsection (b)(1) to the United States, the Secretary—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id772549cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall accept the offer on behalf of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id772549cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after the date of acceptance, shall convey to the State of Utah all right, title, and interest of the United States in and to the land described in subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id772549cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simultaneous conveyances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Title to the school trust land shall be conveyed at the same time as conveyance of title to the Federal lands by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id772549ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Valid existing rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The land exchange under this section shall be subject to valid existing rights, and each party shall succeed to the rights and obligations of the other party with respect to any lease, right-of-way, or permit encumbering the exchanged land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id772549cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of parcels","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id772549d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State conveyance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The school trust land to be conveyed by the State of Utah under subsection (a) is section 16, Township 23 South, Range 22 East of the Salt Lake base and meridian.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id772549d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal conveyance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal land to be conveyed by the Secretary consists of approximately 639 acres located in section 1, Township 25 South, Range 18 East, Salt Lake base and meridian, and more fully described as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id772549d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lots 1 through 12.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id772549d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The S½N½ of such section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id772549d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The N½N½N½S½ of such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id772549d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equivalent value","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal land described in paragraph (2) shall be considered to be of equivalent value to that of the school trust land described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id772549d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management by State","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id772549d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least 60 days before undertaking or permitting any surface disturbing activities to occur on land acquired by the State of Utah under this section, the State shall consult with the Utah State Office of the Bureau of Land Management concerning the extent and impact of such activities on Federal land and resources and conduct, in a manner consistent with Federal law, inventory, mitigation, and management activities in connection with any archaeological, paleontological, and cultural resources located on the acquired lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id772549d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of existing uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that it is consistent with applicable law governing the use and disposition of State school trust land, the State shall preserve existing grazing, recreational, and wildlife uses of the acquired lands in existence on ","children":[{"tag":"date","attrib":{"date":"1998-10-30"},"text":"October 30, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id772549d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272g/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities authorized by management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection precludes the State of Utah from authorizing or undertaking a surface or mineral activity that is authorized by a land management plan for the acquired land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id772549da-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/155/s8"},"text":"Pub. L. 92–155, § 8","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/329/s2/e/2"},"text":"Pub. L. 105–329, § 2(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3062"},"text":"112 Stat. 3062","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/176/tIII/s302"},"text":"Pub. L. 106–176, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-03-10"},"text":"Mar. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/32"},"text":"114 Stat. 32","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id772549db-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id772549dc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id772549dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/176/s302/1"},"text":"Pub. L. 106–176, § 302(1)","children":[],"tail":", substituted “located in section 1, Township 25 South, Range 18 East, Salt Lake base and meridian, and more fully described as follows:” and subpars. (A) to (C) for “, described as lots 1 through 12 located in the S½N½ and the N½N½N½S½ of section 1, Township 25 South, Range 18 East, Salt Lake base and meridian.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/176/s302/2"},"text":"Pub. L. 106–176, § 302(2)","children":[],"tail":", struck out heading and text of subsec. (d). Text read as follows: “Administrative actions necessary to implement the land exchange under this section shall be completed not later than 180 days after "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"October 30, 1998","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id772549de-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id772549df-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effect on School Trust Land","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/329/s2/e/1"},"text":"Pub. L. 105–329, § 2(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3062"},"text":"112 Stat. 3062","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/329/s2/e/1"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds that—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a parcel of State school trust land, more specifically described as section 16, township 23 south, range 22 east, of the Salt Lake base and meridian, is partially contained within the Lost Spring Canyon Addition included within the boundaries of Arches National Park by the amendment by subsection (a) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s272"},"text":"section 272 of this title","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the parcel was originally granted to the State of Utah for the purpose of generating revenue for the public schools through the development of natural and other resources located on the parcel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the interest of the State of Utah and the United States for the parcel to be exchanged for Federal land of equivalent value outside the Lost Spring Canyon Addition to permit Federal management of all lands within the Lost Spring Canyon Addition.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
