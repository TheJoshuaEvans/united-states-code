{"tag":"section","attrib":{"id":"id79c37479-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3705"},"text":null,"children":[{"tag":"num","attrib":{"value":"3705"},"text":"§ 3705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteer status","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior or the Secretary of Commerce may accept, without regard to the civil service classification laws, rules, or regulations, the services of the Foundation, the Board, and the officers and employees of the Board, without compensation from the Department of the Interior or the Department of Commerce, as volunteers in the performance of the functions authorized herein, in the manner provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s742f/c"},"text":"section 742f(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79c3747a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/244/s6"},"text":"Pub. L. 98–244, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-03-26"},"text":"Mar. 26, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/109"},"text":"98 Stat. 109","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/408/tII/s203/c/2"},"text":"Pub. L. 106–408, title II, § 203(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1779"},"text":"114 Stat. 1779","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c3747b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c3747c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79c3747d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/408"},"text":"Pub. L. 106–408","children":[],"tail":" substituted “Secretary of the Interior or the Secretary of Commerce” for “Secretary” and inserted “or the Department of Commerce” after “Department of the Interior”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
