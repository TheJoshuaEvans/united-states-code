{"tag":"section","attrib":{"id":"id79c374ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3710"},"text":null,"children":[{"tag":"num","attrib":{"value":"3710"},"text":"§ 3710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter authorizes the Foundation to perform any function the exclusive authority for which is provided to the National Park Foundation by subchapter II of chapter 1011 of title 54.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79c374af-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/244/s11"},"text":"Pub. L. 98–244, § 11","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/408/tII/s208"},"text":"Pub. L. 106–408, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1781"},"text":"114 Stat. 1781","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s5/d/35"},"text":"Pub. L. 113–287, § 5(d)(35)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3267"},"text":"128 Stat. 3267","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/188/tI/s107/d"},"text":"Pub. L. 116–188, title I, § 107(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/920"},"text":"134 Stat. 920","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c374b0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"