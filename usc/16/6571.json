{"tag":"section","attrib":{"id":"id7a120994-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6571"},"text":null,"children":[{"tag":"num","attrib":{"value":"6571"},"text":"§ 6571.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of healthy forests reserve program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a120995-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6571/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall establish the healthy forests reserve program for the purpose of restoring and enhancing forest ecosystems—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120996-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6571/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the recovery of threatened and endangered species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120997-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6571/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve biodiversity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120998-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6571/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conserve forest land that provides habitat for species described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6572/b"},"text":"section 6572(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120999-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6571/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance carbon sequestration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12099a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6571/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall carry out the healthy forests reserve program in coordination with the Secretary of the Interior and the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a12099b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tV/s501"},"text":"Pub. L. 108–148, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1911"},"text":"117 Stat. 1911","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8407/a/1"},"text":"Pub. L. 115–334, title VIII, § 8407(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4845"},"text":"132 Stat. 4845","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a12099c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a12099d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"childr