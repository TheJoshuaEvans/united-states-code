{"tag":"section","attrib":{"id":"id781882fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"470aaa–4"},"text":"§ 470aaa–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Curation of resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any paleontological resource, and any data and records associated with the resource, collected under a permit, shall be deposited in an approved repository. The Secretary may enter into agreements with non-Federal repositories regarding the curation of these resources, data, and records.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id781882fd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVI/s6305"},"text":"Pub. L. 111–11, title VI, § 6305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1174"},"text":"123 Stat. 1174","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
