{"tag":"section","attrib":{"id":"id796ffd8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1828"},"text":null,"children":[{"tag":"num","attrib":{"value":"1828"},"text":"§ 1828.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign fishing incursions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id796ffd90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1828/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", the Secretary of the department in which the Coast Guard is operating shall provide to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report on steps that the Coast Guard will take to significantly improve the Coast Guard’s detection and interdiction of illegal incursions into the United States exclusive economic zone by foreign fishing vessels."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796ffd91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1828/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific issues to be addressed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id796ffd92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1828/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focus on areas in the exclusive economic zone where the Coast Guard has failed to detect or interdict such incursions in the 4-fiscal-year period beginning with fiscal year 2000, including such areas in the Western/Central Pacific and the Bering Sea; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796ffd93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1828/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an evaluation of the potential use of unmanned aircraft and offshore platforms for detecting or interdicting such incursions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796ffd94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1828/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide biannual reports updating the Coast Guard’s progress in detecting or interdicting such incursions to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id796ffd95-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/tVIII/s804"},"text":"Pub. L. 109–241, title VIII, § 804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/563"},"text":"120 Stat. 563","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id796ffd96-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id796ffd97-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id796ffd98-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Coast Guard and Maritime Transportation Act of 2006, and not as part of the Magnuson-Stevens Fishery Conservation and Management Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id796ffd99-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id796ffd9a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Combination of Fisheries Enforcement Plans and Foreign Fishing Incursion Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/207/s4/b"},"text":"Pub. L. 111–207, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-27"},"text":"July 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2251"},"text":"124 Stat. 2251","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s221/a/5"},"text":"Pub. L. 113–281, title II, § 221(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3037"},"text":"128 Stat. 3037","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/281/tII/s221/a/5"},"text":"“The Secretary of the department in which the Coast Guard is operating shall combine the reports required under section 224 of the Coast Guard and Maritime Transportation Act of 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1861b"},"text":"16 U.S.C. 1861b","children":[],"tail":") and section 804 of the Coast Guard and Maritime Transportation Act of 2006 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1828"},"text":"16 U.S.C. 1828","children":[],"tail":") into a single annual report for fiscal years beginning after fiscal year 2010. No report shall be required under this subsection, including that no report shall be required under section 224 of the Coast Guard and Maritime Transportation Act of 2004 or section 804 of the Coast Guard and Maritime Transportation Act of 2006, for fiscal years beginning after fiscal year 2014.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
