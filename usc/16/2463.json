{"tag":"section","attrib":{"id":"id799d4ea6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2463"},"text":null,"children":[{"tag":"num","attrib":{"value":"2463"},"text":"§ 2463.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of Antarctic mineral resource activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is unlawful for any person to engage in, finance, or otherwise knowingly provide assistance to any Antarctic mineral resource activity.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id799d4ea7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/594/s4"},"text":"Pub. L. 101–594, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2977"},"text":"104 Stat. 2977","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/227/tII/s202/a"},"text":"Pub. L. 104–227, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-02"},"text":"Oct. 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3044"},"text":"110 Stat. 3044","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799d4ea8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799d4ea9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id799d4eaa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/227"},"text":"Pub. L. 104–227","children":[],"tail":" substituted “It” for “Pending a new agreement among the Antarctic Treaty Consultative Parties in force for the United States, to which the Senate has given advice and consent or which is authorized by further legislation by the Congress, which provides an indefinite ban on Antarctic mineral resource activities, it”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
