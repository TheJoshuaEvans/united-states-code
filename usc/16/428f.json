{"tag":"section","attrib":{"id":"id778e44e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s428f"},"text":null,"children":[{"tag":"num","attrib":{"value":"428f"},"text":"§ 428f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Control of battlefield; regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The said Fort Donelson National Battlefield shall be under the control of the Secretary of the Interior, and he is authorized to make all needed regulations for the care of the battlefield. The superintendent of the Fort Donelson National Cemetery shall likewise be the superintendent of and have the custody and care of the Fort Donelson National Battlefield, under the direction of the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778e44e3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-03-26/ch248/s7"},"text":"Mar. 26, 1928, ch. 248, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/368"},"text":"45 Stat. 368","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/738"},"text":"Pub. L. 86–738","children":[],"tail":", §§ 4, 5, "},{"tag":"date","attrib":{"date":"1960-09-08"},"text":"Sept. 8, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/876"},"text":"74 Stat. 876","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778e44e4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id778e44e5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id778e44e6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Fort Donelson National Battlefield” and “battlefield” substituted in text for “Fort Donelson National Military Park” and “park”, respectively, in view of redesignation of Fort Donelson National Military Park as Fort Donelson National Battlefield by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/738"},"text":"Pub. L. 86–738","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s428n"},"text":"section 428n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id778e44e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id778e44e8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of administrative functions of park, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s428"},"text":"section 428 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
