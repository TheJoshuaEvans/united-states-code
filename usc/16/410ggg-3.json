{"tag":"section","attrib":{"id":"id77719521-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ggg–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ggg–3"},"text":"§ 410ggg–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77719522-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ggg–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77719523-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ggg–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oral histories, preservation, and visitor services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to conduct oral histories and to carry out the preservation, interpretation, education, and other essential visitor services provided for by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77719524-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ggg–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Artifacts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $1,000,000 for the acquisition and curation of historical artifacts related to the park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77719525-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ggg–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property acquisition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to acquire the properties listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ggg–1/e/2"},"text":"section 410ggg–1(e)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77719526-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ggg–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of funds for S.S. RED OAK VICTORY","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds authorized to be appropriated by this section may be used for the operation, maintenance, or preservation of the vessel S.S. RED OAK VICTORY.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77719527-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/352/s5"},"text":"Pub. L. 106–352, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-24"},"text":"Oct. 24, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1372"},"text":"114 Stat. 1372","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
