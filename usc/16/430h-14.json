{"tag":"section","attrib":{"id":"id779570ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430h–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"430h–14"},"text":"§ 430h–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vicksburg National Military Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id779570bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430h–14/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of land","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id779570bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430h–14/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior (referred to in this section as the “Secretary”) may acquire the land or any interests in land within the area identified as “Modified Core Battlefield” for the Port Gibson Unit, the Champion Hill Unit, and the Raymond Unit as generally depicted on the map entitled “Vicksburg National Military Park—Proposed Battlefield Additions”, numbered 306/100986A (4 sheets), and dated July 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id779570bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430h–14/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods of acquisition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Land may be acquired under paragraph (1) by donation, purchase with donated or appropriated funds, or exchange, except that land owned by the State of Mississippi or any political subdivisions of the State may be acquired only by donation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id779570be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430h–14/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map described in subsection (a)(1) shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id779570bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430h–14/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the acquisition of land by the Secretary under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id779570c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430h–14/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquired land shall be added to Vicksburg National Military Park;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id779570c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430h–14/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the boundary of the Vicksburg National Military Park shall be adjusted to reflect the acquisition of the land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id779570c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430h–14/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquired land shall be administered as part of the Vicksburg National Military Park in accordance with applicable laws (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id779570c3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXX/s3044"},"text":"Pub. L. 113–291, div. B, title XXX, § 3044","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3798"},"text":"128 Stat. 3798","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
