{"tag":"section","attrib":{"id":"id79f09e75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4501"},"text":null,"children":[{"tag":"num","attrib":{"value":"4501"},"text":"§ 4501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forestry and related natural resource assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f09e76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Focus of activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To achieve the maximum impact from activities undertaken under the authority of this chapter, the Secretary shall focus such activities on the key countries which could have a substantial impact on emissions of greenhouse gases related to global warming.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f09e77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for international forestry activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In support of forestry and related natural resource activities outside of the United States and its territories and possessions, the Secretary of Agriculture may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f09e78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4501/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide assistance that promotes sustainable development and global environmental stability, including assistance for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f09e79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4501/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conservation and sustainable management of forest land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09e7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4501/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forest plantation technology and tree improvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09e7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4501/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rehabilitation of cutover lands, eroded watersheds, and areas damaged by wildfires or other natural disasters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09e7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4501/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevention and control of insects, diseases, and other damaging agents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09e7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4501/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparedness planning, training, and operational assistance to combat natural disasters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09e7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4501/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more complete utilization of forest products leading to resource conservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09e7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4501/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" range protection and enhancement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09e80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4501/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wildlife and fisheries habitat protection and improvement;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09e81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4501/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" share technical, managerial, extension, and administrative skills related to public and private natural resource administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09e82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4501/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide education and training opportunities to promote the transfer and utilization of scientific information and technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09e83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4501/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in scientific exchange and cooperative research with foreign governmental, educational, technical and research institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09e84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4501/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with domestic and international organizations that further international programs for the management and protection of forests, rangelands, wildlife and fisheries, and related natural resource activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f09e85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall undertake the activities described in subsection (b), in countries that receive assistance from the Agency for International Development only at the request, or with the concurrence, of the Administrator of the Agency for International Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f09e86-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513/tVI/s602"},"text":"Pub. L. 101–513, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2070"},"text":"104 Stat. 2070","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/574/s2/b/1"},"text":"Pub. L. 102–574, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4596"},"text":"106 Stat. 4596","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f09e87-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f09e88-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79f09e89-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b), was in the original “this title”, meaning title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513"},"text":"Pub. L. 101–513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2070"},"text":"104 Stat. 2070","children":[],"tail":", which is classified principally to this chapter. For complete classification of title VI to the Code, see Short Title note set out below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79f09e8a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/574"},"text":"Pub. L. 102–574","children":[],"tail":" struck out “(hereinafter referred to in this chapter as the Secretary)” after “Agriculture” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79f09e8b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79f09e8c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/574/s1"},"text":"Pub. L. 102–574, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4593"},"text":"106 Stat. 4593","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/574/s1"},"text":"“This Act [enacting sections 4502a and 4503a to 4503d of this title, amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4503"},"text":"section 4503 of this title","children":[],"tail":", and enacting provisions set out as notes under sections 4502a and 4503a of this title] may be cited as the ‘Hawaii Tropical Forest Recovery Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79f09e8d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513/tVI/s601"},"text":"Pub. L. 101–513, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2070"},"text":"104 Stat. 2070","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/513/tVI/s601"},"text":"“This title [enacting this chapter and amending sections 1641, 1643, 2101, and 2109 of this title] may be cited as the ‘International Forestry Cooperation Act of 1990’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
