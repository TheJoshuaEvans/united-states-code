{"tag":"section","attrib":{"id":"id778bd45d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s426h"},"text":null,"children":[{"tag":"num","attrib":{"value":"426h"},"text":"§ 426h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ascertaining and marking lines of battle","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be lawful for the authorities of any State having troops engaged in the battle of Stones River to enter upon the lands and approaches of the Stones River National Battlefield for the purpose of ascertaining and marking the lines of battle of troops engaged therein: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That before any such lines are permanently designated, the position of the lines and the proposed methods of marking them by monuments, tablets, or otherwise shall be submitted to the Secretary of the Interior, and shall first receive the written approval of the Secretary."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778bd45e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-03/ch374/s9"},"text":"Mar. 3, 1927, ch. 374, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1401"},"text":"44 Stat. 1401","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/443/s2"},"text":"Pub. L. 86–443, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-04-22"},"text":"Apr. 22, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/82"},"text":"74 Stat. 82","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778bd45f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id778bd460-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id778bd461-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Stones River National Battlefield” substituted in text for “Stones River National Park” in view of redesignation of Stones River National Military Park as Stones River National Battlefield by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/443"},"text":"Pub. L. 86–443","children":[],"tail":". See section 426"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id778bd462-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id778bd463-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of administrative functions of park, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s426"},"text":"section 426 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
