{"tag":"section","attrib":{"id":"id7708c146-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s142"},"text":null,"children":[{"tag":"num","attrib":{"value":"142"},"text":"§ 142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Control; regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Wind Cave National Park shall be under the exclusive control of the Secretary of the Interior, whose duty it shall be to prescribe such rules and regulations and establish such service as he may deem necessary for the care and management of the same.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7708c147-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1903-01-09/ch63/s2"},"text":"Jan. 9, 1903, ch. 63, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/765"},"text":"32 Stat. 765","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7708c148-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7708c149-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7708c14a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section is a part of section 2 of act ","children":[{"tag":"date","attrib":{"date":"1903-01-09"},"text":"Jan. 9, 1903","children":[],"tail":". The other part of section 2 of said act is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s141"},"text":"section 141 of this title","children":[],"tail":". See note under section 141."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
