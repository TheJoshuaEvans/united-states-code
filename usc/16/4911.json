{"tag":"section","attrib":{"id":"id79f7cbcf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4911"},"text":null,"children":[{"tag":"num","attrib":{"value":"4911"},"text":"§ 4911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any prohibition, suspension, or quota under this chapter on the importation of a species of exotic bird, the Secretary may, through the issuance of import permits, authorize the importation of a bird of the species if the Secretary determines that such importation is not detrimental to the survival of the species and the bird is being imported exclusively for any of the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cbd0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4911/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Scientific research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cbd1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4911/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As a personally owned pet of an individual who is returning to the United States after being continuously out of the country for a minimum of one year, except that an individual may not import more than 2 exotic birds under this paragraph in any year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cbd2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4911/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Zoological breeding or display programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cbd3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4911/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Cooperative breeding programs that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cbd4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4911/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed to promote the conservation of the species and maintain the species in the wild by enhancing the propagation and survival of the species; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cbd5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4911/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developed and administered by, or in conjunction with, an avicultural, conservation, or zoological organization that meets standards developed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f7cbd6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tI/s112"},"text":"Pub. L. 102–440, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2230"},"text":"106 Stat. 2230","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
