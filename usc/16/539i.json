{"tag":"section","attrib":{"id":"id782e074f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539i"},"text":null,"children":[{"tag":"num","attrib":{"value":"539i"},"text":"§ 539i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fossil Ridge Recreation Management Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id782e0750-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id782e0751-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to conserve, protect, and enhance the scenic, wildlife, recreational, and other natural resource values of the Fossil Ridge area, there is hereby established the Fossil Ridge Recreation Management Area (hereinafter referred to as the “recreation management area”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id782e0752-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The recreation management area shall consist of certain lands in the Gunnison National Forest, Colorado, which comprise approximately 43,900 acres, as generally depicted as “Area A” on a map entitled “Fossil Ridge Wilderness Proposal”, dated January, 1993.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id782e0753-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall administer the recreation management area in accordance with this section and the laws and regulations generally applicable to the National Forest System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id782e0754-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to valid existing rights, all lands within the recreation management area are hereby withdrawn from all forms of entry, appropriation, or disposal under the public land laws, from location, entry, and patent under the mining laws, and from disposition under the mineral and geothermal leasing laws, including all amendments thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id782e0755-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timber harvesting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No timber harvesting shall be allowed within the recreation management area except to the extent that would be permitted in wilderness under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1133/d/1"},"text":"section 1133(d)(1) of this title","children":[],"tail":" for necessary control of fire, insects, and diseases, and for public safety."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id782e0756-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539i/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Livestock grazing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The designation of the recreation management area shall not be construed to prohibit, or change the administration of, the grazing of livestock within the recreation management area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id782e0757-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539i/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No developed campgrounds shall be constructed within the recreation management area. After ","children":[{"tag":"date","attrib":{"date":"1993-08-13"},"text":"August 13, 1993","children":[],"tail":", no new roads or trails may be constructed within the recreation management area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id782e0758-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539i/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Off-road recreation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Motorized travel shall be permitted within the recreation management area only on those established trails and routes existing as of ","children":[{"tag":"date","attrib":{"date":"1991-07-01"},"text":"July 1, 1991","children":[],"tail":", on which such travel was permitted as of such date, except that other trails and routes may be used where necessary for administrative purposes or to respond to an emergency. No later than one year after "},{"tag":"date","attrib":{"date":"1993-08-13"},"text":"August 13, 1993","children":[],"tail":", the Secretary shall identify such routes and trails and shall prepare and make available to the public a map showing such routes and trails. Nothing in this subsection shall be construed as precluding the Secretary from closing any trail or route from use for purposes of resource protection or public safety."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id782e0759-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/77/s5"},"text":"Pub. L. 103–77, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-13"},"text":"Aug. 13, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/760"},"text":"107 Stat. 760","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id782e075a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id782e075b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id782e075c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/77/s1/a"},"text":"Pub. L. 103–77, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-13"},"text":"Aug. 13, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/756"},"text":"107 Stat. 756","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/77/s1/a"},"text":"“This Act [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539j"},"text":"section 539j of this title","children":[],"tail":", enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539j"},"text":"section 539j of this title","children":[],"tail":", and enacting and amending provisions listed in a table of Wilderness Areas set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"section 1132 of this title","children":[],"tail":"] may be cited as the ‘Colorado Wilderness Act of 1993’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
