{"tag":"section","attrib":{"id":"id7a38309d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461"},"text":null,"children":[{"tag":"num","attrib":{"value":"8461"},"text":"§ 8461.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership agreements to modernize federally owned campgrounds, resorts, cabins, and visitor centers on Federal recreational lands and waters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a38309e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a38309f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered activity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered activity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3830a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a capital improvement, including the construction, reconstruction, and nonroutine maintenance of any structure, infrastructure, or improvement, relating to the operation of, or access to, a covered recreation facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3830a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity necessary to operate or maintain a covered recreation facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3830a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered recreation facility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered recreation facility” means a federally owned campground, resort, cabin, or visitor center that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3830a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in existence on ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3830a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" located on Federal recreational lands and waters administered by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3830a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief of the Forest Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3830a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3830a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3830a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of State, Tribal, or local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3830a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3830aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3830ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries shall establish a pilot program under which the Secretary concerned may enter into an agreement with, or issue or amend a land use authorization to, an eligible entity to allow the eligible entity to carry out covered activities relating to a covered recreation facility, subject to the requirements of this section and the terms of any relevant land use authorization, regardless of whether the eligible entity holds, on ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", an authorization to be a concessionaire for the covered recreation facility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3830ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum number of agreements or land use authorizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary concerned shall enter into at least 1 agreement or land use authorization under subsection (b) in—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3830ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of the National Forest System in each region of the National Forest System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3830ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal recreational lands and waters administered by the Director of the Bureau of Land Management in not fewer than 5 States in which the Bureau of Land Management administers Federal recreational lands and waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3830af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3830b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before entering into an agreement or issuing a land use authorization under subsection (b), an eligible entity shall submit to the Secretary concerned a development plan that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3830b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes investments in the covered recreation facility to be made by the eligible entity during the first 3 years of the agreement or land use authorization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3830b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes annual maintenance spending to be made by the eligible entity for each year of the agreement or land use authorization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3830b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any other terms and conditions determined to be necessary or appropriate by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3830b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements and land use authorizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement or land use authorization under subsection (b) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3830b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be for a term of not more than 30 years, commensurate with the level of investment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3830b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that, not later than 3 years after the date on which the Secretary concerned enters into the agreement or issues or amends the land use authorization, the applicable eligible entity shall expend, place in an escrow account for the eligible entity to expend, or deposit in a special account in the Treasury for expenditure by the Secretary concerned, without further appropriation, for covered activities relating to the applicable covered recreation facility, an amount or specified percentage, as determined by the Secretary concerned, which shall be equal to not less than $500,000, of the anticipated receipts for the term of the agreement or land use authorization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3830b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the eligible entity to operate and maintain the covered recreation facility and any associated infrastructure designated by the Secretary concerned in a manner acceptable to the Secretary concerned and the eligible entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3830b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include any terms and conditions that the Secretary concerned determines to be necessary for a special use permit issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s580d"},"text":"section 580d of this title","children":[],"tail":", including the payment described in subparagraph (E) or the Federal Land Policy and Management Act of 1976 ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.), as applicable;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3830b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for payment to the Federal Government of a fee or a sharing of revenue—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3830ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consistent with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a3830bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/2/E/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the land use fee for a special use permit authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s580d"},"text":"section 580d of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a3830bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/2/E/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value to the eligible entity of the rights provided by the agreement or land use authorization, taking into account the capital invested by, and obligations of, the eligible entity under the agreement or land use authorization; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3830bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all or part of which may be offset by the work to be performed at the expense of the eligible entity that is separate from the routine costs of operating and maintaining the applicable covered recreation facility and any associated infrastructure designated by the Secretary concerned, as determined to be appropriate by the Secretary concerned;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3830be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include provisions stating that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3830bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity shall obtain no property interest in the covered recreation facility pursuant to the expenditures of the eligible entity, as required by the agreement or land use authorization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3830c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all structures and other improvements constructed, reconstructed, or nonroutinely maintained by that entity under the agreement or land use authorization on land owned by the United States shall be the property of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3830c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/2/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity shall be solely responsible for any cost associated with the decommissioning or removal of a capital improvement, if needed, at the conclusion of the agreement or land use authorization; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3830c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to any other terms and conditions determined to be necessary or appropriate by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3830c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8461/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land use fee retention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A land use fee paid or revenue shared with the Secretary concerned under an agreement or land use authorization under this section shall be available for expenditure by the Secretary concerned for recreation-related purposes on the unit or area of Federal recreational lands and waters at which the land use fee or revenue is collected, without further appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3830c4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s153"},"text":"Pub. L. 118–234, title I, § 153","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2868"},"text":"138 Stat. 2868","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3830c5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3830c6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a3830c7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in subsec. (d)(2)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
