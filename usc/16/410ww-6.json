{"tag":"section","attrib":{"id":"id7760f40c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ww–6"},"text":"§ 410ww–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination between Secretary and Secretary of Defense","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The decisions concerning the execution of this subchapter as it applies to properties under control of the Secretary of Defense shall be made by such Secretary, in consultation with the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7760f40d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/419/tI/s107"},"text":"Pub. L. 102–419, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2143"},"text":"106 Stat. 2143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/356/s2/c"},"text":"Pub. L. 106–356, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-24"},"text":"Oct. 24, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1392"},"text":"114 Stat. 1392","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7760f40e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7760f40f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7760f410-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/356"},"text":"Pub. L. 106–356","children":[],"tail":" substituted “Secretary of the Interior” for “Secretary of Interior”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
