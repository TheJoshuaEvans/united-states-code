{"tag":"section","attrib":{"id":"id78922013-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"760–4"},"text":"§ 760–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of trout hatchery at Pittsford, Vermont","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall develop, reconstruct, equip, operate, and maintain the Federal fish hatchery, known as the Holden trout hatchery, at Pittsford, Vermont, in accordance with the program established by the Fish and Wildlife Service, Department of the Interior, for the improvement of such hatchery.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78922014-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch845/s1"},"text":"Aug. 1, 1956, ch. 845, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/897"},"text":"70 Stat. 897","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78922015-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78922016-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id78922017-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8/dE/tI/s116"},"text":"Pub. L. 111–8, div. E, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/724"},"text":"123 Stat. 724","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/8/dE/tI/s116"},"text":"“The Pittsford National Fish Hatchery in Chittenden, Vermont is hereby renamed the Dwight D. Eisenhower National Fish Hatchery.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78922018-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2 of act ","children":[{"tag":"date","attrib":{"date":"1956-08-01"},"text":"Aug. 1, 1956","children":[],"tail":", authorized the appropriation of $220,000 to carry out the provisions of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
