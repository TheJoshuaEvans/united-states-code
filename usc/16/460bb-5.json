{"tag":"section","attrib":{"id":"id77d81f40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bb–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"460bb–5"},"text":"§ 460bb–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; limitation; adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to carry out the provisions of this subchapter, but not more than $61,610,000 plus $15,500,000 shall be appropriated for the acquisition of lands and interests in lands. There are authorized to be appropriated not more than $58,000,000 (May 1971 prices) for the development of the recreation area, plus or minus such amounts, if any, as may be justified by reason of ordinary fluctuations in construction costs as indicated by engineering cost indices applicable to the type of construction involved herein said total development ceiling to be reduced by $10,000,000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77d81f41-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/589/s6"},"text":"Pub. L. 92–589, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1303"},"text":"86 Stat. 1303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/199/tI/s103/b"},"text":"Pub. L. 96–199, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-05"},"text":"Mar. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/68"},"text":"94 Stat. 68","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77d81f42-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77d81f43-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77d81f44-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/199"},"text":"Pub. L. 96–199","children":[],"tail":" inserted “plus $15,500,000” after “$61,610,000” and “said total development ceiling to be reduced by $10,000,000” after “type of construction involved herein”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
