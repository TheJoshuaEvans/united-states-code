{"tag":"section","attrib":{"id":"id78438ad4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s552"},"text":null,"children":[{"tag":"num","attrib":{"value":"552"},"text":"§ 552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent to agreement by States for conservation of forests and water supply","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Consent of the Congress of the United States is given to each of the several States of the Union to enter into any agreement or compact, not in conflict with any law of the United States, with any other State or States for the purpose of conserving the forests and the water supply of the States entering into such agreement or compact.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78438ad5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-01/ch186/s1"},"text":"Mar. 1, 1911, ch. 186, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/961"},"text":"36 Stat. 961","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78438ad6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78438ad7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id78438ad8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-01/ch186"},"text":"Act Mar. 1, 1911, ch. 186","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/961"},"text":"36 Stat. 961","children":[],"tail":", which enacted this section, former sections 513 and 514 of this title, and sections 515 to 519, 521, and 563 of this title and amended sections 480 and 500 of this title, is popularly known as the Weeks Law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
