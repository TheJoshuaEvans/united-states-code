{"tag":"section","attrib":{"id":"id785b593b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620"},"text":null,"children":[{"tag":"num","attrib":{"value":"620"},"text":"§ 620.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id785b593c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id785b593d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Timber is essential to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id785b593e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Forests, forest resources, and the forest environment are exhaustible natural resources that require efficient and effective conservation efforts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id785b593f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the interest of conserving those resources, the United States has set aside millions of acres of otherwise harvestable timberlands in the western United States, representing well over 100,000,000,000 board feet of otherwise harvestable timber.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id785b5940-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In recent years, administrative, statutory, or judicial action has been taken to set aside an increased amount of otherwise harvestable timberlands for conservation purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id785b5941-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the next few months and years, additional amounts of otherwise harvestable timberlands may be set aside for conservation purposes, pursuant to the Endangered Species Act of 1973 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.], the National Forest Management Act of 1976, or other expected statutory, administrative, and judicial actions."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id785b5942-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is evidence of a shortfall in the supply of unprocessed timber in the western United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id785b5943-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is reason to believe that any shortfall which may already exist may worsen unless action is taken.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id785b5944-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In conjunction with the broad conservation actions expected in the next few months and years, conservation action is necessary with respect to exports of unprocessed timber.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id785b5945-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of sections 620 to 620j of this title are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id785b5946-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the conservation of forest resources in conjunction with State and Federal resources management plans, and other actions or decisions, affecting the use of forest resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id785b5947-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take action essential for the acquisition and distribution of forest resources or products in short supply in the western United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id785b5948-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take action necessary, to meet the goals of Article XI 2.(a) of the GATT 1994 (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/1/B"},"text":"section 3501(1)(B) of title 19","children":[],"tail":"), to ensure sufficient supplies of certain forest resources or products which are essential to the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id785b5949-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to continue and refine the existing Federal policy of restricting the export of unprocessed timber harvested from Federal lands in the western United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id785b594a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to effect measures aimed at meeting these objectives in conformity with the obligations of the United States under the WTO Agreement and the multilateral trade agreements (as such terms are defined in paragraphs (9) and (4), respectively, of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501"},"text":"section 3501 of title 19","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id785b594b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/tIV/s488"},"text":"Pub. L. 101–382, title IV, § 488","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-20"},"text":"Aug. 20, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/714"},"text":"104 Stat. 714","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/36/tI/s1002/a/1"},"text":"Pub. L. 106–36, title I, § 1002(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-06-25"},"text":"June 25, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/132"},"text":"113 Stat. 132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id785b594c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id785b594d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id785b594e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Endangered Species Act of 1973, referred to in subsec. (a)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/884"},"text":"87 Stat. 884","children":[],"tail":", which is classified generally to chapter 35 (§ 1531 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"section 1531 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Forest Management Act of 1976, referred to in subsec. (a)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/588"},"text":"Pub. L. 94–588","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2949"},"text":"90 Stat. 2949","children":[],"tail":", which enacted sections 472a, 521b, 1600, and 1611 to 1614 of this title, amended sections 500, 515, 516, 518, 576b, 581h, and 1601 to 1610 of this title, repealed sections 476, 513, and 514 of this title, and enacted provisions set out as notes under sections 476, 513, 528, 594–2, and 1600 of this title. For complete classification of this Act to the Code, see Short Title of 1976 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1600"},"text":"section 1600 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 620 to 620j of this title, referred to in subsec. (b), was in the original “this title”, meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382"},"text":"Pub. L. 101–382","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-20"},"text":"Aug. 20, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/714"},"text":"104 Stat. 714","children":[],"tail":", known as the Forest Resources Conservation and Shortage Relief Act of 1990, which enacted sections 620 to 620j of this title and provisions set out as notes below. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id785b594f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/36/s1002/a/1/A"},"text":"Pub. L. 106–36, § 1002(a)(1)(A)","children":[],"tail":", substituted “GATT 1994 (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/1/B"},"text":"section 3501(1)(B) of title 19","children":[],"tail":")” for “General Agreement on Tariffs and Trade”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/36/s1002/a/1/B"},"text":"Pub. L. 106–36, § 1002(a)(1)(B)","children":[],"tail":", substituted “WTO Agreement and the multilateral trade agreements (as such terms are defined in paragraphs (9) and (4), respectively, of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501"},"text":"section 3501 of title 19","children":[],"tail":")” for “General Agreement on Tariffs and Trade”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id785b5950-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id785b5951-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/tIV/s494"},"text":"Pub. L. 101–382, title IV, § 494","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-20"},"text":"Aug. 20, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/725"},"text":"104 Stat. 725","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/382/tIV/s494"},"text":"“Except as otherwise provided in this title, the provisions of this title [enacting this section and sections 620a to 620j of this title and provisions set out as a note below] take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-08-20"},"text":"Aug. 20, 1990","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id785b5952-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/83/tVI/s601"},"text":"Pub. L. 105–83, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-14"},"text":"Nov. 14, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1617"},"text":"111 Stat. 1617","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/83/tVI/s601"},"text":"“This title [amending sections 620b to 620f of this title] may be cited as the ‘Forest Resources Conservation and Shortage Relief Act of 1997’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id785b5953-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/45/s1"},"text":"Pub. L. 103–45, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-07-01"},"text":"July 1, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/223"},"text":"107 Stat. 223","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/45/s1"},"text":"“This Act [amending sections 620c and 620d of this title and enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s620c"},"text":"section 620c of this title","children":[],"tail":"] may be cited as the ‘Forest Resources Conservation and Shortage Relief Amendments Act of 1993’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id785b5954-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/tIV/s487"},"text":"Pub. L. 101–382, title IV, § 487","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-20"},"text":"Aug. 20, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/714"},"text":"104 Stat. 714","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/382/tIV/s487"},"text":"“This title [enacting this section and sections 620a to 620j of this title and provisions set out as a note above] may be cited as the ‘Forest Resources Conservation and Shortage Relief Act of 1990’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
