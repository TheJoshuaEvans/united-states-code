{"tag":"section","attrib":{"id":"id7a29ff0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601"},"text":null,"children":[{"tag":"num","attrib":{"value":"7601"},"text":"§ 7601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29ff0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a29ff0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29ff0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Co-Chairs of the Task Force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Co-Chairs of the Task Force” means the Secretary of State, the Secretary of the Interior, and the Attorney General, as established pursuant to Executive Order 13648.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community conservation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “community conservation” means an approach to conservation involving local communities that recognizes the rights of local people to manage, or benefit directly and indirectly from wildlife and other natural resources in a long-term biologically viable manner and includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a29ff12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" devolving management and governance to local communities to create positive conditions for resource use that takes into account current and future ecological requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29ff13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building the capacity of communities for conservation and natural resource management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Country of concern","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “country of concern” means a foreign country specially designated by the Secretary of State pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7621/b"},"text":"section 7621(b) of this title","children":[],"tail":" as a major source of wildlife trafficking products or their derivatives, a major transit point of wildlife trafficking products or their derivatives, or a major consumer of wildlife trafficking products, in which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a29ff15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government has actively engaged in, or knowingly profited from, the trafficking of protected species; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29ff16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government facilitates such trafficking through conduct that may include a persistent failure to make serious and sustained efforts to prevent and prosecute such trafficking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Focus country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “focus country” refers to a foreign country determined by the Secretary of State to be a major source of wildlife trafficking products or their derivatives, a major transit point of wildlife trafficking products or their derivatives, or a major consumer of wildlife trafficking products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defense article; defense service; significant military equipment; training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “defense article”, “defense service”, “significant military equipment”, and “training” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2794"},"text":"section 2794 of title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Implementation Plan” means the Implementation Plan for the National Strategy for Combating Wildlife Trafficking released on ","children":[{"tag":"date","attrib":{"date":"2015-02-11"},"text":"February 11, 2015","children":[],"tail":", a modification of that plan, or a successor plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Strategy” means the National Strategy for Combating Wildlife Trafficking published on ","children":[{"tag":"date","attrib":{"date":"2014-02-11"},"text":"February 11, 2014","children":[],"tail":", a modification of that strategy, or a successor strategy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National wildlife services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national wildlife services” refers to the ministries and government bodies designated to manage matters pertaining to wildlife management, including poaching or trafficking, in a focus country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “security force” means a military, law enforcement, gendarmerie, park ranger, or any other security force with a responsibility for protecting wildlife and natural habitats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task Force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Task Force” means the Presidential Task Force on Wildlife Trafficking, as established by Executive Order 13648 (78 Fed. Reg. 40621) and modified by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7631"},"text":"section 7631 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7601/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildlife trafficking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wildlife trafficking” refers to the poaching or other illegal taking of protected or managed species and the illegal trade in wildlife and their related parts and products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a29ff1f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/231/s2"},"text":"Pub. L. 114–231, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"Oct. 7, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/949"},"text":"130 Stat. 949","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIX/s5943/b"},"text":"Pub. L. 117–263, div. E, title LIX, § 5943(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3470"},"text":"136 Stat. 3470","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a29ff20-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a29ff21-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a29ff22-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/231"},"text":"Pub. L. 114–231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"Oct. 7, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/949"},"text":"130 Stat. 949","children":[],"tail":", known as the Eliminate, Neutralize, and Disrupt Wildlife Trafficking Act of 2016, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Executive Order 13648, referred to in pars. (2) and (11), is Ex. Ord. No. 13648, ","children":[{"tag":"date","attrib":{"date":"2013-07-01"},"text":"July 1, 2013","children":[],"tail":", 78 F.R. 40621, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"section 1531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a29ff23-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5943/b/1"},"text":"Pub. L. 117–263, § 5943(b)(1)","children":[],"tail":", inserted “involving local communities” after “approach to conservation” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5943/b/2"},"text":"Pub. L. 117–263, § 5943(b)(2)","children":[],"tail":", amended par. (4) generally. Prior to amendment, text read as follows: “The term ‘country of concern’ refers to a foreign country specially designated by the Secretary of State pursuant to subsection (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7621"},"text":"section 7621 of this title","children":[],"tail":" as a major source of wildlife trafficking products or their derivatives, a major transit point of wildlife trafficking products or their derivatives, or a major consumer of wildlife trafficking products, in which the government has actively engaged in or knowingly profited from the trafficking of endangered or threatened species.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5943/b/3"},"text":"Pub. L. 117–263, § 5943(b)(3)","children":[],"tail":", substituted “section 7631” for “section 7621”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a29ff24-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a29ff25-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/231/s1/a"},"text":"Pub. L. 114–231, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"Oct. 7, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/949"},"text":"130 Stat. 949","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/231/s1/a"},"text":"“This Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1956"},"text":"section 1956 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1978"},"text":"section 1978 of Title 22","children":[],"tail":", Foreign Relations and Intercourse] may be cited as the ‘Eliminate, Neutralize, and Disrupt Wildlife Trafficking Act of 2016’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
