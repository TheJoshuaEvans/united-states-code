{"tag":"section","attrib":{"id":"id7839ee58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s542b"},"text":null,"children":[{"tag":"num","attrib":{"value":"542b"},"text":"§ 542b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration, protection, and regulation of use","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall administer, protect, and regulate use of the research site in accordance with the laws, rules, and regulations applicable to National Forest System lands, and in such manner as will best contribute to purposes of this Act.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7839ee59-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/550/tII/s203"},"text":"Pub. L. 96–550, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-19"},"text":"Dec. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3225"},"text":"94 Stat. 3225","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7839ee5a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7839ee5b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7839ee5c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/550"},"text":"Pub. L. 96–550","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-19"},"text":"Dec. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3221"},"text":"94 Stat. 3221","children":[],"tail":", which enacted sections 410ii to 410ii–7 and 542 to 542d of this title and enacted provisions listed in a table of Wilderness Areas set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"section 1132 of this title","children":[],"tail":" and provisions listed in tables of Miscellaneous National Monuments and National Monuments Established Under Presidential Proclamation set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320301"},"text":"section 320301 of Title 54","children":[],"tail":", National Park Service and Related Programs. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
