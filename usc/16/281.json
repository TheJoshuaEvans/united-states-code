{"tag":"section","attrib":{"id":"id77254a01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s281"},"text":null,"children":[{"tag":"num","attrib":{"value":"281"},"text":"§ 281.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the purpose of this subchapter to facilitate protection and provide interpretation of sites in the Nez Perce country of Idaho and in the States of Oregon, Washington, Montana, and Wyoming that have exceptional value in commemorating the history of the Nation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77254a02-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/19/s1"},"text":"Pub. L. 89–19, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-05-15"},"text":"May 15, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/110"},"text":"79 Stat. 110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/576/s2/1"},"text":"Pub. L. 102–576, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4770"},"text":"106 Stat. 4770","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77254a03-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77254a04-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77254a05-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/576"},"text":"Pub. L. 102–576","children":[],"tail":", which directed the insertion of “and in the States of Oregon, Washington, Montana, and Wyoming” after “the Nez Perce Country of Idaho”, was executed by making the insertion after “the Nez Perce country of Idaho” to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77254a06-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id77254a07-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/576/s1"},"text":"Pub. L. 102–576, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4770"},"text":"106 Stat. 4770","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/576/s1"},"text":"“This Act [amending this section and sections 281a to 281c, 281e, and 281f of this title] may be cited as the ‘Nez Perce National Historical Park Additions Act of 1991’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
