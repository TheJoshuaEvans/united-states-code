{"tag":"section","attrib":{"id":"id77740657-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"410iii–9"},"text":"§ 410iii–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endowment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77740658-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with the provisions of subsection (b), the Secretary is authorized to receive and expend funds from an endowment to be established with the National Park Foundation, or its successors and assigns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77740659-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds from the endowment referred to in subsection (a) shall be expended exclusively as the Secretary, in consultation with the Commission, may designate for the interpretation, preservation, and maintenance of the Park resources and public access areas. No expenditure shall be made pursuant to this section unless the Secretary determines that such expenditure is consistent with the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7774065a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/373/s11"},"text":"Pub. L. 107–373, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3108"},"text":"116 Stat. 3108","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
