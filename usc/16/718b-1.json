{"tag":"section","attrib":{"id":"id788639ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"718b–1"},"text":"§ 718b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of unsold stamps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id788639ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of unsold stamps","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Migratory Bird Hunting and Conservation Stamp shall be transferred to the Postal Service or the Secretary of the Interior (or a designee) for sale to a collector if the stamp—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id788639ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not been sold by the end of the hunting year (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s718j"},"text":"section 718j of this title","children":[],"tail":") during which the stamp is issued; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id788639af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as determined by the Postal Service or the Secretary of the Interior—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id788639b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is appropriate to supply a market for sale to collectors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id788639b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in suitable condition for sale to a collector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id788639b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surplus stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Postal Service or the Secretary of the Interior may destroy any surplus stock of Migratory Bird Hunting and Conservation Stamps at such time and in such manner as the Postal Service or the Secretary of the Interior determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id788639b3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-07-30/ch782/s3/a"},"text":"July 30, 1956, ch. 782, § 3(a)","children":[],"tail":", (b), formerly § 3(a), "},{"tag":"ref","attrib":{"href":"/us/stat/70/722"},"text":"70 Stat. 722","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/214/s3"},"text":"Pub. L. 92–214, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-22"},"text":"Dec. 22, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/777"},"text":"85 Stat. 777","children":[],"tail":"; renumbered § 3(a), (b) and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/266/s10/i/2"},"text":"Pub. L. 109–266, § 10(i)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-03"},"text":"Aug. 3, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/679"},"text":"120 Stat. 679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788639b4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788639b5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id788639b6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of act ","children":[{"tag":"date","attrib":{"date":"1934-03-16"},"text":"Mar. 16, 1934","children":[],"tail":", which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id788639b7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3(b) of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-07-30/ch782"},"text":"act July 30, 1956, ch. 782","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/722"},"text":"70 Stat. 722","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s718b"},"text":"section 718b of this title","children":[],"tail":" prior to being redesignated 3(c) by "},{"tag":"ref","attrib":{"href":"/us/pl/109/266/s10/i/1"},"text":"section 10(i)(1) of Pub. L. 109–266","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id788639b8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/266"},"text":"Pub. L. 109–266","children":[],"tail":" inserted section catchline and substituted subsecs. (a) and (b) for former text which read: “On or after "},{"tag":"date","attrib":{"date":"1956-07-30"},"text":"July 30, 1956","children":[],"tail":", such quantity of migratory-bird hunting stamps, not sold at the end of the fiscal year for which issued, as determined by the Postal Service to be (1) required to supply the market for sale to collectors, and (2) in suitable condition for such sale to collectors, shall be turned over to the Philatelic Agency and therein placed on sale. Any surplus stock of such migratory-bird hunting stamps may be destroyed in such manner as the Postal Service shall direct.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/214"},"text":"Pub. L. 92–214","children":[],"tail":" substituted “Postal Service” for “Postmaster General”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
