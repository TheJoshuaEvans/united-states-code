{"tag":"section","attrib":{"id":"id78863a01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718j"},"text":null,"children":[{"tag":"num","attrib":{"value":"718j"},"text":"§ 718j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78863a02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subchapter, the terms defined in the Migratory Bird Conservation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s715"},"text":"16 U.S.C. 715","children":[],"tail":" et seq.) and the Migratory Bird Treaty Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s703"},"text":"16 U.S.C. 703","children":[],"tail":" et seq.) have the meanings given those terms in those Acts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78863a03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78863a04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “hunting year” means the 1-year period beginning on July 1 of each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Migratory waterfowl","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “migratory waterfowl” means the species enumerated in paragraph (a) of subdivision 1 of article I of the Convention between the United States and Great Britain for the Protection of Migratory Birds, signed at Washington on ","children":[{"tag":"date","attrib":{"date":"1916-08-16"},"text":"August 16, 1916","children":[],"tail":" (USTS 628) ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s703"},"text":"16 U.S.C. 703","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718j/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718j/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78863a08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718j/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a