{"tag":"section","attrib":{"id":"id77f01466-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"460aaa–7"},"text":"§ 460aaa–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grand Island Advisory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77f01467-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to appointments as provided in subsection (b), there is established a Grand Island Advisory Commission (hereafter in this subchapter referred to as the “Commission”) comprised of 12 members for the purpose of advising the Secretary on the preparation of the management plan which is provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460aaa–6"},"text":"section 460aaa–6 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f01468-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77f01469-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Commission members shall be appointed by the Secretary as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77f0146a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three non-voting members, who shall be employees of the Forest Service including the Forest Supervisor of the Hiawatha National Forest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77f0146b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member who shall be a resident of Munising, Michigan, who is not a Forest Service employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77f0146c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members who shall be recreational users of Grand Island who are not Forest Service employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77f0146d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member from nominations made by the Alger County Board of Commissioners who is a member of such board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77f0146e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member from nominations made by the Alger County Economic Development Corporation who is a member of such corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77f0146f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member from nominations made by the Grand Island Association who is a member of such association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77f01470-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member from nominations made by the private landowners of Grand Island who is a private landowner on Grand Island.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77f01471-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member from nominations made by the Grand Island Township Board who is a member of such board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77f01472-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Munising city manager, upon accepting the invitation of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f01473-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vacancy shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f01474-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A quorum shall be six members. The operations of the Commission shall not be impaired by the fact that a member has not been appointed as long as a quorum has been attained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f01475-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall elect a Chairman and establish such rules and procedures as it deems necessary or desirable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f01476-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Commission on a periodic and regular basis with respect to the management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f01477-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77f01478-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Commission who are not full-time officers or employees of the United States shall serve without pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f01479-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Commission who are full-time officers or employees of the United States shall receive no additional pay by reason of their service on the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f0147a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals for non-Federal development on Federal land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall recommend proposals for non-Federal development on the 55 acres described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460aaa–6/b/2"},"text":"section 460aaa–6(b)(2) of this title","children":[],"tail":". It shall submit any such proposals to the Secretary for approval, rejection, or revision. The Secretary shall include in the management plan a development proposal submitted by the Commission or arrived at by any other means available to the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f0147b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–7/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall cease to exist on the date upon which the management plan is adopted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77f0147c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/292/s8"},"text":"Pub. L. 101–292, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-17"},"text":"May 17, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/189"},"text":"104 Stat. 189","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77f0147d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77f0147e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77f0147f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Commissions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory commissions established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a commission established by the President or an officer of the Federal Government, such commission is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a commission established by the Congress, its duration is otherwise provided for by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
