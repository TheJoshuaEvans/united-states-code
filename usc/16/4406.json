{"tag":"section","attrib":{"id":"id79f09e33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4406"},"text":null,"children":[{"tag":"num","attrib":{"value":"4406"},"text":"§ 4406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts available to carry out this chapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f09e34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4406/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f09e35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4406/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Migratory bird fines, penalties, forfeitures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sums received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s707"},"text":"section 707 of this title","children":[],"tail":" as penalties or fines, or from forfeitures of property are authorized to be appropriated to the Department of the Interior for purposes of allocation under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4407"},"text":"section 4407 of this title","children":[],"tail":". This subsection shall not be construed to require the sale of instrumentalities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f09e36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4406/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children