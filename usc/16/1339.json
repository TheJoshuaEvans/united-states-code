{"tag":"section","attrib":{"id":"id79155a6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1339"},"text":null,"children":[{"tag":"num","attrib":{"value":"1339"},"text":"§ 1339.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to authorize the Secretary to relocate wild free-roaming horses or burros to areas of the public lands where they do not presently exist.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79155a6e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/195/s10"},"text":"Pub. L. 92–195, § 10","children":[],"tail":", formerly § 9, "},{"tag":"date","attrib":{"date":"1971-12-15"},"text":"Dec. 15, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/651"},"text":"85 Stat. 651","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/94/579/tIV/s404"},"text":"Pub. L. 94–579, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2775"},"text":"90 Stat. 2775","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
