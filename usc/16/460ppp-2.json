{"tag":"section","attrib":{"id":"id78032729-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ppp–2"},"text":"§ 460ppp–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the conservation area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7803272a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to conserve, protect, and enhance for the benefit and enjoyment of present and future generations the unique and nationally important historical, cultural, paleontological, scenic, scientific, biological, educational, wildlife, riparian, wilderness, endangered species, and recreational values and resources associated with the Applegate-Lassen and Nobles Trails corridors and surrounding areas, there is hereby established the Black Rock Desert-High Rock Canyon Emigrant Trails National Conservation Area in the State of Nevada.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7803272b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The conservation area shall consist of approximately 797,100 acres of public lands as generally depicted on the map entitled “Black Rock Desert Emigrant Trail National Conservation Area” and dated ","children":[{"tag":"date","attrib":{"date":"2001-10-03"},"text":"October 3, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7803272c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maps and legal description","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2000-12-21"},"text":"December 21, 2000","children":[],"tail":", the Secretary shall submit to Congress a map and legal description of the conservation area. The map and legal description shall have the same force and effect as if included in this subchapter, except the Secretary may correct clerical and typographical errors in such map and legal description. Copies of the map and legal description shall be on file and available for public inspection in the appropriate offices of the Bureau of Land Management."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7803272d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s125"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 125 [§ 4]","children":[],"tail":"], "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–229, 2763A–354; "},{"tag":"ref","attrib":{"href":"/us/pl/107/63/tI/s135/a"},"text":"Pub. L. 107–63, title I, § 135(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-05"},"text":"Nov. 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/443"},"text":"115 Stat. 443","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7803272e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7803272f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78032730-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/63"},"text":"Pub. L. 107–63","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2001-10-03"},"text":"October 3, 2001","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2000-07-19"},"text":"July 19, 2000","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
