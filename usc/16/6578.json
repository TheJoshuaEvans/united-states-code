{"tag":"section","attrib":{"id":"id7a120a11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6578"},"text":null,"children":[{"tag":"num","attrib":{"value":"6578"},"text":"§ 6578.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a120a12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6578/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years 2009 through 2013 ","children":[{"tag":"ref","attrib":{"idref":"fn002828"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002828"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Heading and text do not correspond."}],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary of Agriculture shall make available $9,750,000 for each of fiscal years 2009 through 2012 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" to carry out this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6578/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary of Agriculture to carry out this section $12,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6578/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional source of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to funds appropriated pursuant to the authorization of appropriations in subsection (b) for a fiscal year, the Secretary may use such amount of the funds appropriated for that fiscal year to carry out the Soil Conservation and Domestic Allotment Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590a"},"text":"16 U.S.C. 590a","children":[],"tail":" et seq.) as the Secretary determines necessary to cover the cost of technical assistance, management, and enforcement responsibilities for land enrolled in the healthy forests reserve program pursuant to subsections (a) and (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6574"},"text":"section 6574 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6578/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funds made available under subsection (a) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a120a16-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tV/s508"},"text":"Pub. L. 108–148, title V, § 508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1914"},"text":"117 Stat. 1914","children":[],"tail":"; "},{"tag":"ref","attrib"