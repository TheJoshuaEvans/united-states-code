{"tag":"section","attrib":{"id":"id7a0fbfc3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6518"},"text":null,"children":[{"tag":"num","attrib":{"value":"6518"},"text":"§ 6518.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated $660,000,000 for each of fiscal years 2019 through 2023 to carry out—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fbfc4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6518/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities authorized by this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbfc5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6518/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other hazardous fuel reduction activities of the Secretary, including making grants to States, local governments, Indian tribes, and other eligible recipients for activities authorized by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0fbfc6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tI/s108"},"text":"Pub. L. 108–148, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1901"},"text":"117 Stat. 1901","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8402"},"text":"Pub. L. 115–334, title VIII, § 8402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4841"},"text":"132 Stat. 4841","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0fbfc7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0fbfc8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a0fbfc9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “$660,000,000 for each of fiscal years 2019 through 2023” for “$760,000,000 for each fiscal year” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
