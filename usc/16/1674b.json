{"tag":"section","attrib":{"id":"id795a79d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1674b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1674b"},"text":"§ 1674b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sustainable Forestry Outreach Initiative","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program, to be known as the “Sustainable Forestry Outreach Initiative”, to educate landowners concerning the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795a79d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1674b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The value and benefits of practicing sustainable forestry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795a79d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1674b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The importance of professional forestry advice in achieving sustainable forestry objectives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795a79d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1674b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The variety of public and private sector resources available to assist the landowners in planning for and practicing sustainable forestry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id795a79d9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/306/s5B"},"text":"Pub. L. 95–306, § 5B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVIII/s8101/a"},"text":"Pub. L. 107–171, title VIII, § 8101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/474"},"text":"116 Stat. 474","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
