{"tag":"section","attrib":{"id":"id775c3898-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410oo–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"410oo–4"},"text":"§ 410oo–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natchez Trace study","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall prepare, in consultation with the city of Natchez, a study of the feasibility of extending the Natchez Trace within the city of Natchez, including the acceptance of donations of rights-of-way. The Secretary shall transmit the study to the Committee on Interior and Insular Affairs of the United States House of Representatives and to the Committee on Energy and Natural Resources of the United States Senate within one year after ","children":[{"tag":"date","attrib":{"date":"1988-10-07"},"text":"October 7, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id775c3899-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/479/s5"},"text":"Pub. L. 100–479, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-07"},"text":"Oct. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2326"},"text":"102 Stat. 2326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id775c389a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id775c389b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id775c389c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Interior and Insular Affairs of the House of Representatives changed to Committee on Natural Resources of the House of Representatives on ","children":[{"tag":"date","attrib":{"date":"1993-01-05"},"text":"Jan. 5, 1993","children":[],"tail":", by House Resolution No. 5, One Hundred Third Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
