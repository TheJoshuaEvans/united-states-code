{"tag":"section","attrib":{"id":"id77fbfaa5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–11"},"text":"§ 460lll–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fbfaa6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the transfer of administrative jurisdiction under section 460","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–41 of this title, the Land Between the Lakes National Recreation Area in the States of Kentucky and Tennessee is established as a unit of the National Forest System."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfaa7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfaa8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–11/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall manage the Recreation Area for multiple use as a unit of the National Forest System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfaa9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–11/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emphases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The emphases in the management of the Recreation Area shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77fbfaaa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–11/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide public recreational opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fbfaab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–11/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conserve fish and wildlife and their habitat; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fbfaac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–11/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for diversity of native and desirable non-native plants, animals, opportunities for hunting and fishing, and environmental education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfaad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–11/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of unit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer the Recreation Area as a separate unit of the National Forest System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfaae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–11/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area included","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfaaf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–11/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Recreation Area shall comprise the federally owned land, water, and interests in the land and water lying between Kentucky Lake and Lake Barkley in the States of Kentucky and Tennessee, as generally depicted on the map entitled “Land Between the Lakes National Recreation Area—January, 1998”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfab0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–11/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map described in paragraph (1) shall be available for public inspection in the Office of the Chief of the Forest Service, Washington, D.C.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfab1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–11/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfab2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–11/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water levels and navigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter affects the jurisdiction of the Tennessee Valley Authority or the Army Corps of Engineers to manage and regulate water levels and navigation of Kentucky Lake and Lake Barkley and areas subject to flood easements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfab3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–11/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Occupancy and use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the jurisdiction of the Tennessee Valley Authority and the Army Corps of Engineers, the Secretary shall have jurisdiction to regulate the occupancy and use of the surface waters of the lakes for recreational purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fbfab4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s511"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 511]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–312; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tII/s201/b"},"text":"Pub. L. 117–328, div. DD, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5582"},"text":"136 Stat. 5582","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77fbfab5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77fbfab6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77fbfab7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added par. (3) and struck out former par. (3). Prior to amendment, text read as follows: “The Secretary may administer the Recreation Area as a separate unit of the National Forest System or in conjunction with an existing national forest.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
