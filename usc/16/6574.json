{"tag":"section","attrib":{"id":"id7a1209ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6574"},"text":null,"children":[{"tag":"num","attrib":{"value":"6574"},"text":"§ 6574.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1209ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6574/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanent easements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of land enrolled in the healthy forests reserve program using a permanent easement (or an easement described in section 6572(f)(1)(C)(ii) ","children":[{"tag":"ref","attrib":{"idref":"fn002827"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002827"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “6572(e)(1)(C)(ii)”."}],"tail":" of this title), the Secretary of Agriculture shall pay the owner of the land an amount equal to not less than 75 percent, nor more than 100 percent, of (as determined by the Secretary)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1209ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6574/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of the enrolled land during the period the land is subject to the easement, less the fair market value of the land encumbered by the easement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1209ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6574/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual costs of the approved conservation practices or the average cost of approved practices carried out on the land during the period in which the land is subject to the easement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1209f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6574/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Thirty-year easement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of land enrolled in the healthy forests reserve program using a 30-year easement, the Secretary of Agriculture shall pay the owner of the land an amount equal to not more than (as determined by the Secretary)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1209f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6574/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 percent of the fair market value of the land, less the fair market value of the land encumbered by the easement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1209f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6574/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 percent of the actual costs of the approved conservation practices or 75 percent of the average cost of approved practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1209f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6574/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ten-year agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of land enrolled in the healthy forests reserve program using a 10-year cost-share agreement, the Secretary of Agriculture shall pay the owner of the land an amount equal to not more than (as determined by the Secretary)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1209f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6574/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fifty percent of the actual costs of the approved conservation practices; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1209f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6574/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fifty percent of the average cost of approved practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1209f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6574/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may accept and use contributions of non-Federal funds to make payments under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1209f7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tV/s504"},"text":"Pub. L. 108–148, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1913"},"text":"117 Stat. 1913","children":[],"tail":"; "},{