{"tag":"section","attrib":{"id":"id7787195b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj"},"text":null,"children":[{"tag":"num","attrib":{"value":"410jjjj"},"text":"§ 410jjjj.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of Pullman National Historical Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7787195c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7787195d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historical park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “historical park” means the Pullman National Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7787195e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “map” means the map entitled “Pullman National Historical Park Boundary”, numbered 590/125,485, and dated November 2021.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7787195f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redesignation of Pullman National Monument","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77871960-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Pullman National Monument, established by Proclamation Number 9233, dated ","children":[{"tag":"date","attrib":{"date":"2015-02-19"},"text":"February 19, 2015","children":[],"tail":", is redesignated as the “Pullman National Historical Park”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77871961-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds available for purposes of the Pullman National Monument shall be available for purposes of the historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77871962-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any references in a law, regulation, document, record, map, or other paper of the United States to the Pullman National Monument shall be considered to be a reference to the historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77871963-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proclamation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Proclamation Number 9233, dated ","children":[{"tag":"date","attrib":{"date":"2015-02-19"},"text":"February 19, 2015","children":[],"tail":", shall have no force or effect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77871964-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the historical park are to preserve, protect, and interpret Pullman’s nationally significant cultural and historical resources associated with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77871965-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the labor history of the United States and creation of a national Labor Day holiday;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77871966-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first planned industrial community in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77871967-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the architecture and landscape design of the planned community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77871968-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pivotal role of the Pullman porter in the rise of the African-American middle class; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77871969-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entirety of history, culture, and historic figures embodied in Presidential Proclamation Number 9233.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7787196a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall administer the land within the boundary of the historical park in accordance with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7787196b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7787196c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the laws generally applicable to units of the National Park System, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7787196d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 100101(a), chapter 1003, and sections 100751(a), 100752, 100753 and 102101 of title 54; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7787196e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 3201 of title 54.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7787196f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77871970-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To further the purposes of this section and notwithstanding chapter 63 of title 31, the Secretary may enter into cooperative agreements with the State of Illinois, other public and nonprofit entities, and other interested parties, subject to paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77871971-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support collaborative interpretive and educational programs at non-Federal historic properties within the boundaries of the historical park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77871972-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify, interpret, and provide assistance for the preservation of non-Federal land within the boundaries of the historical park and at sites in close proximity to the historical park, but located outside the boundaries of the historical park, including providing for placement of directional and interpretive signage, exhibits, and technology-based interpretive devices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77871973-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A cooperative agreement entered under this subsection shall provide for reasonable public access.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77871974-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77871975-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use appropriated funds to mark, interpret, improve, restore, and provide technical assistance with respect to the preservation and interpretation of the properties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77871976-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inconsistent purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any payment made by the Secretary under this subsection shall be subject to an agreement that the conversion, use, or disposal of the project for purposes that are inconsistent with the purposes of this section, as determined by the Secretary, shall result in a right of the United States to reimbursement of the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77871977-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount provided by the Secretary to the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77871978-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the increase in the value of the project that is attributable to the funds, as determined by the Secretary at the time of the conversion, use, or disposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77871979-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire for inclusion in the historical park any land (including interests in land), buildings, or structures owned by the State of Illinois, or any other political, private, or nonprofit entity by donation, transfer, exchange, or purchase from a willing seller.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7787197a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjjj/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 fiscal years after the date on which funds are first made available to carry out this section, the Secretary shall complete a management plan for the historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7787197b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tVI/s619"},"text":"Pub. L. 117–328, div. DD, title VI, § 619","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5606"},"text":"136 Stat. 5606","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7787197c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7787197d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7787197e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Proclamation Number 9233 and Presidential Proclamation Number 9233, referred to in subsecs. (b)(1), (4), and (c)(5), is Proc. No. 9233, ","children":[{"tag":"date","attrib":{"date":"2015-02-19"},"text":"Feb. 19, 2015","children":[],"tail":", 80 F.R. 10315, which appears in a table under the heading “National Monuments Established Under Presidential Proclamation”, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320301"},"text":"section 320301 of Title 54","children":[],"tail":", National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
