{"tag":"section","attrib":{"id":"id7a1935a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703"},"text":null,"children":[{"tag":"num","attrib":{"value":"6703"},"text":"§ 6703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1935a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adaptive ecosystem management","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1935aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “adaptive ecosystem management” means a natural resource management process under which planning, implementation, monitoring, research, evaluation, and incorporation of new knowledge are combined into a management approach that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1935ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based on scientific findings and the needs of society;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1935ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treats management actions as experiments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1935ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acknowledges the complexity of these systems and scientific uncertainty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1935ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses the resulting new knowledge to modify future management methods and policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1935af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This paragraph shall not define the term “adaptive ecosystem management” for the purposes of the Forest and Rangeland Renewable Resources Planning Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1600"},"text":"16 U.S.C. 1600","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affected entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “affected entities” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1935b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land managers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1935b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stakeholders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1935b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concerned citizens; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1935b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the States of the interior West, including political subdivisions of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dry forest and woodland ecosystem","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dry forest and woodland ecosystem” means an ecosystem that is dominated by ponderosa pines and associated dry forest and woodland types.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institute","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Institute” means an Institute established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6704/a"},"text":"section 6704(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interior West","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “interior West” means the States of Arizona, Colorado, Idaho, Nevada, New Mexico, and Utah.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land manager","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1935b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “land manager” means a person or entity that practices or guides natural resource management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1935ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “land manager” includes a Federal, State, local, or tribal land management agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “restoration” means a process undertaken to move an ecosystem or habitat toward—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1935bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sustainable structure of the ecosystem or habitat; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1935bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a condition that supports a natural complement of species, natural function, or ecological process (such as a low-intensity fire).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture, acting through the Chief of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretaries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretaries” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1935c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, acting through the Chief of the Forest Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1935c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stakeholder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “stakeholder” means any person interested in or affected by management of forest or woodland ecosystems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subdominant trees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Are trees that occur underneath the canopy or extend into the canopy but are smaller and less vigorous than dominant trees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overstocked stands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where the number of trees per acre exceeds the natural carrying capacity of the site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6703/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resilience","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The ability of a system to absorb disturbance without being pushed into a different, possibly less desirable stable state.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1935c6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/317/s4"},"text":"Pub. L. 108–317, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-05"},"text":"Oct. 5, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1206"},"text":"118 Stat. 1206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1935c7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1935c8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a1935c9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Forest and Rangeland Renewable Resources Planning Act of 1974, referred to in par. (1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/378"},"text":"Pub. L. 93–378","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-17"},"text":"Aug. 17, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/476"},"text":"88 Stat. 476","children":[],"tail":", which is classified generally to subchapter I (§ 1600 et seq.) of chapter 36 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1600"},"text":"section 1600 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
