{"tag":"section","attrib":{"id":"id77681fbf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–53"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–53"},"text":"§ 410aaa–53.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Granite Mountains Natural Reserve","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77681fc0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–53/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby designated the Granite Mountains Natural Reserve within the preserve comprising approximately nine thousand acres as generally depicted on a map entitled “Mojave National Park Boundary and Wilderness—Proposed 6”, dated May 1991.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77681fc1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–53/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative management agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On ","children":[{"tag":"date","attrib":{"date":"1994-10-31"},"text":"October 31, 1994","children":[],"tail":", the Secretary shall enter into a cooperative management agreement with the University of California for the purposes of managing the lands within the Granite Mountains Natural Reserve. Such cooperative agreement shall ensure continuation of arid lands research and educational activities of the University of California, consistent with the provisions of this part and laws generally applicable to units of the National Park System."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},