{"tag":"section","attrib":{"id":"id774de040-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bb–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410bb–3"},"text":"§ 410bb–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to carry out the purposes of this subchapter, but not more than $2,655,000 for the acquisition of lands and interests in lands, and not more than $5,885,000 for development.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id774de041-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/323/s4"},"text":"Pub. L. 94–323, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/719"},"text":"90 Stat. 719","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
