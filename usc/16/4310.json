{"tag":"section","attrib":{"id":"id79ee54bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4310"},"text":null,"children":[{"tag":"num","attrib":{"value":"4310"},"text":"§ 4310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Cave Research Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ee54c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to provide for needed research relating to cave resources on certain lands in the United States, the Secretary of the Interior, acting through the Director of the National Park Service shall establish and administer a Cave Research Program (hereinafter in this section referred to as the “Program”). The Program shall include the orderly and scholarly collection, analysis, and dissemination of research material related to caves in lands managed by the National Park Service including, but not limited to, Carlsbad Caverns National Park and the Capitan Reef area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ee54c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Program shall produce educational and interpretive information and materials vital to public understanding of cave geology, assist students and researchers, and provide for a comprehensive evaluation of cave resources and measures needed for their protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ee54c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4310/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emphasis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program ","children":[{"tag":"ref","attrib":{"idref":"fn002792"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002792"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" shall be directed primarily toward lands managed by the National Park Service, but the Secretary of the Interior may enter into cooperative agreements with other agencies or entities as may be appropriate to carry out the purposes of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ee54c3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/578/tII/s202"},"text":"Pub. L. 101–578, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2859"},"text":"104 Stat. 2859","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79ee54c4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79ee54c5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79ee54c6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section, referred to in subsecs. (a) and (c), was in the original “this title” meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/578"},"text":"Pub. L. 101–578","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2859"},"text":"104 Stat. 2859","children":[],"tail":", which enacted this section and provisions set out as notes below. For complete classification of title II to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79ee54c7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Federal Cave Resources Protection Act of 1988 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79ee54c8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79ee54c9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Cave and Karst Research Institute","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/325"},"text":"Pub. L. 105–325","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3038"},"text":"112 Stat. 3038","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7305"},"text":"Pub. L. 111–11, title VII, § 7305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1219"},"text":"123 Stat. 1219","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/11/tVII/s7305"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘National Cave and Karst Research Institute Act of 1998’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PURPOSES.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“The purposes of this Act are—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to further the science of speleology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to centralize and standardize speleological information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to foster interdisciplinary cooperation in cave and karst research programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote public education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote national and international cooperation in protecting the environment for the benefit of cave and karst landforms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote and develop environmentally sound and sustainable resource management practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“SEC. 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ESTABLISHMENT OF THE INSTITUTE.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Interior (referred to in this Act as the ‘Secretary’), acting through the Director of the National Park Service, shall establish the National Cave and Karst Research Institute (referred to in this Act as the ‘Institute’).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Institute shall, to the extent practicable, further the purposes of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Location","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Institute shall be located in the vicinity of Carlsbad Caverns National Park, in the State of New Mexico. The Institute shall not be located inside the boundaries of Carlsbad Caverns National Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“SEC. 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ADMINISTRATION OF THE INSTITUTE.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Institute shall be jointly administered by the National Park Service and a public or private agency, organization, or institution, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Institute shall be operated and managed in accordance with the study prepared by the National Park Service pursuant to section 203 of the Act entitled ‘An Act to conduct certain studies in the State of New Mexico’, approved ","children":[{"tag":"date","attrib":{"date":"1990-11-15"},"text":"November 15, 1990","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/101/578"},"text":"Public Law 101–578","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4310"},"text":"16 U.S.C. 4310","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracts and Cooperative Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may enter into a contract or cooperative agreement with a public or private agency, organization, or institution to carry out this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Facility.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Leasing or acquiring a facility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may lease or acquire a facility for the Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction of a facility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary determines that a suitable facility is not available for a lease or acquisition under paragraph (1), the Secretary may construct a facility for the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of Grants and Transfers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out this Act, the Secretary may accept—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a grant or donation from a private person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a transfer of funds from another Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“SEC. 5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AUTHORIZATION OF APPROPRIATIONS.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“There are authorized to be appropriated such sums as are necessary to carry out this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79ee54ca-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/578/tII/s201"},"text":"Pub. L. 101–578, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2859"},"text":"104 Stat. 2859","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/578/tII/s201"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The World’s most exposed fossil reef, Capitan Reef, in southern New Mexico that includes Carlsbad Caverns, contains over 300 caves, including 75 identified caves in Carlsbad Caverns National Park and 22 caves in Guadalupe Mountains National Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recent explorations of Lechuguilla Cave at Carlsbad Caverns National Park have provided much new information about the wonders of this cave including the fact that it is the second deepest cave in the United States and contains outstanding world-class cave features such as gypsum crystal chandeliers and gypsum flowers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Lechuguilla Cave has been described by cave researchers as possibly the finest cave in America.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The interest and excitement of cave researchers throughout the world have been focused on Carlsbad Caverns National Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cave researchers could use this research institute as an operational base for study of caves in other regions and as a focal point for storage of data on cave geology and speleology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Congress, with the passage of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/691"},"text":"Public Law 100–691","children":[],"tail":", the Federal Cave Resources Protection Act of 1988 ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4301"},"text":"16 U.S.C. 4301","children":[],"tail":" et seq.], recognized the significance of cave resources on Federal lands and established the policy that Federal lands be managed in a manner which protects and maintains, to the extent practicable, significant cave resources.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79ee54cb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Cave Research Institute Study","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/578/tII/s203"},"text":"Pub. L. 101–578, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2860"},"text":"104 Stat. 2860","children":[],"tail":", directed Secretary of the Interior, not later than one year after "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", to prepare and transmit to Congress a study on the feasibility of establishing a Cave Research Institute."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79ee54cc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/578/tII/s204"},"text":"Pub. L. 101–578, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2860"},"text":"104 Stat. 2860","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/578/tII/s204"},"text":"“There are authorized to be appropriated such sums as may be necessary to carry out the provisions of this title [enacting this section and provisions set out as notes above].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
