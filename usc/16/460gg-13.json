{"tag":"section","attrib":{"id":"id77df4a6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gg–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"460gg–13"},"text":"§ 460gg–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77df4a6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gg–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated the sum of not more than $10,000,000 for the acquisition of lands and interests in lands within the recreation area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77df4a6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gg–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of recreation facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated the sum of not more than $10,000,000 for the development of recreation facilities within the recreation area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77df4a70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gg–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory, identification, development and protection of historic and archeological sites","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated the sum of not more than $1,500,000 for the inventory, identification, development, and protection of the historic and archeological sites described in section 5 of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77df4a71-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/199/s16"},"text":"Pub. L. 94–199, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1122"},"text":"89 Stat. 1122","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77df4a72-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77df4a73-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77df4a74-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 5 of this Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/199/s5"},"text":"section 5 of Pub. L. 94–199","children":[],"tail":". Subsec. (a) of section 5 added par. (57) to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1276/a"},"text":"section 1276(a) of this title","children":[],"tail":", relating to the designation of the Snake River for potential addition to the national wildlife and scenic rivers system. Subsec. (b) of section 5, relating to the deauthorization of the Asotin Dam, was not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
