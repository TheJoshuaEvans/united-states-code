{"tag":"section","attrib":{"id":"id7858e888-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s593"},"text":null,"children":[{"tag":"num","attrib":{"value":"593"},"text":"§ 593.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of timber in Florida","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized to employ so much of the land and naval forces of the United States as may be necessary effectually to prevent the felling, cutting down, or other destruction of the timber of the United States in Florida, and to prevent the transportation or carrying away any such timber as may be already felled or cut down; and to take such other and further measures as may be deemed advisable for the preservation of the timber of the United States in Florida.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7858e889-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(R.S. § 2460.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7858e88a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7858e88b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7858e88c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2460 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1882-02-23/ch9"},"text":"act Feb. 23, 1882, ch. 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/3/651"},"text":"3 Stat. 651","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
