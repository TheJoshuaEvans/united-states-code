{"tag":"section","attrib":{"id":"id77825e11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"410eeee–13"},"text":"§ 410eeee–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvement of access at Cunard","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77825e12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and improvement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall expeditiously acquire such lands, and undertake such developments and improvements, as may be necessary to provide for commercial and noncommercial access to the river near Cunard. No restriction shall be imposed on such access based on the time of day, except to the extent required to protect public health and safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77825e13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pending completion of the developments and improvements referred to in subsection (a), the Secretary shall permit the motorized towing of whitewater rafts in the section of the national river between Thurmond and Cunard when the volume of flow in the river is less than three thousand cubic feet per second.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77825e14-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/tXI/s1114"},"text":"Pub. L. 95–625, title XI, § 1114","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/534/tI/s103"},"text":"Pub. L. 100–534, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-26"},"text":"Oct. 26, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2700"},"text":"102 Stat. 2700","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77825e15-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77825e16-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77825e17-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460m–27"},"text":"section 460m–27 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
