{"tag":"section","attrib":{"id":"id773d3f28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s404e"},"text":null,"children":[{"tag":"num","attrib":{"value":"404e"},"text":"§ 404e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations of money; acquisition of title to lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the establishment of the said Mammoth Cave National Park the Secretary of the Interior is authorized to accept donations of money for the acquisition of lands and rights therein and to acquire the same by purchase, condemnation, or otherwise.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id773d3f29-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-05-14/ch282/s2"},"text":"May 14, 1934, ch. 282, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/775"},"text":"48 Stat. 775","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
