{"tag":"section","attrib":{"id":"id78e34dcd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1015a"},"text":"§ 1015a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78e34dce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", the Secretary shall establish a program, to be known as the “Cooperative Watershed Management Program”, under which the Secretary shall provide grants—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e34dcf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78e34dd0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to form a watershed group; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34dd1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enlarge a watershed group; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34dd2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct 1 or more projects in accordance with the goals of a watershed group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e34dd3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of application process; criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2021-09-30"},"text":"September 30, 2021","children":[],"tail":", the Secretary shall update—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e34dd4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application process for the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34dd5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the States, the prioritization and eligibility criteria for considering applications submitted in accordance with the application process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e34dd6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of grant funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e34dd7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In distributing grant funds under this section, the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78e34dd8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall comply with paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34dd9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may give priority to watershed groups that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78e34dda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent maximum diversity of interests; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34ddb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve subbasin-sized watersheds with an 8-digit hydrologic unit code, as defined by the United States Geological Survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34ddc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding procedure","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78e34ddd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First phase","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78e34dde-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide to a grant recipient a first-phase grant in an amount not greater than $100,000 each year for a period of not more than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34ddf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant recipient that receives a first-phase grant shall use the funds—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78e34de0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish or enlarge a watershed group;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34de1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop a mission statement for the watershed group;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34de2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop project concepts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34de3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop a restoration plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34de4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual determination of eligibility","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78e34de5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each year of a first-phase grant, not later than 270 days after the date on which a grant recipient first receives grant funds for the year, the Secretary shall determine whether the grant recipient has made sufficient progress during the year to justify additional funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34de6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines under subclause (I) that the progress of a grant recipient during the year covered by the determination justifies additional funding, the Secretary shall provide to the grant recipient grant funds for the following year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34de7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advancement conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant recipient shall not be eligible to receive a second-phase grant under subparagraph (B) until the date on which the Secretary determines that the watershed group—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78e34de8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has approved articles of incorporation and bylaws governing the organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34de9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"item","attrib":{"id":"id78e34dea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/A/iv/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds regular meetings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id78e34deb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/A/iv/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed a mission statement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id78e34dec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/A/iv/II/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has developed a restoration plan and project concepts for the watershed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34ded-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A watershed group that has not applied for or received first-phase grants may apply for and receive second-phase grants under subparagraph (B) if the Secretary determines that the group has satisfied the requirements of first-phase grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34dee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second phase","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78e34def-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A watershed group may apply for and receive second-phase grants of $1,000,000 each year for a period of not more than 4 years if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78e34df0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the watershed group has applied for and received watershed grants under subparagraph (A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34df1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the watershed group has satisfied the requirements of first-phase grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34df2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant recipient that receives a second-phase grant shall use the funds to plan and carry out watershed management projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34df3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual determination of eligibility","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78e34df4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each year of the second-phase grant, not later than 270 days after the date on which a grant recipient first receives grant funds for the year, the Secretary shall determine whether the grant recipient has made sufficient progress during the year to justify additional funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34df5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines under subclause (I) that the progress of a grant recipient during the year justifies additional funding, the Secretary shall provide to the grant recipient grant funds for the following year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34df6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advancement condition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant recipient shall not be eligible to receive a third-phase grant under subparagraph (C) until the date on which the Secretary determines that the grant recipient has—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78e34df7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completed each requirement of the second-phase grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34df8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrated that 1 or more pilot projects of the grant recipient have resulted in demonstrable improvements, as determined by the Secretary, in the functioning condition of at least 1 river or stream in the watershed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34df9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third phase","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78e34dfa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding limitation","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78e34dfb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subclause (II), the Secretary may provide to a grant recipient a third-phase grant in an amount not greater than $5,000,000 for a period of not more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34dfc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide to a grant recipient a third-phase grant in an amount that is greater than the amount described in subclause (I) if the Secretary determines that the grant recipient is capable of using the additional amount to further the purposes of the program in a way that could not otherwise be achieved by the grant recipient using the amount described in subclause (I).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34dfd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant recipient that receives a third-phase grant shall use the funds to plan and carry out at least 1 watershed management project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34dfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizing use of funds for administrative and other costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant recipient that receives a grant under this section may use the funds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78e34dff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to pay for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78e34e00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" administrative and coordination costs, if the costs are not greater than the lesser of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78e34e01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 20 percent of the total amount of the grant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34e02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34e03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the salary of not more than 1 full-time employee of the watershed group; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34e04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any legal fees arising from the establishment of the relevant watershed group; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34e05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to fund—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78e34e06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water quality and quantity studies of the relevant watershed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34e07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planning, design, and implementation of any projects relating to water quality or quantity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e34e08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e34e09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of an activity provided assistance through a first-phase grant shall be 100 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34e0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects carried out under second phase","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78e34e0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of any activity of a watershed management project provided assistance through a second-phase grant shall not exceed 50 percent of the total cost of the activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34e0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share under subparagraph (A) may be in the form of in-kind contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34e0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects carried out under third phase","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78e34e0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the costs of any activity of a watershed group of a grant recipient relating to a watershed management project provided assistance through a third-phase grant shall not exceed 50 percent of the total costs of the watershed management project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34e0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share under subparagraph (A) may be in the form of in-kind contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e34e10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e34e11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date on which a grant recipient first receives funds under this section, and annually thereafter, in accordance with paragraph (2), the watershed group shall submit to the Secretary a report that describes the progress of the watershed group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34e12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required degree of detail","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The contents of an annual report required under paragraph (1) shall contain sufficient information to enable the Secretary to complete each report required under subsection (f), as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e34e13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", and every 5 years thereafter, the Secretary shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives a report that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e34e14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the ways in which the program assists the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78e34e15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in addressing water conflicts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34e16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in conserving water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34e17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in improving water quality; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34e18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in improving the ecological resiliency of a river or stream; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34e19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefits that the program provides, including, to the maximum extent practicable, a quantitative analysis of economic, social, and environmental benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e34e1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e34e1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 for each of fiscal years 2008 and 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34e1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for fiscal year 2010;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34e1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2011; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34e1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015a/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for each of fiscal years 2012 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78e34e1f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVI/s6002"},"text":"Pub. L. 111–11, title VI, § 6002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1166"},"text":"123 Stat. 1166","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dD/tII/s206"},"text":"Pub. L. 116–260, div. D, title II, § 206","children":[],"tail":", div. FF, title XI, § 1107(b), "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1363"},"text":"134 Stat. 1363","children":[],"tail":", 3243.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78e34e20-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78e34e21-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78e34e22-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s1107/b/1"},"text":"Pub. L. 116–260, § 1107(b)(1)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which required Secretary to establish application process not later than 1 year after "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s1107/b/2"},"text":"Pub. L. 116–260, § 1107(b)(2)","children":[],"tail":", which directed substitution of “2026” for “2020”, was executed by making the substitution for “2021” to reflect the probable intent of Congress and the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/s206"},"text":"Pub. L. 116–260, § 206","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s206"},"text":"Pub. L. 116–260, § 206","children":[],"tail":", substituted “2021” for “2020”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
