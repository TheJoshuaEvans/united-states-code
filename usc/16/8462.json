{"tag":"section","attrib":{"id":"id7a3830c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8462"},"text":null,"children":[{"tag":"num","attrib":{"value":"8462"},"text":"§ 8462.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parking and restroom opportunities for Federal recreational lands and waters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3830c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8462/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parking opportunities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3830ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8462/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries shall seek to increase and improve parking opportunities for persons recreating on Federal recreational lands and waters—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3830cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8462/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with existing laws and applicable land use plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3830cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8462/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that minimizes any increase in maintenance obligations on Federal recreational lands and waters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3830cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8462/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that does not impact wildlife habitat that is critical to the mission of a Federal agency responsible for managing Federal recreational lands and waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3a9fce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8462/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To supplement the quantity of parking spaces available at units of Federal recreational lands and waters on ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretaries may—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3a9fcf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8462/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into a public-private partnership for parking opportunities on non-Federal land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3a9fd0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8462/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts or agreements with State, Tribal, or local governments for parking opportunities using non-Federal lands and resources; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3a9fd1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8462/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide alternative transportation systems for a unit of Federal recreational lands and waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3a9fd2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8462/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restroom opportunities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3a9fd3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8462/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries shall seek to increase and improve the function, cleanliness, and availability of restroom facilities for persons recreating on Federal recreational lands and waters, including by entering into partnerships with non-Federal partners, including State, Tribal, and local governments and volunteer organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3a9fd4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8462/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretaries shall submit a report to Congress that identifies—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3a9fd5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8462/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" challenges to maintaining or improving the function, cleanliness, and availability of restroom facilities on Federal recreational lands and waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3a9fd6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8462/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current state of restroom facilities on Federal recreational lands and waters and the effect restroom facilities have on visitor experiences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3a9fd7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8462/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policy recommendations that suggest innovative new models or partnerships to increase or improve the function, cleanliness, and availability of restroom facilities for persons recreating on Federal recreational lands and waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3a9fd8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s154"},"text":"Pub. L. 118–234, title I, § 154","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2870"},"text":"138 Stat. 2870","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
