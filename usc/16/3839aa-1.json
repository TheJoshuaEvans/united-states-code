{"tag":"section","attrib":{"id":"id79d1a56d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"3839aa–1"},"text":"§ 3839aa–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subpart:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d1a56e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation planning assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “conservation planning assessment” means a report, as determined by the Secretary, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d1a56f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is developed by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d1a570-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or unit of local government (including a conservation district);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a571-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a572-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a third-party provider certified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3842/e"},"text":"section 3842(e) of this title","children":[],"tail":" (including a certified rangeland professional);"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d1a573-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses rangeland or cropland function and describes conservation activities to enhance the economic and ecological management of that land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d1a574-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can be incorporated into a comprehensive planning document required by the Secretary for enrollment in a conservation program of the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d1a575-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible land","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d1a576-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible land” means land on which agricultural commodities, livestock, or forest-related products are produced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d1a577-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible land” includes the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d1a578-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cropland.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a579-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grassland.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a57a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rangeland.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a57b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pasture land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a57c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nonindustrial private forest land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a57d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other agricultural land (including cropped woodland, marshes, environmentally sensitive areas, and agricultural land used for the production of livestock) on which identified or expected resource concerns related to agricultural production could be addressed through a contract under the program, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d1a57e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentive practice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “incentive practice” means a practice or set of practices approved by the Secretary that, when implemented and maintained on eligible land, address 1 or more priority resource concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d1a57f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organic system plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “organic system plan” means an organic plan approved under the national organic program established under the Organic Foods Production Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6501"},"text":"7 U.S.C. 6501","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d1a580-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “payment” means financial assistance provided to a producer for performing practices under this subpart, including compensation for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d1a581-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incurred costs associated with planning, design, materials, equipment, installation, labor, management, maintenance, or training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d1a582-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" income forgone by the producer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d1a583-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Practice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “practice” means 1 or more improvements and conservation activities that are consistent with the purposes of the program under this subpart, as determined by the Secretary, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d1a584-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improvements to eligible land of the producer, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d1a585-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" structural practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a586-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land management practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a587-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vegetative practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a588-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forest management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a589-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/6/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soil testing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a58a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/6/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soil remediation to be carried out by the producer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a58b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/6/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other practices that the Secretary determines would further the purposes of the program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d1a58c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conservation activities involving the development of plans appropriate for the eligible land of the producer, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d1a58d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprehensive nutrient management planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a58e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning for resource-conserving crop rotations (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–24/d/1"},"text":"section 3839aa–24(d)(1) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a58f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soil health planning, including increasing soil organic matter and the use of cover crops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a590-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/6/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a conservation planning assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a591-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/6/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" precision conservation management planning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d1a592-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/6/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other plans that the Secretary determines would further the purposes of the program under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d1a593-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority resource concern","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “priority resource concern” means a natural resource concern or problem, as determined by the Secretary, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d1a594-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is identified at the national, State, or local level as a priority for a particular area of a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d1a595-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represents a significant concern in a State or region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d1a596-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the environmental quality incentives program established by this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d1a597-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Soil remediation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “soil remediation” means scientifically based practices that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d1a598-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the safety of producers from contaminants in soil;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d1a599-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit contaminants in soil from entering agricultural products for human or animal consumption; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d1a59a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regenerate and sustain the soil.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d1a59b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Soil testing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “soil testing” means the evaluation of soil health, including testing for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d1a59c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the optimal level of constituents in the soil, such as organic matter, nutrients, and the potential presence of soil contaminants, including heavy metals, volatile organic compounds, polycyclic aromatic hydrocarbons, or other contaminants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d1a59d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–1/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the biological and physical characteristics indicative of proper soil functioning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d1a59e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1240A"},"text":"Pub. L. 99–198, title XII, § 1240A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tII/s2301"},"text":"Pub. L. 107–171, title II, § 2301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/253"},"text":"116 Stat. 253","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2502"},"text":"Pub. L. 110–234, title II, § 2502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1058"},"text":"122 Stat. 1058","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title II, § 2502, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1786; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2202"},"text":"Pub. L. 113–79, title II, § 2202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/729"},"text":"128 Stat. 729","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII"},"text":"Pub. L. 115–334, title II","children":[],"tail":", §§ 2301(d)(1)(E), 2303, "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4554"},"text":"132 Stat. 4554","children":[],"t