{"tag":"section","attrib":{"id":"id774b6f7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410x–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"410x–1"},"text":"§ 410x–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residential occupancy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id774b6f7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410x–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of each individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id774b6f7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410x–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sold residential property between 1966 and 1968 to the United States for purposes of the park, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id774b6f7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410x–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continues to occupy such residential property pursuant to a residential special use permit as of ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary of the Interior shall offer to extend such residential special use permit for a term ending on the death of such individual or such individual’s spouse, whichever is later.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6f7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410x–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any residential special use permit extended pursuant to subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id774b6f80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410x–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit the reasonable residential use and occupancy of the property by the individual to whom such permit is granted and such individual’s spouse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id774b6f81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410x–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to such terms and conditions as the Secretary may prescribe (including termination) to ensure that the permit does not unreasonably diminish the values of the park.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The extension of any such residential special use permit shall be conditional upon the payment by the individual holding such permit of an annual fee in the same amount as required as of ","children":[{"tag":"date","attrib":{"date":"1991-07-01"},"text":"July 1, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id774b6f82-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/321/s7"},"text":"Pub. L. 86–321, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/488/s2/5/s4"},"text":"Pub. L. 102–488, § 2(5)[(4)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3136"},"text":"106 Stat. 3136","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
