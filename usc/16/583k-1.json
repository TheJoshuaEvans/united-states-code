{"tag":"section","attrib":{"id":"id7851bc5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"583k–1"},"text":"§ 583k–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7851bc5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative Unit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrative Unit” means a national forest or national grassland.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outfitter or guide","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “outfitter or guide” means an individual, organization, or business who provides outfitting or guiding services, as defined in section 251.51 of title 36, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–1/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “partner” means a non-Federal entity that engages in a partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–1/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “partnership” means arrangements between the Department of Agriculture or the Forest Service and a non-Federal entity that are voluntary, mutually beneficial, and entered into for the purpose of mutually agreed-upon objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–1/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “priority area” means a well-defined region on National Forest System land selected by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s583k–3/a"},"text":"section 583k–3(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–1/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–1/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “strategy” means the National Forest System Trails Volunteer and Partnership Strategy authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s583k–2/a"},"text":"section 583k–2(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–1/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trail maintenance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “trail maintenance” means any activity to maintain the usability and sustainability of trails within the National Forest System, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7851bc66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–1/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring trails are passable by the users for which they are managed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7851bc67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–1/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing environmental damage resulting from trail deterioration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7851bc68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–1/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting public safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7851bc69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–1/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" averting future deferred maintenance costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–1/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “volunteer” means an individual whose services are accepted by the Secretary without compensation under the Volunteers in the National Forests Act of 1972 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s558a"},"text":"16 U.S.C. 558a","children":[],"tail":" et seq.)."},{"tag":"ref","attrib":{"idref":"fn002458"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002458"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7851bc6b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/245/s3"},"text":"Pub. L. 114–245, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-11-28"},"text":"Nov. 28, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/990"},"text":"130 Stat. 990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7851bc6c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7851bc6d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7851bc6e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Volunteers in the National Forests Act of 1972, referred to in par. (9), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/300"},"text":"Pub. L. 92–300","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-05-18"},"text":"May 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/147"},"text":"86 Stat. 147","children":[],"tail":", which was classified generally to former sections 558a to 558d of this title, prior to being amended generally and renamed the Volunteers in the National Forests and Public Lands Act by "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tIII/s341"},"text":"Pub. L. 118–234, title III, § 341","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2913"},"text":"138 Stat. 2913","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/s342"},"text":"Section 342 of Pub. L. 118–234","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s558a"},"text":"section 558a of this title","children":[],"tail":", provides that a reference in any law to the Volunteers in National Forests Act of 1972 shall be deemed to be a reference to the Volunteers in the National Forests and Public Lands Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s558a"},"text":"section 558a of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
