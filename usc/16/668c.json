{"tag":"section","attrib":{"id":"id78673f93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s668c"},"text":null,"children":[{"tag":"num","attrib":{"value":"668c"},"text":"§ 668c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this subchapter “whoever” includes also associations, partnerships, and corporations; “take” includes also pursue, shoot, shoot at, poison, wound, kill, capture, trap, collect, molest or disturb; “transport” includes also ship, convey, carry, or transport by any means whatever, and deliver or receive or cause to be delivered or received for such shipment, conveyance, carriage, or transportation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78673f94-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-06-08/ch278/s4"},"text":"June 8, 1940, ch. 278, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/251"},"text":"54 Stat. 251","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/535/s4"},"text":"Pub. L. 92–535, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-23"},"text":"Oct. 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1065"},"text":"86 Stat. 1065","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78673f95-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78673f96-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78673f97-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/535"},"text":"Pub. L. 92–535","children":[],"tail":" substituted “poison, wound, kill, capture, trap, collect, molest” for “wound, kill, capture, trap, collect, or otherwise willfully molest”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
