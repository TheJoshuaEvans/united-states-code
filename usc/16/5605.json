{"tag":"section","attrib":{"id":"id7a016796-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5605"},"text":null,"children":[{"tag":"num","attrib":{"value":"5605"},"text":"§ 5605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations as may be necessary to carry out the purposes and objectives of the Convention and this chapter. Any such regulation may be made applicable, as necessary, to all persons and all vessels subject to the jurisdiction of the United States, wherever located.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a016797-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tII/s206"},"text":"Pub. L. 104–43, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/379"},"text":"109 Stat. 379","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
