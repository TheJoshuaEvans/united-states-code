{"tag":"section","attrib":{"id":"id79f30fcc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4713"},"text":null,"children":[{"tag":"num","attrib":{"value":"4713"},"text":"§ 4713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Armed services ballast water programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f30fcd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to operational conditions, the Secretary of Defense, in consultation with the Secretary, the Task Force, and the International Maritime Organization, shall implement a ballast water management program for seagoing vessels of the Department of Defense to minimize the risk of introduction of nonindigenous species from releases of ballast water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f30fce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coast Guard vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to operational conditions, the Secretary, in consultation with the Task Force and the International Maritime Organization, shall implement a ballast water management program for seagoing vessels of the Coast Guard to minimize the risk of introduction of nonindigenous species from releases of ballast water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f30fcf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646/tI/s1103"},"text":"Pub. L. 101–646, title I, § 1103","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/d"},"text":"Pub. L. 104–332, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4083"},"text":"110 Stat. 4083","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f30fd0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79f30fd1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id79f30fd2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
