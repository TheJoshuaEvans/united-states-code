{"tag":"section","attrib":{"id":"id77e67762-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ss–2"},"text":"§ 460ss–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Klamath Fishery Management Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77e67763-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a Klamath Fishery Management Council (hereafter in this subchapter referred to as the “Council”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e67764-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e67765-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Council shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e67766-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a comprehensive long-term plan and policy, that must be consistent with the goals of the program, for the management of the in-river and ocean harvesting that affects or may affect Klamath and Trinity River basin anadromous fish populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e67767-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make recommendations, that must be consistent with the plan and policy established under subparagraph (A) and with the standards in paragraph (2)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77e67768-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the California Fish and Game Commission regarding in-river and offshore recreational harvesting regulations,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e67769-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Oregon Department of Fish and Wildlife regarding offshore recreational harvesting regulations,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e6776a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Pacific Fishery Management Council regarding ocean harvesting regulations,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e6776b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Bureau of Indian Affairs regarding regulations for harvesting in the Area by non-Hoopa Indians, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e6776c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/b/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Hoopa Valley Business Council regarding regulations for harvesting in the Area by members of the Hoopa Indian Tribe; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e6776d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct public hearings on any regulation referred to in subparagraph (B)(i) through (v).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e6776e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any recommendation made by the Council under paragraph (1)(B) regarding harvesting regulations shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e6776f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be based upon the best scientific information available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e67770-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize costs where practicable, and avoid unnecessary duplication of regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e67771-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into account and allow for variations among, and contingencies in, fisheries, fishery resources, and catches; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e67772-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be designed to achieve an escapement that preserves and strengthens the viability of the Area’s natural anadromous fish populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e67773-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership and appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council is composed of 11 members as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e67774-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A representative, who shall be appointed by the Governor of California, of each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e67775-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The commercial salmon fishing industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e67776-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The in-river sportfishing community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e67777-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The offshore recreational fishing industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e67778-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The California Department of Fish and Game.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e67779-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A representative of the Hoopa Indian Tribe who shall be appointed by Hoopa Valley Business Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e6777a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A representative, who shall be appointed by the Secretary, of each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e6777b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The non-Hoopa Indians residing in the Area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e6777c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e6777d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A representative, who shall be appointed by the Secretary of Commerce, of each of the following—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e6777e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Marine Fisheries Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e6777f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Pacific Fishery Management Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e67780-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A representative, who shall be appointed by the Governor of Oregon, of each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e67781-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The commercial salmon fishing industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e67782-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Oregon Department of Fish and Wildlife.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e67783-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appointments required under subsection (c) shall be made in consultation with the appropriate users of Area anadromous fish resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e67784-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Council members shall be individuals who are knowledgable ","children":[{"tag":"ref","attrib":{"idref":"fn002337"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002337"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “knowledgeable”."}],"tail":" and experienced in the management and conservation, or the recreational or commercial harvest, of the anadromous fish resources in Northern California."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e67785-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e67786-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of a member is 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e67787-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Council serve at the pleasure of the appointing authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e67788-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy on the Council shall be filled in the manner in which the original appointment was made. Any member appointed to fill a vacancy occurring before the expiration of the term for which his predecessor was appointed shall be appointed only for the remainder of such term. A member may serve after the expiration of his term until his successor has taken office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e67789-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transaction of business","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e6778a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall establish practices and procedures for the carrying out of its functions under subsection (b). The procedures shall include requirements that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e6778b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a quorum of the Council must be present before business may be transacted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e6778c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no comprehensive plan or recommendation referred to in subsection (b)(1)(A) or (B) may be adopted by the Council except by the unanimous vote of all members present and voting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e6778d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall elect a Chairman from among its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e6778e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall meet at the call of the Chairman or upon the request of a majority of its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e6778f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff and administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e67790-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Director of the California Department of Fish and Game shall provide the Council with such administrative and technical support services as are necessary for the effective functioning of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e67791-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Director of the California Department of Fish and Game shall furnish the Council with relevant information concerning the Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e67792-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall determine its organization, and prescribe the practices and procedures for carrying out its functions under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e67793-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal or State employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Council member who is an officer or employee of the United States, the State of California, or the State of Oregon at the time of appointment to the Council shall cease to be a Council member within 14 days after the date on which he ceases to be so employed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e67794-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e67795-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"While away from their homes or regular places of business in the performance of services for the Council, Council members shall be allowed travel expenses, including a per diem allowance in lieu of subsistence, in the same manner as persons employed intermittently in the Government service are allowed travel expenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":". Any Council member who is an employee of an agency or governmental unit and is eligible for travel expenses from that agency or unit for performing services for the Council is not eligible for travel expenses under this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e67796-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–2/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on spending authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No money authorized to be appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460ss–5"},"text":"section 460ss–5 of this title","children":[],"tail":" may be used to reimburse any agency or governmental unit (whose employees are Council members) for time spent by any such employee performing Council duties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77e67797-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/552/s3"},"text":"Pub. L. 99–552, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3082"},"text":"100 Stat. 3082","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/653/tVI"},"text":"Pub. L. 100–653, title VI","children":[],"tail":", §§ 602(a), 603(1), (2), "},{"tag":"date","attrib":{"date":"1988-11-14"},"text":"Nov. 14, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3830"},"text":"102 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77e67798-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77e67799-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77e6779a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/653/s602/a"},"text":"Pub. L. 100–653, § 602(a)","children":[],"tail":", substituted “Procedures” for “Decisions of Council” as par. heading and amended text generally. Prior to amendment, text read as follows: “All decisions of the Council must be by unanimous vote of all of the members.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/653/s603/1"},"text":"Pub. L. 100–653, § 603(1)","children":[],"tail":", substituted “, the State of California, or the State of Oregon” for “or the State of California”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/653/s603/2"},"text":"Pub. L. 100–653, § 603(2)","children":[],"tail":", inserted provision at end that any Council member who is employee of agency or governmental unit and is eligible for travel expenses from that agency or unit for performing services for Council not be eligible for travel expenses under this par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
