{"tag":"section","attrib":{"id":"id78e597ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1108"},"text":null,"children":[{"tag":"num","attrib":{"value":"1108"},"text":"§ 1108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission shall maintain insurance in reasonable amounts, including, but not limited to, liability and property insurance. Such insurance may not cover the Commissioners or employees of the Commission except when sued by name for acts done in the scope of their employment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78e597ae-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/363/s9"},"text":"Pub. L. 88–363, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-07"},"text":"July 7, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/301"},"text":"78 Stat. 301","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
