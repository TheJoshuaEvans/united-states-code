{"tag":"section","attrib":{"id":"id78438b30-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s556e"},"text":null,"children":[{"tag":"num","attrib":{"value":"556e"},"text":"§ 556e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency appropriations for rehabilitation and wildfire suppression","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Beginning in fiscal year 1993, and in each year thereafter, only amounts for emergency rehabilitation and wildfire suppression activities that are in excess of the average of such costs for the previous ten years shall be considered “emergency requirements” pursuant to section 901(b)(2)(D) ","children":[{"tag":"ref","attrib":{"idref":"fn002445"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002445"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 2, and such amounts shall on and after "},{"tag":"date","attrib":{"date":"1991-11-13"},"text":"November 13, 1991","children":[],"tail":", be so designated."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78438b31-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/154/tII"},"text":"Pub. L. 102–154, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-13"},"text":"Nov. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1015"},"text":"105 Stat. 1015","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78438b32-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78438b33-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78438b34-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s901"},"text":"Section 901 of title 2","children":[],"tail":", referred to in text, was amended, and as so amended, section 901(b)(2)(D) no longer refers to “emergency requirements”. However, “emergency requirements” are referred to elsewhere in section 901."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
