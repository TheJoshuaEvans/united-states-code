{"tag":"section","attrib":{"id":"id772a04f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s343a"},"text":null,"children":[{"tag":"num","attrib":{"value":"343a"},"text":"§ 343a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Naval radio station, Seawall, Maine, as addition to park","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Navy is authorized to transfer to the control and jurisdiction of the Secretary of the Interior as an addition to the Acadia National Park all that tract of land containing two hundred and twenty-three acres, more or less, with improvements thereon, comprising the former naval radio station at Seawall, town of Southwest Harbor, Hancock County, Maine, said tract being no longer needed for naval purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id772a04f8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-05-23/ch315"},"text":"May 23, 1930, ch. 315","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/377"},"text":"46 Stat. 377","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id772a04f9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id772a04fa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id772a04fb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Recitation in this section as originally enacted of the fact that Acadia National Park was established under act ","children":[{"tag":"date","attrib":{"date":"1919-02-26"},"text":"Feb. 26, 1919","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/40/1178"},"text":"40 Stat. 1178","children":[],"tail":"), as amended by act "},{"tag":"date","attrib":{"date":"1929-01-19"},"text":"Jan. 19, 1929","children":[],"tail":" (Public Numbered 667, Seventieth Congress), was omitted as historically obsolete."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
