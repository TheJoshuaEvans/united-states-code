{"tag":"section","attrib":{"id":"id778e446b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s426j"},"text":null,"children":[{"tag":"num","attrib":{"value":"426j"},"text":"§ 426j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriation; fixing of boundaries as condition to purchase of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The sum of $100,000, or so much thereof as may be necessary, is authorized to be appropriated, out of any moneys in the Treasury not otherwise appropriated, to be expended for the purposes of sections 426 to 426j of this title: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no obligation for the purchase of lands shall be incurred until the commission has fixed the boundaries of said battlefield."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778e446c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-03/ch374/s11"},"text":"Mar. 3, 1927, ch. 374, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1401"},"text":"44 Stat. 1401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/443/s2"},"text":"Pub. L. 86–443, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-04-22"},"text":"Apr. 22, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/82"},"text":"74 Stat. 82","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778e446d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id778e446e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id778e446f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Battlefield” substituted in text for “park” in view of redesignation of Stones River National Military Park as Stones River National Battlefield by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/443"},"text":"Pub. L. 86–443","children":[],"tail":". See section 426"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
