{"tag":"section","attrib":{"id":"id7a35e5bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8213"},"text":null,"children":[{"tag":"num","attrib":{"value":"8213"},"text":"§ 8213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against implementation of regulatory authority by Federal agencies through partnerships","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any Partnership designated under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e5bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8213/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be for the sole purpose of promoting fish conservation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e5bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8213/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be used to implement any regulatory authority of any Federal agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a35e5be-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188/tII/s213"},"text":"Pub. L. 116–188, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/938"},"text":"134 Stat. 938","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
