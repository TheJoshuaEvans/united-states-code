{"tag":"section","attrib":{"id":"id7a35e59d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212"},"text":null,"children":[{"tag":"num","attrib":{"value":"8212"},"text":"§ 8212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a35e59e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e59f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish habitat Partnerships and conservation projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary $7,200,000 for each of fiscal years 2021 through 2030 to provide funds for Partnership operations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8204"},"text":"section 8204 of this title","children":[],"tail":" and fish habitat conservation projects approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s8205/f"},"text":"section 8205(f) of this title","children":[],"tail":", of which 5 percent is authorized only for projects carried out by Indian Tribes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e5a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative and planning expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated to the Secretary for each of fiscal years 2021 through 2030 an amount equal to 5 percent of the amount appropriated for the applicable fiscal year pursuant to paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a35e5a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for administrative and planning expenses under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e5a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8209"},"text":"section 8209 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e5a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical and scientific assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated for each of fiscal years 2021 through 2030 to carry out, and provide technical and scientific assistance under, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8206"},"text":"section 8206 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a35e5a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $400,000 to the Secretary for use by the United States Fish and Wildlife Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e5a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $400,000 to the National Oceanic and Atmospheric Administration Assistant Administrator for use by the National Oceanic and Atmospheric Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e5a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $400,000 to the Environmental Protection Agency Assistant Administrator for use by the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e5a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $400,000 to the Secretary for use by the United States Geological Survey; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e5a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $400,000 to the Secretary of Agriculture, acting through the Chief of the Forest Service, for use by the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e5a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements and grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e5aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the recommendation of the Board, and notwithstanding sections 6304 and 6305 of title 31 and the Federal Financial Assistance Management Improvement Act of 1999 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6101"},"text":"31 U.S.C. 6101","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/106/107"},"text":"Public Law 106–107","children":[],"tail":"), enter into a grant agreement, cooperative agreement, or contract with a Partnership or other entity to provide funds authorized by this chapter for a fish habitat conservation project or restoration or enhancement project;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e5ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply for, accept, and, subject to the availability of appropriations, use a grant from any individual or entity to carry out the purposes of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e5ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the availability of appropriations, make funds authorized by this Act available to any Federal department or agency for use by that department or agency to provide grants for any fish habitat protection project, restoration project, or enhancement project that the Secretary determines to be consistent with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e5ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e5ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a35e5af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into an agreement with any organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" that is exempt from taxation under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/a"},"text":"section 501(a) of title 26","children":[],"tail":" to solicit private donations to carry out the purposes of this chapter; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e5b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept donations of funds, property, and services to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e5b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A donation accepted under this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a35e5b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be considered to be a gift or bequest to, or otherwise for the use of, the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e5b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a35e5b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used directly by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a35e5b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8212/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided to another Federal department or agency through an interagency agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a35e5b6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188/tII/s212"},"text":"Pub. L. 116–188, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"t