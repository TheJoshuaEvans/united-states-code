":"Pub. L. 116–188","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/905"},"text":"134 Stat. 905","children":[],"tail":", known as America’s Conservation Enhancement Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s8201"},"text":"section 8201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a35e5ba-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s206/1"},"text":"Pub. L. 118–198, § 206(1)","children":[],"tail":", inserted “Partnerships and” after “habitat” in heading and “Partnership operations under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s8204"},"text":"section 8204 of this title","children":[],"tail":" and” after “to provide funds for” in text and substituted “2030” for “2025”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s206/2"},"text":"Pub. L. 118–198, § 206(2)","children":[],"tail":", substituted “2030” for “2025” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s206/3"},"text":"Pub. L. 118–198, § 206(3)","children":[],"tail":", substituted “2030” for “2025” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
