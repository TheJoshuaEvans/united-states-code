{"tag":"section","attrib":{"id":"id781639de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470mm"},"text":null,"children":[{"tag":"num","attrib":{"value":"470mm"},"text":"§ 470mm.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surveying of lands; reporting of violations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretaries of the Interior, Agriculture, and Defense and the Chairman of the Board of the Tennessee Valley Authority shall—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id781639df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470mm/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop plans for surveying lands under their control to determine the nature and extent of archeological resources on those lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id781639e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470mm/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare a schedule for surveying lands that are likely to contain the most scientifically valuable archeological resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id781639e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470mm/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop documents for the reporting of suspected violations of this chapter and establish when and how those documents are to be completed by officers, employees, and agents of their respective agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id781639e2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/95/s14"},"text":"Pub. L. 96–95, § 14","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/555"},"text":"Pub. L. 100–555","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-28"},"text":"Oct. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2778"},"text":"102 Stat. 2778","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
