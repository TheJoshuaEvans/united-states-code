{"tag":"section","attrib":{"id":"id79a935d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3119"},"text":null,"children":[{"tag":"num","attrib":{"value":"3119"},"text":"§ 3119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into cooperative agreements or otherwise cooperate with other Federal agencies, the State, Native Corporations, other appropriate persons and organizations, and, acting through the Secretary of State, other nations to effectuate the purposes and policies of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79a935d9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487/tVIII/s809"},"text":"Pub. L. 96–487, title VIII, § 809","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2427"},"text":"94 Stat. 2427","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
