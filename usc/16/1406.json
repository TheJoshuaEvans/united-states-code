{"tag":"section","attrib":{"id":"id792ab6b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1406"},"text":null,"children":[{"tag":"num","attrib":{"value":"1406"},"text":"§ 1406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission, in carrying out its responsibilities under this subchapter, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792ab6b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1406/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ and fix the compensation of such personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab6b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1406/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, furnish, and equip such office space;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab6b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1406/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into such contracts or agreements with, or provide such grants to, other organizations, both public and private;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab6b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1406/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure the services of such experts or consultants or an organization thereof as is authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":" (but at rates for individuals not to exceed $100 per diem); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab6b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1406/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incur such necessary expenses and exercise such other powers, as are consistent with and reasonably required to perform its functions under this subchapter; except that no fewer than 11 employees must be employed under paragraph (1) at any time. Financial and administrative services (including those related to budgeting, accounting, financial reporting, personnel, and procurement) shall be provided the Commission by the General Services Administration, for which payment shall be made in advance, or by reimbursement from funds of the Commission in such amounts as may be agreed upon by the Chairman and the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792ab6b6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tII/s206"},"text":"Pub. L. 92–522, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1045"},"text":"86 Stat. 1045","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/58/s6/2"},"text":"Pub. L. 97–58, § 6(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-09"},"text":"Oct. 9, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/987"},"text":"95 Stat. 987","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/364/tI/s103/b"},"text":"Pub. L. 98–364, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/442"},"text":"98 Stat. 442","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792ab6b7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792ab6b8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id792ab6b9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364"},"text":"Pub. L. 98–364","children":[],"tail":" inserted “; except that no fewer than 11 employees must be employed under paragraph (1) at any time” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/58"},"text":"Pub. L. 97–58","children":[],"tail":" substituted “contracts or agreements with, or provide such grants to, other organizations” for “contracts or agreements with other organizations”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id792ab6ba-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id792ab6bb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of the sixty-day period following ","children":[{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/522/s4"},"text":"section 4 of Pub. L. 92–522","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1361"},"text":"section 1361 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
