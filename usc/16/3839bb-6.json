ail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6294"},"text":"136 Stat. 6294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79d8d177-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79d8d178-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79d8d179-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Food Security Act of 1985, referred to in subsecs. (a)(1)(B)(i)(I) and (c)(2)(E)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1354"},"text":"99 Stat. 1354","children":[],"tail":". Title XII of the Act is classified principally to this chapter. Subtitle H of the Food Security Act of 1985 probably means subtitle H (§ 1265 et seq.) of title XII of "},{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":", which is classified generally to subchapter VII of this chapter. For complete classification of this Act to the Code, see Short Title of 1985 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1281"},"text":"section 1281 of Title 7","children":[],"tail":", Agriculture, and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Crop Insurance Act, referred to in subsec. (c)(2)(E)(ii), is subtitle A of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"act Feb. 16, 1938, ch. 30","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/72"},"text":"52 Stat. 72","children":[],"tail":", which is classified generally to subchapter I (§ 1501 et seq.) of chapter 36 of Title 7, Agriculture. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"section 1501 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2507 of the Farm Security and Rural Investment Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s2211"},"text":"43 U.S.C. 2211","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Public Law 107–171","children":[],"tail":") (as in effect on the day before "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":"), referred to in subsec. (d)(3)(B)(i), is "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/s2507"},"text":"section 2507 of Pub. L. 107–171","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/275"},"text":"116 Stat. 275","children":[],"tail":", which was classified as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s2211"},"text":"section 2211 of Title 43","children":[],"tail":", Public Lands, prior to being amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" and editorially reclassified as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 207 of the Energy and Water Development Appropriations Act, 2003, referred to in subsec. (d)(3)(B)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/s207"},"text":"section 207 of Pub. L. 108–7","children":[],"tail":", div. D, title II, "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/146"},"text":"117 Stat. 146","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 208 of the Energy and Water Development Appropriations Act, 2006, referred to in subsec. (d)(3)(B)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/103/s208"},"text":"section 208 of Pub. L. 109–103","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"2005-11-19"},"text":"Nov. 19, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2268"},"text":"119 Stat. 2268","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 208 of the Energy and Water Development and Related Agencies Appropriations Act, 2010, referred to in subsec. (d)(3)(B)(iv), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/85/s208"},"text":"section 208 of Pub. L. 111–85","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2858"},"text":"123 Stat. 2858","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79d8d17a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enac