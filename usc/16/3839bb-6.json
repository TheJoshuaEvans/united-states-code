{"tag":"section","attrib":{"id":"id79d8d137-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"3839bb–6"},"text":"§ 3839bb–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terminal lakes assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d8d138-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d8d139-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible land” means privately owned agricultural land (including land in which a State has a property interest as a result of State water law)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d8d13a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that a landowner voluntarily agrees to sell to a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d8d13b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d8d13c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79d8d13d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is ineligible for enrollment as a wetland reserve easement established under the agricultural conservation easement program under subtitle H ","children":[{"tag":"ref","attrib":{"idref":"fn002769"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002769"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Food Security Act of 1985;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79d8d13e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is flooded to—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id79d8d13f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a/1/B/i/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an average depth of at least 6.5 feet; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79d8d140-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a/1/B/i/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a level below which the State determines the management of the water level is beyond the control of the State or landowner; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79d8d141-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is inaccessible for agricultural use due to the flooding of adjoining property (such as islands of agricultural land created by flooding);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d8d142-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located within a watershed with water rights available for lease or purchase; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d8d143-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has been used during at least 5 of the immediately preceding 30 years—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79d8d144-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a/1/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to produce crops or hay; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79d8d145-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a/1/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as livestock pasture or grazing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d8d146-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the voluntary land purchase program established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d8d147-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terminal lake","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “terminal lake” means a lake and its associated riparian and watershed resources that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d8d148-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considered flooded because there is no natural outlet for water accumulating in the lake or the associated riparian area such that the watershed and surrounding land is consistently flooded; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d8d149-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considered terminal because it has no natural outlet and is at risk due to a history of consistent Federal assistance to address critical resource conditions, including insufficient water available to meet the needs of the lake, general uses, and water rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d8d14a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d8d14b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide grants under subsection (c) for the purchase of eligible land impacted by a terminal lake described in subsection (a)(3)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d8d14c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide funds to the Secretary of the Interior pursuant to subsection (e)(2) with assistance in accordance with subsection (d) for terminal lakes described in subsection (a)(3)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d8d14d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land purchase grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d8d14e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Using funds provided under subsection (e)(1), the Secretary shall make available land purchase grants to States for the purchase of eligible land in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d8d14f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d8d150-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A land purchase grant shall be in an amount not to exceed the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d8d151-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the total purchase price per acre of the eligible land; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d8d152-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79d8d153-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of eligible land that was used to produce crops or hay, $400 per acre; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79d8d154-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of eligible land that was pasture or grazing land, $200 per acre.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d8d155-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of purchase price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State purchasing eligible land with a land purchase grant shall ensure, to the maximum extent practicable, that the purchase price of such land reflects the value, if any, of other encumbrances on the eligible land to be purchased, including easements and mineral rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d8d156-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-share required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a land purchase grant, a State shall provide matching non-Federal funds in an amount equal to 50 percent of the amount described in subparagraph (A), including additional non-Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d8d157-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To receive a land purchase grant, a State shall agree—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d8d158-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to ensure that any eligible land purchased is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79d8d159-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conveyed in fee simple to the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79d8d15a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" free from mortgages or other liens at the time title is transferred;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d8d15b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain ownership of the eligible land in perpetuity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d8d15c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay (from funds other than grant dollars awarded) any costs associated with the purchase of eligible land under this section, including surveys and legal fees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d8d15d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to keep eligible land in a conserving use, as defined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d8d15e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loss of Federal benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Eligible land purchased with a grant under this section shall lose eligibility for any benefits under other Federal programs, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d8d15f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefits under title XII of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3801"},"text":"16 U.S.C. 3801","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d8d160-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefits under the Federal Crop Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"7 U.S.C. 1501","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d8d161-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covered benefits described in section 1001D(b) of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308–3a"},"text":"7 U.S.C. 1308–3a","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d8d162-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Federal rights or benefits associated with eligible land prior to purchase by a State may not be transferred to any other land or person in anticipation of or as a result of such purchase.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d8d163-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d8d164-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior, acting through the Commissioner of Reclamation, may use the funds described in subsection (e)(2) to administer and provide financial assistance to carry out this subsection to provide water and assistance to a terminal lake described in subsection (a)(3)(B) through willing sellers or willing participants only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d8d165-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to lease water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d8d166-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase land, water appurtenant to the land, and related interests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d8d167-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out research, support, and conservation activities for associated fish, wildlife, plant, and habitat resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d8d168-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior may not use this subsection to deliver assistance to the Great Salt Lake in Utah, lakes that are considered dry lakes, or other lakes that do not meet the purposes of this section, as determined by the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d8d169-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"