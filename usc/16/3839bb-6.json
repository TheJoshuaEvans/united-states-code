"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d8d16d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 207 of the Energy and Water Development Appropriations Act, 2003 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Public Law 108–7","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/117/146"},"text":"117 Stat. 146","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d8d16e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/d/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 208 of the Energy and Water Development Appropriations Act, 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/103"},"text":"Public Law 109–103","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/119/2268"},"text":"119 Stat. 2268","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2856"},"text":"123 Stat. 2856","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d8d16f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–6/d/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 208 of the Energy and Water Development and Related Agencies Appropriations Act, 2010 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/85"},"text":"Public Law 111–85","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/123/2858"},"text":"123 Stat. 2858","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1