1865/a"},"text":"section 1865(a) of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and section 100101(a), chapter 1003, and sections 100751(a), 100752, 100753, and 102101 of Title 54 by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 4(a)(1), 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3260, 3272. For complete classification of this Act to the Code, see Tables. For disposition of former sections of this title, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
