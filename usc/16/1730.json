{"tag":"section","attrib":{"id":"id795f342f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1730"},"text":null,"children":[{"tag":"num","attrib":{"value":"1730"},"text":"§ 1730.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id795f3430-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1730/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subchapter $12,000,000 for each fiscal year, of which $8,000,000 is authorized to carry out priority projects and $4,000,000 of which is authorized to carry out other appropriate conservation projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795f3431-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1730/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster relief or prevention projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a), any amounts made available under that subsection shall be available for disaster prevention or relief projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795f3432-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1730/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, amounts appropriated for any fiscal year to carry out this subchapter shall remain available for obligation and expenditure until the end of the fiscal year following the fiscal year for which the amounts are appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id795f3433-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/378/tII/s213"},"text":"Pub. L. 91–378, title II, § 213","children":[],"tail":", formerly § 211, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/f/2"},"text":"Pub. L. 109–154, § 2(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-30"},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2892"},"text":"119 Stat. 2892","children":[],"tail":"; renumbered § 213, "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tIX/s9003/f/1"},"text":"Pub. L. 116–9, title IX, § 9003(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/835"},"text":"133 Stat. 835","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
