{"tag":"section","attrib":{"id":"id78d4f57d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s938"},"text":null,"children":[{"tag":"num","attrib":{"value":"938"},"text":"§ 938.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"At least thirty days before approving a proposal to utilize a lamprey control measure or install a device in any stream, the United States Section shall cause notice of such proposal to be sent to the official agency having jurisdiction over fisheries in each of the States through which the stream flows.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78d4f57e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-06-04/ch358/s9"},"text":"June 4, 1956, ch. 358, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/243"},"text":"70 Stat. 243","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
