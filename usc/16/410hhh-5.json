{"tag":"section","attrib":{"id":"id77719588-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"410hhh–5"},"text":"§ 410hhh–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of national park and preserve","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77719589-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall administer the national park and the preserve in accordance with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7771958a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7771958b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" all laws generally applicable to units of the National Park System, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7771958c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act entitled “An Act to establish a National Park Service, and for other purposes”, approved ","children":[{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":", 2–4); "},{"tag":"ref","attrib":{"idref":"fn002171"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002171"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7771958d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act entitled “An Act to provide for the preservation of historic American sites, buildings, objects, and antiquities of national significance, and for other purposes”, approved ","children":[{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s461"},"text":"16 U.S.C. 461","children":[],"tail":" et seq.)."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7771958e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7771958f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquired State or private land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to former State or private land on which grazing is authorized to occur on ","children":[{"tag":"date","attrib":{"date":"2000-11-22"},"text":"November 22, 2000","children":[],"tail":", and which is acquired for the national monument, or the national park and preserve, or the wildlife refuge, the Secretary, in consultation with the lessee, may permit the continuation of grazing on the land by the lessee at the time of acquisition, subject to applicable law (including regulations)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77719590-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where grazing is permitted on land that is Federal land as of ","children":[{"tag":"date","attrib":{"date":"2000-11-22"},"text":"November 22, 2000","children":[],"tail":", and that is located within the boundaries of the national monument or the national park and preserve, the Secretary is authorized to permit the continuation of such grazing activities unless the Secretary determines that grazing would harm the resources or values of the national park or the preserve."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77719591-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of leases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall prohibit the Secretary from accepting the voluntary termination of leases or permits for grazing within the national monument or the national park or the preserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77719592-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting, fishing, and trapping","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77719593-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Secretary shall permit hunting, fishing, and trapping on land and water within the preserve in accordance with applicable Federal and State laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77740594-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may designate areas where, and establish limited periods when, no hunting, fishing, or trapping shall be permitted under paragraph (1) for reasons of public safety, administration, or compliance with applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77740595-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except in an emergency, regulations closing areas within the preserve to hunting, fishing, or trapping under this subsection shall be made in consultation with the appropriate agency of the State of Colorado having responsibility for fish and wildlife administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77740596-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter affects any jurisdiction or responsibility of the State of Colorado with respect to fish and wildlife on Federal land and water covered by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77740597-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closed Basin Division, San Luis Valley Project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any feature of the Closed Basin Division, San Luis Valley Project, located within the boundaries of the national monument, national park or the national wildlife refuge, including any well, pump, road, easement, pipeline, canal, ditch, power line, power supply facility, or any other project facility, and the operation, maintenance, repair, and replacement of such a feature—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77740598-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be affected by this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77740599-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall continue to be the responsibility of, and be operated by, the Bureau of Reclamation in accordance with title I of the Reclamation Project Authorization Act of 1972 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s615aaa"},"text":"43 U.S.C. 615aaa","children":[],"tail":" et seq.)."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7774059a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7774059b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On ","children":[{"tag":"date","attrib":{"date":"2000-11-22"},"text":"November 22, 2000","children":[],"tail":", subject to valid existing rights, all Federal land depicted on the map as being located within Zone A, or within the boundaries of the national monument, the national park or the preserve is withdrawn from—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7774059c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all forms of entry, appropriation, or disposal under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7774059d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7774059e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disposition under all laws relating to mineral and geothermal leasing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7774059f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provisions of this subsection also shall apply to any lands—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777405a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquired under this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777405a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transferred from any Federal agency after ","children":[{"tag":"date","attrib":{"date":"2000-11-22"},"text":"November 22, 2000","children":[],"tail":", for the national monument, the national park or preserve, or the national wildlife refuge."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777405a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wilderness protection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777405a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subchapter alters the Wilderness designation of any land within the national monument, the national park, or the preserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777405a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–5/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All areas designated as Wilderness that are transferred to the administrative jurisdiction of the National Park Service shall remain subject to the Wilderness Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.) and the Colorado Wilderness Act of 1993 ("},{"tag":"ref","attrib":{"href":"/us/pl/103/77"},"text":"Public Law 103–77","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539i"},"text":"16 U.S.C. 539i","children":[],"tail":" note). If any part of this subchapter conflicts with the provisions of the Wilderness Act or the Colorado Wilderness Act of 1993 with respect to the wilderness areas within the preserve boundaries, the provisions of those Acts shall control."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777405a5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/530/s7"},"text":"Pub. L. 106–530, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2530"},"text":"114 Stat. 2530","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777405a6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777405a7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id777405a8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Act entitled “An Act to establish a National Park Service, and for other purposes”, approved ","children":[{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":", 2–4), referred to in subsec. (a)(2)(A), is "},{"tag":"ref","attrib":{"href":"/us/act/1916-08-25/ch408"},"text":"act Aug. 25, 1916, ch. 408","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":", known as the National Park Service Organic Act, which enacted sections 1, 2, 3, and 4 of this title and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":", National Park Service and Related Programs. Sections 1 to 4 of the Act were repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1865/a"},"text":"section 1865(a) of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and section 100101(a), chapter 1003, and sections 100751(a), 100752, 100753, and 102101 of Title 54 by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 4(a)(1), 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3260, 3272. For complete classification of this Act to the Code, see Tables. For disposition of former sections of this title, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Act entitled “An Act to provide for the preservation of historic American sites, buildings, objects, and antiquities of national significance, and for other purposes”, approved ","children":[{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s461"},"text":"16 U.S.C. 461","children":[],"tail":" et seq.), referred to in subsec. (a)(2)(B), is "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-21/ch593"},"text":"act Aug. 21, 1935, ch. 593","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/666"},"text":"49 Stat. 666","children":[],"tail":", known as the Historic Sites Act of 1935 and also as the Historic Sites, Buildings, and Antiquities Act, which enacted sections 461 to 467 of this title. The Act was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1866/a"},"text":"section 1866(a) of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and sections 102303 and 102304 and chapter 3201 of Title 54, National Park Service and Related Programs, by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 4(a)(1), 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3260, 3272. For complete classification of this Act to the Code, see Tables. For disposition of former sections of this title, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Reclamation Project Authorization Act of 1972, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/514"},"text":"Pub. L. 92–514","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-20"},"text":"Oct. 20, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/964"},"text":"86 Stat. 964","children":[],"tail":". Title I of the Act was classified generally to subchapter XXXI (§ 615aaa et seq.) of chapter 12 of Title 43, Public Lands, prior to its omission from the Code. See Codification notes under sections 615aaa to 615iii of Title 43."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Wilderness Act, referred to in subsec. (f)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/577"},"text":"Pub. L. 88–577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-03"},"text":"Sept. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/890"},"text":"78 Stat. 890","children":[],"tail":", which is classified generally to chapter 23 (§ 1131 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"section 1131 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Colorado Wilderness Act of 1993, referred to in subsec. (f)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/77"},"text":"Pub. L. 103–77","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-13"},"text":"Aug. 13, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/756"},"text":"107 Stat. 756","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539i"},"text":"section 539i of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
