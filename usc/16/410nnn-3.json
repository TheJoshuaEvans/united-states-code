{"tag":"section","attrib":{"id":"id7778c096-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410nnn–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410nnn–3"},"text":"§ 410nnn–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Within the historical park, the Secretary is authorized to acquire lands and interest in lands by donation, purchase with donated or appropriated funds, or exchange. Lands or interests in lands owned by the State of Texas or political subdivisions thereof may be acquired only by donation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7778c097-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/304/s5"},"text":"Pub. L. 102–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-06-23"},"text":"June 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/257"},"text":"106 Stat. 257","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7113/a/3/C"},"text":"Pub. L. 111–11, title VII, § 7113(a)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1202"},"text":"123 Stat. 1202","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7778c098-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7778c099-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7778c09a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":" substituted “historical park” for “historic site”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
