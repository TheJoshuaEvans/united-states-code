{"tag":"section","attrib":{"id":"id79d1a559-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"3839aa"},"text":"§ 3839aa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the environmental quality incentives program established by this subpart are to promote agricultural production, forest management, and environmental quality as compatible goals, and to optimize environmental benefits, by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d1a55a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assisting producers in complying with local, State, and national regulatory requirements concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d1a55b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soil, water, and air quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d1a55c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wildlife habitat; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d1a55d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surface and ground water conservation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d1a55e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoiding, to the maximum extent practicable, the need for resource and regulatory programs by assisting producers in protecting soil, water, air, and related natural resources and meeting environmental quality criteria established by Federal, State, tribal, and local agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d1a55f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing flexible assistance to producers to install and maintain conservation practices that sustain food and fiber production while—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d1a560-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing soil, water, and related natural resources, including grazing land, forestland, wetland, and wildlife;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d1a561-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and improving wildlife habitat; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d1a562-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conserving energy; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d1a563-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting producers to make beneficial, cost-effective changes to production systems, including addressing identified, new, or expected resource concerns related to organic production, grazing management, fuels management, forest management, nutrient management associated with crops and livestock, pest management, irrigation management, adapting to, and mitigating against, increasing weather volatility, drought resiliency measures, or other practices on agricultural and forested land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d1a564-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1240"},"text":"Pub. L. 99–198, title XII, § 1240","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tII/s2301"},"text":"Pub. L. 107–171, title II, § 2301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/253"},"text":"116 Stat. 253","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2501/a"},"text":"Pub. L. 110–234, title II, § 2501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1057"},"text":"122 Stat. 1057","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title II, § 2501(a), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1785; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2201"},"text":"Pub. L. 113–79, title II, § 2201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/728"},"text":"128 Stat. 728","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII"},"text":"Pub. L. 115–334, title II","children":[],"tail":", §§ 2301(d)(1)(D), 2302, "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4554"},"text":"132 Stat. 4554","children":[],"tail":", 4555.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79d1a565-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79d1a566-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79d1a567-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79d1a568-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3839aa, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1240"},"text":"Pub. L. 99–198, title XII, § 1240","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIII/s334"},"text":"Pub. L. 104–127, title III, § 334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/996"},"text":"110 Stat. 996","children":[],"tail":", related to purposes, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79d1a569-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2301/d/1/D"},"text":"Pub. L. 115–334, § 2301(d)(1)(D)","children":[],"tail":", substituted “this subpart” for “this part” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2302"},"text":"Pub. L. 115–334, § 2302","children":[],"tail":", added par. (4) and struck out former par. (4) which read as follows: “assisting producers to make beneficial, cost effective changes to production systems (including conservation practices related to organic production), grazing management, fuels management, forest management, nutrient management associated with livestock, pest or irrigation management, or other practices on agricultural and forested land.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s2201/1"},"text":"Pub. L. 113–79, § 2201(1)","children":[],"tail":", added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s2201/2"},"text":"Pub. L. 113–79, § 2201(2)","children":[],"tail":", substituted a period for “; and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s2201/3"},"text":"Pub. L. 113–79, § 2201(3)","children":[],"tail":", struck out par. (5) which read as follows: “consolidating and streamlining conservation planning and regulatory compliance processes to reduce administrative burdens on producers and the cost of achieving environmental goals.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s2501/a/1"},"text":"Pub. L. 110–246, § 2501(a)(1)","children":[],"tail":", inserted “, forest management,” after “agricultural production” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s2501/a/2"},"text":"Pub. L. 110–246, § 2501(a)(2)","children":[],"tail":", added pars. (3) and (4) and struck out former pars. (3) and (4) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) providing flexible assistance to producers to install and maintain conservation practices that enhance soil, water, related natural resources (including grazing land and wetland), and wildlife while sustaining production of food and fiber;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) assisting producers to make beneficial, cost effective changes to cropping systems, grazing management, nutrient management associated with livestock, pest or irrigation management, or other practices on agricultural land; and”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79d1a56a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79d1a56b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79d1a56c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effect on Existing Contracts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2208"},"text":"Pub. L. 113–79, title II, § 2208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/731"},"text":"128 Stat. 731","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/79/tII/s2208"},"text":"“The amendments made by this subtitle [subtitle C (§§ 2201–2208) of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":", amending this section and sections 3839aa–1 to 3839aa–4, 3839aa–7, and 3839aa–8 of this title] shall not affect the validity or terms of any contract entered into by the Secretary of Agriculture under chapter 4 of subtitle D of title XII of the Food Security Act of 1985 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa"},"text":"16 U.S.C. 3839aa","children":[],"tail":" et seq.) before the date of enactment of the Agricultural Act of 2014 ["},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":"], or any payments required to be made in connection with the contract.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
