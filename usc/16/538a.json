{"tag":"section","attrib":{"id":"id782b95a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a"},"text":null,"children":[{"tag":"num","attrib":{"value":"538a"},"text":"§ 538a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest Service Legacy Road and Trail Remediation Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id782b95a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish the Forest Service Legacy Road and Trail Remediation Program (referred to in this section as the “Program”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id782b95aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Program, the Secretary shall, taking into account foreseeable changes in weather and hydrology—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id782b95ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" restore passages for fish and other aquatic species by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id782b95ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving, repairing, or replacing culverts and other infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id782b95ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" removing barriers, as the Secretary determines appropriate, from the passages;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id782b95ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" decommission unauthorized user-created roads and trails that are not a National Forest System road or a National Forest System trail, if the applicable unit of the National Forest System has published—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id782b95af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Motor Vehicle Use Map and the road is not identified as a National Forest System road on that Motor Vehicle Use Map; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id782b95b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a map depicting the authorized trails in the applicable unit of the National Forest System and the trail is not identified as a National Forest System trail on that map;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id782b95b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prepare previously closed National Forest System roads for long-term storage, in accordance with subsections (c)(1) and (d), in a manner that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id782b95b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevents motor vehicle use, as appropriate to conform to route designations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id782b95b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevents the roads from damaging adjacent resources, including aquatic and wildlife resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id782b95b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces or eliminates the need for road maintenance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id782b95b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserves the roads for future use;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id782b95b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decommission previously closed National Forest System roads and trails in accordance with subsections (c)(1) and (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id782b95b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" relocate National Forest System roads and trails—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id782b95b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase resilience to extreme weather events, flooding, and other natural disasters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id782b95b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to respond to changing resource conditions and public input;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id782b95ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convert National Forest System roads to National Forest System trails, while allowing for continued use for motorized and nonmotorized recreation, to the extent the use is compatible with the management status of the road or trail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id782b95bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" decommission temporary roads—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id782b95bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that were constructed before ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id782b95bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for emergency operations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id782b95be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate a resource extraction project;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id782b95bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that were designated as a temporary road by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id782b95c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id782b95c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/7/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1608/b"},"text":"section 1608(b) of this title","children":[],"tail":", on which vegetation cover has not been reestablished; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id782b95c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/7/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that have not been fully decommissioned; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id782b95c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out projects on National Forest System roads, trails, and bridges to improve resilience to extreme weather events, flooding, or other natural disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id782b95c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project selection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id782b95c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project eligibility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id782b95c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may only fund under the Program a project described in paragraph (3) or (4) of subsection (b) if the Secretary previously and separately—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id782b95c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" solicited public comment for changing the management status of the applicable National Forest System road or trail—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id782b95c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to close the road or trail to access; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id782b95c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to minimize impacts to natural resources; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id782b95ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has closed the road or trail to access as described in clause (i)(I).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id782b95cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each project carried out under the Program shall be on a National Forest System road or trail, except with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id782b95cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project described in subsection (b)(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id782b95cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project carried out on a watershed for which the Secretary has entered into a cooperative agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1011a"},"text":"section 1011a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id782b95ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual selection of projects for funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id782b95cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a process for annually selecting projects for funding under the Program, consistent with the requirements of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id782b95d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit and consider public input regionally in the ranking of projects for funding under the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id782b95d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" give priority for funding under the Program to projects that would—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id782b95d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect or improve water quality in public drinking water source areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id782b95d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restore the habitat of a threatened, endangered, or sensitive fish or wildlife species; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id782b95d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain future access to the adjacent area for the public, contractors, permittees, or firefighters; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id782b95d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" publish on the website of the Forest Service—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id782b95d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the selection process established under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id782b95d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list that includes a description and the proposed outcome of each project funded under the Program in each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id782b95d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In implementing the Program, the Secretary shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id782b95d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the system of roads and trails on the applicable unit of the National Forest System—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id782b95da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is adequate to meet any increasing demands for timber, recreation, and other uses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id782b95db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for intensive use, protection, development, and management of the land under principles of multiple use and sustained yield of products and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id782b95dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not damage, degrade, or impair adjacent resources, including aquatic and wildlife resources, to the extent practicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id782b95dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflects long-term funding expectations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id782b95de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is adequate for supporting emergency operations, such as evacuation routes during wildfires, floods, and other natural disasters; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id782b95df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all projects funded under the Program are consistent with any applicable forest plan or travel management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id782b95e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s538a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A decision to fund a project under the Program shall not affect any determination made previously or to be made in the future by the Secretary with regard to road or trail closures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id782b95e1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/657/s8"},"text":"Pub. L. 88–657, § 8","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tVIII/s40801/a"},"text":"Pub. L. 117–58, div. D, title VIII, § 40801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1094"},"text":"135 Stat. 1094","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id782b95e2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id782b95e3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id782b95e4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
