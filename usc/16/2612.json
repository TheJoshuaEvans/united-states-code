{"tag":"section","attrib":{"id":"id799d4f29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2612"},"text":null,"children":[{"tag":"num","attrib":{"value":"2612"},"text":"§ 2612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799d4f2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volume of total retail sales","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter applies to each electric utility in any calendar year, and to each proceeding relating to each electric utility in such year, if the total sales of electric energy by such utility for purposes other than resale exceeded 500 million kilowatt-hours during any calendar year beginning after ","children":[{"tag":"date","attrib":{"date":"1975-12-31"},"text":"December 31, 1975","children":[],"tail":", and before the immediately preceding calendar year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799d4f2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of wholesale sales","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this chapter do not apply to the operations of an electric utility, or to proceedings respecting such operations, to the extent that such operations or proceedings relate to sales of electric energy for purposes of resale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799d4f2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of covered utilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the beginning of each calendar year, the Secretary shall publish a list identifying each electric utility to which this chapter applies during such calendar year. Promptly after publication of such list each State regulatory authority shall notify the Secretary of each electric utility on the list for which such State regulatory authority has ratemaking authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799d4f2d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617/tI/s102"},"text":"Pub. L. 95–617, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3121"},"text":"92 Stat. 3121","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799d4f2e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799d4f2f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id799d4f30-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title I (§ 101 et seq.) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617"},"text":"Pub. L. 95–617","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3120"},"text":"92 Stat. 3120","children":[],"tail":", which enacted subchapters I to IV of this chapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6808"},"text":"section 6808 of Title 42","children":[],"tail":", The Public Health and Welfare, and amended sections 6802 to 6807 of Title 42. For complete classification of title I to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
