{"tag":"section","attrib":{"id":"id79adf105-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3167"},"text":null,"children":[{"tag":"num","attrib":{"value":"3167"},"text":"§ 3167.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights-of-way terms and conditions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79adf106-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3167/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, or the Secretary of Agriculture where national forest wilderness is involved, shall include in any right-of-way issued pursuant to an application under this subchapter, terms and conditions which shall include, but not be limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79adf107-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3167/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements to insure that, to the maximum extent feasible, the right-of-way is used in a manner compatible with the purposes for which the affected conservation system unit, national recreation area, or national conservation area was established or is managed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79adf108-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3167/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements for restoration, revegetation, and curtailment of erosion of the surface of the land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79adf109-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3167/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements to insure that activities in connection with the right-of-way will not violate applicable air and water quality standards and related facility siting standards established pursuant to law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79adf10a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3167/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" requirements, including the minimum necessary width, designed to control or prevent—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79adf10b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3167/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damage to the environment (including damage to fish and wildlife habitat),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79adf10c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3167/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damage to public or private property, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79adf10d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3167/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hazards to public health and safety;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79adf10e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3167/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements to protect the interests of individuals living in the general area of the right-of-way who rely on the fish, wildlife, and biotic resources of the area for subsistence purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79adf10f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3167/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements to employ measures to avoid or minimize adverse environmental, social or economic impacts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79adf110-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3167/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wild and Scenic Rivers System","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any transportation or utility system approved pursuant to this subchapter which occupies, uses, or traverses any area within the boundaries of a unit of the National Wild and Scenic Rivers System shall be subject to such conditions as may be necessary to assure that the stream flow of, and transportation on, such river are not interfered with or impeded, and that the transportation or utility system is located and constructed in an environmentally sound manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79adf111-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3167/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pipeline rights-of-way","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a pipeline described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s185/a"},"text":"section 185(a) of title 30","children":[],"tail":", a right-of-way issued pursuant to this subchapter shall be issued in the same manner as a right-of-way is granted under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s185"},"text":"section 185 of title 30","children":[],"tail":", and the provisions of subsections (c) through (j), ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") through (q), and (u) through (y) of "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s185"},"text":"section 185 of title 30","children":[],"tail":" shall apply to rights-of-way issued pursuant to this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79adf112-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487/tXI/s1107"},"text":"Pub. L. 96–487, title XI, § 1107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2463"},"text":"94 Stat. 2463","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
