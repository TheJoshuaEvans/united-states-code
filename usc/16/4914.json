{"tag":"section","attrib":{"id":"id79f7cbf7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4914"},"text":null,"children":[{"tag":"num","attrib":{"value":"4914"},"text":"§ 4914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marking and recordkeeping","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f7cbf8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4914/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to promulgate regulations to require marking or recordkeeping that the Secretary determines will contribute significantly to the ability of the Secretary to ensure compliance with the prohibitions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4910"},"text":"section 4910 of this title","children":[],"tail":", for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cbf9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4914/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any exotic bird that is imported after ","children":[{"tag":"date","attrib":{"date":"1992-10-23"},"text":"October 23, 1992","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cbfa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4914/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any other exotic bird that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cbfb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4914/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hatched after ","children":[{"tag":"date","attrib":{"date":"1992-10-23"},"text":"October 23, 1992","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cbfc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4914/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offered for sale; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cbfd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4914/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" of a species—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f7cbfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4914/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the export of which from any country of origin is prohibited; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f7cbff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4914/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is subject to a high level of illegal trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f7cc00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4914/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Avoiding deterrence of breeding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall seek to ensure that regulations promulgated under this section will not have the effect of deterring captive breeding of exotic birds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f7cc01-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tI/s115"},"text":"Pub. L. 102–440, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2232"},"text":"106 Stat. 2232","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
