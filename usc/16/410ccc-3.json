{"tag":"section","attrib":{"id":"id776cda80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ccc–3"},"text":"§ 410ccc–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id776cda81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, the Secretary is authorized to acquire lands and interest therein within the boundaries of the historical park by donation, purchase with donated or appropriated funds, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776cda82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local properties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Lands and interests therein that are owned by the State of Louisiana, or any political subdivision thereof, may be acquired only by donation or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776cda83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Museum Contents, Inc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Lands and structures identified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ccc–1/b/2"},"text":"section 410ccc–1(b)(2) of this title","children":[],"tail":" may be acquired only by donation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776cda84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreement sites","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Lands and interests therein that are the subject of cooperative agreements pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ccc–1/b/3"},"text":"section 410ccc–1(b)(3) of this title","children":[],"tail":" shall not be acquired except with the consent of the owner thereof."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id776cda85-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/449/tIII/s305"},"text":"Pub. L. 103–449, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4759"},"text":"108 Stat. 4759","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
