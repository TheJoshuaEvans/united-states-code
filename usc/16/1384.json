{"tag":"section","attrib":{"id":"id79238b6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1384"},"text":null,"children":[{"tag":"num","attrib":{"value":"1384"},"text":"§ 1384.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79238b70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1384/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Commerce","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79238b71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1384/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated to the Department of Commerce, for purposes of carrying out its functions and responsibilities under this subchapter (other than sections 1386 and 1387 of this title) and subchapter V, $12,138,000 for fiscal year 1994, $12,623,000 for fiscal year 1995, $13,128,000 for fiscal year 1996, $13,653,000 for fiscal year 1997, $14,200,000 for fiscal year 1998, and $14,768,000 for fiscal year 1999.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79238b72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1384/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated to the Department of Commerce, for purposes of carrying out sections 1386 and 1387 of this title, $20,000,000 for each of the fiscal years 1994 through 1999.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79238b73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1384/b"},"text":null,"children":[{"tag":"num","attrib