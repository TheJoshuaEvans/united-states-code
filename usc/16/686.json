{"tag":"section","attrib":{"id":"id7875984f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s686"},"text":null,"children":[{"tag":"num","attrib":{"value":"686"},"text":"§ 686.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of local game laws not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the purpose of sections 684 and 685 of this title to protect from trespass the public lands of the United States and the game animals and birds which may be thereon, and not to interfere with the operation of the local game laws as affecting private, State, or Territorial lands.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78759850-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1905-01-24/ch137/s3"},"text":"Jan. 24, 1905, ch. 137, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/614"},"text":"33 Stat. 614","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1906-06-29/ch3593/s3"},"text":"June 29, 1906, ch. 3593, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/607"},"text":"34 Stat. 607","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
