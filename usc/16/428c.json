{"tag":"section","attrib":{"id":"id778e44bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s428c"},"text":null,"children":[{"tag":"num","attrib":{"value":"428c"},"text":"§ 428c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistants to commission; expenses of commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to assign any officials of the Interior Department to the assistance of the commission if he deems it advisable. He is authorized to pay the reasonable expenses of the commission and their assistants incurred in the actual performance of the duties herein imposed upon them.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778e44bd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-03-26/ch248/s4"},"text":"Mar. 26, 1928, ch. 248, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/367"},"text":"45 Stat. 367","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/738/s5"},"text":"Pub. L. 86–738, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-08"},"text":"Sept. 8, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/876"},"text":"74 Stat. 876","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778e44be-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id778e44bf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id778e44c0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Herein, referred to in text, means act ","children":[{"tag":"date","attrib":{"date":"1928-03-26"},"text":"Mar. 26, 1928","children":[],"tail":", which is classified to sections 428 to 428d and 428e to 428i of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id778e44c1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id778e44c2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of administrative functions of park, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s428"},"text":"section 428 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
