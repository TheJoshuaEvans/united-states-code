{"tag":"section","attrib":{"id":"id787a529f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698m"},"text":null,"children":[{"tag":"num","attrib":{"value":"698m"},"text":"§ 698m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for Big Cypress Preserve and Addition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id787a52a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), there are authorized to be appropriated such sums as may be necessary to carry out the provisions of sections 698f to 698m–4 of this title, but not to exceed $156,700,000 for the acquisition of lands and interests in lands and not to exceed $900,000 for development. Any funds donated to the United States by the State of Florida pursuant to chapter 73–131 of the Florida statutes shall be used solely for the acquisition of lands and interests in land within the preserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787a52a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby authorized to be appropriated from the Land and Water Conservation Fund not to exceed $49,500,000 for the acquisition of lands within the Addition. There is hereby authorized to be appropriated such sums as may be necessary for development in the Addition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id787a52a2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/440/s8"},"text":"Pub. L. 93–440, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-11"},"text":"Oct. 11, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1261"},"text":"88 Stat. 1261","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tII/s201/1"},"text":"Pub. L. 95–625, title II, § 201(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3473"},"text":"92 Stat. 3473","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/301/s7"},"text":"Pub. L. 100–301, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-29"},"text":"Apr. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/446"},"text":"102 Stat. 446","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787a52a3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id787a52a4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id787a52a5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/301/s7/1"},"text":"Pub. L. 100–301, § 7(1)","children":[],"tail":", designated existing provisions as subsec. (a), substituted “Except as provided in subsection (b), there” for “There”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Pub. L. 95–625","children":[],"tail":" increased land acquisition appropriations authorization to $156,700,000 from $116,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
