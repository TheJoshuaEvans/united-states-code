{"tag":"section","attrib":{"id":"id79286d64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393"},"text":null,"children":[{"tag":"num","attrib":{"value":"1393"},"text":"§ 1393.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation and mitigation assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79286d65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79286d66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the Secretary of Commerce, acting through the Under Secretary of Commerce for Oceans and Atmosphere (in this title "},{"tag":"ref","attrib":{"idref":"fn002634"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002634"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" referred to as the “Under Secretary”) shall establish a program to provide competitive financial assistance, on an annual basis, and cooperative agreements including multiyear grants and direct payment, to eligible entities for eligible uses, such as projects designed to reduce the lethal and sub-lethal effects of human activities on North Atlantic right whales."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of existing authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance provided under this section shall be carried out in a manner consistent with authorities available to the Secretary under the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.) and the Marine Mammal Protection Act of 1972 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1361"},"text":"16 U.S.C. 1361","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary may enter into cooperative agreements with the National Fish and Wildlife Foundation established by the National Fish and Wildlife Foundation Establishment Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3701"},"text":"16 U.S.C. 3701","children":[],"tail":" et seq.) to carry out this title."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79286d69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity is an eligible entity for purposes of assistance awarded under subsection (a) if the entity is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79286d6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a relevant port authority for a port;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a relevant State, regional, local, or Tribal government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any other individual or entity, as determined appropriate by the Under Secretary, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79286d6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an owner or operator of a vessel, as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s3"},"text":"section 3 of title 1","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79286d6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participants within sectors of the maritime industry, such as boating, shipping, fishing, fishing gear and rope manufacturing, and other maritime activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization or research institution with expertise in commercial fisheries, gear innovation, and North Atlantic right whale conservation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of entities described in paragraphs (1) through (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79286d71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance awarded under subsection (a) may be used to develop, assess, and carry out activities that reduce human induced threats to North Atlantic right whales, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79286d72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding research to identify, deploy, or test innovative gear technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsidizing acquisition of innovative gear technologies to improve adoption of those technologies by fisheries participants, which may include direct payment to fisheries participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training for fisheries participants to improve deployment, safety, and adoption of innovative gear technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding for monitoring necessary to support dynamic management of fisheries, vessel traffic, or other needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other uses as determined by the Under Secretary in consultation with relevant eligible entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79286d77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether to fund project proposals under this section, the Under Secretary shall prioritize projects—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79286d78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with a substantial likelihood of reducing lethal and sub-lethal effects on North Atlantic right whales from fishing gear entanglements or vessel collisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that include cooperation with fishing industry participants or other private sector stakeholders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that demonstrate, or have the potential to provide, economic benefits to small businesses based in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79286d7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited uses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79286d7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), funds awarded under this section may not be used to distribute resources to an entity or individual that is not a United States person (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7701/a/3"},"text":"section 7701(a)(3) of title 26","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds awarded under this section may be used to distribute resources to a partnership that includes an entity or individual that is not a United States person (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7701/a/30"},"text":"section 7701(a)(30) of title 26","children":[],"tail":") if the resources are distributed directly to a partner in the partnership that is a United States person (as so defined)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79286d7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79286d7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each individual or entity that receives assistance under this section for a project shall submit to the Under Secretary periodic reports (at such intervals as the Under Secretary may require) that include all information that the Under Secretary, after consultation with other government officials, determines is necessary to evaluate the progress and success of the project for the purposes of ensuring positive results, assessing problems, and fostering improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1393/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to the public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Reports under paragraph (1) shall be made available to the public in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79286d81-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dJJ/tII/s201"},"text":"Pub. L. 117–328, div. JJ, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6090"},"text":"136 Stat. 6090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79286d82-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79286d83-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79286d84-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (a)(1), (3), means title II of div. JJ of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":", which enacted this section and provisions set out as notes under this section. For complete classification of title II to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Endangered Species Act of 1973, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/884"},"text":"87 Stat. 884","children":[],"tail":", which is classified principally to chapter 35 (§ 1531 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"section 1531 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Marine Mammal Protection Act of 1972, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522"},"text":"Pub. L. 92–522","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1027"},"text":"86 Stat. 1027","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1361"},"text":"section 1361 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Fish and Wildlife Foundation Establishment Act, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/244"},"text":"Pub. L. 98–244","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-03-26"},"text":"Mar. 26, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/107"},"text":"98 Stat. 107","children":[],"tail":", which is classified generally to chapter 57 (§ 3701 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3701"},"text":"section 3701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79286d85-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Consolidated Appropriations Act, 2023, and not as part of the Marine Mammal Protection Act of 1972 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79286d86-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79286d87-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report to Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dJJ/tII/s202"},"text":"Pub. L. 117–328, div. JJ, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6092"},"text":"136 Stat. 6092","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dJJ/tII/s202"},"text":"“Not later than 2 years after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"], and every 5 years thereafter, the Under Secretary [of Commerce for Oceans and Atmosphere] shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Natural Resources of the House of Representatives a report on the results and effectiveness of projects receiving assistance provided under this title [enacting this section and provisions set out as notes under this section].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79286d88-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Acceptance and Use of Donations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dJJ/tII/s203/b"},"text":"Pub. L. 117–328, div. JJ, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6092"},"text":"136 Stat. 6092","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dJJ/tII/s203/b"},"text":"“The Under Secretary [of Commerce for Oceans and Atmosphere] may accept, receive, solicit, hold, administer, and use any gift, devise, or bequest, consistent with policy of the Department of Commerce in effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"], to provide assistance under section 201 ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1393"},"text":"16 U.S.C. 1393","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
