{"tag":"section","attrib":{"id":"id7883c833-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715n"},"text":null,"children":[{"tag":"num","attrib":{"value":"715n"},"text":"§ 715n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Take” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of this subchapter the word “take” shall be construed to mean pursue, hunt, shoot, capture, collect, kill, or attempt to pursue, hunt, shoot, capture, collect, or kill, unless the context otherwise requires.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7883c834-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-02-18/ch257/s15"},"text":"Feb. 18, 1929, ch. 257, § 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1225"},"text":"45 Stat. 1225","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
