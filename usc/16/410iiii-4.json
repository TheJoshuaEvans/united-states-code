{"tag":"section","attrib":{"id":"id7787192b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"410iiii–4"},"text":"§ 410iiii–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of historical park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7787192c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer the historical park in accordance with this subchapter and the laws generally applicable to units of the National Park System, including the Act of ","children":[{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":"), and the Act of "},{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/49/666"},"text":"49 Stat. 666","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7787192d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to enter into cooperative agreements with private as well as public agencies, organizations, and institutions in furtherance of the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7787192e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment to general management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prepare and submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives an amendment to the management plan for the historical park to include the portions of the historical park in Summerton, Clarendon County, South Carolina.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7787192f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/525/tI/s105"},"text":"Pub. L. 102–525, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-26"},"text":"Oct. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3439"},"text":"106 Stat. 3439","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/123"},"text":"Pub. L. 117–123","children":[],"tail":", §§ 2(c)(3), (4), 3(g), "},{"tag":"date","attrib":{"date":"2022-05-12"},"text":"May 12, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1196"},"text":"136 Stat. 1196","children":[],"tail":", 1199.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77871930-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77871931-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":