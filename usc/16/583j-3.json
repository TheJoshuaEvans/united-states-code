{"tag":"section","attrib":{"id":"id7851bc24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"583j–3"},"text":"§ 583j–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative services and support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7851bc25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Startup funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of assisting the Foundation in establishing an office and meeting initial administrative, project, and other startup expenses, the Secretary is authorized to provide to the Foundation $500,000, from funds appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s583j–8/a"},"text":"section 583j–8(a) of this title","children":[],"tail":", per year for the two years beginning "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"October 1, 1992","children":[],"tail":". Such funds shall remain available to the Foundation until they are expended for authorized purposes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the startup funds provided under subsection (a) of this section, during fiscal years 2016 through 2023, the Secretary is authorized to provide matching funds for administrative and project expenses incurred by the Foundation as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s583j–8/b"},"text":"section 583j–8(b) of this title","children":[],"tail":" including reimbursement of expenses under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s583j–1"},"text":"section 583j–1 of this title","children":[],"tail":", not to exceed then current Federal Government per diem rates."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At any time, the Secretary may provide the Foundation use of Department of Agriculture personnel, facilities, and equipment, with partial or no reimbursement, with such limitations and on such terms and conditions as the Secretary shall establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7851bc28-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/593/tIV/s405"},"text":"Pub. L. 101–593, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2972"},"text":"104 Stat. 2972","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/106/s3/a"},"text":"Pub. L. 103–106, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-12"},"text":"Oct. 12, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1031"},"text":"107 Stat. 1031","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/54/tII/s201/a"},"text":"Pub. L. 114–54, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"Sept. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/515"},"text":"129 Stat. 515","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8503/a"},"text":"Pub. L. 115–334, title VIII, § 8503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4847"},"text":"132 Stat. 4847","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7851bc29-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7851bc2a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7851bc2b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/54"},"text":"Pub. L. 114–54","children":[],"tail":" substituted “during fiscal years 2016 through 2018” for “for a period of five years beginning "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"October 1, 1992","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/106/s3/a/1"},"text":"Pub. L. 103–106, § 3(a)(1)","children":[],"tail":", inserted “, project,” after “administrative” and substituted “beginning "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"October 1, 1992","children":[],"tail":"” for “following "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/106/s3/a/2"},"text":"Pub. L. 103–106, § 3(a)(2)","children":[],"tail":", substituted “beginning "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"October 1, 1992","children":[],"tail":"” for “from "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":"” and inserted “and project” after “administrative”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7851bc2c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7851bc2d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/106"},"text":"Pub. L. 103–106","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/106/s2"},"text":"Pub. L. 103–106, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-12"},"text":"Oct. 12, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1031"},"text":"107 Stat. 1031","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/106/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“It is the purpose of this Act [see Short Title of 1993 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s583j"},"text":"section 583j of this title","children":[],"tail":"]—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for start-up and matching funds for project expenses to carry out the National Forest Foundation Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s583j"},"text":"16 U.S.C. 583j","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to extend the funding authorization for start-up expenses for 1 year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
