{"tag":"section","attrib":{"id":"id79fcacaf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5158"},"text":null,"children":[{"tag":"num","attrib":{"value":"5158"},"text":"§ 5158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of striped bass in the exclusive economic zone","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79fcacb0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5158/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation of fishing in exclusive economic zone","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall promulgate regulations governing fishing for Atlantic striped bass in the exclusive economic zone that the Secretary determines—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fcacb1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5158/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the national standards set forth in section 301 of the Magnuson Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1851"},"text":"16 U.S.C. 1851","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcacb2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5158/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are compatible with the Plan and each Federal moratorium in effect on fishing for Atlantic striped bass within the coastal waters of a coastal State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcacb3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5158/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the effectiveness of State regulations on fishing for Atlantic striped bass within the coastal waters of a coastal State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcacb4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5158/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are sufficient to assure the long-term conservation of Atlantic striped bass populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fcacb5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5158/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation; periodic review of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In preparing regulations under subsection (a), the Secretary shall consult with the Atlantic States Marine Fisheries Commission, the appropriate Regional Fishery Management Councils, and each affected Federal, State, and local government entity. The Secretary shall periodically review regulations promulgated under subsection (a), and if necessary to ensure their continued consistency with the requirements of subsection (a), shall amend those regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fcacb6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5158/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of Magnuson Act provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of sections 307, 308, 309, 310, and 311 of the Magnuson Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1857"},"text":"16 U.S.C. 1857","children":[],"tail":", 1858, 1859, 1860, and 1861) regarding prohibited acts, civil penalties, criminal offenses, civil forfeitures, and enforcement shall apply with respect to regulations and any plan issued under subsection (a) of this section as if such regulations or plan were issued under the Magnuson Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fcacb7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/613/s9"},"text":"Pub. L. 98–613, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/146/s2"},"text":"Pub. L. 105–146, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-16"},"text":"Dec. 16, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2676"},"text":"111 Stat. 2676","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fcacb8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79fcacb9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79fcacba-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/613/s9"},"text":"section 9 of Pub. L. 98–613","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-31"},"text":"Oct. 31, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3190"},"text":"98 Stat. 3190","children":[],"tail":"; "},{"tag":"ref