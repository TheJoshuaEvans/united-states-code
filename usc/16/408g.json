{"tag":"section","attrib":{"id":"id7741fa23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s408g"},"text":null,"children":[{"tag":"num","attrib":{"value":"408g"},"text":"§ 408g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submerged lands surrounding islands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The boundaries of the Isle Royale National Park are hereby extended to include any submerged lands within the territorial jurisdiction of the United States within four and one-half miles of the shoreline of Isle Royale and the surrounding islands, including Passage Island and the Gull Islands, and the Secretary of the Interior is hereby authorized, in his discretion, to acquire title by donation to any such lands not now owned by the United States, the title to be satisfactory to him.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7741fa24-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1942-03-06/ch152/s3"},"text":"Mar. 6, 1942, ch. 152, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/138"},"text":"56 Stat. 138","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/567/s4/a/2"},"text":"Pub. L. 94–567, § 4(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-20"},"text":"Oct. 20, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2694"},"text":"90 Stat. 2694","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7741fa25-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7741fa26-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7741fa27-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/567"},"text":"Pub. L. 94–567","children":[],"tail":" inserted “within the territorial jurisdiction of the United States” after “submerged lands”, “including Passage Island and the Gull Islands” after “surrounding islands”, and struck out “immediately” after “Isle Royale and the”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
