{"tag":"section","attrib":{"id":"id788fd679-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s754b"},"text":null,"children":[{"tag":"num","attrib":{"value":"754b"},"text":"§ 754b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds from private entities credited to Resource Management account","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, in fiscal year 1999 and thereafter, sums provided by private entities for activities pursuant to reimbursable agreements shall be credited to the “Resource Management” account and shall remain available until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788fd67a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/3/tI"},"text":"Pub. L. 106–113, div. B, § 1000(a)(3) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–139.)"}],"tail":"\n"}],"tail":null}
