":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–41, provided that the amendment made by that section is effective 15 days after "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79be9260-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/251"},"text":"Pub. L. 102–251","children":[],"tail":" effective on date on which Agreement between United States and Union of Soviet Socialist Republics on the Maritime Boundary, signed "},{"tag":"date","attrib":{"date":"1990-06-01"},"text":"June 1, 1990","children":[],"tail":", enters into force for United States, with authority to prescribe implementing regulations effective "},{"tag":"date","attrib":{"date":"1992-03-09"},"text":"Mar. 9, 1992","children":[],"tail":", but with no such regulation to be effective until date on which Agreement enters into force for United States, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/251/s308"},"text":"section 308 of Pub. L. 102–251","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s773"},"text":"section 773 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79be9261-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/5/s1"},"text":"Pub. L. 99–5, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-03-15"},"text":"Mar. 15, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/7"},"text":"99 Stat. 7","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/5/s1"},"text":"“That this Act [enacting this chapter and repealing sections 776 to 776f of this title and provisions set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s776"},"text":"section 776 of this title","children":[],"tail":"] may be cited as the ‘Pacific Salmon Treaty Act of 1985’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id79be9262-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79be9263-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Territorial Sea of United States","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For extension of territorial sea of United States, see Proc. No. 5928, set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
