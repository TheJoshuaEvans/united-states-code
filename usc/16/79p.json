{"tag":"section","attrib":{"id":"id76fcda4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s79p"},"text":null,"children":[{"tag":"num","attrib":{"value":"79p"},"text":"§ 79p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community services and employment opportunities of Redwoods United, Inc. to be maintained at present rate of employment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is further authorized, and the Congress specifically directs that it shall be a purpose of this Act, that the community services and employment opportunities provided by Redwoods United, Incorporated, a nonprofit corporation located in Manila, California, shall be maintained at the present rate of employment to the greatest degree practicable.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76fcda4c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/250/tI/s107"},"text":"Pub. L. 95–250, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-27"},"text":"Mar. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/171"},"text":"92 Stat. 171","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id76fcda4d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id76fcda4e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id76fcda4f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, means "