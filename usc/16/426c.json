{"tag":"section","attrib":{"id":"id778bd43e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s426c"},"text":null,"children":[{"tag":"num","attrib":{"value":"426c"},"text":"§ 426c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistants to commission; expenses of commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to assign any officials of the Interior Department to the assistance of the commission if he deems it advisable. He is authorized to pay the reasonable expenses of the commission and their assistants incurred in the actual performance of the duties imposed upon them by sections 426 to 426j of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778bd43f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-03/ch374/s4"},"text":"Mar. 3, 1927, ch. 374, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1400"},"text":"44 Stat. 1400","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778bd440-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id778bd441-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id778bd442-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of administrative functions of park, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s426"},"text":"section 426 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
