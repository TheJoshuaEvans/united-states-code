{"tag":"section","attrib":{"id":"id79b9d7d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3454"},"text":null,"children":[{"tag":"num","attrib":{"value":"3454"},"text":"§ 3454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of the Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b9d7d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3454/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this subchapter, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b9d7d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3454/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to any council to assist in developing and implementing an area plan for a designated area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3454/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with other departments and agencies of the Federal Government, States, local units of government, local Indian tribes, and local nonprofit organizations in conducting surveys and inventories, disseminating information, and developing area plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3454/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in carrying out an area plan approved by the Secretary for any designated area by providing technical assistance and financial assistance to any council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3454/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into agreements with councils in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3455"},"text":"section 3455 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b9d7d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3454/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinator","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b9d7da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3454/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To improve the provision of technical assistance to councils under this subchapter, the Secretary shall designate for each council an individual to be the coordinator for the council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3454/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A coordinator for a council shall be directly responsible for the provision of technical assistance to the council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b9d7dc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXV/s1531"},"text":"Pub. L. 97–98, title XV, § 1531","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tII/s2504"},"text":"Pub. L. 107–171, title II, § 2504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/272"},"text":"116 Stat. 272","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2805/c"},"text":"Pub. L. 110–234, title II, § 2805(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1088"},"text":"122 Stat. 1088","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title II, § 2805(c), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1816.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b9d7dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79b9d7de-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79b9d7df-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"hre