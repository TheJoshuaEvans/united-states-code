{"tag":"section","attrib":{"id":"id77a157fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450bb–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"450bb–3"},"text":"§ 450bb–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of additional lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To further the commemorative purposes of sections 450bb to 450bb–2 of this title, by providing historic properties and administrative facilities, the Secretary of the Interior is authorized to acquire, in the manner hereafter stated, the Storer College site, the original site of John Brown’s “Fort” and the old Federal armory, comprising altogether approximately thirty acres, for addition to Harpers Ferry National Historical Park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a157fc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/655/s1"},"text":"Pub. L. 86–655, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-14"},"text":"July 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/520"},"text":"74 Stat. 520","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/33"},"text":"Pub. L. 88–33","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-05-29"},"text":"May 29, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/52"},"text":"77 Stat. 52","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77a157fd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77a157fe-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77a157ff-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Harpers Ferry National Historical Park” substituted in text for “Harpers Ferry National Monument” in view of redesignation of Harpers Ferry National Monument as Harpers Ferry National Historical Park by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/33"},"text":"Pub. L. 88–33","children":[],"tail":", classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s450bb–6"},"text":"section 450bb–6 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
