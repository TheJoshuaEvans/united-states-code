{"tag":"section","attrib":{"id":"id7a3aa0bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484"},"text":null,"children":[{"tag":"num","attrib":{"value":"8484"},"text":"§ 8484.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accessible trails","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3aa0c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary concerned shall select a location or locations to develop at least 3 new accessible trails—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa0c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on National Forest System lands in each region of the Forest Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on land managed by the National Park Service in each region of the National Park Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on land managed by the Bureau of Land Management in each region of the Bureau of Land Management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on land managed by the United States Fish and Wildlife Service in each region of the United States Fish and Wildlife Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa0c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing an accessible trail under subsection (a), the Secretary concerned—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa0c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa0c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create a new accessible trail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa0c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modify an existing trail into an accessible trail; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa0c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create an accessible trail from a combination of new and existing trails; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa0cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with stakeholders with respect to the feasibility and resources necessary for completing the accessible trail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa0cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the accessible trail complies with the Architectural Barriers Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4151"},"text":"42 U.S.C. 4151","children":[],"tail":" et seq.) and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"section 794 of title 29","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa0cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, ensure that outdoor constructed features supporting the accessible trail, including trail bridges, parking spaces, and restroom facilities, meet the requirements of the Architectural Barriers Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4151"},"text":"42 U.S.C. 4151","children":[],"tail":" et seq.) and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"section 794 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa0ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 7 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary concerned, in coordination with stakeholders described under subsection (b)(2), shall complete each accessible trail developed under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa0cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maps, signage, and promotional materials","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each accessible trail developed under subsection (a), the Secretary concerned shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa0d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish and distribute maps and install signage, consistent with Architectural Barriers Act of 1968 accessibility guidelines and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794d"},"text":"section 794d of title 29","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with stakeholders to leverage any non-Federal resources necessary for the development, stewardship, completion, or promotion of the accessible trail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa0d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict avoidance with other uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing each accessible trail under subsection (a), the Secretary concerned shall ensure that the accessible trail—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa0d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" minimizes conflict with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa0d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the uses in effect before ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", with respect to any trail that is part of that accessible trail;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa0d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiple-use areas where biking, hiking, horseback riding, off-highway vehicle recreation, or use by pack and saddle stock are existing uses on ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa0d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes for which any trail is established under the National Trails System Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1241"},"text":"16 U.S.C. 1241","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with all applicable land use and management plans of the Federal recreational lands and waters on which the accessible trail is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa0d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa0d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary concerned, in coordination with stakeholders and other interested organizations, shall prepare and publish an interim report that lists the accessible trails developed under this section during the previous 3 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8484/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 7 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary concerned, in coordination with stakeholders and other interested organizations, shall prepare and publish a final report that lists the accessible trails developed under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3aa0db-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tII/s214"},"text":"Pub. L. 118–234, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2883"},"text":"138 Stat. 2883","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3aa0dc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3aa0dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a3aa0de-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Architectural Barriers Act of 1968, referred to in subsec. (b)(2)(B), (C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/480"},"text":"Pub. L. 90–480","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-12"},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/718"},"text":"82 Stat. 718","children":[],"tail":", which is classified generally to chapter 51 (§ 4151 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4151"},"text":"section 4151 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"Section 794 of title 29","children":[],"tail":", referred to in subsec. (b)(2)(B), (C), was in the original a reference to section 504 of the Rehabilitation Act, and was translated as meaning section 504 of the Rehabilitation Act of 1973, "},{"tag":"ref","attrib":{"href":"/us/pl/93/112"},"text":"Pub. L. 93–112","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794d"},"text":"Section 794d of title 29","children":[],"tail":", referred to in subsec. (d)(1), was in the original a reference to section 508 of the Rehabilitation Act, and was translated as meaning section 508 of the Rehabilitation Act of 1973, "},{"tag":"ref","attrib":{"href":"/us/pl/93/112"},"text":"Pub. L. 93–112","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Trails System Act, referred to in subsec. (e)(1)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/543"},"text":"Pub. L. 90–543","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-02"},"text":"Oct. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/919"},"text":"82 Stat. 919","children":[],"tail":", which is classified generally to chapter 27 (§ 1241 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1241"},"text":"section 1241 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
