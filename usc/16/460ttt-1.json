{"tag":"section","attrib":{"id":"id7807e258-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ttt–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ttt–1"},"text":"§ 460ttt–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map and description","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7807e259-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ttt–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2006-12-01"},"text":"December 1, 2006","children":[],"tail":", the Secretary shall file a map and a legal description of the national recreation area designated by "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460ttt"},"text":"section 460ttt of this title","children":[],"tail":" with—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e25a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ttt–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Resources of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e25b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ttt–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e25c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ttt–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture, Nutrition, and Forestry of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e25d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ttt–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Force of law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A map and legal description filed under subsection (a) shall have the same force and effect as if included in this subchapter, except that the Secretary may correct clerical and typographical errors in the map and legal description.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e25e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ttt–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each map and legal description filed under subsection (a) shall be filed and made available for public inspection in the Office of the Chief of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7807e25f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/382/tII/s222"},"text":"Pub. L. 109–382, title II, § 222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-01"},"text":"Dec. 1, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2676"},"text":"120 Stat. 2676","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7807e260-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7807e261-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7807e262-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
