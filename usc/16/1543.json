{"tag":"section","attrib":{"id":"id7950dcb5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1543"},"text":null,"children":[{"tag":"num","attrib":{"value":"1543"},"text":"§ 1543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction with Marine Mammal Protection Act of 1972","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this chapter, no provision of this chapter shall take precedence over any more restrictive conflicting provision of the Marine Mammal Protection Act of 1972 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1361"},"text":"16 U.S.C. 1361","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7950dcb6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/205/s17"},"text":"Pub. L. 93–205, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/903"},"text":"87 Stat. 903","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7950dcb7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7950dcb8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7950dcb9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/884"},"text":"81 Stat. 884","children":[],"tail":", known as the Endangered Species Act of 1973, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"section 1531 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Marine Mammal Protection Act of 1972, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522"},"text":"Pub. L. 92–522","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1027"},"text":"86 Stat. 1027","children":[],"tail":", which is classified generally to chapter 31 (§ 1361 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1361"},"text":"section 1361 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
