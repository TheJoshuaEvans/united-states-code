{"tag":"section","attrib":{"id":"id78fd6580-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1272"},"text":null,"children":[{"tag":"num","attrib":{"value":"1272"},"text":"§ 1272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this chapter is to implement the policy set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1271"},"text":"section 1271 of this title","children":[],"tail":" by instituting a national wild and scenic rivers system, by designating the initial components of that system, and by prescribing the methods by which and standards according to which additional components may be added to the system from time to time."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78fd6581-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/542/s1/c"},"text":"Pub. L. 90–542, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-02"},"text":"Oct. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/906"},"text":"82 Stat. 906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78fd6582-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78fd6583-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78fd6584-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consists of subsec. (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/542/s1"},"text":"section 1 of Pub. L. 90–542","children":[],"tail":". Subsecs. (a) and (b) of section 1 are classified to section 1271 and section 1271 note, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
