{"tag":"section","attrib":{"id":"id76ff2455-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s80a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"80a–1"},"text":"§ 80a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands excluded from Kings Canyon National Park and added to Sequoia National Forest","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of improving the boundary of Kings Canyon National Park, California, and excluding therefrom certain land that is no longer needed for park purposes, that particular area of the park, comprising approximately 160 acres, lying west of the section line between sections 21 and 22, and lying west of the section line between sections 27 and 28, township 13 south, range 30 east, Mount Diablo meridian, is excluded from the park.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Land excluded from the park by this section on and after ","children":[{"tag":"date","attrib":{"date":"1958-08-14"},"text":"August 14, 1958","children":[],"tail":" shall be a part of the Sequoia National Forest."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76ff2456-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/666/s1"},"text":"Pub. L. 85–666, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-14"},"text":"Aug. 14, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/616"},"text":"72 Stat. 616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id76ff2457-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id76ff2458-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id76ff2459-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-03-04/ch40"},"text":"act Mar. 4, 1940, ch. 40","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/41"},"text":"54 Stat. 41","children":[],"tail":", which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
