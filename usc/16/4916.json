{"tag":"section","attrib":{"id":"id79f7cc04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4916"},"text":null,"children":[{"tag":"num","attrib":{"value":"4916"},"text":"§ 4916.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to State law","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter may be construed as precluding the regulation under State law of the sale, transfer, or possession of exotic birds if such regulation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cc05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4916/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not authorize any sale, transfer, or possession of exotic birds that is prohibited under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cc06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4916/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the international obligations of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f7cc07-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tI/s117"},"text":"Pub. L. 102–440, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2233"},"text":"106 Stat. 2233","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
