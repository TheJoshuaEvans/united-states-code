{"tag":"section","attrib":{"id":"id7a0167f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5701"},"text":null,"children":[{"tag":"num","attrib":{"value":"5701"},"text":"§ 5701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0167f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement the interim agreement for the conservation of salmon stocks originating from the Yukon River in Canada agreed to through an exchange of notes between the Government of the United States and the Government of Canada on ","children":[{"tag":"date","attrib":{"date":"1995-02-03"},"text":"February 3, 1995","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for representation by the United States on the Yukon River Panel established under such agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize to be appropriated sums necessary to carry out the responsibilities of the United States under such agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0167f4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tVII/s702"},"text":"Pub. L. 104–43, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/392"},"text":"109 Stat. 392","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0167f5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a0167f6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7a0167f7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/219/tIII/s301"},"text":"Pub. L. 108–219, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-04-13"},"text":"Apr. 13, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/616"},"text":"118 Stat. 616","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/219/tIII/s301"},"text":"“This title [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5727"},"text":"section 5727 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1977"},"text":"section 1977 of Title 22","children":[],"tail":", Foreign Relations and Intercourse] may be cited as the ‘International Fisheries Reauthorization Act of 2004’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a0167f8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tVII/s701"},"text":"Pub. L. 104–43, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/392"},"text":"109 Stat. 392","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/43/tVII/s701"},"text":"“This title [enacting this subchapter] may be cited as the ‘Yukon River Salmon Act of 1995’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/450/tII/s201"},"text":"Pub. L. 106–450, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1941"},"text":"114 Stat. 1941","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/450/tII/s201"},"text":"“This title [enacting subchapter II of this chapter] may be cited as the ‘Yukon River Salmon Act of 2000’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
