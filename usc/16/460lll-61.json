{"tag":"section","attrib":{"id":"id77fe44d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–61"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–61"},"text":"§ 460lll–61.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fe44d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–61/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agriculture","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary of Agriculture such sums as are necessary to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fe44d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–61/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit the Secretary to exercise administrative jurisdiction over the Recreation Area under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe44d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–61/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer the Recreation Area as a unit of the National Forest System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fe44da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–61/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interior","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary of the Interior such sums as are necessary to carry out activities within the Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fe44db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–61/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fe44dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–61/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Secretary of Agriculture may expend amounts appropriated to carry out this subchapter in a manner consistent with the authorities exercised by the Tennessee Valley Authority before the transfer of the Recreation Area to the administrative jurisdiction of the Secretary of Agriculture, including campground management and visitor services, paid advertisement, and procurement of food and supplies for resale purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe44dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–61/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall not use amounts appropriated to carry out this subchapter for an activity described in section 460","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–24(b) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fe44de-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s551"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 551]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–326; "},{"tag":"ref","attrib":{"href":"/us/pl/106/291/tII"},"text":"Pub. L. 106–291, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-11"},"text":"Oct. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/974"},"text":"114 Stat. 974","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/63/tIII/s335"},"text":"Pub. L. 107–63, title III, § 335","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-05"},"text":"Nov. 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/472"},"text":"115 Stat. 472","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/108/tIII/s334"},"text":"Pub. L. 108–108, title III, § 334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-10"},"text":"Nov. 10, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1312"},"text":"117 Stat. 1312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tII/s201/i"},"text":"Pub. L. 117–328, div. DD, title II, § 201(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5584"},"text":"136 Stat. 5584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77fe44df-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77fe44e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77fe44e1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s201/i/1"},"text":"Pub. L. 117–328, § 201(i)(1)","children":[],"tail":", substituted “Recreation Area” for “Recreation Area area”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s201/i/2"},"text":"Pub. L. 117–328, § 201(i)(2)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c). Prior to amendment, text read as follows: “The Secretary of Agriculture may expend amounts appropriated or otherwise made available to carry out this subchapter in a manner consistent with the authorities exercised by the Tennessee Valley Authority before the transfer of the Recreation Area to the administrative jurisdiction of the Secretary, including campground management and visitor services, paid advertisement, and procurement of food and supplies for resale purposes.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/108"},"text":"Pub. L. 108–108","children":[],"tail":" amended heading and text of subsec. (c) generally. Prior to amendment, text read as follows: “Until "},{"tag":"date","attrib":{"date":"2004-09-30"},"text":"September 30, 2004","children":[],"tail":", the Secretary of Agriculture may expend amounts appropriated or otherwise made available to carry out this subchapter in a manner consistent with the authorities exercised by the Tennessee Valley Authority, before the transfer of the Recreation Area to the administrative jurisdiction of the Secretary, regarding procurement of property, services, supplies, and equipment.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/63"},"text":"Pub. L. 107–63","children":[],"tail":" substituted “2004” for “2002”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/291"},"text":"Pub. L. 106–291","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
