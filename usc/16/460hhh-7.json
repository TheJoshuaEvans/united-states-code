{"tag":"section","attrib":{"id":"id77f7194d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"460hhh–7"},"text":"§ 460hhh–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to encourage unified and cost-effective management and interpretation of natural and cultural resources in southern Nevada, the Secretary may enter into cooperative agreements with other Federal, State, and local agencies, and with nonprofit entities, that provide for the management and interpretation of natural and cultural resources.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77f7194e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/63/s9"},"text":"Pub. L. 103–63, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-04"},"text":"Aug. 4, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/300"},"text":"107 Stat. 300","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
