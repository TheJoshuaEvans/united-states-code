{"tag":"section","attrib":{"id":"id7848466e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s576d"},"text":null,"children":[{"tag":"num","attrib":{"value":"576d"},"text":"§ 576d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure of Supplemental National Forest Reforestation Fund moneys; availability of moneys from other sources unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Moneys transferred to the National Forest Reforestation Fund under the provisions of sections 576c to 576e ","children":[{"tag":"ref","attrib":{"idref":"fn002452"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002452"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title shall be available to the Secretary of Agriculture, for expenditure upon appropriation, for the purpose of supplementing programs of tree planting and seeding of national forest lands determined by the Secretary to be in need of reforestation. Such moneys shall be available until expended, and shall be provided without prejudice to appropriations or funds available from other sources for the same purposes, including those available pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s576b"},"text":"section 576b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7848466f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/421/s2"},"text":"Pub. L. 92–421, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-18"},"text":"Sept. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/678"},"text":"86 Stat. 678","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78484670-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78484671-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78484672-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s576e"},"text":"Section 576e of this title","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/96/470/tI/s102/b"},"text":"Pub. L. 96–470, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-19"},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2237"},"text":"94 Stat. 2237","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
