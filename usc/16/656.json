{"tag":"section","attrib":{"id":"id786013b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s656"},"text":null,"children":[{"tag":"num","attrib":{"value":"656"},"text":"§ 656.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agents; administering oaths and taking testimony","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The agents are empowered to administer oaths in all cases relating to the service of the United States, and to take testimony in Alaska for the use of the Government in any matter concerning the public revenue.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id786013b9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(R.S. § 1976.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id786013ba-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id786013bb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id786013bc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 1976 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1872-03-05/ch31/s3"},"text":"act Mar. 5, 1872, ch. 31, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/35"},"text":"17 Stat. 35","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
