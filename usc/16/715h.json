{"tag":"section","attrib":{"id":"id78817f06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715h"},"text":null,"children":[{"tag":"num","attrib":{"value":"715h"},"text":"§ 715h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of State game laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter is intended to interfere with the operation of the game laws of the several States applying to migratory game birds insofar as they do not permit what is forbidden by Federal law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78817f07-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-02-18/ch257/s9"},"text":"Feb. 18, 1929, ch. 257, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1224"},"text":"45 Stat. 1224","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
