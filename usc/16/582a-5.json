{"tag":"section","attrib":{"id":"id784f72ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"582a–5"},"text":"§ 582a–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apportionments, advice, criteria, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Apportionments among participating States shall be determined by the Secretary after consultation with the council appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s582a–4"},"text":"section 582a–4 of this title","children":[],"tail":". In making such apportionments, consideration shall be given to pertinent factors including non-Federal expenditures for forestry research by State-certified eligible institutions, areas of non-Federal commercial forest land, and the volume of timber cut annually. Three per centum of such funds as may be appropriated shall be made available to the Secretary for administration of this subchapter. These administrative funds may be used for transportation of scientists who are not officers or employees of the United States to research meetings convened for purposes of assessing research opportunities or research planning."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id784f72ac-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/788/s6"},"text":"Pub. L. 87–788, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-10"},"text":"Oct. 10, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/807"},"text":"76 Stat. 807","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIV/s1441/c"},"text":"Pub. L. 97–98, title XIV, § 1441(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1320"},"text":"95 Stat. 1320","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id784f72ad-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id784f72ae-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id784f72af-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98"},"text":"Pub. L. 97–98","children":[],"tail":" substituted provisions directing the Secretary to make apportionments among participating States only after consultation with the council appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s582a–4"},"text":"section 582a–4 of this title","children":[],"tail":", enumerating the factors to be considered in making apportionments, and authorizing the expenditure of funds to transport scientists to research meetings for provisions which had authorized the Secretary to prescribe necessary rules and regulations, to furnish necessary advice and assistance, and to appoint an advisory committee. See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s582a–4"},"text":"section 582a–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id784f72b0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id784f72b1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98"},"text":"Pub. L. 97–98","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1801"},"text":"section 1801 of Pub. L. 97–98","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4301"},"text":"section 4301 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
