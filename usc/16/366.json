{"tag":"section","attrib":{"id":"id772ee6c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s366"},"text":null,"children":[{"tag":"num","attrib":{"value":"366"},"text":"§ 366.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of water on reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The authority conferred upon the Secretary of the Interior to collect the hot water upon said Hot Springs National Park shall be so construed as to require water to be collected only where such collection is necessary for its proper distribution, and not where by gravity the same can be properly utilized.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id772ee6c7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1891-03-03/ch533/s6"},"text":"Mar. 3, 1891, ch. 533, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/844"},"text":"26 Stat. 844","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-03-04/ch161/s1"},"text":"Mar. 4, 1921, ch. 161, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1407"},"text":"41 Stat. 1407","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id772ee6c8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id772ee6c9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id772ee6ca-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Hot Springs National Park” substituted in text for “Hot Springs Reservation” pursuant to act ","children":[{"tag":"date","attrib":{"date":"1921-03-04"},"text":"Mar. 4, 1921","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
