{"tag":"section","attrib":{"id":"id7a35e566-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8209"},"text":null,"children":[{"tag":"num","attrib":{"value":"8209"},"text":"§ 8209.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability and reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a35e567-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8209/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2020-10-30"},"text":"October 30, 2020","children":[],"tail":", and every 5 years thereafter, the Board shall submit to the appropriate congressional committees a report describing the progress of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e568-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8209/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e569-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8209/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the number of acres, stream miles, or acre-feet, or other suitable measures of fish habitat, that was maintained or improved by Partnerships under this chapter during the 5-year period ending on the date of submission of the report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e56a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8209/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the public access to fish habitats established or improved under this chapter during that 5-year period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e56b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8209/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the improved opportunities for public recreational fishing achieved under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e56c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8209/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the status of fish habitats in the United States as identified by Partnerships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e56d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8209/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment of the status of fish habitat conservation projects carried out with funds provided under this chapter during that period, disaggregated by year, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a35e56e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8209/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the fish habitat conservation projects recommended by the Board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8205/b"},"text":"section 8205(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e56f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8209/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of each fish habitat conservation project approved by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8205/f"},"text":"section 8205(f) of this title","children":[],"tail":", in order of priority for funding;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e570-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8209/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a justification for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a35e571-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8209/b/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the approval of each fish habitat conservation project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a35e572-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8209/b/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the order of priority for funding of each fish habitat conservation project;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e573-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8209/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a justification for any rejection of a fish habitat conservation project recommended by the Board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8205/b"},"text":"section 8205(b) of this title","children":[],"tail":" that was based on a factor other than the criteria described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s8205/c"},"text":"section 8205(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e574-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8209/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accounting of expenditures by Federal, State, or local governments, Indian Tribes, or other entities to carry out fish habitat conservation projects under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a35e575-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188/tII/s209"},"text":"Pub. L. 116–188, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/935"},"text":"134 Stat. 935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/198/tII/s205"},"text":"Pub. L. 118–198, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2682"},"text":"138 Stat. 2682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a35e576-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a35e577-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a35e578-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s205/2/A"},"text":"Pub. L. 118–198, § 205(2)(A)","children":[],"tail":", inserted subsec. (a) designation and heading and struck out former subsec. (a) designation and heading “Reporting” and former par. (1) designation and heading “In general” before “Not later than”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s205/2/B"},"text":"Pub. L. 118–198, § 205(2)(B)","children":[],"tail":", redesignated par. (2) of subsec. (a) as subsec. (b) and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s205/1"},"text":"Pub. L. 118–198, § 205(1)","children":[],"tail":", (2)(B), (3)(A), (B), redesignated par. (2) of subsec. (a) as subsec. (b) and subpars. (A), (B), (C), and (D) of former par. (2) of subsec. (a) as pars. (1), (2), (3), and (5), respectively, of subsec. (b), realigned margins, substituted “subsection (a)” for “paragraph (1)” in introductory provisions, and struck out former subsec. (b) which authorized the Board to submit status and trends report to appropriate congressional committees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s205/3/C"},"text":"Pub. L. 118–198, § 205(3)(C)","children":[],"tail":", (D), added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s205/3/E/i"},"text":"Pub. L. 118–198, § 205(3)(E)(i)","children":[],"tail":", redesignated cls. (i) to (v) as subpars. (A) to (E), respectively, and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s205/3/E/ii"},"text":"Pub. L. 118–198, § 205(3)(E)(ii)","children":[],"tail":", redesignated subcls. (I) and (II) as cls. (i) and (ii), respectively, and realigned margins."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
