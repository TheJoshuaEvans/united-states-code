{"tag":"section","attrib":{"id":"id78b84633-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"831h–3"},"text":"§ 831h–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreational access","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78b84634-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of floating cabin","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “floating cabin” means a watercraft or other floating structure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b84635-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primarily designed and used for human habitation or occupation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b84636-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not primarily designed or used for navigation or transportation on water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b84637-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreational access","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board may allow the use of a floating cabin if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b84638-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the floating cabin is maintained by the owner to reasonable health, safety, and environmental standards, as required by the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b84639-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation has authorized the use of recreational vessels on the waters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b8463a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the floating cabin was located on waters under the jurisdiction of the Corporation as of ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78bab73b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may levy fees on the owner of a floating cabin on waters under the jurisdiction of the Corporation for the purpose of ensuring compliance with subsection (b) if the fees are necessary and reasonable for such purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78bab73c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued recreational use","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78bab73d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a floating cabin located on waters under the jurisdiction of the Corporation on ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", the Board—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78bab73e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may not require the removal of the floating cabin—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78bab73f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a floating cabin that was granted a permit by the Corporation before ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", for a period of 15 years beginning on such date; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78bab740-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a floating cabin not granted a permit by the Corporation before ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", for a period of 5 years beginning on such date; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78bab741-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall approve and allow the use of the floating cabin on waters under the jurisdiction of the Corporation at such time and for such duration as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78bab742-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the floating cabin meets the requirements of subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78bab743-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner of the floating cabin has paid any fee assessed pursuant to subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78bab744-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provisions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78bab745-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subsection restricts the ability of the Corporation to enforce reasonable health, safety, or environmental standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78bab746-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section applies only to floating cabins located on waters under the jurisdiction of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78bab747-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831h–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may establish regulations to prevent the construction of new floating cabins.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78bab748-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-18/ch32/s9b"},"text":"May 18, 1933, ch. 32, § 9b","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tIV/s5003"},"text":"Pub. L. 114–322, title IV, § 5003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1886"},"text":"130 Stat. 1886","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
