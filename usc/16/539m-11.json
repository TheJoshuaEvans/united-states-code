{"tag":"section","attrib":{"id":"id7832c304-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"539m–11"},"text":"§ 539m–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions relating to contributions and land exchange","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7832c305-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c306-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may accept contributions from the Pueblo, or from other persons or governmental entities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c307-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perform and complete a survey of the Area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c308-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out any other project or activity for the benefit of the Area in accordance with sections 539m to 539m–12 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c309-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2003-02-20"},"text":"February 20, 2003","children":[],"tail":", the Secretary shall complete the survey of the Area under paragraph (1)(A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c30a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land exchange","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c30b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2003-02-20"},"text":"February 20, 2003","children":[],"tail":", after consultation with the Pueblo, the Secretary shall, in accordance with applicable laws, prepare and offer a land exchange of National Forest land outside the Area and contiguous to the northern boundary of the Pueblo’s Reservation within sections 3, 10, 11, and 14 of T12N, R4E, N.M.P.M., Sandoval County, New Mexico excluding wilderness land, for land owned by the Pueblo in the Evergreen Hills subdivision in Sandoval County contiguous to National Forest land, and the La Luz tract in Bernalillo County."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c30c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1716/b"},"text":"section 1716(b) of title 43","children":[],"tail":", the Secretary may either make or accept a cash equalization payment in excess of 25 percent of the total value of the land or interests transferred out of Federal ownership."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c30d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds received","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds received by the Secretary as a result of the exchange shall be deposited in the fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s484a"},"text":"section 484a of this title","children":[],"tail":", and shall be available to purchase non-Federal land within or adjacent to the National Forests in the State of New Mexico."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c30e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of land exchanged or conveyed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All land exchanged or conveyed to the Pueblo is declared to be held in trust for the Pueblo by the United States and added to the Pueblo’s Reservation subject to all existing and outstanding rights and shall, as a condition of the title to be conveyed, remain in its natural state and shall not be subject to commercial development of any kind. Land exchanged or conveyed to the Forest Service shall be subject to all limitations on use pertaining to the Area under sections 539m to 539m–12 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c30f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to make offer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the land exchange offer is not made by the date that is 180 days after ","children":[{"tag":"date","attrib":{"date":"2003-02-20"},"text":"February 20, 2003","children":[],"tail":", the Secretary shall submit to the Committee on Energy and Natural Resources of the United States Senate and the Committee on Resources of the United States House of Representatives, a report explaining the reasons for the failure to make the offer including an assessment of the need for any additional legislation that may be necessary for the exchange. If additional legislation is not necessary, the Secretary, consistent with this section, should proceed with the exchange pursuant to existing law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c310-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to exchange","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c311-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the land exchange authorized under paragraph (1) is not completed by the date that is 30 days after ","children":[{"tag":"date","attrib":{"date":"2014-06-09"},"text":"June 9, 2014","children":[],"tail":", the Secretary, on request of the Pueblo and the Secretary of the Interior, shall transfer the National Forest land generally depicted as “Land to be Held in Trust” on the map entitled “Sandia Pueblo Settlement Technical Amendment Act” and dated "},{"tag":"date","attrib":{"date":"2013-10-18"},"text":"October 18, 2013","children":[],"tail":", to the Secretary of the Interior to be held in trust by the United States for the Pueblo—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7832c312-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the restriction enforced by the Secretary of the Interior that the land remain undeveloped, with the natural characteristics of the land to be preserved in perpetuity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7832c313-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c314-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other transfers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After the transfer under subparagraph (A) is complete, the Secretary of the Interior, with the consent of the Pueblo, shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7832c315-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/b/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" transfer to the Secretary, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–9/c"},"text":"section 539m–9(c) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id7832c316-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/b/6/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the La Luz tract generally depicted on the map entitled “Sandia Pueblo Settlement Technical Amendment Act” and dated ","children":[{"tag":"date","attrib":{"date":"2013-10-18"},"text":"October 18, 2013","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7832c317-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/b/6/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conservation easement for the Piedra Lisa tract generally depicted on the map entitled “Sandia Pueblo Settlement Technical Amendment Act” and dated ","children":[{"tag":"date","attrib":{"date":"2013-10-18"},"text":"October 18, 2013","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7832c318-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/b/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant to the Secretary a right-of-way for the Piedra Lisa Trail within the Piedra Lisa tract generally depicted on the map entitled “Sandia Pueblo Settlement Technical Amendment Act” and dated ","children":[{"tag":"date","attrib":{"date":"2013-10-18"},"text":"October 18, 2013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c319-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition and other compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c31a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire land owned by the Pueblo within the Evergreen Hills Subdivision in Sandoval County or any other privately held land inside of the exterior boundaries of the Area. The boundaries of the Cibola National Forest and the Area shall be adjusted to encompass any land acquired pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c31b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Piedra Lisa tract","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Secretary shall compensate the Pueblo for the fair market value of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c31c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right-of-way established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–7/h/3/C"},"text":"section 539m–7(h)(3)(C) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c31d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conservation easement established by the limitations on use of the Piedra Lisa tract pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–7/b/2"},"text":"section 539m–7(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c31e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of certain costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c31f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Pueblo, the County of Bernalillo, New Mexico, and any person that owns or has owned property inside of the exterior boundaries of the Area as designated on the map, and who has incurred actual and direct costs as a result of participating in the case of Pueblo of Sandia v. Babbitt, Civ. No. 94–2624 HHG (D.D.C.), or other proceedings directly related to resolving the issues litigated in that case, may apply for reimbursement in accordance with this section. Costs directly related to such participation which shall qualify for reimbursement shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c320-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dues or payments to a homeowner association for the purpose of legal representation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78353321-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legal fees and related expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78353322-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reimbursement provided in this subsection shall be in lieu of that which might otherwise be available pursuant to the Equal Access to Justice Act (24 ","children":[{"tag":"ref","attrib":{"idref":"fn002415"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002415"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “28”."}],"tail":" U.S.C. 2412)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78353323-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriated funds the Secretary of the Treasury shall make reimbursement payments as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78353324-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2003-02-20"},"text":"February 20, 2003","children":[],"tail":", applications for reimbursement shall be filed with the Department of the Treasury, Financial Management Service, Washington, D.C."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78353325-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–11/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No party shall be reimbursed in excess of $750,000 under this section, and the total amount reimbursed in accordance with this section shall not exceed $3,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78353326-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tIV/s413"},"text":"Pub. L. 108–7, div. F, title IV, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/292"},"text":"117 Stat. 292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIII/s3309"},"text":"Pub. L. 111–11, title III, § 3309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1139"},"text":"123 Stat. 1139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/119/s2"},"text":"Pub. L. 113–119, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-09"},"text":"June 9, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1185"},"text":"128 Stat. 1185","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78353327-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78353328-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78353329-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 539m to 539m–12 of this title, referred to in subsecs. (a)(1)(B) and (b)(4), was in the original “this title”, meaning title IV of div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/279"},"text":"117 Stat. 279","children":[],"tail":", which is classified generally to sections 539m to 539m–12 of this title. For complete classification of title IV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m"},"text":"section 539m of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1716/b"},"text":"Section 1716(b) of title 43","children":[],"tail":", referred to in subsec. (b)(2), was in the original “section 206(b) of the Federal Land Policy and Management Act” and was translated as reading “section 206(b) of the Federal Land Policy and Management Act of 1976” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Equal Access to Justice Act, referred to in subsec. (d)(2), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/481"},"text":"Pub. L. 96–481","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2325"},"text":"94 Stat. 2325","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s504"},"text":"section 504 of Title 5","children":[],"tail":", Government Organization and Employees, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7835332a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/119/s2/1"},"text":"Pub. L. 113–119, § 2(1)","children":[],"tail":", substituted “title to be conveyed” for “conveyance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/119/s2/2"},"text":"Pub. L. 113–119, § 2(2)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href"