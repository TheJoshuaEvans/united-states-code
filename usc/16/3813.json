{"tag":"section","attrib":{"id":"id79c82f03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3813"},"text":null,"children":[{"tag":"num","attrib":{"value":"3813"},"text":"§ 3813.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Soil surveys","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall, as soon as is practicable after ","children":[{"tag":"date","attrib":{"date":"1985-12-23"},"text":"December 23, 1985","children":[],"tail":", complete soil surveys on those private lands that do not have a soil survey suitable for use in determining the land capability class for purposes of this subchapter. In carrying out this section, the Secretary shall, insofar as possible, concentrate on those localities where significant amounts of highly erodible land are being converted to the production of agricultural commodities."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79c82f04-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1214"},"text":"Pub. L. 99–198, title XII, § 1214","children":[],"tail":", formerly § 1213, "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1507"},"text":"99 Stat. 1507","children":[],"tail":"; renumbered § 1214, "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIII/s315/a/1"},"text":"Pub. L. 104–127, title III, § 315(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/983"},"text":"110 Stat. 983","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
