{"tag":"section","attrib":{"id":"id78b11ad8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824r"},"text":null,"children":[{"tag":"num","attrib":{"value":"824r"},"text":"§ 824r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of transmission contracts in the Pacific Northwest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78b11ad9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of electric utility or person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “electric utility or person” means an electric utility or person that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b11ada-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824r/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", holds firm transmission rights pursuant to contract or by reason of ownership of transmission facilities; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b11adb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824r/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is located—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78b11adc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824r/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the Pacific Northwest, as that region is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s839a"},"text":"section 839a of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b11add-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824r/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in that portion of a State included in the geographic area proposed for a regional transmission organization in Commission Docket Number RT01–35 on the date on which that docket was opened.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b11ade-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of transmission contracts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter confers on the Commission the authority to require an electric utility or person to convert to tradable or financial rights—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b11adf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824r/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" firm transmission rights described in subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b11ae0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824r/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" firm transmission rights obtained by exercising contract or tariff rights associated with the firm transmission rights described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78b11ae1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"June 10, 1920, ch. 285","children":[],"tail":", pt. II, § 218, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXII/s1235"},"text":"Pub. L. 109–58, title XII, § 1235","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/960"},"text":"119 Stat. 960","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
