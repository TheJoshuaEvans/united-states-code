{"tag":"section","attrib":{"id":"id7a206214-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7001"},"text":null,"children":[{"tag":"num","attrib":{"value":"7001"},"text":"§ 7001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a206215-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory panel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advisory panel” means the Advisory Panel on Pacific Hake/Whiting established by the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a206216-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Agreement” means the Agreement between the Government of the United States and the Government of Canada on Pacific Hake/Whiting, signed at Seattle, Washington, on ","children":[{"tag":"date","attrib":{"date":"2003-11-21"},"text":"November 21, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a206217-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Catch","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “catch” means all fishery removals from the offshore whiting resource, including landings, discards, and bycatch in other fisheries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a206218-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7001/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint management committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “joint management committee” means the joint management committee established by the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a206219-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7001/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint technical committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “joint technical committee” means the joint technical committee established by the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a20621a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7001/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offshore whiting resource","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “offshore whiting resource” means the transboundary stock of Merluccius productus that is located in the offshore waters of the United States and Canada except in Puget Sound and the Strait of Georgia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a20621b-6992-11f1-ab3f-8b4c043f8cd5","i