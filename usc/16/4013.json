{"tag":"section","attrib":{"id":"id79e999c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4013"},"text":null,"children":[{"tag":"num","attrib":{"value":"4013"},"text":"§ 4013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e999c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4013/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of petition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person subject to assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4012"},"text":"section 4012 of this title","children":[],"tail":" may file a written petition with the Secretary alleging that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e999c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4013/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assessment,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e999c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4013/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4011/a/1"},"text":"section 4011(a)(1) of this title","children":[],"tail":" on which the assessment is based, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e999c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4013/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any obligation imposed under the plan,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is not in accordance with law and requesting the Secretary to modify or take other appropriate action regarding the assessment or plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e999c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4013/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of petition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any such petition shall be in writing and filed within the period prescribed by the Secretary. A person who files a petition under this section shall be given an opportunity for a hearing regarding the petition in accordance with regulations issued by the Secretary. After such a hearing, or if no hearing is requested, after consideration of all documentation and other evidence, the Secretary shall make a ruling upon such petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e999c9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659/tII/s214"},"text":"Pub. L. 99–659, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3728"},"text":"100 Stat. 3728","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
