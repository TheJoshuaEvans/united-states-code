{"tag":"section","attrib":{"id":"id79fef64a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5305b"},"text":null,"children":[{"tag":"num","attrib":{"value":"5305b"},"text":"§ 5305b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational outreach program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79fef64b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5305b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1998-10-30"},"text":"October 30, 1998","children":[],"tail":", the Secretary shall develop and implement an educational outreach program in the United States for the conservation of rhinoceros and tiger species."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fef64c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5305b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish in the Federal Register guidelines for the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fef64d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5305b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the program, the Secretary shall publish and disseminate information regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fef64e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5305b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" laws protecting rhinoceros and tiger species, in particular laws prohibiting trade in products containing, or labeled or advertised as containing, their parts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef64f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5305b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of traditional medicines that contain parts or products of rhinoceros and tiger species, health risks associated with their use, and available alternatives to the medicines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef650-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5305b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of rhinoceros and tiger species and the reasons for protecting the species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fef651-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/391/s8"},"text":"Pub. L. 103–391, § 8","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/312/tIV/s406"},"text":"Pub. L. 105–312, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2961"},"text":"112 Stat. 2961","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
