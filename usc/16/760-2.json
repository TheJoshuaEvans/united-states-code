{"tag":"section","attrib":{"id":"id78922008-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"760–2"},"text":"§ 760–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of fish hatchery in Montana","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to establish, construct, equip, operate, and maintain a new fish hatchery in the vicinity of Miles City, Montana.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78922009-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-06-04/ch366/s1"},"text":"June 4, 1956, ch. 366, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/247"},"text":"70 Stat. 247","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7892200a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7892200b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7892200c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Miles City National Fish Hatchery","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/432/s7"},"text":"Pub. L. 99–432, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/990"},"text":"100 Stat. 990","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/432/s7"},"text":"“Notwithstanding any other law, the Secretary of the Interior shall convey to the State of Montana, without reimbursement to the United States and no later than thirty days following enactment of this legislation [","children":[{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":"], all of the rights (including all water rights), title, and interest of the United States in and to the fish hatchery property located south of Miles City, Montana, and known as the Miles City National Fish Hatchery, consisting of 168.22 acres, more or less, of land, together with any improvements and related personal property thereon. The property conveyed shall be used by the Montana Department of Fish, Wildlife and Parks as part of the Montana fishery resources management program. If the property conveyed is ever used for other than these purposes, title to such property shall revert to the United States.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/h/tI/s112"},"text":"Pub. L. 99–500, § 101(h) [title I, § 112]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-242"},"text":"100 Stat. 1783–242","children":[],"tail":", 1783–262, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/h/tI/s112"},"text":"Pub. L. 99–591, § 101(h) [title I, § 112]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-242"},"text":"100 Stat. 3341–242","children":[],"tail":", 3341–262."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7892200d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2 of act ","children":[{"tag":"date","attrib":{"date":"1956-06-04"},"text":"June 4, 1956","children":[],"tail":", authorized an appropriation of $465,000 to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
