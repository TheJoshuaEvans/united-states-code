{"tag":"section","attrib":{"id":"id78246a49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497d"},"text":null,"children":[{"tag":"num","attrib":{"value":"497d"},"text":"§ 497d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreation residence fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall on and after ","children":[{"tag":"date","attrib":{"date":"1997-11-14"},"text":"November 14, 1997","children":[],"tail":", phase in, over a 3-year period in equal annual installments, that portion of the fee increase for a recreation residence special use permit holder which is more than 100 percent of the previous year’s fee: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no recreation residence fee may be increased any sooner than one year from the time the permittee has been notified by the Forest Service of the results of an appraisal which has been conducted for the purpose of establishing such fees: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That no increases in recreation residence fees on the Sawtooth National Forest will be implemented prior to "},{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78246a4a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/83/tIII/s343"},"text":"Pub. L. 105–83, title III, § 343","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-14"},"text":"Nov. 14, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1604"},"text":"111 Stat. 1604","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78246a4b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78246a4c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78246a4d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation on Increases in Recreation Residence Fees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/3/tIII/s342"},"text":"Pub. L. 106–113, div. B, § 1000(a)(3) [title III, § 342]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–202, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/113/dB/s1000/a/3/tIII/s342"},"text":"“Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/83/s343"},"text":"section 343 of Public Law 105–83","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s497d"},"text":"16 U.S.C. 497d","children":[],"tail":"], increases in recreation residence fees shall be implemented in fiscal year 2000 only to the extent that the fiscal year 2000 fees do not exceed the fiscal year 1999 fee by more than $2,000.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78246a4e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation on Recreation Residence Fee Increases on Sawtooth National Forest","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tIII/s345"},"text":"Pub. L. 105–277, div. A, § 101(e) [title III, § 345]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–298, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dA/s101/e/tIII/s345"},"text":"“Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/83/s343"},"text":"section 343 of Public Law 105–83","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s497d"},"text":"16 U.S.C. 497d","children":[],"tail":"], increases in recreation residence fees on the Sawtooth National Forest shall be implemented in fiscal year 1999 only to the extent that such fee increases do not exceed 25 percent.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
