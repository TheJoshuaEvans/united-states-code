{"tag":"section","attrib":{"id":"id777405e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"410hhh–8"},"text":"§ 410hhh–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id777405e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an advisory council to be known as the “Great Sand Dunes National Park Advisory Council”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777405e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Council shall advise the Secretary with respect to the preparation and implementation of a management plan for the national park and the preserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777405e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Council shall consist of 10 members, to be appointed by the Secretary, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777405e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–8/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member of, or nominated by, the Alamosa County Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777405e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–8/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member of, or nominated by, the Saguache County Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777405e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–8/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member of, or nominated by, the Friends of the Dunes Organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777405e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–8/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Four members residing in, or within reasonable proximity to, the San Luis Valley and 3 of the general public, all of whom have recognized backgrounds reflecting—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777405e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–8/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes for which the national park and the preserve are established; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777405ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–8/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interests of persons that will be affected by the planning and management of the national park and the preserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777405eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–8/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Council shall function in accordance with chapter 10 of title 5 and other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777405ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–8/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy on the Advisory Council shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777405ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–8/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Council shall elect a chairperson and shall establish such rules and procedures as it deems necessary or desirable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777405ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–8/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Advisory Council shall serve without compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777405ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–8/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Council shall terminate upon the completion of the management plan for the national park and preserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777405f0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/530/s10"},"text":"Pub. L. 106–530, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2535"},"text":"114 Stat. 2535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/87"},"text":"Pub. L. 117–286, § 4(a)(87)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4315"},"text":"136 Stat. 4315","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777405f1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777405f2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id777405f3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “the Federal Advisory Committee Act (5 U.S.C. App.)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
