{"tag":"section","attrib":{"id":"id7a193601-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6707"},"text":null,"children":[{"tag":"num","attrib":{"value":"6707"},"text":"§ 6707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a193602-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this chapter $15,000,000 for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a193603-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds made available under subsection (a) shall be used to pay the costs of constructing any facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a193604-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/317/s8"},"text":"Pub. L. 108–317, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-05"},"text":"Oct. 5, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1210"},"text":"118 Stat. 1210","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
