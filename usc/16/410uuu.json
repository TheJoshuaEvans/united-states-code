{"tag":"section","attrib":{"id":"id777b3224-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu"},"text":null,"children":[{"tag":"num","attrib":{"value":"410uuu"},"text":"§ 410uuu.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manhattan Project National Historical Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id777b3225-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b3226-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve and protect for the benefit of present and future generations the nationally significant historic resources associated with the Manhattan Project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b3227-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve public understanding of the Manhattan Project and the legacy of the Manhattan Project through interpretation of the historic resources associated with the Manhattan Project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b3228-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance public access to the Historical Park consistent with protection of public safety, national security, and other aspects of the mission of the Department of Energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b3229-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the Department of Energy, Historical Park communities, historical societies, and other interested organizations and individuals in efforts to preserve and protect the historically significant resources associated with the Manhattan Project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777b322a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b322b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historical Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Historical Park” means the Manhattan Project National Historical Park established under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b322c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manhattan Project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Manhattan Project” means the Federal military program to develop an atomic bomb ending on ","children":[{"tag":"date","attrib":{"date":"1946-12-31"},"text":"December 31, 1946","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b322d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777b322e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Manhattan Project National Historical Park","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b322f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b3230-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"December 19, 2014","children":[],"tail":", there shall be established as a unit of the National Park System the Manhattan Project National Historical Park."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b3231-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Historical Park shall consist of facilities and areas listed under paragraph (2) as determined by the Secretary, in consultation with the Secretary of Energy. The Secretary shall include the area referred to in paragraph (2)(C)(i), the B Reactor National Historic Landmark, in the Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b3232-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Historical Park may only be comprised of one or more of the following areas, or portions of the areas, as generally depicted in the map titled “Manhattan Project National Historical Park Sites”, numbered 540/108,834–C, and dated September 2012:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b3233-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oak Ridge, Tennessee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Facilities, land, or interests in land that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777b3234-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Buildings 9204–3 and 9731 at the Department of Energy Y–12 National Security Complex;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b3235-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the X–10 Graphite Reactor at the Department of Energy Oak Ridge National Laboratory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b3236-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the K–25 Building site at the Department of Energy East Tennessee Technology Park;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b3237-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former Guest House located at 210 East Madison Road; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b3238-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at other sites in Oak Ridge, Tennessee, that are not depicted on the map but are determined by the Secretary to be suitable and appropriate for inclusion in the Historical Park, except that sites administered by the Secretary of Energy may be included only with the concurrence of the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b3239-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Los Alamos, New Mexico","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Facilities, land, or interests in land that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777b323a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the Los Alamos Scientific Laboratory National Historic Landmark District, or any addition to the Landmark District proposed in the National Historic Landmark Nomination—Los Alamos Scientific Laboratory (LASL) NHL District (Working Draft of NHL Revision), Los Alamos National Laboratory document LA–UR 12–00387 (","children":[{"tag":"date","attrib":{"date":"2012-01-26"},"text":"January 26, 2012","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b323b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former East Cafeteria located at 1670 Nectar Street; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b323c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former dormitory located at 1725 17th Street.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b323d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hanford, Washington","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Facilities, land, or interests in land on the Department of Energy Hanford Nuclear Reservation that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777b323e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the B Reactor National Historic Landmark;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b323f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Hanford High School in the town of Hanford and Hanford Construction Camp Historic District;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b3240-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the White Bluffs Bank building in the White Bluffs Historic District;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b3241-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the warehouse at the Bruggemann’s Agricultural Complex;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b3242-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Hanford Irrigation District Pump House; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b3243-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/c/2/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the T Plant (221–T Process Building).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777b3244-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b3245-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"December 19, 2014","children":[],"tail":", the Secretary and the Secretary of Energy (acting through the Oak Ridge, Los Alamos, and Richland site offices) shall enter into an agreement governing the respective roles of the Secretary and the Secretary of Energy in administering the facilities, land, or interests in land under the administrative jurisdiction of the Department of Energy that is "},{"tag":"ref","attrib":{"idref":"fn002188"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002188"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “are”."}],"tail":" to be included in the Historical Park under subsection (c)(2), including provisions for enhanced public access, management, interpretation, and historic preservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b3246-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any agreement under paragraph (1) shall provide that the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b3247-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have decisionmaking authority for the content of historic interpretation of the Manhattan Project for purposes of administering the Historical Park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b3248-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the agreement provides an appropriate advisory role for the National Park Service in preserving the historic resources covered by the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b3249-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the Secretary of Energy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any agreement under paragraph (1) shall provide that the Secretary of Energy—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b324a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall ensure that the agreement appropriately protects public safety, national security, and other aspects of the ongoing mission of the Department of Energy at the Oak Ridge Reservation, Los Alamos National Laboratory, and Hanford Site;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b324b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may consult with and provide historical information to the Secretary concerning the Manhattan Project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b324c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall retain responsibility, in accordance with applicable law, for any environmental remediation or activities relating to structural safety that may be necessary in or around the facilities, land, or interests in land governed by the agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b324d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall retain authority and legal obligations for historic preservation and general maintenance, including to ensure safe access, in connection with the Department’s Manhattan Project resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b324e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The agreement under paragraph (1) may be amended, including to add to the Historical Park facilities, land, or interests in land within the eligible areas described in subsection (c)(2) that are under the jurisdiction of the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777b324f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public participation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b3250-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall consult with interested State, county, and local officials, organizations, and interested members of the public—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b3251-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before executing any agreement under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b3252-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the development of the general management plan under subsection (f)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b3253-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date on which an agreement under subsection (d) is entered into, the Secretary shall publish in the Federal Register notice of the establishment of the Historical Park, including an official boundary map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b3254-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The official boundary map published under paragraph (2) shall be on file and available for public inspection in the appropriate offices of the National Park Service. The map shall be updated to reflect any additions to the Historical Park from eligible areas described in subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b3255-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any land, interest in land, or facility within the eligible areas described in subsection (c)(2) that is acquired by the Secretary or included in an amendment to the agreement under subsection (d)(4) shall be added to the Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777b3256-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b3257-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall administer the Historical Park in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b3258-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b3259-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the laws generally applicable to units of the National Park System, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777b325a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Park System Organic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":" et seq.); "},{"tag":"ref","attrib":{"idref":"fn002189"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002189"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b325b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s461"},"text":"16 U.S.C. 461","children":[],"tail":" et seq.)."},{"tag":"sup","attrib":{},"text":"2","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b325c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after the date on which funds are made available to carry out this subsection, the Secretary, with the concurrence of the Secretary of Energy, with respect to land administered by the Secretary of Energy, and in consultation and collaboration with the Oak Ridge, Los Alamos and Richland Department of Energy site offices, shall complete a general management plan for the Historical Park in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b325d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpretive tours","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, subject to applicable law, provide interpretive tours of historically significant Manhattan Project sites and resources in the States of Tennessee, New Mexico, and Washington that are located outside the boundary of the Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b325e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b325f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may acquire land and interests in land within the eligible areas described in subsection (c)(2) by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777b3260-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer of administrative jurisdiction from the Department of Energy by agreement between the Secretary and the Secretary of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b3261-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b3262-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exchange; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b3263-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of land and interests in land within the eligible areas described in subparagraphs (A) and (B) of subsection (c)(2), purchase from a willing seller.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b3264-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No use of condemnation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not acquire by condemnation any land or interest in land under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b3265-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire land or interests in land in the vicinity of the Historical Park for visitor and administrative facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b3266-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations; cooperative agreements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b3267-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal facilities","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777b3268-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into one or more agreements with the head of a Federal agency to provide public access to, and management, interpretation, and historic preservation of, historically significant Manhattan Project resources under the jurisdiction or control of the Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b3269-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations; cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may accept donations from, and enter into cooperative agreements with, State governments, units of local government, tribal governments, organizations, or individuals to further the purpose of an interagency agreement entered into under clause (i) or to provide visitor services and administrative facilities within reasonable proximity to the Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b326a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical assistance to State, local, or tribal governments, organizations, or individuals for the management, interpretation, and historic preservation of historically significant Manhattan Project resources not included within the Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b326b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/f/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations to Department of Energy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, or for the purpose of preserving and providing access to historically significant Manhattan Project resources, the Secretary of Energy may accept, hold, administer, and use gifts, bequests, and devises (including labor and services).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777b326c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjacent management","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b326d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section creates a protective perimeter or buffer zone around the boundary of the Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b326e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities outside the boundary of the Historical Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fact that an activity or use on land outside the boundary of the Historical Park can be seen or heard from within the boundary shall not preclude the activity or use outside the boundary of the Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777b326f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uuu/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No cause of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to create a cause of action with respect to activities outside or adjacent to the established boundary of the Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777b3270-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXX/s3039"},"text":"Pub. L. 113–291, div. B, title XXX, § 3039","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3784"},"text":"128 Stat. 3784","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777b3271-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777b3272-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id777b3273-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Park System Organic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":" et seq.), referred to in subsec. (f)(1)(B)(i), probably means the National Park Service Organic Act, "},{"tag":"ref","attrib":{"href":"/us/act/1916-08-25/ch408"},"text":"act Aug. 25, 1916, ch. 408","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":", which enacted sections 1, 2, 3, and 4 of this title and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":", National Park Service and Related Programs. Sections 1 to 4 of the Act were repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1865/a"},"text":"section 1865(a) of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and section 100101(a), chapter 1003, and sections 100751(a), 100752, 100753, and 102101 of Title 54 by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 4(a)(1), 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3260, 3272. For complete classification of this Act to the Code, see Tables. For disposition of former sections of this title, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s461"},"text":"16 U.S.C. 461","children":[],"tail":" et seq.), referred to in subsec. (f)(1)(B)(ii), is "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-21/ch593"},"text":"act Aug. 21, 1935, ch. 593","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/666"},"text":"49 Stat. 666","children":[],"tail":", known as the Historic Sites Act of 1935 and also as the Historic Sites, Buildings, and Antiquities Act, which enacted sections 461 to 467 of this title. The Act was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1866/a"},"text":"section 1866(a) of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and sections 102303 and 102304 and chapter 3201 of Title 54, National Park Service and Related Programs, by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 4(a)(1), 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3260, 3272. For complete classification of this Act to the Code, see Tables. For disposition of former sections of this title, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id777d7b64-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (f)(2), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":"” substituted for “"},{"tag":"ref","attrib":{"href":"/us/pl/91/383/s12/b"},"text":"section 12(b) of Public Law 91–383","children":[],"tail":" (commonly known as the National Park Service General Authorities Act; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1a–7/b"},"text":"16 U.S.C. 1a–7(b)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/e"},"text":"Pub. L. 113–287, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3272"},"text":"128 Stat. 3272","children":[],"tail":", which Act enacted Title 54, National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
