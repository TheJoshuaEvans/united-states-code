{"tag":"section","attrib":{"id":"id79f7cbd7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4912"},"text":null,"children":[{"tag":"num","attrib":{"value":"4912"},"text":"§ 4912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties and regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f7cbd8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cbd9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4912/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cbda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4912/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who knowingly violates, and any person engaged in business as an importer of exotic birds who violates, section 4910(a)(1) or (2) ","children":[{"tag":"ref","attrib":{"idref":"fn002802"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002802"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “4910(a)(1)(A) or (B)”."}],"tail":" of this title or any permit issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4911"},"text":"section 4911 of this title","children":[],"tail":" may be assessed a civil penalty by the Secretary of not more than $25,000 for each violation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cbdb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4912/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who knowingly violates, and any person engaged in business as an importer of exotic birds who violates, section 4910(a)(3) ","children":[{"tag":"ref","attrib":{"idref":"fn002803"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002803"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be section “4910(a)(1)(C)”."}],"tail":" of this title may be assessed a civil penalty by the Secretary of not more than $12,000 for each such violation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cbdc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4912/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who otherwise violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4910/a"},"text":"section 4910(a) of this title","children":[],"tail":" or any permit issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4911"},"text":"section 4911 of this title","children":[],"tail":" may be assessed a civil penalty by the Secretary of not more than $500 for each such violation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cbdd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4912/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civil penalty under this section shall be assessed, and may be collected, in the manner in which a civil penalty under the Act of ","children":[{"tag":"date","attrib":{"date":"1973-12-28"},"text":"December 28, 1973","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Public Law 93–205","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.], may be assessed and collected under section 111(a) "},{"tag":"ref","attrib":{"idref":"fn002804"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002804"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be section “11(a)”."}],"tail":" of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1540/a"},"text":"16 U.S.C. 1540(a)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cbde-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4912/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cbdf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4912/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who knowingly violates, and any person engaged in business as an importer of exotic birds who violates, section 4910(a)(1) or (2) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title or any permit issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4911"},"text":"section 4911 of this title","children":[],"tail":" shall be fined under title 18 or imprisoned for not more than 2 years, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cbe0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4912/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who knowingly violates section 4910(a)(3) ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" of this title shall be fined under title 18, imprisoned not more than 6 months, or both."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f7cbe1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" District court jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The several district courts of the United States, including the courts enumerated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s460"},"text":"section 460 of title 28","children":[],"tail":", shall have jurisdiction over any action arising under this chapter. For the purposes of this chapter, American Samoa shall be included in the Judicial District of the District Court of the United States for the District of Hawaii, and the Trust Territory of Palau and the Northern Marianas shall be included in the Judicial District of the District Court of the United States for the District of Guam."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f7cbe2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4912/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The importation of an exotic bird is deemed to be transportation of wildlife for purposes of section 3(a) of the Lacey Act Amendments of 1981 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3372/a"},"text":"16 U.S.C. 3372(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f7cbe3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4912/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe regulations that are necessary and appropriate to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f7cbe4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4912/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Secretary under this chapter is in addition to and shall not affect the authority of the Secretary under the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.) or diminish the authority of the Secretary under the Lacey Act Amendments of 1981 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3371"},"text":"16 U.S.C. 3371","children":[],"tail":" et seq.). Nothing in this chapter shall be construed as repealing, superseding, or modifying any provision of Federal law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f7cbe5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tI/s113"},"text":"Pub. L. 102–440, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2231"},"text":"106 Stat. 2231","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f7cbe6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f7cbe7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79f7cbe8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1973-12-28"},"text":"December 28, 1973","children":[],"tail":", referred to in subsec. (a)(1)(D), and the Endangered Species Act of 1973, referred to in subsec. (e), are "},{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/884"},"text":"87 Stat. 884","children":[],"tail":", which is classified generally to chapter 35 (§ 1531 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"section 1531 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Lacey Act Amendments of 1981, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/79"},"text":"Pub. L. 97–79","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-16"},"text":"Nov. 16, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1073"},"text":"95 Stat. 1073","children":[],"tail":", which is classified principally to chapter 53 (§ 3371 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3371"},"text":"section 3371 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id79f7cbe9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79f7cbea-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of Palau and Northern Marianas, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
