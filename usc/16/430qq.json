{"tag":"section","attrib":{"id":"id7797ba87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430qq"},"text":null,"children":[{"tag":"num","attrib":{"value":"430qq"},"text":"§ 430qq.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior, in order to implement the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s430pp"},"text":"section 430pp of this title","children":[],"tail":", is authorized to exchange lands which may be acquired pursuant to sections 430pp to 430tt of this title for other lands or interests therein of approximately equal value lying within the original George Washington land patent at Fort Necessity."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7797ba88-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/134/s2"},"text":"Pub. L. 87–134, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-10"},"text":"Aug. 10, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/336"},"text":"75 Stat. 336","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
