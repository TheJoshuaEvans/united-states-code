{"tag":"section","attrib":{"id":"id7845d5b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s560"},"text":null,"children":[{"tag":"num","attrib":{"value":"560"},"text":"§ 560.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of timber for telephone lines for fire protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture, whenever he may deem it necessary for the protection of the national forests from fire, may permit the use of timber free of charge for the construction of telephone lines.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7845d5b5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch145/s1"},"text":"Mar. 4, 1913, ch. 145, § 1","children":[],"tail":" (part), "},{"tag":"ref","attrib":{"href":"/us/stat/37/843"},"text":"37 Stat. 843","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
