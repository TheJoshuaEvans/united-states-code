{"tag":"section","attrib":{"id":"id798ef6b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2101a"},"text":"§ 2101a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State-wide assessment and strategies for forest resources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id798ef6ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment and strategies for forest resources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a State to be eligible to receive funds under the authorities of this chapter, the State forester of that State or equivalent State official shall develop and submit to the Secretary, not later than two years after the date of enactment of the Food, Conservation, and Energy Act of 2008, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798ef6bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A State-wide assessment of forest resource conditions, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id798ef6bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conditions and trends of forest resources in that State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798ef6bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the threats to forest lands and resources in that State consistent with the national priorities specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2101/c"},"text":"section 2101(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798ef6be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any areas or regions of that State that are a priority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798ef6bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any multi-State areas that are a regional priority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A long-term State-wide forest resource strategy, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id798ef6c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategies for addressing threats to forest resources in the State outlined in the assessment required by paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798ef6c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the resources necessary for the State forester or equivalent State official from all sources to address the State-wide strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798ef6c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updating","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At such times as the Secretary determines to be necessary, the State forester or equivalent State official shall update and resubmit to the Secretary the State-wide assessment and State-wide strategy required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798ef6c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing or updating the State-wide assessment and State-wide strategy required by subsection (a), the State Forester or equivalent State official shall coordinate with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798ef6c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State Forest Stewardship Coordinating Committee established for the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2113/b"},"text":"section 2113(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State wildlife agency, with respect to strategies contained in the State wildlife action plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State Technical Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable Federal land management agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as feasible, appropriate military installations where the voluntary participation and management of private or State-owned or other public forestland is able to support, promote, and contribute to the missions of such installations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of the Forest Legacy Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2103c"},"text":"section 2103c of this title","children":[],"tail":", the State lead agency designated by the Governor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798ef6cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation of other plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing or updating the State-wide assessment and State-wide strategy required by subsection (a), the State forester or equivalent State official shall incorporate any forest management plan of the State, including community wildfire protection plans and State wildlife action plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798ef6cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sufficiency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Once approved by the Secretary, a State-wide assessment and State-wide strategy developed under subsection (a) shall be deemed to be sufficient to satisfy all relevant State planning and assessment requirements under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798ef6cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798ef6ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section up to $10,000,000 for each of fiscal years 2008 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funding sources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the funds appropriated for a fiscal year pursuant to the authorization of appropriations in paragraph (1) to carry out this section, the Secretary may use any other funds made available for planning under this chapter to carry out this section, except that the total amount of combined funding used to carry out this section may not exceed $10,000,000 in any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798ef6d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2101a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State forester or equivalent State official shall submit to the Secretary an annual report detailing how funds made available to the State under this chapter are being used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id798ef6d1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/313/s2A"},"text":"Pub. L. 95–313, § 2A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVIII/s8002"},"text":"Pub. L. 110–234, title VIII, § 8002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1280"},"text":"122 Stat. 1280","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VIII, § 8002, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2041; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVIII/s8101"},"text":"Pub. L. 113–79, title VIII, § 8101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/914"},"text":"128 Stat. 914","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8101"},"text":"Pub. L. 115–334, title VIII, § 8101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4837"},"text":"132 Stat. 4837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id798ef6d2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id798ef6d3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id798ef6d4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a), (e), (f)(2), and (g), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/313"},"text":"Pub. L. 95–313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-07-01"},"text":"July 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/365"},"text":"92 Stat. 365","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2101"},"text":"section 2101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of the Food, Conservation, and Energy Act of 2008, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id798ef6d5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id798ef6d6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s8101/1"},"text":"Pub. L. 113–79, § 8101(1)","children":[],"tail":", added par. (5) and redesignated former par. (5) as (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s8101/2"},"text":"Pub. L. 113–79, § 8101(2)","children":[],"tail":", substituted “2018” for “2012”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id798ef6d7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id798ef6d8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
