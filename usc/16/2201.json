{"tag":"section","attrib":{"id":"id79962399-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2201"},"text":null,"children":[{"tag":"num","attrib":{"value":"2201"},"text":"§ 2201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency conservation program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7996239a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture (referred to in this chapter as the “Secretary”) is authorized to make payments to agricultural producers who carry out emergency measures to control wind erosion on farmlands or to rehabilitate farmlands damaged by wind erosion, floods, hurricanes, wildfires, or other natural disasters when, as a result of the foregoing, new conservation problems have been created that (1) if not treated, will impair or endanger the land, (2) materially affect the productive capacity of the land, (3) represent damage that is unusual in character and, except for wind erosion, is not the type that would recur frequently in the same area, and (4) will be so costly to rehabilitate that Federal assistance is or will be required to return the land to productive agricultural use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7996239b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repair or replacement of fencing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7996239c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2201/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a payment to an agricultural producer under subsection (a) for the repair or replacement of fencing, the Secretary shall give the agricultural producer the option of receiving not more than 25 percent of the payment, determined by the Secretary based on the applicable percentage of the fair market value of the cost of the repair or replacement, before the agricultural producer carries out the repair or replacement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7996239d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2201/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the funds provided under paragraph (1) are not expended by the end of the 60-day period beginning on the date on which the agricultural producer receives those funds, the funds shall be returned within a reasonable timeframe, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7996239e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/334/tIV/s401"},"text":"Pub. L. 95–334, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-04"},"text":"Aug. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/433"},"text":"92 Stat. 433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2403/a/1"},"text":"Pub. L. 115–334, title II, § 2403(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4571"},"text":"132 Stat. 4571","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7996239f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799623a0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id799623a1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" inserted section catchline, designated existing provisions as subsec. (a), inserted heading, substituted “The Secretary of Agriculture (referred to in this chapter as the ‘Secretary’)” for “The Secretary of Agriculture”, inserted “wildfires,” after “hurricanes,”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id799623a2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id799623a3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/334/tIV/s406"},"text":"Pub. L. 95–334, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-04"},"text":"Aug. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/434"},"text":"92 Stat. 434","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/334/tIV/s406"},"text":"“The provisions of this title [enacting this chapter] shall become effective ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
