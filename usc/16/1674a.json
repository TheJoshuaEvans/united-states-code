{"tag":"section","attrib":{"id":"id795a79c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1674a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1674a"},"text":"§ 1674a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanded programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id795a79c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1674a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the National Institute of Food and Agriculture and the State cooperative extension services, and in consultation with State foresters or equivalent State officials, school boards, and universities, shall expand forestry and natural resources education programs conducted under this subchapter for private forest owners and managers, public officials, youth, and the general public, and shall include guidelines for the transfer of technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795a79c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1674a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795a79c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1674a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In expanding the programs conducted under this subchapter, the Secretary shall ensure that activities are undertaken to promote policies and practices that enhance the health, vitality, productivity, economic value, and environmental attributes of the forest lands of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795a79ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1674a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The activities referred to in paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id795a79cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1674a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrating and teaching landowners and forest managers the concepts of multiple-use and sustainable natural resource management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795a79cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1674a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting comprehensive environmental education programs that assist citizens to participate in environmentally positive activities such as tree planting, recycling, erosion prevention, and waste management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795a79cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1674a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational programs and materials that will improve the capacity of schools, local governments and resource agencies to deliver forestry and natural resources information to young people, environmentally concerned citizens, and action groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id795a79ce-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/306/s5A"},"text":"Pub. L. 95–306, § 5A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXII/s1251/a"},"text":"Pub. L. 101–624, title XII, § 1251(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3552"},"text":"104 Stat. 3552","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7511/c/34"},"text":"Pub. L. 110–234, title VII, § 7511(c)(34)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1270"},"text":"122 Stat. 1270","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7511(c)(34), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2032.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795a79cf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id795a79d0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id795a79d1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id795a79d2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c/34"},"text":"Pub. L. 110–246, § 7511(c)(34)","children":[],"tail":", which directed amendment of section 5(a) of the Renewable Resources Extension Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1674a/a"},"text":"16 U.S.C. 1674a(a)","children":[],"tail":") by substituting “National Institute of Food and Agriculture” for “Extension Service”, was executed by making the substitution in subsec. (a) of this section, which is section 5A of the Act, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id795a79d3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id795a79d4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendm