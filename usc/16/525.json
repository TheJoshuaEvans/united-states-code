{"tag":"section","attrib":{"id":"id78294c59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s525"},"text":null,"children":[{"tag":"num","attrib":{"value":"525"},"text":"§ 525.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights-of-way for wagon roads or railroads","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the form provided by existing law the Secretary of the Interior may file and approve surveys and plats of any right of way for a wagon road, railroad, or other highway over and across any national forest when in his judgment the public interests will not be injuriously affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78294c5a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1899-03-03/ch427/s1"},"text":"Mar. 3, 1899, ch. 427, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/1233"},"text":"30 Stat. 1233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78294c5b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78294c5c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78294c5d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"As originally enacted, this section contained following the word “forest” the words “or reservoir site”. See sections 665 and 958 of Title 43, Public Lands, which represent the phase of the section here omitted.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“National forest” substituted in text for “forest reserve” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"act Mar. 4, 1907, ch. 2907","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1269"},"text":"34 Stat. 1269","children":[],"tail":", which provided that forest reserves shall hereafter be known as national forests."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78294c5e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78294c5f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal; Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579/tVII/s706/a"},"text":"Pub. L. 94–579, title VII, § 706(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2793"},"text":"90 Stat. 2793","children":[],"tail":", effective on and after "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", insofar as applicable to the issuance of rights-of-way over, upon, under, and through the public lands and lands in the National Forest System. Such repeal not to be construed as terminating any valid lease, permit, patent, etc., existing on "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/579/s701"},"text":"section 701 of Pub. L. 94–579","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
