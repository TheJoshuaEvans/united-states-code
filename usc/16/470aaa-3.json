{"tag":"section","attrib":{"id":"id781882e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"470aaa–3"},"text":"§ 470aaa–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of paleontological resources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id781882e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permit requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id781882e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in this chapter, a paleontological resource may not be collected from Federal land without a permit issued under this chapter by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781882ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Casual collecting exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allow casual collecting without a permit on Federal land controlled or administered by the Bureau of Land Management, the Bureau of Reclamation, and the Forest Service, where such collection is consistent with the laws governing the management of those Federal land ","children":[{"tag":"ref","attrib":{"idref":"fn002398"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002398"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “lands”."}],"tail":" and this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781882eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Previous permit exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall affect a valid permit issued prior to ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id781882ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for issuance of a permit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may issue a permit for the collection of a paleontological resource pursuant to an application if the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id781882ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant is qualified to carry out the permitted activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781882ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the permitted activity is undertaken for the purpose of furthering paleontological knowledge or for public education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781882ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the permitted activity is consistent with any management plan applicable to the Federal land concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781882f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed methods of collecting will not threaten significant natural or cultural resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id781882f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permit specifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A permit for the collection of a paleontological resource issued under this section shall contain such terms and conditions as the Secretary deems necessary to carry out the purposes of this chapter. Every permit shall include requirements that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id781882f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the paleontological resource that is collected from Federal land under the permit will remain the property of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781882f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the paleontological resource and copies of associated records will be preserved for the public in an approved repository, to be made available for scientific research and public education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781882f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific locality data will not be released by the permittee or repository without the written permission of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id781882f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification, suspension, and revocation of permits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id781882f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may modify, suspend, or revoke a permit issued under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id781882f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for resource, safety, or other management considerations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781882f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when there is a violation of term or condition of a permit issued pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781882f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The permit shall be revoked if any person working under the authority of the permit is convicted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s470aaa–5"},"text":"section 470aaa–5 of this title","children":[],"tail":" or is assessed a civil penalty under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s470aaa–6"},"text":"section 470aaa–6 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id781882fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area closures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to protect paleontological or other resources or to provide for public safety, the Secretary may restrict access to or close areas under the Secretary’s jurisdiction to the collection of paleontological resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id781882fb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVI/s6304"},"text":"Pub. L. 111–11, title VI, § 6304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1173"},"text":"123 Stat. 1173","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
