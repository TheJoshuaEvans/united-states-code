{"tag":"section","attrib":{"id":"id77c051c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460k–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"460k–4"},"text":"§ 460k–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated such funds as may be necessary to carry out the purposes of this subchapter, including the construction and maintenance of public recreational facilities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77c051c7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/714/s5"},"text":"Pub. L. 87–714, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-28"},"text":"Sept. 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/654"},"text":"76 Stat. 654","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
