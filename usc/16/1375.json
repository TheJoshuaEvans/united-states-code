{"tag":"section","attrib":{"id":"id791c8619-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1375"},"text":null,"children":[{"tag":"num","attrib":{"value":"1375"},"text":"§ 1375.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id791c861a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1375/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791c861b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1375/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who violates any provision of this subchapter or of any permit or regulation issued thereunder, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1387"},"text":"section 1387 of this title","children":[],"tail":", may be assessed a civil penalty by the Secretary of not more than $10,000 for each such violation. No penalty shall be assessed unless such person is given notice and opportunity for a hearing with respect to such violation. Each unlawful taking or importation shall be a separate offense. Any such civil penalty may be remitted or mitigated by the Secretary for good cause shown. Upon any failure to pay a penalty assessed under this subsection, the Secretary may request the Attorney General to institute a civil action in a district court of the United States for any district in which such person is found, resides, or transacts business to collect the penalty and such court shall have jurisdiction to hear and decide any such action."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791c861c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1375/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case involving an alleged unlawful importation of a marine mammal or marine mammal product, if such importation is made by an individual for his own personal or family use (which does not include importation as an accommodation to others or for sale or other commercial use), the Secretary may, in lieu of instituting a proceeding under paragraph (1), allow the individual to abandon the mammal or product, under procedures to be prescribed by the Secretary, to the enforcement officer at the port of entry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791c861d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1375/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who knowingly violates any provision of this subchapter or of any permit or regulation issued thereunder (except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1387"},"text":"section 1387 of this title","children":[],"tail":") shall, upon conviction, be fined not more than $20,000 for each such violation, or imprisoned for not more than one year, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id791c861e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tI/s105"},"text":"Pub. L. 92–522, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1036"},"text":"86 Stat. 1036","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/58/s3/b"},"text":"Pub. L. 97–58, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-09"},"text":"Oct. 9, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/982"},"text":"95 Stat. 982","children":[],"tail":"; "},{"tag"