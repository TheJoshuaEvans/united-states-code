{"tag":"section","attrib":{"id":"id77957090-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430h–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"430h–5"},"text":"§ 430h–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums, but not more than $3,850,000, as are required for acquisition of lands and interests in lands and for construction and relocation of roads pursuant to sections 430h–3 to 430h–5 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77957091-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/37/s3"},"text":"Pub. L. 88–37, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-06-04"},"text":"June 4, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/56"},"text":"77 Stat. 56","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/578/tII/s201/8"},"text":"Pub. L. 94–578, title II, § 201(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2733"},"text":"90 Stat. 2733","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77957092-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77957093-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77957094-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578"},"text":"Pub. L. 94–578","children":[],"tail":" substituted “$3,850,000” for “$2,050,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
