{"tag":"section","attrib":{"id":"id77825e0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"410eeee–12"},"text":"§ 410eeee–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements with State","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In administering the national river, the Secretary is authorized to enter into cooperative agreements with the State of West Virginia, or any political subdivision thereof, for the rendering, on a reimbursable or non-reimbursable basis, of rescue, fire fighting, and law enforcement services and cooperative assistance by nearby law enforcement and fire preventive agencies.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77825e0d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/tXI/s1113"},"text":"Pub. L. 95–625, title XI, § 1113","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/534/tI/s102"},"text":"Pub. L. 100–534, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-26"},"text":"Oct. 26, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2700"},"text":"102 Stat. 2700","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77825e0e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77825e0f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77825e10-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"