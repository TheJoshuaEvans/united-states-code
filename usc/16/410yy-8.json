{"tag":"section","attrib":{"id":"id776364ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"410yy–8"},"text":"§ 410yy–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Keweenaw National Historical Park Advisory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id776364cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established the Keweenaw National Historical Park Advisory Commission. The Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776364d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary in the preparation and implementation of a general management plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410yy–5"},"text":"section 410yy–5 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary on the development of and priorities for implementing standards and criteria by which the Secretary, pursuant to agreements referred to in sections 410yy–6 and 410yy–7 of this title, will provide financial as well as technical assistance to owners of non-Federal properties within the park;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary on the development of rules governing the disbursal of funds for the development of non-Federal properties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary with respect to the selection of sites for interpretation and preservation by means of cooperative agreements pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410yy–6"},"text":"section 410yy–6 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Secretary in developing policies and programs for the conservation and protection of the scenic, historical, cultural, natural and technological values of the park which would complement the purposes of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Secretary in coordinating with local governments and the State of Michigan the implementation of the general management plan, and furthering the purposes of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be authorized to carry out historical, educational, or cultural programs which encourage or enhance appreciation of the historic resources in the park, surrounding areas, and on the Keweenaw Peninsula; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be authorized to seek, accept, and dispose of gifts, bequests, or donations of money, personal property, or services, received from any source, consistent with the purposes of this subchapter and the park management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776364d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776364d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission may acquire real property, or interests in real property, to further the purposes of the subchapter by gift or devise; or, by purchase from a willing seller with money which was given or bequeathed to the Commission on the condition that such money would be used to purchase real property, or interests in real property, to further the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s170/c"},"text":"section 170(c) of title 26","children":[],"tail":", any gift to the Commission shall be deemed to be a gift to the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any real property or interest in real property acquired by the Commission shall be conveyed by the Commission to the National Park Service or the appropriate public agency as soon as possible after such acquisition, without consideration, and on the condition that the real property or interest in real property so conveyed is used for public purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The value of funds or property, or interests in property, conveyed to the National Park Service by the Commission may be considered as non-Federal, at the Commission’s discretion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776364dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776364de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall be composed of seven members appointed by the Secretary, of whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776364df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members shall be appointed after consideration of nominees submitted by the Calumet Village Council and the Calumet Township Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776364e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member shall be appointed after consideration of nominees submitted by the Quincy Township Board and the Franklin Township Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776364e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member shall be appointed after consideration of nominees submitted by the Houghton County Board of Commissioners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776364e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member shall be appointed after consideration of nominees submitted by the Governor of the State of Michigan; and,","children":[{"tag":"ref","attrib":{"idref":"fn002141"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002141"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776364e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members who are qualified to serve on the Commission because of their familiarity with National Parks and historic preservation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chairperson of the Commission shall be elected by the members to serve a term of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy on the Commission shall be filled in the same manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of service","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776364e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member shall be appointed for a term of 3 years and may be reappointed not more than three times.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776364e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the members first appointed under subsection (b)(1),","children":[{"tag":"ref","attrib":{"idref":"fn002142"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002142"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “paragraph (1),”."}],"tail":" the Secretary shall appoint—"}],"tail":null},{"tag":"clause","attrib":{"id":"id776364e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members for a term of 1 year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776364ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members for a term of 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776364eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three members for a term of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extended service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member may serve after the expiration of that member’s term until a successor has taken office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall meet at least quarterly at the call of the chairperson or a majority of the members of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Five members shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776364ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members shall serve without pay. Members who are full-time officers or employees of the United States, the State of Michigan, or any political subdivision thereof shall receive no additional pay on account of their service on the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776364f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"While away from their homes or regular places of business in the performance of services for the Commission, members shall be allowed travel expenses, including per diem in lieu of subsistence, in the same manner as persons employed intermittently in the Government service are allowed expenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776364f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mails","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may use the United States mails in the same manner and under the same conditions as other departments and agencies of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776364f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may appoint and fix the pay of such personnel as the Commission deems desirable. The Secretary may provide the Commission with such staff and technical assistance as the Secretary, after consultation with the Commission, considers appropriate to enable the Commission to carry out its duties, on a cost reimbursable basis. Upon request of the Secretary, any Federal agency may provide information, personnel, property, and services on a reimbursable basis, to the Commission to assist in carrying out its duties under this section. The Secretary may accept the services of personnel detailed from the State of Michigan or any political subdivision of the State and reimburse the State or such political subdivision for such services. The Commission may procure additional temporary and intermittent services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":", with funds obtained under subsection (a)(6), or as provided by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776364f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–8/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may, for the purpose of carrying out this subchapter, hold such hearings, sit and act at such times and places, take such testimony, and receive such evidence, as the Commission considers appropriate. The Commission may not issue subpoenas or exercise any subpoena authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id776364f4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/543/s9"},"text":"Pub. L. 102–543, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3572"},"text":"106 Stat. 3572","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/134/s1"},"text":"Pub. L. 106–134, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-07"},"text":"Dec. 7, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1684"},"text":"113 Stat. 1684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id776364f5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id776364f6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id776364f7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (c)(1)(A) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/134"},"text":"Pub. L. 106–134","children":[],"tail":" substituted “after consideration of nominees” for “from nominees”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id776364f8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id776364f9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Commissions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory commissions established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a commission established by the President or an officer of the Federal Government, such commission is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a commission established by Congress, its duration is otherwise provided for by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
