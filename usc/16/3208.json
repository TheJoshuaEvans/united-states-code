{"tag":"section","attrib":{"id":"id79b2ab5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3208"},"text":null,"children":[{"tag":"num","attrib":{"value":"3208"},"text":"§ 3208.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; contract authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b2ab5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3208/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002742"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002742"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (b) has been enacted."}],"tail":" There are hereby authorized to be appropriated such sums as may be necessary to carry out the provisions of this Act for fiscal years beginning after the fiscal year 1980. No authority to enter into contracts or to make payments or to expend previously appropriated funds under this Act shall be effective except to the extent or in such amounts as are provided in advance in appropriation Acts."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b2ab5d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487/tXIII/s1321"},"text":"Pub. L. 96–487, title XIII, § 1321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2487"},"text":"94 Stat. 2487","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b2ab5e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79b2ab5f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":