{"tag":"section","attrib":{"id":"id77ad3ea7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459d–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"459d–5"},"text":"§ 459d–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Roadways to access highways from mainland","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may provide for roadways from the north and south boundaries of such public recreation area to the access highways from the mainland to Padre Island.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77ad3ea8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/712/s6"},"text":"Pub. L. 87–712, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-28"},"text":"Sept. 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/652"},"text":"76 Stat. 652","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
