{"tag":"section","attrib":{"id":"id774b6f86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y"},"text":null,"children":[{"tag":"num","attrib":{"value":"410y"},"text":"§ 410y.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id774b6f87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Park” means the Chesapeake and Ohio Canal National Historical Park, as herein established.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6f88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Canal” means the Chesapeake and Ohio Canal, including its towpath.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6f89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6f8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means any State, and includes the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6f8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Local government” means any political subdivision of a State, including a county, municipality, city, town, township, or a school or other special district created pursuant to State law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6f8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Person” means any individual, partnership, corporation, private nonprofit organization, or club.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6f8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Landowner” means any person, local government, or State owning, or on reasonable grounds professing to own, lands or interests in lands adjacent to or in the vicinity of the park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id774b6f8e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/664/s2"},"text":"Pub. L. 91–664, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1978"},"text":"84 Stat. 1978","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id774b6f8f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id774b6f90-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id774b6f91-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/163/s1"},"text":"Pub. L. 118–163, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2578"},"text":"138 Stat. 2578","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/163/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410y–4"},"text":"section 410y–4 of this title","children":[],"tail":"] may be cited as the ‘Chesapeake and Ohio Canal National Historical Park Commission Extension Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id774b6f92-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/664/s1"},"text":"Pub. L. 91–664, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1978"},"text":"84 Stat. 1978","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/664/s1"},"text":"“That this Act [enacting this subchapter] shall be known as the ‘Chesapeake and Ohio Canal Development Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id774b6f93-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Dedication to Justice William O. Douglas","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/11"},"text":"Pub. L. 95–11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-03-15"},"text":"Mar. 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/21"},"text":"91 Stat. 21","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/11"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“That the canal and towpath of the Chesapeake and Ohio Canal National Historical Park are hereby dedicated to Justice William O. Douglas in grateful recognition of his long outstanding service as a prominent American conservationist and for his efforts to preserve and protect the canal and towpath from development.","children":[],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“Sec. 2.","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to carry out the provisions of this Act, the Secretary of the Interior is authorized and directed to provide such identification by signs, including, but not limited to changes in existing signs, materials, maps, markers, interpretive programs or other means as will appropriately inform the public of the contributions of Justice William O. Douglas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“Sec. 3.","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior is further authorized and directed to cause to be erected and maintained, within the exterior boundaries of the Chesapeake and Ohio Canal National Historical Park, an appropriate memorial to Justice William O. Douglas. Such memorial shall be of such design and be located at such place within the park as the Secretary shall determine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“Sec. 4.","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated such sums as may be necessary to carry out the provisions of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
