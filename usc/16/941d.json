{"tag":"section","attrib":{"id":"id78d73feb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941d"},"text":null,"children":[{"tag":"num","attrib":{"value":"941d"},"text":"§ 941d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals of United States Fish and Wildlife Service programs related to Great Lakes fish and wildlife resources","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In administering programs of the United States Fish and Wildlife Service related to the Great Lakes Basin, the Director shall seek to achieve the following goals:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78d73fec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Restoring and maintaining self-sustaining fish and wildlife resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d73fed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Minimizing the impacts of contaminants on fishery and wildlife resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d73fee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Protecting, maintaining, and, where degraded and destroyed, restoring fish and wildlife habitat, including the enhancement and creation of wetlands that result in a net gain in the amount of those habitats.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d73fef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Stopping illegal activities adversely impacting fishery and wildlife resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d73ff0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Restoring threatened and endangered species to viable, self-sustaining levels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d73ff1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Protecting, managing, and conserving migratory birds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78d73ff2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/537/tI/s1006"},"text":"Pub. L. 101–537, title I, § 1006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-08"},"text":"Nov. 8, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2373"},"text":"104 Stat. 2373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/tII/s2006"},"text":"Pub. L. 101–646, title II, § 2006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4777"},"text":"104 Stat. 4777","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/h/1"},"text":"Pub. L. 104–332, § 2(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4091"},"text":"110 Stat. 4091","children":[],"tail":"; "},{"tag":"