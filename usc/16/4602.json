{"tag":"section","attrib":{"id":"id79f09f0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4602"},"text":null,"children":[{"tag":"num","attrib":{"value":"4602"},"text":"§ 4602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts and bequests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f09f0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may solicit, accept, hold, administer, invest in government securities, and use gifts and bequests of money and other personal property to aid or facilitate the purposes of the TPIA Program. Property so donated and accepted shall not be subject to sequestration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f09f10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain a full accounting of such gifts and bequests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f09f11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4602/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of donations, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of Federal law, property accepted pursuant to this section shall be considered as a gift, bequest, or devise to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f09f12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4602/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any property and the proceeds thereof shall be used as nearly as practicable in accordance with the terms of the gift or bequest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f09f13-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/628/tXI/s1103"},"text":"Pub. L. 101–628, title XI, § 1103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4502"},"text":"104 Stat. 4502","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
