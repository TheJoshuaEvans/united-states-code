{"tag":"section","attrib":{"id":"id776f4b38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410eee–3"},"text":"§ 410eee–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id776f4b39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The park shall be administered by the Secretary in accordance with this section and the provisions of law generally applicable to units of the National Park System, including the Act entitled “An Act to establish a National Park Service, and for other purposes”, approved ","children":[{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":", 2, 3, and 4) "},{"tag":"ref","attrib":{"idref":"fn002165"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002165"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and the Act of "},{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/49/666"},"text":"49 Stat. 666","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s461–467"},"text":"16 U.S.C. 461–467","children":[],"tail":"),"},{"tag":"ref","attrib":{"idref":"fn002165"},"text":"1","children":[],"tail":" as amended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776f4b3a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776f4b3b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may consult and enter into cooperative agreements with interested entities and individuals to provide for the preservation, development, interpretation, and use of the park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b3c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any payment made by the Secretary pursuant to a cooperative agreement under this paragraph shall be subject to an agreement that conversion, use, or disposal of the project so assisted for purposes contrary to the purposes of this subchapter, as determined by the Secretary, shall result in a right of the United States to reimbursement of all funds made available to such a project or the proportion of the increased value of the project attributable to such funds as determined at the time of such conversion, use, or disposal, whichever is greater.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776f4b3d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of real property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of the park, the Secretary is authorized to acquire real property with appropriated or donated funds, by donation, or by exchange, within the boundaries of the park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776f4b3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776f4b3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References to historic site","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in any law (other than this subchapter), regulation, document, record, map, or other paper of the United States to the Adams National Historic Site shall be considered to be a reference to the historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id776f4b40-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/342/s5"},"text":"Pub. L. 105–342, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-02"},"text":"Nov. 2, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3201"},"text":"112 Stat. 3201","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id776f4b41-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id776f4b42-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"child