{"tag":"section","attrib":{"id":"id7883c835-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715o"},"text":null,"children":[{"tag":"num","attrib":{"value":"715o"},"text":"§ 715o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National forest and power sites; use for migratory bird reservations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed as authorizing or empowering the Migratory Bird Conservation Commission herein created, the Secretary of the Interior, or any other board, commission, or officer, to declare, withdraw, or determine, except heretofore designated, any part of any national forest or power site, a migratory bird reservation under any of the provisions of this subchapter, except by and with the consent of the legislature of the State wherein such forest or power site is located.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7883c836-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-02-18/ch257/s16"},"text":"Feb. 18, 1929, ch. 257, § 16","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1225"},"text":"45 Stat. 1225","children":[],"tail":"; 1939 Reorg. Plan No. II, § 4(f), eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2731, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1433"},"text":"53 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7883c837-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7883c838-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7883c839-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Herein created, referred to in text, means created by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s715a"},"text":"section 715a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7883c83a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id7883c83b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of functions of Secretary of Agriculture to Secretary of the Interior by Reorg. Plan No. II of 1939, see Transfer of Functions note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s715a"},"text":"section 715a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
