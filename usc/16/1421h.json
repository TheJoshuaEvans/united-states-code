{"tag":"section","attrib":{"id":"id792f98c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421h"},"text":"§ 1421h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792f98c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “entangle” or “entanglement” means an event in the wild in which a living or dead marine mammal has gear, rope, line, net, or other material wrapped around or attached to the marine mammal and is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792f98c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on lands under the jurisdiction of the United States, including beaches and shorelines; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f98c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in waters under the jurisdiction of the United States, including any navigable waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f98c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as used in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421f–1"},"text":"section 1421f–1 of this title","children":[],"tail":", the term “Fund” means the Marine Mammal Unusual Mortality Event Fund established by "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421d/a"},"text":"section 1421d(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f98ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Health MAP” means the Marine Mammal Health Monitoring and Analysis Platform established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421f–2/a/1"},"text":"section 1421f–2(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f98cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Observation System” means the National Integrated Coastal and Ocean Observation System established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3603"},"text":"section 3603 of title 33","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f98cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Office” means the Office of Protected Resources, in the National Marine Fisheries Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f98cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “stranding” means an event in the wild in which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792f98ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a marine mammal is dead and is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id792f98cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a beach or shore of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792f98d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in waters under the jurisdiction of the United States (including any navigable waters); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f98d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a marine mammal is alive and is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id792f98d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a beach or shore of the United States and unable to return to the water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792f98d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a beach or shore of the United States and, although able to return to the water, is in need of apparent medical attention; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792f98d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the waters under the jurisdiction of the United States (including any navigable waters), but is unable to return to its natural habitat under its own power or without assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f98d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “stranding network participant” means a person who is authorized by an agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1382/c"},"text":"section 1382(c) of this title","children":[],"tail":" to take marine mammals as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1379/h/1"},"text":"section 1379(h)(1) of this title","children":[],"tail":" in response to a stranding."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f98d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Tissue Bank” means the National Marine Tissue Bank provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421f/a"},"text":"section 1421f(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f98d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “unusual mortality event” means a stranding that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792f98d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is unexpected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f98d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves a significant die-off of any marine mammal population; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f98da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421h/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demands immediate response.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792f98db-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tIV/s410"},"text":"Pub. L. 92–522, title IV, § 410","children":[],"tail":", formerly title III, § 309, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tIII/s3003/a"},"text":"Pub. L. 102–587, title III, § 3003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5066"},"text":"106 Stat. 5066","children":[],"tail":"; renumbered title IV, § 409, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/238/s24/b"},"text":"Pub. L. 103–238, § 24(b)","children":[],"tail":", (c)(7), (8), "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/565"},"text":"108 Stat. 565","children":[],"tail":", 566; renumbered § 410, "},{"tag":"ref","attrib":{"href":"/us/pl/106/555/tII/s202/a/1"},"text":"Pub. L. 106–555, title II, § 202(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2767"},"text":"114 Stat. 2767","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIV/s10410"},"text":"Pub. L. 117–263, div. J, title CIV, § 10410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3992"},"text":"136 Stat. 3992","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792f98dc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792f98dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id792f98de-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10410/2"},"text":"Pub. L. 117–263, § 10410(2)","children":[],"tail":", added par. (1). Former par. (1) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10410/3"},"text":"Pub. L. 117–263, § 10410(3)","children":[],"tail":", substituted “Except as used in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421f–1"},"text":"section 1421f–1 of this title","children":[],"tail":", the term” for “The term”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10410/1"},"text":"Pub. L. 117–263, § 10410(1)","children":[],"tail":", redesignated par. (1) as (2). Former par. (2) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10410/1"},"text":"Pub. L. 117–263, § 10410(1)","children":[],"tail":", (4), added pars. (3) and (4) and redesignated former pars. (2) to (6) as (5) to (9), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/238/s24/c/7"},"text":"Pub. L. 103–238, § 24(c)(7)","children":[],"tail":", made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421d/a"},"text":"section 1421d(a) of this title","children":[],"tail":" to reflect renumbering of corresponding section of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/238/s24/c/8"},"text":"Pub. L. 103–238, § 24(c)(8)","children":[],"tail":", made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421f/a"},"text":"section 1421f(a) of this title","children":[],"tail":" to reflect renumbering of corresponding section of original act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
