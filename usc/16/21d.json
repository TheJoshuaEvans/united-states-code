{"tag":"section","attrib":{"id":"id76f0cc6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s21d"},"text":null,"children":[{"tag":"num","attrib":{"value":"21d"},"text":"§ 21d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing claims, locations, and entries as affected by revised boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing herein contained shall affect any valid existing claim, location, or entry under the land laws of the United States, whether for homestead, mineral right of way, or any other purposes whatsoever, or shall affect the right of any such claimant, locator, or entryman to the full use and enjoyment of his land.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76f0cc6e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-03-01/ch437/s4"},"text":"Mar. 1, 1929, ch. 437, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1436"},"text":"45 Stat. 1436","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id76f0cc6f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id76f0cc70-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id76f0cc71-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Herein, referred to in text, means act ","children":[{"tag":"date","attrib":{"date":"1929-03-01"},"text":"Mar. 1, 1929","children":[],"tail":", which is classified to sections 21a to 21d of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
