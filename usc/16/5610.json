{"tag":"section","attrib":{"id":"id7a0167e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5610"},"text":null,"children":[{"tag":"num","attrib":{"value":"5610"},"text":"§ 5610.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this chapter, including to pay the United States contribution to the Organization as provided in Article IX of the Convention, $500,000 for each fiscal year through fiscal year 2021.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a0167e3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tII/s211"},"text":"Pub. L. 104–43, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/382"},"text":"109 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/384/tII/s201/a"},"text":"Pub. L. 105–384, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3451"},"text":"112 Stat. 3451","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/372/tIII/s305"},"text":"Pub. L. 107–372, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3096"},"text":"116 Stat. 3096","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/tIII/s302/i"},"text":"Pub. L. 109–479, title III, § 302(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"h