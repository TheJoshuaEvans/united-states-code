{"tag":"section","attrib":{"id":"id7714a84a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s217"},"text":null,"children":[{"tag":"num","attrib":{"value":"217"},"text":"§ 217.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change in name of Abraham Lincoln National Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Abraham Lincoln National Park, in the State of Kentucky, authorized by sections 211 to 214 of this title, shall hereafter be called and known as the “Abraham Lincoln National Historical Park”, and all moneys heretofore or hereafter appropriated for this area under previous designations may be used in this area as redesignated.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7714a84b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-11/ch686"},"text":"Aug. 11, 1939, ch. 686","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1405"},"text":"53 Stat. 1405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7714a84c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7714a84d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7714a84e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Portion of act ","children":[{"tag":"date","attrib":{"date":"1939-08-11"},"text":"Aug. 11, 1939","children":[],"tail":", relating to Fort McHenry National Monument and Historic Shrine is set out as "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s440a"},"text":"section 440a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7714a84f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7714a850-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Abraham Lincoln National Historical Park was renamed Abraham Lincoln Birthplace National Historic Site by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/231"},"text":"Pub. L. 86–231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-08"},"text":"Sept. 8, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/466"},"text":"73 Stat. 466","children":[],"tail":", and then was renamed Abraham Lincoln Birthplace National Historical Park by "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7114/a"},"text":"Pub. L. 111–11, title VII, § 7114(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1202"},"text":"123 Stat. 1202","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
