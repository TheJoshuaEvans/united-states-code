{"tag":"section","attrib":{"id":"id7a1209fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6575"},"text":null,"children":[{"tag":"num","attrib":{"value":"6575"},"text":"§ 6575.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1209ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6575/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall provide landowners with technical assistance to assist the owners in complying with the terms of plans (as included in agreements or easements) under the healthy forests reserve program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6575/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical service providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may request the services of, and enter into cooperative agreements with, individuals or entities certified as technical service providers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3842"},"text":"section 3842 of this title","children":[],"tail":", to assist the Secretary in providing technical assistance necessary to develop and implement the healthy forests reserve program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a120a01-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tV/s505"},"text":"Pub. L. 108–148, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1913"},"text":"117 Stat. 1913","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
