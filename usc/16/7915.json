{"tag":"section","attrib":{"id":"id7a2eba12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915"},"text":null,"children":[{"tag":"num","attrib":{"value":"7915"},"text":"§ 7915.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identifying opportunities for recreation, hunting, and fishing on Federal land","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2eba13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2eba14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretary” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2eba15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary, with respect to land administered by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2eba16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Park Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2eba17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the United States Fish and Wildlife Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2eba18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Bureau of Land Management; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eba19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, with respect to land administered by the Chief of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eba1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State or regional office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State or regional office” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2eba1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State office of the Bureau of Land Management; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eba1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a regional office of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2eba1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Park Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2eba1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Fish and Wildlife Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2eba1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eba20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel management plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “travel management plan” means a plan for the management of travel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2eba21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to land under the jurisdiction of the National Park Service, on park roads and designated routes under section 4.10 of title 36, Code of Federal Regulations (or successor regulations);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eba22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to land under the jurisdiction of the United States Fish and Wildlife Service, on the land under a comprehensive conservation plan prepared under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s668dd/e"},"text":"section 668dd(e) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eba23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to land under the jurisdiction of the Forest Service, on National Forest System land under part 212 of title 36, Code of Federal Regulations (or successor regulations); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eba24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to land under the jurisdiction of the Bureau of Land Management, under a resource management plan developed under the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2eba25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority lists required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2eba26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", and biennially thereafter during the 10-year period beginning on the date on which the first priority list is completed, the Secretary shall prepare a priority list, to be made publicly available on the website of the applicable Federal agency referred to in subsection (a)(1), which shall identify the location and acreage of land within the jurisdiction of each State or regional office on which the public is allowed, under Federal or State law, to hunt, fish, or use the land for other recreational purposes but—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2eba27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which there is no public access or egress; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eba28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which public access or egress to the legal boundaries of the land is significantly restricted (as determined by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eba29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum size","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any land identified under paragraph (1) shall consist of contiguous acreage of at least 640 acres.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eba2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In preparing the priority list required under paragraph (1), the Secretary shall consider, with respect to the land—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2eba2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether access is absent or merely restricted, including the extent of the restriction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eba2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the likelihood of resolving the absence of or restriction to public access;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eba2d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for recreational use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eba2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information received from the public or other stakeholders during the nomination process described in paragraph (5); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eba2f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other factor, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eba30-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjacent land status","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each parcel of land on the priority list, the Secretary shall include in the priority list whether resolving the issue of public access or egress to the land would require acquisition of an easement, right-of-way, or fee title from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a310321-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another Federal agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a310322-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, local, or Tribal government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a310323-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private landowner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310324-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nomination process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In preparing a priority list under this section, the Secretary shall provide an opportunity for members of the public to nominate parcels for inclusion on the priority list.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a310325-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access options","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to land included on a priority list described in subsection (b), the Secretary shall develop and submit to the Committees on Appropriations and Energy and Natural Resources of the Senate and the Committees on Appropriations and Natural Resources of the House of Representatives a report on options for providing access that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a310326-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies how public access and egress could reasonably be provided to the legal boundaries of the land in a manner that minimizes the impact on wildlife habitat and water quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310327-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies the steps recommended to secure the access and egress, including acquiring an easement, right-of-way, or fee title from a willing owner of any land that abuts the land or the need to coordinate with State land management agencies or other Federal, State, or Tribal governments to allow for such access and egress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310328-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the travel management plan in effect on the land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a310329-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of personally identifying information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making the priority list and report prepared under subsections (b) and (c) available, the Secretary shall ensure that no personally identifying information is included, such as names or addresses of individuals or entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a31032a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Willing owners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of providing any permits to, or entering into agreements with, a State, local, or Tribal government or private landowner with respect to the use of land under the jurisdiction of the government or landowner, the Secretary shall not take into account whether the State, local, or Tribal government or private landowner has granted or denied public access or egress to the land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a31032b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Means of public access and egress included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In considering public access and egress under subsections (b) and (c), the Secretary shall consider public access and egress to the legal boundaries of the land described in those subsections, including access and egress—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a31032c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by motorized or non-motorized vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31032d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on foot or horseback.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a31032e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a31032f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall have no effect on whether a particular recreational use shall be allowed on the land included in a priority list under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310330-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7915/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of allowable uses on agency consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In preparing the priority list under subsection (b), the Secretary shall only consider recreational uses that are allowed on the land at the time that the priority list is prepared.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a310331-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tIV/s4105"},"text":"Pub. L. 116–9, title IV, § 4105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/759"},"text":"133 Stat. 759","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a310332-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a310333-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a310334-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in subsec. (a)(3)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":", Public Lands, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a310335-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7a310336-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2"},"text":"section 2 of Pub. L. 116–9","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
