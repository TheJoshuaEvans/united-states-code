{"tag":"section","attrib":{"id":"id78d73ff7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941e"},"text":null,"children":[{"tag":"num","attrib":{"value":"941e"},"text":"§ 941e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of offices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78d73ff8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lower Great Lakes Fish and Wildlife Conservation Office","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78d73ff9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish an office with necessary administrative and technical support services to carry out all United States Fish and Wildlife Service operational activities related to fishery resource protection, restoration, maintenance, and enhancement in the lower Great Lakes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d73ffa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Name and location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The office shall be known as the “Lower Great Lakes Fish and Wildlife Conservation Office”, and shall be centrally located in the lower Great Lakes so as to facilitate fishery resource restoration and enhancement activities relating to the lower Great Lakes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d73ffb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responsibilities of the Lower Great Lakes Fish and Wildlife Conservation Office shall include operational activities of the United States Fish and Wildlife Service related to fishery resource protection, restoration, maintenance, and enhancement in the Lower Great Lakes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d73ffc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Upper Great Lakes Fish and Wildlife Conservation Offices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78d73ffd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish one or more offices with necessary administrative and technical support services to carry out United States Fish and Wildlife Service operational activities related to fishery resource protection, restoration, maintenance, and enhancement in the upper Great Lakes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d73ffe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Name and location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each of the offices shall be known as an “Upper Great Lakes Fish and Wildlife Conservation Office”, and shall be appropriately located so as to facilitate fishery resource activities in the upper Great Lakes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d73fff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responsibilities of the Upper Great Lakes Fish and Wildlife Conservation Offices shall include operational activities of the United States Fish and Wildlife Service related to fishery resource protection, restoration, maintenance, and enhancement in the Upper Great Lakes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78d74000-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/537/tI/s1007"},"text":"Pub. L. 101–537, title I, § 1007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-08"},"text":"Nov. 8, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2374"},"text":"104 Stat. 2374","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/tII/s2007"},"text":"Pub. L. 101–646, title II, § 2007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4777"},"text":"104 Stat. 4777","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/h/1"},"text":"Pub. L. 104–332, § 2(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4091"},"text":"110 Stat. 4091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/265/s3/b"},"text":"Pub. L. 105–265, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2358"},"text":"112 Stat. 2358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/326/s6"},"text":"Pub. L. 109–326, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-11"},"text":"Oct. 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1764"},"text":"120 Stat. 1764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tIII/s3901/d"},"text":"Pub. L. 114–322, title III, § 3901(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1850"},"text":"130 Stat. 1850","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78d74001-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78d74002-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78d74003-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/537"},"text":"Pub. L. 101–537","children":[],"tail":" and title II of "},{"tag":"ref","attrib":{"href":"/us/pl/101/646"},"text":"Pub. L. 101–646","children":[],"tail":" enacted substantially identical sections. Title II of "},{"tag":"ref","attrib":{"href":"/us/pl/101/646"},"text":"Pub. L. 101–646","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/265"},"text":"Pub. L. 105–265","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78d74004-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s3901/d/3"},"text":"Pub. L. 114–322, § 3901(d)(3)","children":[],"tail":", (4), redesignated subsec. (b) as (a) and struck out former subsec. (a) which related to establishment of the Great Lakes Coordination Office."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s3901/d/4"},"text":"Pub. L. 114–322, § 3901(d)(4)","children":[],"tail":", redesignated subsec. (c) as (b). Former subsec. (b) redesignated (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s3901/d/1"},"text":"Pub. L. 114–322, § 3901(d)(1)","children":[],"tail":", substituted “Fish and Wildlife Conservation” for “Fishery Resources” in heading and in pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s3901/d/4"},"text":"Pub. L. 114–322, § 3901(d)(4)","children":[],"tail":", redesignated subsec. (c) as (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s3901/d/2"},"text":"Pub. L. 114–322, § 3901(d)(2)","children":[],"tail":", substituted “Fish and Wildlife Conservation” for “Fishery Resources” in heading and in pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/326/s6/1"},"text":"Pub. L. 109–326, § 6(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Text read as follows: “The Director shall establish a centrally located facility for the coordination of all United States Fish and Wildlife Service activities in the Great Lakes Basin, to be known as the ‘Great Lakes Coordination Office’. The functional responsibilities of the Great Lakes Coordination Office shall include intra- and interagency coordination, information distribution, and public awareness outreach. The Great Lakes Coordination Office shall include all administrative and technical support necessary to carry out its responsibilities.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/326/s6/2"},"text":"Pub. L. 109–326, § 6(2)","children":[],"tail":", designated first and second sentences of subsec. (b) as pars. (1) and (2), respectively, inserted headings, and added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/326/s6/3"},"text":"Pub. L. 109–326, § 6(3)","children":[],"tail":", designated first and second sentences of subsec. (c) as pars. (1) and (2), respectively, inserted headings, and added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332"},"text":"Pub. L. 104–332","children":[],"tail":" made technical amendment to "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/s2007"},"text":"Pub. L. 101–646, § 2007","children":[],"tail":", which enacted this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
