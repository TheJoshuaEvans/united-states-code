{"tag":"section","attrib":{"id":"id793453de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1436"},"text":null,"children":[{"tag":"num","attrib":{"value":"1436"},"text":"§ 1436.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited activities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is unlawful for any person to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id793453df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1436/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" destroy, cause the loss of, or injure any sanctuary resource managed under law or regulations for that sanctuary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793453e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1436/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possess, sell, offer for sale, purchase, import, export, deliver, carry, transport, or ship by any means any sanctuary resource taken in violation of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793453e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1436/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" interfere with the enforcement of this chapter by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id793453e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1436/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refusing to permit any officer authorized to enforce this chapter to board a vessel, other than a vessel operated by the Department of Defense or United States Coast Guard, subject to such person’s control for the purposes of conducting any search or inspection in connection with the enforcement of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id793453e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1436/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resisting, opposing, impeding, intimidating, harassing, bribing, interfering with, or forcibly assaulting any person authorized by the Secretary to implement this chapter or any such authorized officer in the conduct of any search or inspection performed under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id793453e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1436/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully submitting false information to the Secretary or any officer authorized to enforce this chapter in connection with any search or inspection conducted under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793453e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1436/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violate any provision of this chapter or any regulation or permit issued pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id793453e6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tIII/s306"},"text":"Pub. L. 92–532, title III, § 306","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/498/tI/s102"},"text":"Pub. L. 98–498, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2302"},"text":"98 Stat. 2302","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tII/s2106"},"text":"Pub. L. 102–587, title II, § 2106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5043"},"text":"106 Stat. 5043","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/513/s7"},"text":"Pub. L. 106–513, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2386"},"text":"114 Stat. 2386","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id793453e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id793453e8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id793453e9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s7/1"},"text":"Pub. L. 106–513, § 7(1)","children":[],"tail":", inserted “for any person” after “unlawful” in introductory provision."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s7/2"},"text":"Pub. L. 106–513, § 7(2)","children":[],"tail":", inserted “offer for sale, purchase, import, export,” after “sell,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s7/3"},"text":"Pub. L. 106–513, § 7(3)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “interfere with the enforcement of this chapter; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The Secretary shall conduct research and educational programs as are necessary and reasonable to carry out the purposes and policies of this chapter.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id793453ea-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id793453eb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
