{"tag":"section","attrib":{"id":"id7708c150-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s146"},"text":null,"children":[{"tag":"num","attrib":{"value":"146"},"text":"§ 146.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses within park","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All persons who shall unlawfully intrude upon said park, or who shall without permission appropriate any object therein or commit unauthorized injury or waste in any form whatever upon the lands or other public property therein, or who shall violate any of the rules and regulations prescribed hereunder, shall upon conviction be fined in a sum not more than $1,000 or be imprisoned for a period not more than twelve months, or shall suffer both fine and imprisonment, in the discretion of the court.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7708c151-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1903-01-09/ch63/s6"},"text":"Jan. 9, 1903, ch. 63, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/766"},"text":"32 Stat. 766","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7708c152-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7708c153-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7708c154-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Hereunder, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/act/1903-01-09/ch63"},"text":"act Jan. 9, 1903, ch. 63","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/765"},"text":"32 Stat. 765","children":[],"tail":", which is classified to sections 141, and 142 to 146 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
