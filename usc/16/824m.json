{"tag":"section","attrib":{"id":"id78aecfc6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824m"},"text":null,"children":[{"tag":"num","attrib":{"value":"824m"},"text":"§ 824m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sales by exempt wholesale generators","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No rate or charge received by an exempt wholesale generator for the sale of electric energy shall be lawful under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s824d"},"text":"section 824d of this title","children":[],"tail":" if, after notice and opportunity for hearing, the Commission finds that such rate or charge results from the receipt of any undue preference or advantage from an electric utility which is an associate company or an affiliate of the exempt wholesale generator. For purposes of this section, the terms “associate company” and “affiliate” shall have the same meaning as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16451"},"text":"section 16451 of title 42","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002537"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002537"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78aecfc7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"June 10, 1920, ch. 285","children":[],"tail":", pt. II, § 214, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tVII/s724"},"text":"Pub. L. 102–486, title VII, § 724","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2920"},"text":"106 Stat. 2920","children":[],"tail":";