{"tag":"section","attrib":{"id":"id799ade7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2443"},"text":null,"children":[{"tag":"num","attrib":{"value":"2443"},"text":"§ 2443.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated, out of any moneys in the Treasury not otherwise appropriated, such sums as may be necessary for carrying out the provisions of this chapter, including, but not limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799ade80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2443/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary travel expenses of the United States representatives referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2433"},"text":"section 2433 of this title","children":[],"tail":", alternate United States representatives, and authorized advisers and experts, in accordance with sections 5701 through 5708, 5731, and 5733 of title 5 and the regulations issued under those sections;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799ade81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2443/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States contribution to the budget of the Commission as provided in article XIX of the Convention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799ade82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2443/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the directed research program and the furnishing of facilities and personnel to the Commission referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2441"},"text":"section 2441 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799ade83-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623/tIII/s314"},"text":"Pub. L. 98–623, title III, § 314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3406"},"text":"98 Stat. 3406","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
