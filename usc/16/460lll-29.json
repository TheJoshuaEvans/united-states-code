{"tag":"section","attrib":{"id":"id77fbfb34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–29"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–29"},"text":"§ 460lll–29.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resource management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fbfb35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–29/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minerals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfb36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–29/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The land within the Recreation Area is withdrawn from the operation of the mining and mineral leasing laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–29/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of mineral materials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may permit the use of common varieties of mineral materials for the development and maintenance of the Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–29/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting and fishing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfb39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–29/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall permit hunting and fishing on land and water under the jurisdiction of the Secretary within the boundaries of the Recreation Area in accordance with applicable laws of the United States and of each State, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb3a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–29/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77fbfb3b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–29/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may designate areas where, and establish periods when, hunting or fishing is prohibited for reasons of public safety, administration, or public use and enjoyment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fbfb3c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–29/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except in emergencies, a prohibition under subparagraph (A) shall become effective only after consultation with the appropriate fish and game departments of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb3d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–29/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish and wildlife","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter affects the jurisdiction or responsibilities of the States with respect to wildlife and fish on national forests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–29/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historical resources","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfb3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–29/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall identify and manage the historical resources of the Recreation Area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77fbfb40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–29/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the requirements of division A of subtitle III of title 54 (formerly known as the “National Historic Preservation Act”); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fbfb41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–29/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with qualified residents or relatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–29/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77fbfb43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–29/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with applicable law, give consideration to requests by qualified residents or relatives to use and maintain traditional sites, buildings, cemeteries, and other areas of cultural importance in the Recreation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fbfb44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–29/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with qualified residents or relatives in the management of the historical resources of the Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fbfb45-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s529"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 529]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–317; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tII/s201/h"},"text":"Pub. L. 117–328, div. DD, title II, § 201(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5583"},"text":"136 Stat. 5583","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77fbfb46-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77fbfb47-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77fbfb48-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
