{"tag":"section","attrib":{"id":"id7a1ba6e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803"},"text":null,"children":[{"tag":"num","attrib":{"value":"6803"},"text":"§ 6803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public participation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1ba6e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As required in this section, the Secretary shall provide the public with opportunities to participate in the development of or changing of a recreation fee established under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1ba6e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish a notice in the Federal Register of the establishment of a new recreation fee area for each agency 6 months before establishment. The Secretary shall publish notice of a new recreation fee or a change to an existing recreation fee established under this chapter in local newspapers and publications located near the site at which the recreation fee would be established or changed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1ba6e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public involvement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before establishing any new recreation fee area, the Secretary shall provide opportunity for public involvement by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1ba6e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing guidelines for public involvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ba6e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing guidelines on how agencies will demonstrate on an annual basis how they have provided information to the public on the use of recreation fee revenues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ba6e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publishing the guidelines in paragraphs (1) and (2) in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1ba6ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreation Resource Advisory Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1ba6eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1ba6ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to establish","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraphs (C) and (D), the Secretary or the Secretaries shall establish a Recreation Resource Advisory Committee in each State or region for Federal recreational lands and waters managed by the Forest Service or the Bureau of Land Management to perform the duties described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1ba6ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of Committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may have as many additional Recreation Resource Advisory Committees in a State or region as the Secretary considers necessary for the effective operation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1ba6ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not establish a Recreation Resource Advisory Committee in a State if the Secretary determines, in consultation with the Governor of the State, that sufficient interest does not exist to ensure that participation on the Committee is balanced in terms of the points of view represented and the functions to be performed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1ba6ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of other entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In lieu of establishing a Recreation Resource Advisory Committee under subparagraph (A), the Secretary may use a Resource Advisory Committee established pursuant to another provision of law and in accordance with that law or a recreation fee advisory board otherwise established by the Secretary to perform the duties specified in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ba6f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with the procedures required by paragraph (9), a Recreation Resource Advisory Committee may make recommendations to the Secretary regarding a standard amenity recreation fee or an expanded amenity recreation fee, whenever the recommendations relate to public concerns in the State or region covered by the Committee regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1ba6f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of a standard amenity recreation fee or an expanded amenity recreation fee or the establishment of a specific recreation fee site;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1ba6f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the elimination of a standard amenity recreation fee or an expanded amenity recreation fee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1ba6f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expansion or limitation of the recreation fee program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ba6f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Recreation Resource Advisory Committee shall meet at least annually, but may, at the discretion of the Secretary, meet as often as needed to deal with citizen concerns about the recreation fee program in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ba6f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of rejection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary rejects the recommendation of a Recreation Resource Advisory Committee, the Secretary shall issue a notice that identifies the reasons for rejecting the recommendation to the Committee on Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate not later than 30 days before the Secretary implements a decision pertaining to that recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ba6f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition of the Advisory Committee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1ba6f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Recreation Resource Advisory Committee shall be comprised of 12 members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1ba6f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor and the designated county official from each county in the relevant State or Region may submit a list of nominations in the categories described under subparagraph (D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1ba6f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may appoint members of the Recreation Resource Advisory Committee from the list as provided in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1ba6fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broad and balanced representation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In appointing the members of a Recreation Resource Advisory Committee, the Secretary shall provide for a balanced and broad representation from the recreation community that shall include the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1ba6fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Five persons who represent recreation users and that include, as appropriate, persons representing the following:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a1ba6fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Winter motorized recreation, such as snowmobiling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a1ba6fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Winter non-motorized recreation, such as snowshoeing, cross country and down hill skiing, and snowboarding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a1ba6fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/D/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Summer motorized recreation, such as motorcycles, boaters, and off-highway vehicles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a1ba6ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/D/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Summer nonmotorized recreation, such as backpacking, horseback riding, mountain biking, canoeing, and rafting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a1ba700-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/D/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hunting and fishing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1ba701-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Four persons who represent interest groups that include, as appropriate, the following:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a1ba702-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Motorized outfitters and guides.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a1ba703-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Non-motorized outfitters and guides.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a1ba704-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/D/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Local environmental groups.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a1ba705-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/D/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans organizations, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8471"},"text":"section 8471 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1ba706-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Three persons, as follows:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a1ba707-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/D/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State tourism official to represent the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a1ba708-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/D/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who represents affected Indian tribes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a1ba709-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/5/D/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who represents affected local government interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ba70a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1ba70b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Length of term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint the members of a Recreation Resource Advisory Committee for staggered terms of 2 and 3 years beginning on the date that the members are first appointed. The Secretary may reappoint members to subsequent 2- or 3-year terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1ba70c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of vacancy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make appointments to fill a vacancy on a Recreation Resource Advisory Committee as soon as practicable after the vacancy has occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1ba70d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of unexpected vacancy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where an unexpected vacancy occurs, the Governor and the designated county officials from each county in the relevant State shall provide the Secretary with a list of nominations in the relevant category, as described under paragraph (5)(D), not later than two months after notification of the vacancy. To the extent possible, a vacancy shall be filled in the same category and term in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ba70e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chairperson of a Recreation Resource Advisory Committee shall be selected by the majority vote of the members of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ba70f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Six members shall constitute a quorum. A quorum must be present to constitute an official meeting of a Recreation Resource Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ba710-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Recreation Resource Advisory Committee shall establish procedures for making recommendations to the Secretary. A recommendation may be submitted to the Secretary only if the recommendation is approved by a majority of the members of the Committee from each of the categories specified in paragraph (5)(D) and general public support for the recommendation is documented.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ba711-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Recreation Resource Advisory Committee shall not receive any compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ba712-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public participation in the Recreation Resource Advisory Committee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1ba713-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All meetings of a Recreation Resource Advisory Committee shall be announced at least one week in advance in a local newspaper of record and the Federal Register, and shall be open to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1ba714-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Recreation Resource Advisory Committee shall maintain records of the meetings of the Recreation Resource Advisory Committee and make the records available for public inspection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ba715-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6803/d/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Recreation Resource Advisory Committee is subject to the provisions of chapter 10 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1ba716-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dJ/tVIII/s804"},"text":"Pub. L. 108–447, div. J, title VIII, § 804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3382"},"text":"118 Stat. 3382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/132"},"text":"Pub. L. 117–286, § 4(a)(132)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4320"},"text":"136 Stat. 4320","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tII/s225"},"text":"Pub. L. 118–234, title II, § 225","children":[],"tail":", title III, § 311(c), "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2888"},"text":"138 Stat. 2888","children":[],"tail":", 2897.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1ba717-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1ba718-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a1ba719-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a), (b), and (d)(1)(B), was in the original “this Act”, and was translated as reading “this title”, meaning title VIII of div. J of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3377"},"text":"118 Stat. 3377","children":[],"tail":", known as the Federal Lands Recreation Enhancement Act, to reflect the probable intent of Congress. For complete classification of title VIII to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6801"},"text":"section 6801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a1ba71a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s225/1"},"text":"Pub. L. 118–234, § 225(1)","children":[],"tail":", substituted “12” for “11”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5)(D)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s225/2/A"},"text":"Pub. L. 118–234, § 225(2)(A)","children":[],"tail":", substituted “Four” for “Three” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5)(D)(ii)(IV). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s225/2/B"},"text":"Pub. L. 118–234, § 225(2)(B)","children":[],"tail":", added subcl. (IV)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s225/3"},"text":"Pub. L. 118–234, § 225(3)","children":[],"tail":", substituted “Six” for “Eight”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s311/c"},"text":"Pub. L. 118–234, § 311(c)","children":[],"tail":", struck out subsec. (e) which authorized the Secretary to post clear notice of any entrance fee, standard amenity recreation fee, and available recreation passes and clear notice of locations where work is performed using recreation fee or recreation pass revenues collected."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “chapter 10 of title 5.” for “the Federal Advisory Committee Act (5 U.S.C. App.).” in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a1ba71b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7a1ba71c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
