{"tag":"section","attrib":{"id":"id79cceb3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833"},"text":null,"children":[{"tag":"num","attrib":{"value":"3833"},"text":"§ 3833.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79cceb3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-share and rental payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In return for a contract entered into by an owner or operator under the conservation reserve program, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cceb40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" share the cost of carrying out the conservation measures and practices set forth in the contract for which the Secretary determines that cost sharing is appropriate and in the public interest, including the cost of fencing and other water distribution practices, if applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cceb41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for a period of years not in excess of the term of the contract, pay an annual rental payment, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3834/d"},"text":"section 3834(d) of this title","children":[],"tail":", for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cceb42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conversion of highly erodible cropland, marginal pastureland, or other eligible lands normally devoted to the production of an agricultural commodity on a farm or ranch to a less intensive use; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cceb43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and management of grasslands for multiple natural resource conservation benefits, including to soil, water, air, and wildlife.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cceb44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified activities permitted","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cceb45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in coordination with the applicable State technical committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3861/a"},"text":"section 3861(a) of this title","children":[],"tail":", shall permit certain activities or commercial uses of established cover on land that is subject to a contract under the conservation reserve program if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cceb46-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" those activities or uses—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cceb47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the conservation of soil, water quality, and wildlife habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cceb48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are subject to appropriate restrictions during the primary nesting season for birds in the local area that are economically significant, in significant decline, or conserved in accordance with Federal or State law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cceb49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to the health and vigor of the established cover; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cceb4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with a site-specific plan, including vegetative management requirements, stocking rates, and frequency and duration of activity, taking into consideration regional differences, such as climate, soil type, and natural resources; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cceb4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary, in coordination with the State technical committee, includes contract modifications—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cceb4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" without any reduction in the rental rate for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79cceb4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" emergency haying, emergency grazing, or other emergency use of the forage in response to a localized or regional drought, flooding, wildfire, or other emergency, on all practices, outside the primary nesting season, when—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id79cceb4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/i/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the county is designated as D2 (severe drought) or greater according to the United States Drought Monitor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79cceb4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/i/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is at least a 40 percent loss in forage production in the county; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79cceb50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/i/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, in coordination with the State technical committee, determines that the program can assist in the response to a natural disaster event without permanent damage to the established cover;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cceb51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency grazing on all practices during the primary nesting season if payments are authorized for a county under the livestock forage disaster program under clause (ii) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9081/c/3/D"},"text":"section 9081(c)(3)(D) of title 7","children":[],"tail":", at 50 percent of the normal carrying capacity determined under clause (i) of that section, adjusted to the site-specific plan;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cf5b52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency haying on certain practices, outside the primary nesting season, if payments are authorized for a county under the livestock forage disaster program under clause (ii) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9081/c/3/D"},"text":"section 9081(c)(3)(D) of title 7","children":[],"tail":", on not more than 50 percent of contract acres, as identified in the site-specific plan;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cf5b53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grazing of all practices, outside the primary nesting season, if included as a mid-contract management practice under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3832/a/5"},"text":"section 3832(a)(5) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cf5b54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the intermittent and seasonal use of vegetative buffer established under paragraphs (4) and (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831/b"},"text":"section 3831(b) of this title","children":[],"tail":" that are incidental to agricultural production on land adjacent to the buffer such that the permitted use—"}],"tail":null},{"tag":"item","attrib":{"id":"id79cf5b55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/i/V/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not destroy the permanent vegetative cover; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79cf5b56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/i/V/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retains suitable vegetative structure for wildlife cover and shelter outside the primary nesting season; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cf5b57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grazing on all practices, outside the primary nesting season, if conducted by a beginning farmer or rancher; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cf5b58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with a 25 percent reduction in the annual rental rate for the acres covered by the authorized activity, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79cf5b59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grazing not more frequently than every other year on the same land, except that during the primary nesting season, grazing shall be subject to a 50 percent reduction in the stocking rate specified in the site-specific plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cf5b5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grazing of all practices during the primary nesting season, with a 50 percent reduction in the stocking rate specified in the site-specific plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cf5b5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" haying and other commercial use (including the managed harvesting of biomass and excluding the harvesting of vegetative cover), on the condition that the activity—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id79cf5b5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/ii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is completed outside the primary nesting season;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79cf5b5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/ii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occurs not more than once every 3 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79cf5b5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/ii/III/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains 25 percent of the total contract acres unharvested, in accordance with a site-specific plan that provides for wildlife cover and shelter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cf5b5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual grazing outside the primary nesting season if consistent with a site-specific plan that is authorized for the control of invasive species; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cf5b60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the installation of wind turbines and associated access, except that in permitting the installation of wind turbines, the Secretary shall determine the number and location of wind turbines that may be installed, taking into account—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id79cf5b61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/ii/V/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location, size, and other physical characteristics of the land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79cf5b62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/ii/V/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the land contains threatened or endangered wildlife and wildlife habitat; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79cf5b63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/1/B/ii/V/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes of the conservation reserve program under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cf5b64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions on haying and grazing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cf5b65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may permit haying or grazing in accordance with paragraph (1) on any land or practice subject to a contract under the conservation reserve program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cf5b66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cf5b67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Damage to vegetative cover","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Haying or grazing described in paragraph (1) shall not be permitted on land subject to a contract under the conservation reserve program, or under a particular practice, if haying or grazing for that year under that practice, as applicable, would cause long-term damage to vegetative cover on that land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cf5b68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special agreements","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79cf5b69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subclause (II), haying or grazing described in paragraph (1) shall not be permitted on—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id79cf5b6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/2/B/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land covered by a contract enrolled under the State acres for wildlife enhancement program established by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79cf5b6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/2/B/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land covered by a contract enrolled under a conservation reserve enhancement program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831a"},"text":"section 3831a of this title","children":[],"tail":" or the Conservation Reserve Enhancement Program established by the Secretary under this subpart."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cf5b6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subclause (I) shall not apply to land on which haying or grazing is specifically permitted under the applicable conservation reserve enhancement program agreement or other partnership agreement entered into under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cf5b6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities on grasslands","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For eligible land described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831/b/3"},"text":"section 3831(b)(3) of this title","children":[],"tail":", the Secretary shall permit the following activities:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cf5b6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Common grazing practices, including maintenance and necessary cultural practices, on the land in a manner that is consistent with maintaining the viability of grassland, forb, and shrub species appropriate to that locality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cf5b6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Haying, mowing, or harvesting for seed production, subject to appropriate restrictions during the nesting season for birds in the local area that are economically significant, in significant decline, or conserved in accordance with Federal or State law, as determined by the Secretary in consultation with the State technical committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cf5b70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fire presuppression, fire-related rehabilitation, and construction of fire breaks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cf5b71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grazing-related activities, such as fencing and livestock watering.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cf5b72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resource conserving use","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cf5b73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on the date that is 1 year before the date of termination of a contract under the program, the Secretary shall allow an owner or operator to make conservation and land improvements for economic use that facilitate maintaining protection of enrolled land after expiration of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cf5b74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require an owner or operator carrying out the activities described in paragraph (1) to develop and implement a conservation plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cf5b75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Re-enrollment prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Land improved under paragraph (1) may not be re-enrolled in the conservation reserve program for 5 years after the date of termination of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cf5b76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an activity carried out under paragraph (1), the Secretary shall reduce the payment otherwise payable under the contract by an amount commensurate with the economic value of the activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cf5b77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3833/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural disaster or adverse weather as mid-contract management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a natural disaster or adverse weather event that has the effect of a management practice consistent with the conservation plan, the Secretary shall not require further management practices pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3832/a/5"},"text":"section 3832(a)(5) of this title","children":[],"tail":" that are intended to achieve the same effect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79cf5b78-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1233"},"text":"Pub. L. 99–198, title XII, § 1233","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tII/s2101/a"},"text":"Pub. L. 107–171, title II, § 2101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/245"},"text":"116 Stat. 245","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2004"},"text":"Pub. L. 113–79, title II, § 2004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/715"},"text":"128 Stat. 715","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2206"},"text":"Pub. L. 115–334, title II, § 2206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4543"},"text":"132 Stat. 4543","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79cf5b79-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79cf5b7a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79cf5b7b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3833, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1233"},"text":"Pub. L. 99–198, title XII, § 1233","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1511"},"text":"99 Stat. 1511","children":[],"tail":", related to duties of Secretary, prior to the general amendment of this subpart by "},{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79cf5b7c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2206/a/1"},"text":"Pub. L. 115–334, § 2206(a)(1)","children":[],"tail":", inserted “, including the cost of fencing and other water distribution practices, if applicable” after “in the public interest”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2206/a/2/A"},"text":"Pub. L. 115–334, § 2206(a)(2)(A)","children":[],"tail":", substituted “, in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3834/d"},"text":"section 3834(d) of this title","children":[],"tail":",” for “in an amount necessary to compensate” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2206/a/2/B"},"text":"Pub. L. 115–334, § 2206(a)(2)(B)","children":[],"tail":" inserted “, marginal pastureland,” after “cropland” and “or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2206/a/2/C"},"text":"Pub. L. 115–334, § 2206(a)(2)(C)","children":[],"tail":", (D), redesignated subpar. (C) as (B) and struck out former subpar. (B) which read as follows: “the retirement of any base history that the owner or operator agrees to retire permanently; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2206/b"},"text":"Pub. L. 115–334, § 2206(b)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which described certain activities or commercial uses that would be permitted on land subject to a contract under the conservation reserve program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2206/c"},"text":"Pub. L. 115–334, § 2206(c)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" amended section generally. Prior to amendment, section also related to duties of the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
