{"tag":"section","attrib":{"id":"id78922033-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760c"},"text":null,"children":[{"tag":"num","attrib":{"value":"760c"},"text":"§ 760c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies; authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated from time to time, out of any moneys in the Treasury not otherwise appropriated, such sums, not in excess of $250,000 per annum, as may be necessary to carry out the purposes and objectives of sections 760a to 760c of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78922034-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-25/ch782/s3"},"text":"Aug. 25, 1950, ch. 782, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/474"},"text":"64 Stat. 474","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
