{"tag":"section","attrib":{"id":"id7741f9da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"407aa"},"text":"§ 407aa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7741f9db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407aa/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7741f9dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407aa/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1987 was the bicentennial of the signing of the United States Constitution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7741f9dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407aa/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commemoration of the Constitution’s bicentennial included various events conducted by the Federal Commission on the Bicentennial of the United States Constitution, and State and local bicentennial commissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7741f9de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407aa/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bicentennial activities included important educational and instructional programs to heighten public awareness of the Constitution and the democratic process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7741f9df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407aa/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational programs for the Constitution should continue after the bicentennial to document its profound impact on the political, economic and social development of this Nation, and in order to recognize those Americans instrumental in the history of the Constitution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7741f9e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407aa/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" units of the National Park System preserve and interpret key historic sites that document the history of the origins, subsequent development, and effects of the United States Constitution on this Nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7741f9e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407aa/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is therefore the policy of the Congress to provide each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7741f9e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407aa/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the necessary resources to develop a national resource center to undertake, on an ongoing basis, educational programs on the Constitution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7741f9e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407aa/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exhibits of, and an archives for, programs on or related to the recent bicentennial of the United States Constitution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7741f9e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407aa/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interpretation of the United States Constitution at those units of the National Park System particularly relevant to its history.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7741f9e5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/433/s2"},"text":"Pub. L. 100–433, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-16"},"text":"Sept. 16, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1640"},"text":"102 Stat. 1640","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7741f9e6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7741f9e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7741f9e8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/433/s1"},"text":"Pub. L. 100–433, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-16"},"text":"Sept. 16, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1640"},"text":"102 Stat. 1640","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/433/s1"},"text":"“This Act [enacting this subchapter] may be cited as the ‘Constitution Heritage Act of 1988’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
