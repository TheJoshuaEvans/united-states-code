{"tag":"section","attrib":{"id":"id770fed96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s192b–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"192b–7"},"text":"§ 192b–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon consummation of the exchange the Secretary shall, by publishing notice in the Federal Register, revise the boundary of Rocky Mountain National Park so as to exclude from the park the land described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s192b–8"},"text":"section 192b–8 of this title","children":[],"tail":" as combined parcels A and B."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id770fed97-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/146/s2"},"text":"Pub. L. 87–146, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-17"},"text":"Aug. 17, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/383"},"text":"75 Stat. 383","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
