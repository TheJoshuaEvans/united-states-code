{"tag":"section","attrib":{"id":"id79f58193-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4725"},"text":null,"children":[{"tag":"num","attrib":{"value":"4725"},"text":"§ 4725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f58194-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency with environmental laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All actions taken by Federal agencies in implementing the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4722"},"text":"section 4722 of this title","children":[],"tail":" shall be consistent with all applicable Federal, State, and local environmental laws."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f58195-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of chapter","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f58196-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4725/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), nothing in this chapter shall affect the authority of any State or political subdivision thereof to adopt or enforce control measures for aquatic nuisance species, or diminish or affect the jurisdiction of any State over species of fish and wildlife.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f58197-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4725/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any discharge incidental to the normal operation of a vessel, including any discharge of ballast water (as those terms are defined in subsections (a) and (p)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1322"},"text":"section 1322 of title 33","children":[],"tail":"), shall be regulated in accordance with that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f58198-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4725/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Compliance with the control and eradication measures of any State or political subdivision thereof regarding aquatic nuisance species shall not relieve any person of the obligation to comply with the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f58199-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646/tI/s1205"},"text":"Pub. L. 101–646, title I, § 1205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4771"},"text":"104 Stat. 4771","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/h/1"},"text":"Pub. L. 104–332, § 2(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4091"},"text":"110 Stat. 4091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIX/s903/h/2"},"text":"Pub. L. 115–282, title IX, § 903(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4363"},"text":"132 Stat. 4363","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f5819a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f5819b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79f5819c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(1), was in the original “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646"},"text":"Pub. L. 101–646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4761"},"text":"104 Stat. 4761","children":[],"tail":", known as the Nonindigenous Aquatic Nuisance Prevention and Control Act of 1990, which is classified principally to this chapter. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4701"},"text":"section 4701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79f5819d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s903/h/2/C"},"text":"Pub. L. 115–282, § 903(h)(2)(C)","children":[],"tail":", designated first sentence as subsec. (a) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s903/h/2/B"},"text":"Pub. L. 115–282, § 903(h)(2)(B)","children":[],"tail":", (D), designated second sentence as subsec. (b)(1), inserted subsec. (b) and par. (1) headings, substituted “Except as provided in paragraph (2), nothing” for “Nothing”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s903/h/2/A"},"text":"Pub. L. 115–282, § 903(h)(2)(A)","children":[],"tail":", designated third sentence as subsec. (c) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332"},"text":"Pub. L. 104–332","children":[],"tail":" made technical amendment to "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/s1205"},"text":"Pub. L. 101–646, § 1205","children":[],"tail":", which enacted this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
