{"tag":"section","attrib":{"id":"id79f7cb62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4903"},"text":null,"children":[{"tag":"num","attrib":{"value":"4903"},"text":"§ 4903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cb63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4903/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Convention” means the Convention on International Trade in Endangered Species of Wild Fauna and Flora, as amended, signed in Washington on ","children":[{"tag":"date","attrib":{"date":"1973-03-03"},"text":"March 3, 1973","children":[],"tail":", and the Appendices thereto."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4903/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “exotic bird”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cb65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4903/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any live or dead member of the class Aves that is not indigenous to the 50 States or the District of Columbia, including any egg or offspring thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cb66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4903/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f7cb67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4903/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" domestic poultry, dead sport-hunted birds, dead museum specimens, dead scientific specimens, or products manufactured from such birds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f7cb68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4903/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" birds in the following families: Phasianidae, Numididae, Cracidae, Meleagrididae, Megapodiidae, Anatidae, Struthionidae, Rheidae, Dromaiinae, and Gruidae.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4903/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each of the terms “import” and “importation” means to land on, bring into, or introduce into, or attempt to land on, bring into, or introduce into, any place subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4903/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” means an individual, corporation, partnership, trust, association, or any other private entity; or any officer, employee, agent, department, or instrumentality of the Federal Government, of any State, municipality, or political subdivision of a State, or of any foreign government; any State, municipality, or political subdivision of a State; or any other entity subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4903/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “qualifying facility” means an exotic bird breeding facility that is included in a list published by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4906"},"text":"section 4906 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4903/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of the Interior or a designee of the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4903/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “species”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cb6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4903/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any species, any subspecies, or any distinct population segment of a species or subspecies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cb6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4903/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes hybrids of any species or subspecies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4903/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States” means the 50 States, the District of Columbia, the Commonwealth of Puerto Rico, American Samoa, the Virgin Islands, Guam, the Commonwealth of the Northern Mariana Islands, and the Trust Territory of the Pacific Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f7cb71-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tI/s104"},"text":"Pub. L. 102–440, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2225"},"text":"106 Stat. 2225","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f7cb72-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id79f7cb73-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79f7cb74-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
