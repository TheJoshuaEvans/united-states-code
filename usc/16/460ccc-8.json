{"tag":"section","attrib":{"id":"id77f4ce71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ccc–8"},"text":"§ 460ccc–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77f4ce72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within the conservation area designated by this subchapter, there is hereby reserved a quantity of water sufficient to fulfill the purposes for which the conservation area is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f4ce73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority date of reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The priority date of the water rights reserved in paragraph ","children":[{"tag":"ref","attrib":{"idref":"fn002363"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002363"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":" (a) shall be "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":", except that as related to rights associated with lands added to the conservation area after "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":", the priority date shall be the date of enactment of the Act adding such lands to the conservation area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f4ce74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall take all steps necessary to protect the water rights reserved by this section, including the filing of a claim for quantification of such rights in any appropriate water adjudication in the courts of the State of Nevada in which the United States is or may be joined and which is conducted in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s666"},"text":"section 666 of title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f4ce75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–8/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on previously secured rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal water rights reserved by this subchapter shall be in addition to any water rights which may have been previously secured by the United States for purposes other than for the conservation area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f4ce76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–8/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope and construction of rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal water rights reserved by this subchapter are specific to the conservation area designated by this subchapter. Nothing in this subchapter shall be construed as establishing a precedent with regard to any future designations, nor shall it constitute an interpretation of any other Act or any designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77f4ce77-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/621/s10"},"text":"Pub. L. 101–621, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3345"},"text":"104 Stat. 3345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/450/s2/c"},"text":"Pub. L. 103–450, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4766"},"text":"108 Stat. 4766","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77f4ce78-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77f4ce79-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77f4ce7a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/450"},"text":"Pub. L. 103–450","children":[],"tail":" inserted before period at end “, except that as related to rights associated with lands added to the conservation area after "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":", the priority date shall be the date of enactment of the Act adding such lands to the conservation area”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
