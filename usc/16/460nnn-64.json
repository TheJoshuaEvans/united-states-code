{"tag":"section","attrib":{"id":"id7800b64f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–64"},"text":null,"children":[{"tag":"num","attrib":{"value":"460nnn–64"},"text":"§ 460nnn–64.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of wilderness study areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7800b650-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–64/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn–92"},"text":"section 460nnn–92 of this title","children":[],"tail":", any wilderness study area, or portion of a wilderness study area, within the boundaries of the Cooperative Management and Protection Area, but not included in the Wilderness Area, shall remain a wilderness study area notwithstanding the enactment of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b651-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–64/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The wilderness study areas referred to in subsection (a) shall continue to be managed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1782/c"},"text":"section 1782(c) of title 43","children":[],"tail":" in a manner so as not to impair the suitability of the areas for preservation as wilderness."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b652-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–64/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of Basque Hills Wilderness Study Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The boundaries of the Basque Hills Wilderness Study Area are hereby expanded to include the Federal lands within sections 8, 16, 17, 21, 22, and 27 of township 36 south, range 31 east, Willamette Meridian. These lands shall be managed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1782/c"},"text":"section 1782(c) of title 43","children":[],"tail":" to protect and enhance the wilderness values of these lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7800b653-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399/tII/s204"},"text":"Pub. L. 106–399, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1667"},"text":"114 Stat. 1667","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7800b654-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7800b655-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7800b656-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399"},"text":"Pub. L. 106–399","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1655"},"text":"114 Stat. 1655","children":[],"tail":", known as the Steens Mountain Cooperative Management and Protection Act of 2000, which is classified generally to this subchapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn"},"text":"section 460nnn of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
