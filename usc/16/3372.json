{"tag":"section","attrib":{"id":"id79b76698-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372"},"text":null,"children":[{"tag":"num","attrib":{"value":"3372"},"text":"§ 3372.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b76699-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses other than marking offenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is unlawful for any person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b7669a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to import, export, transport, sell, receive, acquire, or purchase any fish or wildlife or plant taken, possessed, transported, or sold in violation of any law, treaty, or regulation of the United States or in violation of any Indian tribal law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b7669b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to import, export, transport, sell, receive, acquire, or purchase in interstate or foreign commerce—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b7669c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any fish or wildlife taken, possessed, transported, or sold in violation of any law or regulation of any State or in violation of any foreign law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b7669d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any plant—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79b7669e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" taken, possessed, transported, or sold in violation of any law or regulation of any State, or any foreign law, that protects plants or that regulates—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79b7669f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the theft of plants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79b766a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taking of plants from a park, forest reserve, or other officially protected area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79b766a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taking of plants from an officially designated area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79b766a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/2/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taking of plants without, or contrary to, required authorization;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b766a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taken, possessed, transported, or sold without the payment of appropriate royalties, taxes, or stumpage fees required for the plant by any law or regulation of any State or any foreign law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b766a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taken, possessed, transported, or sold in violation of any limitation under any law or regulation of any State, or under any foreign law, governing the export or transshipment of plants;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b766a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" within the special maritime and territorial jurisdiction of the United States (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s7"},"text":"section 7 of title 18","children":[],"tail":")—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b766a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to possess any fish or wildlife taken, possessed, transported, or sold in violation of any law or regulation of any State or in violation of any foreign law or Indian tribal law, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b766a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to possess any plant—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79b766a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" taken, possessed, transported, or sold in violation of any law or regulation of any State, or any foreign law, that protects plants or that regulates—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79b766a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the theft of plants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79b766aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taking of plants from a park, forest reserve, or other officially protected area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79b766ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/3/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taking of plants from an officially designated area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79b766ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/3/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taking of plants without, or contrary to, required authorization;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b766ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taken, possessed, transported, or sold without the payment of appropriate royalties, taxes, or stumpage fees required for the plant by any law or regulation of any State or any foreign law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b766ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taken, possessed, transported, or sold in violation of any limitation under any law or regulation of any State, or under any foreign law, governing the export or transshipment of plants; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b766af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to attempt to commit any act described in paragraphs (1) through (3) or subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b766b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marking offenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is unlawful for any person to import, export, or transport in interstate commerce any container or package containing any fish or wildlife unless the container or package has previously been plainly marked, labeled, or tagged in accordance with the regulations issued pursuant to paragraph (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3376/a"},"text":"section 3376(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b766b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale and purchase of guiding and outfitting services and invalid licenses and permits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b766b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is deemed to be a sale of fish or wildlife in violation of this chapter for a person for money or other consideration to offer or provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b766b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guiding, outfitting, or other services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b766b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a hunting or fishing license or permit;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for the illegal taking, acquiring, receiving, transporting, or possessing of fish or wildlife.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b766b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is deemed to be a purchase of fish or wildlife in violation of this chapter for a person to obtain for money or other consideration—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b766b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guiding, outfitting, or other services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b766b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a hunting or fishing license or permit;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for the illegal taking, acquiring, receiving, transporting, or possessing of fish or wildlife.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b766b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False labeling offenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is unlawful for any person to make or submit any false record, account, or label for, or any false identification of, any fish, wildlife, or plant which has been, or is intended to be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b766b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imported, exported, transported, sold, purchased, or received from any foreign country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b766ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transported in interstate or foreign commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b766bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Captive wildlife offense","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b766bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), it is unlawful for any person to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b766bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" import, export, transport, sell, receive, acquire, or purchase in interstate or foreign commerce, or in a manner substantially affecting interstate or foreign commerce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b766be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" breed or possess;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any prohibited wildlife species.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b766bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) does not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b766c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an entity exhibiting animals to the public under a Class C license from the Department of Agriculture, or a Federal facility registered with the Department of Agriculture that exhibits animals, if such entity or facility holds such license or registration in good standing and if the entity or facility—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79b766c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not allow any individual to come into direct physical contact with a prohibited wildlife species, unless that individual is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79b766c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trained professional employee or contractor of the entity or facility (or an accompanying employee receiving professional training);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79b766c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a licensed veterinarian (or a veterinary student accompanying such a veterinarian); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79b766c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" directly supporting conservation programs of the entity or facility, the contact is not in the course of commercial activity (which may be evidenced by advertisement or promotion of such activity or other relevant evidence), and the contact is incidental to humane husbandry conducted pursuant to a species-specific, publicly available, peer-edited population management and care plan that has been provided to the Secretary with justifications that the plan—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id79b766c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/A/i/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflects established conservation science principles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79b766c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/A/i/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporates genetic and demographic analysis of a multi-institution population of animals covered by the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79b766c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/A/i/III/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotes animal welfare by ensuring that the frequency of breeding is appropriate for the species; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b766c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that during public exhibition of a lion (Panthera leo), tiger (Panthera tigris), leopard (Panthera pardus), snow leopard (Uncia uncia), jaguar (Panthera onca), cougar (Puma concolor), or any hybrid thereof, the animal is at least 15 feet from members of the public unless there is a permanent barrier sufficient to prevent public contact;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b766c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State college, university, or agency, or a State-licensed veterinarian;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b766ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a wildlife sanctuary that cares for prohibited wildlife species, and—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79b766cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a corporation that is exempt from taxation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/a"},"text":"section 501(a) of title 26","children":[],"tail":" and described in sections 501(c)(3) and 170(b)(1)(A)(vi) of such title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b766cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not commercially trade in any prohibited wildlife species, including offspring, parts, and byproducts of such animals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b766cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not breed any prohibited wildlife species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b766ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not allow direct contact between the public and any prohibited wildlife species; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b766cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not allow the transportation and display of any prohibited wildlife species off-site;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b766d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has custody of any prohibited wildlife species solely for the purpose of expeditiously transporting the prohibited wildlife species to a person described in this paragraph with respect to the species; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b766d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an entity or individual that is in possession of any prohibited wildlife species that was born before ","children":[{"tag":"date","attrib":{"date":"2022-12-20"},"text":"December 20, 2022","children":[],"tail":", and—"}],"tail":null},{"tag":"clause","attrib":{"id":"id79b766d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-20"},"text":"December 20, 2022","children":[],"tail":", the entity or individual registers each individual animal of each prohibited wildlife species possessed by the entity or individual with the United States Fish and Wildlife Service;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b766d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not breed, acquire, or sell any prohibited wildlife species after ","children":[{"tag":"date","attrib":{"date":"2022-12-20"},"text":"December 20, 2022","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b766d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/e/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not allow direct contact between the public and prohibited wildlife species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b766d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plant declarations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b766d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Import declaration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective 180 days from the date of enactment of this subsection, and except as provided in paragraph (3), it shall be unlawful for any person to import any plant unless the person files upon importation a declaration that contains—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b766d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scientific name of any plant (including the genus and species of the plant) contained in the importation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b766d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79b766d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of the importation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b766da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity, including the unit of measure, of the plant; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b766db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the country from which the plant was taken.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b766dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration relating to plant products","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Until the date on which the Secretary promulgates a regulation under paragraph (6), a declaration relating to a plant product shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b766dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case in which the species of plant used to produce the plant product that is the subject of the importation varies, and the species used to produce the plant product is unknown, contain the name of each species of plant that may have been used to produce the plant product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b766de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case in which the species of plant used to produce the plant product that is the subject of the importation is commonly taken from more than one country, and the country from which the plant was taken and used to produce the plant product is unknown, contain the name of each country from which the plant may have been taken; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b766df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case in which a paper or paperboard plant product includes recycled plant product, contain the average percent recycled content without regard for the species or country of origin of the recycled plant product, in addition to the information for the non-recycled plant content otherwise required by this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b766e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (1) and (2) shall not apply to plants used exclusively as packaging material to support, protect, or carry another item, unless the packaging material itself is the item being imported.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b766e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than two years after the date of enactment of this subsection, the Secretary shall review the implementation of each requirement imposed by paragraphs (1) and (2) and the effect of the exclusion provided by paragraph (3). In conducting the review, the Secretary shall provide public notice and an opportunity for comment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b766e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date on which the Secretary completes the review under paragraph (4), the Secretary shall submit to the appropriate committees of Congress a report containing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b766e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an evaluation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79b766e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of each type of information required under paragraphs (1) and (2) in assisting enforcement of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b766e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential to harmonize each requirement imposed by paragraphs (1) and (2) with other applicable import regulations in existence as of the date of the report;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b766e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for such legislation as the Secretary determines to be appropriate to assist in the identification of plants that are imported into the United States in violation of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b766e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an analysis of the effect of subsection (a) and this subsection on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79b766e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of legal plant imports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b766e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent and methodology of illegal logging practices and trafficking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b766ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation of regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date on which the Secretary completes the review under paragraph (4), the Secretary may promulgate regulations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b766eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit the applicability of any requirement imposed by paragraph (2) to specific plant products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b766ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make any other necessary modification to any requirement imposed by paragraph (2), as determined by the Secretary based on the review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b766ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3372/f/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit the scope of the exclusion provided by paragraph (3), if the limitations in scope are warranted as a result of the review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b766ee-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/79/s3"},"text":"Pub. L. 97–79, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-16"},"text":"Nov. 16, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1074"},"text":"95 Stat. 1074","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/653/tI/s101"},"text":"Pub. L. 100–653, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-14"},"text":"Nov. 14, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3825"},"text":"102 Stat. 3825","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/191/s3/a"},"text":"Pub. L. 108–191, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2871"},"text":"117 Stat. 2871","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVIII/s8204/b"},"text":"Pub. L. 110–234, title VIII, § 8204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1292"},"text":"122 Stat. 1292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VIII, § 8204(b), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2053; "},{"tag":"ref","attrib":{"href":"/us/pl/117/243/s3"},"text":"Pub. L. 117–243, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2336"},"text":"136 Stat. 2336","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b766ef-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79b766f0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79b766f1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/79"},"text":"Pub. L. 97–79","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-16"},"text":"Nov. 16, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1073"},"text":"95 Stat. 1073","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3371"},"text":"section 3371 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this subsection, referred to in subsec. (f)(1), (4), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79b766f2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79b766f3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/243/s3/1/A"},"text":"Pub. L. 117–243, § 3(1)(A)","children":[],"tail":", struck out subpar. (C) which read as follows: “any prohibited wildlife species (subject to subsection (e));”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/243/s3/1/B"},"text":"Pub. L. 117–243, § 3(1)(B)","children":[],"tail":", substituted “(1) through (3) or subsection (e)” for “(1) through (3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/243/s3/2"},"text":"Pub. L. 117–243, § 3(2)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, subsec. (e) related to nonapplicability of prohibited wildlife species offense."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s8204/b/1/A"},"text":"Pub. L. 110–246, § 8204(b)(1)(A)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “any plant taken, possessed, transported, or sold in violation of any law or regulation of any State; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s8204/b/1/B"},"text":"Pub. L. 110–246, § 8204(b)(1)(B)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “to possess any plant taken, possessed, transported, or sold in violation of any law or regulation of any State; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s8204/b/2"},"text":"Pub. L. 110–246, § 8204(b)(2)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/191/s3/a/1/A"},"text":"Pub. L. 108–191, § 3(a)(1)(A)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/191/s3/a/1/B"},"text":"Pub. L. 108–191, § 3(a)(1)(B)","children":[],"tail":", inserted “or” after semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/191/s3/a/1/C"},"text":"Pub. L. 108–191, § 3(a)(1)(C)","children":[],"tail":", substituted “paragraphs (1) through (3)” for “paragraphs (1) through (4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/191/s3/a/2"},"text":"Pub. L. 108–191, § 3(a)(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/653/s101/1"},"text":"Pub. L. 100–653, § 101(1)","children":[],"tail":", substituted “taken, possessed, transported, or sold” for “taken or possessed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/653/s101/2"},"text":"Pub. L. 100–653, § 101(2)","children":[],"tail":", redesignated par. (5) as (4) and struck out former par. (4), which made it unlawful for any person having imported, exported, transported, sold, purchased, or received any fish or wildlife or plant imported from any foreign country or transported in interstate or foreign commerce, to make or submit any false record, account, label, or identification thereof."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/653/s101/3"},"text":"Pub. L. 100–653, § 101(3)","children":[],"tail":", added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79b766f4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79b766f5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79b766f6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/191/s3/b"},"text":"Pub. L. 108–191, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2872"},"text":"117 Stat. 2872","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/191/s3/b"},"text":"“Section 3(a)(2)(C) of the Lacey Act Amendments of 1981 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3372/a/2/C"},"text":"16 U.S.C. 3372(a)(2)(C)","children":[],"tail":"] (as added by subsection (a)(1)(A)(iii)) shall apply beginning on the effective date of regulations promulgated under section 3(e)(3) of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3372/e/3"},"text":"16 U.S.C. 3372(e)(3)","children":[],"tail":"] (as added by subsection (a)(2)) ["},{"tag":"date","attrib":{"date":"2007-09-17"},"text":"Sept. 17, 2007","children":[],"tail":", see 72 F.R. 45938].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
