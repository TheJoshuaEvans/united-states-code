{"tag":"section","attrib":{"id":"id7a0fbfb0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6516"},"text":null,"children":[{"tag":"num","attrib":{"value":"6516"},"text":"§ 6516.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review in United States district courts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0fbfb1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6516/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1391"},"text":"section 1391 of title 28","children":[],"tail":" or other applicable law, an authorized hazardous fuels reduction project conducted under this subchapter shall be subject to judicial review only in the United States district court for a district in which the Federal land to be treated under the authorized hazardous fuels reduction project is located."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fbfb2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6516/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expeditious completion of judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the judicial review of an action challenging an authorized hazardous fuel reduction project under subsection (a), Congress encourages a court of competent jurisdiction to expedite, to the maximum extent practicable, the proceedings in the action with the goal of rendering a final determination on jurisdiction, and (if jurisdiction exists) a final determination on the merits, as soon as practicable after the date on which a complaint or appeal is filed to initiate the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fbfb3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6516/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fbfb4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6516/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the length of any preliminary injunctive relief and stays pending appeal covering an authorized hazardous fuel reduction project carried out under this subchapter shall not exceed 60 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbfb5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6516/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fbfb6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6516/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A court of competent jurisdiction may issue 1 or more renewals of any preliminary injunction, or stay pending appeal, granted under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbfb7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6516/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In each renewal of an injunction in an action, the parties to the action shall present the court with updated information on the status of the authorized hazardous fuel reduction project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbfb8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6516/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Balancing of short- and long-term effects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of its weighing the equities while considering any request for an injunction that applies to an agency action under an authorized hazardous fuel reduction project, the court reviewing the project shall balance the impact to the ecosystem likely affected by the project of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fbfb9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6516/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the short- and long-term effects of undertaking the agency action; against","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbfba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6516/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the short- and long-term effects of not undertaking the agency action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0fbfbb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tI/s106"},"text":"Pub. L. 108–148, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1900"},"text":"117 Stat. 1900","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
