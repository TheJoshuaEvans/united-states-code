{"tag":"section","attrib":{"id":"id77a1583f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ff–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"450ff–3"},"text":"§ 450ff–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of preserving certain historic properties associated with the Fort Vancouver National Historic Site, established pursuant to sections 450ff to 450ff–2 of this title, the Secretary of the Interior may revise the boundaries of the historic site to include therein not more than one hundred and thirty additional acres of land adjacent to, contiguous to, or in the vicinity of, the existing historic site.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a15840-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/78/s1"},"text":"Pub. L. 87–78, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-06-30"},"text":"June 30, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/196"},"text":"75 Stat. 196","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77a15841-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77a15842-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77a15843-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“National Historic Site” and “historic site” substituted in text for “National Monument” and “monument”, respectively, in view of redesignation of Fort Vancouver National Monument as Fort Vancouver National Historic Site by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/78"},"text":"Pub. L. 87–78","children":[],"tail":", classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s450ff–6"},"text":"section 450ff–6 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
