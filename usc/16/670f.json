{"tag":"section","attrib":{"id":"id7870b626-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s670f"},"text":null,"children":[{"tag":"num","attrib":{"value":"670f"},"text":"§ 670f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations and expenditures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7870b627-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s670f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures of collected funds under integrated natural resources management plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall expend such funds as may be collected in accordance with the integrated natural resources management plans agreed to under sections 670a and 670b of this title and cooperative agreements agreed to under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s670c–1"},"text":"section 670c–1 of this title","children":[],"tail":" and for no other purpose. All funds that are so collected shall remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7870b628-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s670f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations to Secretary of Defense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts authorized to be appropriated to the Department of Defense, there are authorized to be appropriated to the Secretary of Defense not to exceed $1,500,000 for each of the fiscal years 2014 through 2019, to carry out this subchapter, including the enhancement of fish and wildlife habitat and the development of public recreation and other facilities, and to carry out such functions and responsibilities as the Secretary may have under cooperative agreements entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s670c–1"},"text":"section 670c–1 of this title","children":[],"tail":". The Secretary of Defense shall, to the greatest extent practicable, enter into agreements to utilize the services, personnel, equipment, and facilities, with or without reimbursement, of the Secretary of the Interior in carrying out the provisions of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7870b629-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s670f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations to Secretary of the Interior","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts authorized to be appropriated to the Department of the Interior, there are authorized to be appropriated to the Secretary of the Interior not to exceed $3,000,000 for each of the fiscal years 2014 through 2019, to carry out such functions and responsibilities as the Secretary may have under integrated natural resources management plans to which such Secretary is a party under this section, including those for the enhancement of fish and wildlife habitat and the development of public recreation and other facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7870b62a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s670f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of other conservation or rehabilitation authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense and the Secretary of the Interior may each use any authority available to him under other laws relating to fish, wildlife, or plant conservation or rehabilitation for purposes of carrying out the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7870b62b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/797/tI/s108"},"text":"Pub. L. 86–797, title I, § 108","children":[],"tail":", formerly § 6, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/465/s2"},"text":"Pub. L. 90–465, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-08"},"text":"Aug. 8, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/661"},"text":"82 Stat. 661","children":[],"tail":"; renumbered title I, § 106, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/452"},"text":"Pub. L. 93–452","children":[],"tail":", §§ 1(2), 3(1), (4), (5), "},{"tag":"date","attrib":{"date":"1974-10-18"},"text":"Oct. 18, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1369"},"text":"88 Stat. 1369","children":[],"tail":", 1375; "},{"tag":"ref","attrib":{"href":"/us/pl/95/420/s2"},"text":"Pub. L. 95–420, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-05"},"text":"Oct. 5, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/921"},"text":"92 Stat. 921","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/396/s2"},"text":"Pub. L. 97–396, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-31"},"text":"Dec. 31, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2005"},"text":"96 Stat. 2005","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/561"},"text":"Pub. L. 99–561","children":[],"tail":", §§ 1(a), 3(b), "},{"tag":"date","attrib":{"date":