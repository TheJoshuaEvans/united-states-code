f":"/us/pl/112/81/s312/b/6"},"text":"Pub. L. 112–81, § 312(b)(6)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1091/c/1"},"text":"Pub. L. 113–66, § 1091(c)(1)","children":[],"tail":", inserted section catchline and headings for subsecs. (a) to (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s312/a"},"text":"Pub. L. 111–84, § 312(a)","children":[],"tail":", (b)(1), substituted “Of the amounts authorized to be appropriated to the Department of Defense, there are authorized” for “There are authorized” and “fiscal years 2009 through 2014” for “fiscal years 2004 through 2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s312/a"},"text":"Pub. L. 111–84, § 312(a)","children":[],"tail":", (b)(2), substituted “Of the amounts authorized to be appropriated to the Department of the Interior, there are authorized” for “There are authorized” and “fiscal years 2009 through 2014” for “fiscal years 2004 through 2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “fiscal years 2004 through 2008” for “fiscal years 1998 through 2003”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s2904/b/7"},"text":"Pub. L. 105–85, § 2904(b)(7)","children":[],"tail":", substituted “integrated natural resources management plans” for “cooperative plans”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s2914/a"},"text":"Pub. L. 105–85, § 2914(a)","children":[],"tail":", substituted “1998 through 2003,” for “1983, 1984, 1985, 1986, 1987, 1988, 1989, 1990, 1991, 1992, and 1993,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s2914/a"},"text":"Pub. L. 105–85, § 2914(a)","children":[],"tail":", substituted “1998 through 2003,” for “1983, 1984, 1985, 1986, 1987, 1988, 1989, 1990, 1991, 1992, and 1993,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s2904/b/8"},"text":"Pub. L. 105–85, § 2904(b)(8)","children":[],"tail":", substituted “integrated natural resources management plans” for “cooperative plans”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s2845/b/1"},"text":"Pub. L. 101–189, § 2845(b)(1)","children":[],"tail":", inserted “and cooperative agreements agreed to under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s670c–1"},"text":"section 670c–1 of this title","children":[],"tail":"” after “sections 670a and 670b of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s2845/b/2"},"text":"Pub. L. 101–189, § 2845(b)(2)","children":[],"tail":", inserted “, and to carry out such functions and responsibilities as the Secretary may have under cooperative agreements entered into under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s670c–1"},"text":"section 670c–1 of this title","children":[],"tail":"” before period at end of first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/653"},"text":"Pub. L. 100–653","children":[],"tail":" substituted “1988, 1989, 1990, 1991, 1992, and 1993” for “and 1988”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/561/s3/b"},"text":"Pub. L. 99–561, § 3(b)","children":[],"tail":", inserted provision that all funds collected remain available until expended."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/561/s1/a"},"text":"Pub. L. 99–561, § 1(a)","children":[],"tail":", substituted “1985, 1986, 1987, and 1988” for “and 1985”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/396/s2/1"},"text":"Pub. L. 97–396, § 2(1)","children":[],"tail":", substituted “1983, 1984, and 1985,” for “ending "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":",” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/396/s2/2"},"text":"Pub. L. 97–396, § 2(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/420"},"text":"Pub. L. 95–420","children":[],"tail":" substituted provisions authorizing the appropriation of not to exceed $1,500,000 for each of the fiscal years ending "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"Sept. 30, 1979","children":[],"tail":", 1980 and 1981 for provisions authorizing the appropriation of not to exceed $500,000 per fiscal year for fiscal years beginning "},{"tag":"date","attrib":{"date":"1969-07-01"},"text":"July 1, 1969","children":[],"tail":", 1970, and 1971 and not to exceed $1,500,000 for fiscal year beginning "},{"tag":"date","attrib":{"date":"1972-07-01"},"text":"July 1, 1972","children":[],"tail":" and for each of the next five fiscal years thereafter and struck out provisions relating to the authorization of appropriations to the Secretary of the Interior not to exceed $2,000,000 for the fiscal year beginning "},{"tag":"date","attrib":{"date":"1973-07-01"},"text":"July 1, 1973","children":[],"tail":" and for each of the next four fiscal years thereafter to enable the Secretary to carry out the functions and responsibilities under cooperative plans, sums appropriated under this subchapter to be available until expended."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/420"},"text":"Pub. L. 95–420","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/452/s3/5"},"text":"Pub. L. 93–452, § 3(5)","children":[],"tail":", substituted “sections 101 and 102” for “sections 1 and 2” which for purposes of codification was translated as “sections 670a and 670b”, therefore requiring no change in text because of redesignation of former sections 1 and 2 of "},{"tag":"ref","attrib":{"href":"/us/pl/86/797"},"text":"Pub. L. 86–797","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/93/452/s3/1"},"text":"section 3(1) of Pub. L. 93–452","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/452"},"text":"Pub. L. 93–452","children":[],"tail":", §§ 1(2), 3(4), inserted provisions authorizing appropriations of not to exceed $1,500,000 for the fiscal year beginning "},{"tag":"date","attrib":{"date":"1972-07-01"},"text":"July 1, 1972","children":[],"tail":", and for each of the next five fiscal years thereafter, and authorizing appropriations to the Secretary of the Interior not to exceed $2,000,000 for the fiscal year beginning "},{"tag":"date","attrib":{"date":"1973-07-01"},"text":"July 1, 1973","children":[],"tail":", and for each of the next four fiscal years thereafter, and substituted “title” for “Act” wherever appearing, which for purposes of codification was translated as “subchapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7870b62f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7870b630-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tX/s1091/c"},"text":"Pub. L. 113–66, div. A, title X, § 1091(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/876"},"text":"127 Stat. 876","children":[],"tail":", provided in part that the amendment by section 1091(c)(1) is effective as of "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
