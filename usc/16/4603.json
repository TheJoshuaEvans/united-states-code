{"tag":"section","attrib":{"id":"id79f09f14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4603"},"text":null,"children":[{"tag":"num","attrib":{"value":"4603"},"text":"§ 4603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall provide such facilities, administrative services, personnel, and support to the TPIA Program as the Secretary determines is necessary and appropriate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79f09f15-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/628/tXI/s1104"},"text":"Pub. L. 101–628, title XI, § 1104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4502"},"text":"104 Stat. 4502","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
