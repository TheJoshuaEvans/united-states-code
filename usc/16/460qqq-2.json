{"tag":"section","attrib":{"id":"id7805706c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"460qqq–2"},"text":"§ 460qqq–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7805706d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460qqq"},"text":"section 460qqq of this title","children":[],"tail":", there is established in the State a conservation area to be known as the Sloan Canyon National Conservation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7805706e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Conservation Area shall consist of approximately 57,728 acres of public land in the County, as generally depicted on the map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7805706f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map and legal description","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78057070-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2002-11-06"},"text":"November 6, 2002","children":[],"tail":", the Secretary shall submit to Congress a map and legal description of the Conservation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78057071-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description shall have the same force and effect as if included in this section, except that the Secretary may correct minor errors in the map or legal description.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78057072-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A copy of the map and legal description shall be on file and available for public inspection in the appropriate office of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78057073-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/282/tVI/s604"},"text":"Pub. L. 107–282, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-06"},"text":"Nov. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2010"},"text":"116 Stat. 2010","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/91/s3/a/2"},"text":"Pub. L. 119–91, § 3(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-05-19"},"text":"May 19, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/822"},"text":"140 Stat. 822","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78057074-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78057075-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78057076-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2026—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/91"},"text":"Pub. L. 119–91","children":[],"tail":" substituted “57,728” for “48,438”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
