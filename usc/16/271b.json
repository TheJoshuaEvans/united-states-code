{"tag":"section","attrib":{"id":"id77230085-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s271b"},"text":null,"children":[{"tag":"num","attrib":{"value":"271b"},"text":"§ 271b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing privileges; right of occupancy or use for fixed term of years; renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where any Federal lands included within the Canyonlands National Park are legally occupied or utilized on the date of approval of this Act or any amendment thereto for grazing purposes, pursuant to a lease, permit, or license for a fixed term of years issued or authorized by any department, establishment, or agency of the United States, the Secretary of the Interior shall permit the persons holding such grazing privileges to continue in the exercise thereof during the term of the lease, permit, or license, and one period of renewal thereafter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77230086-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/590/s3"},"text":"Pub. L. 88–590, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-12"},"text":"Sept. 12, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/938"},"text":"78 Stat. 938","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/154/s1/c"},"text":"Pub. L. 92–154, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-11-12"},"text":"Nov. 12, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/421"},"text":"85 Stat. 421","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77230087-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77230088-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77230089-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Date of approval of this Act or any amendment thereto, referred to in text, means ","children":[{"tag":"date","attrib":{"date":"1964-09-12"},"text":"Sept. 12, 1964","children":[],"tail":", date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/88/590"},"text":"Pub. L. 88–590","children":[],"tail":", originally classified to sections 271 to 271d of this title, and "},{"tag":"date","attrib":{"date":"1971-11-12"},"text":"Nov. 12, 1971","children":[],"tail":", date of approval of "},{"tag":"ref","attrib":{"href":"/us/pl/92/154"},"text":"Pub. L. 92–154","children":[],"tail":", amendatory of "},{"tag":"ref","attrib":{"href":"/us/pl/88/590"},"text":"Pub. L. 88–590","children":[],"tail":" and classified to sections 271 to 271b, 271e to 271g of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7723008a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1971—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/154"},"text":"Pub. L. 92–154","children":[],"tail":" inserted “or any amendment thereto” after “date of approval of this Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
