{"tag":"section","attrib":{"id":"id7760f411-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ww–7"},"text":"§ 410ww–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7760f412-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical and preservation assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide to any owner of property within the park, and to any organization having an agreement with the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ww–1/b"},"text":"section 410ww–1(b) of this title","children":[],"tail":", such technical assistance as the Secretary considers appropriate to carry out the purposes of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f413-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make grants to the parks’ partners, including the Aviation Trail, Inc., the Ohio Historical Society, and Dayton History, for projects not requiring Federal involvement other than providing financial assistance, subject to the availability of appropriations in advance identifying the specific partner grantee and the specific project. Projects funded through these grants shall be limited to construction and development on non-Federal property within the boundaries of the park. Any project funded by such a grant shall support the purposes of the park, shall be consistent with the park’s general management plan, and shall enhance public use and enjoyment of the park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f414-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpretative materials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to publish interpretative materials for historic aviation resources in the Miami Valley.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7760f415-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/419/tI/s108"},"text":"Pub. L. 102–419, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2143"},"text":"106 Stat. 2143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7117/c"},"text":"Pub. L. 111–11, title VII, § 7117(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1204"},"text":"123 Stat. 1204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7760f416-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7760f417-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7760f418-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":" added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
