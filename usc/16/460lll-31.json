{"tag":"section","attrib":{"id":"id77fbfb4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–31"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–31"},"text":"§ 460lll–31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fbfb4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–31/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a special interest-bearing fund known as the “Land Between the Lakes Trust Fund”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–31/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts in the Fund shall be available to the Secretary, until expended, for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfb4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–31/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public education, grants, and internships related to recreation, conservation, and multiple use land management in the Recreation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–31/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional promotion in the Recreation Area, in cooperation with development districts, chambers of commerce, and State and local governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–31/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Tennessee Valley Authority shall deposit into the Fund $1,000,000 annually for each of the 5 fiscal years commencing in the first fiscal year of the transfer. Funding to carry out this section shall be derived from funding described in section 460","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–49 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fbfb51-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s531"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 531]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–317.)"}],"tail":"\n"}],"tail":null}
