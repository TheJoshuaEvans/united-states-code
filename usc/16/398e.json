{"tag":"section","attrib":{"id":"id77385d0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s398e"},"text":null,"children":[{"tag":"num","attrib":{"value":"398e"},"text":"§ 398e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bathing and fishing rights protected","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77385d0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s398e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in sections 398c to 398f of this title shall be construed as authorizing any limitation on customary uses of or access to the areas specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s398c"},"text":"section 398c of this title","children":[],"tail":" for bathing and fishing (including setting out of fishpots and landing boats), subject to such regulations as the Secretary of the Interior may find reasonable and necessary for protection of natural conditions and prevention of damage to marine life and formations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77385d0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s398e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admission fee prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any provision of law to the contrary, no fee or charge shall be imposed for entrance or admission into the Virgin Islands National Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77385d0d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/750/s3"},"text":"Pub. L. 87–750, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-05"},"text":"Oct. 5, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/747"},"text":"76 Stat. 747","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/348/s7/b/4"},"text":"Pub. L. 95–348, § 7(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-18"},"text":"Aug. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/495"},"text":"92 Stat. 495","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77385d0e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77385d0f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77385d10-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/348"},"text":"Pub. L. 95–348","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
