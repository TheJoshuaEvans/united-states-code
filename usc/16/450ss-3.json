{"tag":"section","attrib":{"id":"id77a61375-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ss–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"450ss–3"},"text":"§ 450ss–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of Memorial property, rights, authorities, and duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77a61376-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ss–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of Memorial property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77a61377-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ss–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2004-01-23"},"text":"January 23, 2004","children":[],"tail":", the Trust shall transfer to the Foundation—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77a61378-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ss–3/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all assets of the Trust, including all real and personal property of the Memorial, any appurtenances, buildings, facilities, monuments, contents, artifacts, contracts and contract rights, accounts, deposits, intangibles, trademarks, trade names, copyrights, all other intellectual property, all other real and personal property of every kind and character comprising the Memorial, and any amounts appropriated for the Trust;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77a61379-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ss–3/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property owned by the Trust that is adjacent or related to the Memorial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77a6137a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ss–3/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all property maintained for the Memorial, together with all rights, authorities, and duties relating to the ownership, administration, operation, and management of the Memorial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a6137b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ss–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent gifts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any artifact, memorial, or other personal property that is received by, or is intended by any person to be given to, the Trust after the date of transfer of property under paragraph (1) shall be the property of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a6137c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ss–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assumption of Trust obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any obligations of the Trust relating to the Memorial that have been approved by the Trust before the date on which the property is transferred under subsection (a) shall become the responsibility of the Foundation on the date of the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a6137d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ss–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissolution of Trust","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the transfer under subsection (a) is completed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77a6137e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ss–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Trust shall be dissolved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a6137f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ss–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Trust shall notify the Secretary of the date of dissolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a61380-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ss–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to enter into agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the National Park Service, is authorized to enter into 1 or more cooperative agreements with the Foundation for the National Park Service to provide interpretive services related to the Memorial and such other assistance as may be agreed upon between the Secretary and the Foundation. The costs of the services and other agreed assistance shall be paid by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a61381-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ss–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General Services Administration authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of General Services shall provide, on a non-reimbursable basis, services necessary for the facilitation of the transfer of the Memorial to the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a88382-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ss–3/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in sections 450ss to 450ss–7 of this title shall prohibit the use of State and local law enforcement for the purposes of security related to the Memorial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77a88383-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/58/s5"},"text":"Pub. L. 105–58, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-09"},"text":"Oct. 9, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1262"},"text":"111 Stat. 1262","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/199/dF/tV/s544/d"},"text":"Pub. L. 108–199, div. F, title V, § 544(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/347"},"text":"118 Stat. 347","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77a88384-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77a88385-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77a88386-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199"},"text":"Pub. L. 108–199","children":[],"tail":" amended section generally. Prior to amendment, section provided for establishment of the Oklahoma City National Memorial Trust, its Board of Directors, staff, powers, and tax exempt status."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77a88387-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77a88388-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Secretary To Reimburse Previous Costs Paid by Foundation or Trust","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dF/tV/s544/g"},"text":"Pub. L. 108–199, div. F, title V, § 544(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/348"},"text":"118 Stat. 348","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/199/dF/tV/s544/g"},"text":"“To the extent that funds are made available for the Trust, the Secretary of the Interior shall reimburse the Oklahoma City National Memorial Foundation for funds obligated or expended by the Oklahoma City National Memorial Foundation or the Oklahoma City National Memorial Trust to the Secretary of the Interior for interpretive services, security, and other costs and services related to the Oklahoma City National Memorial before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":"]. The Oklahoma City National Memorial Foundation may use such reimbursed funds for the operation, maintenance, and permanent endowment of the Oklahoma City National Memorial.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
