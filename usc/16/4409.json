{"tag":"section","attrib":{"id":"id79f09e50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4409"},"text":null,"children":[{"tag":"num","attrib":{"value":"4409"},"text":"§ 4409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall report to the appropriate Committees on the implementation of this chapter. The report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f09e51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4409/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a biennial assessment of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f09e52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4409/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated number of acres of wetlands and habitat for waterfowl and other migratory birds that were restored, protected, or enhanced during such two-year period by Federal, State, and local agencies and other entities in the United States, Canada, and Mexico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09e53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4409/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trends in the population size and distribution of North American migratory birds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09e54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4409/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of efforts to establish agreements with nations in the Western Hemisphere pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4413"},"text":"section 4413 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09e55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4409/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wetlands conservation projects funded under this chapter, listed and identified by type, conservation mechanism (such as acquisition, easement, or lease), location, and duration; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09e56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4409/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual assessment of the status of wetlands conservation projects, including an accounting of expenditures by Federal, State, and other United States entities, and expenditures by Canadian and Mexican sources to carry out these projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f09e57-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/233/s10"},"text":"Pub. L. 101–233, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-13"},"text":"Dec. 13, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1976"},"text":"103 Stat. 1976","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/375/s2/b"},"text":"Pub. L. 103–375, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-19"},"text":"Oct. 19, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3494"},"text":"108 Stat. 3494","children":[],"tail":"; "},{"tag":"ref","attri