{"tag":"section","attrib":{"id":"id79369e30-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1447d"},"text":"§ 1447d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79369e31-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the National Oceanic and Atmospheric Administration shall administer a grant program to support the administrative functions of each Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369e32-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79369e33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each Board may annually submit a grant application to the Administrator of the National Oceanic and Atmospheric Administration to fund projects aimed at achieving the research priorities set forth in each research plan, including amendments thereto, developed and approved pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1447c"},"text":"section 1447c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Projects eligible for funding under this section shall include research, investigations, studies, surveys, or demonstrations with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79369e35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" baseline assessment of marine environmental quality, including chemical, physical, and biological indicators of environmental quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effects or potential effects of contaminants, including nutrients, toxic chemicals and heavy metals, on the environment, including marine and aquatic organisms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effects of modification of habitats, including coastal wetlands, seagrass beds and reefs, on the environment, including marine organisms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessment of impacts of pollutant sources and pollutant discharges into the coastal environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transport, dispersion, transformation, and fate and effect of contaminants in the marine environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e3a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine and estuarine habitat assessment and restoration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e3b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods and techniques for modeling environmental quality conditions and trends;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e3c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods and techniques for sampling of water, sediment, marine and aquatic organisms, and demonstration of such methods and techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e3d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects on human health and the environment of contaminants or combinations of contaminants at various levels, whether natural or anthropogenic, that are found in the marine environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental assessment of potential effects of major coastal and offshore development projects in the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessment of the effects of climate change on marine resources in the region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analysis and interpretation of research data for the benefit of State and local environmental protection and resource management agencies in the region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Grant applications submitted pursuant to this subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79369e42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the specific research projects to be conducted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of the organization responsible for each project and the principal investigator directing the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a budget statement for each project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a schedule of milestones and interim products for each research project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e46-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the relationship of the proposed project to the goals, objectives, and priorities of the research plan for the region and to other research projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information which may be required by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369e48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and approval of project proposals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79369e49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the National Oceanic and Atmospheric Administration shall review the annual grant application and, with the concurrence of the Administrator of the Environmental Protection Agency, approve such grant application with such conditions as are determined to be appropriate based on peer reviews conducted pursuant to paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the National Oceanic and Atmospheric Administration shall develop a system of peer review of grant applications which shall ensure that only the highest quality research is approved for funding and that each project is reviewed by research scientists outside the region concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369e4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any recipient of a grant under this section shall report to the appropriate Board, not later than 18 months after award of the grant, on the activities of such recipient conducted pursuant to this subsection. Such report shall include narrative summaries and technical data in such form as the Administrator of the National Oceanic and Atmospheric Administration may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79369e4c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tIV/s405"},"text":"Pub. L. 92–532, title IV, § 405","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/593/tIII/s301"},"text":"Pub. L. 101–593, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2967"},"text":"104 Stat. 2967","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
