{"tag":"section","attrib":{"id":"id78ecc31a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1154"},"text":null,"children":[{"tag":"num","attrib":{"value":"1154"},"text":"§ 1154.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific research on fur seal resources; use of fur seals for educational, scientific, or exhibition purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall (1) conduct such scientific research and investigations on the fur seal resources of the North Pacific Ocean as he deems necessary to carry out the obligations of the United States under the Convention, and (2) permit, subject to such terms and conditions as he deems desirable, the taking, transportation, importation, exportation, or possession of fur seals or their parts for educational, scientific, or exhibition purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78ecc31b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/702/tI/s104"},"text":"Pub. L. 89–702, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1091"},"text":"80 Stat. 1091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/129/s2"},"text":"Pub. L. 98–129, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-10-14"},"text":"Oct. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/836"},"text":"97 Stat. 836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78ecc31c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78ecc31d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78ecc31e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/129"},"text":"Pub. L. 98–129","children":[],"tail":" amended section generally, substituting provisions authorizing scientific research on fur seal resources, which were previously contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1153"},"text":"section 1153 of this title","children":[],"tail":", for provisions delineating the authority of the Secretary of Commerce. See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1155"},"text":"section 1155 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
