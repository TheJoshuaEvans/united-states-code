{"tag":"section","attrib":{"id":"id7a0fc00a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543"},"text":null,"children":[{"tag":"num","attrib":{"value":"6543"},"text":"§ 6543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Watershed Condition Framework","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0fc00b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture, acting through the Chief of the Forest Service (referred to in this section as the “Secretary”), may establish and maintain a Watershed Condition Framework for National Forest System land—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fc00c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to evaluate and classify the condition of watersheds, taking into consideration—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fc00d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water quality and quantity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc00e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aquatic habitat and biota;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc00f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" riparian and wetland vegetation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc010-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the presence of roads and trails;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc011-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soil type and condition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc012-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" groundwater-dependent ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc013-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant terrestrial indicators, such as fire regime, risk of catastrophic fire, forest and rangeland vegetation, invasive species, and insects and disease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc014-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other significant factors, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc015-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to identify for protection and restoration up to 5 priority watersheds in each National Forest, and up to 2 priority watersheds in each national grassland, taking into consideration the impact of the condition of the watershed condition on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fc016-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wildfire behavior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc017-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flood risk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc018-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fish and wildlife;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc019-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drinking water supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc01a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" irrigation water supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc01b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forest-dependent communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc01c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other significant impacts, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc01d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to develop a watershed protection and restoration action plan for each priority watershed that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fc01e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes into account existing restoration activities being implemented in the watershed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc01f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes, at a minimum—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a0fc020-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the major stressors responsible for the impaired condition of the watershed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0fc021-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a set of essential projects that, once completed, will address the identified stressors and improve watershed conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0fc022-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proposed implementation schedule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0fc023-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential partners and funding sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0fc024-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a monitoring and evaluation program;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc025-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prioritize protection and restoration activities for each watershed restoration action plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc026-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement each watershed protection and restoration action plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc027-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to monitor the effectiveness of protection and restoration actions and indicators of watershed health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fc028-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fc029-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with interested non-Federal landowners and State, Tribal, and local governments within the relevant watershed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc02a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for an active and ongoing public engagement process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fc02b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (2) of subsection (a), the Secretary may identify a watershed as a priority for rehabilitation in the Watershed Condition Framework without using the process described in that subsection if a Forest Supervisor determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fc02c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a wildfire has significantly diminished the condition of the watershed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc02d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6543/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the emergency stabilization activities of the Burned Area Emergency Response Team are insufficient to return the watershed to proper function.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0fc02e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tIII/s304"},"text":"Pub. L. 108–148, title III, § 304","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8405/a"},"text":"Pub. L. 115–334, title VIII, § 8405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4843"},"text":"132 Stat. 4843","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
