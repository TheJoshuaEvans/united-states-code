{"tag":"section","attrib":{"id":"id78922001-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760"},"text":null,"children":[{"tag":"num","attrib":{"value":"760"},"text":"§ 760.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of rearing ponds and fish hatchery in Kentucky","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to construct, equip, maintain, and operate rearing ponds and a fish hatchery at a suitable location in Kentucky.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78922002-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-07-18/ch465/s1"},"text":"July 18, 1950, ch. 465, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/343"},"text":"64 Stat. 343","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
