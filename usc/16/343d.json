{"tag":"section","attrib":{"id":"id772c760e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s343d"},"text":null,"children":[{"tag":"num","attrib":{"value":"343d"},"text":"§ 343d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of lands; disposal as surplus property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The tract of land in Acadia National Park, State of Maine, comprising approximately three hundred acres and identified as the “Green Lake Fish Hatchery Tract” is excluded from Acadia National Park, and the said tract is authorized to be disposed of in accordance with the laws relating to the disposition of Federal property.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id772c760f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-07-24/ch667"},"text":"July 24, 1956, ch. 667","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/597"},"text":"70 Stat. 597","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id772c7610-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id772c7611-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id772c7612-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For laws relating to the disposition of Federal property, referred to in text, see, generally, subtitle I of Title 40, Public Buildings, Property, and Works.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
