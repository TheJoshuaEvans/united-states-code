{"tag":"section","attrib":{"id":"id772c763e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s346d"},"text":null,"children":[{"tag":"num","attrib":{"value":"346d"},"text":"§ 346d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All funds heretofore made available for purposes of Zion National Park and Zion National Monument may be used for purposes of Zion National Park as established by sections 346b to 346d of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id772c763f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-07-11/ch568/s3"},"text":"July 11, 1956, ch. 568, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/527"},"text":"70 Stat. 527","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
