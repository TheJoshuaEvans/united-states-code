{"tag":"section","attrib":{"id":"id7845d5c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s563"},"text":null,"children":[{"tag":"num","attrib":{"value":"563"},"text":"§ 563.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with States for fire protection on private or State forest lands upon the watersheds of navigable rivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized, and on such conditions as he deems wise, to stipulate and agree with any State or group of States to cooperate in the organization and maintenance of a system of fire protection on any private or State forest lands within such State or States and situated upon the watershed of a navigable river. No such stipulation or agreement shall be made with any State which has not provided by law for a system of forest-fire protection. In no case shall the amount expended in any State exceed in any fiscal year the amount appropriated by that State for the same purpose during the same fiscal year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7845d5c7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-01/ch186/s2"},"text":"Mar. 1, 1911, ch. 186, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/961"},"text":"36 Stat. 961","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7845d5c8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7845d5c9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7845d5ca-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Fiscal Year Transition Period of ","children":[{"tag":"date","attrib":{"date":"1976-07-01"},"text":"July 1, 1976","children":[],"tail":", Through "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"September 30, 1976","children":[],"tail":", Deemed Fiscal Year for Purposes of Matching Requirements"}],"tail":null},{"tag":"p","attrib":{},"text":"Fiscal year transition period of ","children":[{"tag":"date","attrib":{"date":"1976-07-01"},"text":"July 1, 1976","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", deemed fiscal year for purposes of this section relating to matching requirements, see "},{"tag":"ref","attrib":{"href":"/us/pl/94/274/s202/1"},"text":"section 202(1) of Pub. L. 94–274","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-21"},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/390"},"text":"90 Stat. 390","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2652"},"text":"section 2652 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
