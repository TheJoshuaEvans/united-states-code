{"tag":"section","attrib":{"id":"id772c7674-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s353"},"text":null,"children":[{"tag":"num","attrib":{"value":"353"},"text":"§ 353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior may, in his discretion, execute leases to parcels of ground not exceeding twenty acres in extent for periods not to exceed twenty years whenever such ground is necessary for the erection of establishments for the accommodation of visitors; may grant such other necessary privileges and concessions as he deems wise for the accommodation of visitors; and may likewise arrange for the removal of such mature or dead or down timber as he may deem necessary and advisable for the protection and improvement of the park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id772c7675-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-02-26/ch121/s7"},"text":"Feb. 26, 1917, ch. 121, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/939"},"text":"39 Stat. 939","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1928-05-21/ch654/s1"},"text":"May 21, 1928, ch. 654, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/622"},"text":"45 Stat. 622","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id772c7676-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id772c7677-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id772c7678-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1928—Act ","children":[{"tag":"date","attrib":{"date":"1928-05-21"},"text":"May 21, 1928","children":[],"tail":", repealed provision that no appropriation for the maintenance of the park in excess of $10,000 annually should be made unless expressly authorized by law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
