{"tag":"section","attrib":{"id":"id796b1b0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1825"},"text":null,"children":[{"tag":"num","attrib":{"value":"1825"},"text":"§ 1825.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Import prohibitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id796b1b0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1825/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations by Secretary of State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary of State determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id796b1b0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1825/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he has been unable, within a reasonable period of time, to conclude with any foreign nation an international fishery agreement allowing fishing vessels of the United States equitable access to fisheries over which that nation asserts exclusive fishery management authority, including fisheries for tuna species, as recognized by the United States, in accordance with fishing activities of such vessels, if any, and under terms not more restrictive than those established under sections 1821(c) and (d) and 1824(b)(7) and (10) of this title, because such nation has (A) refused to commence negotiations, or (B) failed to negotiate in good faith;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796b1b0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1825/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign nation is not allowing fishing vessels of the United States to engage in fishing for tuna species in accordance with an applicable international fishery agreement, whether or not such nation is a party thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796b1b0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1825/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign nation is not complying with its obligations under any existing international fishery agreement concerning fishing by fishing vessels of the United States in any fishery over which that nation asserts exclusive fishery management authority; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796b1b10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1825/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any fishing vessel of the United States, while fishing in waters beyond any foreign nation’s territorial sea, to the extent that such sea is recognized by the United States, is seized by any foreign nation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id796b1b11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1825/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in violation of an applicable international fishery agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id796b1b12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1825/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without authorization under an agreement between the United States and such nation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id796b1b13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1825/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a consequence of a claim of jurisdiction which is not recognized by the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"he shall certify such determination to the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796b1b14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1825/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon receipt of any certification from the Secretary of State under subsection (a), the Secretary of the Treasury shall immediately take such action as may be necessary and appropriate to prohibit the importation into the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id796b1b15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1825/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of all fish and fish products from the fishery involved, if any; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796b1b16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1825/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon recommendation of the Secretary of State, such other fish or fish products, from any fishery of the foreign nation concerned, which the Secretary of State finds to be appropriate to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796b1b17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1825/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary of State finds that the reasons for the imposition of any import prohibition under this section no longer prevail, the Secretary of State shall notify the Secretary of the Treasury, who shall promptly remove such import prohibition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796b1b18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1825/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id796b1b19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1825/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “fish” includes any highly migratory species.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796b1b1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1825/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “fish products” means any article which is produced from or composed of (in whole or in part) any fish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id796b1b1b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265/tII/s205"},"text":"Pub. L. 94–265, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/345"},"text":"90 Stat. 345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/627/tI/s105/b/1"},"text":"Pub. L. 101–627, title I, § 105(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4440"},"text":"104 Stat. 4440","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id796b1b1c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id796b1b1d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id796b1b1e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/627/s105/b/1/A"},"text":"Pub. L. 101–627, § 105(b)(1)(A)","children":[],"tail":", inserted “including fisheries for tuna species,” after “authority,” and struck out “traditional” after “in accordance with”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/627/s105/b/1/B"},"text":"Pub. L. 101–627, § 105(b)(1)(B)","children":[],"tail":", substituted “tuna” for “highly migratory”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id796b1b1f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id796b1b20-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/627/tI/s105/b/2"},"text":"Pub. L. 101–627, title I, § 105(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4440"},"text":"104 Stat. 4440","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/627/tI/s105/b/2"},"text":"“The amendments made by this subsection [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1992-01-01"},"text":"January 1, 1992","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
