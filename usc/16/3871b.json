{"tag":"section","attrib":{"id":"id79e26dea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3871b"},"text":"§ 3871b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional conservation partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e26deb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership agreements authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into a partnership agreement with an eligible partner to implement a project that will assist producers with installing and maintaining an eligible activity on eligible land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e26dec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Length","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e26ded-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A partnership agreement shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26dee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period not to exceed 5 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26def-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period that is longer than 5 years, if the longer period is necessary to meet the objectives of the program, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26df0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A partnership agreement may be renewed under subsection (e)(5) for a period not to exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26df1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A partnership agreement, or any renewal of a partnership agreement, may each be extended 1 time for a period not longer than 12 months, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e26df2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of partners","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e26df3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under a partnership agreement, the eligible partner shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26df4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" define the scope of a project, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79e26df5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more conservation benefits that the project shall achieve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79e26df6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible activities on eligible land to be conducted under the project to achieve conservation benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79e26df7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation timeline for carrying out the project, including any interim milestones;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79e26df8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local, State, multistate, or other geographic area covered; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79e26df9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planning, outreach, implementation, and assessment to be conducted;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26dfa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct outreach and education to producers for potential participation in the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26dfb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of a producer, act on behalf of a producer participating in the project in applying for assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871c"},"text":"section 3871c of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26dfc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage financial or technical assistance provided by the Secretary with additional contributions to help achieve the project objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26dfd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct an assessment of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79e26dfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress made by the project in achieving each conservation benefit defined in the partnership agreement, including in a quantified form to the extent practicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79e26dff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, other outcomes of the project; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the conclusion of the project, report to the Secretary on its results and funds leveraged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contribution","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26e02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible partner shall provide a significant portion of the overall costs of the scope of the project that is the subject of the agreement entered into under subsection (a), as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contribution of an eligible partner under this paragraph may be in the form of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79e26e04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct funding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79e26e05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in-kind support; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79e26e06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a combination of direct funding and in-kind support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts expended during the period beginning on the date on which the Secretary announces the approval of an application under subsection (e) and ending on the day before the effective date of the partnership agreement by an eligible partner for staff salaries or development of the partnership agreement may be considered to be a part of the contribution of the eligible partner under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e26e08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e26e09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a timeline for carrying out the duties of the Secretary under a partnership agreement, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26e0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entering into program contracts with producers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing financial assistance to producers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a partnership agreement that is funded through an alternative funding arrangement or grant agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871c/d"},"text":"section 3871c(d) of this title","children":[],"tail":", providing the payments to the eligible partner for carrying out eligible activities;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify in each State a program coordinator for the State, who shall be responsible for providing assistance to eligible partners under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish guidance to assist eligible partners with carrying out the assessment required under subsection (c)(1)(E);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide to each eligible partner that has entered into a partnership agreement that is not funded through an alternative funding arrangement or grant agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871c/d"},"text":"section 3871c(d) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26e10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a semiannual report describing the status of each pending and obligated contract under the project of the eligible partner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual report describing how the Secretary used amounts reserved by the Secretary for that year for technical assistance under section 3871d(f) ","children":[{"tag":"ref","attrib":{"idref":"fn002776"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002776"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section 3871d(e)”."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that any eligible activity effectively achieves the conservation benefits identified in the partnership agreement under subsection (c)(1)(A)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e26e13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e26e14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a simplified competitive process to select applications for partnership agreements and may assess and rank applications with similar conservation purposes as a group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria used","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the process described in paragraph (1), the Secretary shall make public the criteria used in evaluating applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop a simplified application that includes a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26e17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scope of the project, as described in subsection (c)(1)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan for monitoring, evaluating, and reporting on progress made toward achieving the project’s objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program resources requested for the project and estimated funding needed from the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each eligible partner collaborating to achieve project objectives, including their roles, responsibilities, capabilities, and contribution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other elements the Secretary considers necessary to adequately evaluate and competitively select applications for funding under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority to certain applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may give a higher priority to applications that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26e1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist producers in meeting or avoiding the need for a natural resource regulatory requirement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a high percentage of producers in the area to be covered by the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly leverage non-Federal financial and technical resources and coordinate with other local, State, or national efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" build new partnerships with local, State, and private entities to include a diversity of stakeholders in the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" deliver a high percentage of applied conservation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79e26e22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/4/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve conservation benefits; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79e26e23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/4/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project in a critical conservation area under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871f"},"text":"section 3871f of this title","children":[],"tail":", to address the priority resource concern for that critical conservation area;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the project consistent with existing watershed, habitat, or other area restoration plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide innovation in conservation methods and delivery, including outcome-based performance measures and methods; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/4/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet other factors that are important for achieving the purposes of the program, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that a project that is the subject of a partnership agreement has met or exceeded the objectives of the project, the Secretary may renew the partnership agreement through an expedited noncompetitive process if the 1 or more eligible partners that are parties to the partnership agreement request the renewal in order—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26e28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to continue to implement the project under a renewal of the partnership agreement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand the scope of the project under a renewal of the partnership agreement, as long as the expansion is within the objectives and purposes of the original partnership agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e26e2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of adjusted gross income limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The adjusted gross income limitation described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308–3a/b/1"},"text":"section 1308–3a(b)(1) of title 7","children":[],"tail":" shall not apply to an eligible partner under the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e26e2b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1271B"},"text":"Pub. L. 99–198, title XII, § 1271B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2401"},"text":"Pub. L. 113–79, title II, § 2401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/746"},"text":"128 Stat. 746","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2703"},"text":"Pub. L. 115–334, title II, § 2703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4594"},"text":"132 Stat. 4594","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e26e2c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e26e2d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79e26e2e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2703/1"},"text":"Pub. L. 115–334, § 2703(1)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “A partnership agreement shall be for a period not to exceed 5 years, except that the Secretary may extend the agreement one time for up to 12 months when an extension is necessary to meet the objectives of the program.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2703/2/A/i"},"text":"Pub. L. 115–334, § 2703(2)(A)(i)","children":[],"tail":", added cls. (i) to (iii), redesignated former cls. (iii) and (iv) as (iv) and (v), respectively, and struck out former cls. (i) and (ii) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the eligible activities to be implemented;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the potential agricultural or nonindustrial private forest land operations affected;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2703/2/A/ii"},"text":"Pub. L. 115–334, § 2703(2)(A)(ii)","children":[],"tail":", substituted “contributions” for “funds”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2703/2/A/iii"},"text":"Pub. L. 115–334, § 2703(2)(A)(iii)","children":[],"tail":", substituted “of—” for “of the project’s effects; and” and added cls. (i) and (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2703/2/B"},"text":"Pub. L. 115–334, § 2703(2)(B)","children":[],"tail":", designated existing provisions as subpar. (A), inserted heading, and added subpars. (B) and (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2703/3"},"text":"Pub. L. 115–334, § 2703(3)","children":[],"tail":", (4), added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2703/5/A"},"text":"Pub. L. 115–334, § 2703(5)(A)","children":[],"tail":", inserted “simplified” before “competitive process”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2703/5/B/i"},"text":"Pub. L. 115–334, § 2703(5)(B)(i)","children":[],"tail":", substituted “Contents” for “Content” in heading and “The Secretary shall develop a simplified application that includes a description of—” for “An application to the Secretary shall include a description of—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2703/5/B/ii"},"text":"Pub. L. 115–334, § 2703(5)(B)(ii)","children":[],"tail":", struck out “, including the covered programs to be used” after “resources requested for the project”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2703/5/B/iii"},"text":"Pub. L. 115–334, § 2703(5)(B)(iii)","children":[],"tail":", struck out “financial” before “contribution”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4)(D) to (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2703/5/C"},"text":"Pub. L. 115–334, § 2703(5)(C)","children":[],"tail":", added subpars. (D) to (F), redesignated former subpars. (E) and (F) as (G) and (H), respectively, and struck out former subpar. (D) which read as follows: “deliver high percentages of applied conservation to address conservation priorities or regional, State, or national conservation initiatives;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2703/5/D"},"text":"Pub. L. 115–334, § 2703(5)(D)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2703/6"},"text":"Pub. L. 115–334, § 2703(6)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
