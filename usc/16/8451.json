{"tag":"section","attrib":{"id":"id7a383048-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451"},"text":null,"children":[{"tag":"num","attrib":{"value":"8451"},"text":"§ 8451.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Connect our parks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a383049-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a38304a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a38304b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Natural Resources of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38304c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38304d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Natural Resources of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38304e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38304f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadband internet access service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “broadband internet access service” has the meaning given the term in section 8.1(b) of title 47, Code of Federal Regulations (or a successor regulation).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383050-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cellular service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cellular service” has the meaning given the term in section 22.99 of title 47, Code of Federal Regulations (or a successor regulation).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383051-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Park” means a unit of the National Park System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383052-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior, acting through the Director of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a383053-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a383054-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary shall complete an assessment of National Parks to identify—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a383055-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" locations in National Parks in which there is the greatest need for broadband internet access service, based on the considerations described in paragraph (2)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383056-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas in National Parks in which there is the greatest need for cellular service, based on the considerations described in paragraph (2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383057-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a383058-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadband internet access service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of identifying locations in National Parks under paragraph (1)(A), the Secretary shall consider, with respect to each National Park, the availability of broadband internet access service in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a383059-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a38305a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative facilities and related structures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a38305b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lodging;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a38305c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developed campgrounds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a38305d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other location within the National Park in which broadband internet access service is determined to be necessary by the superintendent of the National Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38305e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cellular service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of identifying areas in National Parks under paragraph (1)(B), the Secretary shall consider, with respect to each National Park, the availability of cellular service in any developed area within the National Park that would increase—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a38305f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the access of the public to emergency services and traveler information technologies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a383060-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the communications capabilities of National Park Service employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383061-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On completion of the assessment under paragraph (1), the Secretary shall submit to the appropriate committees of Congress, and make available on the website of the Department of the Interior, a report describing the results of the assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a383062-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a383063-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary shall develop a plan, based on the results of the assessment completed under subsection (b) and subject to paragraph (4)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a383064-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to install broadband internet access service infrastructure in certain locations in National Parks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383065-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to install cellular service equipment and infrastructure in certain areas of National Parks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383066-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the plan under paragraph (1), the Secretary shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a383067-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affected Indian Tribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383068-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local stakeholders that the superintendent of the applicable National Park determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383069-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan developed under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a38306a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for avoiding or minimizing impacts to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a38306b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Park viewsheds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a38306c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cultural and natural resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a38306d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the visitor experience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a38306e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" historic properties and the viewsheds of historic properties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a38306f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other resources or values of the National Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383070-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for infrastructure providing broadband internet access service or cellular service to be located in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a383071-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" previously disturbed or developed areas; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a383072-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas zoned for uses that would support the infrastructure;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383073-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for the use of public-private partnerships—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a383074-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to install broadband internet access service or cellular service equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a383075-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide broadband internet access service or cellular service;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383076-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be technology neutral; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383077-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of broadband internet access service, provide for broadband internet access service of at least—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a383078-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 100–Mbps downstream transmission capacity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a383079-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 20–Mbps upstream transmission capacity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38307a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8451/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), a plan developed under that paragraph shall not be required to address broadband internet access service or cellular service in any National Park with respect to which the superintendent of the National Park determines that there is adequate access to broadband internet access service or cellular service, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a38307b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s141"},"text":"Pub. L. 118–234, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2862"},"text":"138 Stat. 2862","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
