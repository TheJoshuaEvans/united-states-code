{"tag":"section","attrib":{"id":"id784f7235-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s580p–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"580p–2"},"text":"§ 580p–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of fees collected under regulations relating to “Smokey Bear”; availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall deposit into a special account to be available for furthering the nationwide forest-fire prevention campaign all fees collected under regulations promulgated by him relating to “Smokey Bear”.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id784f7236-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-05-23/ch327/s3"},"text":"May 23, 1952, ch. 327, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/92"},"text":"66 Stat. 92","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/318/s7"},"text":"Pub. L. 93–318, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-06-22"},"text":"June 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/245"},"text":"88 Stat. 245","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id784f7237-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id784f7238-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id784f7239-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s488a"},"text":"section 488a of Title 31","children":[],"tail":" prior to the general revision and enactment of Title 31, Money and Finance, by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s1"},"text":"Pub. L. 97–258, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/877"},"text":"96 Stat. 877","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id784f723a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/318"},"text":"Pub. L. 93–318","children":[],"tail":" struck out “under the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s711"},"text":"section 711 of title 18","children":[],"tail":"” after “relating to ‘Smokey Bear’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
