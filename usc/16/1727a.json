{"tag":"section","attrib":{"id":"id795f33fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1727a"},"text":"§ 1727a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting and data collection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id795f33fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", and annually thereafter, the Chief Executive Officer of the Corporation for National and Community Service, in coordination with the Secretaries, shall submit to Congress a report that includes data on the Corps, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id795f33ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of participants enrolled in the Corps and the length of the term of service for each participant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795f3400-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projects carried out by Corps participants, categorized by type of project and Federal agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795f3401-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount and sources of funding provided for the service of participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795f3402-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of service performed by participants and the impact and accomplishments of the service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795f3403-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other similar data determined to be appropriate by the Chief Executive Officer of the Corporation for National and Community Service or the Secretaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795f3404-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", and annually thereafter, the Secretaries shall submit to the Chief Executive Officer of the Corporation for National and Community Service the data described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795f3405-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer of the Corporation for National and Community Service may coordinate with qualified youth or conservation corps to improve the collection of the required data described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795f3406-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795f3407-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries shall, to the maximum extent practicable, coordinate with each other to carry out activities authorized under this subchapter, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id795f3408-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the data collection and reporting requirements of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795f3409-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing and issuing guidance on eligibility for noncompetitive hiring status under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1726/d"},"text":"section 1726(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795f340a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of coordinators","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate a coordinator to coordinate and serve as the primary point of contact for any activity of the Corps carried out by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id795f340b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/378/tII/s209"},"text":"Pub. L. 91–378, title II, § 209","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tIX/s9003/f/2"},"text":"Pub. L. 116–9, title IX, § 9003(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/835"},"text":"133 Stat. 835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795f340c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id795f340d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id795f340e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (d)(1), was in the original “this Act”, and was translated as reading “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/378"},"text":"Pub. L. 91–378","children":[],"tail":", known as the Public Lands Corps Act of 1993, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id795f340f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/378/s209"},"text":"section 209 of Pub. L. 91–378","children":[],"tail":" was renumbered section 211 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1728"},"text":"section 1728 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
