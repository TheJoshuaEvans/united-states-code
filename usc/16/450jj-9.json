{"tag":"section","attrib":{"id":"id77a612d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"450jj–9"},"text":"§ 450jj–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities in Memorial area pending submission of plan","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Pending submission of the Commission’s plan, any Federal entity conducting or supporting significant activities directly affecting East Saint Louis, Illinois, generally and the site specifically referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s450jj–3"},"text":"section 450jj–3 of this title","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id77a612d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–9/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Secretary of the Interior and the Commission with respect to such activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a612d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–9/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with the Secretary of the Interior and the Commission in carrying out their duties under sections 450jj to 450jj–9 of this title, and to the maximum extent practicable, coordinate such activities with the carrying out of such duties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a612d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–9/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, conduct or support such activities in 