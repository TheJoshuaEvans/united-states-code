{"tag":"section","attrib":{"id":"id78ecc2f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1151"},"text":null,"children":[{"tag":"num","attrib":{"value":"1151"},"text":"§ 1151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78ecc2f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1151/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Commission” means the North Pacific Fur Seal Commission established pursuant to article V of the Convention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ecc2f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1151/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Convention” means the Interim Convention on the Conservation of North Pacific Fur Seals signed at Washington on ","children":[{"tag":"date","attrib":{"date":"1957-02-09"},"text":"February 9, 1957","children":[],"tail":", as amended by the protocol signed in Washington on "},{"tag":"date","attrib":{"date":"1963-10-08"},"text":"October 8, 1963","children":[],"tail":"; by the exchange of notes among the party governments which became effective on "},{"tag":"date","attrib":{"date":"1969-09-03"},"text":"September 3, 1969","children":[],"tail":"; by the protocol signed in Washington on "},{"tag":"date","attrib":{"date":"1976-05-07"},"text":"May 7, 1976","children":[],"tail":"; and by the protocol signed in Washington on "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"October 14, 1980","children":[],"tail":", by the parties."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ecc2f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1151/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Cure” or “curing” means the performance of those post-harvest activities traditionally performed on the Pribilof Islands, including cooling, washing, removal of blubber, soaking in brine, draining, treating with salt or boric acid, and packing in containers for shipment of fur seal skins.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ecc2f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1151/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Fur Seal” means the North Pacific Fur Seal, Callorhinus Ursinus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ecc2fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1151/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Import” means to land on, bring into, or introduce into, or attempt to land on, bring into, or introduce into, any place subject to the jurisdiction of the United States, whether or not such landing, bringing, or introduction constitutes an importation within the meaning of the customs laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ecc2fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1151/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Natives of the Pribilof Islands” means any Aleuts who are permanent residents of the Pribilof Islands, or any organization or entity representing such natives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ecc2fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1151/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “North Pacific Ocean” means the waters of the Pacific Ocean north of the thirtieth parallel of north latitude, including the Bering, Okhotsk, and Japan Seas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ecc2fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1151/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Party” or “parties” means the United States of America, Canada, Japan, and Russia (except that as used in subsection (b) of this section, “party” and “parties” refer to the Union of Soviet Socialist Republics).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ecc2fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1151/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Person” means any individual, partnership, corporation, trust, association or any other private entity, or any officer, employee, agent, department, or instrumentality of the Federal Government, of any State or political subdivision thereof, or of any foreign government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ecc2ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1151/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Pribilof Islands” means the islands of Saint Paul and Saint George, Walrus and Otter Islands, and Sea Lion Rock.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ecc300-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1151/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Sealing” means the taking of fur seals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ecc301-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1151/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ecc302-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1151/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Take” or “taking” means to harass, hunt, capture, or kill, or attempt to harass, hunt, capture, or kill.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78ecc303-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/702/tI/s101"},"text":"Pub. L. 89–702, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1091"},"text":"80 Stat. 1091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/129/s2"},"text":"Pub. L. 98–129, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-10-14"},"text":"Oct. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/835"},"text":"97 Stat. 835","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/251/tIII/s303"},"text":"Pub. L. 102–251, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-09"},"text":"Mar. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/65"},"text":"106 Stat. 65","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/199/tVI/s602/1"},"text":"Pub. L. 103–199, title VI, § 602(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2327"},"text":"107 Stat. 2327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78ecc304-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id78ecc305-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/251/tIII"},"text":"Pub. L. 102–251, title III","children":[],"tail":", §§ 303, 308, "},{"tag":"date","attrib":{"date":"1992-03-09"},"text":"Mar. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/65"},"text":"106 Stat. 65","children":[],"tail":", 66, provided that, effective on the date on which the Agreement between the United States and the Union of Soviet Socialist Republics on the Maritime Boundary, signed "},{"tag":"date","attrib":{"date":"1990-06-01"},"text":"June 1, 1990","children":[],"tail":", enters into force for the United States, with authority to prescribe implementing regulations effective "},{"tag":"date","attrib":{"date":"1992-03-09"},"text":"Mar. 9, 1992","children":[],"tail":", but with no such regulation to be effective until the date on which the Agreement enters into force for the United States, this section is amended by redesignating subsections (f) to (m) as (g) to (n), respectively, and by inserting after subsection (e) the following new subsection:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"(f) “Jurisdiction of the United States” includes jurisdiction over the areas referred to as eastern special areas in Article 3(1) of the Agreement between the United States of America and the Union of Soviet Socialist Republics on the Maritime Boundary, signed ","children":[{"tag":"date","attrib":{"date":"1990-06-01"},"text":"June 1, 1990","children":[],"tail":"; in particular, those areas east of the maritime boundary, as defined in that Agreement, that lie within 200 nautical miles of the baselines from which the breadth of the territorial sea of Russia is measured but beyond 200 nautical miles of the baselines from which the breadth of the territorial sea of the United States is measured."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78ecc306-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78ecc307-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/199"},"text":"Pub. L. 103–199","children":[],"tail":" substituted “Russia (except that as used in subsection (b) of this section, ‘party’ and ‘parties’ refer to the Union of Soviet Socialist Republics)” for “the Union of Soviet Socialist Republics”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/129"},"text":"Pub. L. 98–129","children":[],"tail":" amended section generally, substituting provisions defining terms, previously defined in former sections 1159 and 1186 of this title, for provisions enumerating the activities prohibited under this chapter. See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1152"},"text":"section 1152 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78ecc308-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78ecc309-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/251"},"text":"Pub. L. 102–251","children":[],"tail":" effective on date on which Agreement between United States and Union of Soviet Socialist Republics on the Maritime Boundary, signed "},{"tag":"date","attrib":{"date":"1990-06-01"},"text":"June 1, 1990","children":[],"tail":", enters into force for United States, with authority to prescribe implementing regulations effective "},{"tag":"date","attrib":{"date":"1992-03-09"},"text":"Mar. 9, 1992","children":[],"tail":", but with no such regulation to be effective until date on which Agreement enters into force for United States, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/251/s308"},"text":"section 308 of Pub. L. 102–251","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s773"},"text":"section 773 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id78ecc30a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3531"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2794"},"text":"130 Stat. 2794","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":