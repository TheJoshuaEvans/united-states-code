:"id78ecc30d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/702/s1"},"text":"Pub. L. 89–702, § 1","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s144/e/6/C"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 144(e)(6)(C)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–248, and "},{"tag":"ref","attrib":{"href":"/us/pl/106/562/tI/s106/c"},"text":"Pub. L. 106–562, title I, § 106(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2799"},"text":"114 Stat. 2799","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/562/tI/s106/c"},"text":"“This Act [generally enacting this chapter, for complete classification, see Tables] may be cited as the ‘Fur Seal Act of 1966’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
