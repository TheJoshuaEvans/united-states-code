{"tag":"section","attrib":{"id":"id771bd42b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230g"},"text":null,"children":[{"tag":"num","attrib":{"value":"230g"},"text":"§ 230g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; general management plan; submission to Congressional committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id771bd42c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated, to carry out the provisions of this part, not to exceed $50,000,000 from the Land and Water Conservation Fund for acquisition of lands, waters, and interests therein and such sums as necessary for the development of essential facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id771bd42d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Within three years from ","children":[{"tag":"date","attrib":{"date":"1978-11-10"},"text":"November 10, 1978","children":[],"tail":", the Secretary, after consultation with the Commission, shall submit to the Committee on Interior and Insular Affairs of the House of Representatives, and the Committee on Energy and Natural Resources of the Senate a general management plan for the park indicating—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id771bd42e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation alternatives for public access to the park;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd42f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of visitors and types of public use within the park which can be accommodated in accordance with the protection of its resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd430-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location and estimated cost of facilities deemed necessary to accommodate such visitors and uses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd431-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230g/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement setting forth the actions which have been and should be taken to assure appropriate protection, interpretation, and management of the areas known as Big Oak Island and Couba Island.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id771bd432-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/tIX/s908"},"text":"Pub. L. 95–625, title IX, § 908","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3537"},"text":"92 Stat. 3537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id771bd433-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id771bd434-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id771bd435-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Interior and Insular Affairs of the House of Representatives changed to Committee on Natural Resources of the House of Representatives on ","children":[{"tag":"date","attrib":{"date":"1993-01-05"},"text":"Jan. 5, 1993","children":[],"tail":", by House Resolution No. 5, One Hundred Third Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id771bd436-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/s2"},"text":"section 2 of Pub. L. 95–625","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s45f"},"text":"section 45f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
