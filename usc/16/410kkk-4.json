{"tag":"section","attrib":{"id":"id777676e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkk–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"410kkk–4"},"text":"§ 410kkk–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private property protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id777676e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkk–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to private property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter shall be construed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777676e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkk–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require any private property owner to permit public access (including Federal, State, or local government access) to such private property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777676e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkk–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modify any provision of Federal, State, or local law with regard to public access to or use of private lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777676e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkk–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Designation of the park shall not be considered to create any liability, or to have any effect on any liability under any other law, of any private property owner with respect to any persons injured on such private property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777676e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkk–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition of authority to control land use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to modify any authority of Federal, State, or local governments to regulate the use of private land within the boundary of the park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777676e6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/387/tI/s106"},"text":"Pub. L. 108–387, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2236"},"text":"118 Stat. 2236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777676e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777676e8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id777676e9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsecs. (a) and (c), was in the original “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/387"},"text":"Pub. L. 108–387","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2234"},"text":"118 Stat. 2234","children":[],"tail":", which is classified principally to this subchapter. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410kkk"},"text":"section 410kkk of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
