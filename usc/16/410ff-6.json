{"tag":"section","attrib":{"id":"id77529bbb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ff–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ff–6"},"text":"§ 410ff–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entrance or admission fees prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, no fees shall be charged for entrance or admission to the park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77529bbc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/199/tII/s207"},"text":"Pub. L. 96–199, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-05"},"text":"Mar. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/77"},"text":"94 Stat. 77","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
