{"tag":"section","attrib":{"id":"id7a278d76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202"},"text":null,"children":[{"tag":"num","attrib":{"value":"7202"},"text":"§ 7202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the National Landscape Conservation System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a278d77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to conserve, protect, and restore nationally significant landscapes that have outstanding cultural, ecological, and scientific values for the benefit of current and future generations, there is established in the Bureau of Land Management the National Landscape Conservation System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a278d78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The system shall include each of the following areas administered by the Bureau of Land Management:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a278d79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each area that is designated as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a278d7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national monument;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a278d7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national conservation area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a278d7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a wilderness study area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a278d7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national scenic trail or national historic trail designated as a component of the National Trails System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a278d7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a component of the National Wild and Scenic Rivers System; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a278d7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a component of the National Wilderness Preservation System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a278d80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any area designated by Congress to be administered for conservation purposes, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a278d81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Steens Mountain Cooperative Management and Protection Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a278d82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Headwaters Forest Reserve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a278d83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Yaquina Head Outstanding Natural Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a278d84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public land within the California Desert Conservation Area administered by the Bureau of Land Management for conservation purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a278d85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional area designated by Congress for inclusion in the system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a278d86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall manage the system—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a278d87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with any applicable law (including regulations) relating to any component of the system included under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a278d88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that protects the values for which the components of the system were designated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a278d89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a278d8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter enhances, diminishes, or modifies any law or proclamation (including regulations relating to the law or proclamation) under which the components of the system described in subsection (b) were established or are managed, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a278d8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Alaska National Interest Lands Conservation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3101"},"text":"16 U.S.C. 3101","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a278d8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Wilderness Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a278d8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Wild and Scenic Rivers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1271"},"text":"16 U.S.C. 1271","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a278d8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Trails System Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1241"},"text":"16 U.S.C. 1241","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a278d8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a278d90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7202/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish and wildlife","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed as affecting the authority, jurisdiction, or responsibility of the several States to manage, control, or regulate fish and resident wildlife under State law or regulations, including the regulation of hunting, fishing, trapping and recreational shooting on public land managed by the Bureau of Land Management. Nothing in this chapter shall be construed as limiting access for hunting, fishing, trapping, or recreational shooting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a278d91-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tII/s2002"},"text":"Pub. L. 111–11, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1095"},"text":"123 Stat. 1095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a278d92-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a278d93-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a278d94-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Alaska National Interest Lands Conservation Act, referred to in subsec. (d)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487"},"text":"Pub. L. 96–487","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2371"},"text":"94 Stat. 2371","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3101"},"text":"section 3101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Wilderness Act, referred to in subsec. (d)(1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/577"},"text":"Pub. L. 88–577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-03"},"text":"Sept. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/890"},"text":"78 Stat. 890","children":[],"tail":", which is classified generally to chapter 23 (§ 1131 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"section 1131 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Wild and Scenic Rivers Act, referred to in subsec. (d)(1)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/542"},"text":"Pub. L. 90–542","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-02"},"text":"Oct. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/906"},"text":"82 Stat. 906","children":[],"tail":", which is classified generally to chapter 28 (§ 1271 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1271"},"text":"section 1271 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Trails System Act, referred to in subsec. (d)(1)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/543"},"text":"Pub. L. 90–543","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-02"},"text":"Oct. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/919"},"text":"82 Stat. 919","children":[],"tail":", which is classified generally to chapter 27 (§ 1241 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1241"},"text":"section 1241 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in subsec. (d)(1)(E), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
