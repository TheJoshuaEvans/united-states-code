{"tag":"section","attrib":{"id":"id770b0a93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s159e"},"text":null,"children":[{"tag":"num","attrib":{"value":"159e"},"text":"§ 159e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of boundary; additional acreage; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id770b0a94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s159e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior is authorized to revise the boundary of the Saratoga National Historic Park to add approximately one hundred and forty-seven acres.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id770b0a95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s159e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of acquiring land and interest in land added to the unit referred to in subsection (a) there are authorized to be appropriated from the Land and Water Conservation Fund such sums as may be necessary but not to exceed $74,000 for Saratoga National Historic Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id770b0a96-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/199/tI/s115"},"text":"Pub. L. 96–199, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-05"},"text":"Mar. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/71"},"text":"94 Stat. 71","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
