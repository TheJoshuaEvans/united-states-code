n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f09e64-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/233/s12"},"text":"Pub. L. 101–233, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-13"},"text":"Dec. 13, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1977"},"text":"103 Stat. 1977","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f09e65-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f09e66-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79f09e67-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Fish and Wildlife Coordination Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-03-10/ch55"},"text":"act Mar. 10, 1934, ch. 55","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/401"},"text":"48 Stat. 401","children":[],"tail":", which is classified generally to sections 661 to 666c–1 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s661/a"},"text":"section 661(a) of this title","children":[],"tail":", Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s661"},"text":"section 661 of this title","children":[],"tail":", and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Water Resources Development Act of 1986, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662"},"text":"Pub. L