{"tag":"section","attrib":{"id":"id78921fca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s758b"},"text":null,"children":[{"tag":"num","attrib":{"value":"758b"},"text":"§ 758b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with agencies, organizations, and others","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out the purposes and objectives of sections 758 and 758a of this title, the Secretary of Commerce may cooperate with appropriate agencies of the State and island governments, and with such educational, industrial, or other organizations, enterprises, and individuals as may be expedient.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78921fcb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-08-04/ch451/s3"},"text":"Aug. 4, 1947, ch. 451, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/726"},"text":"61 Stat. 726","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/624/s11/c"},"text":"Pub. L. 86–624, § 11(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/412"},"text":"74 Stat. 412","children":[],"tail":"; 1970 Reorg. Plan No. 4, eff. "},{"tag":"date","attrib":{"date":"1970-10-03"},"text":"Oct. 3, 1970","children":[],"tail":", 35 F.R. 15627, "},{"tag":"ref","attrib":{"href":"/us/stat/84/2090"},"text":"84 Stat. 2090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78921fcc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78921fcd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","ch