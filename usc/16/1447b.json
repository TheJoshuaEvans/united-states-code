{"tag":"section","attrib":{"id":"id79369df2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1447b"},"text":"§ 1447b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional Marine Research Boards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79369df3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Regional Marine Research board ","children":[{"tag":"ref","attrib":{"idref":"fn002646"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002646"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" shall be established for each of the following regions:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79369df4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Gulf of Maine region, comprised of the marine and coastal waters off the State of Maine, New Hampshire, and Massachusetts (north of Cape Cod);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369df5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the greater New York bight region, comprised of the marine and coastal waters off the States of Massachusetts (south of Cape Cod), Rhode Island, Connecticut, New York, and New Jersey, from Cape Cod to Cape May;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369df6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mid-Atlantic region, comprised of the marine and coastal waters off the States of New Jersey, Delaware, Maryland, Virginia, and North Carolina, from Cape May to Cape Fear;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369df7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the South Atlantic region, comprised of the marine and coastal waters off the States of North Carolina, South Carolina, Georgia, and Florida, from Cape Fear to the Florida Keys, including the marine and coastal waters off Puerto Rico and the United States Virgin Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369df8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Gulf of Mexico region, comprised of the marine and coastal waters off the States of Florida, Alabama, Mississippi, Louisiana, and Texas, along the Gulf coast from the Florida Keys to the Mexican border;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369df9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the California region, comprised of the marine and coastal waters off the State of California, from Point Reyes to the Mexican border;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369dfa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the North Pacific region, comprised of the marine and coastal waters off the States of California, Oregon, and Washington, from Point Reyes to the Canadian border;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369dfb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Alaska region, comprised of the marine and coastal waters off the State of Alaska; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369dfc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insular Pacific region, comprised of the marine and coastal waters off the State of Hawaii, Guam, American Samoa, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Great Lakes Research Office authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1268/d"},"text":"section 1268(d) of title 33","children":[],"tail":" shall be responsible for research in the Great Lakes region and shall be considered the Great Lakes counterpart to the research program established pursuant to this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369dfd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79369dfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Board shall be comprised of 11 members of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79369dff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members shall be appointed by the Administrator of the National Oceanic and Atmospheric Administration, including 1 member who shall be a Sea Grant Program Director from a State within such region, who shall serve as chairman of the board; ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 members shall be appointed by the Administrator of the Environmental Protection Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79369e01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 members shall be appointed by Governors of States located within the region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each individual appointed as a member of a Board shall possess expertise, pertinent to the region concerned, in scientific research, coastal zone management, fishery management, water quality management, State and local government, or any other area which is directly relevant to the functions of the Board. A majority of the members of each Board shall be trained in a field of marine or aquatic science and shall be currently engaged in research or research administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each appointed member of a Board shall serve for a term of 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event of a vacancy, a replacement member shall be appointed in the same manner and in accordance with the same requirements as the member being replaced and shall serve the remainder of the term of the replaced member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each appointed member of a Board may be paid actual travel expenses, and per diem in lieu of subsistence expenses when away from the member’s usual place of residence, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":", when engaged in the actual performance of Board duties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369e06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Board shall, in accordance with the provisions of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79369e07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and submit to the Administrators of the National Oceanic and Atmospheric Administration and the Environmental Protection Agency a marine research plan, including periodic amendments thereto, that meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1447c"},"text":"section 1447c of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a forum for coordinating research among research institutions and agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for review and comment on research plans by affected users and interests, such as the commercial and recreational fishing industries, other marine industries, State and local government entities, and environmental organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the highest quality of research projects will be conducted to carry out the comprehensive plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare, for submission to Congress, a periodic report on the marine environmental research issues and activities within the region in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1447e"},"text":"section 1447e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369e0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Board shall be authorized to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79369e0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with Federal agencies, with States and with local government entities, interstate and regional agencies, other public agencies and authorities, nonprofit institutions, laboratories, and organizations, or other appropriate persons, in the preparation and support of marine research in the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts, cooperative agreements or grants to State and local governmental entities, other public agencies or institutions, and non-profit institutions and organizations for purposes of carrying out the provisions of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and make available through publications and other appropriate means, the results of, and other information pertaining to, the research conducted in the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" call conferences on regional marine research and assessment issues, giving opportunity for interested persons to be heard and present papers at such conferences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and stimulate, in consultation with the Department of State, joint marine research projects with foreign nations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize facilities and personnel of existing Federal agencies, including scientific laboratories and research facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept, and for all general purposes of this Act, utilize funds from other sources, including but not limited to State and local funds, university funds, and donations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire secret processes, inventions, patent applications, patents, licenses, and property rights, by purchase, license, lease, or donation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369e15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79369e16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Practices and procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Board shall determine its organization, and prescribe its practices and procedures for carrying out its functions under this chapter. Each Board should use existing research administrative capability to the extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committees and subcommittees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Board shall establish such committees and subcommittees as are appropriate in the performance of its functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff and support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Board is authorized to hire such staff as are necessary to carry out the functions of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369e19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Board shall cease to exist on ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":", unless extended by Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79369e1a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tIV/s403"},"text":"Pub. L. 92–532, title IV, § 403","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/593/tIII/s301"},"text":"Pub. L. 101–593, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2964"},"text":"104 Stat. 2964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79369e1b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79369e1c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79369e1d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (d)(7), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532"},"text":"Pub. L. 92–532","children":[],"tail":", which enacted this chapter, chapter 32 (§ 1431 et seq.) of this title, and chapters 27 (§ 1401 et seq.) and 41 (§ 2801 et seq.) of Title 33, Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
