{"tag":"section","attrib":{"id":"id7807e252-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ttt"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ttt"},"text":"§ 460ttt.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Certain Federal land managed by the United States Forest Service, comprising approximately 15,857 acres, as generally depicted on the map entitled “Moosalamoo National Recreation Area—Proposed”, dated September 2006, is designated as the “Moosalamoo National Recreation Area”.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7807e253-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/382/tII/s221"},"text":"Pub. L. 109–382, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-01"},"text":"Dec. 1, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2676"},"text":"120 Stat. 2676","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7807e254-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7807e255-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7807e256-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/382/s1/a"},"text":"Pub. L. 109–382, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-01"},"text":"Dec. 1, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2673"},"text":"120 Stat. 2673","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/382/s1/a"},"text":"“This Act [enacting this subchapter and provisions set out as notes under this section and amending provisions listed in a table of Wilderness Areas under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"section 1132 of this title","children":[],"tail":"] may be cited as the ‘New England Wilderness Act of 2006’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7807e257-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/382/s2"},"text":"Pub. L. 109–382, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-01"},"text":"Dec. 1, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2673"},"text":"120 Stat. 2673","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/382/s2"},"text":"“In this Act [see Short Title note above], the term ‘Secretary’ means the Secretary of Agriculture, acting through the Chief of the Forest Service.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/382/tII/s201"},"text":"Pub. L. 109–382, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-01"},"text":"Dec. 1, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2675"},"text":"120 Stat. 2675","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/382/tII/s201"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this title [enacting this subchapter and amending provisions listed in a table of Wilderness Areas under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"section 1132 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Management Plan’ means the Green Mountain National Forest Land and Resource Management Plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘State’ means the State of Vermont.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
