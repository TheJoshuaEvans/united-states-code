{"tag":"section","attrib":{"id":"id777b31bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss"},"text":null,"children":[{"tag":"num","attrib":{"value":"410sss"},"text":"§ 410sss.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harriet Tubman Underground Railroad National Historical Park, Maryland","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id777b31bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b31be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historical park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “historical park” means the Harriet Tubman Underground Railroad National Historical Park established by subsection (b)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “map” means the map entitled “Harriet Tubman Underground Railroad National Historical Park, Proposed Boundary and Authorized Acquisition Areas”, numbered T20/80,001A, and dated March 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the State of Maryland.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777b31c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harriet Tubman Underground Railroad National Historical Park","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b31c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b31c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established as a unit of the National Park System the Harriet Tubman Underground Railroad National Historical Park in the State, consisting of the area depicted on the map as “Harriet Tubman Underground Railroad National Historical Park Boundary”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The boundary of the historical park shall consist of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777b31c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the land described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b31c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any land and interests in land acquired under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map shall be on file and available for public inspection in appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the historical park is to preserve and interpret for the benefit of present and future generations the historical, cultural, and natural resources associated with the life of Harriet Tubman and the Underground Railroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b31cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire land and interests in land within the areas depicted on the map as “Authorized Acquisition Areas for the National Historical Park” only by purchase from willing sellers, donation, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not acquire land or an interest in land for purposes of this section by condemnation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On acquisition of land or an interest in land under subparagraph (A), the boundary of the historical park shall be adjusted to reflect the acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777b31ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b31cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer the historical park and the portion of the Harriet Tubman Underground Railroad National Monument administered by the National Park Service as a single unit of the National Park System, which shall be known as the “Harriet Tubman Underground Railroad National Historical Park”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall administer the historical park in accordance with this section, Presidential Proclamation Number 8943 (78 Fed. Reg. 18763), and the laws generally applicable to units of the National Park System, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b31d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Park System Organic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":" et seq.); "},{"tag":"ref","attrib":{"idref":"fn002186"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002186"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s461"},"text":"16 U.S.C. 461","children":[],"tail":" et seq.)."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"December 19, 2014","children":[],"tail":", the Director of the National Park Service and the Director of the United States Fish and Wildlife Service shall enter into an agreement to allow the National Park Service to provide for archeological research and the public interpretation of historic resources located within the boundary of the Blackwater National Wildlife Refuge that are associated with the life of Harriet Tubman, consistent with the management requirements of the Refuge."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpretive tours","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide interpretive tours to sites and resources located outside the boundary of the historical park in Caroline, Dorchester, and Talbot Counties, Maryland, relating to the life of Harriet Tubman and the Underground Railroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land uses and agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section affects—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b31d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land within the boundaries of the Blackwater National Wildlife Refuge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agreements between the Secretary and private landowners regarding hunting, fishing, farming, or other activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land use rights of private property owners within or adjacent to the historical park or the Harriet Tubman Underground Railroad National Monument, including activities or uses on private land that can be seen or heard within the historical park or the Harriet Tubman Underground Railroad National Monument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b31da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enter into an agreement with the State, political subdivisions of the State, colleges and universities, non-profit organizations, and individuals—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777b31db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to mark, interpret, and restore nationally significant historic or cultural resources relating to the life of Harriet Tubman or the Underground Railroad within the boundaries of the historical park, if the agreement provides for reasonable public access; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b31dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct research relating to the life of Harriet Tubman and the Underground Railroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visitor center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enter into an agreement to design, construct, operate, and maintain a joint visitor center on land owned by the State—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777b31de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for National Park Service visitor and interpretive facilities for the historical park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b31df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide to the Secretary, at no additional cost, sufficient office space to administer the historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing requirement","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777b31e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/6/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the total cost of any activity carried out under this paragraph shall not exceed 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b31e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/c/6/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the cost of carrying out an activity under this paragraph may be in the form of in-kind contributions or goods or services fairly valued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777b31e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General management plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b31e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after the date on which funds are made available to carry out this section, the Secretary shall prepare a general management plan for the historical park in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The general management plan shall be prepared in consultation with the State (including political subdivisions of the State).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b31e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold not less than 1 public meeting in the area of the historical park on the proposed general management plan, including opportunity for public comment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the draft general management plan on the internet and provide an opportunity for public comment on the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall coordinate the preparation and implementation of the management plan with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b31ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Blackwater National Wildlife Refuge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Harriet Tubman National Historical Park established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ttt"},"text":"section 410ttt of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410sss/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Underground Railroad Network to Freedom.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777b31ed-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXX/s3035"},"text":"Pub. L. 113–291, div. B, title XXX, § 3035","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3778"},"text":"128 Stat. 3778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/289/tVI/s601/e"},"text":"Pub. L. 114–289, title VI, § 601(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1491"},"text":"130 Stat. 1491","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777b31ee-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777b31ef-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id777b31f0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Presidential Proclamation Number 8943, referred to in subsec. (c)(2), is listed in a table of National Monuments Established Under Presidential Proclamation set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s320301"},"text":"section 320301 of Title 54","children":[],"tail":", National Park Service and Related Programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Park System Organic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":" et seq.), referred to in subsec. (c)(2)(A), probably means the National Park Service Organic Act, "},{"tag":"ref","attrib":{"href":"/us/act/1916-08-25/ch408"},"text":"act Aug. 25, 1916, ch. 408","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":", which enacted sections 1, 2, 3, and 4 of this title and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":", National Park Service and Related Programs. Sections 1 to 4 of the Act were repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1865/a"},"text":"section 1865(a) of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and section 100101(a), chapter 1003, and sections 100751(a), 100752, 100753, and 102101 of Title 54 by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 4(a)(1), 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3260, 3272. For complete classification of this Act to the Code, see Tables. For disposition of former sections of this title, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s461"},"text":"16 U.S.C. 461","children":[],"tail":" et seq.), referred to in subsec. (c)(2)(B), is "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-21/ch593"},"text":"act Aug. 21, 1935, ch. 593","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/666"},"text":"49 Stat. 666","children":[],"tail":", known as the Historic Sites Act of 1935 and also as the Historic Sites, Buildings, and Antiquities Act, which enacted sections 461 to 467 of this title. The Act was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1866/a"},"text":"section 1866(a) of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and sections 102303 and 102304 and chapter 3201 of Title 54, National Park Service and Related Programs, by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 4(a)(1), 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3260, 3272. For complete classification of this Act to the Code, see Tables. For disposition of former sections of this title, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id777b31f1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (d)(1), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":"” substituted for “section 12(b) of the National Park Service General Authorities Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1a–7/b"},"text":"16 U.S.C. 1a–7(b)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/e"},"text":"Pub. L. 113–287, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3272"},"text":"128 Stat. 3272","children":[],"tail":", which Act enacted Title 54, National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id777b31f2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (d)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289"},"text":"Pub. L. 114–289","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ttt"},"text":"section 410ttt of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
