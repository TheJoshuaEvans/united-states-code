{"tag":"section","attrib":{"id":"id79e728eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003"},"text":null,"children":[{"tag":"num","attrib":{"value":"4003"},"text":"§ 4003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e728ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “consumer education” means actions undertaken to inform consumers on matters related to the consumption of fish and fish products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “council” means a seafood promotional council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4009"},"text":"section 4009 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “fish” means finfish, mollusks, crustaceans, and all other forms of aquatic animal life used for human consumption; the term does not include marine mammals and seabirds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Fund” means the Fisheries Promotional Fund established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4008"},"text":"section 4008 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “harvester” means any individual who is in the business of catching or growing fish for purposes of sale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “importer” means any person in the business of importing fish or fish products into the United States from another country for commercial purposes or who acts as an agent, broker, or consignee for any person or nation that produces, processes or markets fish or fish products outside of the United States for sale or other commercial purpose in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “marketer” means any person who is in the business of selling fish or fish products in the wholesale, retail, or restaurant trade, but whose primary business function is not the processing or packaging of fish or fish products in preparation for sale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “marketing and promotion” means an activity aimed at encouraging the consumption of fish or fish products or expanding or maintaining commercial markets for fish or fish products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “member” means any person serving on the National Council or on any council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “National Council” means the National Fish and Seafood Promotional Council established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4004"},"text":"section 4004 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “person” means any individual, group of individuals, partnership, corporation, association, cooperative, or any private entity organized or existing under the laws of the United States or any State, commonwealth, territory or possession of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “processor” means any person who is in the business of preparing or packaging fish or fish products (including fish of the processor’s own harvesting) for sale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “receiver” means any person who owns fish processing vessels and any person in the business of acquiring fish directly from harvesters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “research” means any type of research designed to advance the image, desirability, usage, marketability, production or quality of fish and fish products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “sector” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e728fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sector consisting of harvesters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e728fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sector consisting of importers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e728fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/15/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sector consisting of marketers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e728fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/15/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sector consisting of processors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e728ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/15/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sector consisting of receivers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e72900-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/15/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consumer sector consisting of persons professionally engaged in the dissemination of information pertaining to the nutritional benefits and preparation of fish and fish products;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e72901-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Commerce, or the Secretary’s designee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e72902-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4003/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States” means the several States, the District of Columbia, Puerto Rico, the Virgin Islands, Guam, American Samoa, the Northern Mariana Islands and any other territory, possession, or commonwealth of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e72903-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659/tII/s204"},"text":"Pub. L. 99–659, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3716"},"text":"100 Stat. 3716","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
