{"tag":"section","attrib":{"id":"id772549c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272f"},"text":null,"children":[{"tag":"num","attrib":{"value":"272f"},"text":"§ 272f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to carry out the purposes of this subchapter, not to exceed, however, $275,000 for the acquisition of lands and interests in lands and not to exceed $1,031,800 (April 1970 prices) for development, plus or minus such amounts, if any, as may be justified by reason of ordinary fluctuations in construction costs as indicated by engineering cost indices applicable to the types of construction involved herein. The sums authorized in this section shall be available for acquisition and development undertaken subsequent to ","children":[{"tag":"date","attrib":{"date":"1971-11-12"},"text":"November 12, 1971","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id772549c4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/155/s7"},"text":"Pub. L. 92–155, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-11-12"},"text":"Nov. 12, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/423"},"text":"85 Stat. 423","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/578/tI/s101/1"},"text":"Pub. L. 94–578, title I, § 101(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2732"},"text":"90 Stat. 2732","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id772549c5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id772549c6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id772549c7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578"},"text":"Pub. L. 94–578","children":[],"tail":" substituted “$275,000” for “$125,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
