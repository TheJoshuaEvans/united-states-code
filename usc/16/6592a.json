{"tag":"section","attrib":{"id":"id7a16c3de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6592a"},"text":"§ 6592a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ecosystem restoration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a16c3df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary of the Interior and the Secretary of Agriculture, acting through the Chief of the Forest Service, for the activities described in subsection (b), $2,130,000,000 for the period of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a16c3e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts made available under subsection (a) for the period of fiscal years 2022 through 2026—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a16c3e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" $300,000,000 shall be made available, in accordance with subsection (c), to the Secretary of the Interior and the Secretary of Agriculture—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c3e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a16c3e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entering into contracts, including stewardship contracts or agreements, the purpose of each of which shall be to restore ecological health on not fewer than 10,000 acres of Federal land, including Indian forest land or rangeland, and for salaries and expenses associated with preparing and executing those contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a16c3e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a Working Capital Fund that may be accessed by the Secretary of the Interior or the Secretary of Agriculture to fund requirements of contracts described in clause (i), including cancellation and termination costs, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6591c/h"},"text":"section 6591c(h) of this title","children":[],"tail":", and periodic payments over the span of the contract period; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c3e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" of which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a16c3e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 shall be made available to the Secretary of the Interior to enter into contracts described in subparagraph (A)(i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a16c3e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $150,000,000 shall be made available to the Secretary of Agriculture to enter into contracts described in subparagraph (A)(i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a16c3e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 shall be made available until expended to the Secretary of the Interior, notwithstanding any other provision of this Act, to establish the Working Capital Fund described in subparagraph (A)(ii);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c3e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" $200,000,000 shall be made available to provide to States and Indian Tribes for implementing restoration projects on Federal land pursuant to good neighbor agreements entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2113a"},"text":"section 2113a of this title","children":[],"tail":" or agreements entered into under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3115a/b"},"text":"section 3115a(b) of title 25","children":[],"tail":", of which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c3ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $40,000,000 shall be made available to the Secretary of the Interior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c3eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $160,000,000 shall be made available to the Secretary of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c3ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $400,000,000 shall be made available to the Secretary of Agriculture to provide financial assistance to facilities that purchase and process byproducts from ecosystem restoration projects in accordance with subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c3ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" $400,000,000 shall be made available to the Secretary of the Interior to provide grants to States, territories of the United States, and Indian Tribes for implementing voluntary ecosystem restoration projects on private or public land, in consultation with the Secretary of Agriculture, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c3ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritizes funding cross-boundary projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c3ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires matching funding from the State, territory of the United States, or Indian Tribe to be eligible to receive the funding;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c3f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 shall be made available to the Secretary of Agriculture to award grants to States and Indian Tribes to establish rental programs for portable skidder bridges, bridge mats, or other temporary water crossing structures, to minimize stream bed disturbance on non-Federal land and Federal land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c3f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" $200,000,000 shall be made available for invasive species detection, prevention, and eradication, including conducting research and providing resources to facilitate detection of invasive species at points of entry and awarding grants for eradication of invasive species on non-Federal land and on Federal land, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c3f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 shall be made available to the Secretary of the Interior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c3f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 shall be made available to the Secretary of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c3f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 shall be made available to restore, prepare, or adapt recreation sites on Federal land, including Indian forest land or rangeland, in accordance with subsection (e);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c3f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" $200,000,000 shall be made available to restore native vegetation and mitigate environmental hazards on mined land on Federal and non-Federal land, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c3f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 shall be made available to the Secretary of the Interior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c3f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 shall be made available to the Secretary of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c3f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" $200,000,000 shall be made available to establish and implement a national revegetation effort on Federal and non-Federal land, including to implement the National Seed Strategy for Rehabilitation and Restoration, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c3f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $70,000,000 shall be made available to the Secretary of the Interior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c3fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $130,000,000 shall be made available to the Secretary of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c3fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $80,000,000 shall be made available to the Secretary of Agriculture, in coordination with the Secretary of the Interior, to establish a collaborative-based, landscape-scale restoration program to restore water quality or fish passage on Federal land, including Indian forest land or rangeland, in accordance with subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a16c3fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ecological health restoration contracts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a16c3fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of list of projects to congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Until the date on which all of the amounts made available to carry out subsection (b)(1)(A)(i) are expended, not later than 90 days before the end of each fiscal year, the Secretary of the Interior and the Secretary of Agriculture shall submit to the Committee on Energy and Natural Resources and the Committee on Appropriations of the Senate and the Committee on Natural Resources and the Committee on Appropriations of the House of Representatives a list of projects to be funded under that subsection in the subsequent fiscal year, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c3fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of each project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c3ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the cost, including salaries and expenses, for the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c400-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternate allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appropriations Acts may provide for alternate allocation of amounts made available under subsection (b)(1), consistent with the allocations under subparagraph (B) of that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c401-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lack of alternate allocations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If Congress has not enacted legislation establishing alternate allocations described in paragraph (2) by the date on which the Act making full-year appropriations for the Department of the Interior, Environment, and Related Agencies for the applicable fiscal year is enacted into law, amounts made available under subsection (b)(1)(B) shall be allocated by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a16c402-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wood products infrastructure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture, in coordination with the Secretary of the Interior, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a16c403-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop a ranking system that categorizes units of Federal land, including Indian forest land or rangeland, with regard to treating areas at risk of unnaturally severe wildfire or insect or disease infestation, as being—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c404-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" very low priority for ecological restoration involving vegetation removal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c405-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low priority for ecological restoration involving vegetation removal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c406-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medium priority for ecological restoration involving vegetation removal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c407-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high priority for ecological restoration involving vegetation removal; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c408-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" very high priority for ecological restoration involving vegetation removal;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c409-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determine, for a unit identified under paragraph (1) as being high or very high priority for ecological restoration involving vegetation removal, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c40a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sawmill or other wood-processing facility exists in close proximity to, or a forest worker is seeking to conduct restoration treatment work on or in close proximity to, the unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c40b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the presence of a sawmill or other wood-processing facility would substantially decrease or does substantially decrease the cost of conducting ecological restoration projects involving vegetation removal;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c40c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with any conditions the Secretary of Agriculture determines to be necessary, using the amounts made available under subsection (b)(3), provide financial assistance, including a low-interest loan or a loan guarantee, to an entity seeking to establish, reopen, retrofit, expand, or improve a sawmill or other wood-processing facility in close proximity to a unit of Federal land that has been identified under paragraph (1) as high or very high priority for ecological restoration, if the presence of a sawmill or other wood-processing facility would substantially decrease or does substantially decrease the cost of conducting ecological restoration projects involving vegetation removal on the unit of Federal land, including Indian forest land or rangeland, as determined under paragraph (2)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c40d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent practicable, when allocating funding to units of Federal land for ecological restoration projects involving vegetation removal, give priority to a unit of Federal land that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c40e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been identified under paragraph (1) as being high or very high priority for ecological restoration involving vegetation removal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c40f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has a sawmill or other wood-processing facility—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a16c410-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that, as determined under paragraph (2)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a16c411-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exists in close proximity to the unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a16c412-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does substantially decrease the cost of conducting ecological restoration projects involving vegetation removal on the unit; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a16c413-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has received financial assistance under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a16c414-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreation sites","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a16c415-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Site restoration and improvements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts made available under subsection (b)(7), $45,000,000 shall be made available to the Secretary of the Interior and $35,000,000 shall be made available the ","children":[{"tag":"ref","attrib":{"idref":"fn002832"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002832"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “to”."}],"tail":" Secretary of Agriculture to restore, prepare, or adapt recreation sites on Federal land, including Indian forest land or rangeland, that have experienced or may likely experience visitation and use beyond the carrying capacity of the sites."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c416-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public use recreation cabins","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c417-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts made available under subsection (b)(7), $20,000,000 shall be made available to the Secretary of Agriculture for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a16c418-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation, repair, reconstruction, and construction of public use recreation cabins on National Forest System land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a16c419-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent necessary, the repair or reconstruction of historic buildings that are to be outleased under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s306121"},"text":"section 306121 of title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c41a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount described in subparagraph (A), $5,000,000 shall be made available to the Secretary of Agriculture for associated salaries and expenses in carrying out that subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c41b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture may enter into a lease or cooperative agreement with a State, Indian Tribe, local government, or private entity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a16c41c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the activities described in subparagraph (A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a16c41d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to manage the renting of a cabin or building described in subparagraph (A) to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c41e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project shall not be eligible for funding under this subsection if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c41f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding for the project would be used for deferred maintenance, as defined by Federal Accounting Standards Advisory Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c420-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior or the Secretary of Agriculture has identified the project for funding from the National Parks and Public Land Legacy Restoration Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s200402/a"},"text":"section 200402(a) of title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a16c421-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaborative-based, aquatic-focused, landscape-scale restoration program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary of Agriculture shall, in coordination with the Secretary of the Interior and using the amounts made available under subsection (b)(10)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a16c422-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" solicit collaboratively developed proposals that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c423-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are for 5-year projects to restore fish passage or water quality on Federal land and non-Federal land to the extent allowed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1011a/a"},"text":"section 1011a(a) of this title","children":[],"tail":", including Indian forest land or rangeland;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c424-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain proposed accomplishments and proposed non-Federal funding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c425-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request not more than $5,000,000 in funding made available under subsection (b)(10);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c426-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" select project proposals for funding in a manner that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c427-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gives priority to a project proposal that would result in the most miles of streams being restored for the lowest amount of Federal funding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c428-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discontinues funding for a project that fails to achieve the results included in a proposal submitted under paragraph (1) for more than 2 consecutive years; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c429-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" publish a list of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c42a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all of the priority watersheds on National Forest System land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c42b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the condition of each priority watershed on ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c42c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592a/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the condition of each priority watershed on the date that is 5 years after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a16c42d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tVIII/s40804"},"text":"Pub. L. 117–58, div. D, title VIII, § 40804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1105"},"text":"135 Stat. 1105","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a16c42e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a16c42f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a16c430-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b)(1)(B)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/429"},"text":"135 Stat. 429","children":[],"tail":", known as the Infrastructure Investment and Jobs Act. For complete classification of this Act to the Code, see Short Title of 2021 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a16c431-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Infrastructure Investment and Jobs Act, and not as part of the Healthy Forests Restoration Act of 2003 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a16c432-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attr