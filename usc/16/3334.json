{"tag":"section","attrib":{"id":"id79b51d5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3334"},"text":null,"children":[{"tag":"num","attrib":{"value":"3334"},"text":"§ 3334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of State program by Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b51d5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3334/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a continuing review of the State program to determine whether the program remains consistent with this chapter or other applicable law. Such review shall include a biennial audit of the rec­ords of the State program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b51d5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3334/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action upon finding of noncompliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary finds that the program or the administration thereof is no longer in compliance with this subchapter, he shall reduce or discontinue distribution of funds under this subchapter, or take other appropriate action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b51d60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3334/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of certain moneys","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary finds that any money provided to the State or obtained by the State from the resale of any fishing or charter vessel purchased under the program is not being used in accordance with the provisions of this subchapter, the Secretary shall recover from the fund, and place in the United States Treasury, such moneys.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b51d61-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/561/tI/s133"},"text":"Pub. L. 96–561, title I, § 133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3285"},"text":"94 Stat. 3285","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
