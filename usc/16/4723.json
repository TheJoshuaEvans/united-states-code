{"tag":"section","attrib":{"id":"id79f5815d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723"},"text":null,"children":[{"tag":"num","attrib":{"value":"4723"},"text":"§ 4723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional coordination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f5815e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes panel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f5815f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days following ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"November 29, 1990","children":[],"tail":", the Task Force shall request that the Great Lakes Commission (established under Article IV of the Great Lakes Compact to which the Congress granted consent in the Act of "},{"tag":"date","attrib":{"date":"1968-07-24"},"text":"July 24, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/419"},"text":"P.L. 90–419","children":[],"tail":") convene a panel of Great Lakes region representatives from Federal, State and local agencies and from private environmental and commercial interests to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f58160-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify priorities for the Great Lakes region with respect to aquatic nuisance species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f58161-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Task Force regarding programs to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4722/i"},"text":"section 4722(i) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f58162-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Task Force in coordinating Federal aquatic nuisance species program activities in the Great Lakes region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f58163-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate, where possible, aquatic nuisance species program activities in the Great Lakes region that are not conducted pursuant to this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f58164-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice to public and private individuals and entities concerning methods of controlling aquatic nuisance species; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f58165-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit annually a report to the Task Force describing activities within the Great Lakes region related to aquatic nuisance species prevention, research, and control.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f58166-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force shall request that the Great Lakes Fishery Commission provide information to the panel convened under this subsection on technical and policy matters related to the international fishery resources of the Great Lakes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f58167-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Canadian participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The panel convened under this subsection is encouraged to invite representatives from the Federal, provincial or territorial governments of Canada to participate as observers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f58168-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Western regional panel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"October 26, 1996","children":[],"tail":", the Task Force shall request a Western regional panel, comprised of Western region representatives from Federal, State, and local agencies and from private environmental and commercial interests, to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f58169-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify priorities for the Western region with respect to aquatic nuisance species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f5816a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Task Force regarding an education, monitoring (including inspection), prevention, and control program to prevent the spread of the zebra mussel west of the 100th Meridian pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4722/i"},"text":"section 4722(i) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f5816b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate, where possible, other aquatic nuisance species program activities in the Western region that are not conducted pursuant to this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f5816c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop an emergency response strategy for Federal, State, and local entities for stemming new invasions of aquatic nuisance species in the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f5816d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice to public and private individuals and entities concerning methods of preventing and controlling aquatic nuisance species infestations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f5816e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit annually a report to the Task Force describing activities within the Western region related to aquatic nuisance species prevention, research, and control.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f5816f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional regional panels","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f58170-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the development and use of regional panels and other similar entities in regions in addition to the Great Lakes and Western regions (including providing financial assistance for the development and use of such entities) to carry out, with respect to those regions, activities that are similar to the activities described in subsections (a) and (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f58171-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4723/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with regional panels and similar entities that carry out the activities described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f58172-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646/tI/s1203"},"text":"Pub. L. 101–646, title I, § 1203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4769"},"text":"104 Stat. 4769","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/e/5"},"text":"Pub. L. 104–332, § 2(e)(5)","children":[],"tail":", (h)(1), "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4087"},"text":"110 Stat. 4087","children":[],"tail":", 4091; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIII/s11327/e/3"},"text":"Pub. L. 117–263, div. K, title CXIII, § 11327(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4098"},"text":"136 Stat. 4098","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f58173-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f58174-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79f58175-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1968-07-24"},"text":"July 24, 1968","children":[],"tail":", referred to in subsec. (a)(1), is "},{"tag":"ref","attrib":{"href":"/us/pl/90/419"},"text":"Pub. L. 90–419","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-24"},"text":"July 24, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/414"},"text":"82 Stat. 414","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(1)(D) and (b)(3), was in the original “this Act”, which, to reflect the probable intent of Congress, was translated as reading “this title” meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646"},"text":"Pub. L. 101–646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4761"},"text":"104 Stat. 4761","children":[],"tail":", known as the Nonindigenous Aquatic Nuisance Prevention and Control Act of 1990, which is classified principally to this chapter. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4701"},"text":"section 4701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79f58176-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11327/e/3/A"},"text":"Pub. L. 117–263, § 11327(e)(3)(A)","children":[],"tail":", inserted “and” after “research,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11327/e/3/B"},"text":"Pub. L. 117–263, § 11327(e)(3)(B)","children":[],"tail":", substituted “encouraged” for “encourage”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/h/1"},"text":"Pub. L. 104–332, § 2(h)(1)","children":[],"tail":", made technical amendment to "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/s1203"},"text":"Pub. L. 101–646, § 1203","children":[],"tail":", which enacted this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/e/5/A"},"text":"Pub. L. 104–332, § 2(e)(5)(A)","children":[],"tail":", substituted “Regional” for “Great Lakes regional” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/e/5/B"},"text":"Pub. L. 104–332, § 2(e)(5)(B)","children":[],"tail":"–(F), designated existing provisions as subsec. (a) and inserted subsec. heading, redesignated former subsec. (a) as par. (1), and former pars. (1) to (6) as subpars. (A) to (F), respectively, of par. (1), in par. (1) inserted “region” before “representatives” in introductory provisions and after “Great Lakes” in subpars. (A), (C), (D), and (F), redesignated subsecs. (b) and (c) as pars. (2) and (3), respectively, of subsec. (a), substituted “this subsection” for “this section” in those pars., and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
