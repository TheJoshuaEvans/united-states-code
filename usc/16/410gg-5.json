{"tag":"section","attrib":{"id":"id77550be2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410gg–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"410gg–5"},"text":"§ 410gg–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; entrance or admission fees prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to the sums previously authorized to be appropriated for Biscayne National Monument, there are authorized to be appropriated such sums as may be necessary for the administration of the park, and not to exceed $8,500,000 for the acquisition of lands and interests therein, as provided in this subchapter. Notwithstanding any other provision of law, no fees shall be charged for entrance or admission to the park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77550be3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/287/tI/s106"},"text":"Pub. L. 96–287, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-28"},"text":"June 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/600"},"text":"94 Stat. 600","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77550be4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77550be5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77550be6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorizations Effective ","children":[{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":"; Contractual, Obligatory, and Payment Authority Provided in Appropriations"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/287/tIV/s401"},"text":"Pub. L. 96–287, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-28"},"text":"June 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/602"},"text":"94 Stat. 602","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/287/tIV/s401"},"text":"“Authorizations of moneys to be appropriated under this Act [","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/287"},"text":"Pub. L. 96–287","children":[],"tail":"] shall be effective "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":". Notwithstanding any other provision of this Act, authority to enter into contracts to incur obligations, or to make payments under this Act shall be effective only to the extent, and in such amounts, as are provided in advance in appropriation Acts.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
