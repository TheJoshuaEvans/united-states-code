{"tag":"section","attrib":{"id":"id78bd27b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831o"},"text":null,"children":[{"tag":"num","attrib":{"value":"831o"},"text":"§ 831o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion of unfinished plants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board, whenever the President deems it advisable, is empowered and directed to complete Dam Numbered 2 at Muscle Shoals, Alabama, and the steam plant at nitrate plant numbered 2, in the vicinity of Muscle Shoals, by installing in Dam Numbered 2 the additional power units according to the plans and specifications of said dam, and the additional power unit in the steam plant at nitrate plant numbered 2.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78bd27b1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-18/ch32/s16"},"text":"May 18, 1933, ch. 32, § 16","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/67"},"text":"48 Stat. 67","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dC/tVI/s603/a/2"},"text":"Pub. L. 108–447, div. C, title VI, § 603(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2966"},"text":"118 Stat. 2966","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78bd27b2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78bd27b3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"i