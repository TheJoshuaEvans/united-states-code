{"tag":"section","attrib":{"id":"id772300a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272"},"text":null,"children":[{"tag":"num","attrib":{"value":"272"},"text":"§ 272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id772300a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id772300a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to valid existing rights, the lands, waters, and interests therein within the boundary generally depicted on the map entitled “Boundary Map, Proposed Arches National Park, Utah,” numbered RPSSC–138–20, 001E and dated September 1969, are hereby established as the Arches National Park (hereinafter referred to as the “park”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id772300a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanded boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective on ","children":[{"tag":"date","attrib":{"date":"1998-10-30"},"text":"October 30, 1998","children":[],"tail":", the boundary of the park shall include the area consisting of approximately 3,140 acres and known as the “Lost Spring Canyon Addition”, as depicted on the map entitled “Boundary Map, Arches National Park, Lost Spring Canyon Addition”, numbered 138/60,000–B, and dated April 1997."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id772300a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maps described in paragraphs (1) and (2) shall be on file and available for public inspection in the offices of the National Park Service, Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id772300a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abolition of Arches National Monument; funds of monument available for park; administration of lands excluded from monument","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Arches National Monument is hereby abolished, and any funds available for purposes of the monument shall be available for purposes of the park. Federal lands, waters, and interests therein excluded from the monument by this subchapter shall be administered by the Secretary of the Interior (hereinafter referred to as the “Secretary”) in accordance with the laws applicable to the public lands of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id772300a8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/155/s1"},"text":"Pub. L. 92–155, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-11-12"},"text":"Nov. 12, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/422"},"text":"85 Stat. 422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/329/s2/a"},"text":"Pub. L. 105–329, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3060"},"text":"112 Stat. 3060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id772300a9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id772300aa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id772300ab-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/329"},"text":"Pub. L. 105–329","children":[],"tail":" inserted section designation and catchline and in subsec. (a) inserted subsec. heading, inserted par. (1) designation and heading before first sentence, added par. (2), inserted par. (3) designation and heading before second sentence and substituted “The maps described in paragraphs (1) and (2)” for “Such map”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id772300ac-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id772300ad-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/329/s1"},"text":"Pub. L. 105–329, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3060"},"text":"112 Stat. 3060","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/329/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s272g"},"text":"section 272g of this title","children":[],"tail":", amending this section and sections 272a, 272b, and 272d of this title, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s272g"},"text":"section 272g of this title","children":[],"tail":"] may be cited as the ‘Arches National Park Expansion Act of 1998’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
