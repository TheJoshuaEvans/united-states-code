{"tag":"section","attrib":{"id":"id7839ee56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s542a"},"text":null,"children":[{"tag":"num","attrib":{"value":"542a"},"text":"§ 542a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Congress finds that the high altitude and freedom from air pollution and night luminosity caused by human activity, make the research site uniquely suited to the conduct of research probes into thunder clouds and for other atmospheric and astronomical research purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7839ee57-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/550/tII/s202"},"text":"Pub. L. 96–550, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-19"},"text":"Dec. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3225"},"text":"94 Stat. 3225","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
