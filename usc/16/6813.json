{"tag":"section","attrib":{"id":"id7a1df0ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6813"},"text":null,"children":[{"tag":"num","attrib":{"value":"6813"},"text":"§ 6813.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other laws and fee collection authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1df0ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6813/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal and State laws unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall authorize Federal hunting or fishing licenses or fees or charges for commercial or other activities not related to recreation, affect any rights or authority of the States with respect to fish and wildlife, or repeal or modify any provision of law that permits States or political subdivisions of States to share in the revenues from Federal lands or, except as provided in subsection (b), any provision of law that provides that any fees or charges collected at particular Federal areas be used for or credited to specific purposes or special funds as authorized by that provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1df0ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6813/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to revenue allocation laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts collected under this chapter, and the existence of a fee management agreement with a governmental entity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6805/a"},"text":"section 6805(a) of this title","children":[],"tail":", may not be taken into account for the purposes of any of the following laws:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1df0af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6813/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The sixth paragraph under the heading “","children":[{"tag":"inline","attrib":{},"text":"Forest service","children":[],"tail":"” in the Act of "},{"tag":"date","attrib":{"date":"1908-05-23"},"text":"May 23, 1908","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s500"},"text":"16 U.S.C. 500","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df0b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6813/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-01/s13"},"text":"Section 13 of the Act of March 1, 1911","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s500"},"text":"16 U.S.C. 500","children":[],"tail":"; commonly known as the Weeks Act)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df0b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6813/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The fourteenth paragraph under the heading “","children":[{"tag":"inline","attrib":{},"text":"Forest service","children":[],"tail":"” in the Act of "},{"tag":"date","attrib":{"date":"1913-03-04"},"text":"March 4, 1913","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s501"},"text":"16 U.S.C. 501","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df0b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16