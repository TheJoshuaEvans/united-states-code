{"tag":"section","attrib":{"id":"id78b38bb8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s825o–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"825o–1"},"text":"§ 825o–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of certain provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78b38bb9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s825o–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person to violate any provision of subchapter II or any rule or order issued under any such provision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b38bba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s825o–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who violates any provision of subchapter II or any provision of any rule or order thereunder shall be subject to a civil penalty of not more than $1,000,000 for each day that such violation continues. Such penalty shall be assessed by the Commission, after notice and opportunity for public hearing, in accordance with the same provisions as are applicable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s823b/d"},"text":"section 823b(d) of this title","children":[],"tail":" in the case of civil penalties assessed under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s823b"},"text":"section 823b of this title","children":[],"tail":". In determining the amount of a proposed penalty, the Commission shall take into consideration the seriousness of the violation and the efforts of such person to remedy the violation in a timely manner."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78b38bbb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"June 10, 1920, ch. 285","children":[],"tail":", pt. III, § 316A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tVII/s725/b"},"text":"Pub. L. 102–486, title VII, § 725(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2920"},"text":"106 Stat. 2920","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXII/s1284/e"},"text":"Pub. L. 109–58, title XII, § 1284(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/980"},"text":"119 Stat. 980","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78b38bbc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78b38bbd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78b38bbe-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" substituted “subchapter II” for “section 824j, 824k, 824"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":", or 824m of this title” in subsecs. (a) and (b) and “$1,000,000” for “$10,000” in subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78b38bbf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78b38bc0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"State Authorities; Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in this section to be construed as affecting or intending to affect, or in any way to interfere with, authority of any State or local government relating to environmental protection or siting of facilities, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s731"},"text":"section 731 of Pub. L. 102–486","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s796"},"text":"section 796 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
