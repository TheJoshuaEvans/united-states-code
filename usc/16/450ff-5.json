{"tag":"section","attrib":{"id":"id77a15846-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ff–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"450ff–5"},"text":"§ 450ff–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative jurisdiction of Federal lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The heads of executive departments may transfer to the Secretary of the Interior, without exchange of funds, administrative jurisdiction over such federally owned lands and other property under their administrative jurisdictions within the revised boundary as may become excess to the needs of their respective agencies, for inclusion in the Fort Vancouver National Historic Site.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a15847-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/78/s3"},"text":"Pub. L. 87–78, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-06-30"},"text":"June 30, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/197"},"text":"75 Stat. 197","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77a15848-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77a15849-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77a1584a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“National Historic Site” substituted in text for “National Monument” in view of redesignation of Fort Vancouver National Monument as Fort Vancouver National Historic Site by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/78"},"text":"Pub. L. 87–78","children":[],"tail":", classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s450ff–6"},"text":"section 450ff–6 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
