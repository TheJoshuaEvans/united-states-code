{"tag":"section","attrib":{"id":"id7a120a2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6591a"},"text":"§ 6591a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of treatment areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a120a2f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of declining forest health","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “declining forest health” means a forest that is experiencing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a30-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially increased tree mortality due to insect or disease infestation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a31-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dieback due to infestation or defoliation by insects or disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a32-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of treatment areas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", the Secretary shall, if requested by the Governor of the State, designate as part of an insect and disease treatment program 1 or more landscape-scale areas, such as subwatersheds (sixth-level hydrologic units, according to the System of Hydrologic Unit Codes of the United States Geological Survey), in at least 1 national forest in each State that is experiencing an insect or disease epidemic."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the end of the 60-day period described in paragraph (1), the Secretary may designate additional landscape-scale areas under this section as needed to address insect or disease threats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be designated a landscape-scale area under subsection (b), the area shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experiencing declining forest health, based on annual forest health surveys conducted by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at risk of experiencing substantially increased tree mortality over the next 15 years due to insect or disease infestation, based on the most recent National Insect and Disease Risk Map published by the Forest Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an area in which the risk of hazard trees poses an imminent risk to public infrastructure, health, or safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of areas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a3a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may carry out priority projects on Federal land in the areas designated under subsection (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a120a3b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the risk or extent of, or increase the resilience to, insect or disease infestation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120a3c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce hazardous fuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a3d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any project under paragraph (1) for which a public notice to initiate scoping is issued on or before ","children":[{"tag":"date","attrib":{"date":"2023-09-30"},"text":"September 30, 2023","children":[],"tail":", may be carried out in accordance with subsections (b), (c), and (d) of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6512"},"text":"section 6512 of this title","children":[],"tail":", and sections 6514, 6515, and 6516 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Projects carried out under this subsection shall be considered authorized hazardous fuel reduction projects for purposes of the authorities described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a120a40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with the schedule described in subparagraph (B), the Secretary shall issue 2 reports on actions taken to carry out this subsection, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a120a41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the progress towards project goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a120a42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for modifications to the projects and management treatments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120a43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a120a44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not earlier than ","children":[{"tag":"date","attrib":{"date":"2018-09-30"},"text":"September 30, 2018","children":[],"tail":", issue the initial report under subparagraph (A); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a120a45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not earlier than ","children":[{"tag":"date","attrib":{"date":"2024-09-30"},"text":"September 30, 2024","children":[],"tail":", issue the second report under that subparagraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a46-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tree retention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out projects under subsection (d) in a manner that maximizes the retention of old-growth and large trees, as appropriate for the forest type, to the extent that the trees promote stands that are resilient to insects and disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a120a47-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tVI/s602"},"text":"Pub. L. 108–148, title VI, § 602","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVIII/s8204"},"text":"Pub. L. 113–79, title VIII, § 8204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/915"},"text":"128 Stat. 915","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII"},"text":"Pub. L. 115–334, title VIII","children":[],"tail":", §§ 8407(b), 8408, "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4846"},"text":"132 Stat. 4846","children":[],"tail":", 4847.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a120a48-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a120a49-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a120a4a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The authorities provided by each provision of, and each amendment made by, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", to continue, and authorities to be carried out, until the later of "},{"tag":"date","attrib":{"date":"2024-09-30"},"text":"Sept. 30, 2024","children":[],"tail":", or the date specified in the provision of, or amendment made by, "},{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/a"},"text":"section 102(a) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a120a4b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8407/b/1"},"text":"Pub. L. 115–334, § 8407(b)(1)","children":[],"tail":", substituted “subsection (b)—” and subpars. (A) and (B) for “subsection (b) to reduce the risk or extent of, or increase the resilience to, insect or disease infestation in the areas.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8407/b/2"},"text":"Pub. L. 115–334, § 8407(b)(2)","children":[],"tail":", substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8408"},"text":"Pub. L. 115–334, § 8408","children":[],"tail":", struck out subsec. (f). Prior to amendment, text read as follows: “There is authorized to be appropriated to carry out this section $200,000,000 for each of fiscal years 2014 through 2024.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
