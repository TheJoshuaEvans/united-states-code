{"tag":"section","attrib":{"id":"id780f0df3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee"},"text":null,"children":[{"tag":"num","attrib":{"value":"460eeee"},"text":"§ 460eeee.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vinagre Wash Special Management Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id780f0df4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780f0df5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Management Area” means the Vinagre Wash Special Management Area established by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0df6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “map” means the map entitled “Proposed Vinagre Wash Special Management Area and Proposed Wilderness” and dated ","children":[{"tag":"date","attrib":{"date":"2018-12-04"},"text":"December 4, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0df7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “public land” has the meaning given the term “public lands” in section 103 of the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1702"},"text":"43 U.S.C. 1702","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0df8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the State of California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0df9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Vinagre Wash Special Management Area in the State, to be managed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0dfa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the Management Area is to conserve, protect, and enhance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780f0dfb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plant and wildlife values of the Management Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0dfc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the outstanding and nationally significant ecological, geological, scenic, recreational, archaeological, cultural, historic, and other resources of the Management Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0dfd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Management Area shall consist of the public land in Imperial County, California, comprising approximately 81,880 acres, as generally depicted on the map as “Proposed Special Management Area”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0dfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map; legal description","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780f0dff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable, but not later than 3 years, after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall submit a map and legal description of the Management Area to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780f0e00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Natural Resources of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780f0e01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0e02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description submitted under paragraph (1) shall have the same force and effect as if included in this section, except that the Secretary may correct any errors in the map and legal description.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0e03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Copies of the map submitted under paragraph (1) shall be on file and available for public inspection in the appropriate offices of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0e04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780f0e05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall manage the Management Area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780f0e06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that conserves, protects, and enhances the purposes for which the Management Area is established; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780f0e07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id780f0e08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780f0e09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780f0e0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0e0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall allow only those uses that are consistent with the purposes of the Management Area, including hiking, camping, hunting, and sightseeing and the use of motorized vehicles, mountain bikes, and horses on designated routes in the Management Area in a manner that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780f0e0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the purpose of the Management Area described in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780f0e0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures public health and safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780f0e0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with all applicable laws (including regulations), including the Desert Renewable Energy Conservation Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0e0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Off-highway vehicle use","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780f0e10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraphs (B) and (C) and all other applicable laws, the use of off-highway vehicles shall be permitted on routes in the Management Area as generally depicted on the map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780f0e11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may close or permanently reroute a portion of a route described in subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78115702-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent, or allow for restoration of, resource damage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78115703-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect Tribal cultural resources, including the resources identified in the Tribal cultural resources management plan developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410aaa–75/d"},"text":"section 410aaa–75(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78115704-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address public safety concerns; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78115705-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as otherwise required by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78115706-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of additional routes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the 3-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary—"}],"tail":null},{"tag":"clause","attrib":{"id":"id78115707-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall accept petitions from the public regarding additional routes for off-highway vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78115708-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may designate additional routes that the Secretary determines—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78115709-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/3/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would provide significant or unique recreational opportunities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7811570a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/3/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the purposes of the Management Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7811570b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, all Federal land within the Management Area is withdrawn from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7811570c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all forms of entry, appropriation, or disposal under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7811570d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7811570e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" right-of-way, leasing, or disposition under all laws relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7811570f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minerals and mineral materials; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78115710-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solar, wind, and geothermal energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78115711-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No buffer zone","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The establishment of the Management Area shall not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78115712-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create a protective perimeter or buffer zone around the Management Area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78115713-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preclude uses or activities outside the Management Area that are permitted under other applicable laws, even if the uses or activities are prohibited within the Management Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78115714-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of available routes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that visitors to the Management Area have access to adequate notice relating to the availability of designated routes in the Management Area through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78115715-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the placement of appropriate signage along the designated routes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78115716-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distribution of maps, safety education materials, and other information that the Secretary determines to be appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78115717-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restoration of areas that are not designated as open routes, including vertical mulching.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78115718-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stewardship","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with Indian Tribes and other interests, shall develop a program to provide opportunities for monitoring and stewardship of the Management Area to minimize environmental impacts and prevent resource damage from recreational use, including volunteer assistance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78115719-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" route signage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7811571a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restoration of closed routes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7811571b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection of Management Area resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7811571c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recreation education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7811571d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of tribal cultural resources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary, in accordance with chapter 2003 of title 54 and any other applicable law, shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7811571e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and complete a Tribal cultural resources survey of the Management Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7811571f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Quechan Indian Nation and other Indian Tribes demonstrating ancestral, cultural, or other ties to the resources within the Management Area on the development and implementation of the Tribal cultural resources survey under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78115720-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460eeee/f/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may authorize use of the non-wilderness portion of the Management Area by the Secretary of the Navy for Naval Special Warfare Tactical Training, including long-range small unit training and navigation, vehicle concealment, and vehicle sustainment training, consistent with this section and other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78115721-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tI/s109"},"text":"Pub. L. 103–433, title I, § 109","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1421"},"text":"Pub. L. 116–9, title I, § 1421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/696"},"text":"133 Stat. 696","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78115722-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78115723-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78115724-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in subsec. (f)(1)(B)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78115725-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78115726-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/s103"},"text":"Section 103 of Pub. L. 103–433","children":[],"tail":" provided in part that in this subchapter “Secretary” means the Secretary of the Interior."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
