{"tag":"section","attrib":{"id":"id7a1935ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704"},"text":null,"children":[{"tag":"num","attrib":{"value":"6704"},"text":"§ 6704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Institutes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1935cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of the Interior, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1935cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2004-10-05"},"text":"October 5, 2004","children":[],"tail":", establish Institutes to promote the use of adaptive ecosystem management to reduce the risk of wildfires, and restore the health of forest and woodland ecosystems, in the interior West; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance to the Institutes to promote the use of collaborative processes and adaptive ecosystem management in accordance with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1935ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1935cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing Institutes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may designate an institute in existence on ","children":[{"tag":"date","attrib":{"date":"2004-10-05"},"text":"October 5, 2004","children":[],"tail":", to serve as an Institute established under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the Institutes established under this chapter, the Secretary shall establish 1 Institute in each of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1935d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State of Arizona, to be located at Northern Arizona University;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1935d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State of New Mexico, to be located at New Mexico Highlands University, while engaging the full resources of the consortium of universities represented in the Institute of Natural Resource Analysis and Management (INRAM); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1935d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State of Colorado.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1935d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Institute shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1935d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, conduct research on, transfer, promote, and monitor restoration-based hazardous fuel reduction treatments to reduce the risk of severe wildfires and improve the health of dry forest and woodland ecosystems in the interior West;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" synthesize and adapt scientific findings from conventional research to implement restoration-based hazardous fuel reduction treatments on a landscape scale using an adaptive ecosystem management framework;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" translate for and transfer to affected entities any scientific and interdisciplinary knowledge about restoration-based hazardous fuel reduction treatments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist affected entities with the design of adaptive management approaches (including monitoring) for the implementation of restoration-based hazardous fuel reduction treatments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide peer-reviewed annual reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1935da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Institute shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1935db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and demonstrate capabilities in the natural, physical, social, and policy sciences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explicitly integrate those disciplines in the performance of the duties listed in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1935dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Institute may cooperate with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1935de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" researchers and cooperative extension programs at colleges, community colleges, and universities in the States of Arizona, New Mexico, and Colorado that have a demonstrated capability to conduct research described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other organizations and entities in the interior West (such as the Western Governors’ Association).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1935e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual work plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of the receipt of funds made available under this chapter, for each fiscal year, each Institute shall develop in consultation with the Secretary, for review by the Secretary, in consultation with the Secretary of the Interior, an annual work plan that includes assurances, satisfactory to the Secretaries, that the proposed work of the Institute will serve the informational needs of affected entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1935e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6704/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of additional Institutes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If after 2 years after ","children":[{"tag":"date","attrib":{"date":"2004-10-05"},"text":"October 5, 2004","children":[],"tail":", the Secretary finds that the Institute model established at the locations named in subsection (b)(2) would be constructive for other interior West States, the Secretary may establish 1 institute in each of those States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1935e2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/317/s5"},"text":"Pub. L. 108–317, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-05"},"text":"Oct. 5, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1207"},"text":"118 Stat. 1207","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
