{"tag":"section","attrib":{"id":"id78e597b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1110"},"text":null,"children":[{"tag":"num","attrib":{"value":"1110"},"text":"§ 1110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78e597b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Government shall not be liable for any act or omission of the Commission or of any person employed by, or assigned or detailed to, the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e597b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment; exemption of property from attachment, execution, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any liability of the Commission shall be met from funds of the Commission to the extent that it is not covered by insurance, or otherwise. Property belonging to the Commission shall be exempt from attachment, execution, or other process for satisfaction of claims, debts, or judgments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e597b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1110/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual members of Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No liability of the Commission shall be imputed to any member of the Commission solely on the basis that he occupies the position of member of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78e597b5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/363/s11"},"text":"Pub. L. 88–363, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-07"},"text":"July 7, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/301"},"text":"78 Stat. 301","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
