{"tag":"section","attrib":{"id":"id7851bc53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k"},"text":null,"children":[{"tag":"num","attrib":{"value":"583k"},"text":"§ 583k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7851bc54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Forest System features a world-class trail system with over 157,000 miles of trails that provide world-class opportunities for hiking, horseback riding, hunting, mountain bicycling, motorized vehicles, and other outdoor activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" According to the Government Accountability Office, the Forest Service is only able to maintain about one-quarter of National Forest System trails to the agency standard, and the agency faces a trail maintenance backlog of $314 million, and an additional backlog of $210 million in annual maintenance, capital improvements, and operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The lack of maintenance on National Forest System trails threatens access to public lands, and may cause increased environmental damage, threaten public safety, and increase future maintenance costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal budget limitations require solutions to National Forest System trail maintenance issues that make more efficient use of existing resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Volunteers, partners, and outfitters and guides play an important role in maintaining National Forest System trails, and a comprehensive strategy is needed to ensure that volunteers and partners are used as effectively as possible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7851bc59-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/245/s2"},"text":"Pub. L. 114–245, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-11-28"},"text":"Nov. 28, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/990"},"text":"130 Stat. 990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7851bc5a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7851bc5b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7851bc5c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/245/s1/a"},"text":"Pub. L. 114–245, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-11-28"},"text":"Nov. 28, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/990"},"text":"130 Stat. 990","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/245/s1/a"},"text":"“This Act [enacting this subchapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s558c"},"text":"section 558c of this title","children":[],"tail":"] may be cited as the ‘National Forest System Trails Stewardship Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
