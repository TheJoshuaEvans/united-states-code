{"tag":"section","attrib":{"id":"id785b58a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s601"},"text":null,"children":[{"tag":"num","attrib":{"value":"601"},"text":"§ 601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of moneys collected for depredations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All moneys collected for depredations upon the public lands shall be covered into the Treasury of the United States as other moneys received from the sale of public lands.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id785b58a7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1878-04-30/ch76/s2"},"text":"Apr. 30, 1878, ch. 76, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/20/46"},"text":"20 Stat. 46","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
