{"tag":"section","attrib":{"id":"id7774062b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"410iii–7"},"text":"§ 410iii–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cedar Creek and Belle Grove National Historical Park Advisory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7774062c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Cedar Creek and Belle Grove National Historical Park Advisory Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7774062d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7774062e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary in the preparation and implementation of a general management plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410iii–6"},"text":"section 410iii–6 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7774062f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary with respect to the identification of sites of significance outside the Park boundary deemed necessary to fulfill the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77740630-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77740631-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall be composed of 15 members appointed by the Secretary so as to include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77740632-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative from the Commonwealth of Virginia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77740633-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative each from the local governments of Strasburg, Middletown, Frederick County, Shenandoah County, and Warren County.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77740634-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 representatives of private landowners within the Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77740635-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative from a citizen interest group.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77740636-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative from the Cedar Creek Battlefield Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77740637-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative from Belle Grove, Incorporated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77740638-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative from the National Trust for Historic Preservation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77740639-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative from the Shenandoah Valley Battlefields Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7774063a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 ex-officio representative from the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7774063b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 ex-officio representative from the United States Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7774063c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairperson of the Commission shall be elected by the members to serve a term of one year renewable for one additional year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7774063d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy on the Commission shall be filled in the same manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7774063e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of service","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7774063f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member shall be appointed for a term of 3 years and may be reappointed for not more than 2 successive terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77740640-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the members first appointed under paragraph (1), the Secretary shall appoint—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77740641-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 members for a term of 1 year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77740642-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 members for a term of 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77740643-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 members for a term of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77740644-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extended service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member may serve after the expiration of that member’s term until a successor has taken office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77740645-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Majority rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall act and advise by affirmative vote of a majority of its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77740646-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall meet at least quarterly at the call of the chairperson or a majority of the members of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77740647-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"8 members shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77740648-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members shall serve without pay. Members who are full-time officers or employees of the United States, the Commonwealth of Virginia, or any political subdivision thereof shall receive no additional pay on account of their service on the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77740649-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"While away from their homes or regular places of business in the performance of service for the Commission, members shall be allowed travel expenses, including per diem in lieu of subsistence, in the same manner as persons employed intermittently in the Government service are allowed expenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7774064a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–7/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings; public involvement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may, for purposes of carrying out this subchapter, hold such hearings, sit and act at such times and places, take such public testimony, and receive such evidence, as the Commission considers appropriate. The Commission may not issue subpoenas or exercise any subpoena authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7774064b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/373/s9"},"text":"Pub. L. 107–373, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3107"},"text":"116 Stat. 3107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7774064c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7774064d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7774064e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Commissions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory commissions established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a commission established by the President or an officer of the Federal Government, such commission is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a commission established by the Congress, its duration is otherwise provided for by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
