{"tag":"section","attrib":{"id":"id7892201d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"760–7"},"text":"§ 760–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of fish hatchery in West Virginia","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to establish, construct, equip, operate, and maintain a new fish hatchery in the State of West Virginia.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7892201e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-06/ch978/s1"},"text":"Aug. 6, 1956, ch. 978, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1057"},"text":"70 Stat. 1057","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
