{"tag":"section","attrib":{"id":"id78e59766-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1057"},"text":null,"children":[{"tag":"num","attrib":{"value":"1057"},"text":"§ 1057.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation of annual report by Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the National Fisheries Center and Aquarium shall prepare for the Advisory Board an annual report for presentation to the Secretary of the Interior and to the Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78e59767-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/758/s7"},"text":"Pub. L. 87–758, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-09"},"text":"Oct. 9, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/754"},"text":"76 Stat. 754","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
