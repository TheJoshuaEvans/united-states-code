{"tag":"section","attrib":{"id":"id7a278d99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7301"},"text":null,"children":[{"tag":"num","attrib":{"value":"7301"},"text":"§ 7301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this chapter is to encourage the collaborative, science-based ecosystem restoration of priority forest landscapes through a process that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a278d9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourages ecological, economic, and social sustainability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a278d9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverages local resources with national and private resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a278d9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitates the reduction of wildfire management costs, including through reestablishing natural fire regimes and reducing the risk of uncharacteristic wildfire; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a278d9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demonstrates the degree to which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a278d9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7301/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" various ecological restoration techniques—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a278d9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7301/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieve ecological and watershed health objectives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a278da0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7301/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affect wildfire activity and management costs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a278da1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7301/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of forest restoration byproducts can offset treatment costs while benefitting local rural economies and improving forest health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a278da2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIV/s4001"},"text":"Pub. L. 111–11, title IV, § 4001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1141"},"text":"123 Stat. 1141","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
