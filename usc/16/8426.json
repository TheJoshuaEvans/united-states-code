"tag":"subparagraph","attrib":{"id":"id7a382fca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/7/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Oregon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fcb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/7/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" South Dakota.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fcc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/7/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Texas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fcd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/7/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Utah.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/7/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Washington.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fcf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/7/R"},"text":null,"children":[{"tag":"num","attrib":{"value":"R"},"text":"(R)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wyoming.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382fd0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reclamation project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reclamation ","children":[{"tag":"ref","attrib":{"idref":"fn002872"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002872"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. “Reclamation” is capitalized in this term in section 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–32(3) of this title and in this section."}],"tail":" project” has the meaning given such term in section 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–32(3) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382fd1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretaries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretaries” means each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a382fd2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, acting through the Director of the Bureau of Land Management, the Commissioner of Reclamation, and the Director of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fd3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture, acting through the Chief of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382fd4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “vessel” means any watercraft or other contrivance used or designed for transportation or navigation on, under, or immediately above, water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a382fd5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Bureau of Land Management, Bureau of Reclamation, National Park Service, and Forest Service with respect to certain aquatic resource activities on Federal land and waters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a382fd6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of each Federal land management agency is authorized to carry out inspections and decontamination of vessels entering or leaving Federal land and waters under the jurisdiction of the respective Federal land management agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382fd7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a382fd8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in carrying out an inspection and decontamination under paragraph (1), coordinate with 1 or more partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fd9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Aquatic Nuisance Species Task Force to identify potential improvements and efficiencies in the detection and management of aquatic nuisance species on Federal land and water; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, inspect and decontaminate vessels in a manner that minimizes disruptions to public access for boating and recreation in noncontaminated vessels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382fdb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries may enter into a partnership to lead, collaborate with, or provide technical assistance to a partner—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a382fdc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out an inspection or decontamination of vessels; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fdd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish an inspection and decontamination station for vessels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382fde-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries shall not prohibit access to vessels due solely to the absence of a Federal, State, or partner’s inspection program or station.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382fdf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a382fe0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to regulate vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to limit the authority of the Commandant of the Coast Guard to regulate vessels provided under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fe1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Authorities granted in this subsection shall not apply at locations where inspection or decontamination activities would duplicate efforts by the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382fe2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries shall make available to a Reclamation State any relevant data gathered related to inspections or decontaminations carried out under this subsection in such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a382fe3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program for Reclamation States for vessel inspection and decontamination stations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a382fe4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessels inspections in Reclamation States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Secretary, acting through the Commissioner of Reclamation, shall establish a competitive grant program to provide financial assistance to partners to conduct inspections and decontamination of vessels operating in Reclamation projects, including to purchase, establish, operate, or maintain a vessel inspection and decontamination station.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382fe5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of a grant under paragraph (1), including personnel costs, shall not exceed 75 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382fe6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before awarding a grant under paragraph (1), the Secretary shall determine that the project is technically and financially feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382fe7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this subsection, the Secretary shall coordinate with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a382fe8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the Reclamation States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fe9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affected Indian Tribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Aquatic Nuisance Species Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a382feb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s128"},"text":"Pub. L. 118–234, title I, § 128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2856"},"text":"138 Stat. 2856","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
