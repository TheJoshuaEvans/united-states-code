{"tag":"section","attrib":{"id":"id7a382fb0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426"},"text":null,"children":[{"tag":"num","attrib":{"value":"8426"},"text":"§ 8426.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aquatic resource activities assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a382fb1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a382fb2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aquatic Nuisance Species Task Force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Aquatic Nuisance Species Task Force” means the Aquatic Nuisance Species Task Force established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4721/a"},"text":"section 4721(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382fb3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decontamination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “decontamination” means actions to remove aquatic nuisance species to prevent introduction or spread into new aquatic ecosystems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382fb4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal land and water","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal land and water” means Federal land and water operated and maintained by the Bureau of Land Management, the U.S. Fish and Wildlife Service, the Bureau of Reclamation, the Forest Service, or the National Park Service, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382fb5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian Tribe” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382fb6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “inspection” means actions to find aquatic nuisance species to prevent introduction or spread into new aquatic ecosystems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382fb7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partner","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “partner” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a382fb8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Reclamation State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fb9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe in a Reclamation State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicable nonprofit organization in a Reclamation State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fbb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government in a Reclamation State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fbc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382fbd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reclamation State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Reclamation State” includes any of the following States:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a382fbe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Alaska.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fbf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Arizona.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fc0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" California.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fc1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Colorado.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fc2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Idaho.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382fc3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8426/a/7/F"},"text":null,"children":[{"tag":"num","at