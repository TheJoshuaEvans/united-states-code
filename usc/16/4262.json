{"tag":"section","attrib":{"id":"id79ebe417-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4262"},"text":null,"children":[{"tag":"num","attrib":{"value":"4262"},"text":"§ 4262.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ebe418-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4262/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To perpetuate healthy populations of Asian elephants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe419-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4262/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assist in the conservation and protection of Asian elephants by supporting the conservation programs of Asian elephant range states and the CITES Secretariat.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe41a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4262/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide financial resources for those programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ebe41b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/96/s3"},"text":"Pub. L. 105–96, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-19"},"text":"Nov. 19, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2150"},"text":"111 Stat. 2150","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
