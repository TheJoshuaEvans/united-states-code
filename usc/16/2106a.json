{"tag":"section","attrib":{"id":"id7993b243-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2106a"},"text":"§ 2106a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency reforestation assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7993b244-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized to provide assistance under this section to eligible landowners who suffer destruction of 35 percent or more of a commercial tree stand due to damaging weather, related condition, or wildfire.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7993b245-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The assistance, if any, provided by the Secretary under this section shall consist of either—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7993b246-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimbursement of up to 65 percent of the cost of reestablishing such tree stand damaged by the damaging weather, related condition, or wildfire in excess of 35 percent mortality; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b247-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the discretion of the Secretary, provision of sufficient tree seedlings to reestablish such tree stand.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7993b248-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7993b249-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person may receive an amount in excess of $25,000 in any fiscal year, or an equivalent value in tree seedlings, under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b24a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who has qualifying gross revenues in excess of $2,000,000 annually, as determined by the Secretary, shall not be eligible to receive any disaster payment or other benefits under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b24b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In implementing this section, the Secretary shall issue regulations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7993b24c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defining the term “person” for the purposes of this section that shall conform, to the extent practicable, to the regulations defining the term “person” issued under section 1308 ","children":[{"tag":"ref","attrib":{"idref":"fn002712"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002712"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 7 (before the amendment made by section 1603(a) of the Food, Conservation, and Energy Act of 2008);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b24d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribing such rules as the Secretary determines necessary to ensure a fair and reasonable application of the limitations established under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b24e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that no person receives duplicative payments or assistance under this section, the Cooperative Forestry Assistance Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2101"},"text":"16 U.S.C. 2101","children":[],"tail":" et seq.), and the environmental quality incentives program established under subchapter A of chapter 4 of subtitle D of title XII of the Food Security Act of 1985 ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa"},"text":"16 U.S.C. 3839aa","children":[],"tail":" et seq.], or other Federal program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7993b24f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7993b250-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “damaging weather” includes drought, hail, excessive moisture, freeze, tornado, hurricane, excessive wind, or any combination thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b251-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “eligible landowner” means a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7993b252-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produces annual crops from trees for commercial purposes and owns 500 acres or less of such trees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b253-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns 1,000 acres or less of private forest land; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b254-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns more than 1,000 acres but less than 5,000 acres of private forest land if the Secretary, in the Secretary’s discretion, determines the person eligible;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b255-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “qualifying gross revenues” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7993b256-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a majority of the person’s annual income is received from farming, ranching, and forestry operations, the gross revenue from the person’s farming, ranching, and forestry operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b257-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if less than a majority of the person’s annual income is received from farming, ranching, and forestry operations, the person’s gross revenue from all sources;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b258-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “related condition” includes insect infestations, disease, or other deterioration of a tree stand that is accelerated or exacerbated by damaging weather;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b259-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “reestablish” includes site preparation, reforestation of a damaged stand, and timber stand improvement practices, including thinning, prescribed burning, and other practices approved by the Secretary for reforestation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b25a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b25b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “wildfire” means any forest or range fire.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7993b25c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retroactive assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use funds provided under this section to reimburse landowners for approved reforestation practices that were implemented before ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":". The Secretary shall not make reimbursements for reforestation practices that were implemented prior to "},{"tag":"date","attrib":{"date":"1989-09-01"},"text":"September 1, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7993b25d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXII/s1271"},"text":"Pub. L. 101–624, title XII, § 1271","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3557"},"text":"104 Stat. 3557","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1018/f"},"text":"Pub. L. 102–237, title X, § 1018(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1906"},"text":"105 Stat. 1906","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIII/s336/a/2/E"},"text":"Pub. L. 104–127, title III, § 336(a)(2)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1005"},"text":"110 Stat. 1005","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1603/g/5"},"text":"Pub. L. 110–234, title I, § 1603(g)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1011"},"text":"122 Stat. 1011","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1603(g)(5), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1740; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1609/b/1"},"text":"Pub. L. 113–79, title I, § 1609(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/709"},"text":"128 Stat. 709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2301/d/2/E"},"text":"Pub. L. 115–334, title II, § 2301(d)(2)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4554"},"text":"132 Stat. 4554","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7993b25e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7993b25f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7993b260-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308"},"text":"Section 1308 of title 7","children":[],"tail":" (before the amendment made by section 1603(a) of the Food, Conservation, and Energy Act of 2008), referred to in subsec. (c)(3)(A), means "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308"},"text":"section 1308 of title 7","children":[],"tail":" before the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1603/a"},"text":"section 1603(a) of Pub. L. 110–246","children":[],"tail":", which amended the definition of “covered commodity” in section 1308(a)(1). "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1603/b"},"text":"Section 1603(b) of Pub. L. 110–246","children":[],"tail":" amended section 1308 by, among other things, adding subsec. (a)(4) which defined “person” and striking out subsec. (e) which related to issuance of regulations defining “person”. The amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1603"},"text":"section 1603 of Pub. L. 110–246","children":[],"tail":" to section 1308 were effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Cooperative Forestry Assistance Act of 1978, referred to in subsec. (c)(3)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/313"},"text":"Pub. L. 95–313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-07-01"},"text":"July 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/365"},"text":"92 Stat. 365","children":[],"tail":", which is classified principally to this chapter (§ 2101 et seq.). For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2101"},"text":"section 2101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Food Security Act of 1985, referred to in subsec. (c)(3)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1354"},"text":"99 Stat. 1354","children":[],"tail":". Subchapter A of chapter 4 of subtitle D of title XII of the Act is classified generally to subpart A (§ 3839aa et seq.) of part IV of subchapter IV of chapter 58 of this title. For complete classification of this Act to the Code, see Short Title of 1985 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1281"},"text":"section 1281 of Title 7","children":[],"tail":", Agriculture, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7993b261-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Federal Stewardship Act of 1990 and also as part of the Food, Agriculture, Conservation, and Trade Act of 1990, and not as part of the Cooperative Forestry Assistance Act of 1978 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7993b262-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" inserted “subchapter A of” before “chapter 4”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1609/b/1"},"text":"Pub. L. 113–79, § 1609(b)(1)","children":[],"tail":", amended language inserted by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1603/g/5"},"text":"Pub. L. 110–246, § 1603(g)(5)","children":[],"tail":". See 2008 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1603/g/5"},"text":"Pub. L. 110–246, § 1603(g)(5)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1609/b/1"},"text":"Pub. L. 113–79, § 1609(b)(1)","children":[],"tail":", inserted “(before the amendment made by section 1603(a) of the Food, Conservation, and Energy Act of 2008)” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308"},"text":"section 1308 of title 7","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" substituted “environmental quality incentives program established under chapter 4 of subtitle D of title XII of the Food Security Act of 1985” for “Agricultural Conservation Program established under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s590p/b"},"text":"section 590p(b) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" inserted “("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2101"},"text":"16 U.S.C. 2101","children":[],"tail":" et seq.)” after “1978” and made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s590p/b"},"text":"section 590p(b) of this title","children":[],"tail":" to correct corresponding provision of orig