{"tag":"section","attrib":{"id":"id7a1935f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6706"},"text":null,"children":[{"tag":"num","attrib":{"value":"6706"},"text":"§ 6706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring and evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1935f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2004-10-05"},"text":"October 5, 2004","children":[],"tail":", and every 5 years thereafter, the Secretary, in consultation with the Secretary of the Interior, shall complete and submit to the Committee on Resources and the Committee on Agriculture of the House of Representatives and to the Committee on Energy and Natural Resources of the Senate a detailed evaluation of the programs and activities of each Institute—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1935f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to ensure, to the maximum extent practicable, that the research, communication tools, and information transfer activities of each Institute are sufficient to achieve the purposes of this chapter, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1935f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6706/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing active adaptive ecosystem management practices at the landscape level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1935f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6706/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing unnecessary planning costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1935f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6706/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoiding duplicative and conflicting efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1935f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6706/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing public acceptance of active adaptive ecosystem management practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1935f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6706/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieving general satisfaction on the part of affected entities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the extent to which each Institute has implemented its duties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6704/c"},"text":"section 6704(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6706/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine whether continued provision of Federal assistance to each Institute is warranted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1935fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, as a result of an evaluation under subsection (a), the Secretary, in consultation with the Secretary of the Interior, determines that an Institute does not qualify for further Federal assistance under this chapter, the Institute shall receive no further Federal assistance under this chapter until such time as the qualifications of the Institute are reestablished to the satisfaction of the Secretaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1935fd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/317/s7"},"text":"Pub. L. 108–317, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-05"},"text":"Oct. 5, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1209"},"text":"118 Stat. 1209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1935fe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a1935ff-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7a193600-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
