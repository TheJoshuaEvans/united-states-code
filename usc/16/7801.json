{"tag":"section","attrib":{"id":"id7a2eb92e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801"},"text":null,"children":[{"tag":"num","attrib":{"value":"7801"},"text":"§ 7801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2eb92f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1982 Convention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “1982 Convention” means the United Nations Convention on the Law of the Sea of 10 December 1982.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb930-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Commission of the South Pacific Regional Fisheries Management Organization established in accordance with the South Pacific Fishery Resources Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb931-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Convention Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Convention Area” means the area to which the Convention on the Conservation and Management of High Seas Fishery Resources in the South Pacific Ocean applies under Article 5 of such Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb932-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Council” means the Western Pacific Regional Fishery Management Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb933-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive economic zone","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “exclusive economic zone” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2eb934-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the United States, the zone established by Presidential Proclamation Numbered 5030 of ","children":[{"tag":"date","attrib":{"date":"1983-03-10"},"text":"March 10, 1983","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453"},"text":"16 U.S.C. 1453","children":[],"tail":" note); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eb935-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a foreign country, a designated zone similar to the zone referred to in subparagraph (A) for that country, consistent with international law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb936-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishery resources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “fishery resources” means all fish, mollusks, crustaceans, and other marine species, and any products thereof, caught by a fishing vessel within the Convention Area, but excluding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2eb937-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sedentary species insofar as they are subject to the national jurisdiction of coastal States pursuant to Article 77 paragraph 4 of the 1982 Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eb938-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" highly migratory species listed in Annex I of the 1982 Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eb939-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anadromous and catadromous species; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eb93a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine mammals, marine reptiles and sea birds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb93b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “fishing”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2eb93c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as provided in subparagraph (B), means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2eb93d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual or attempted searching for, catching, taking, or harvesting of fishery resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2eb93e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaging in any activity that can reasonably be expected to result in the locating, catching, taking or harvesting of fishery resources for any purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2eb93f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transshipment and any operation at sea, in support of, or in preparation for, any activity described in this subparagraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2eb940-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/7/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of any vessel, vehicle, aircraft, or hovercraft in relation to any activity described in this subparagraph; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eb941-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any operation related to emergencies involving the health and safety of crew members or the safety of a fishing vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb942-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishing vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fishing vessel” means any vessel used or intended to be used for fishing, including any fish processing vessel support ship, carrier vessel, or any other vessel directly engaged in fishing operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb943-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means any individual (whether or not a citizen or national of the United States); any corporation, partnership, association, or other entity (whether or not organized or existing under the laws of any State); and any Federal, State, local, or foreign government or any entity of any such government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb944-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb945-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" South Pacific Fishery Resources Convention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “South Pacific Fishery Resources Convention” means the Convention on the Conservation and Management of the High Seas Fishery Resources in the South Pacific Ocean (including any annexes, amendments, or protocols that are in force, or have come into force, for the United States), which was adopted at Auckland, New Zealand, on ","children":[{"tag":"date","attrib":{"date":"2009-11-14"},"text":"November 14, 2009","children":[],"tail":", by the International Consultations on the Proposed South Pacific Regional Fisheries Management Organization."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb946-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7801/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of the Northern Mariana Islands, American Samoa, Guam, and any other commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2eb947-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/tII/s201"},"text":"Pub. L. 114–327, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1985"},"text":"130 Stat. 1985","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
