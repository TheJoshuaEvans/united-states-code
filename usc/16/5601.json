{"tag":"section","attrib":{"id":"id7a016748-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601"},"text":null,"children":[{"tag":"num","attrib":{"value":"5601"},"text":"§ 5601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation of United States under Convention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a016749-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioners","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a01674a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments, generally","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall appoint not more than 3 individuals to serve as the representatives of the United States on the Commission, who shall each—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a01674b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be known as a “United States Commissioner to the Northwest Atlantic Fisheries Organization”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a01674c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve at the pleasure of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a01674d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for appointments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a01674e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall ensure that of the individuals serving as Commissioners—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a01674f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 is appointed from among representatives of the commercial fishing industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a016750-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 (but no more than 1) is an official of the Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a016751-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1, other than the individual appointed under clause (ii), is a voting member of the New England Fishery Management Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a016752-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not appoint as a Commissioner an individual unless the individual is knowledgeable and experienced concerning the fishery resources to which the Convention applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a016753-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a016754-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term of an individual appointed as a Commissioner—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a016755-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be specified by the Secretary at the time of appointment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a016756-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not exceed 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a016757-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who is not a Government official may not serve more than 2 consecutive terms as a Commissioner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016758-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternate Commissioners","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a016759-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, for any anticipated absence of a duly appointed Commissioner, designate an individual to serve as an Alternate Commissioner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a01675a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Alternate Commissioner may exercise all powers and perform all duties of the Commissioner for whom the Alternate Commissioner is designated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a01675b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representatives","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a01675c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint not more than 3 individuals to serve as the representatives of the United States on the Scientific Council, who shall each be known as a “United States Representative to the Northwest Atlantic Fisheries Organization Scientific Council”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a01675d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for appointment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a01675e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not appoint an individual as a Representative unless the individual is knowledgeable and experienced concerning the scientific issues dealt with by the Scientific Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a01675f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall appoint as a Representative at least 1 individual who is an official of the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a016760-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual appointed as a Representative—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a016761-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall serve for a term of not to exceed 4 years, as specified by the Secretary at the time of appointment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a016762-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be reappointed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a016763-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall serve at the pleasure of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016764-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternate Representatives","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a016765-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, for any anticipated absence of a duly appointed Representative, designate an individual to serve as an Alternate Representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a016766-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Alternate Representative may exercise all powers and perform all duties of the Representative for whom the Alternate Representative is designated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016767-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Experts and advisers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioners, Alternate Commissioners, Representatives, and Alternate Representatives may be accompanied at meetings of the Organization by experts and advisers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016768-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination and consultation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a016769-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out their functions under the Convention, Commissioners, Alternate Commissioners, Representatives, and Alternate Representatives shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a01676a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the appropriate Regional Fishery Management Councils established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1852"},"text":"section 1852 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a01676b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5607"},"text":"section 5607 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a01676c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5601/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to coordination and consultations under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a01676d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tII/s202"},"text":"Pub. L. 104–43, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/377"},"text":"109 Stat. 377","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/327/tV/s502"},"text":"Pub. L. 114–327, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1995"},"text":"130 Stat. 1995","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/124"},"text":"Pub. L. 117–286, § 4(a)(124)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4319"},"text":"136 Stat. 4319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a01676e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a01676f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a016770-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/s502/1"},"text":"Pub. L. 114–327, § 502(1)","children":[],"tail":", in introductory provisions, struck out “General Council and the Fisheries” before “Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/s502/2"},"text":"Pub. L. 114–327, § 502(2)","children":[],"tail":", struck out “at a meeting of the General Council or the Fisheries Commission” after “appointed Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/s502/3"},"text":"Pub. L. 114–327, § 502(3)","children":[],"tail":", struck out “, at any meeting of the General Council or the Fisheries Commission for which the Alternate Commissioner is designated” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/s502/4"},"text":"Pub. L. 114–327, § 502(4)","children":[],"tail":", struck out “at a meeting of the Scientific Council” after “appointed Representative”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/s502/5"},"text":"Pub. L. 114–327, § 502(5)","children":[],"tail":", struck out “, at any meeting of the Scientific Council for which the Alternate Representative is designated” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/s502/6"},"text":"Pub. L. 114–327, § 502(6)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1852"},"text":"section 1852 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a016771-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7a016772-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/tV/s501/a"},"text":"Pub. L. 114–327, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1995"},"text":"130 Stat. 1995","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/327/tV/s501/a"},"text":"“This title [amending this section and sections 5602 to 5604, 5606, 5607, 5609, and 5610 of this title and repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5612"},"text":"section 5612 of this title","children":[],"tail":"] may be cited as the ‘Northwest Atlantic Fisheries Convention Amendments Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a016773-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tII/s201"},"text":"Pub. L. 104–43, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/377"},"text":"109 Stat. 377","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/43/tII/s201"},"text":"“This title [enacting this chapter] may be cited as the ‘Northwest Atlantic Fisheries Convention Act of 1995’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
