{"tag":"section","attrib":{"id":"id788af44c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s742d–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"742d–1"},"text":"§ 742d–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies of effects in use of chemicals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator of the Environmental Protection Agency is authorized and directed to undertake comprehensive continuing studies on the effects of insecticides, herbicides, fungicides and pesticides, upon the fish and wildlife resources of the United States, for the purpose of determining the amounts, percentages, and formulations of such chemicals that are lethal to or injurious to fish and wildlife and the amounts, percentages, mixtures, or formulations that can be used safely, and thereby prevent losses of fish and wildlife from such spraying, dusting, or other treatment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788af44d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/582/s1"},"text":"Pub. L. 85–582, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-01"},"text":"Aug. 1, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/479"},"text":"72 Stat. 479","children":[],"tail":"; 1970 Reorg. Plan No. 3, § 2(a)(2)(i), eff. "},{"tag":"date","attrib":{"date":"1970-12-02"},"text":"Dec. 2, 1970","children":[],"tail":", 35 F.R. 15623, "},{"tag":"ref","attrib":{"href":"/us/stat/84/2086"},"text":"84 Stat. 2086","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788af44e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id788af44f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id788af450-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/582/s2"},"text":"Section 2 of Pub. L. 85–582","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-01"},"text":"Aug. 1, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/479"},"text":"72 Stat. 479","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/86/279"},"text":"Pub. L. 86–279","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-16"},"text":"Sept. 16, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/563"},"text":"73 Stat. 563","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/232"},"text":"Pub. L. 89–232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-01"},"text":"Oct. 1, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/902"},"text":"79 Stat. 902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/394"},"text":"Pub. L. 90–394","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-11"},"text":"July 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/338"},"text":"82 Stat. 338","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/394"},"text":"“In order to carry out the provisions of this Act [this section], there is authorized to be appropriated $3,500,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1969-06-30"},"text":"June 30, 1969","children":[],"tail":", and for each of the two fiscal years immediately following such year. Such sums shall remain available until expended.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id788af451-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id788af452-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Administrator of the Environmental Protection Agency” substituted in text for “Secretary of the Interior” pursuant to Reorg. Plan No. 3 of 1970, set out in the Appendix to Title 5, Government Organization and Employees, which abolished the Federal Water Quality Administration in Department of the Interior and transferred to Administrator of Environmental Protection Agency all functions vested in Secretary of the Interior by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
