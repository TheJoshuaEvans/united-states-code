{"tag":"section","attrib":{"id":"id774b6f9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y–1a"},"text":null,"children":[{"tag":"num","attrib":{"value":"410y–1a"},"text":"§ 410y–1a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The boundaries of the park are revised to include approximately 600 additional acres.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id774b6f9f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/tIII/s320"},"text":"Pub. L. 95–625, title III, § 320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3488"},"text":"92 Stat. 3488","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/199/tI/s101/c"},"text":"Pub. L. 96–199, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-05"},"text":"Mar. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/68"},"text":"94 Stat. 68","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id774b6fa0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id774b6fa1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id774b6fa2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Parks and Recreation Act of 1978, and not as 