{"tag":"section","attrib":{"id":"id788fd634-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s746"},"text":null,"children":[{"tag":"num","attrib":{"value":"746"},"text":"§ 746.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessels of Fish and Wildlife Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Navy is authorized to place the vessels of the United States Fish and Wildlife Service on the same footing with the Navy Department as those of the National Ocean Survey.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788fd635-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1880-05-31/ch113"},"text":"May 31, 1880, ch. 113","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/21/151"},"text":"21 Stat. 151","children":[],"tail":"; 1939 Reorg. Plan No. II, § 4(e), eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2731, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1433"},"text":"53 Stat. 1433","children":[],"tail":"; 1940 Reorg. Plan No. III, § 3, eff. "},{"tag":"date","attrib":{"date":"1940-06-30"},"text":"June 30, 1940","children":[],"tail":", 5 F.R. 2108, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1232"},"text":"54 Stat. 1232","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-08/ch1036/s3"},"text":"Aug. 8, 1956, ch. 1036, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1120"},"text":"70 Stat. 1120","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788fd636-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id788fd637-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{}