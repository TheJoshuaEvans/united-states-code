{"tag":"section","attrib":{"id":"id770d7c23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s161e"},"text":null,"children":[{"tag":"num","attrib":{"value":"161e"},"text":"§ 161e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional lands, buildings, or other real and personal property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to acquire, and the State of Montana is authorized to convey to the United States, without regard to the requirements contained in section 11 of the Act approved ","children":[{"tag":"date","attrib":{"date":"1889-02-22"},"text":"February 22, 1889","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/25/676"},"text":"25 Stat. 676","children":[],"tail":"), any lands, interests in lands, buildings, or other property, real and personal, owned by the State of Montana within the boundaries of Glacier National Park. The aforesaid properties may be acquired from the State of Montana by the Secretary of the Interior for such consideration as he may deem advisable, when the acquisition of such property would, in his judgment, be in the best interests of the United States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id770d7c24-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-03-16/ch133"},"text":"Mar. 16, 1948, ch. 133","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/80"},"text":"62 Stat. 80","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id770d7c25-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id770d7c26-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id770d7c27-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 11 of the Act approved ","children":[{"tag":"date","attrib":{"date":"1889-02-22"},"text":"February 22, 1889","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/25/676"},"text":"25 Stat. 676","children":[],"tail":"), referred to in text, was not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
