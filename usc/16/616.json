{"tag":"section","attrib":{"id":"id785b58fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s616"},"text":null,"children":[{"tag":"num","attrib":{"value":"616"},"text":"§ 616.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exportation of timber cut on national forest or public land in Alaska","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Timber lawfully cut on any national forest, or on the public lands in Alaska, may be exported from the State or Territory where grown if, in the judgment of the Secretary of the department administering the national forests, or the public lands in Alaska, the supply of timber for local use will not be endangered thereby, and the respective Secretaries concerned are authorized to issue rules and regulations to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id785b58fb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"date","attrib":{"date":"1926-04-12"},"text":"Apr. 12, 1926","children":[],"tail":", § 1, ch. 117, "},{"tag":"ref","attrib":{"href":"/us/stat/44/242"},"text":"44 Stat. 242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id785b58fc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id785b58fd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id785b58fe-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Admission of Alaska as State","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Admission of Alaska into the Union was accomplished ","children":[{"tag":"date","attrib":{"date":"1959-01-03"},"text":"Jan. 3, 1959","children":[],"tail":", on issuance of Proc. No. 3269, "},{"tag":"date","attrib":{"date":"1959-01-03"},"text":"Jan. 3, 1959","children":[],"tail":", 24 F.R. 81, 73 Stat. c16, as required by sections 1 and 8(c) of "},{"tag":"ref","attrib":{"href":"/us/pl/85/508"},"text":"Pub. L. 85–508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-07"},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/339"},"text":"72 Stat. 339","children":[],"tail":", set out as notes preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s21"},"text":"section 21 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
