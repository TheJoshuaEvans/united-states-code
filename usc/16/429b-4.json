{"tag":"section","attrib":{"id":"id77908f56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s429b–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"429b–4"},"text":"§ 429b–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds from Land and Water Conservation Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77908f57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s429b–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount usable for acquisition of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to sums heretofore expended for the acquisition of property and interests therein for the park, from funds available for expenditure from the Land and Water Conservation Fund, as established under the Land and Water Conservation Fund Act of 1965,","children":[{"tag":"ref","attrib":{"idref":"fn002228"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002228"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" not more than a total of $8,700,000 may be expended for the acquisition of property and interests therein under sections 429b to 429b–5 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77908f58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s429b–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion of acquisition in two years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the express intent of Congress that, except for property referred to in ","children":[{"tag":"ref","attrib":{"