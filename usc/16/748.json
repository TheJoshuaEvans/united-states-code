{"tag":"section","attrib":{"id":"id788fd640-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s748"},"text":null,"children":[{"tag":"num","attrib":{"value":"748"},"text":"§ 748.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure of appropriations for propagation of food fishes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appropriations for propagation of food fishes shall not be expended for hatching or planting fish or eggs in any State in which, in the judgment of the Secretary of the Interior, there are not adequate laws for the protection of the fishes, nor in any State in which the United States Director of the Fish and Wildlife Service and his duly authorized agents are not accorded full and free right to conduct fish-cultural operations, and all fishing and other operations necessary therefor, in such manner and at such times as is considered necessary and proper by the said director or his agents.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788fd641-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1918-07-01/ch113/s1"},"text":"July 1, 1918, ch. 113, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/693"},"text":"40 Stat. 693","children":[],"tail":"; 1939 Reorg. Plan No. II, § 4(e), eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2731, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1433"},"text":"53 Stat. 1433","children":[],"tail":"; 1940 Reorg. Plan No. III, § 3, eff. "},{"tag":"date","attrib":{"date":"1940-06-30"},"text":"June 30, 1940","children":[],"tail":", 5 F.R. 2108, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1232"},"text":"54 Stat. 1232","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-08/ch1036/s3"},"text":"Aug. 8, 1956, ch. 1036, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1120"},"text":"70 Stat. 1120","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788fd642-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id788fd643-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id788fd644-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of functions to Secretary of Commerce from Secretary of the Interior by Reorg. Plan No. 4 of 1970, eff. ","children":[{"tag":"date","attrib":{"date":"1970-10-03"},"text":"Oct. 3, 1970","children":[],"tail":", 35 F.R. 15627, "},{"tag":"ref","attrib":{"href":"/us/stat/84/2090"},"text":"84 Stat. 2090","children":[],"tail":", see note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s742b"},"text":"section 742b of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Fish and Wildlife Service, created by Reorg. Plan No. III of 1940, eff. ","children":[{"tag":"date","attrib":{"date":"1940-06-30"},"text":"June 30, 1940","children":[],"tail":", 5 F.R. 2107, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1231"},"text":"54 Stat. 1231","children":[],"tail":", succeeded by United States Fish and Wildlife Service established by "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-08/ch1036/s3"},"text":"act Aug. 8, 1956, ch. 1036, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1120"},"text":"70 Stat. 1120","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s742b"},"text":"section 742b of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer and consolidation of bureaus and functions, see note set out under sections 742 and 744 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
