{"tag":"section","attrib":{"id":"id79f09ed0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b"},"text":null,"children":[{"tag":"num","attrib":{"value":"4503b"},"text":"§ 4503b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hawaii Experimental Tropical Forest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f09ed1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f09ed2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Forest” means the Hawaii Experimental Tropical Forest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09ed3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Governor” means the Governor of Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09ed4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lands” means lands, waters, and interests in lands and waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09ed5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the State of Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f09ed6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and management","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the request of the Governor, the Secretary shall establish and administer within the State a Hawaii Experimental Tropical Forest. The Forest shall be managed as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f09ed7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a model of quality tropical forest management where harvesting on a sustainable yield basis can be demonstrated in balance with natural resource conservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09ed8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a site for research on tropical forestry, conservation biology, and natural resource management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09ed9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a center for demonstration, education, training, and outreach on tropical forestry, conservation biology, and natural resources research and management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f09eda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delineation of location of Forest","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f09edb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor and the Secretary shall identify one or more suitable sites for the Forest in lands within the State. The identification of each site shall be based on scientific, ecological, administrative, and such other factors as the Governor and Secretary consider to be necessary or desirable to achieve the purposes of this section. Each site identified pursuant to the preceding sentence shall be of sufficient size and located so that the site can be effectively managed for Forest purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09edc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exterior boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The exterior boundaries of the Forest, including the boundaries of all sites identified for Forest purposes, shall be delineated on an official map. The map shall be available for public inspection in the office of the Administrator of the Division of Forestry and Wildlife of the Department of Land and Natural Resources of the State. The Governor and the Secretary may from time to time, by mutual agreement, amend the official map to modify the boundaries of the Forest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f09edd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities of Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f09ede-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out the purposes of this section, the Secretary is authorized—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f09edf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to administer the Forest in cooperation with the Governor and affected State agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09ee0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make grants and enter into contracts and cooperative agreements with the Federal Government, the government of the State, local governments, corporations, nonprofit organizations and individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09ee1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exercise existing authority with respect to cooperative forestry and research for Forest purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09ee2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to issue necessary rules and regulations or apply existing rules and regulations applicable to areas administered by the Forest Service that are necessary or desirable to administer the Forest—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f09ee3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/d/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purposes described in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f09ee4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/d/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect persons within the Forest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f09ee5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/d/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve and protect the resources in the Forest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09ee6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1643"},"text":"section 1643 of this title","children":[],"tail":" shall be available to the Secretary to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09ee7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section is intended to affect the jurisdiction of the State, both civil and criminal, over any person within the Forest by reason of the establishment of the Forest under this section, except in the case of a penalty for an offense against the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f09ee8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513/tVI/s606"},"text":"Pub. L. 101–513, title VI, § 606","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/574/s2/a/2"},"text":"Pub. L. 102–574, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4594"},"text":"106 Stat. 4594","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f09ee9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f09eea-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79f09eeb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513/s606"},"text":"section 606 of Pub. L. 101–513","children":[],"tail":" was renumbered section 610 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4505"},"text":"section 4505 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
