{"tag":"section","attrib":{"id":"id77719563-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410hhh–3"},"text":"§ 410hhh–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Sand Dunes National Preserve, Colorado","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77719564-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Great Sand Dunes National Preserve","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77719565-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby established the Great Sand Dunes National Preserve in the State of Colorado, as generally depicted on the map, as a unit of the National Park System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77719566-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Administrative jurisdiction of lands and interests therein administered by the Secretary of Agriculture within the boundaries of the preserve is transferred to the Secretary of the Interior, to be administered as part of the preserve. The Secretary of Agriculture shall modify the boundaries of the Rio Grande National Forest to exclude the transferred lands from the forest boundaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77719567-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any lands within the preserve boundaries which were designated as wilderness prior to ","children":[{"tag":"date","attrib":{"date":"2000-11-22"},"text":"November 22, 2000","children":[],"tail":", shall remain subject to the Wilderness Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.) and the Colorado Wilderness Act of 1993 ("},{"tag":"ref","attrib":{"href":"/us/pl/103/767"},"text":"Public Law 103–767","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539i"},"text":"16 U.S.C. 539i","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77719568-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map and legal description","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77719569-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As soon as practicable after the establishment of the national park and the preserve, the Secretary shall file maps and a legal description of the national park and the preserve with the Committee on Energy and Natural Resources of the Senate and the Committee on Resources of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7771956a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The map and legal description shall have the same force and effect as if included in this subchapter, except that the Secretary may correct clerical and typographical errors in the legal description and maps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7771956b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The map and legal description shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7771956c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the establishment of the national park and preserve and subject to the availability of funds, the Secretary shall complete an official boundary survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7771956d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/530/s5"},"text":"Pub. L. 106–530, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2529"},"text":"114 Stat. 2529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7771956e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7771956f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77719570-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Wilderness Act, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/577"},"text":"Pub. L. 88–577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-03"},"text":"Sept. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/890"},"text":"78 Stat. 890","children":[],"tail":", which is classified generally to chapter 23 (§ 1131 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"section 1131 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Colorado Wilderness Act of 1993, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/77"},"text":"Pub. L. 103–77","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-13"},"text":"Aug. 13, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/756"},"text":"107 Stat. 756","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539i"},"text":"section 539i of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77719571-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77719572-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
