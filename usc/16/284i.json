{"tag":"section","attrib":{"id":"id7727bac7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s284i"},"text":null,"children":[{"tag":"num","attrib":{"value":"284i"},"text":"§ 284i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of additional appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated not more than $17,000,000 to carry out sections 284c and 284d of this title. No authority under this subchapter to enter into contracts or to make payments shall be effective except to the extent and in such amounts as provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7727bac8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/671/s10"},"text":"Pub. L. 89–671, § 10","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/310"},"text":"Pub. L. 97–310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-14"},"text":"Oct. 14, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1458"},"text":"96 Stat. 1458","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
