{"tag":"section","attrib":{"id":"id7942aba6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1465"},"text":null,"children":[{"tag":"num","attrib":{"value":"1465"},"text":"§ 1465.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals to the Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7942aba7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1465/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date of the filing of an appeal to the Secretary of a consistency determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1456"},"text":"section 1456 of this title","children":[],"tail":", the Secretary shall publish an initial notice in the Federal Register."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942aba8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1465/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closure of record","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7942aba9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1465/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the end of the 160-day period beginning on the date of publication of an initial notice under subsection (a), except as provided in paragraph (3), the Secretary shall immediately close the decision record and receive no more filings on the appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abaa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1465/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After closing the administrative record, the Secretary shall immediately publish a notice in the Federal Register that the administrative record has been closed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1465/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7942abac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1465/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), during the 160-day period described in paragraph (1), the Secretary may stay the closing of the decision record—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7942abad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1465/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a specific period mutually agreed to in writing by the appellant and the State agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7942abae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1465/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as the Secretary determines necessary to receive, on an expedited basis—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7942abaf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1465/b/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any supplemental information specifically requested by the Secretary to complete a consistency review under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7942abb0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1465/b/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any clarifying information submitted by a party to the proceeding related to information in the consolidated record compiled by the lead Federal permitting agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942abb1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1465/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may only stay the 160-day period described in paragraph (1) for a period not to exceed 60 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942abb2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1465/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for decision","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7942abb3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1465/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the date of publication of a Federal Register notice stating when the decision record for an appeal has been closed, the Secretary shall issue a decision or publish a notice in the Federal Register explaining why a decision cannot be issued at that time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abb4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1465/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent decision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 15 days after the date of publication of a Federal Register notice explaining why a decision cannot be issued within the 60-day period, the Secretary shall issue a decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7942abb5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454/tIII/s319"},"text":"Pub. L. 89–454, title III, § 319","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/150/s8"},"text":"Pub. L. 104–150, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-06-03"},"text":"June 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1382"},"text":"110 Stat. 1382","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s381"},"text":"Pub. L. 109–58, title III, § 381","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/737"},"text":"119 Stat. 737","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7942abb6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7942abb7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7942abb8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(3)(A)(ii)(I), was in the original “this Act” which was translated as reading “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454"},"text":"Pub. L. 89–454","children":[],"tail":" which is classified generally to this chapter, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7942abb9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" amended section catchline and text generally, substituting provisions relating to notice, closure of record, and deadline for decision for provisions relating to notice, deadline for decision, and application of section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
