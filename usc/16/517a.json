{"tag":"section","attrib":{"id":"id7826dbe4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s517a"},"text":null,"children":[{"tag":"num","attrib":{"value":"517a"},"text":"§ 517a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of awards in condemnation proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In condemnation proceedings, heretofore or hereafter prosecuted, for the acquisition of lands under this Act, in which a decree is entered vesting title thereto in the United States upon payment of the award into the registry of the court, the Secretary of Agriculture is authorized to make such payment when advised by the Attorney General that the proceedings and the decree are regular.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7826dbe5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-01/ch186/s8"},"text":"Mar. 1, 1911, ch. 186, § 8","children":[],"tail":" (part), "},{"tag":"ref","attrib":{"href":"/us/stat/36/962"},"text":"36 Stat. 962","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1926-12-11/ch5"},"text":"Dec. 11, 1926, ch. 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/919"},"text":"44 Stat. 919","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7826dbe6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7826dbe7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7826dbe8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-01/ch186"},"text":"act Mar. 1, 1911, ch. 186","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/961"},"text":"36 Stat. 961","children":[],"tail":", popularly known as the Weeks Law, which enacted this section, former sections 513 and 514 of this title, and sections 515 to 517, 518, 519, 521, 552, and 563 of this title and amended sections 480 and 500 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s552"},"text":"section 552 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7826dbe9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1926—Act ","children":[{"tag":"date","attrib":{"date":"1926-12-11"},"text":"Dec. 11, 1926","children":[],"tail":", amended act "},{"tag":"date","attrib":{"date":"1911-03-01"},"text":"Mar. 1, 1911","children":[],"tail":", constituting "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s517"},"text":"section 517 of this title","children":[],"tail":", by inserting text of this section as a proviso thereof."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
