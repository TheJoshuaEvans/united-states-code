{"tag":"section","attrib":{"id":"id77a88401-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459a–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"459a–8"},"text":"§ 459a–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on expenditure","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The total amount which may be expended for the land acquisition program at Cape Hatteras National Seashore Recreational Area, pursuant to the authorizations contained in sections 459a–6 to 459a–8 of this title, is expressly limited to $250,000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a88402-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-06/ch988/s3"},"text":"Aug. 6, 1956, ch. 988, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1066"},"text":"70 Stat. 1066","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
