{"tag":"section","attrib":{"id":"id78f17e2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1220d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1220d"},"text":"§ 1220d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Obsolete ship” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of sections 1220, 1220a, 1220b, and 1220c of this title, the term “obsolete ship” means any vessel owned by the Department of Transportation that has been determined to be of insufficient value for commercial or national defense purposes to warrant its maintenance and preservation in the national defense reserve fleet and has been designated as an artificial reef candidate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78f17e2f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/402/s8"},"text":"Pub. L. 92–402, § 8","children":[],"tail":", formerly § 7, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/623/tII/s207/4"},"text":"Pub. L. 98–623, title II, § 207(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3397"},"text":"98 Stat. 3397","children":[],"tail":"; renumbered § 8, "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dC/tXXXV/s3504/a/1/A"},"text":"Pub. L. 107–314, div. C, title XXXV, § 3504(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2754"},"text":"116 Stat. 2754","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
