{"tag":"section","attrib":{"id":"id79f09f00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4601"},"text":null,"children":[{"tag":"num","attrib":{"value":"4601"},"text":"§ 4601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Take Pride in America Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f09f01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established the Take Pride in America Program within the Department of the Interior (hereinafter referred to as the “TPIA Program”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f09f02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the TPIA Program shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f09f03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4601/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To establish and maintain a public awareness campaign in cooperation with public and private organizations and individuals—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f09f04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4601/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to instill in the public the importance of the appropriate use of, and appreciation for Federal, State, and local lands, facilities, and natural and cultural resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09f05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4601/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage an attitude of stewardship and responsibility toward these lands, facilities, and resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09f06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4601/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote participation by individuals, organizations, and communities of a conservation ethic in caring for these lands, facilities, and resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09f07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4601/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To conduct a national awards program to honor those individuals and entities which, in the opinion of the Secretary of the Interior (hereafter in this chapter referred to as the “Secretary”), have distinguished themselves in the activities described in paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f09f08-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/628/tXI/s1102"},"text":"Pub. L. 101–628, title XI, § 1102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4502"},"text":"104 Stat. 4502","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f09f09-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f09f0a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79f09f0b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(2), was in the original “this Act”, and was translated as reading “this title”, meaning title XI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/628"},"text":"Pub. L. 101–628","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4502"},"text":"104 Stat. 4502","children":[],"tail":", known as the Take Pride in America Act, which is classified generally to this chapter, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79f09f0c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79f09f0d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/628/tXI/s1101"},"text":"Pub. L. 101–628, title XI, § 1101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4502"},"text":"104 Stat. 4502","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/628/tXI/s1101"},"text":"“This title [enacting this chapter] may be cited as the ‘Take Pride in America Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
