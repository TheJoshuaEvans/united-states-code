{"tag":"section","attrib":{"id":"id77a612d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"450jj–10"},"text":"§ 450jj–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of Gateway Arch National Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77a612d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redesignation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Jefferson National Expansion Memorial established under sections 450jj to 450jj–9 of this title shall be known and designated as the “Gateway Arch National Park”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a612da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in a law, map, regulation, document, paper, or other record of the United States to the Jefferson National Expansion Memorial shall be considered to be a reference to the “Gateway Arch National Park”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77a612db-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/128/s2"},"text":"Pub. L. 115–128, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-22"},"text":"Feb. 22, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/328"},"text":"132 Stat. 328","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
