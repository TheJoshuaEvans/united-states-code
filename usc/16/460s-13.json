{"tag":"section","attrib":{"id":"id77c9ee5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460s–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"460s–13"},"text":"§ 460s–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated not more than $6,873,000 for the acquisition of lands and interests in land in connection with, and not more than $6,348,000 for development of, the Pictured Rocks National Lakeshore.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77c9ee5b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/668/s14"},"text":"Pub. L. 89–668, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/925"},"text":"80 Stat. 925","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
