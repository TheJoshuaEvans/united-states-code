{"tag":"section","attrib":{"id":"id79155a1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1332"},"text":null,"children":[{"tag":"num","attrib":{"value":"1332"},"text":"§ 1332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79155a1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of the Interior when used in connection with public lands administered by him through the Bureau of Land Management and the Secretary of Agriculture in connection with public lands administered by him through the Forest Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79155a1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “wild free-roaming horses and burros” means all unbranded and unclaimed horses and burros on public lands of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79155a20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1332/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “range” means the amount of land necessary to sustain an existing herd or herds of wild free-roaming horses and burros, which does not exceed their known territorial limits, and which is devoted principally but not necessarily exclusively to their welfare in keeping with the multiple-use management concept for the public lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79155a21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1332/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “herd” means one or more stallions and his mares; and ","children":[{"tag":"ref","attrib":{"idref":"fn002617"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002617"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79155a22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1332/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “public lands” means any lands administered by the Secretary of the Interior through the Bureau of Land Management or by the Secretary of Agriculture through the Forest Service.","children":[{"tag":"ref","attrib":{"idref":"fn002618"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002618"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The period probably should be “; and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79155a23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1332/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “excess animals” means wild free-roaming horses or burros (1) which have been removed from an area by the Secretary pursuant to applicable law or, (2) which must be removed from an area in order to preserve and maintain a thriving natural ecological balance and multiple-use relationship in that area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79155a24-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/195/s2"},"text":"Pub. L. 92–195, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-15"},"text":"Dec. 15, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/649"},"text":"85 Stat. 649","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/514/s14/b"},"text":"Pub. L. 95–514, § 14(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1810"},"text":"92 Stat. 1810","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79155a25-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79155a26-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79155a27-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/514"},"text":"Pub. L. 95–514","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
