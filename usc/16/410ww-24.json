{"tag":"section","attrib":{"id":"id7763645d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–24"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ww–24"},"text":"§ 410ww–24.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff of Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7763645e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–24/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall have a Director who shall be appointed by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7763645f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–24/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may appoint and fix the pay of such additional personnel as the Commission deems necessary. Such staff may include specialists in areas such as interpretation, historic preservation, black history and literature, aviation history and technology, and urban revitalization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77636460-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–24/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to such rules as may be adopted by the Commission, the Commission may procure temporary and intermittent services to the same extent as is authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":", but at rates determined by the Commission to be reasonable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77636461-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–24/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon request of the Commission, the head of any Federal agency represented by a member on the Commission may detail, on a reimbursable basis, any of the personnel of such agency to the Commission to assist it in carrying out its duties under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77636462-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–24/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the General Services Administration shall provide to the Commission on a reimbursable basis such administrative support services as the Commission may request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77636463-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–24/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may accept the services of personnel detailed from the State or any political subdivision of the State and may reimburse the State or such political subdivision for such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77636464-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–24/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of certain provisions of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The director and staff of the Commission may be appointed without regard to the provisions of title 5 governing appointments in the competitive service, and may be paid without regard to the provisions of chapter 51 and subchapter III of chapter 53 of such title relating to classification and General Schedule pay rates, except that no individual so appointed may receive pay in excess of the annual rate of basic pay payable for grade GS–15 of the General Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77636465-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/419/tII/s204"},"text":"Pub. L. 102–419, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2147"},"text":"106 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77636466-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77636467-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77636468-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Grade GS–15 of the General Schedule, referred to in subsec. (g), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
