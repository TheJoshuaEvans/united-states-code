{"tag":"section","attrib":{"id":"id788fd691-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s757"},"text":null,"children":[{"tag":"num","attrib":{"value":"757"},"text":"§ 757.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of State services; expenditure of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out the authorizations and duties imposed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s756"},"text":"section 756 of this title","children":[],"tail":", the Secretary of Commerce is authorized to utilize the facilities and services of the agencies of the States of Oregon, Washington, and Idaho responsible for the conservation of the fish and wildlife resources in such States, under the terms of agreements entered into between the United States and these States, without regard to the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":", and funds appropriated to carry out the purposes of sections 755 to 757 of this title may be expended for the construction of facilities on and the improvement of lands not owned or controlled by the United States: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the appropriate agency of the State wherein such construction or improvement is to be carried on first shall have obtained without cost to the United States the necessary title to, interest therein, rights-of-way over, or licenses covering the use of such lands."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788fd692-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-05-11/ch193/s3"},"text":"May 11, 1938, ch. 193, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/345"},"text":"52 Stat. 345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-08/ch883/s2"},"text":"Aug. 8, 1946, ch. 883, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/932"},"text":"60 Stat. 932","children":[],"tail":"; 1970 Reorg. Plan No. 4, eff. "},{"tag":"date","attrib":{"date":"1970-10-03"},"text":"Oct. 3, 1970","children":[],"tail":", 35 F.R. 15627, "},{"tag":"ref","attrib":{"href":"/us/stat/84/2090"},"text":"84 Stat. 2090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788fd693-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788fd694-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id788fd695-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In text, “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"” substituted for “section 3709 of the Revised Statutes” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id788fd696-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1946—Act ","children":[{"tag":"date","attrib":{"date":"1946-08-08"},"text":"Aug. 8, 1946","children":[],"tail":", amended section generally to provide for utilization of State services, and for expenditure of funds for construction of facilities and improvements on lands not owned by the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id788fd697-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id788fd698-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of functions to Secretary of Commerce from Secretary of the Interior, by Reorg. Plan No. 4 of 1970, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s755"},"text":"section 755 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
