{"tag":"section","attrib":{"id":"id7778c0a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410nnn–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"410nnn–5"},"text":"§ 410nnn–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Within 3 years after ","children":[{"tag":"date","attrib":{"date":"1992-06-23"},"text":"June 23, 1992","children":[],"tail":", the Secretary shall develop and transmit to the Committee on Interior and Insular Affairs of the United States House of Representatives and the Committee on Energy and Natural Resources of the Senate, a general management plan for the historical park. The plan shall be consistent with "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":" and with the purposes of this subchapter and shall include (but not be limited to) each of the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7778c0a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410nnn–5/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A resource protection program including land acquisition needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7778c0a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410nnn–5/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A general visitor use and interpretive program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7778c0a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410nnn–5/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A general development plan including such roads, trails, markers, structures, and other improvements and facilities as may be necessary for the accommodation of visitor use in accordance with the purposes of this subchapter and the need to preserve the integrity of the historical park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7778c0a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410nnn–5/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A research plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7778c0a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410nnn–5/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of appropriate cooperative agreements as identified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410nnn–4"},"text":"section 410nnn–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7778c0a6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/304/s7"},"text":"Pub. L. 102–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-06-23"},"text":"June 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/257"},"text":"106 Stat. 257","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7113/a/3/C"},"text":"Pub. L. 111–11, title VII, § 7113(a)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1202"},"text":"123 Stat. 1202","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7778c0a7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topi