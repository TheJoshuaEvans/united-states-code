{"tag":"section","attrib":{"id":"id7a089397-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402"},"text":null,"children":[{"tag":"num","attrib":{"value":"6402"},"text":"§ 6402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal coral reef management and restoration activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a089398-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, the Secretary of the Interior, or the Secretary of Commerce may conduct activities described in subsection (b) to conserve and restore coral reefs and coral reef ecosystems that are consistent with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a089399-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all applicable laws governing resource management in Federal and State waters, including this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a08939a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Coral Reef Resilience Strategy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a08939b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coral reef action plans in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6404"},"text":"section 6404 of this title","children":[],"tail":", as applicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a08939c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities described in this subsection are activities to conserve, research, monitor, assess, and restore coral reefs and coral reef ecosystems in waters managed under the jurisdiction of a Federal agency specified in subsection (c) or in coordination with a State in waters managed under the jurisdiction of such State, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a08939d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" developing, including through the collection of requisite in situ and remotely sensed data, high-quality and digitized maps reflecting—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a08939e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current and historical live coral cover data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a08939f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coral reef habitat quality data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" priority areas for coral reef conservation to maintain biodiversity and ecosystem structure and function, including the reef matrix, that benefit coastal communities and living marine resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" priority areas for coral reef restoration to enhance biodiversity and ecosystem structure and function, including the reef matrix, to benefit coastal communities and living marine resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas of concern that may require enhanced monitoring of coral health and cover;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enhancing compliance with Federal laws that prohibit or regulate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0893a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taking of coral products or species associated with coral reefs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use and management of coral reef ecosystems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" long-term ecological monitoring of coral reef ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing species-specific recovery plans for listed coral species consistent with the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restoring degraded coral reef ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing land-based stressors to coral reef ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting ecologically sound navigation and anchorages, including through navigational aids and expansion of reef-safe anchorages and mooring buoy systems, to enhance recreational access while preventing or minimizing the likelihood of vessel impacts or other physical damage to coral reefs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring and responding to severe bleaching or mortality events, disease outbreaks, invasive species outbreaks, and significant maritime accidents, including hazardous spill cleanup and the removal of grounded vessels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting scientific research that contributes to the understanding, sustainable use, and long-term conservation of coral reefs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing public awareness, understanding, and appreciation of coral reefs and coral reef ecosystems and their ecological and socioeconomic value; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" centrally archiving, managing, and distributing on a public website data sets and coral reef ecosystem assessments, including the data repositories of the Coral Reef Conservation Program of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0893af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agencies specified","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Federal agency specified in this subsection is one of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0893b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Park Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Fish and Wildlife Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6402/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Insular Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0893b4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s203"},"text":"Pub. L. 106–562, title II, § 203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/a"},"text":"Pub. L. 117–263, div. J, title C, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3932"},"text":"136 Stat. 3932","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0893b5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0893b6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a0893b7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(1), was in the original “this Act” which was translated as reading “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562"},"text":"Pub. L. 106–562","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Endangered Species Act of 1973, referred to in subsec. (b)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/884"},"text":"87 Stat. 884","children":[],"tail":", which is classified principally to chapter 35 (§ 1531 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"section 1531 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a0893b8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6402, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s203"},"text":"Pub. L. 106–562, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2800"},"text":"114 Stat. 2800","children":[],"tail":", related to national coral reef action strategy, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/a"},"text":"Pub. L. 117–263, div. J, title C, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3931"},"text":"136 Stat. 3931","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
