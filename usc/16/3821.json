{"tag":"section","attrib":{"id":"id79c82f0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821"},"text":null,"children":[{"tag":"num","attrib":{"value":"3821"},"text":"§ 3821.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program ineligibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79c82f0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production on converted wetland","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in this subchapter and notwithstanding any other provision of law, any person who in any crop year produces an agricultural commodity on converted wetland, as determined by the Secretary, shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c82f0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in violation of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c82f0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ineligible for loans or payments in an amount determined by the Secretary to be proportionate to the severity of the violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c82f0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility for certain loans and payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a person is determined to have committed a violation under subsection (a) during a crop year, the Secretary shall determine which of, and the amount of, the following loans and payments for which the person shall be ineligible:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c82f10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contract payments under a production flexibility contract, marketing assistance loans, and any type of price support or payment made available under the Agricultural Market Transition Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7201"},"text":"7 U.S.C. 7201","children":[],"tail":" et seq.], the Commodity Credit Corporation Charter Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s714"},"text":"15 U.S.C. 714","children":[],"tail":" et seq.), or any other Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c82f11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A loan made or guaranteed under the Consolidated Farm and Rural Development Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"7 U.S.C. 1921","children":[],"tail":" et seq.) or any other provision of law administered by the Consolidated Farm Service Agency,"},{"tag":"ref","attrib":{"idref":"fn002763"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002763"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" if the Secretary determines that the proceeds of the loan will be used for a purpose that will contribute to conversion of a wetland (other than as provided in this subchapter) to produce an agricultural commodity."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c82f12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" During the crop year:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79c82f13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A payment made pursuant to a contract entered into under the environmental quality incentives program under subpart A of part IV of subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c82f14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A payment under any other provision of subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c82f15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A payment under section 2201 or 2202 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c82f16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A payment, loan, or other assistance under section 1003 or 1006a of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c82f17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility for crop insurance premium assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c82f18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79c82f19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a person is determined to have committed a violation under subsection (a) or (d) during a crop year, the person shall be ineligible to receive any payment of any portion of premium paid by the Federal Crop Insurance Corporation for a plan or policy of insurance under the Federal Crop Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"7 U.S.C. 1501","children":[],"tail":" et seq.) pursuant to this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c82f1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Ineligibility under this subsection shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79c82f1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only apply to reinsurance years subsequent to the date of a final determination of a violation, including all administrative appeals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79c82f1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not apply to the existing reinsurance year or any reinsurance year prior to the date of the final determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c82f1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79c82f1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), ineligibility for crop insurance premium assistance shall apply in accordance with this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c82f1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New conversions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a wetland that the Secretary determines was converted after ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id79c82f20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person shall be ineligible to receive crop insurance premium subsidies in subsequent reinsurance years unless the Secretary determines that an exemption pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3822"},"text":"section 3822 of this title","children":[],"tail":" applies; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79c82f21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any violation that the Secretary determines impacts less than 5 acres of an entire farm, the person may pay a contribution in an amount equal to 150 percent of the cost of mitigation, as determined by the Secretary, to the fund described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3841/f"},"text":"section 3841(f) of this title","children":[],"tail":" for wetland restoration in lieu of ineligibility to receive crop insurance premium assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c82f22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior conversions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a wetland that the Secretary determines was converted prior to ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", ineligibility under this subsection shall not apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c82f23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversions and new policies or plans of insurance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an agricultural commodity for which an individual policy or plan of insurance is available for the first time to the person after ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id79c82f24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ineligibility shall apply only to conversions that take place after the date on which the policy or plan of insurance first becomes available to the person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79c82f25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person shall take such steps as the Secretary determines appropriate to mitigate any prior conversion in a timely manner but not to exceed 2 reinsurance years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c82f26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79c82f27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mitigation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this paragraph, a person subject to a final determination, including all administrative appeals, of a violation described in subsection (d) shall have 1 reinsurance year to initiate a mitigation plan to remedy the violation, as determined by the Secretary, before becoming ineligible under this subsection in the following reinsurance year to receive any payment of any portion of the premium paid by the Federal Crop Insurance Corporation for a policy or plan of insurance under the Federal Crop Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"7 U.S.C. 1501","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c82f28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons covered for the first time","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the requirements of paragraph (1), in the case of a person that is subject to this subsection for the first time solely due to the amendment made by section 2611(b) of the Agricultural Act of 2014, the person shall have 2 reinsurance years after the reinsurance year in which a final determination is made, including all administrative appeals, of a violation described in this subsection to take such steps as the Secretary determines appropriate to remedy or mitigate the violation in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c82f29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Good faith","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that a person subject to a final determination, including all administrative appeals, of a violation described in this subsection acted in good faith and without intent to commit a violation described in this subsection as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3822/h"},"text":"section 3822(h) of this title","children":[],"tail":", the person shall have 2 reinsurance years to take such steps as the Secretary determines appropriate to remedy or mitigate the violation in accordance with this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c82f2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tenant relief","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79c82f2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a tenant is determined to be ineligible for payments and other benefits under this subsection, the Secretary may limit the ineligibility only to the farm that is the basis for the ineligibility determination if the tenant has established, to the satisfaction of the Secretary that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79c82f2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tenant has made a good faith effort to meet the requirements of this section, including enlisting the assistance of the Secretary to obtain a reasonable plan for restoration or mitigation for the farm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79c82f2d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the landlord on the farm refuses to comply with the plan on the farm; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79c82f2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/D/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the lack of compliance is not a part of a scheme or device to avoid the compliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79c82f2f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate an annual report concerning the ineligibility determinations limited during the previous 12-month period under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c82f30-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificate of compliance","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79c82f31-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning with the first full reinsurance year immediately following ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", all persons seeking eligibility for the payment of a portion of the premium paid by the Federal Crop Insurance Corporation for a policy or plan of insurance under the Federal Crop Insurance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"7 U.S.C. 1501","children":[],"tail":" et seq.) shall provide certification of compliance with this section as determined by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79c82f32-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall evaluate the certification in a timely manner and—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79c82f33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/E/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who has properly complied with certification shall be held harmless with regard to eligibility during the period of evaluation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79c82f34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/E/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary fails to evaluate the certification in a timely manner and the person is subsequently found to be in violation of this subsection, ineligibility shall not apply to the person for that violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79c82f35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable contribution","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79c82f36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/E/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a person fails to notify the Secretary as required and is subsequently found to be in violation of this subsection, the Secretary shall—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id79c82f37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/E/iii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the amount of an equitable contribution to conservation by the person for the violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79c82f38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/E/iii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposit the contribution in the fund described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3841/f"},"text":"section 3841(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79c82f39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/3/E/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The contribution shall not exceed the total of the portion of the premium paid by the Federal Crop Insurance Corporation for a policy or plan of insurance for all years the person is determined to have been in violation subsequent to the date on which certification was first required under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c82f3a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Secretary","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79c82f3b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Secretary shall use existing processes and procedures for certifying compliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c82f3c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the agencies of the Department of Agriculture, shall be solely responsible for determining whether a producer is eligible to receive crop insurance premium subsidies in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c82f3d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that no agent, approved insurance provider, or employee or contractor of an agency or approved insurance provider, bears responsibility or liability for the eligibility of an insured producer under this subsection, other than in cases of misrepresentation, fraud, or scheme and device.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c82f3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wetland conversion","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c82f3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3822"},"text":"section 3822 of this title","children":[],"tail":" and notwithstanding any other provision of law, any person who in any crop year beginning after "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":", converts a wetland by draining, dredging, filling, leveling, or any other means for the purpose, or to have the effect, of making the production of an agricultural commodity possible on such converted wetland shall be ineligible for those payments, loans, or programs specified in subsection (b) for that crop year and all subsequent crop years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c82f40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty of the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall become ineligible under paragraph (1) if the Secretary determines that an exemption under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3822/b"},"text":"section 3822(b) of this title","children":[],"tail":" applies to that person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c82f41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to a loan described in subsection (b) made before ","children":[{"tag":"date","attrib":{"date":"1985-12-23"},"text":"December 23, 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c82f42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3821/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wetland","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall have, and shall not delegate to any private person or entity, authority to determine whether a person has complied with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c82f43-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1221"},"text":"Pub. L. 99–198, title XII, § 1221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1507"},"text":"99 Stat. 1507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIV/s1421/b"},"text":"Pub. L. 101–624, title XIV, § 1421(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3572"},"text":"104 Stat. 3572","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tII/s204/3"},"text":"Pub. L. 102–237, title II, § 204(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1855"},"text":"105 Stat. 1855","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/552/tIII/s308/a"},"text":"Pub. L. 102–552, title III, § 308(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4116"},"text":"106 Stat. 4116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIII/s321"},"text":"Pub. L. 104–127, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/986"},"text":"110 Stat. 986","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tII/s2002/b"},"text":"Pub. L. 107–171, title II, § 2002(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/233"},"text":"116 Stat. 233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2611/b"},"text":"Pub. L. 113–79, title II, § 2611(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/763"},"text":"128 Stat. 763","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII"},"text":"Pub. L. 115–334, title II","children":[],"tail":", §§ 2101, 2301(d)(1)(B), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4530"},"text":"132 Stat. 4530","children":[],"tail":", 4553.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c82f44-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c82f45-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79c82f46-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Agricultural Market Transition Act, referred to in subsec. (b)(1), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/896"},"text":"110 Stat. 896","children":[],"tail":", which is classified principally to chapter 100 (§ 7201 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7201"},"text":"section 7201 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation Charter Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-29/ch704"},"text":"act June 29, 1948, ch. 704","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1070"},"text":"62 Stat. 1070","children":[],"tail":", which is classified generally to subchapter II (§ 714 et seq.) of chapter 15 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s714"},"text":"section 714 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Consolidated Farm and Rural Development Act, referred to in subsec. (b)(2), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/307"},"text":"75 Stat. 307","children":[],"tail":", which is classified principally to chapter 50 (§ 1921 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Crop Insurance Act, referred to in subsec. (c)(1)(A), (3)(A), (E)(i), is subtitle A of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"act Feb. 16, 1938, ch. 30","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/72"},"text":"52 Stat. 72","children":[],"tail":", which is classified generally to subchapter I (§ 1501 et seq.) of chapter 36 of Title 7, Agriculture. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"section 1501 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2611(b) of the Agricultural Act of 2014, referred to in subsec. (c)(3)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s2611/b"},"text":"section 2611(b) of Pub. L. 113–79","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/763"},"text":"128 Stat. 763","children":[],"tail":", which amended this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79c82f47-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2301/d/1/B"},"text":"Pub. L. 115–334, § 2301(d)(1)(B)","children":[],"tail":", inserted “subpart A of” before “part IV”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2101"},"text":"Pub. L. 115–334, § 2101","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsecs. (c) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" added subsec. (c) and redesignated former subsecs. (c) to (e) as (d) to (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s321/a/2"},"text":"Pub. L. 104–127, § 321(a)(2)","children":[],"tail":", reenacted section catchline without change."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s321/a/2"},"text":"Pub. L. 104–127, § 321(a)(2)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which related to ineligibility of persons producing an agricultural commodity on converted wetland to receive certain Federal payments, loans, insurance benefits, and other benefits."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s321/a/2"},"text":"Pub. L. 104–127, § 321(a)(2)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s321/b/1"},"text":"Pub. L. 104–127, § 321(b)(1)","children":[],"tail":", inserted heading and substituted “beginning after "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":",” for “subsequent to "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":",” and “subsection (b)” for “subsections (a)(1) through (3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s321/a/1"},"text":"Pub. L. 104–127, § 321(a)(1)","children":[],"tail":", redesignated subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s321/b/2"},"text":"Pub. L. 104–127, § 321(b)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/552"},"text":"Pub. L. 102–552","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":". See 1991 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/552"},"text":"Pub. L. 102–552","children":[],"tail":", substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"7 U.S.C. 1421","children":[],"tail":" note)” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421"},"text":"16 U.S.C. 1421","children":[],"tail":" note)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1421/b/1"},"text":"Pub. L. 101–624, § 1421(b)(1)","children":[],"tail":", designated existing provisions as subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1421/b/2"},"text":"Pub. L. 101–624, § 1421(b)(2)","children":[],"tail":", inserted reference to section 132 of the Disaster Assistance Act of 1989 and similar provisions enacted after "},{