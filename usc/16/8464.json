{"tag":"section","attrib":{"id":"id7a3aa037-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464"},"text":null,"children":[{"tag":"num","attrib":{"value":"8464"},"text":"§ 8464.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outdoor Recreation Legacy Partnership Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3aa038-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa039-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible entity” means an entity or combination of entities that represents or otherwise serves a qualifying area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa03a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible nonprofit organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible nonprofit organization” means an organization that is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" and is exempt from taxation under section 501(a) of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa03b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa03c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa03d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a political subdivision of a State, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3aa03e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a city;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa03f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a county; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa040-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a special purpose district that manages open space, including a park district; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa041-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe, urban Indian organization, or Alaska Native or Native Hawaiian community or organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa042-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “low-income community” has the same meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s45D/e/1"},"text":"26 U.S.C. 45D(e)(1)","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002875"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002875"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa043-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outdoor Recreation Legacy Partnership Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Outdoor Recreation Legacy Partnership Program” means the program codified under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa044-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying area","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualifying area” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa045-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an urbanized area or urban cluster that has a population of 25,000 or more in the most recent census;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa046-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 or more adjacent urban clusters with a combined population of 25,000 or more in the most recent census; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa047-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an area administered by an Indian Tribe or an Alaska Native or Native Hawaiian community organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa048-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa049-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Codification of program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa04a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established an existing program, to be known as the “Outdoor Recreation Legacy Partnership Program”, under which the Secretary may award grants to eligible entities for projects—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3aa04b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire land and water for parks and other outdoor recreation purposes in qualifying areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa04c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop new or renovate existing outdoor recreation facilities that provide outdoor recreation opportunities to the public in qualifying areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa04d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants to eligible entities under subparagraph (A), the Secretary shall give priority to projects that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3aa04e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create or significantly enhance access to park and recreational opportunities in a qualifying area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa04f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage and empower low-income communities and youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa050-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide employment or job training opportunities for youth or low-income communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa051-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish or expand public-private partnerships, with a focus on leveraging resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa052-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take advantage of coordination among various levels of government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa053-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa054-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receiving a grant under paragraph (1), an eligible entity shall provide matching funds in the form of cash or an in-kind contribution in an amount equal to not less than 100 percent of the amounts made available under the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa055-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 7 percent of funds provided to an eligible entity under a grant awarded under paragraph (1) may be used for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa056-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants to eligible entities under paragraph (1), the Secretary shall consider the extent to which a project would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa057-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide recreation opportunities in low-income communities in which access to parks is not adequate to meet local needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa058-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide opportunities for outdoor recreation and public land volunteerism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa059-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support innovative or cost-effective ways to enhance parks and other recreation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3aa05a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa05b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delivery of services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa05c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support park and recreation programming provided by local governments, including cooperative agreements with community-based eligible nonprofit organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa05d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop Native American event sites and cultural gathering spaces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa05e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide benefits such as community resilience, reduction of urban heat islands, enhanced water or air quality, or habitat for fish or wildlife; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa05f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate any combination of purposes listed in subparagraphs (A) through (F).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa060-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible uses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa061-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), an eligible entity may use a grant awarded under paragraph (1) for a project described in subparagraph (A) or (B) of that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa062-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity may not use grant funds for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3aa063-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incidental costs related to land acquisition, including appraisal and titling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa064-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation and maintenance activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa065-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilities that support semiprofessional or professional athletics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa066-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indoor facilities, such as recreation centers or facilities that support primarily nonoutdoor purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa067-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition of land or interests in land that restrict public access.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa068-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion to other than public outdoor recreation use","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3aa069-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No property acquired or developed with assistance under this section shall, without the approval of the Secretary, be converted to other than public outdoor recreation use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa06a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition for approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall approve a conversion only if the Secretary finds it to be in accordance with the then-existing comprehensive Statewide outdoor recreation plan and only on such conditions as the Secretary considers necessary to ensure the substitution of other recreation properties of at least equal fair market value and of reasonably equivalent usefulness and location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa06b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/b/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wetland areas and interests therein","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Wetland areas and interests therein as identified in the wetlands provisions of the comprehensive plan and proposed to be acquired as suitable replacement property within the same State that is otherwise acceptable to the Secretary, acting through the Director of the National Park Service, shall be deemed to be of reasonably equivalent usefulness with the property proposed for conversion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa06c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and evaluation requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Outdoor Recreation Legacy Partnership Program, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa06d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an initial screening and technical review of applications received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa06e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate and score all qualifying applications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa06f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide culturally and linguistically appropriate information to eligible entities (including low-income communities and eligible entities serving low-income communities) on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa070-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opportunity to apply for grants under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa071-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application procedures by which eligible entities may apply for grants under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa072-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible uses for grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa073-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa074-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the last day of each report period, each State-lead agency that receives a grant under this section shall annually submit to the Secretary performance and financial reports that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa075-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summarize project activities conducted during the report period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa076-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the status of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa077-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8464/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the earlier of the date of expiration of a project period or the completion of a project, each State-lead agency that receives a grant under this section shall submit to the Secretary a final report containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3aa078-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s156"},"text":"Pub. L. 118–234, title I, § 156","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2876"},"text":"138 Stat. 2876","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3aa079-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3aa07a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a3aa07b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s45D/e/1"},"text":"26 U.S.C. 45D(e)(1)","children":[],"tail":", referred to in subsec. (a)(4), was so in the original, but probably should have been a reference to section 45D(e)(1) of the Internal Revenue Code of 1986, which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s45D/e/1"},"text":"section 45D(e)(1) of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
