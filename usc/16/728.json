{"tag":"section","attrib":{"id":"id7888aae0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s728"},"text":null,"children":[{"tag":"num","attrib":{"value":"728"},"text":"§ 728.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to make such expenditures for construction, equipment, maintenance, repairs, and improvements, including expenditures for personal services at the seat of government and elsewhere, as may be necessary to execute the functions imposed upon him by this chapter and as may be provided for by Congress from time to time.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7888aae1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-06-07/ch346/s9"},"text":"June 7, 1924, ch. 346, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/652"},"text":"43 Stat. 652","children":[],"tail":"; 1939 Reorg. Plan No. II, § 4(e), (f), eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2731, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1433"},"text":"53 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7888aae2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7888aae3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7888aae4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"As originally enacted, this section contained an additional paragraph which appropriated a sum half of which was to be available, until expended, for the expenditures mentioned herein.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7888aae5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id7888aae6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of functions of Secretary of Agriculture and Secretary of Commerce to Secretary of the Interior, by Reorg. Plan No. II of 1939, see Transfer of Functions note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s723"},"text":"section 723 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
