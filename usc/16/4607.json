{"tag":"section","attrib":{"id":"id79f09f22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4607"},"text":null,"children":[{"tag":"num","attrib":{"value":"4607"},"text":"§ 4607.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Slogan and logo","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The “Take Pride in America” slogan and logo, which are registered by the Department of the Interior, and the goodwill associated with such slogan and logo, shall be administered pursuant to the TPIA Program.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79f09f23-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/628/tXI/s1108"},"text":"Pub. L. 101–628, title XI, § 1108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4503"},"text":"104 Stat. 4503","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
