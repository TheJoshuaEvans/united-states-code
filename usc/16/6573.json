{"tag":"section","attrib":{"id":"id7a1209df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6573"},"text":null,"children":[{"tag":"num","attrib":{"value":"6573"},"text":"§ 6573.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1209e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6573/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Land enrolled in the healthy forests reserve program shall be subject to a restoration plan, to be developed jointly by the landowner and the Secretary of Agriculture, in coordination with the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1209e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6573/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Practices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The restoration plan shall require such restoration practices and measures as are necessary to restore and enhance habitat for species described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6572/b"},"text":"section 6572(b) of this title","children":[],"tail":", including the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1209e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6573/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Land management practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1209e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6573/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vegetative treatments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1209e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6573/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Structural practices and measures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1209e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6573/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Practices to increase carbon sequestration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1209e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6573/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Practices to improve biological diversity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1209e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6573/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other practices and measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1209e8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tV/s503"},"text":"Pub. L. 108–148, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1912"},"text":"117 Stat. 1912","children":[],"tail":"; "},{"tag":"ref",