{"tag":"section","attrib":{"id":"id7a29fe62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404"},"text":null,"children":[{"tag":"num","attrib":{"value":"7404"},"text":"§ 7404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization or denial of port entry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a29fe63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of information required under Agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29fe64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vessel described in paragraph (2) seeking entry to a port that is subject to the jurisdiction of the United States must submit to the Secretary of the department in which the Coast Guard is operating information as required under the Agreement in advance of its arrival in port. The Secretary of the department in which the Coast Guard is operating shall provide that information to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered vessels","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel referred to in paragraph (1) is any vessel that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a29fe66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not documented under chapter 121 of title 46; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29fe67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not numbered under chapter 123 of that title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29fe68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decision to authorize or deny port entry","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29fe69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall decide, based on the information submitted under subsection (a), whether to authorize or deny port entry by the vessel, and shall communicate such decision to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a29fe6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the department in which the Coast Guard is operating; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29fe6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel or its representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization or denial of entry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the department in which the Coast Guard is operating shall authorize or deny entry to vessels to which such a decision applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessels to which entry may be denied","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the department in which the Coast Guard is operating may deny entry to any vessel to which such a decision applies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a29fe6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is described in subsection (a)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29fe6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a29fe70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a listed IUU vessel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a29fe71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of Commerce has reasonable grounds to believe—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a29fe72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/b/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has engaged in IUU fishing or fishing-related activities in support of such fishing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a29fe73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/b/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has violated this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29fe74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of use of port","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a vessel described in subsection (a)(2) is in a port that is subject to the jurisdiction of the United States, the Secretary of the department in which the Coast Guard is operating, at the request of the Secretary, shall deny such vessel the use of the port for landing, transshipment, packaging and processing of fish, refueling, resupplying, maintenance, and drydocking, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29fe75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel entered without authorization under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is a listed IUU vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is not documented under the laws of another nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the flag nation of the vessel has failed to provide confirmation requested by the Secretary that the fish on board were taken in accordance with applicable RFMO conservation and management measures; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary has reasonable grounds to believe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a29fe7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel lacks valid authorizations to engage in fishing or fishing-related activities as required by its flag nation or the relevant coastal nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29fe7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fish on board were taken in violation of foreign law or in contravention of any RFMO conservation and management measure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29fe7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the vessel has engaged in IUU fishing or fishing-related activities in support of such fishing, including in support of a listed IUU vessel, unless it can establish that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a29fe7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/c/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it was acting in a manner consistent with applicable RFMO conservation and management measures; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a29fe7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/c/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the provision of personnel, fuel, gear, and other supplies at sea, the vessel provisioned was not, at the time of provisioning, a listed IUU vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29fe7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsections (b) and (c), the Secretary of the department in which the Coast Guard is operating may allow port entry or the use of port services—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29fe80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if they are essential to the safety or health of the crew or safety of the vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow, where appropriate, for the scrapping of the vessel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7404/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to an inspection or other enforcement action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a29fe83-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/81/tIII/s305"},"text":"Pub. L. 114–81, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/666"},"text":"129 Stat. 666","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
