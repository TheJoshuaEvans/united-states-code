{"tag":"section","attrib":{"id":"id778719dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s422c"},"text":null,"children":[{"tag":"num","attrib":{"value":"422c"},"text":"§ 422c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ascertaining and marking of lines of battle","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be lawful for any State that had troops engaged in the battle of the Moores Creek National Battlefield, to enter upon the same for the purpose of ascertaining and marking the lines of battle of its troops engaged therein: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That before any such lines are permanently designated the position of the lines and the proposed methods of marking them by monuments, tablets, or otherwise, shall be submitted to and approved by the Secretary of the Interior; and all such lines, designs, and inscriptions for the same shall first receive the written approval of the Secretary of the Interior."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778719de-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-06-02/ch448/s4"},"text":"June 2, 1926, ch. 448, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/686"},"text":"44 Stat. 686","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/344/s12"},"text":"Pub. L. 96–344, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1136"},"text":"94 Stat. 1136","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778719df-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id778719e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id778719e1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Battlefield” substituted in text for “Military Park” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/344/s12"},"text":"Pub. L. 96–344, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1136"},"text":"94 Stat. 1136","children":[],"tail":", which redesignated Moores Creek National Military Park as Moores Creek National Battlefield."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id778719e2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id778719e3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of administrative functions of park, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s422a"},"text":"section 422a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
