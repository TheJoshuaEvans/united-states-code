{"tag":"section","attrib":{"id":"id7800b614-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51"},"text":null,"children":[{"tag":"num","attrib":{"value":"460nnn–51"},"text":"§ 460nnn–51.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of advisory council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7800b615-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish the Steens Mountain Advisory Council to advise the Secretary in managing the Cooperative Management and Protection Area and in promoting the cooperative management under subpart 3 of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b616-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory council shall consist of 12 voting members, to be appointed by the Secretary, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b617-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A private landowner in the Cooperative Management and Protection Area, appointed from nominees submitted by the county court for Harney County, Oregon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b618-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two persons who are grazing permittees on Federal lands in the Cooperative Management and Protection Area, appointed from nominees submitted by the county court for Harney County, Oregon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b619-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person interested in fish and recreational fishing in the Cooperative Management and Protection Area, appointed from nominees submitted by the Governor of Oregon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b61a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Burns Paiute Tribe, appointed from nominees submitted by the Burns Paiute Tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b61b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two persons who are recognized environmental representatives, one of whom shall represent the State as a whole, and one of whom is from the local area, appointed from nominees submitted by the Governor of Oregon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b61c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who participates in what is commonly called dispersed recreation, such as hiking, camping, nature viewing, nature photography, bird watching, horse back riding, or trail walking, appointed from nominees submitted by the Oregon State Director of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b61d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who is a recreational permit holder or is a representative of a commercial recreation operation in the Cooperative Management and Protection Area, appointed from nominees submitted jointly by the Oregon State Director of the Bureau of Land Management and the county court for Harney County, Oregon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b61e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who participates in what is commonly called mechanized or consumptive recreation, such as hunting, fishing, off-road driving, hang gliding, or parasailing, appointed from nominees submitted by the Oregon State Director of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b61f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person with expertise and interest in wild horse management on Steens Mountain, appointed from nominees submitted by the Oregon State Director of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b620-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who has no financial interest in the Cooperative Management and Protection Area to represent statewide interests, appointed from nominees submitted by the Governor of Oregon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b621-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In reviewing nominees submitted under subsection (b) for possible appointment to the advisory council, the Secretary shall consult with the respective community of interest that the nominees are to represent to ensure that the nominees have the support of their community of interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b622-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002380"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002380"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Two subsecs. (d) have been enacted."}],"tail":" Terms"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b623-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staggered terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the advisory council shall be appointed for terms of 3 years, except that, of the members first appointed, four members shall be appointed for a term of 1 year and four members shall be appointed for a term of 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b624-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member may be reappointed to serve on the advisory council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b625-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy on the advisory council shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b626-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Chairperson and procedures"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory council shall elect a chairperson and establish such rules and procedures as it deems necessary or desirable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b627-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service without compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the advisory council shall serve without pay, but the Secretary shall reimburse members for reasonable expenses incurred in carrying out official duties as a member of the council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b628-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide the advisory council with necessary administrative support and shall designate an appropriate officer of the Bureau of Land Management to serve as the Secretary’s liaison to the council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b629-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State liaison","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint one person, nominated by the Governor of Oregon, to serve as the State government liaison to the advisory council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b62a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–51/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory committee ","children":[{"tag":"ref","attrib":{"idref":"fn002381"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002381"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “advisory council”."}],"tail":" shall be subject to the Federal Land Policy and Management Act of 1976 ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.) and chapter 10 of title 5."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7800b62b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399/tI/s131"},"text":"Pub. L. 106–399, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1664"},"text":"114 Stat. 1664","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/96"},"text":"Pub. L. 117–286, § 4(a)(96)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4316"},"text":"136 Stat. 4316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7800b62c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7800b62d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7800b62e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in subsec. (h), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7800b62f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5.” for “the Federal Advisory Committee Act (5 U.S.C. App.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
