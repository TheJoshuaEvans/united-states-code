{"tag":"section","attrib":{"id":"id77c2c2b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–15"},"text":null,"children":[{"tag":"num","attrib":{"value":"460l–15"},"text":"§ 460l–15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease of facilities and lands to non-Federal public bodies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"At projects, the construction of which has commenced or been completed as of ","children":[{"tag":"date","attrib":{"date":"1965-07-09"},"text":"July 9, 1965","children":[],"tail":", where non-Federal public bodies agree to administer project land and water areas for recreation and fish and wildlife enhancement purposes and to bear the "},{"tag":"ref","attrib":{"idref":"fn002299"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002299"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “the” probably should not appear."}],"tail":" not less than one-half the costs of operation, maintenance, and replacement of existing facilities serving those purposes, such facilities and appropriate project lands may be leased to non-Federal public bodies."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77c2c2b5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/72/s4"},"text":"Pub. L. 89–72, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-09"},"text":"July 9, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/215"},"text":"79 Stat. 215","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXXVIII/s2804/c"},"text":"Pub. L. 102–575, title XXVIII, § 2804(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4691"},"text":"106 Stat. 4691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77c2c2b6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77c2c2b7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77c2c2b8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575"},"text":"Pub. L. 102–575","children":[],"tail":" substituted “not less than one-half the costs of operation” for “costs of operation”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
