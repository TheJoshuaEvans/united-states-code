{"tag":"section","attrib":{"id":"id7839eeaf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e"},"text":null,"children":[{"tag":"num","attrib":{"value":"543e"},"text":"§ 543e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scenic Area Advisory Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7839eeb0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; consultations with Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby established the Scenic Area Advisory Board (hereinafter referred to as the “Board”). The Secretary shall consult with and seek the advice and recommendations of the Board with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7839eeb1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administration of the Scenic Area with respect to policies, programs, and activities in accordance with sections 543 to 543h of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eeb2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparation and implementation of the comprehensive management plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eeb3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of the visitor center authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s543c/f"},"text":"section 543c(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eeb4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition and selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall be composed of nine members, who shall be selected as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7839eeb5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" five members appointed by the Mono County Board of Supervisors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eeb6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members appointed by the Governor of California (one of whom shall be an employee of the California Division of Parks and Recreation);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eeb7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member appointed by the mayor of the city of Los Angeles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eeb8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member appointed by the Secretary (who shall be an employee of the Forest Service).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eeb9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member of the Board shall be appointed to serve for a term of three years except that the initial appointments shall be for terms as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7839eeba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of those members appointed by the Mono County Board of Supervisors one shall be appointed to serve for a term of one year, two shall be for a term of two years, and two shall be for a term of three years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eebb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of those members appointed by the Governor of California one shall be appointed to serve for a term of one year and one shall be appointed to serve for a term of three years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eebc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member appointed by the mayor of the city of Los Angeles shall be appointed to serve for a term of two years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eebd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member appointed by the Secretary shall be appointed to serve for a term of three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eebe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial appointment; Chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Board shall be appointed within ninety days of ","children":[{"tag":"date","attrib":{"date":"1984-09-28"},"text":"September 28, 1984","children":[],"tail":". The members of the Board shall, at their first meeting, elect a Chairman."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eebf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual meetings and consultations with Secretary or designee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, or a designee, shall from time to time, but at least annually, meet and consult with the Board on matters relating to the administration of the scenic area.","children":[{"tag":"ref","attrib":{"idref":"fn002423"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002423"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eec0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation; expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board shall serve without compensation as such, but the Secretary is authorized to pay, upon vouchers signed by the Chairman, the expenses reasonably incurred by the Board and its members in carrying out their duties under sections 543 to 543h of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eec1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy in the Board shall be filled in the same manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eec2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of those members appointed shall constitute a quorum for the conduct of all business of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eec3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543e/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall terminate ten years from the date of its first meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7839eec4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/425/tIII/s306"},"text":"Pub. L. 98–425, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1637"},"text":"98 Stat. 1637","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
