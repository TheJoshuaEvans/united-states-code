{"tag":"section","attrib":{"id":"id78921fe1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s758e"},"text":null,"children":[{"tag":"num","attrib":{"value":"758e"},"text":"§ 758e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Central, Western, and South Pacific Ocean fisheries development program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce (hereafter referred to in sections 758e to 758e–5 of this title as the “Secretary”) is authorized to carry out, directly or by contract, with the Pacific Fisheries Development Foundation or other agency or organization, a program for the development of the tuna and other latent fisheries resources of the Central, Western, and South Pacific Ocean. The program shall include, but not be limited to, exploration for, and stock assessment of, tuna and other fish; improvement of harvesting techniques; gear development; biological resource monitoring; and an economic evaluation of the potential for tuna and other fisheries in such area.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78921fe2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/444/s2"},"text":"Pub. L. 92–444, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-29"},"text":"Sept. 29, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/745"},"text":"86 Stat. 745","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/343/s1/1"},"text":"Pub. L. 94–343, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-06"},"text":"July 6, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/809"},"text":"90 Stat. 809","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/295/s1/1"},"text":"Pub. L. 95–295, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-16"},"text":"June 16, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/319"},"text":"92 Stat. 319","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/498/tIV/s410"},"text":"Pub. L. 98–498, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2309"},"text":"98 Stat. 2309","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78921fe3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78921fe4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78921fe5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/498"},"text":"Pub. L. 98–498","children":[],"tail":" substituted “Pacific Fisheries Development Foundation” for “Pacific Tuna Development Foundation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/295"},"text":"Pub. L. 95–295","children":[],"tail":" inserted provision authorizing contracts for programs with the Pacific Tuna Development Foundation or other agency or organization."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/343"},"text":"Pub. L. 94–343","children":[],"tail":" struck “three year” before “program for”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78921fe6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id78921fe7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/444/s1"},"text":"Pub. L. 92–444, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-29"},"text":"Sept. 29, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/744"},"text":"86 Stat. 744","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/444/s1"},"text":"“That this Act [enacting this section and sections 758e–1 to 758e–5 of this title] may be cited as the ‘Central, Western, and South Pacific Fisheries Development Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
