{"tag":"section","attrib":{"id":"id77eb31f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vv–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"460vv–10"},"text":"§ 460vv–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nomenclature","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The wilderness areas, the national recreation area, the national scenic and wildlife area, the national scenic area, and the botanical areas designated in this subchapter shall be referred to as the “Winding Stair Mountain National Recreation and Wilderness Area”.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77eb31f1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/499/s12"},"text":"Pub. L. 100–499, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-18"},"text":"Oct. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2497"},"text":"102 Stat. 2497","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
