{"tag":"section","attrib":{"id":"id781639d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470kk"},"text":null,"children":[{"tag":"num","attrib":{"value":"470kk"},"text":"§ 470kk.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id781639d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470kk/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mining, mineral leasing, reclamation, and other multiple uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to repeal, modify, or impose additional restrictions on the activities permitted under existing laws and authorities relating to mining, mineral leasing, reclamation, and other multiple uses of the public lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id781639d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470kk/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private collections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter applies to, or requires a permit for, the collection for private purposes of any rock, coin, bullet, or mineral which is not an archaeological resource, as determined under uniform regulations promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s470bb/1"},"text":"section 470bb(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id781639d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470kk/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands within chapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to affect any land other than public land or Indian land or to affect the lawful recovery, collection, or sale of archaeological resources from land other than public land or Indian land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id781639d8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/95/s12"},"text":"Pub. L. 96–95, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-31"},"text":"Oct. 31, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/728"},"text":"93 Stat. 728","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
