{"tag":"section","attrib":{"id":"id780f0dab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd"},"text":null,"children":[{"tag":"num","attrib":{"value":"460dddd"},"text":"§ 460dddd.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Recreation Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id780f0dac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780f0dad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to valid existing rights, there is established the San Rafael Swell Recreation Area in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0dae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Recreation Area shall consist of approximately 216,995 acres of Federal land managed by the Bureau of Land Management, as generally depicted on the Map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0daf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purposes of the Recreation Area are to provide for the protection, conservation, and enhancement of the recreational, cultural, natural, scenic, wildlife, ecological, historical, and educational resources of the Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0db0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map and legal description","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780f0db1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall file a map and legal description of the Recreation Area with the Committee on Natural Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0db2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description filed under paragraph (1) shall have the same force and effect as if included in this subchapter, except that the Secretary may correct clerical and typographical errors in the map and legal description.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0db3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A copy of the map and legal description filed under paragraph (1) shall be on file and available for public inspection in the appropriate offices of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id780f0db4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1221"},"text":"Pub. L. 116–9, title I, § 1221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/668"},"text":"133 Stat. 668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id780f0db5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id780f0db6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id780f0db7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Emery County Public Land Management","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI"},"text":"Pub. L. 116–9, title I","children":[],"tail":", §§ 1211–1214, "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/667"},"text":"133 Stat. 667","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/9/tI"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1211"},"text":"“SEC. 1211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DEFINITIONS.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“In this part [part II (§§ 1211–1255) of subtitle C of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9"},"text":"Pub. L. 116–9","children":[],"tail":", enacting this subchapter, amending "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1274"},"text":"section 1274 of this title","children":[],"tail":", enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1274"},"text":"section 1274 of this title","children":[],"tail":", and enacting provisions listed in a table of Wilderness Areas set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"section 1132 of this title","children":[],"tail":" and in a table of National Monuments set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320301"},"text":"section 320301 of Title 54","children":[],"tail":", National Parks Service and Related Programs]:"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Council","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Council’ means the San Rafael Swell Recreation Area Advisory Council established under section 1223(a) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460dddd–2/a"},"text":"16 U.S.C. 460dddd–2(a)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"County","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘County’ means Emery County in the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Management Plan’ means the management plan for the Recreation Area developed under section 1222(c) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460dddd–1/c"},"text":"16 U.S.C. 460dddd–1(c)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Map","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Map’ means the map entitled ‘Emery County Public Land Management Act of 2018 Overview Map’ and dated ","children":[{"tag":"date","attrib":{"date":"2019-02-05"},"text":"February 5, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recreation area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Recreation Area’ means the San Rafael Swell Recreation Area established by section 1221(a)(1) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460dddd/a/1"},"text":"16 U.S.C. 460dddd(a)(1)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘Secretary’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary [of the Interior], with respect to public land administered by the Bureau of Land Management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, with respect to National Forest System land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘State’ means the State of Utah.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Wilderness area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘wilderness area’ means a wilderness area designated by section 1231(a) [enacting provisions listed in a table of Wilderness Areas set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"section 1132 of this title","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1212"},"text":"“SEC. 1212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ADMINISTRATION.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“Nothing in this part affects or modifies—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any right of any federally recognized Indian Tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any obligation of the United States to any federally recognized Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1213"},"text":"“SEC. 1213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" EFFECT ON WATER RIGHTS.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“Nothing in this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects the use or allocation, in existence on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":"], of any water, water right, or interest in water;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects any water right (as defined by applicable State law) in existence on the date of enactment of this Act, including any water right held by the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects any interstate water compact in existence on the date of enactment of this Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be considered to be a relinquishment or reduction of any water rights reserved or appropriated by the United States in the State on or before the date of enactment of this Act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects the management and operation of Flaming Gorge Dam and Reservoir, including the storage, management, and release of water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1214"},"text":"“SEC. 1214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SAVINGS CLAUSE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Nothing in this part diminishes the authority of the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/195"},"text":"Public Law 92–195","children":[],"tail":" (commonly known as the ‘Wild Free-Roaming Horses and Burros Act’) ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1331"},"text":"16 U.S.C. 1331","children":[],"tail":" et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
