{"tag":"section","attrib":{"id":"id78994bfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777g–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"777g–1"},"text":"§ 777g–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boating infrastructure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78994bff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777g–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to provide funds to States for the development and maintenance of facilities for transient nontrailerable recreational vessels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78994c00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777g–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78994c01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777g–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 6 months after submitting a survey to the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s777g/g"},"text":"section 777g(g) of this title","children":[],"tail":", a State may develop and submit to the Secretary a plan for the construction, renovation, and maintenance of facilities for transient nontrailerable recreational vessels, and access to those facilities, to meet the needs of nontrailerable recreational vessels operating on navigable waters in the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78994c02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777g–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78994c03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777g–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall obligate amounts made available under section 777c(a)(4) ","children":[{"tag":"ref","attrib":{"idref":"fn002513"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002513"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title to make grants to any State to pay not more than 75 percent of the cost to a State of constructing, renovating, or maintaining facilities for transient nontrailerable recreational vessels."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78994c04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777g–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under paragraph (1), the Secretary shall give priority to projects that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78994c05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777g–1/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consist of the construction, renovation, or maintenance of facilities for transient nontrailerable recreational vessels in accordance with a plan submitted by a State under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78994c06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777g–1/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for public/private partnership efforts to develop, maintain, and operate facilities for transient nontrailerable recreational vessels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78994c07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777g–1/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" propose innovative ways to increase the availability of facilities for transient nontrailerable recreational vessels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78994c08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777g–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78994c09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777g–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “nontrailerable recreational vessel” means a recreational vessel 26 feet in length or longer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78994c0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777g–1/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated primarily for pleasure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78994c0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777g–1/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leased, rented, or chartered to another for the latter’s pleasure;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78994c0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777g–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “facilities for transient nontrailerable recreational vessels” includes mooring buoys, day-docks, navigational aids, seasonal slips, safe harbors, or similar structures located on navigable waters, that are available to the general public (as determined by the Secretary of the Interior) and designed for temporary use by nontrailerable recreational vessels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78994c0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777g–1/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, American Samoa, the Virgin Islands, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78994c0e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tVII/s7404"},"text":"Pub. L. 105–178, title VII, § 7404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/486"},"text":"112 Stat. 486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIX/s9012/c"},"text":"Pub. L. 105–206, title IX, § 9012(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/864"},"text":"112 Stat. 864","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tX/s10115"},"text":"Pub. L. 109–59, title X, § 10115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1928"},"text":"119 Stat. 1928","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78994c0f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78994c10-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78994c11-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Paragraph (4) of section 777c(a), referred to in subsec. (d)(1), was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tX/s10001/b/1/D"},"text":"Pub. L. 114–94, div. A, title X, § 10001(b)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1620"},"text":"129 Stat. 1620","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s777c/a/3/A"},"text":"section 777c(a)(3)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78994c12-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s7404"},"text":"section 7404 of Pub. L. 105–178","children":[],"tail":". Subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/s7404"},"text":"section 7404 of Pub. L. 105–178","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s9012/c"},"text":"Pub. L. 105–206, § 9012(c)","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s777g"},"text":"section 777g of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Sportfishing and Boating Safety Act of 1998, and also as part of the Transportation Equity Act for the 21st Century, and not as part of the Fish Restoration and Management Projects Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78994c13-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s777c/a/4"},"text":"section 777c(a)(4) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s777c/b/3/B"},"text":"