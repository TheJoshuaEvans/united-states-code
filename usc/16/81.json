{"tag":"section","attrib":{"id":"id76ff2483-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s81"},"text":null,"children":[{"tag":"num","attrib":{"value":"81"},"text":"§ 81.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; statement of purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon proclamation of the President, as herein provided, sufficient of the areas hereinafter specified for the purposes of this subchapter shall be established and set apart as the Colonial National Historical Park for the preservation of the historical structures and remains thereon and for the benefit and enjoyment of the people.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76ff2484-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-07-03/ch837/s1"},"text":"July 3, 1930, ch. 837, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/855"},"text":"46 Stat. 855","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-05/ch525/s2"},"text":"June 5, 1936, ch. 525, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1483"},"text":"49 Stat. 1483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id76ff2485-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id76ff2486-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id76ff2487-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s443"},"text":"section 443 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id76ff2488-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id76ff2489-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-05/ch525/s2"},"text":"Act June 5, 1936, ch. 525, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1483"},"text":"49 Stat. 1483","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1936-06-05/ch525/s2"},"text":"“That the area now within the Colonial National Monument, together with such additions as may hereafter be made thereto, pursuant to section 1 hereof [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s81b"},"text":"section 81b of this title","children":[],"tail":"], shall be known as the ‘Colonial National Historical Park’, under which name the aforesaid national park shall be entitled to receive and to use all moneys heretofore or hereafter appropriated for the Colonial National Monument.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id76ff248a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Jamestown 400th Commemoration Commission","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/565"},"text":"Pub. L. 106–565","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2812"},"text":"114 Stat. 2812","children":[],"tail":", known as the “Jamestown 400th Commemoration Commission Act of 2000”, established the Jamestown 400th Commemoration Commission to ensure a suitable national observance of the 400th anniversary of the founding of Jamestown in 2007 and provided that the Commission report to Congress by "},{"tag":"date","attrib":{"date":"2008-09-30"},"text":"Sept. 30, 2008","children":[],"tail":", and terminate on "},{"tag":"date","attrib":{"date":"2008-12-31"},"text":"Dec. 31, 2008","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s127"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 127]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–229, 2763A–359, enacted provisions substantially identical to those enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/106/565"},"text":"Pub. L. 106–565","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
