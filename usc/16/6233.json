{"tag":"section","attrib":{"id":"id7a03b2d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6233"},"text":null,"children":[{"tag":"num","attrib":{"value":"6233"},"text":"§ 6233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a03b2d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6233/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prompt implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue direction regarding implementation of this chapter by interim directive within 180 days after ","children":[{"tag":"date","attrib":{"date":"2003-02-20"},"text":"February 20, 2003","children":[],"tail":". The Secretary shall implement this chapter beginning with the first billing cycle for organizational camp special use authorizations occurring more than 180 days after "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"February 20, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a03b2d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6233/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Phase-in of use fee increases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In issuing any direction regarding implementation of this chapter under subsection (a), the Secretary shall consider whether to phase-in any significant increases in annual land or facility use fees for organizational camps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a03b2d7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tV/s504"},"text":"Pub. L. 108–7, div. F, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/296"},"text":"117 Stat. 296","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a03b2d8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a03b2d9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a03b2da-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, which was translated as reading “this title”, meaning title V of div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":", known as the National Forest Organizational Camp Fee Improvement Act of 2003, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
