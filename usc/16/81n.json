{"tag":"section","attrib":{"id":"id770194e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s81n"},"text":null,"children":[{"tag":"num","attrib":{"value":"81n"},"text":"§ 81n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of lands for State Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is further authorized to transfer without compensation up to fifteen acres of the Colonial National Historical Park, Virginia, to the Commonwealth of Virginia for use by agencies of the Commonwealth in the establishment of a State Park in furtherance of the purposes of the Colonial National Historical Park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id770194e6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-03-29/ch105/s2"},"text":"Mar. 29, 1956, ch. 105, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/62"},"text":"70 Stat. 62","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id770194e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id770194e8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id770194e9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-07-03/ch837"},"text":"act July 3, 1930, ch. 837","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/855"},"text":"46 Stat. 855","children":[],"tail":", which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
