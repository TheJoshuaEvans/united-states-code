{"tag":"section","attrib":{"id":"id7a3d119f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8542"},"text":null,"children":[{"tag":"num","attrib":{"value":"8542"},"text":"§ 8542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permit flexibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3d11a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8542/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned shall establish guidelines to allow a holder of a special recreation permit under subsection (h) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6802"},"text":"section 6802 of this title","children":[],"tail":" (as amended by this title), to engage in another recreational activity under the special recreation permit that is substantially similar to the specific activity authorized under the special recreation permit."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d11a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8542/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, a recreational activity shall be considered to be a substantially similar recreational activity if the recreational activity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3d11a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8542/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is comparable in type, nature, scope, and ecological setting to the specific activity authorized under the special recreation permit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d11a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8542/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not result in a greater impact on natural and cultural resources than the impact of the authorized activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d11a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8542/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not adversely affect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3d11a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8542/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other holder of a special recreation permit or other permit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3d11a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8542/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other authorized use of the Federal recreational lands and waters; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d11a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8542/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is consistent with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3d11a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8542/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any applicable laws (including regulations); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3d11a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8542/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the land management plan, resource management plan, or equivalent plan applicable to the Federal recreational lands and waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d11aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8542/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surrender of unused visitor-use days","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3d11ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8542/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recreation service provider holding a special recreation permit described in paragraph (13)(A)(iv) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6801"},"text":"section 6801 of this title","children":[],"tail":" (as amended by this title) may—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3d11ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8542/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Secretary concerned of an inability to use visitor-use days annually allocated to the recreation service provider under the special recreation permit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3d11ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8542/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surrender to the Secretary concerned the unused visitor-use days for the applicable year for temporary reassignment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8547/b"},"text":"section 8547(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d11ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8542/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure a recreation service provider described in paragraph (1) is able to make an informed decision before surrendering any unused visitor-use day under paragraph (1)(B), the Secretary concerned shall, on the request of the applicable recreation service provider, determine and notify the recreation service provider whether the unused visitor-use day meets the requirement described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8546/b/3/B"},"text":"section 8546(b)(3)(B) of this title","children":[],"tail":" before the recreation service provider surrenders the unused visitor-use day."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d11af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8542/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section affects any authority of, regulation issued by, or decision of the Secretary concerned relating to the use of electric bicycles on Federal recreational lands and waters under any other Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3d11b0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tIII/s313"},"text":"Pub. L. 118–234, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2901"},"text":"138 Stat. 2901","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3d11b1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3d11b2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a3d11b3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"As amended by this title, referred to in subsecs. (a) and (c)(1), means as amended by title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234"},"text":"Pub. L. 118–234","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
