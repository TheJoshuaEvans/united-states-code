{"tag":"section","attrib":{"id":"id778bd3b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c"},"text":null,"children":[{"tag":"num","attrib":{"value":"424c"},"text":"§ 424c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Moccasin Bend National Archeological District","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id778bd3b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Moccasin Bend National Archeological District Act”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id778bd3b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id778bd3b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id778bd3b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Archeological district","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “archeological district” means the Moccasin Bend National Archeological District.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id778bd3b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the State of Tennessee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id778bd3b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Map” means the map entitled, “Boundary Map Moccasin Bend National Archeological District”, numbered 301/80098, and dated September 2002.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id778bd3ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id778bd3bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to preserve, protect, and interpret for the benefit of the public the nationally significant archeological and historic resources located on the peninsula known as Moccasin Bend, Tennessee, there is established as a unit of Chickamauga and Chattanooga National Military Park, the Moccasin Bend National Archeological District.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id778bd3bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The archeological district shall consist of approximately 780 acres generally depicted on the Map. The Map shall be on file and available for public inspection in the appropriate offices of the National Park Service, Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id778bd3bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of land and interests in land","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id778bd3be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire by donation, purchase from willing sellers using donated or appropriated funds, or exchange, lands and interests in lands within the exterior boundary of the archeological district. The Secretary may acquire the State, county and city-owned land and interests in land for inclusion in the archeological district only by donation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id778bd3bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Easement outside boundary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To allow access between areas of the archeological district that on ","children":[{"tag":"date","attrib":{"date":"2003-02-20"},"text":"February 20, 2003","children":[],"tail":", are noncontiguous, the Secretary may acquire by donation or purchase from willing owners using donated or appropriated funds, or exchange, easements connecting the areas generally depicted on the Map."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id778bd3c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id778bd3c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The archeological district shall be administered by the Secretary in accordance with this section, with laws applicable to Chickamauga and Chattanooga National Military Park, and with the laws generally applicable to units of the National Park System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id778bd3c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may consult and enter into cooperative agreements with culturally affiliated federally recognized Indian tribes, governmental entities, and interested persons to provide for the restoration, preservation, development, interpretation, and use of the archeological district.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id778bd3c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visitor interpretive center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of interpreting the historical themes and cultural resources of the archeological district, the Secretary may establish and administer a visitor center in the archeological district.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id778bd3c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424c/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after funds are made available under this section, the Secretary shall develop a general management plan for the archeological district. The general management plan shall describe the appropriate protection and preservation of natural, cultural, and scenic resources, visitor use, and facility development within the archeological district consistent with the purposes of this section, while ensuring continued access by private landowners to their property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id778bd3c5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tI/s160"},"text":"Pub. L. 108–7, div. F, title I, § 160","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/247"},"text":"117 Stat. 247","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778bd3c6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id778bd3c7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id778bd3c8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/s160"},"text":"section 160 of div. F of Pub. L. 108–7","children":[],"tail":". Subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/s160"},"text":"section 160 of div. F of Pub. L. 108–7","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s424a–4"},"text":"section 424a–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
