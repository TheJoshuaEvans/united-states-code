{"tag":"section","attrib":{"id":"id79a2099c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2701"},"text":null,"children":[{"tag":"num","attrib":{"value":"2701"},"text":"§ 2701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program in accordance with this chapter to encourage municipalities, electric cooperatives, industrial development agencies, nonprofit organizations, and other persons to undertake the development of small hydroelectric power projects in connection with existing dams which are not being used to generate electric power.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79a2099d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617/tIV/s401"},"text":"Pub. L. 95–617, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3154"},"text":"92 Stat. 3154","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a2099e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a2099f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79a209a0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Secretary, referred to in text, means the Secretary of Energy, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2602/14"},"text":"section 2602(14) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a209a1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79a209a2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Promulgation of Implementing Rules and Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tIV/s408/d"},"text":"Pub. L. 96–294, title IV, § 408(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/718"},"text":"94 Stat. 718","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/294/tIV/s408/d"},"text":"“The Secretary shall take such action as may be necessary to assure the establishment, as soon as possible after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":"] (and in any event within six months after such date in the case of the amendments made by subsections (a) and (c) of this section and in the case of the loan program under section 403 of the Public Utility Regulatory Policies Act of 1978) [amending section 2708 of the title, and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2703"},"text":"section 2703 of this title","children":[],"tail":" respectively], of such rules and regulations as may be necessary to fully implement his responsibilities under title IV of the Public Utility Regulatory Policies Act of 1978 [this subchapter] and the amendments thereto made by this section [amending sections 2705 and 2708 of this title]”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
