{"tag":"section","attrib":{"id":"id77fe44c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–49"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–49"},"text":"§ 460lll–49.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tennessee Valley Authority transfer funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fe44c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–49/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The funding described in this section is funding derived from only 1 or more of the following sources:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fe44c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–49/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nonpower fund balances and collections.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe44c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–49/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Investment returns of the nonpower program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe44c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–49/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Applied programmatic savings in the power and nonpower programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe44c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–49/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Savings from the suspension of bonuses and awards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe44c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–49/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Savings from reductions in memberships and contributions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe44ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–49/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increases in collections resulting from nonpower activities, including user fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe44cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–49/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increases in charges to private and public utilities both investor and cooperatively owned, as well as to direct load customers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fe44cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–49/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds from the sources described in subsection (a) shall be available notwithstanding section 11, 14, 15, or 29 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s831j"},"text":"16 U.S.C. 831j","children":[],"tail":", 831m, 831n, 831bb] or any other provision of the Tennessee Valley Authority Act of 1933 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s831"},"text":"16 U.S.C. 831","children":[],"tail":" et seq.) or any provisions of the covenants contained in any power bonds issued by the Tennessee Valley Authority."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fe44cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–49/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sufficiency of savings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The savings from and the revenue adjustment to the budget of the Tennessee Valley Authority for the first fiscal year of the transfer and each fiscal year thereafter shall be sufficient so that the net spending authority and resulting outlays to carry out activities with funding described in subsection (a) shall not exceed $0 for the first fiscal year of the transfer and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fe44ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–49/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Itemized list of reductions and increased receipts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fe44cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–49/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposed changes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date of transfer pursuant to section 460","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–41 of this title, the Chairman of the Tennessee Valley Authority shall submit to the Committee on Appropriations of the House of Representatives and the Committee on Appropriations of the Senate an itemized list of the amounts of reductions in spending and increases in receipts that are proposed to be made as a result of activities under this subsection during the first fiscal year of the transfer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe44d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–49/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actual changes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 24 months after the effective date of the transfer, the Chairman of the Tennessee Valley Authority shall submit to the Committee on Appropriations of the House of Representatives and the Committee on Appropriations of the Senate an itemized list of the amounts of reductions in spending and increases in receipts as a result of activities under this subsection during the first fiscal year of the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fe44d1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s549"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 549]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–325.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77fe44d2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77fe44d3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77fe44d4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Tennessee Valley Authority Act of 1933, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-18/ch32"},"text":"act May 18, 1933, ch. 32","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/58"},"text":"48 Stat. 58","children":[],"tail":", which is classified generally to chapter 12A (§ 831 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s831"},"text":"section 831 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
