{"tag":"section","attrib":{"id":"id7760f371-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"410uu–1"},"text":"§ 410uu–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of boundaries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7760f372-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The boundaries of the Hopewell Culture National Historical Park (referred to as the “park”) are revised to include the lands within the areas marked for inclusion in the monument as generally depicted on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7760f373-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the map entitled “Hopeton Earthworks” numbered 353–80025 and dated July 1987;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f374-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the map entitled “High Banks Works” numbered 353–80027 and dated July 1987;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f375-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the map entitled “Hopewell Mound Group” numbered 353–80029 and dated July 1987;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f376-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the map entitled “Seip Earthworks” numbered 353–80033 and dated July 1987; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f377-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–1/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the map entitled “Hopewell Culture National Historical Park, Ohio Proposed Boundary Adjustment” numbered 353/80,049 and dated June, 2006.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f378-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public inspection of maps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each map described in subsection (a) shall be on file and available for public inspection in the office of the Director of the National Park Service, Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f379-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior (referred to as the “Secretary”) may, by notice in the Federal Register after receipt of public comment, make minor adjustments in the boundaries of areas added to the park by subsection (a) and other areas of the park: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That any such minor boundary adjustments cumulatively shall not cause the total acreage of the park to increase more than 10 per centum above the existing acreage of Mound City Group National Monument, plus the acreage of the inclusions authorized under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f37a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of lands","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7760f37b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Secretary may acquire lands and interests in land within the areas added to the park by subsection (a) by donation, purchase with donated or appropriated funds, or exchange.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f37c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7760f37d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–1/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lands and interests in land owned by the State of Ohio or a political subdivision thereof may be acquired only by donation or exchange.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7760f37e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–1/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lands and interests in land may be acquired by purchase at a price based on the fair market value thereof as determined by independent appraisal, consistent with the Uniform Relocation Assistance and Real Property Acquisition Policies Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4601"},"text":"42 U.S.C. 4601","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f37f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may acquire lands added by subsection (a)(5) only from willing sellers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7760f380-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/294/s2"},"text":"Pub. L. 102–294, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-27"},"text":"May 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/185"},"text":"106 Stat. 185","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7104"},"text":"Pub. L. 111–11, title VII, § 7104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1191"},"text":"123 Stat. 1191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7760f381-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7760f382-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7760f383-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Uniform Relocation Assistance and Real Property Acquisition Policies Act of 1970, referred to in subsec. (d)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/646"},"text":"Pub. L. 91–646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-02"},"text":"Jan. 2, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1894"},"text":"84 Stat. 1894","children":[],"tail":", which is classified principally to chapter 61 (§ 4601 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4601"},"text":"section 4601 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7760f384-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7104/1"},"text":"Pub. L. 111–11, § 7104(1)","children":[],"tail":"–(3), added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7104/4"},"text":"Pub. L. 111–11, § 7104(4)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
