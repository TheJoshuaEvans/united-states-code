{"tag":"section","attrib":{"id":"id77064fb8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s112"},"text":null,"children":[{"tag":"num","attrib":{"value":"112"},"text":"§ 112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Control; regulations; prehistoric ruins","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Mesa Verde National Park shall be under the exclusive control of the Secretary of the Interior, whose duty it shall be to prescribe such rules and regulations and establish such service as he may deem necessary for the care and management of the same. Such regulations shall provide specifically for the preservation from injury or spoliation of the ruins and other works and relics of prehistoric or primitive man within said park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77064fb9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1906-06-29/ch3607/s2"},"text":"June 29, 1906, ch. 3607, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/617"},"text":"34 Stat. 617","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77064fba-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77064fbb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77064fbc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"As enacted by act ","children":[{"tag":"date","attrib":{"date":"1906-06-29"},"text":"June 29, 1906","children":[],"tail":", this section began with a clause naming the park which was stricken out and inserted as the last sentence of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
