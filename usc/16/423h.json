{"tag":"section","attrib":{"id":"id77898a44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423h"},"text":null,"children":[{"tag":"num","attrib":{"value":"423h"},"text":"§ 423h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report of completion; superintendent of battlefield","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon completion of the acquisition of the land and the work of the commission, the Secretary of the Interior shall render a report thereon to Congress, and thereafter the battlefield shall be placed in charge of a superintendent at a salary to be fixed by the Secretary of the Interior and paid out of the appropriation available for the maintenance of the battlefield.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77898a45-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-07-03/ch746/s9"},"text":"July 3, 1926, ch. 746, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/823"},"text":"44 Stat. 823","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/603/s1"},"text":"Pub. L. 87–603, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-08-24"},"text":"Aug. 24, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/403"},"text":"76 Stat. 403","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77898a46-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77898a47-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77898a48-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Battlefield” substituted in text for “park” in view of redesignation of Petersburg National Military Park as Petersburg National Military Battlefield by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/603"},"text":"Pub. L. 87–603","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s423h–1"},"text":"section 423h–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id77898a49-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id77898a4a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of administrative functions of park, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s423"},"text":"section 423 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
