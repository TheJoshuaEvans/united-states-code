{"tag":"section","attrib":{"id":"id7a0ade2f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6451"},"text":null,"children":[{"tag":"num","attrib":{"value":"6451"},"text":"§ 6451.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is established a task force to lead, coordinate, and strengthen Federal Government actions to better preserve, conserve, and restore coral reef ecosystems, to be known as the “United States Coral Reef Task Force” (in this subchapter referred to as the “Task Force”).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a0ade30-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10011"},"text":"Pub. L. 117–263, div. J, title C, § 10011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3951"},"text":"136 Stat. 3951","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
