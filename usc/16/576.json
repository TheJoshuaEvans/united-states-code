{"tag":"section","attrib":{"id":"id78484659-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s576"},"text":null,"children":[{"tag":"num","attrib":{"value":"576"},"text":"§ 576.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reforestation; establishment of forest tree nurseries; tree planting; seed sowing and forest improvement work","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized to establish forest tree nurseries and do all other things needful in preparation for planting on national forests on the scale possible under the appropriations authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s576a"},"text":"section 576a of this title","children":[],"tail":": "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That nothing in this section shall be deemed to restrict the authority of the said Secretary under other authority of law."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7848465a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-09/ch416/s1"},"text":"June 9, 1930, ch. 416, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/527"},"text":"46 Stat. 527","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7848465b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7848465c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7848465d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The ","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-09/ch416"},"text":"act of June 9, 1930, ch. 416","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/527"},"text":"46 Stat. 527","children":[],"tail":", as amended, which is classified to sections 576 to 576b of this title, is popularly known as the “Knutson-Vandenberg Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
