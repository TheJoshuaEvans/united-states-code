{"tag":"section","attrib":{"id":"id771bd45d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s231d"},"text":null,"children":[{"tag":"num","attrib":{"value":"231d"},"text":"§ 231d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeal of inconsistent laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All Acts or parts of Acts inconsistent with this subchapter are repealed to the extent of such inconsistency.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id771bd45e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-10/ch640/s5"},"text":"Aug. 10, 1939, ch. 640, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1342"},"text":"53 Stat. 1342","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
