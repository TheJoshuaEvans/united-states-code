{"tag":"section","attrib":{"id":"id7826dc1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521c"},"text":null,"children":[{"tag":"num","attrib":{"value":"521c"},"text":"§ 521c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of sections 521c to 521i of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7826dc1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “person” includes any State or any political subdivision or entity thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7826dc1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “interchange” means a land transfer in which the Secretary and another person exchange titles to lands or interests in lands of approximately equal value where the Secretary finds that such a value determination can be made without a formal appraisal and under such regulations as the Secretary may prescribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78294c1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Agriculture of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78294c1e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/465/s1"},"text":"Pub. L. 97–465, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2535"},"text":"96 Stat. 2535","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
