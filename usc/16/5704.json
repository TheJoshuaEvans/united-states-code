{"tag":"section","attrib":{"id":"id7a01680d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5704"},"text":null,"children":[{"tag":"num","attrib":{"value":"5704"},"text":"§ 5704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a01680e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor of Alaska may appoint an Advisory Committee of not less than eight, but not more than twelve, individuals who are knowledgeable and experienced with regard to the salmon fisheries on the Yukon River. At least 2 of the Advisory Committee members shall be Alaska Natives. Members of the Advisory Committee may attend all meetings of the United States section of the Panel, and shall be given the opportunity to examine and be heard on any matter under consideration by the United States section of the Panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a01680f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of such Advisory Committee shall receive no compensation for their services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016810-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term length","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Advisory Committee members shall serve two-year terms. Any individual appointed to fill a vacancy occurring before the expiration of any term shall be appointed for the remainder of that term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016811-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Advisory Committee members shall be eligible for reappointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a016812-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tVII/s705"},"text":"Pub. L. 104–43, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/394"},"text":"109 Stat. 394","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
