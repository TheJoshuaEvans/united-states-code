tle III of Pub. L. 97–389","children":[],"tail":", and has been translated as "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3602"},"text":"section 3602 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/389/tIII/s303"},"text":"section 303 of title III of Pub. L. 97–389","children":[],"tail":", as the probable intent of Congress, because title III of "},{"tag":"ref","attrib":{"href":"/us/pl/97/389"},"text":"Pub. L. 97–389","children":[],"tail":" does not contain a section 403 and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3602"},"text":"section 3602 of this title","children":[],"tail":" relates to appointment of a United States Commissioner."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79be9214-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79be9215-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/389/s1"},"text":"Pub. L. 97–389, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-29"},"text":"Dec. 29, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1949"},"text":"96 Stat. 1949","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/389/s1"},"text":"“That this Act [enacting this chapter, amending sections 779b, 1034, and 1401 of this title and sections 688 and 883 of Title 46, Appendix, Shipping, and enacting provisions set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1823"},"text":"section 1823 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s688"},"text":"section 688 of Title 46","children":[],"tail":", Appendix] may be cited as the ‘Fisheries Amendments of 1982’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/389/tIII/s301"},"text":"Pub. L. 97–389, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-29"},"text":"Dec. 29, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1951"},"text":"96 Stat. 1951","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/389/tIII/s301"},"text":"“This title [enacting this chapter] may be cited as the ‘Atlantic Salmon Convention Act of 1982’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
