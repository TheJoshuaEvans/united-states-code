{"tag":"section","attrib":{"id":"id79be9205-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3601"},"text":null,"children":[{"tag":"num","attrib":{"value":"3601"},"text":"§ 3601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79be9206-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3601/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Act of 1976” means the Act entitled “An Act to provide for the conservation and management of the fisheries, and for other purposes”, approved ","children":[{"tag":"date","attrib":{"date":"1976-04-13"},"text":"April 13, 1976","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"16 U.S.C. 1801","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79be9207-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3601/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Commission” means any of the Commissions of the Organization that are established by the Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79be9208-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3601/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Commissioner” means a United States Commissioner appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3602"},"text":"section 3602 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79be9209-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3601/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Convention” means the Convention for the Conservation of Salmon in the North Atlantic Ocean, signed at Reykjavik, Iceland, on ","children":[{"tag":"date","attrib":{"date":"1982-03-02"},"text":"March 2, 1982","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79be920a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3601/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Council” means the Council established by the Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79be920b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3601/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “fishing” has the same meaning as such term has in section 3(10) ","children":[{"tag":"ref","attrib":{"idref":"fn002753"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002753"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Act of 1976 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1802/10"},"text":"16 U.S.C. 1802(10)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79be920c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3601/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Organization” means the North Atlantic Salmon Conservation Organization established under the Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79be920d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3601/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “person” has the same meaning as such term has in section 3(19) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the Act of 1976 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1802/19"},"text":"16 U.S.C. 1802(19)","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79be920e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3601/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “salmon” means all species of salmon which migrate in or into the waters of the Atlantic Ocean north of 36 degrees north latitude.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79be920f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/389/tIII/s302"},"text":"Pub. L. 97–389, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-29"},"text":"Dec. 29, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1951"},"text":"96 Stat. 1951","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79be9210-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79be9211-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79be9212-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"An Act to provide for the con