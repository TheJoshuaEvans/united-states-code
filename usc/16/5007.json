{"tag":"section","attrib":{"id":"id79fa3b61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5007"},"text":null,"children":[{"tag":"num","attrib":{"value":"5007"},"text":"§ 5007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with other agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79fa3b62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any agency of the Federal Government is authorized, upon request of the Commission, to cooperate in the conduct of scientific and other programs, and to furnish, on a reimbursable basis, facilities and personnel for the purpose of assisting the Commission in carrying out its duties under the Convention. Such agency may accept reimbursement from the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fa3b63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Secretary of Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the provisions of the Convention and this chapter, the Secretary of Commerce may arrange for cooperation with agencies of the United States, the States, private institutions and organizations, and agencies of the government of any Party, to conduct scientific and other programs, and may execute such memoranda as may be necessary to reflect such agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fa3b64-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567/tVIII/s808"},"text":"Pub. L. 102–567, title VIII, § 808","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4312"},"text":"106 Stat. 4312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tVIII/s8008"},"text":"Pub. L. 102–587, title VIII, § 8008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5101"},"text":"106 Stat. 5101","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/562/tIII/s304/a"},"text":"Pub. L. 106–562, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2806"},"text":"114 Stat. 2806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fa3b65-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79fa3b66-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79fa3b67-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567"},"text":"Pub. L. 102–567","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":" enacted identical sections. Title VIII of "},{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"P