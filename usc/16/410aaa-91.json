{"tag":"section","attrib":{"id":"id776a69ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–91"},"text":"§ 410aaa–91.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of Off-Highway Vehicle Recreation Areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id776a69ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776a69ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.) and resource management plans developed under this part and subject to valid rights, the following land within the Conservation Area in San Bernardino County, California, is designated as Off-Highway Vehicle Recreation Areas:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776a69af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dumont Dunes Off-Highway Vehicle Recreation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Certain Bureau of Land Management land in the Conservation Area, comprising approximately 7,620 acres, as generally depicted on the map entitled “Proposed Dumont Dunes OHV Recreation Area” and dated ","children":[{"tag":"date","attrib":{"date":"2018-11-07"},"text":"November 7, 2018","children":[],"tail":", which shall be known as the “Dumont Dunes Off-Highway Vehicle Recreation Area”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a69b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" El Mirage Off-Highway Vehicle Recreation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Certain Bureau of Land Management land in the Conservation Area, comprising approximately 16,370 acres, as generally depicted on the map entitled “Proposed El Mirage OHV Recreation Area” and dated ","children":[{"tag":"date","attrib":{"date":"2018-12-10"},"text":"December 10, 2018","children":[],"tail":", which shall be known as the “El Mirage Off-Highway Vehicle Recreation Area”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a69b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rasor Off-Highway Vehicle Recreation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Certain Bureau of Land Management land in the Conservation Area, comprising approximately 23,900 acres, as generally depicted on the map entitled “Proposed Rasor OHV Recreation Area” and dated ","children":[{"tag":"date","attrib":{"date":"2018-11-07"},"text":"November 7, 2018","children":[],"tail":", which shall be known as the “Rasor Off-Highway Vehicle Recreation Area”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a69b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spangler Hills Off-Highway Vehicle Recreation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Certain Bureau of Land Management land in the Conservation Area, comprising approximately 92,340 acres, as generally depicted on the map entitled “Proposed Spangler Hills OHV Recreation Area” and dated ","children":[{"tag":"date","attrib":{"date":"2018-12-10"},"text":"December 10, 2018","children":[],"tail":", which shall be known as the “Spangler Hills Off-Highway Vehicle Recreation Area”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a69b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stoddard Valley Off-Highway Vehicle Recreation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Certain Bureau of Land Management land in the Conservation Area, comprising approximately 40,110 acres, as generally depicted on the map entitled “Proposed Stoddard Valley OHV Recreation Area” and dated ","children":[{"tag":"date","attrib":{"date":"2018-11-07"},"text":"November 7, 2018","children":[],"tail":", which shall be known as the “Stoddard Valley Off-Highway Vehicle Recreation Area”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a69b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of Johnson Valley Off-Highway Vehicle Recreation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Johnson Valley Off-Highway Vehicle Recreation Area designated by section 2945 of the Military Construction Authorization Act for Fiscal Year 2014 (division B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Public Law 113–66","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/127/1038"},"text":"127 Stat. 1038","children":[],"tail":") is expanded to include approximately 20,240 acres, depicted as “Proposed OHV Recreation Area Additions” and “Proposed OHV Recreation Area Study Areas” on the map entitled “Proposed Johnson Valley OHV Recreation Area” and dated "},{"tag":"date","attrib":{"date":"2018-11-07"},"text":"November 7, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a69b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the off-highway vehicle recreation areas designated or expanded under subsection (a) is to preserve and enhance the recreational opportunities within the Conservation Area (including opportunities for off-highway vehicle recreation), while conserving the wildlife and other natural resource values of the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a69b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maps and descriptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776a69b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation and submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall file a map and legal description of each off-highway vehicle recreation area designated or expanded by subsection (a) with—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776a69b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Natural Resources of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a69b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a69ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal descriptions of the off-highway vehicle recreation areas filed under paragraph (1) shall have the same force and effect as if included in this part, except that the Secretary may correct errors in the map and legal descriptions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a69bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each map and legal description filed under paragraph (1) shall be filed and made available for public inspection in the appropriate offices of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a69bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of the land","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776a69bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreational activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776a69be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall continue to authorize, maintain, and enhance the recreational uses of the off-highway vehicle recreation areas designated or expanded by subsection (a), as long as the recreational use is consistent with this section and any other applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a69bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Off-highway vehicle and off-highway recreation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent consistent with applicable Federal law (including regulations) and this section, any authorized recreation activities and use designations in effect on ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", and applicable to the off-highway vehicle recreation areas designated or expanded by subsection (a) shall continue, including casual off-highway vehicular use, racing, competitive events, rock crawling, training, and other forms of off-highway recreation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a69c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildlife guzzlers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Wildlife guzzlers shall be allowed in the off-highway vehicle recreation areas designated or expanded by subsection (a) in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776a69c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable Bureau of Land Management guidelines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a69c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a69c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited uses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776a69c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), commercial development (including development of energy facilities, but excluding energy transport facilities, rights-of-way, and related telecommunication facilities) shall be prohibited in the off-highway vehicle recreation areas designated or expanded by subsection (a) if the Secretary determines that the development is incompatible with the purpose described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a69c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may issue a temporary permit to a commercial vendor to provide accessories and other support for off-highway vehicle use in an off-highway vehicle recreation area designated or expanded by subsection (a) for a limited period and consistent with the purposes of the off-highway vehicle recreation area and applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a69c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776a69c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall administer the off-highway vehicle recreation areas designated or expanded by subsection (a) in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776a69c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a69c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a69ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other applicable laws (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a69cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776a69cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable, but not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"id776a69cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amend existing resource management plans applicable to the off-highway vehicle recreation areas designated or expanded by subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776a69ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop new management plans for each off-highway vehicle recreation area designated or expanded under that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a69cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All new or amended plans under subparagraph (A) shall be designed to preserve and enhance safe off-highway vehicle and other recreational opportunities within the applicable recreation area consistent with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id776a69d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776a69d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any applicable laws (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a69d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pending completion of a new management plan under subparagraph (A), the existing resource management plans shall govern the use of the applicable off-highway vehicle recreation area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a69d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, all Federal land within the off-highway vehicle recreation areas designated or expanded by subsection (a) is withdrawn from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776a69d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all forms of entry, appropriation, or disposal under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a69d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a69d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" right-of-way, leasing, or disposition under all laws relating to mineral leasing, geothermal leasing, or mineral materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a69d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Southern California Edison Company utility facilities and rights-of-way","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776a69d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"headin