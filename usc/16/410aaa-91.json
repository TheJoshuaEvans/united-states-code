tag":"clause","attrib":{"id":"id776a69dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/g/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Johnson Valley Off-Highway Vehicle Recreation Area;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a69de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects the application, siting, route selection, right-of-way acquisition, or construction of the Coolwater-Lugo transmission project, as may be approved by the California Public Utilities Commission and the Bureau of Land Management; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a69df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prohibits the upgrading or replacement of any Southern California Edison Company—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id776a69e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/g/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" utility facility, including such a utility facility known on ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", as—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id776a69e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/g/1/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Gale-PS 512 transmission lines or rights-of-way”;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id776a69e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/g/1/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Patio, Jack Ranch, and Kenworth distribution circuits or rights-of-way”; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id776a69e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/g/1/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Bessemer and Peacor distribution circuits or rights-of-way”; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776a69e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/g/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy transport facility in a right-of-way issued, granted, or permitted by the Secretary adjacent to a utility facility referred to in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a69e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans for access","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Southern California Edison Company, shall publish plans for regular and emergency access by the Southern California Edison Company to the rights-of-way of the Company by the date that is 1 year after the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776a6