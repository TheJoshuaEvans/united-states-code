":[],"tail":null},{"tag":"content","attrib":{},"text":" the Johnson Valley Off-Highway Vehicle Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a69ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pacific Gas and Electric Company utility facilities and rights-of-way","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776a69ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of part","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this part—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776a69ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects any validly issued right-of-way for the customary operation, maintenance, upgrade, repair, relocation within an existing right-of-way, replacement, or other authorized activity (including the use of any mechanized vehicle, helicopter, and other aerial device) in a right-of-way acquired by or issued, granted, or permitted to Pacific Gas and Electric Company (including any successor in interest or assign) that is located on land included in the Spangler Hills Off-Highway Vehicle Recreation Area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a69ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–91/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},