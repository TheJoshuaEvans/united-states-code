 Management Act of 1976, referred to in subsecs. (a)(1) and (e)(1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2945 of the Military Construction Authorization Act for Fiscal Year 2014, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dB/tXXIX/s2945"},"text":"section 2945 of title XXIX of div. B of Pub. L. 113–66","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1038"},"text":"127 Stat. 1038","children":[],"tail":", which is set out as a note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id776a69f9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id776a69fa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Johnson Valley Off-Highway Vehicle Recreation Area","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dB/tXXIX/s2945"},"text":"Pub. L. 113–66, div. B, title XXIX, § 2945","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1038"},"text":"127 Stat. 1038","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/66/dB/tXXIX/s2945"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby designated the ‘Johnson Valley Off-Highway Vehicle Recreation Area’, consisting of—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 43,431 acres (as depicted on the map referred to in subsection (b) of section 2941 [","children":[{"tag":"ref","attrib":{"href":"/us/stat/127/1034"},"text":"127 Stat. 1034","children":[],"tail":"]) of the existing Bureau of Land Management-designated Johnson Valley Off-Highway Vehicle Area that is not withdrawn and reserved for defense-related uses by such section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Shared Use Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent consistent with applicable Federal law (including regulations) and this subtitle [subtitle C (§§ 2941–2946) of title XXIX of div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":", see Tables for classification] any authorized recreation activities and use designation in effect on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":"] and applicable to the Johnson Valley Off-Highway Vehicle Recreation Area may continue, including casual off-highway vehicular use and recreation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior shall administer the Johnson Valley Off-Highway Vehicle Recreation Area (other than the Shared Use Area, which is being managed in accordance with the other provisions of this subtitle) in accordance with—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In coordination with the Secretary of the Interior, the Secretary of the Navy may authorize transit through the Johnson Valley Off-Highway Vehicle Recreation Area for defense-related purposes supporting military training (including military range management and management of exercise activities) conducted on the land withdrawn and reserved by section 2941.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “Shared Use Area” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s2945"},"text":"section 2945 of Pub. L. 113–66","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dB/tXXIX/s2941"},"text":"section 2941 of title XXIX of div. B of Pub. L. 113–66","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1034"},"text":"127 Stat. 1034","children":[],"tail":", which is not classified to the Code.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
