{"tag":"section","attrib":{"id":"id7733a19d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s396c"},"text":null,"children":[{"tag":"num","attrib":{"value":"396c"},"text":"§ 396c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7733a19e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s396c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any limitations on land acquisition as provided by sections 391b, 391b–1, 392b, 392c, 396, and 396a of this title, the Secretary of the Interior may acquire for addition to the park any land on the island of Maui within the boundaries of the area generally depicted on the map entitled “Haleakala̅ National Park, Segment 03,” numbered 162–30,000–G, and dated May 1972, by donation, purchase with donated or appropriated funds, or exchange. The map shall be on file and available for public inspection in the offices of the National Park Service, Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7733a19f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s396c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated such sums but not to exceed $920,000 as may be necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7733a1a0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/744/s2"},"text":"Pub. L. 86–744, § 2","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/578/tIII/s313"},"text":"Pub. L. 94–578, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2737"},"text":"90 Stat. 2737","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/510/s3/b/1"},"text":"Pub. L. 106–510, § 3(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2363"},"text":"114 Stat. 2363","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7733a1a1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7733a1a2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7733a1a3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/510"},"text":"Pub. L. 106–510","children":[],"tail":" substituted “Haleakala̅ National Park” for “Haleakala National Park”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
