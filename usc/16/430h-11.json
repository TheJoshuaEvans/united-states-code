{"tag":"section","attrib":{"id":"id779570af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430h–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"430h–11"},"text":"§ 430h–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id779570b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430h–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pemberton’s Headquarters","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to acquire the properties described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s430h–10"},"text":"section 430h–10 of this title","children":[],"tail":" and subsection (b) by purchase, donation, or exchange, except that each property may only be acquired with the consent of the owner thereof."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id779570b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430h–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is also authorized to acquire not more than one acre of land, or interest therein, adjacent to or near Pemberton’s Headquarters for the purpose of providing parking and other facilities related to the operation of Pemberton’s Headquarters. Upon the acquisition of the property referenced in this subsection, the Secretary shall add the property to Vicksburg National Military Park and shall modify the boundaries of the park to reflect its inclusion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id779570b2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/238/s3"},"text":"Pub. L. 107–238, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-11"},"text":"Oct. 11, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1486"},"text":"116 Stat. 1486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/352/s15"},"text":"Pub. L. 108–352, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-21"},"text":"Oct. 21, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1397"},"text":"118 Stat. 1397","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id779570b3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id779570b4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id779570b5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/352"},"text":"Pub. L. 108–352","children":[],"tail":" substituted “the Secretary shall add the property” for “the Secretary add it”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
