{"tag":"section","attrib":{"id":"id77e67750-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ss–1"},"text":"§ 460ss–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77e67751-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate the anadromous fish habitats and resources of the Klamath River basin as the Klamath River Basin Conservation Area (hereafter in this subchapter referred to as the “Area”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e67752-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e67753-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in consultation with the task force established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460ss–3"},"text":"section 460ss–3 of this title","children":[],"tail":", formulate, establish, and implement a 20-year program to restore the anadromous fish populations of the Area to optimum levels and to maintain such levels. The program shall be based on the Klamath River Basin Fisheries Resource Plan referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460ss/6"},"text":"section 460ss(6) of this title","children":[],"tail":" and shall be known as the Klamath River Basin Conservation Area Restoration Program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e67754-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the objectives of the program, the Secretary, in cooperation with the task force established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460ss–3"},"text":"section 460ss–3 of this title","children":[],"tail":", shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e67755-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor and coordinate research evaluating the Area anadromous fish populations and administer and evaluate the success of activities described in subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e67756-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" take such actions as are necessary to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77e67757-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–1/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve and restore Area habitats, and to promote access to blocked Area habitats, to support increased run sizes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e67758-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–1/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rehabilitate problem watersheds in the Area to reduce negative impacts on fish and fish habitats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e67759-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–1/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve existing Area hatcheries and rearing ponds to assist in rebuilding the natural populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e6775a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–1/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement an intensive, short-term stocking program to rebuild run sizes while maintaining the genetic integrity and diversity of Area subbasin stocks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e6775b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–1/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve upstream and downstream migration by removal of obstacles to fish passage and the provision of facilities for avoiding obstacles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e6775c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration work","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent practicable, any restoration work performed under paragraph (2)(B) shall be performed by unemployed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e6775d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–1/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial fishermen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e6775e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–1/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e6775f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–1/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other persons whose livelihood depends upon Area fishery resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e67760-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memorandum of agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to facilitate the implementation of any activity described in paragraph (2) over which the Secretary does not have jurisdiction, the Secretary shall enter into a memorandum of agreement with the Federal, State, and local agencies having jurisdiction over such activities, and the Area Indian tribes. The memorandum of agreement shall specify the program activities for which the respective signatories to the agreement are responsible and shall contain such provisions as are necessary to ensure the coordinated implementation of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77e67761-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/552/s2"},"text":"Pub. L. 99–552, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3081"},"text":"100 Stat. 3081","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
