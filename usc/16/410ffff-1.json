{"tag":"section","attrib":{"id":"id7784a83b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ffff–1"},"text":"§ 410ffff–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7784a83c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7784a83d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Weir Farm in Connecticut is listed on the National Register of Historic Places as a historic site associated with major American artists and several artistic developments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7784a83e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Weir Farm, acquired in 1882 by J. Alden Weir, a founder and principal exponent of American Impressionism, has been continuously occupied by working artists and their families who have maintained its significance and integrity as a historic site; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7784a83f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Weir Farm, including the house, barns, studios, pond, field, and woods thereon, and the approximately 113 acres of adjacent natural areas owned by the Nature Conservancy and the Town of Ridgefield, Connecticut, provide opportunities for illustrating and interpreting cultural themes of our Nation’s heritage and provide opportunities for public use and enjoyment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7784a840-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7784a841-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve a significant site of the tradition of American Impressionism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7784a842-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain the integrity of a setting that inspired artistic expression and encourages public enjoyment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7784a843-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to offer opportunities for the inspirational benefit and education of the American people.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7784a844-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/485/s3"},"text":"Pub. L. 101–485, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-31"},"text":"Oct. 31, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1171"},"text":"104 Stat. 1171","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
