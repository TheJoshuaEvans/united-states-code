{"tag":"section","attrib":{"id":"id791a1564-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372"},"text":null,"children":[{"tag":"num","attrib":{"value":"1372"},"text":"§ 1372.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id791a1565-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in sections 1371, 1373, 1374, 1379, 1381, 1383, 1383a, and 1387 of this title and subchapter V, it is unlawful—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791a1566-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any person subject to the jurisdiction of the United States or any vessel or other conveyance subject to the jurisdiction of the United States to take any marine mammal on the high seas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791a1567-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as expressly provided for by an international treaty, convention, or agreement to which the United States is a party and which was entered into before the effective date of this subchapter or by any statute implementing any such treaty, convention, or agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791a1568-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any person or vessel or other conveyance to take any marine mammal in waters or on lands under the jurisdiction of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791a1569-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any person to use any port, harbor, or other place under the jurisdiction of the United States to take or import marine mammals or marine mammal products; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791a156a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any person, with respect to any marine mammal taken in violation of this subchapter, to possess that mammal or any product from that mammal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791a156b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for any person to transport, purchase, sell, export, or offer to purchase, sell, or export any marine mammal or marine mammal product—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791a156c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is taken in violation of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791a156d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any purpose other than public display, scientific research, or enhancing the survival of a species or stock as provided for under sub","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1374/c"},"text":"section 1374(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791a156e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any person to use, in a commercial fishery, any means or methods of fishing in contravention of any regulations or limitations, issued by the Secretary for that fishery to achieve the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791a156f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importation of pregnant or nursing mammals; depleted species or stock; inhumane taking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except pursuant to a permit for scientific research, or for enhancing the survival or recovery of a species or stock, issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1374/c"},"text":"section 1374(c) of this title","children":[],"tail":", it is unlawful to import into the United States any marine mammal if such mammal was—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id791a1570-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pregnant at the time of taking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791a1571-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nursing at the time of taking, or less than eight months old, whichever occurs later;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791a1572-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taken from a species or population stock which the Secretary has, by regulation published in the Federal Register, designated as a depleted species or stock; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791a1573-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taken in a manner deemed inhumane by the Secretary.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Notwithstanding the provisions of paragraphs (1) and (2), the Secretary may issue a permit for the importation of a marine mammal, if the Secretary determines that such importation is necessary for the protection or welfare of the animal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791a1574-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importation of illegally taken mammals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is unlawful to import into the United States any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791a1575-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any marine mammal which was—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791a1576-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taken in violation of this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791a1577-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taken in another country in violation of the law of that country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791a1578-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any marine mammal product if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791a1579-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importation into the United States of the marine mammal from which such product is made is unlawful under paragraph (1) of this subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791a157a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale in commerce of such product in the country of origin of the product is illegal;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791a157b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any fish, whether fresh, frozen, or otherwise prepared, if such fish was caught in a manner which the Secretary has proscribed for persons subject to the jurisdiction of the United States, whether or not any marine mammals were in fact taken incident to the catching of the fish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791a157c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of prohibitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (b) and (c) of this section shall not apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791a157d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of marine mammals or marine mammal products, as the case may be, to which subsection (b)(3) of this section applies, to such items imported into the United States before the date on which the Secretary publishes notice in the Federal Register of his proposed rulemaking with respect to the designation of the species or stock concerned as depleted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791a157e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of marine mammals or marine mammal products to which subsection (c)(1)(B) or (c)(2)(B) of this section applies, to articles imported into the United States before the effective date of the foreign law making the taking or sale, as the case may be, of such marine mammals or marine mammal products unlawful.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791a157f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retroactive effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter shall not apply with respect to any marine mammal taken before the effective date of this chapter, or to any marine mammal product consisting of, or composed in whole or in part of, any marine mammal taken before such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791a1580-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1372/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial taking of whales","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is unlawful for any person or vessel or other conveyance to take any species of whale incident to commercial whaling in waters subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id791a1581-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tI/s102"},"text":"Pub. L. 92–522, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1032"},"text":"86 Stat. 1032","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/205/s13/e/3"},"text":"Pub. L. 93–205, § 13(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/903"},"text":"87 Stat. 903","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/136/s4"},"text":"Pub. L. 95–136, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-18"},"text":"Oct. 18, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1167"},"text":"91 Stat. 1167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/58/s3/a"},"text":"Pub. L. 97–58, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-09"},"text":"Oct. 9, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/981"},"text":"95 Stat. 981","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/711"},"text":"Pub. L. 100–711","children":[],"tail":", §§ 2(b), 5(b), (e)(2), "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4763"},"text":"102 Stat. 4763","children":[],"tail":", 4769, 4771; "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tIII/s3004/a/1"},"text":"Pub. L. 102–587, title III, § 3004(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5067"},"text":"106 Stat. 5067","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/238"},"text":"Pub. L. 103–238","children":[],"tail":", §§ 5(a), 13(c), 24(c)(9), "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/536"},"text":"108 Stat. 536","children":[],"tail":", 558, 566.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id791a1582-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id791a1583-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id791a1584-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this subchapter, referred to in subsec. (a)(2), means the effective date of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522"},"text":"Pub. L. 92–522","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/pl/92/522/s4"},"text":"section 4 of Pub. L. 92–522","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1361"},"text":"section 1361 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The effective date of this chapter, referred to in subsec. (e), means the effective date of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522"},"text":"Pub. L. 92–522","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/pl/92/522/s4"},"text":"section 4 of Pub. L. 92–522","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1361"},"text":"section 1361 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id791a1585-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/238/s24/c/9"},"text":"Pub. L. 103–238, § 24(c)(9)","children":[],"tail":", which directed technical amendment to reference to subchapter V of this chapter in introductory provisions to reflect renumbering of corresponding title of original act, could not be executed to text because of prior amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/103/238/s13/c"},"text":"section 13(c) of Pub. L. 103–238","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/238/s13/c"},"text":"Pub. L. 103–238, § 13(c)","children":[],"tail":", in introductory provisions inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1387"},"text":"section 1387 of this title","children":[],"tail":" and made technical amendment to reference to subchapter V of this chapter to reflect renumbering of corresponding title of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/238/s5/a/1"},"text":"Pub. L. 103–238, § 5(a)(1)","children":[],"tail":", substituted “to take or import” for “for any purpose in any way connected with the taking or importation of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/238/s5/a/2"},"text":"Pub. L. 103–238, § 5(a)(2)","children":[],"tail":", substituted “export, or offer to purchase, sell, or export” for “or offer to purchase or sell” and “product—” for “product; and” and added subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":" inserted “or subchapter V” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/711/s2/b"},"text":"Pub. L. 100–711, § 2(b)","children":[],"tail":", substituted “1383, and 1383a” for “and 1383”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/711/s5/e/2"},"text":"Pub. L. 100–711, § 5(e)(2)","children":[],"tail":", substituted “research, or for enhancing the survival or recovery of a species or stock,” for “research”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/711/s5/b"},"text":"Pub. L. 100–711, § 5(b)","children":[],"tail":", inserted sentence at end authorizing Secretary to issue permit for importation of marine mammal."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/58/s3/a/1"},"text":"Pub. L. 97–58, § 3(a)(1)","children":[],"tail":", inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1379"},"text":"section 1379 of this title","children":[],"tail":" in the enumeration of sections preceding par. (1), redesignated par. (4) as (5), and revised as pars. (3) and (4) the provisions of former par. (3) amending those provisions so as to make it illegal for any person to possess a marine mammal, or any product from that mammal, and for any person to transport, purchase, sell, or offer to purchase or sell any marine mammal or marine mammal product."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/58/s3/a/2"},"text":"Pub. L. 97–58, § 3(a)(2)","children":[],"tail":", struck out “or which has been listed as an endangered species or threatened species pursuant to the Endangered Species Act of 1973” after “designated as a depleted species or stock”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/58/s3/b/3"},"text":"