{"tag":"section","attrib":{"id":"id77f98a04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460jjj–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"460jjj–4"},"text":"§ 460jjj–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of land","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77f98a05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460jjj–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Land and interests in land within the boundaries of the recreation area that are owned by the State of New Mexico, or a political subdivision of New Mexico, may be acquired only by donation or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f98a06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460jjj–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offers to sell","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77f98a07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460jjj–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary may acquire land and interests in land within the boundaries of the recreation area by donation, purchase with donated or appropriated funds, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f98a08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460jjj–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not acquire lands within the recreation area without the consent of the owner thereof unless the Secretary has determined that such lands will be put to a use different from their use as of ","children":[{"tag":"date","attrib":{"date":"1993-10-12"},"text":"October 12, 1993","children":[],"tail":", and that such new use would be incompatible with the protection of the natural and cultural resources of the recreation area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77f98a09-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/104/s5"},"text":"Pub. L. 103–104, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-12"},"text":"Oct. 12, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1029"},"text":"107 Stat. 1029","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
