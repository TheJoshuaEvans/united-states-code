{"tag":"section","attrib":{"id":"id7a193540-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604"},"text":null,"children":[{"tag":"num","attrib":{"value":"6604"},"text":"§ 6604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marine Turtle Conservation Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a193541-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established in the Multinational Species Conservation Fund a separate account to be known as the “Marine Turtle Conservation Fund”, consisting of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a193542-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts transferred to the Secretary of the Treasury for deposit into the Fund under subsection (e);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193543-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts appropriated to the Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6606/a"},"text":"section 6606(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193544-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any interest earned on investment of amounts in the Fund under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a193545-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures from Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a193546-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), on request by the Secretary, the Secretary of the Treasury shall transfer from the Fund to the Secretary, without further appropriation, such amounts as the Secretary determines are necessary to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6603"},"text":"section 6603 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193547-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts in the account available for each fiscal year, the Secretary may expend not more than 5 percent, or up to $150,000, whichever is greater, to pay the administrative expenses necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a193548-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a193549-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall invest such portion of the Fund as is not, in the judgment of the Secretary of the Treasury, required to meet current withdrawals. Investments may be made only in interest-bearing obligations of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a19354a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of obligations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of investments under paragraph (1), obligations may be acquired—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a19354b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on original issue at the issue price; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a19354c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by purchase of outstanding obligations at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a19354d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any obligation acquired by the Fund may be sold by the Secretary of the Treasury at the market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a19354e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits to Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest on, and the proceeds from the sale or redemption of, any obligations held in the Fund shall be credited to and form a part of the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a19354f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a193550-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts required to be transferred to the Fund under this section shall be transferred at least monthly from the general fund of the Treasury to the Fund on the basis of estimates made by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193551-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Proper adjustment shall be made in amounts subsequently transferred to the extent prior estimates were in excess of or less than the amounts required to be transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a193552-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6604/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance and use of donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may accept and use donations to provide assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6603"},"text":"section 6603 of this title","children":[],"tail":". Amounts received by the Secretary in the form of donations shall be transferred to the Secretary of the Treasury for deposit in the Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a193553-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/266/s5"},"text":"Pub. L. 108–266, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-02"},"text":"July 2, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/794"},"text":"118 Stat. 794","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tVII/s7001/c/3/D"},"text":"Pub. L. 116–9, title VII, § 7001(c)(3)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/788"},"text":"133 Stat. 788","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a193554-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a193555-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a193556-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/D/i"},"text":"Pub. L. 116–9, § 7001(c)(3)(D)(i)","children":[],"tail":", substituted “section 6606(a)” for “section 6605”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/D/ii"},"text":"Pub. L. 116–9, § 7001(c)(3)(D)(ii)","children":[],"tail":", substituted “5 percent, or up to $150,000” for “3 percent, or up to $80,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
