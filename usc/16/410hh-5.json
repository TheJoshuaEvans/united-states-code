{"tag":"section","attrib":{"id":"id7757561e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hh–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"410hh–5"},"text":"§ 410hh–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal of lands from mining and mineral leasing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to valid existing rights, and except as explicitly provided otherwise in this Act, the Federal lands within units of the National Park System established or expanded by or pursuant to this Act are hereby withdrawn from all forms of appropriation or disposal under the public land laws, including location, entry, and patent under the United States mining laws, disposition under the mineral leasing laws, and from future selections by the State of Alaska and Native Corporations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7757561f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487/tII/s206"},"text":"Pub. L. 96–487, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2384"},"text":"94 Stat. 2384","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77575620-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77575621-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77575622-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487"},"text":"Pub. L. 96–487","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2371"},"text":"94 Stat. 2371","children":[],"tail":", known as the Alaska National Interest Lands Conservation Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3101"},"text":"section 3101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
