{"tag":"section","attrib":{"id":"id7839eefd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544a"},"text":null,"children":[{"tag":"num","attrib":{"value":"544a"},"text":"§ 544a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of sections 544 to 544p of this title are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7839eefe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a national scenic area to protect and provide for the enhancement of the scenic, cultural, recreational, and natural resources of the Columbia River Gorge; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eeff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect and support the economy of the Columbia River Gorge area by encouraging growth to occur in existing urban areas and by allowing future economic development in a manner that is consistent with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7839ef00-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/663/s3"},"text":"Pub. L. 99–663, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4276"},"text":"100 Stat. 4276","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
