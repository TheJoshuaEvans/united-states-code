{"tag":"section","attrib":{"id":"id78817e94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s707"},"text":null,"children":[{"tag":"num","attrib":{"value":"707"},"text":"§ 707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations and penalties; forfeitures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78817e95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this section, any person, association, partnership, or corporation who shall violate any provisions of said conventions or of this subchapter, or who shall violate or fail to comply with any regulation made pursuant to this subchapter shall be deemed guilty of a misdemeanor and upon conviction thereof shall be fined not more than $15,000 or be imprisoned not more than six months, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78817e96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever, in violation of this subchapter, shall knowingly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78817e97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s707/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take by any manner whatsoever any migratory bird with intent to sell, offer to sell, barter or offer to barter such bird, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78817e98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s707/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sell, offer for sale, barter or offer to barter, any migratory bird shall be guilty of a felony and shall be fined not more than $2,000 or imprisoned not more than two years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78817e99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s704/b/2"},"text":"section 704(b)(2) of this title","children":[],"tail":" shall be fined under title 18, imprisoned not more than 1 year, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78817e9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s707/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All guns, traps, nets and other equipment, vessels, vehicles, and other means of transportation used by any person when engaged in pursuing, hunting, taking, trapping, ensnaring, capturing, killing, or attempting to take, capture, or kill any migratory bird in violation of this subchapter with the intent to offer for sale, or sell, or offer for barter, or barter such bird in violation of this subchapter shall be forfeited to the United States and may be seized and held pending the prosecution of any person arrested for violating this subchapter and upon conviction for such violation, such forfeiture shall be adjudicated as a penalty in addition to any other provided for violation of this subchapter. Such forfeited property shall be disposed of and accounted for by, and under the authority of, the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78817e9b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1918-07-03/ch128/s6"},"text":"July 3, 1918, ch. 128, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/756"},"text":"40 Stat. 756","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-20/ch634/s2"},"text":"June 20, 1936, ch. 634, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1556"},"text":"49 Stat. 1556","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/732"},"text":"Pub. L. 86–732","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-08"},"text":"Sept. 8, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/866"},"text":"74 Stat. 866","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/645/tV/s501"},"text":"Pub. L. 99–645, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3590"},"text":"100 Stat. 3590","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/312/tI/s103"},"text":"Pub. L. 105–312, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2956"},"text":"112 Stat. 2956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78817e9c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78817e9d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78817e9e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/312/s103/1"},"text":"Pub. L. 105–312, § 103(1)","children":[],"tail":", substituted “$15,000” for “$500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/312/s103/2"},"text":"Pub. L. 105–312, § 103(2)","children":[],"tail":", (3), added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/645"},"text":"Pub. L. 99–645","children":[],"tail":" substituted “shall knowingly” for “shall” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/732"},"text":"Pub. L. 86–732","children":[],"tail":" designated existing provisions as subsec. (a), inserted “Except as otherwise provided in this section”, and added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1936—Act ","children":[{"tag":"date","attrib":{"date":"1936-06-20"},"text":"June 20, 1936","children":[],"tail":", substituted “conventions” for “convention”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78817e9f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78817ea0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1936 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-20/ch634/s2"},"text":"Act June 20, 1936, ch. 634, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1556"},"text":"49 Stat. 1556","children":[],"tail":", provided in part that the amendment by section 2 is effective as of the day aforesaid ("},{"tag":"date","attrib":{"date":"1937-06-30"},"text":"June 30, 1937","children":[],"tail":"). See note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s703"},"text":"section 703 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id78817ea1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id78817ea2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of certain enforcement functions of Secretary or other official in Department of the Interior under this subchapter to Federal Inspector, Office of Federal Inspector for the Alaska Natural Gas Transportation System, and subsequent transfer to Secretary of Energy, then to Federal Coordinator for Alaska Natural Gas Transportation Projects, see Transfer of Functions note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s706"},"text":"section 706 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
