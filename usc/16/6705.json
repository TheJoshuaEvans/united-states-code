{"tag":"section","attrib":{"id":"id7a1935e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6705"},"text":null,"children":[{"tag":"num","attrib":{"value":"6705"},"text":"§ 6705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation between Institutes and Federal agencies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out this chapter, the Secretary, in consultation with the Secretary of the Interior—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1935e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6705/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that funds are appropriated for the purpose, shall provide financial and technical assistance to the Institutes to carry out the duties of the Institutes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6704"},"text":"section 6704 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6705/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall encourage Federal agencies to use, on a cooperative basis, information and expertise provided by the Institutes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6705/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall encourage cooperation and coordination between Federal programs relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1935e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6705/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ecological restoration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1935e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6705/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wildfire risk reduction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1935e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6705/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wildfire management technologies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6705/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notwithstanding chapter 63 of title 31, may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1935eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6705/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts, cooperative agreements, and interagency personnel agreements to carry out this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1935ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6705/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out other transactions under this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6705/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may accept funds from other Federal agencies to supplement or fully fund grants made, and contracts entered into, by the Secretaries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6705/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may support a program of internships for qualified individuals at the undergraduate and graduate levels to carry out the educational and training objectives of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6705/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall encourage professional education and public information activities relating to the purposes of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1935f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6705/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may promulgate such regulations as the Secretaries determine are necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1935f1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/317/s6"},"text":"Pub. L. 108–317, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-05"},"text":"Oct. 5, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1208"},"text":"118 Stat. 1208","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
