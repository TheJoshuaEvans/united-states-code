{"tag":"section","attrib":{"id":"id7816395a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"470aa"},"text":"§ 470aa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and declaration of purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7816395b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aa/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7816395c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aa/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" archaeological resources on public lands and Indian lands are an accessible and irreplaceable part of the Nation’s heritage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7816395d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aa/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" these resources are increasingly endangered because of their commercial attractiveness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7816395e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aa/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing Federal laws do not provide adequate protection to prevent the loss and destruction of these archaeological resources and sites resulting from uncontrolled excavations and pillage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7816395f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aa/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a wealth of archaeological information which has been legally obtained by private individuals for noncommercial purposes and which could voluntarily be made available to professional archaeologists and institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78163960-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aa/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purpose of this chapter is to secure, for the present and future benefit of the American people, the protection of archaeological resources and sites which are on public lands and Indian lands, and to foster increased cooperation and exchange of information between governmental authorities, the professional archaeological community, and private individuals having collections of archaeological resources and data which were obtained before ","children":[{"tag":"date","attrib":{"date":"1979-10-31"},"text":"October 31, 1979","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78163961-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/95/s2"},"text":"Pub. L. 96–95, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-31"},"text":"Oct. 31, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/721"},"text":"93 Stat. 721","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78163962-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78163963-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id78163964-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/95/s1"},"text":"Pub. L. 96–95, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-31"},"text":"Oct. 31, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/721"},"text":"93 Stat. 721","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/95/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Archaeological Resources Protection Act of 1979’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78163965-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Galisteo Basin Archaeological Sites Protection","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/208"},"text":"Pub. L. 108–208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-03-19"},"text":"Mar. 19, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/558"},"text":"118 Stat. 558","children":[],"tail":", known as the “Galisteo Basin Archaeological Sites Protection Act”, provided for the preservation, protection, and interpretation of nationally significant archaeological resources in the Galisteo Basin of New Mexico by designating Galisteo Basin Archaeological Protection Sites and their acreage and provided for addition, deletion or modification of the sites, administration, cooperative agreements, acquisition of land and interests, withdrawal of lands from mining and other public land laws, and construction of the Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
