{"tag":"section","attrib":{"id":"id7877e1ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s693"},"text":null,"children":[{"tag":"num","attrib":{"value":"693"},"text":"§ 693.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Game sanctuaries and refuges in Ouachita National Forest","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of providing breeding places and for the protection and administration of game animals, birds, and fish, the President of the United States is authorized, upon the recommendation of the Secretary of Agriculture, to establish by public proclamation certain specified areas within the Ouachita National Forest as game sanctuaries and refuges.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7877e1bb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-13/ch63/s1"},"text":"June 13, 1933, ch. 63, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/128"},"text":"48 Stat. 128","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7877e1bc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7877e1bd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7877e1be-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Presidential Designation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Areas comprising the Ouachita National Wildlife Preserve, formerly known as the Muddy Creek Refuge, were designated by Proclamations of ","children":[{"tag":"date","attrib":{"date":"1935-03-08"},"text":"Mar. 8, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/49/3439"},"text":"49 Stat. 3439","children":[],"tail":"), and "},{"tag":"date","attrib":{"date":"1938-10-29"},"text":"Oct. 29, 1938","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/53/2495"},"text":"53 Stat. 2495","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
