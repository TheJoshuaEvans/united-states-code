{"tag":"section","attrib":{"id":"id789bbd52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777l"},"text":null,"children":[{"tag":"num","attrib":{"value":"777l"},"text":"§ 777l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State use of contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A State may use contributions of funds, real property, materials, and services to carry out an activity under this chapter in lieu of payment by the State of the State share of the cost of such activity. Such a State share shall be considered to be paid in an amount equal to the fair market value of any contribution so used.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id789bbd53-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-09/ch658/s13"},"text":"Aug. 9, 1950, ch. 658, § 13","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/448/s6/c/2"},"text":"Pub. L. 100–448, § 6(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-28"},"text":"Sept. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1841"},"text":"102 Stat. 1841","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id789bbd54-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id789bbd55-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id789bbd56-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 13 of ","children":