{"tag":"section","attrib":{"id":"id779c9c76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s441b"},"text":null,"children":[{"tag":"num","attrib":{"value":"441b"},"text":"§ 441b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of highway by State of South Dakota","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The establishment of said park is conditioned upon the State of South Dakota first constructing the following highway in a manner satisfactory to the Secretary of the Interior: A highway commencing at the corporation limits of the town of Interior, thence going in a northwesterly direction to and over Big Foot Pass, and through the region known as The Pinnacles; thence in a westerly direction to Sage Creek, being a total distance of about thirty miles.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id779c9c77-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-03-04/ch693/s3"},"text":"Mar. 4, 1929, ch. 693, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1555"},"text":"45 Stat. 1555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tVI/s611"},"text":"Pub. L. 95–625, title VI, § 611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3521"},"text":"92 Stat. 3521","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id779c9c78-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id779c9c79-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id779c9c7a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Word “park” substituted in text for “monument” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/s611"},"text":"Pub. L. 95–625, § 611","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s441e–1"},"text":"section 441e–1 of this title","children":[],"tail":" and which redesignated Badlands National Monument as Badlands National Park."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
