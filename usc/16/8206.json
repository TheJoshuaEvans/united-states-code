{"tag":"section","attrib":{"id":"id7a337552-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8206"},"text":null,"children":[{"tag":"num","attrib":{"value":"8206"},"text":"§ 8206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical and scientific assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a337553-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8206/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, the National Oceanic and Atmospheric Administration Assistant Administrator, the Environmental Protection Agency Assistant Administrator, and the Director of the United States Geological Survey, in coordination with the Forest Service, the Bureau of Land Management, and other appropriate Federal departments and agencies, may provide scientific and technical assistance to Partnerships, participants in fish habitat conservation projects, and the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e554-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8206/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Scientific and technical assistance provided under subsection (a) may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e555-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8206/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical and scientific assistance to States, Indian Tribes, regions, local communities, and nongovernmental organizations in the development and implementation of Partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e556-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8206/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical and scientific assistance to Partnerships for habitat assessment, strategic planning, and prioritization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e557-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8206/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the development and implementation of fish habitat conservation projects that are identified as high priorities by Partnerships and the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e558-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8206/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting and providing recommendations regarding the development of science-based monitoring and assessment approaches for implementation through Partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e559-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8206/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting and providing recommendations for a national fish habitat assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e55a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8206/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring the availability of experts to assist in conducting scientifically based evaluation and reporting of the results of fish habitat conservation projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e55b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8206/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing resources to secure State agency scientific and technical assistance to support Partnerships, participants in fish habitat conservation projects, and the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a35e55c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188/tII/s206"},"text":"Pub. L. 116–188, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/934"},"text":"134 Stat. 934","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/198/tII/s204"},"text":"Pub. L. 118–198, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2682"},"text":"138 Stat. 2682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a35e55d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a35e55e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a35e55f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198"},"text":"Pub. L. 118–198","children":[],"tail":" inserted “, the Bureau of Land Management,” after “the Forest Service”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
