{"tag":"section","attrib":{"id":"id79f09eb4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4503a"},"text":"§ 4503a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institute of Pacific Islands Forestry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f09eb5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall expand the capabilities of and construct additional facilities, as funds are appropriated for the expansion and construction, at—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f09eb6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Institute of Pacific Islands Forestry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09eb7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tropical forests in the State of Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f09eb8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tropical forestry plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f09eb9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date of receipt by the Secretary of the action plan required by section 5(b) ","children":[{"tag":"ref","attrib":{"idref":"fn002796"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002796"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Hawaii Tropical Forest Recovery Act, the Secretary shall prepare and submit to the Committee on Agriculture and the Committee on Natural Resources of the House of Representatives, the Committee on Agriculture, Nutrition, and Forestry of the Senate, and to the Committees on Appropriations of the House of Representatives and Senate, a tropical forestry plan to expand the capabilities of and construct additional facilities under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09eba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f09ebb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of a model center for research, demonstration, education, training, and outreach activities suitable for transferring scientific, technical, managerial, and administrative assistance to governmental and non-governmental organizations seeking to address problems associated with tropical forests within and outside the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09ebc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition or construction of facilities for research, classroom instruction, and housing near an experimental tropical forest in the State of Hawaii;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09ebd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition or construction of facilities for the study and recovery of endangered tropical wildlife, fish, and plant species and the restoration of their habitats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09ebe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the study of biological control of non-native species that degrade or destroy native forest ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09ebf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieving a better understanding of global climate change and the significance of achieving a reduction of greenhouse gases through research associated with the unique atmospheric conditions found in Hawaii and the Pacific Ocean;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09ec0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the extent to which existing Federal forestry programs can be utilized to achieve the purposes of the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09ec1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of experimental tropical forests in the State of Hawaii as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4503b"},"text":"section 4503b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09ec2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In preparing elements of the plan that address paragraph (2)(F), the Secretary shall identify the capability of the plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f09ec3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote a greater understanding of tropical forest ecosystem processes, conservation biology, and biodiversity management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09ec4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to demonstrate the various benefits of maintaining a tropical forest reserve system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09ec5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote sound watershed and forest management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09ec6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop compatible land uses adjacent to protected natural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f09ec7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503a/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop new methods of reclaiming and restoring degraded lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f09ec8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513/tVI/s605"},"text":"Pub. L. 101–513, title VI, § 605","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/574/s2/a/2"},"text":"Pub. L. 102–574, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4593"},"text":"106 Stat. 4593","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s6/d/42"},"text":"Pub. L. 103–437, § 6(d)(42)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4585"},"text":"108 Stat. 4585","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f09ec9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f09eca-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79f09ecb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 5(b) of the Hawaii Tropical Forest Recovery Act, referred to in subsec. (b)(1), probably means section 4(b) of that Act, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/574"},"text":"Pub. L. 102–574","children":[],"tail":", which contains provisions regarding an action plan, and which is set out as a note below. Section 5 of that Act, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4502a"},"text":"section 4502a of this title","children":[],"tail":", does not contain a subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79f09ecc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513/s605"},"text":"section 605 of Pub. L. 101–513","children":[],"tail":" was renumbered section 609 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4504"},"text":"section 4504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79f09ecd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Natural Resources” for “Interior and Insular Affairs” after “Committee on”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79f09ece-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79f09ecf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Hawaii Tropical Forest Recovery Task Force","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/574/s4"},"text":"Pub. L. 102–574, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4597"},"text":"106 Stat. 4597","children":[],"tail":", established the Hawaii Tropical Forest Recovery Task Force to study Hawaii’s tropical forests, required the Task Force to submit an action plan for rejuvenating the forests one year after its first meeting, and terminated the Task Force 180 days after submission of the action plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
