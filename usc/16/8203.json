{"tag":"section","attrib":{"id":"id7a337497-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203"},"text":null,"children":[{"tag":"num","attrib":{"value":"8203"},"text":"§ 8203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Fish Habitat Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a337498-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a337499-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish Habitat Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established a board, to be known as the “National Fish Habitat Board”, whose duties are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a33749a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote, oversee, and coordinate the implementation of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a33749b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish national goals and priorities for fish habitat conservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a33749c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recommend to Congress entities for designation as Partnerships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a33749d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to review and make recommendations regarding fish habitat conservation projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a33749e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall be composed of 28 members, of whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a33749f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 shall be representatives of the Department of the Interior, including the United States Fish and Wildlife Service and the Bureau of Land Management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a representative of the United States Geological Survey;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a representative of the Department of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a representative of the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a representative of the Association of Fish and Wildlife Agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 shall be representatives of State agencies, 1 of whom shall be nominated by a regional association of fish and wildlife agencies from each of the Northeast, Southeast, Midwest, and Western regions of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 2 shall be representatives of Indian Tribes, of whom—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3374a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a representative of Indian Tribes in the State of Alaska; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3374a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a representative of Indian Tribes in States other than the State of Alaska;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 2 shall be representatives of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3374a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Regional Fishery Management Councils established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1852/a/1"},"text":"section 1852(a)(1) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3374aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Marine Fisheries Commissions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a representative of the Sport Fishing and Boating Partnership Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 7 shall be representatives selected from at least one from each of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3374ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/J/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recreational sportfishing industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3374ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/J/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commercial fishing industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3374af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/J/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine recreational anglers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3374b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/J/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" freshwater recreational anglers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3374b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/J/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" habitat conservation organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3374b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/J/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" science-based fishery organizations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a representative of a national private landowner organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a representative of an agricultural production organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a representative of local government interests involved in fish habitat restoration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 2 shall be representatives from different sectors of corporate industries, which may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3374b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/N/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural resource commodity interests, such as petroleum or mineral extraction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3374b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/N/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural resource user industries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3374b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/N/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industries with an interest in fish and fish habitat conservation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/2/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be an individual in a leadership position in the private sector or landowner representative of an active partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board shall serve without compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board may be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for an employee of an agency under subchapter I of chapter 57 of title 5, while away from the home or regular place of business of the member in the performance of the duties of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3374bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3374be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, a member of the Board described in any of subparagraphs (F) through (O) of subsection (a)(2) shall serve for a term of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial Board membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3374c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The initial Board shall consist of representatives as described in subparagraphs (A) through (F) of subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remaining members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2020-10-30"},"text":"October 30, 2020","children":[],"tail":", the representatives of the initial Board under subparagraph (A) shall appoint the remaining members of the Board described in subparagraphs (H) through (O) of subsection (a)(2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2020-10-30"},"text":"October 30, 2020","children":[],"tail":", the Secretary shall provide to the Board a recommendation of not fewer than three Tribal representatives, from which the Board shall appoint one representative pursuant to subparagraph (G) of subsection (a)(2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staggered terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the members described in subsection (a)(2)(J) initially appointed to the Board—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3374c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two shall be appointed for a term of 1 year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two shall be appointed for a term of 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three shall be appointed for a term of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3374c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy of a member of the Board described in subparagraph (H), (I), (J), (K), (L), (M), (N), or (O) of subsection (a)(2) shall be filled by an appointment made by the remaining members of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Following a vacancy of a member of the Board described in subparagraph (G) of subsection (a)(2), the Secretary shall recommend to the Board a list of not fewer than three Tribal representatives, from which the remaining members of the Board shall appoint a representative to fill the vacancy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual whose term of service as a member of the Board expires may continue to serve on the Board until a successor is appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a member of the Board described in any of subparagraphs (H) through (O) of subparagraph (a)(2) misses three consecutive regularly scheduled Board meetings, the members of the Board may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3374cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vote to remove that member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint another individual in accordance with paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3374ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3374cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The representative of the Association of Fish and Wildlife Agencies appointed under subsection (a)(2)(E) shall serve as Chairperson of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairperson of the Board shall serve for a term of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3374d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3374d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall meet—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3374d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the call of the Chairperson; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less frequently than twice each calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All meetings of the Board shall be open to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3374d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3374d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall establish procedures to carry out the business of the Board, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3374d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that a quorum of the members of the Board be present to transact business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that no recommendations may be adopted by the Board, except by the vote of two-thirds of the members present;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for establishing national goals and priorities for fish habitat conservation for the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for designating Partnerships under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8204"},"text":"section 8204 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for reviewing, evaluating, and making recommendations regarding fish habitat conservation projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8203/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Board shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3374de-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188/tII/s203"},"text":"Pub. L. 116–188, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/926"},"text":"134 Stat. 926","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/198/tII/s201"},"text":"Pub. L. 118–198, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2681"},"text":"138 Stat. 2681","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3374df-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3374e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a3374e1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s201/1/A"},"text":"Pub. L. 118–198, § 201(1)(A)","children":[],"tail":", substituted “28 members” for “26 members” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s201/1/B"},"text":"Pub. L. 118–198, § 201(1)(B)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “1 shall be a representative of the Department of the Interior;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(G), (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s201/1/C"},"text":"Pub. L. 118–198, § 201(1)(C)","children":[],"tail":", added subpars. (G) and (H) and struck out former subpars. (G) and (H) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(G) 2 shall be representatives of either—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) Indian Tribes in the State of Alaska; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) Indian Tribes in States other than the State of Alaska;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(H) 1 shall be a representative of either—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the Regional Fishery Management Councils established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1852"},"text":"section 1852 of this title","children":[],"tail":"; or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) a representative of the Marine Fisheries Commissions;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s201/2"},"text":"Pub. L. 118–198, § 201(2)","children":[],"tail":", substituted “the members present” for “all members”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
