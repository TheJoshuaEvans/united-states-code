{"tag":"section","attrib":{"id":"id7993b266-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2106b"},"text":"§ 2106b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of money collected from States for fire suppression assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any money collected from the States for fire suppression assistance rendered by the Forest Service on non-Federal lands not in the vicinity of National Forest System lands shall on and after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":", be used to reimburse the applicable appropriation and shall remain available until expended as the Secretary may direct in conducting activities authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2101"},"text":"16 U.S.C. 2101","children":[],"tail":" note, 2101–2110, 1606, and 2111."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7993b267-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tII"},"text":"Pub. L. 105–277, div. A, § 101(e) [title II]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–273.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7993b268-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7993b269-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id799