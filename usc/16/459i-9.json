{"tag":"section","attrib":{"id":"id77b925e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459i–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"459i–9"},"text":"§ 459i–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated not to exceed $28,500,000 for the acquisition of lands and interests in lands and not to exceed $27,840,000 for development of the seashore.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77b925e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/536/s10"},"text":"Pub. L. 92–536, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-23"},"text":"Oct. 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1068"},"text":"86 Stat. 1068","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tII/s201/3"},"text":"Pub. L. 95–625, title II, § 201(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3473"},"text":"92 Stat. 3473","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77b925e8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77b925e9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77b925ea-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Pub. L. 95–625","children":[],"tail":" substituted “$28,500,000” for “$10,500,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
