{"tag":"section","attrib":{"id":"id79ee5503-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403"},"text":null,"children":[{"tag":"num","attrib":{"value":"4403"},"text":"§ 4403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of North American Wetlands Conservation Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ee5504-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ee5505-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There shall be established a North American Wetlands Conservation Council (hereinafter in this chapter referred to as the “Council”) which shall consist of nine members who may not receive compensation as members of the Council. Of the Council members—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ee5506-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be the Director of the United States Fish and Wildlife Service, who shall be the responsible Federal official for ensuring Council compliance with the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ee5507-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be the Executive Director of the Board of the National Fish and Wildlife Foundation appointed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3702/g/2/B"},"text":"section 3702(g)(2)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ee5508-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four shall be individuals who shall be appointed by the Secretary, who shall reside in different flyways and who shall each be a Director of the State fish and wildlife agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ee5509-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three shall be individuals who shall be appointed by the Secretary and who shall each represent a different charitable and nonprofit organization which is actively participating in carrying out wetlands conservation projects under this chapter, the Plan, or the Agreement.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The provisions of chapter 10 of title 5 shall not apply to the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ee550a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall appoint an alternate member of the Council who shall be knowledgeable and experienced in matters relating to fish, wildlife, and wetlands conservation and who shall perform the duties of a Council member appointed under subsection (a)(1)(C) or subsection (a)(1)(D) of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ee550b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" until a vacancy referred to in subsection (b)(4) of this section is filled; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ee550c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the event of the anticipated absence of such a member from any meeting of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ee550d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ee550e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraphs (2) and (3), the term of office of a member of the Council appointed under subsections (a)(1)(C) and (a)(1)(D) of this section is three years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ee550f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the Council members first appointed under subsection (a)(1)(C) of this section after ","children":[{"tag":"date","attrib":{"date":"1989-12-13"},"text":"December 13, 1989","children":[],"tail":", one shall be appointed for a term of one year, one shall be appointed for a term of two years, and two shall be appointed for a term of three years."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ee5510-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the Council members first appointed under subsection (a)(1)(D) of this section after ","children":[{"tag":"date","attrib":{"date":"1989-12-13"},"text":"December 13, 1989","children":[],"tail":", one shall be appointed for a term of one year, one shall be appointed for a term of two years, and one shall be appointed for a term of three years."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ee5511-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever a vacancy occurs among members of the Council appointed under subsection (a)(1)(C) or subsection (a)(1)(D) of this section, the Secretary shall appoint an individual in accordance with either such subsection to fill that vacancy for the remainder of the applicable term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ee5512-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ex officio Council members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized and encouraged to include as ex officio nonvoting members of the Council representatives of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ee5513-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal, provincial, territorial, or State government agencies of Canada and Mexico, which are participating actively in carrying out one or more wetlands conservation projects under this chapter, the Plan, or the Agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ee5514-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Environmental Protection Agency and other appropriate Federal agencies, in addition to the United States Fish and Wildlife Service, which are participating actively in carrying out one or more wetlands conservation projects under this chapter, the Plan, or the Agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ee5515-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit charitable organizations and Native American interests, including tribal organizations, which are participating actively in one or more wetlands conservation projects under this chapter, the Plan, or the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ee5516-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairman shall be elected by the Council from its members for a three-year term, except that the first elected Chairman may serve a term of less than three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ee5517-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the current membership of the Council shall constitute a quorum for the transaction of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ee5518-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall meet at the call of the Chairman at least once a year. Council meetings shall be open to the public, and the Chairman shall take appropriate steps to provide adequate notice to the public of the time and place of such meetings. If a Council member appointed under subsection (a)(1)(C) or (a)(1)(D) of this section misses three consecutive regularly scheduled meetings, the Secretary may remove that individual in accordance with subsection (b)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ee5519-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the United States Fish and Wildlife Service shall appoint an individual who shall serve at the pleasure of the Director and—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ee551a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who shall be educated and experienced in the principles of fish, wildlife, and wetlands conservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ee551b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who shall be responsible, with assistance from the United States Fish and Wildlife Service, for facilitating consideration of wetlands conservation projects by the Council and otherwise assisting the Council in carrying out its responsibilities under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ee551c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4403/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who shall be compensated with the funds available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4407/a/1"},"text":"section 4407(a)(1) of this title","children":[],"tail":" for administering this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ee551d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/233/s4"},"text":"Pub. L. 101–233, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-13"},"text":"Dec. 13, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1970"},"text":"103 Stat. 1970","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/593/tI/s112/1"},"text":"Pub. L. 101–593, title I, § 112(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2962"},"text":"104 Stat. 2962","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/308/s8/a/6"},"text":"Pub. L. 107–308, § 8(a)(6)","children":[],"tail":", (7), (b)(1), "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2447"},"text":"116 Stat. 2447","children":[],"tail":", 2448; "},{"tag":"ref","attrib":{"href":"/us/pl/116/188/tI/s107/a/2"},"text":"Pub. L. 116–188, title I, § 107(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/917"},"text":"134 Stat. 917","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/122"},"text":"Pub. L. 117–286, § 4(a)(122)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4319"},"text":"136 Stat. 4319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79ee551e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79ee551f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79ee5520-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (a)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79ee5521-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “"},{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Public Law 92–463","children":[],"tail":", as amended,” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188"},"text":"Pub. L. 116–188","children":[],"tail":" substituted “Executive Director of the Board” for “Secretary of the Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/308/s8/b/1"},"text":"Pub. L. 107–308, § 8(b)(1)","children":[],"tail":", amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/593/s112/1"},"text":"Pub. L. 101–593, § 112(1)","children":[],"tail":". See 1990 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/308/s8/a/6"},"text":"Pub. L. 107–308, § 8(a)(6)","children":[],"tail":", substituted “section 3702(g)(2)(B)” for “section 3702(2)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/308/s8/a/7"},"text":"Pub. L. 107–308, § 8(a)(7)","children":[],"tail":", substituted “Council” for “Commission” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/593/s112/2"},"text":"Pub. L. 101–593, § 112(2)","children":[],"tail":", inserted sentence at end relating to "},{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Public Law 92–463","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/593/s112/1"},"text":"Pub. L. 101–593, § 112(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/308/s8/b/1"},"text":"Pub. L. 107–308, § 8(b)(1)","children":[],"tail":", inserted “, who shall be the responsible Federal official for ensuring Council compliance with the National Environmental Policy Act of 1969 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)” after “Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/593/s112/3"},"text":"Pub. L. 101–593, § 112(3)","children":[],"tail":", inserted “, and the Chairman shall take appropriate steps to provide adequate notice to the public of the time and place of such meetings” after “open to the public”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79ee5522-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79ee5523-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/308/s8/b/2"},"text":"Pub. L. 107–308, § 8(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2448"},"text":"116 Stat. 2448","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/308/s8/b/2"},"text":"“Paragraph (1) of this subsection [amending this section] shall be effective on and after the effective date of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/593/s112/1"},"text":"section 112(1) of Public Law 101–593","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/104/2962"},"text":"104 Stat. 2962","children":[],"tail":") ["},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79ee5524-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Membership of North American Wetlands Conservation Council","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/312/tIII/s304"},"text":"Pub. L. 105–312, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2958"},"text":"112 Stat. 2958","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/312/tIII/s304"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding section 4(a)(1)(D) of the North American Wetlands Conservation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4403/a/1/D"},"text":"16 U.S.C. 4403(a)(1)(D)","children":[],"tail":"), during the period of 1999 through 2002, the membership of the North American Wetlands Conservation Council under section 4(a)(1)(D) of that Act shall consist of—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 individual who shall be the Group Manager for Conservation Programs of Ducks Unlimited, Inc. and who shall serve for 1 term of 3 years beginning in 1999; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 individuals who shall be appointed by the Secretary of the Interior in accordance with section 4 of that Act and who shall each represent a different organization described in section 4(a)(1)(D) of that Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication of Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1999-06-30"},"text":"June 30, 1999","children":[],"tail":", the Secretary of the Interior shall publish in the Federal Register, after notice and opportunity for public comment, a policy for making appointments under section 4(a)(1)(D) of the North American Wetlands Conservation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4403/a/1/D"},"text":"16 U.S.C. 4403(a)(1)(D)","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
