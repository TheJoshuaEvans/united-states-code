{"tag":"section","attrib":{"id":"id77fbfab8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–12"},"text":"§ 460lll–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil and criminal jurisdiction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fbfab9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–12/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Chief of the Forest Service, shall administer the Recreation Area in accordance with this subchapter and the laws, rules, and regulations pertaining to the National Forest System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfaba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–12/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Land within the Recreation Area shall have the status of land acquired under the Act of ","children":[{"tag":"date","attrib":{"date":"1911-03-01"},"text":"March 1, 1911","children":[],"tail":" (commonly known as the “Weeks Act”) ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s515"},"text":"16 U.S.C. 515","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfabb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–12/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to provide for a cost-effective transfer of the law enforcement responsibilities between the Forest Service and the Tennessee Valley Authority, the law enforcement authorities designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s831c–3"},"text":"section 831c–3 of this title","children":[],"tail":" are hereby granted to special agents and law enforcement officers of the Forest Service. The law enforcement authorities designated under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s551"},"text":"section 551 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s559"},"text":"section 559 of this title","children":[],"tail":", the National Forest System Drug Control Act of 1986 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s559b–559g"},"text":"16 U.S.C. 559b–559g","children":[],"tail":") are hereby granted to law enforcement agents of the Tennessee Valley Authority, within the boundaries of the Recreation Area, for a period of 1 year from "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fbfabc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s512"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 512]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–313.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77fbfabd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77fbfabe-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77fbfabf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1911-03-01"},"text":"March 1, 1911","children":[],"tail":", referred to in subsec. (b), is "},{"tag":"ref","attrib":{"href":"/us/act/1911-03-01/ch186"},"text":"act Mar. 1, 1911, ch. 186","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/961"},"text":"36 Stat. 961","children":[],"tail":", popularly known as the Weeks Law, which enacted former sections 513 and 514 and sections 515 to 519, 521, 552, and 563 of this title and amended sections 480 and 500 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s552"},"text":"section 552 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Forest System Drug Control Act of 1986, referred to in subsec. (c), is title XV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570"},"text":"Pub. L. 99–570","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-191"},"text":"100 Stat. 3207–191","children":[],"tail":", which enacted sections 559b to 559g of this title, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s841"},"text":"section 841 of Title 21","children":[],"tail":", Food and Drugs, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s559b"},"text":"section 559b of this title","children":[],"tail":". For complete classification of title XV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s559b"},"text":"section 559b of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
