{"tag":"section","attrib":{"id":"id77636469-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–25"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ww–25"},"text":"§ 410ww–25.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated annually to the Commission to carry out its duties under this subchapter $350,000, except that the Federal contribution to the Commission shall not exceed 50 percent of the annual costs to the Commission in carrying out those duties.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7763646a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/419/tII/s205"},"text":"Pub. L. 102–419, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2148"},"text":"106 Stat. 2148","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
