{"tag":"section","attrib":{"id":"id771bd407-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230d"},"text":null,"children":[{"tag":"num","attrib":{"value":"230d"},"text":"§ 230d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting, fishing, and trapping; public safety; consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Within the Barataria Preserve Unit, the Secretary shall permit hunting, fishing (including commercial fishing), and trapping in accordance with applicable Federal and State laws on land, and interests in land and water managed by the Secretary, except that the Secretary may designate zones where and establish periods when no hunting, fishing, or trapping shall be permitted for reasons of public safety. Except in emergencies, any regulations of the Secretary promulgated under this section shall be put into effect only after consultation with the appropriate fish and game agency of Louisiana.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id771bd408-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/tIX/s905"},"text":"Pub. L. 95–625, title IX, § 905","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3536"},"text":"92 Stat. 3536","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7105/d"},"text":"Pub. L. 111–11, title VII, § 7105(d)","children":[],"tail":", (f)(2)(A), "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1192"},"text":"123 Stat. 1192","children":[],"tail":", 1193.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id771bd409-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id771bd40a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id771bd40b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":", in first sentence, substituted “Barataria Preserve Unit” for “Barataria Marsh Unit” and “on land, and interests in land and water managed by the Secretary, except that the Secretary” for “, except that within the core area and on those lands acquired by the Secretary pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s230a/c"},"text":"section 230a(c) of this title","children":[],"tail":", he”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id771bd40c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id771bd40d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/s2"},"text":"section 2 of Pub. L. 95–625","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s45f"},"text":"section 45f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
