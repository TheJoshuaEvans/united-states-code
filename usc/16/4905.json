{"tag":"section","attrib":{"id":"id79f7cb89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905"},"text":null,"children":[{"tag":"num","attrib":{"value":"4905"},"text":"§ 4905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of approved species","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f7cb8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Listing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cb8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"One year after ","children":[{"tag":"date","attrib":{"date":"1992-10-23"},"text":"October 23, 1992","children":[],"tail":", and periodically thereafter, the Secretary shall, after notice and an opportunity for public comment, publish in the Federal Register a list of species of exotic birds that are listed in an Appendix to the Convention and that are not subject to a prohibition or suspension of importation otherwise applicable under section 4904(a), (b), or (c) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of listing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall list a species under paragraph (1) with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cb8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the countries of origin from which the species may be imported; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cb8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if appropriate, the qualifying facilities in those countries from which the species may be imported.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bases for determinations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making a determination required under this subsection, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cb90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the best scientific information available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cb91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the adequacy of regulatory and enforcement mechanisms in all countries of origin for the species, including such mechanisms for control of illegal trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f7cb92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Captive bred species","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall include a species of exotic birds in the list under subsection (a) if the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cb93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the species is regularly bred in captivity and no wild-caught birds of the species are in trade; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the species is bred in a qualifying facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f7cb95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-captive bred species","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall include in the list under subsection (a) a species of exotic birds that is listed in an Appendix to the Convention if the Secretary finds the Convention is being effectively implemented with respect to that species because of each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cb96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each country of origin for which the species is listed is effectively implementing the Convention, particularly with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cb97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of a scientific authority or other equivalent authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cb98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements of Article IV of the Convention with respect to that species; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cb99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remedial measures recommended by the Parties to the Convention with respect to that species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A scientifically-based management plan for the species has been developed which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cb9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for the conservation of the species and its habitat and includes incentives for conservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cb9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that the use of the species is biologically sustainable and maintained throughout the range of the species in the country to which the plan applies at a level that is consistent with the role of the species in the ecosystem and is well above the level at which the species might become threatened with extinction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cb9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addresses factors relevant to the conservation of the species, including illegal trade, domestic trade, subsistence use, disease, and habitat loss.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The management plan is implemented and enforced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4905/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The methods of capture, transport, and maintenance of the species minimizes the risk of injury or damage to health, including inhumane treatment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f7cba0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tI/s106"},"text":"Pub. L. 102–440, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2227"},"text":"106 Stat. 2227","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
