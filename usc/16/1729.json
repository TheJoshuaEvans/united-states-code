{"tag":"section","attrib":{"id":"id795f3423-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1729"},"text":null,"children":[{"tag":"num","attrib":{"value":"1729"},"text":"§ 1729.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id795f3424-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1729/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795f3425-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1729/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects by qualified youth or conservation corps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to pay not more than 75 percent of the costs of any appropriate conservation project carried out pursuant to this subchapter on public lands by a qualified youth or conservation corps. The remaining 25 percent of the costs of such a project may be provided from nonfederal sources in the form of funds, services, facilities, materials, equipment, or any combination of the foregoing. No cost sharing shall be required in the case of any appropriate conservation project carried out on Indian lands or Hawaiian home lands under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795f3426-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1729/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public Lands Corps projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to accept donations of funds, services, facilities, materials, or equipment for the purposes of operating the Public Lands Corps and carrying out appropriate conservation projects by the Corps. However, nothing in this subchapter shall be construed to require any cost sharing for any project carried out directly by the Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795f3427-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1729/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds available under National and Community Service Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to carry out the Public Lands Corps or to support resource assistants and qualified youth or conservation corps under this subchapter, the Secretary shall be eligible to apply for and receive assistance under section 121(b) of the National and Community Service Act of 1990 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571/b"},"text":"42 U.S.C. 12571(b)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795f3428-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1729/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated pursuant to the authorization of appropriations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1730"},"text":"section 1730 of this title","children":[],"tail":" are in addition to amounts allocated to the Public Lands Corps through other Federal programs or projects."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id795f3429-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/378/tII/s212"},"text":"Pub. L. 91–378, title II, § 212","children":[],"tail":", formerly § 210, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s105/6"},"text":"Pub. L. 103–82, title I, § 105(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/853"},"text":"107 Stat. 853","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/f/1"},"text":"Pub. L. 109–154, § 2(f)(1)","children":[],"tail":", (g)(4), "},{"tag":"date","attrib":{"date":"2005-12-30"},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2892"},"text":"119 Stat. 2892","children":[],"tail":", 2893; renumbered § 212 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tIX/s9003/f/1"},"text":"Pub. L. 116–9, title IX, § 9003(f)(1)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/835"},"text":"133 Stat. 835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795f342a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id795f342b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id795f342c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s9003/f/3"},"text":"Pub. L. 116–9, § 9003(f)(3)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1730"},"text":"section 1730 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/g/4/A"},"text":"Pub. L. 109–154, § 2(g)(4)(A)","children":[],"tail":", substituted “Secretary is” for “Secretary of the Interior and the Secretary of Agriculture are each” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/g/4/B"},"text":"Pub. L. 109–154, § 2(g)(4)(B)","children":[],"tail":", substituted “Secretary” for “Secretary of the Interior and the Secretary of Agriculture”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/f/1"},"text":"Pub. L. 109–154, § 2(f)(1)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id795f342d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id795f342e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as an Effective Date of 1993 Amendment note 