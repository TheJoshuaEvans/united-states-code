{"tag":"section","attrib":{"id":"id777405a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"410hhh–6"},"text":"§ 410hhh–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property and boundary adjustments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id777405aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777405ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within the area depicted on the map as the “Acquisition Area” or the national monument, the Secretary may acquire lands and interests therein by purchase, donation, transfer from another Federal agency, or exchange: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That lands or interests therein may only be acquired with the consent of the owner thereof."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777405ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lands or interests therein owned by the State of Colorado, or a political subdivision thereof, may only be acquired by donation or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777405ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the acquisition of any land or interest under this section, the Secretary shall modify the boundary of the unit to which the land is transferred pursuant to subsection (b) ","children":[{"tag":"ref","attrib":{"idref":"fn002172"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002172"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection (c)”."}],"tail":" to include any land or interest acquired."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777405ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of acquired lands","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777405af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–6/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon acquisition of lands under subsection (a), the Secretary shall, as appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777405b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–6/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" transfer administrative jurisdiction of the lands to the National Park Service—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777405b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–6/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for addition to and management as part of the Great Sand Dunes National Monument, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777405b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–6/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for addition to and management as part of the Great Sand Dunes National Park (after designation of the Park) or the Great Sand Dunes National Preserve; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777405b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–6/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer administrative jurisdiction of the lands to the United States Fish and Wildlife Service for addition to and administration as part of the Baca National Wildlife Refuge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777405b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–6/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest service administration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777405b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–6/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any lands acquired within the area depicted on the map as being located within Zone B shall be transferred to the Secretary of Agriculture and shall be added to and managed as part of the Rio Grande National Forest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777405b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–6/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of sections 100506(c) and 200306 of title 54, the boundaries of the Rio Grande National Forest, as revised by the transfer of land under paragraph (A), shall be considered to be the boundaries of the national forest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777405b7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/530/s8"},"text":"Pub. L. 106–530, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2532"},"text":"114 Stat. 2532","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777405b8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777405b9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id777405ba-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (c)(2)(B), “sections 100506(c) and 200306 of title 54” substituted for “section 7 of the Land and Water Conservation Fund Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460"},"text":"16 U.S.C. 460","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–9)” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/e"},"text":"Pub. L. 113–287, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3272"},"text":"128 Stat. 3272","children":[],"tail":", which Act enacted Title 54, National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
