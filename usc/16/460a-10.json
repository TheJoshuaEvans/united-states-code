{"tag":"section","attrib":{"id":"id77bde06a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460a–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"460a–10"},"text":"§ 460a–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of national forest lands to Secretary of Agriculture","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With the concurrence of the Secretary of Agriculture the Secretary of the Interior may transfer to the Secretary of Agriculture for national forest purposes lands or interests in lands within national forests acquired for, or in connection with, the parkway extension.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77bde06b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/555/s5"},"text":"Pub. L. 90–555, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-09"},"text":"Oct. 9, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/968"},"text":"82 Stat. 968","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
