{"tag":"section","attrib":{"id":"id7a206210-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6910"},"text":null,"children":[{"tag":"num","attrib":{"value":"6910"},"text":"§ 6910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary of Commerce such sums as may be necessary to carry out this chapter and to pay the United States’ contribution to the Commission under section 5 of part III of the WCPFC Convention.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a206211-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479/tV/s512"},"text":"Pub. L. 109–479, title V, § 512","children":[],"tail":", formerly § 511, "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3644"},"text":"120 Stat. 3644","children":[],"tail":"; renumbered § 512, "},{"tag":"ref","attrib":{"href":"/us/pl/114/327/tIII/s301/a/2"},"text":"Pub. L. 114–327, title III, § 301(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1994"},"text":"130 Stat. 1994","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
