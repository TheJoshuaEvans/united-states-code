{"tag":"section","attrib":{"id":"id77f7193e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"460hhh–6"},"text":"§ 460hhh–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77f7193f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights and except as provided in subsection (b), all Federal lands within the Recreation Area are withdrawn from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77f71940-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all forms of entry, appropriation, or disposal under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f71941-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f71942-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–6/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation under the mineral leasing and geothermal leasing laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f71943-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77f71944-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a), W½E½ and W½ sec. 27, T. 23 S., R. 58 E., Mt. Diablo Meridian is not subject to withdrawal under that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f71945-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of entry under public land laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1) of subsection (a), the following are not subject to withdrawal under that paragraph:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77f71946-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–6/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any Federal land in the Recreation Area that qualifies for conveyance under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/465"},"text":"Public Law 97–465","children":[],"tail":" (commonly known as the “Small Tracts Act”) ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s521c"},"text":"16 U.S.C. 521c","children":[],"tail":" et seq.), which, notwithstanding section 7 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s521i"},"text":"16 U.S.C. 521i","children":[],"tail":"), may be conveyed under that Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77f71947-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–6/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any Federal land in the Recreation Area that the Secretary determines to be appropriate for conveyance by exchange for non-Federal land within the Recreation Area under authorities generally providing for the exchange of National Forest System land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77f71948-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/63/s8"},"text":"Pub. L. 103–63, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-04"},"text":"Aug. 4, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/300"},"text":"107 Stat. 300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXX/s3092/f"},"text":"Pub. L. 113–291, div. B, title XXX, § 3092(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3872"},"text":"128 Stat. 3872","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77f71949-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77f7194a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77f7194b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/465"},"text":"Public Law 97–465","children":[],"tail":" (commonly known as the “Small Tracts Act”), referred to in subsec. (b)(2)(A), is "},{"tag":"ref","attrib":{"href":"/us/pl/97/465"},"text":"Pub. L. 97–465","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2535"},"text":"96 Stat. 2535","children":[],"tail":", which enacted sections 521c to 521i of this title and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s484a"},"text":"section 484a of this title","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77f7194c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3092/f/1"},"text":"Pub. L. 113–291, § 3092(f)(1)","children":[],"tail":", substituted “as provided” for “for lands described” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3092/f/2"},"text":"Pub. L. 113–291, § 3092(f)(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “The lands referred to in subsection (a) of this section are described as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“W½E½ and W½, Sec. 27, T23S, R58E, Mt. Diablo Meridian.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
