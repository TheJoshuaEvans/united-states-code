{"tag":"section","attrib":{"id":"id79fa3c14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5107"},"text":null,"children":[{"tag":"num","attrib":{"value":"5107"},"text":"§ 5107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary and the Secretary of the Interior may provide financial assistance to the Commission and to the States to carry out their respective responsibilities under this chapter, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fa3c15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5107/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparation, implementation, and enforcement of coastal fishery management plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3c16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5107/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State activities that are specifically required within such plans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fa3c17-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206/tVIII/s808"},"text":"Pub. L. 103–206, title VIII, § 808","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2453"},"text":"107 Stat. 2453","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fa3c18-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79fa3c19-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79fa3c1a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/555/tI/s122/c"},"text":"Pub. L. 106–555, title I, § 122(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2766"},"text":"114 Stat. 2766","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/555/tI/s122/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual report to the Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require, as a condition of providing financial assistance under this subtitle [subtitle B (§§ 121, 122) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/555"},"text":"Pub. L. 106–555","children":[],"tail":", amending sections 5101 to 5103, 5106, and 5107a to 5108 of this title and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s5101"},"text":"section 5101 of this title","children":[],"tail":"], that the Commission and each State receiving such assistance submit to the Secretary an annual report that provides a detailed accounting of the use of the assistance."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Biennial reports to the Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall submit biennial reports to the Committee on Resources [now Committee on Natural Resources] of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate on the use of Federal assistance provided to the Commission and the States under this subtitle. Each biennial report shall evaluate the success of such assistance in implementing this subtitle.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
