{"tag":"section","attrib":{"id":"id78d4f574-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s936"},"text":null,"children":[{"tag":"num","attrib":{"value":"936"},"text":"§ 936.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of the Interior; authority to transfer lamprey control projects and act on behalf of United States Section","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior is authorized, upon the request of the United States Section—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78d4f575-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s936/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to transfer to the United States Section any lamprey control project or works under his jurisdiction now existing or now under construction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d4f576-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s936/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to act for or on behalf of the United States Section in the exercise of the powers granted by this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78d4f577-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-06-04/ch358/s7"},"text":"June 4, 1956, ch. 358, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/243"},"text":"70 Stat. 243","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
