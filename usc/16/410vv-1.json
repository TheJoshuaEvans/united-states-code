{"tag":"section","attrib":{"id":"id7760f39a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"410vv–1"},"text":"§ 410vv–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7760f39b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established as a unit of the National Park System the Marsh-Billings-Rockefeller National Historical Park in Windsor County, Vermont (hereinafter in this subchapter referred to as the “park”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f39c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundaries and map","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7760f39d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The park shall consist of a historic zone, including the Marsh-Billings-Rockefeller Mansion, surrounding buildings and a portion of the area known as “Mt. Tom”, comprising approximately 555 acres, and a protection zone, including the areas presently occupied by the Billings Farm and Museum, comprising approximately 88 acres, all as generally depicted on the map entitled “Marsh-Billings-Rockefeller National Historical Park Boundary Map” and dated ","children":[{"tag":"date","attrib":{"date":"1991-11-19"},"text":"November 19, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f39e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The map referred to in paragraph (1) shall be on file and available for public inspection in the appropriate offices of the National Park Service, Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7760f39f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/350/s3"},"text":"Pub. L. 102–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/934"},"text":"106 Stat. 934","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tI/s143"},"text":"Pub. L. 105–277, div. A, § 101(e) [title I, § 143]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–267.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7760f3a0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7760f3a1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7760f3a2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsecs. (a), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" substituted “Marsh-Billings-Rockefeller” for “Marsh-Billings” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
