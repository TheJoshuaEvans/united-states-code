{"tag":"section","attrib":{"id":"id79dd8c6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865"},"text":null,"children":[{"tag":"num","attrib":{"value":"3865"},"text":"§ 3865.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79dd8c6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an agricultural conservation easement program for the conservation of eligible land and natural resources through easements or other interests in land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dd8c6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the program are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dd8c6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combine the purposes and coordinate the functions of the wetlands reserve program established under section 3837 ","children":[{"tag":"ref","attrib":{"idref":"fn002774"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002774"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, the grassland reserve program established under section 3838n "},{"tag":"ref","attrib":{"idref":"fn002774"},"text":"1","children":[],"tail":" of this title, and the farmland protection program established under section 3838i "},{"tag":"ref","attrib":{"idref":"fn002774"},"text":"1","children":[],"tail":" of this title, as such sections were in effect on the day before "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restore, protect, and enhance wetlands on eligible land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect the agricultural use and future viability, and related conservation values, of eligible land by limiting nonagricultural uses of that land that negatively affect the agricultural uses and conservation values; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect grazing uses and related conservation values by restoring or conserving eligible land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79dd8c72-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1265"},"text":"Pub. L. 99–198, title XII, § 1265","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2301/a"},"text":"Pub. L. 113–79, title II, § 2301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/731"},"text":"128 Stat. 731","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2601"},"text":"Pub. L. 115–334, title II, § 2601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4585"},"text":"132 Stat. 4585","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79dd8c73-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79dd8c74-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79dd8c75-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 3837, 3838n, and 3838i of this title, referred to in subsec. (b)(1), were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII"},"text":"Pub. L. 113–79, title II","children":[],"tail":", §§ 2703(a), 2704(a), 2705(a), "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/767"},"text":"128 Stat. 767","children":[],"tail":", 768."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79dd8c76-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2601/1"},"text":"Pub. L. 115–334, § 2601(1)","children":[],"tail":", inserted “that negatively affect the agricultural uses and conservation values” after “uses of that land”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2601/2"},"text":"Pub. L. 115–334, § 2601(2)","children":[],"tail":", substituted “restoring or conserving” for “restoring and conserving”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
