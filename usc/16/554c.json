{"tag":"section","attrib":{"id":"id78438b03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s554c"},"text":null,"children":[{"tag":"num","attrib":{"value":"554c"},"text":"§ 554c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Care of employees’ graves","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appropriations for the Forest Service shall be available within such limitations as may be prescribed therein for the expenses of properly caring for the graves of persons who have lost their lives as a result of fighting fires while employed by the Forest Service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78438b04-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-09-21/ch412"},"text":"Sept. 21, 1944, ch. 412","children":[],"tail":", title II, § 206, "},{"tag":"ref","attrib":{"href":"/us/stat/58/736"},"text":"58 Stat. 736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78438b05-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78438b06-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78438b07-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as a part of the Department of Agriculture Organic Act of 1944.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
