{"tag":"section","attrib":{"id":"id780c9cd3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"460zzz–6"},"text":"§ 460zzz–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id780c9cd4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", the Secretary shall establish an advisory council, to be known as the “Dominguez-Escalante National Conservation Area Advisory Council”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9cd5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall advise the Secretary with respect to the preparation and implementation of the management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9cd6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be subject to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9cd7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–6/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 10 of title 5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9cd8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–6/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9cd9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall include 10 members to be appointed by the Secretary, of whom, to the extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9cda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–6/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall be appointed after considering the recommendations of the Mesa County Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9cdb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–6/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall be appointed after considering the recommendations of the Montrose County Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9cdc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–6/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall be appointed after considering the recommendations of the Delta County Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9cdd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–6/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall be appointed after considering the recommendations of the permittees holding grazing allotments within the Conservation Area or the Wilderness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9cde-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–6/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 5 members shall reside in, or within reasonable proximity to, Mesa County, Delta County, or Montrose County, Colorado, with backgrounds that reflect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780c9cdf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–6/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes for which the Conservation Area or Wilderness was established; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9ce0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–6/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interests of the stakeholders that are affected by the planning and management of the Conservation Area and Wilderness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9ce1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–6/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the membership of the Council is fairly balanced in terms of the points of view represented and the functions to be performed by the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9ce2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–6/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall terminate on the date that is 1 year from the date on which the management plan is adopted by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id780c9ce3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tII/s2407"},"text":"Pub. L. 111–11, title II, § 2407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1107"},"text":"123 Stat. 1107","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/97"},"text":"Pub. L. 117–286, § 4(a)(97)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4316"},"text":"136 Stat. 4316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id780c9ce4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id780c9ce5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id780c9ce6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in subsec. (c)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id780c9ce7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5;” for “the Federal Advisory Committee Act (5 U.S.C. App.);”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
