{"tag":"section","attrib":{"id":"id7a22d244-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7006"},"text":null,"children":[{"tag":"num","attrib":{"value":"7006"},"text":"§ 7006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a22d245-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is responsible for carrying out the Agreement and this chapter, including the authority, to be exercised in consultation with the Secretary of State, to accept or reject, on behalf of the United States, recommendations made by the joint management committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a22d246-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations; cooperation with Canadian officials","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In exercising responsibilities under this chapter, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a22d247-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7006/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may promulgate such regulations as may be necessary to carry out the purposes and objectives of the Agreement and this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d248-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7006/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the concurrence of the Secretary of State, may cooperate with officials of the Canadian Government duly authorized to carry out the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a22d249-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479/tVI/s607"},"text":"Pub. L. 109–479, title VI, § 607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3646"},"text":"120 Stat. 3646","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
