{"tag":"section","attrib":{"id":"id7942ab73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463"},"text":null,"children":[{"tag":"num","attrib":{"value":"1463"},"text":"§ 1463.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and promulgate, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", after notice and opportunity for full participation by relevant Federal agencies, state agencies, local governments, regional organizations, port authorities, and other interested parties, both public and private, such rules and regulations as may be necessary to carry out the provisions of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7942ab74-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454/tIII/s317"},"text":"Pub. L. 89–454, title III, § 317","children":[],"tail":", formerly § 314, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/583"},"text":"Pub. L. 92–583","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1288"},"text":"86 Stat. 1288","children":[],"tail":"; renumbered § 317, "},{"tag":"ref","attrib":{"href":"/us/pl/94/370/s7"},"text":"Pub. L. 94–370, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-26"},"text":"July 26, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1019"},"text":"90 Stat. 1019","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
