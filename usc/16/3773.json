{"tag":"section","attrib":{"id":"id79c5be30-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3773"},"text":null,"children":[{"tag":"num","attrib":{"value":"3773"},"text":"§ 3773.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partners for Fish and Wildlife Program","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out the Partners for Fish and Wildlife Program within the United States Fish and Wildlife Service to provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c5be31-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3773/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical and financial assistance to private landowners for the conduct of voluntary projects to benefit Federal trust species by promoting habitat improvement, habitat restoration, habitat enhancement, and habitat establishment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c5be32-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3773/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance to other public and private entities regarding fish and wildlife habitat restoration on private land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c5be33-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/294/s4"},"text":"Pub. L. 109–294, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-03"},"text":"Oct. 3, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1354"},"text":"120 Stat. 1354","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
