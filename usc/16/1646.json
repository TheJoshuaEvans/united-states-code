{"tag":"section","attrib":{"id":"id795a796e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1646"},"text":null,"children":[{"tag":"num","attrib":{"value":"1646"},"text":"§ 1646.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated annually such sums as may be needed to implement this subchapter. Funds appropriated under this subchapter shall remain available until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id795a796f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/307/s7"},"text":"Pub. L. 95–307, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-30"},"text":"June 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/356"},"text":"92 Stat. 356","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
