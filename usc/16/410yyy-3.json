{"tag":"section","attrib":{"id":"id777d7c39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410yyy–3"},"text":"§ 410yyy–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ocmulgee Mounds National Historical Park boundary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id777d7c3a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777d7c3b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historical park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Historical Park” means the Ocmulgee Mounds National Historical Park in the State of Georgia, as redesignated by subsection (b)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7c3c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “map” means the map entitled “Ocmulgee National Monument Proposed Boundary Adjustment”, numbered 363/125996, and dated January 2016.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7c3d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “study area” means the Ocmulgee River corridor between the cities of Macon, Georgia, and Hawkinsville, Georgia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777d7c3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ocmulgee Mounds National Historical Park","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777d7c3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redesignation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7c40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Ocmulgee National Monument, established pursuant to sections 410yyy to 410yyy–2 of this title, shall be known and designated as the “Ocmulgee Mounds National Historical Park”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7c41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in a law, map, regulation, document, paper, or other record of the United States to the “Ocmulgee National Monument” shall be deemed to be a reference to the “Ocmulgee Mounds National Historical Park”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7c42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary adjustment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7c43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The boundary of the Historical Park is revised to include approximately 2,100 acres of land, as generally depicted on the map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7c44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7c45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7c46-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire land and interests in land within the boundaries of the Historical Park by donation, purchase from a willing seller with donated or appropriated funds, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7c47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not acquire by condemnation any land or interest in land within the boundaries of the Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7c48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer any land acquired under paragraph (3) as part of the Historical Park in accordance with applicable laws (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777d7c49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ocmulgee River corridor special resource study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777d7c4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a special resource study of the study area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7c4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the study under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7c4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the national significance of the study area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7c4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the suitability and feasibility of designating the study area as a unit of the National Park System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7c4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider other alternatives for preservation, protection, and interpretation of the study area by the Federal Government, State or local government entities, or private and nonprofit organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7c4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with interested Federal agencies, State or local governmental entities, private and nonprofit organizations, or any other interested individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7c50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify cost estimates for any Federal acquisition, development, interpretation, operation, and maintenance associated with the alternatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7c51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The study required under paragraph (1) shall be conducted in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100507"},"text":"section 100507 of title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7c52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after the date on which funds are first made available to carry out the study under paragraph (1), the Secretary shall submit to the Committee on Natural Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a report that describes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7c53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7c54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy–3/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any conclusions and recommendations of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777d7c55-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2102"},"text":"Pub. L. 116–9, title II, § 2102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/724"},"text":"133 Stat. 724","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777d7c56-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777d7c57-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id777d7c58-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the John D. Dingell, Jr. Conservation, Management, and Recreation Act, and not as part of act ","children":[{"tag":"date","attrib":{"date":"1934-06-14"},"text":"June 14, 1934","children":[],"tail":", which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id777d7c59-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id777d7c5a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2"},"text":"section 2 of Pub. L. 116–9","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
