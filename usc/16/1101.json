{"tag":"section","attrib":{"id":"id78e59787-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1101"},"text":null,"children":[{"tag":"num","attrib":{"value":"1101"},"text":"§ 1101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78e59788-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Commission” means the Roosevelt Campobello International Park Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e59789-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States members” means members of the Commission appointed by the President. The term “Canadian members” means members of the Commission appointed by the appropriate authorities in Canada.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78e5978a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/363/s2"},"text":"Pub. L. 88–363, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-07"},"text":"July 7, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/299"},"text":"78 Stat. 299","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78e5978b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78e5978c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id78e5978d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/363/s1"},"text":"Pub. L. 88–363, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-07"},"text":"July 7, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/299"},"text":"78 Stat. 299","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/88/363/s1"},"text":"“That this Act [enacting this chapter] may be cited as the ‘Roosevelt Campobello International Park Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
