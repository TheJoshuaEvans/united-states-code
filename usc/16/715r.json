{"tag":"section","attrib":{"id":"id7883c846-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715r"},"text":null,"children":[{"tag":"num","attrib":{"value":"715r"},"text":"§ 715r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partial invalidity; validity of remainder","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this subchapter or the application thereof to any person or circumstance is held invalid the validity of the remainder of this subchapter and of the application of such provision to other persons and circumstances shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7883c847-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-02-18/ch257/s19"},"text":"Feb. 18, 1929, ch. 257, § 19","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1226"},"text":"45 Stat. 1226","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
