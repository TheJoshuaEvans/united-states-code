{"tag":"section","attrib":{"id":"id7727ba86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s284b"},"text":null,"children":[{"tag":"num","attrib":{"value":"284b"},"text":"§ 284b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary, but not in excess of $5,473,000, to carry out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7727ba87-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/671/s3"},"text":"Pub. L. 89–671, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/951"},"text":"80 Stat. 951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/272/tII/s201/4"},"text":"Pub. L. 92–272, title II, § 201(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-04-11"},"text":"Apr. 11, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/120"},"text":"86 Stat. 120","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7727ba88-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7727ba89-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7727ba8a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":