{"tag":"section","attrib":{"id":"id774de078-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"410cc–14"},"text":"§ 410cc–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subchapter, no authority to enter into agreements or to make payments under this subchapter shall be effective except to the extent, or in such amounts, as may be provided in advance in appropriation Acts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id774de079-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/290/tI/s104"},"text":"Pub. L. 95–290, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-05"},"text":"June 5, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/292"},"text":"92 Stat. 292","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
