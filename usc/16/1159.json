{"tag":"section","attrib":{"id":"id78ecc33e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1159"},"text":null,"children":[{"tag":"num","attrib":{"value":"1159"},"text":"§ 1159.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agency consultations with and technical assistance to Secretary of Commerce or Commission; reimbursement for assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The head of any Federal agency is authorized to consult with and provide technical assistance to the Secretary or the Commission whenever such assistance is needed and reasonably can be furnished in carrying out the provisions of this subchapter. Any Federal agency furnishing assistance hereunder may expend its own funds for such purposes, with or without reimbursement.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78ecc33f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/702/tI/s109"},"text":"Pub. L. 89–702, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1093"},"text":"80 Stat. 1093","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/129/s2"},"text":"Pub. L. 98–129, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-10-14"},"text":"Oct. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/838"},"text":"97 Stat. 838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78ecc340-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78ecc341-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78ecc342-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/129"},"text":"Pub. L. 98–129","children":[],"tail":" amended section generally, substituting provisions authorizing Federal agency consultation with and technical assistance to the Secretary or the Commission, which were previously contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1158"},"text":"section 1158 of this title","children":[],"tail":", for provisions defining terms. See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1151"},"text":"section 1151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
