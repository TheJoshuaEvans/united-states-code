{"tag":"section","attrib":{"id":"id77eb321f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ww"},"text":"§ 460ww.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77eb3220-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to protect and preserve the scenic, recreational, geological, and fish and wildlife resources of the Gauley River and its tributary, the Meadow River, there is hereby established the Gauley River National Recreation Area (hereinafter in this Act referrred ","children":[{"tag":"ref","attrib":{"idref":"fn002348"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002348"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Should be “referred”."}],"tail":" to as the “recreation area”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77eb3221-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recreation area shall consist of the land, waters, and interests therein generally depicted on the boundary map entitled “Gauley River National Recreation Area”, numbered NRA–GR/20,000A and dated July 1987 and on the boundary map depicting the Meadow River, numbered WSR–MEA/20,000A and dated July 1988. The map shall be on file and available for public inspection in the offices of the National Park Service, Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77eb3222-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary modifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within five years after ","children":[{"tag":"date","attrib":{"date":"1988-10-26"},"text":"October 26, 1988","children":[],"tail":", the Secretary of the Interior (hereinafter in this subchapter referred to as the “Secretary”) shall submit to the Committee on Natural Resources of the United States House of Representatives and to the Committee on Energy and Natural Resources of the United States Senate a report containing any boundary modifications which the Secretary recommends, together with the reasons therefor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77eb3223-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/534/tII/s201"},"text":"Pub. L. 100–534, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-26"},"text":"Oct. 26, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2702"},"text":"102 Stat. 2702","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s6/d/21"},"text":"Pub. L. 103–437, § 6(d)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4584"},"text":"108 Stat. 4584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77eb3224-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77eb3225-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77eb3226-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/534"},"text":"Pub. L. 100–534","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-26"},"text":"Oct. 26, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2699"},"text":"102 Stat. 2699","children":[],"tail":", known as the West Virginia National Interest River Conservation Act of 1987, which enacted this subchapter and sections 410eeee–12 to 410eeee–15 of this title, amended sections 410eeee–1 and 1274 of this title, and enacted provisions set out as notes under sections 410eeee–1 and 1274 of this title. For complete classification of this Act to the Code, see Short Title of 1988 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410eeee–1"},"text":"section 410eeee–1 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77eb3227-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Natural Resources” for “Interior and Insular Affairs” after “Committee on”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
