{"tag":"section","attrib":{"id":"id778e44dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s428e"},"text":null,"children":[{"tag":"num","attrib":{"value":"428e"},"text":"§ 428e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands acquired declared national battlefield; name","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon the ceding of jurisdiction by the Legislature of the State of Tennessee and the report of the Attorney General of the United States that a perfect title has been acquired, the lands acquired under the provisions of sections 428 to 428d and 428e to 428i of this title, together with the area already inclosed within the national cemetery at the battle field of Fort Donelson, are declared to be a national battlefield, to be known as the Fort Donelson National Battlefield.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778e44de-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-03-26/ch248/s6"},"text":"Mar. 26, 1928, ch. 248, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/368"},"text":"45 Stat. 368","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/738/s4"},"text":"Pub. L. 86–738, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-08"},"text":"Sept. 8, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/876"},"text":"74 Stat. 876","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778e44df-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id778e44e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id778e44e1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Fort Donelson National Battlefield” and “battlefield” substituted in text for “Fort Donelson National Military Park” and “park”, respectively, in view of redesignation of Fort Donelson National Military Park as Fort Donelson National Battlefield by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/738"},"text":"Pub. L. 86–738","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s428n"},"text":"section 428n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
