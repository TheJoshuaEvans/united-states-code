{"tag":"section","attrib":{"id":"id78de6b60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j"},"text":null,"children":[{"tag":"num","attrib":{"value":"973j"},"text":"§ 973j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78de6b61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited disclosure of certain information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/3"},"text":"section 552(b)(3) of title 5","children":[],"tail":", except as provided in subsection (b), the Secretary shall keep confidential and may not disclose the following information:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78de6b62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information provided to the Secretary by the Administrator that the Administrator has designated confidential.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78de6b63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information collected by observers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78de6b64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information submitted to the Secretary by any person in compliance with the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78de6b65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized disclosure of certain information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may disclose information described in subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78de6b66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if disclosure is ordered by a court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78de6b67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the information is used by a Federal employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78de6b68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for enforcement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78de6b69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in support of the homeland security missions and non-homeland security missions of the Coast Guard as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s468"},"text":"section 468 of title 6","children":[],"tail":"; "},{"tag":"ref","attrib":{"idref":"fn002568"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002568"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78de6b6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the information is used by a Federal employee or an employee of a Fishery Management Council for the administration of the Treaty or fishery management and monitoring;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78de6b6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Administrator, in accordance with the requirements of the Treaty and this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78de6b6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the secretariat or equivalent of an international fisheries management organization of which the United States is a member, in accordance with the requirements or decisions of such organization, and insofar as possible, in accordance with an agreement that prevents public disclosure of the identity of any person that submits such information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78de6b6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary has obtained written authorization from the person providing such information, and disclosure does not violate other requirements of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78de6b6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an aggregate or summary form that does not directly or indirectly disclose the identity of any person that submits such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78de6b6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78de6b70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed to adversely affect the authority of Congress, including a Committee or Member thereof, to obtain any record or information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78de6b71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973j/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The absence of a provision similar to paragraph (1) in any other provision of law shall not be construed to limit the ability of the Senate or the House of Representatives, including a Committee or Member thereof, to obtain any record or information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78de6b72-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/330/s12"},"text":"Pub. L. 100–330, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-07"},"text":"June 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/599"},"text":"102 Stat. 599","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIV/s8420"},"text":"Pub. L. 119–60, div. H, title LXXXIV, § 8420","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1917"},"text":"139 Stat. 1917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78de6b73-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78de6b74-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78de6b75-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s468"},"text":"Section 468 of title 6","children":[],"tail":", referred to in subsec. (b)(2)(B), was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7201/j/2"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7201(j)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1686"},"text":"139 Stat. 1686","children":[],"tail":", by transferring subsec. (a) of that section defining “non-homeland security missions” and “homeland security missions” to "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s102/a"},"text":"section 102(a) of Title 14","children":[],"tail":", Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78de6b76-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" amended section generally. Prior to amendment, section related to reporting requirements and the disclosure of information."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
