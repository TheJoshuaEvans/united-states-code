{"tag":"section","attrib":{"id":"id7851bc2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"583j–4"},"text":"§ 583j–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may accept, without regard to the civil service classification laws, rules and regulations, any director, officer, employee or agent of the Foundation as a volunteer for purposes of the Volunteers in the National Forests Act of 1972 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s558a"},"text":"16 U.S.C. 558a","children":[],"tail":" through 558d; "},{"tag":"ref","attrib":{"href":"/us/stat/86/147"},"text":"86 Stat. 147","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn002457"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002457"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7851bc2f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/593/tIV/s406"},"text":"Pub. L. 101–593, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2973"},"text":"104 Stat. 2973","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7851bc30-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7851bc31-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7851bc32-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Volunteers in the National Forests Act of 1972, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/300"},"text":"Pub. L. 92–300","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-05-18"},"text":"May 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/147"},"text":"86 Stat. 147","children":[],"tail":", which was classified generally to former sections 558a to 558d of this title, prior to being amended generally and renamed the Volunteers in the National Forests and Public Lands Act by "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tIII/s341"},"text":"Pub. L. 118–234, title III, § 341","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2913"},"text":"138 Stat. 2913","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/s342"},"text":"Section 342 of Pub. L. 118–234","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s558a"},"text":"section 558a of this title","children":[],"tail":", provides that a reference in any law to the Volunteers in National Forests Act of 1972 shall be deemed to be a reference to the Volunteers in the National Forests and Public Lands Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s558a"},"text":"section 558a of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
