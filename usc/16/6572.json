{"tag":"section","attrib":{"id":"id7a12099f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572"},"text":null,"children":[{"tag":"num","attrib":{"value":"6572"},"text":"§ 6572.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility and enrollment of lands in program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1209a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture, in coordination with the Secretary of the Interior and the Secretary of Commerce, shall describe and define forest ecosystems that are eligible for enrollment in the healthy forests reserve program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1209a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for enrollment in the healthy forests reserve program, land shall be private forest land, or private land being restored to forest land, the enrollment of which will maintain, restore, enhance, or otherwise measurably—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1209a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the likelihood of recovery of a species that is listed as endangered or threatened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1533"},"text":"section 1533 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1209a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improve the well-being of a species that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1209a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1209a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not listed as endangered or threatened under such section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1209a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a candidate for such listing, a State-listed species, or a special concern species; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1209a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is deemed a species of greatest conservation need by a State wildlife action plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1209a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In enrolling land that satisfies the criteria under subsection (b), the Secretary of Agriculture shall give additional consideration to land the enrollment of which will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1209a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve biological diversity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1209aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conserve forest land that provides habitat for species described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1209ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase carbon sequestration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1209ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment by willing owners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall enroll land in the healthy forests reserve program only with the consent of the owner of the land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1209ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods of enrollment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1209ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized methods","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Land may be enrolled in the healthy forests reserve program in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1209af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 10-year cost-share agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1209b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 30-year easement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1209b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1209b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a permanent easement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1209b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a State that imposes a maximum duration for easements, an easement for the maximum duration allowed under State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1209b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acreage owned by Indian tribes","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1209b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of acreage owned by Indian tribes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph, the term “acreage owned by Indian tribes” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1209b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land that is held in trust by the United States for Indian tribes or individual Indians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1209b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land, the title to which is held by Indian tribes or individual Indians subject to Federal restrictions against alienation or encumbrance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1209b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land that is subject to rights of use, occupancy, and benefit of certain Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1209b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land that is held in fee title by an Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1209ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land that is owned by a native corporation formed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5124"},"text":"section 5124 of title 25","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1607"},"text":"section 1607 of title 43","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1209bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a combination of 1 or more types of land described in clauses (i) through (v).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1209bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment of acreage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of acreage owned by an Indian tribe, the Secretary may enroll acreage into the healthy forests reserve program through the use of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1209bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 30-year contract (the value of which shall be equivalent to the value of a 30-year easement);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1209be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 10-year cost-share agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1209bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a permanent easement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1209c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/e/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of the options described in clauses (i) through (iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1209c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment priority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1209c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Species","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall give priority to the enrollment of land that provides the greatest conservation benefit to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1209c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primarily, species listed as endangered or threatened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1533"},"text":"section 1533 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1209c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" secondarily, species that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1209c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not listed as endangered or threatened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1533"},"text":"section 1533 of this title","children":[],"tail":"; but"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1209c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a1209c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/f/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are candidates for such listing, State-listed species, or special concern species; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a1209c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/f/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are deemed a species of greatest conservation need under a State wildlife action plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1209c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-effectiveness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall also consider the cost-effectiveness of each agreement or easement, and associated restoration plans, so as to maximize the environmental benefits per dollar expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1209ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Easement modification or termination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1209cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may modify or terminate an easement or other interest in land administered by the Secretary under this title if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1209cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner of the land agrees to the modification or termination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1209cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary determines that the modification or termination—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1209ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/g/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will address a compelling public need for which there is no practicable alternative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1209cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/g/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1209d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration; conditions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1209d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As consideration for termination of an easement or other interest in land under this subsection, the Secretary shall enter into a compensatory arrangement, as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1209d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a modification of an easement or other interest in land under this subsection—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1209d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a condition of the modification, the owner of the land shall enter into a compensatory arrangement, as the Secretary determines to be appropriate, to incur the costs of modification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1209d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary shall ensure that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a1209d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/g/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modification will not adversely affect the forest ecosystem functions and values for which the easement or other interest in land was acquired;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a1209d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/g/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any adverse impacts will be mitigated by enrollment and restoration of other land that provides greater forest ecosystem functions and values at no additional cost to the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a1209d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6572/g/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modification will result in equal or greater environmental and economic values to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1209d8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tV/s502"},"text":"Pub. L. 108–148, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1911"},"text":"117 Stat. 1911","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVIII/s8205/a"},"text":"Pub. L. 110–234, title VIII, § 8205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1294"},"text":"122 Stat. 1294","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VIII, § 8205(a), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2056; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVIII/s8203/a"},"text":"Pub. L. 113–79, title VIII, § 8203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/914"},"text":"128 Stat. 914","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8407/a/2"},"text":"Pub. L. 115–334, title VIII, § 8407(a)(2)","children":[],"tail":"–(6), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4845"},"text":"132 Stat. 4845","children":[],"tail":", 4846; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dHH/tIII/s401"},"text":"Pub. L. 117–328, div. HH, title III, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5984"},"text":"136 Stat. 5984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1209d9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1209da-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a1209db-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a1209dc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8407/a/2"},"text":"Pub. L. 115–334, § 8407(a)(2)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, text read as follows: “To be eligible for enrollment in the healthy forests reserve program, land shall be—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) private land the enrollment of which will restore, enhance, or otherwise measurably increase the likelihood of recovery of a species listed as endangered or threatened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1533"},"text":"section 1533 of this title","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) private land the enrollment of which will restore, enhance, or otherwise measurably improve the well-being of species that—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) are not listed as endangered or threatened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1533"},"text":"section 1533 of this title","children":[],"tail":"; but"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) are candidates for such listing, State-listed species, or special concern species.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8407/a/3"},"text":"Pub. L. 115–334, § 8407(a)(3)","children":[],"tail":", added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8407/a/4"},"text":"Pub. L. 115–334, § 8407(a)(4)","children":[],"tail":", redesignated par. (3) as (2) and struck out former par. (2) which related to limitation on use of cost-share agreements and easements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(B)(ii) to (iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8407/a/5"},"text":"Pub. L. 115–334, § 8407(a)(5)","children":[],"tail":", added cls. (ii) to (iv) and struck out former cls. (ii) and (iii) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) a 10-year cost-share agreement; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) any combination of the options described in clauses (i) and (ii).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8407/a/4"},"text":"Pub. L. 115–334, § 8407(a)(4)","children":[],"tail":", redesignated par. (3) as (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8407/a/6"},"text":"Pub. L. 115–334, § 8407(a)(6)","children":[],"tail":", added cl. (ii) and struck out former cl. (ii) which read as follows: “are candidates for such listing, State-listed species, or special concern species.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s8203/a/2"},"text":"Pub. L. 113–79, § 8203(a)(2)","children":[],"tail":", (3), added subpar. (A), designated existing provisions as subpar. (B) and inserted heading, and redesignated former subpars. (A) to (C) as cls. (i) to (iii), respectively, of subpar. (B) and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s8203/a/1"},"text":"Pub. L. 113–79, § 8203(a)(1)","children":[],"tail":", substituted “clauses (i) and (ii)” for “subparagraphs (A) and (B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsecs. (e) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s8205/a"},"text":"Pub. L. 110–246, § 8205(a)","children":[],"tail":", added subsec. (e), redesignated subsec. (g) as (f), and struck out former subsecs. (e) and (f) which related to maximum number of enrolled acres and methods of enrollment."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a1209dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7a1209de-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
