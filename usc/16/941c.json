{"tag":"section","attrib":{"id":"id78d4f5b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c"},"text":null,"children":[{"tag":"num","attrib":{"value":"941c"},"text":"§ 941c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification, review, and implementation of proposals and regional projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78d4f5b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b)(2), the Director—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78d4f5b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall encourage the development and, subject to the availability of appropriations, the implementation of fish and wildlife restoration proposals and regional projects based on the results of the Report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d4f5b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with the State Directors and Indian Tribes, shall identify, develop, and, subject to the availability of appropriations, implement regional projects in the Great Lakes Basin to be administered by Director in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d4f5b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of proposals and regional projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78d4f5b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request by the Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall annually request that State Directors and Indian Tribes, in cooperation or partnership with other interested entities and in accordance with subsection (a), submit proposals or regional projects for the restoration of fish and wildlife resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d4f5ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for proposals and regional projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A proposal or regional project under paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78d4f5bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitted in the manner and form prescribed by the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78d4f5bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consistent with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78d4f5bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the goals of the Great Lakes Water Quality Agreement, as amended;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78d4f5be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 1954 Great Lakes Fisheries Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78d4f5bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 1980 Joint Strategic Plan for Management of Great Lakes Fisheries, as revised in 1997, and Fish Community Objectives for each Great Lake and connecting water as established under the Joint Strategic Plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78d4f5c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Nonindigenous Aquatic Nuisance Prevention and Control Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4701"},"text":"16 U.S.C. 4701","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78d4f5c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the North American Waterfowl Management Plan and joint ventures established under the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78d4f5c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/b/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strategies outlined through the Great Lakes Regional Collaboration authorized under Executive Order 13340 (69 Fed. Reg. 29043; relating to the Great Lakes Interagency Task Force);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78d4f5c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/b/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strategic action plan of the Great Lakes Restoration Initiative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78d4f5c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/b/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each applicable State wildlife action plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d4f5c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sea lamprey authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Great Lakes Fishery Commission shall retain authority and responsibility to formulate and implement a comprehensive program to eradicate or minimize sea lamprey populations in the Great Lakes Basin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d4f5c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of proposals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78d4f5c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Great Lakes Fish and Wildlife Restoration Proposal Review Committee, which shall operate under the guidance of the United States Fish and Wildlife Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d4f5c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership and appointment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78d4f5c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall consist of 2 representatives of each of the State Directors and Indian Tribes, of whom—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78d4f5ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative shall be the individual appointed by the State Director or Indian Tribe to the Council of Lake Committees of the Great Lakes Fishery Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78d4f5cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative shall have expertise in wildlife management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78d4f5cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each representative shall serve at the pleasure of the appointing State Director or Tribal Chair.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78d4f5cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Observer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Fish and Wildlife Service shall participate as an observer of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78d4f5ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recusal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Committee shall recuse himself or herself from consideration of proposals that the member, or the entity that the member represents, has submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d4f5cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78d4f5d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet at least annually;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78d4f5d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review proposals and regional projects developed in accordance with subsection (b) to assess the effectiveness and appropriateness of the proposals and regional projects in fulfilling the purposes of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78d4f5d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend to the Director any of those proposals and regional projects that should be funded and implemented under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d4f5d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of proposals and regional projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78d4f5d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After considering recommendations of the Committee and the goals specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s941d"},"text":"section 941d of this title","children":[],"tail":", the Director shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78d4f5d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select proposals and regional projects to be implemented; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78d4f5d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the availability of appropriations and subsection (e), fund implementation of the proposals and regional projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d4f5d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting and funding proposals and regional projects, the Director shall take into account the effectiveness and appropriateness of the proposals and regional projects in fulfilling the purposes of other laws applicable to restoration of the fish and wildlife resources and habitat of the Great Lakes Basin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d4f5d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78d4f5d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78d4f5da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraphs (3) and (5) and subject to paragraph (2), not less than 25 percent of the cost of implementing a proposal or regional project selected under subsection (d) (excluding the cost of establishing sea lamprey barriers) shall be paid in cash or in-kind contributions by non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78d4f5db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time period for providing match","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the cost of implementing a proposal or regional project required under subparagraph (A) may be provided at any time during the 2-year period preceding January 1 of the year in which the Director receives the application for the proposal or regional project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d4f5dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized sources of non-Federal share","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78d4f5dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may determine the non-Federal share under paragraph (1) by taking into account—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78d4f5de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appraised value of land or a conservation easement as described in subparagraph (B); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78d4f5df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as described in subparagraph (C), the costs associated with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78d4f5e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securing a conservation easement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78d4f5e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restoration or enhancement of the conservation easement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78d4f5e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appraisal of conservation easement","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78d4f5e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The value of a conservation easement may be used to satisfy the non-Federal share of the cost of implementing a proposal or regional project required under paragraph (1)(A) if the Director determines that the conservation easement—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78d4f5e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements of subsection (b)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78d4f5e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is acquired before the end of the grant period of the proposal or regional project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78d4f5e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is held in perpetuity for the conservation purposes of the programs of the United States Fish and Wildlife Service related to the Great Lakes Basin, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s941d"},"text":"section 941d of this title","children":[],"tail":", by an accredited land trust or conservancy or a Federal, State, or tribal agency;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78d4f5e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is connected either physically or through a conservation planning process to the proposal or regional project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78d4f5e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/B/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is appraised in accordance with clause (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78d4f5e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appraisal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the appraisal of a conservation easement described in clause (i)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78d4f5ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appraisal valuation date shall be not later than 1 year after the price of the conservation easement was set under a contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78d4f5eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the appraisal shall—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id78d4f5ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/B/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conform to the Uniform Standards of Professional Appraisal Practice (USPAP); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id78d4f5ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/B/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be completed by a Federal- or State-certified appraiser.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78d4f5ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs of securing conservation easements","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78d4f5ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All costs associated with securing a conservation easement and restoration or enhancement of that conservation easement may be used to satisfy the non-Federal share of the cost of implementing a proposal or regional project required under paragraph (1)(A) if the activities and expenses associated with securing the conservation easement and restoration or enhancement of that conservation easement meet the requirements of subparagraph (B)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78d4f5f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The costs referred to in clause (i) may include cash, in-kind contributions, and indirect costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78d4f5f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The costs referred to in clause (i) may not be costs associated with mitigation or litigation (other than costs associated with the Natural Resource Damage Assessment program).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d4f5f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Regional projects selected under subsection (d) shall be exempt from cost sharing if the Director determines that the authorization for the project does not require a non-Federal cost-share.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d73fe3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of Federal funds from non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may not consider the expenditure, directly or indirectly, of Federal funds received by any entity to be a contribution by a non-Federal source for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d73fe4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941c/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on certain Indian tribes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection affects an Indian tribe affected by an alternative applicable cost sharing requirement under the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.)."},{"tag":"ref","attrib":{"idref":"fn002561"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002561"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78d73fe5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/537/tI/s1005"},"text":"Pub. L. 101–537, title I, § 1005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-08"},"text":"Nov. 8, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2372"},"text":"104 Stat. 2372","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/tII/s2005"},"text":"Pub. L. 101–646, title II, § 2005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4775"},"text":"104 Stat. 4775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/h/1"},"text":"Pub. L. 104–332, § 2(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4091"},"text":"110 Stat. 4091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/265"},"text":"Pub. L. 105–265","children":[],"tail":", §§ 3(b), 6, "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2358"},"text":"112 Stat. 2358","children":[],"tail":", 2359; "},{"tag":"ref","attrib":{"href":"/us/pl/109/326/s4"},"text":"Pub. L. 109–326, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-11"},"text":"Oct. 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1762"},"text":"120 Stat. 1762","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tIII/s3901/c"},"text":"Pub. L. 114–322, title III, § 3901(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1848"},"text":"130 Stat. 1848","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78d73fe6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78d73fe7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78d73fe8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Nonindigenous Aquatic Nuisance Prevention and Control Act of 1990, referred to in subsec. (b)(2)(B)(iv), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646"},"text":"Pub. L. 101–646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4761"},"text":"104 Stat. 4761","children":[],"tail":", which is classified principally to chapter 67 (§ 4701 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4701"},"text":"section 4701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Executive Order 13340, referred to in subsec. (b)(2)(B)(vi), is Ex. Ord. No. 13340, ","children":[{"tag":"date","attrib":{"date":"2004-05-18"},"text":"May 18, 2004","children":[],"tail":", 69 F.R. 29043, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1268"},"text":"section 1268 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in subsec. (e)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which was classified principally to subchapter II (§ 450 et seq.) of chapter 14 of Title 25, Indians, prior to editorial reclassification as chapter 46 (§ 5301 et seq.) of Title 25. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78d73fe9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/537"},"text":"Pub. L. 101–537","children":[],"tail":" and title II of "},{"tag":"ref","attrib":{"href":"/us/pl/101/646"},"text":"Pub. L. 101–646","children":[],"tail":" enacted substantially identical sections. Title II of "},{"tag":"ref","attrib":{"href":"/us/pl/101/646"},"text":"Pub. L. 101–646","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/265/s3/b"},"text":"Pub. L. 105–265, § 3(b)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78d73fea-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(2)(B)(vii), (viii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s3901/c/1"},"text":"Pub. L. 114–322, § 3901(c)(1)","children":[],"tail":", added cls. (vii) and (viii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s3901/c/2"},"text":"Pub. L. 114–322, § 3901(c)(2)","children":[],"tail":", struck out “Great Lakes Coordinator of the” before “United States Fish and Wildlife Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s3901/c/3/A"},"text":"Pub. L. 114–322, § 3901(c)(3)(A)","children":[],"tail":", designated exisiting provisions as subpar. (A) and inserted heading, substituted “Except as provided in paragraphs (3) and (5) and subject to paragraph (2), not less than 25 percent of the cost of implementing a proposal or regional project” for “Except as provided in paragraphs (2) and (4), not less than 25 percent of the cost of implementing a proposal”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s3901/c/3/B"},"text":"Pub. L. 114–322, § 3901(c)(3)(B)","children":[],"tail":", (C), added par. (2) and redesignated former pars. (2) to (4) as (3) to (5), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/326"},"text":"Pub. L. 109–326","children":[],"tail":" amended section generally. Prior to amendment, section related to identification, review, and implementation of proposals."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/265"},"text":"Pub. L. 105–265","children":[],"tail":" amended section generally, substituting present provisions for provisions requiring a Great Lakes fishery resources restoration study and development of proposals for implementing recommendations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332"},"text":"Pub. L. 104–332","children":[],"tail":" made technical amendment to "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/s2005"},"text":"Pub. L. 101–646, § 2005","children":[],"tail":", which enacted this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
