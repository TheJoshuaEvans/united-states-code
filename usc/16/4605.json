{"tag":"section","attrib":{"id":"id79f09f1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4605"},"text":null,"children":[{"tag":"num","attrib":{"value":"4605"},"text":"§ 4605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to execute contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to enter into contracts and cooperative agreements and generally to do any and all lawful acts necessary or appropriate to further the purposes of the TPIA Program.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79f09f1f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/628/tXI/s1106"},"text":"Pub. L. 101–628, title XI, § 1106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4503"},"text":"104 Stat. 4503","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
