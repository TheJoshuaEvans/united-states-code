{"tag":"section","attrib":{"id":"id77767780-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410nnn"},"text":null,"children":[{"tag":"num","attrib":{"value":"410nnn"},"text":"§ 410nnn.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77767781-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410nnn/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The study conducted by the National Park Service under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/s506/b"},"text":"section 506(b) of Public Law 95–625","children":[],"tail":" has resulted in a precise identification of the location of the Battle of Palo Alto and the area requiring protection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77767782-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410nnn/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Palo Alto is the only unit of the National Park System directed to the preservation and interpretation of resources related to the Mexican-American War.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77767783-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/304/s2"},"text":"Pub. L. 102–304, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-06-23"},"text":"June 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/256"},"text":"106 Stat. 256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77767784-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77767785-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77767786-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/s506/b"},"text":"Section 506(b) of Pub. L. 95–625","children":[],"tail":", referred to in par. (1), is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410nnn–1"},"text":"section 410nnn–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77767787-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This subchapter is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/304"},"text":"Pub. L. 102–304","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/102/304"},"text":"Pub. L. 102–304","children":[],"tail":" is also listed in a table of National Historic Sites set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320101"},"text":"section 320101 of Title 54","children":[],"tail":", National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77767788-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id77767789-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/304/s1"},"text":"Pub. L. 102–304, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-06-23"},"text":"June 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/256"},"text":"106 Stat. 256","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7113/a/3/A"},"text":"Pub. L. 111–11, title VII, § 7113(a)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1201"},"text":"123 Stat. 1201","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/11/tVII/s7113/a/3/A"},"text":"“This Act [enacting this subchapter] may be cited as the ‘Palo Alto Battlefield National Historical Park Act of 1991’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7776778a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Designation of Palo Alto Battlefield National Historical Park","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7113/a/1"},"text":"Pub. L. 111–11, title VII, § 7113(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1201"},"text":"123 Stat. 1201","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/11/tVII/s7113/a/1"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Palo Alto Battlefield National Historic Site shall be known and designated as the ‘Palo Alto Battlefield National Historical Park’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reference in a law, map, regulation, document, paper, or other record of the United States to the historic site referred to in subsection (a) shall be deemed to be a reference to the Palo Alto Battlefield National Historical Park.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
