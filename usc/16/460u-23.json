{"tag":"section","attrib":{"id":"id77cea947-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–23"},"text":null,"children":[{"tag":"num","attrib":{"value":"460u–23"},"text":"§ 460u–23.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of interest in area VII–A","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77cea948-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–23/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public access requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire only such interest in that portion of area VII–A which is described in subsection (b) as the Secretary determines is necessary to assure public access over said portion of area VII–A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77cea949-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–23/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portion of area VII–A subject to acquisition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The portion of area VII–A, as designated on the map referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460u"},"text":"section 460u of this title","children":[],"tail":", to which subsection (a) applies is a parcel of land bounded—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id77cea94a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–23/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the east by a line three hundred feet east of the electrical transmission line crossing area VII–A on ","children":[{"tag":"date","attrib":{"date":"1979-01-01"},"text":"January 1, 1979","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cea94b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–23/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the west by a line fifty feet west of such electrical transmission line; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cea94c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–23/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the north and south by the northern and southern boundaries, respectively, of area VII–A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77cea94d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–23/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundaries of area VII–A","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Area VII–A includes the bed of the railroad tracks forming the northern and northwestern boundaries of this area and extends to the northern edge of the bed of the railroad tracks forming the southern boundaries of this area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77cea94e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–23/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion in area I–D","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Area I–D includes the bed of the railroad tracks along the northern boundary of this area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77cea94f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–23/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions from area VII–C","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The area designated as area VII–C on the map referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460u"},"text":"section 460u of this title","children":[],"tail":" does not include approximately 1.3 acres of land on which the Linde Air Products plant is situated, nor does it include approximately 1 acre of land on which the Old Union Station building and the adjacent REA building are situated. Except as provided in the foregoing sentence, area VII–C extends to, but does not include, the beds of the railroad tracks forming the northern and southern boundaries of such area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77cea950-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/761/s23"},"text":"Pub. L. 89–761, § 23","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/612/s1/13"},"text":"Pub. L. 96–612, § 1(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3577"},"text":"94 Stat. 3577","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
