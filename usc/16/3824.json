{"tag":"section","attrib":{"id":"id79ca799a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3824"},"text":null,"children":[{"tag":"num","attrib":{"value":"3824"},"text":"§ 3824.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fairness of compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the actions of an unrelated person or public entity, outside the control of, and without the prior approval of, the landowner or tenant result in a change in the characteristics of cropland that would cause the land to be determined to be a wetland, the affected land shall not be considered to be wetland for purposes of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79ca799b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1224"},"text":"Pub. L. 99–198, title XII, § 1224","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIV/s1424"},"text":"Pub. L. 101–624, title XIV, § 1424","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3576"},"text":"104 Stat. 3576","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
