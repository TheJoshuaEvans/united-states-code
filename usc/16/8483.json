{"tag":"section","attrib":{"id":"id7a3aa0b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8483"},"text":null,"children":[{"tag":"num","attrib":{"value":"8483"},"text":"§ 8483.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trail pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3aa0b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8483/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary concerned shall carry out a pilot program to enter into partnerships with eligible entities to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa0b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8483/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measure high-priority trails as part of the assessment required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8482"},"text":"section 8482 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8483/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop accessible trails under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8484"},"text":"section 8484 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8483/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","childr