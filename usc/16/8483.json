:{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The pilot program established under this subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002876"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002876"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “this section”."}],"tail":" shall terminate on the date that is 7 years after "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3aa0be-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tII/s213"},"text":"Pub. L. 118–234, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2882"},"text":"138 Stat. 2882","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
