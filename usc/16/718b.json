{"tag":"section","attrib":{"id":"id7883c88c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b"},"text":null,"children":[{"tag":"num","attrib":{"value":"718b"},"text":"§ 718b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sales; fund disposition; unsold stamps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7883c88d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sales","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7883c88e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The stamps required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s718a"},"text":"section 718a of this title","children":[],"tail":" shall be sold by the Postal Service and may be sold by the Department of the Interior, pursuant to regulations promulgated jointly by the Postal Service and the Secretary, at—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7883c88f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any post office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7883c890-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other establishments, facilities, or locations as the Postal Service or the Secretary (or a designee) may direct or authorize.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7883c891-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funds received from the sale of stamps under this subchapter by the Department of the Interior shall be deposited in the Migratory Bird Conservation Fund in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s718d"},"text":"section 718d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7883c892-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum and maximum values","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), the Postal Service shall collect the full face value of each stamp sold under this section for the applicable hunting year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7883c893-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Validity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No stamp sold under this subchapter shall be valid under any circumstances to authorize the taking of migratory waterfowl except—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7883c894-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in compliance with Federal and State laws (including regulations);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7883c895-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the condition that the individual so taking the waterfowl wrote the signature of the individual in ink across the face of the stamp prior to the taking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7883c896-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the hunting year for which the stamp was issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7883c897-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unused stamps","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7883c898-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of retail dealer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph, the term “retail dealer” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7883c899-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual or entity that is regularly engaged in the business of retailing hunting or fishing equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7883c89a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual or entity duly authorized to act as an agent of a State or political subdivision of a State for the sale of State or county hunting or fishing licenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7883c89b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redemption of unused stamps","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Department of the Interior, pursuant to regulations promulgated by the Secretary, shall provide for the redemption, on or before the 30th day of June of each year, of unused stamps issued for the year under this subchapter that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7883c89c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were sold on consignment to any person authorized by the Secretary to sell stamps on consignment (including retail dealers for resale to customers); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7883c89d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have not been resold by any such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7883c89e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on certain stamp sales","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Postal Service shall not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7883c89f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sell on consignment any stamps issued under this subchapter to any individual, business, or organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7883c8a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" redeem stamps issued under this subchapter that are sold on consignment by the Secretary (or any agent of the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7883c8a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost of stamps","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Postal Service shall collect $10.00 for each stamp sold under the provisions of this section for hunting years 1987 and 1988, $12.50 for hunting years 1989 and 1990, $15.00 for hunting years 1991 through 2013, and $25 for each hunting year thereafter, if the Secretary determines, at any time before February 1 of the calendar year in which such hunting year begins, that all sums in the Migratory Bird Conservation Fund available for obligation and attributable to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id788639a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts appropriated pursuant to this subchapter for the fiscal year ending in the immediately preceding calendar year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id788639a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of stamps under this section during such fiscal year","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"have been obligated for expenditure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id788639a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction in price of stamp","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may reduce the price of each stamp sold under the provisions of this section for a hunting year if the Secretary determines that the increase in the price of the stamp after hunting year 2013 resulted in a reduction in revenues deposited into the fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id788639a5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-03-16/ch71/s2"},"text":"Mar. 16, 1934, ch. 71, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/451"},"text":"48 Stat. 451","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-06-15/ch261"},"text":"June 15, 1935, ch. 261","children":[],"tail":", title I, § 2, "},{"tag":"ref","attrib":{"href":"/us/stat/49/379"},"text":"49 Stat. 379","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-08-12/ch421/s1"},"text":"Aug. 12, 1949, ch. 421, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/599"},"text":"63 Stat. 599","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-30/ch782"},"text":"July 30, 1956, ch. 782","children":[],"tail":", §§ 2, 3(c), formerly § 3(b), "},{"tag":"ref","attrib":{"href":"/us/stat/70/722"},"text":"70 Stat. 722","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/109/266/s10/i/1"},"text":"Pub. L. 109–266, § 10(i)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-03"},"text":"Aug. 3, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/679"},"text":"120 Stat. 679","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/585/s1"},"text":"Pub. L. 85–585, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-01"},"text":"Aug. 1, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/486"},"text":"72 Stat. 486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/214"},"text":"Pub. L. 92–214","children":[],"tail":", §§ 1, 2, "},{"tag":"date","attrib":{"date":"1971-12-22"},"text":"Dec. 22, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/777"},"text":"85 Stat. 777","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/215/s3/b"},"text":"Pub. L. 94–215, § 3(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1976-02-17"},"text":"Feb. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/189"},"text":"90 Stat. 189","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/273/s34"},"text":"Pub. L. 94–273, § 34","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-21"},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/380"},"text":"90 Stat. 380","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/552/s1"},"text":"Pub. L. 95–552, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-30"},"text":"Oct. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2071"},"text":"92 Stat. 2071","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/616/s7/a"},"text":"Pub. L. 95–616, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-08"},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3114"},"text":"92 Stat. 3114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/625/s3"},"text":"Pub. L. 99–625, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-07"},"text":"Nov. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3502"},"text":"100 Stat. 3502","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/645/tII/s202"},"text":"Pub. L. 99–645, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3586"},"text":"100 Stat. 3586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/266/s10/b"},"text":"Pub. L. 109–266, § 10(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2006-08-03"},"text":"Aug. 3, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/674"},"text":"120 Stat. 674","children":[],"tail":", 675; "},{"tag":"ref","attrib":{"href":"/us/pl/113/264/s2/1"},"text":"Pub. L. 113–264, § 2(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2939"},"text":"128 Stat. 2939","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788639a6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788639a7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id788639a8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/264/s2/1"},"text":"Pub. L. 113–264, § 2(1)","children":[],"tail":", substituted “1990, $15.00 for hunting years 1991 through 2013, and $25 for each hunting year thereafter” for “1990, and $15.00 for each hunting year thereafter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/264/s2/2"},"text":"Pub. L. 113–264, § 2(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/266/s10/b"},"text":"Pub. L. 109–266, § 10(b)","children":[],"tail":", inserted section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/266/s10/b"},"text":"Pub. L. 109–266, § 10(b)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which related to issuance and sale of stamps, fund disposition, and unsold stamps."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/266/s10/c/4"},"text":"Pub. L. 109–266, § 10(c)(4)","children":[],"tail":", which directed amendment of par. (2) by striking “For purposes” and all that follows through “of any such year.”, was executed by striking “For purposes of this section, the term ‘hunting year’ means the 12-month period beginning on July 1 of any such year.” at the end of the concluding provisions following par. (2), to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/266/s10/c/1"},"text":"Pub. L. 109–266, § 10(c)(1)","children":[],"tail":"–(3), inserted heading and substituted “Secretary” for “Secretary of the Interior” and “Migratory Bird Conservation Fund” for “migratory bird conservation fund” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/645/s202/1"},"text":"Pub. L. 99–645, § 202(1)","children":[],"tail":", (2), in introductory provisions, substituted “$10.00 for each stamp sold under the provisions of this section for hunting years 1987 and 1988, $12.50 for hunting years 1989 and 1990, and $15.00 for each hunting year thereafter, if” for “$7.50 for each stamp sold under the provisions of this section for any hunting year if”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/625"},"text":"Pub. L. 99–625","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/645/s202/3"},"text":"Pub. L. 99–645, § 202(3)","children":[],"tail":", amended subsec. (b) identically, inserting “available for obligation” before “attributable to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/616"},"text":"Pub. L. 95–616","children":[],"tail":" substituted “June” for “September” in sixth sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/552/s1/1"},"text":"Pub. L. 95–552, § 1(1)","children":[],"tail":", (2), designated existing provisions as subsec. (a), inserted in third sentence introductory text “Except as provided in subsection (b) of this section,” and “for any hunting year” before “there shall be collected”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/552/s1/3"},"text":"Pub. L. 95–552, § 1(3)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/273"},"text":"Pub. L. 94–273","children":[],"tail":" substituted “the year” for “the fiscal year” and “each year” for “each fiscal year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/215"},"text":"Pub. L. 94–215","children":[],"tail":" authorized sale of stamps by the Department of the Interior, substituted provision for prescription of regulations jointly by the Postal Service and the Secretary of the Interior for prior provision for such prescription by the Postal Service and provision for sale of stamps at any establishment, facility, or location as the Postal Service and the Secretary of the Interior shall direct and authorize for prior provision for sale of stamps at such post offices other than first- and second-class post offices as the Postal Service shall direct and inserted provision respecting deposit of funds from sale of stamps by the Department of the Interior in the migratory bird conservation fund; and substituted “September” for “June” in relation to redemption of blocks of stamps, designated existing provisions as cls. (A) and (B), and substituted “consignment to any person, including, but not limited to, “retail dealers” for “consignment to retail dealers” in cl. (A) and “by any such person” for “by such dealers” in cl. (B), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/214"},"text":"Pub. L. 92–214","children":[],"tail":" substituted “Postal Service” for “Post Office Department” and “Postmaster General” and inserted provisions authorizing the collection of up to $5 for each stamp sold to be determined by the Secretary of the Interior after taking into consideration, among other matters, the increased cost of lands needed for the conservation of migratory birds."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/585"},"text":"Pub. L. 85–585","children":[],"tail":" increased cost of stamp from $2 to $3."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-07-30"},"text":"July 30, 1956","children":[],"tail":", § 2, struck out in existing next to last sentence requirement that stamps remaining unsold by the Post Office Department subsequent to becoming void after the 30th day of June next succeeding issuance be destroyed, substituted provisions in existing last sentence relating to redemption of blocks of unused stamps sold on consignment to retail dealers for resale to their customers, for provisions prohibiting the redemption by the Department in cash or kind of stamps sold under this Act, and inserted sentence defining “retail dealers”. For further amendment of next to last sentence of this section, see section 3(c) of act "},{"tag":"date","attrib":{"date":"1956-07-30"},"text":"July 30, 1956","children":[],"tail":", set out below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1956-07-30"},"text":"July 30, 1956","children":[],"tail":", § 3(c), formerly § 3(b), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/109/266/s10/i/1"},"text":"Pub. L. 109–266, § 10(i)(1)","children":[],"tail":", substituted provisions in fourth sentence authorizing use as migratory-bird stamps only during fiscal year for which issued, for provisions requiring stamps to expire and be void after the 30th day of June next succeeding issuance. Amendment of fourth sentence by section 3(c) further amends amendments made to next to last sentence by section 2 of act "},{"tag":"date","attrib":{"date":"1956-07-30"},"text":"July 30, 1956","children":[],"tail":", as set out above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-08-12"},"text":"Aug. 12, 1949","children":[],"tail":", increased cost of stamp from $1 to $2."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1935—Act ","children":[{"tag":"date","attrib":{"date":"1935-06-15"},"text":"June 15, 1935","children":[],"tail":", amended section generally."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id788639a9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id788639aa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/585/s4"},"text":"Pub. L. 85–585, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-01"},"text":"Aug. 1, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/487"},"text":"72 Stat. 487","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/585/s4"},"text":"“The amendment made by the first section of this Act [amending this section] shall become effective on ","children":[{"tag":"date","attrib":{"date":"1959-07-01"},"text":"July 1, 1959","children":[],"tail":". The amendment made by section 2 of this Act [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s718d"},"text":"section 718d of this title","children":[],"tail":"] making available the net proceeds of all moneys received in the migratory bird conservation fund for the location, ascertainment, and acquisition of Waterfowl Production Areas and suitable areas for migratory bird refuges shall become effective on "},{"tag":"date","attrib":{"date":"1960-07-01"},"text":"July 1, 1960","children":[],"tail":". The remaining amendments made by this Act [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s718d"},"text":"section 718d of this title","children":[],"tail":"] shall become effective on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1958-08-01"},"text":"Aug. 1, 1958","children":[],"tail":"]. Any unobligated balance remaining in the migratory bird conservation fund on "},{"tag":"date","attrib":{"date":"1960-06-30"},"text":"June 30, 1960","children":[],"tail":", shall thereafter be available for expenditure only for the purposes specified in the Migratory Bird Hunting Stamp Act [now Migratory Bird Hunting and Conservation Stamp Act] of "},{"tag":"date","attrib":{"date":"1934-03-16"},"text":"March 16, 1934","children":[],"tail":" [this subchapter], as amended by this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id788639ab-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Spending of Stamp Money","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-12/ch421/s1"},"text":"Act Aug. 12, 1949, ch. 421, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/599"},"text":"63 Stat. 599","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1949-08-12/ch421/s1"},"text":"“That the moneys derived from the sale of such stamps shall be spent only upon specific appropriation by the Congress.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
