{"tag":"section","attrib":{"id":"id77385d24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s402"},"text":null,"children":[{"tag":"num","attrib":{"value":"402"},"text":"§ 402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing claims, locations, or entries not affected; exchange of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing herein contained shall affect any valid claim, location, or entry existing under the land laws of the United States prior to ","children":[{"tag":"date","attrib":{"date":"1924-06-07"},"text":"June 7, 1924","children":[],"tail":", whether for homestead, mineral, right-of-way, or any other purpose whatsoever, or shall affect the rights of any such claimant, locator, or entryman to the full use and enjoyment of his land. The Secretary of the Interior is authorized to exchange, in his discretion, alienated lands in Bryce Canyon National Park for unappropriated and unreserved public lands of equal value and approximately equal area in the State of Utah outside of said park."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77385d25-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-06-07/ch305/s3"},"text":"June 7, 1924, ch. 305, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/594"},"text":"43 Stat. 594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1928-02-25/ch102/s1"},"text":"Feb. 25, 1928, ch. 102, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/147"},"text":"45 Stat. 147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77385d26-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77385d27-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77385d28-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Herein, referred to in text, means act ","children":[{"tag":"date","attrib":{"date":"1924-06-07"},"text":"June 7, 1924","children":[],"tail":", which is classified to sections 346, 401 and 402 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The land laws of the United States, referred to in text, are classified generally to Title 43, Public Lands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77385d29-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The last sentence of this section as originally enacted is expressly applicable also to Zion National Park. See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s346"},"text":"section 346 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77385d2a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77385d2b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Utah National Park” changed to “Bryce Canyon National Park” by section 1 of act ","children":[{"tag":"date","attrib":{"date":"1928-02-25"},"text":"Feb. 25, 1928","children":[],"tail":", classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s402a"},"text":"section 402a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
