{"tag":"section","attrib":{"id":"id77c77cfc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460q–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"460q–6"},"text":"§ 460q–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall deprive any State or political subdivision thereof of its right to exercise civil and criminal jurisdiction within the recreation area or of its right to tax persons, corporations, franchises, or property, including mineral or other interests, in or on lands or waters within the recreation area.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77c77cfd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/336/s7"},"text":"Pub. L. 89–336, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1299"},"text":"79 Stat. 1299","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
