{"tag":"section","attrib":{"id":"id787cc471-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"698u–4"},"text":"§ 698u–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited authority to acquire","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id787cc472-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall acquire, by donation, not more than 180 acres of real property within the boundaries of the Preserve (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s698u–2/b"},"text":"section 698u–2(b) of this title","children":[],"tail":") and the improvements on the real property."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787cc473-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments in lieu of taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of payments made under chapter 69 of title 31, the real property described in subsection (a) shall be deemed to have been acquired for the purposes specified in section 6904(a) of that title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787cc474-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No property may be acquired under this section without the consent of the owner of the property. The United States may not acquire fee ownership of any lands within the Preserve other than lands described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id787cc475-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/333/dI/tX/s1006"},"text":"Pub. L. 104–333, div. I, title X, § 1006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-11-12"},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4208"},"text":"110 Stat. 4208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/352/s17"},"text":"Pub. L. 108–352, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-21"},"text":"Oct. 21, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1398"},"text":"118 Stat. 1398","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787cc476-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id787cc477-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id787cc478-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/352"},"text":"Pub. L. 108–352","children":[],"tail":" substituted “subsection (a)” for “subsection (a)(1)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
