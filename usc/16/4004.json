{"tag":"section","attrib":{"id":"id79e72904-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004"},"text":null,"children":[{"tag":"num","attrib":{"value":"4004"},"text":"§ 4004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of National Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e72905-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the National Fish and Seafood Promotional Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e72906-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e72907-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Council shall be composed of the Secretary, who shall be a nonvoting member, and fifteen voting members appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e72908-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nominations for appointees shall be submitted in a manner prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e72909-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional representation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Council shall be comprised of regional representation from the Northeast, Southeast, Pacific, and Alaska regions. The Northeast region shall consist of the States of Maine, New Hampshire, Massachusetts, Rhode Island, Connecticut, New York, New Jersey, Delaware, Pennsylvania, Maryland and Virginia. The Southeast region shall consist of the States of North Carolina, South Carolina, Georgia, Florida, Alabama, Mississippi, Louisiana and Texas, the Commonwealth of Puerto Rico, and the territory of the Virgin Islands. The Pacific region shall consist of the States of Idaho, Washington, Oregon, California, and Hawaii, the territories of Guam and American Samoa, and the Commonwealth of the Northern Mariana Islands. The Alaska region shall consist of the State of Alaska.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e7290a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting members","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e7290b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The voting members of the National Council shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e7290c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three members who reside in or do substantial fishing industry business in the Northeast region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e7290d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three members who reside in or do substantial fishing industry business in the Southeast region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e7290e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three members who reside in or do substantial fishing industry business in the Pacific region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e7290f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three members who reside in or do substantial fishing industry business in the Alaska region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e72910-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members-at-large with demonstrated expertise in fresh-water and inland commercial fisheries, at least one of whom is not a resident of the States of the Alaska, Pacific, Southeast, and Northeast regions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e72911-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member-at-large who is either a person professionally engaged in the dissemination of information pertaining to the nutritional benefits and preparation of fish and fish products or a person who is a member of an organized labor union and has expertise in the United States fisheries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e72912-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the members appointed pursuant to each of paragraphs (1)(A) through (D) of this subsection, one shall be a harvester, one shall be a processor or a receiver, and one shall be a marketer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e72913-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the National Council shall be appointed for a term of 4 years. A vacancy in the National Council shall not affect its ability to function. The Secretary shall appoint a new member within sixty days to fill a vacancy in an unexpired term. Any member may remain on the National Council beyond that member’s term until a successor is appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e72914-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Council shall annually elect a Chairman by a majority of those voting, if a quorum is present. Ten members of the National Council shall constitute a quorum, but a lesser number may hold hearings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e72915-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Council shall first meet within one hundred and eighty days after ","children":[{"tag":"date","attrib":{"date":"1986-11-14"},"text":"November 14, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e72916-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4004/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the National Council shall serve without compensation, but shall be reimbursed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":" for reasonable travel costs and expenses incurred in performing their duties as members of the National Council."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e72917-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659/tII/s205"},"text":"Pub. L. 99–659, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3717"},"text":"100 Stat. 3717","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/350/s3"},"text":"Pub. L. 100–350, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/660"},"text":"102 Stat. 660","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e72918-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e72919-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79e7291a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (d)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/350"},"text":"Pub. L. 100–350","children":[],"tail":" which directed the substitution of “, at least one of whom is not a resident of the States of the Alaska, Pacific, Southeast, and Northeast regions” for “and who are not residents of the States of the Alaska, Pacific, Southeast, or Northeast regions” was executed by substituting that phrase for “and who are not residents of the states of the Alaska, Pacific, Southeast, or Northeast regions”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79e7291b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79e7291c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continuity of National Council Membership","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/627/tVII/s704/a"},"text":"Pub. L. 101–627, title VII, § 704(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4464"},"text":"104 Stat. 4464","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/627/tVII/s704/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Uninterrupted Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Individuals serving on ","children":[{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":", as members of the National Fish and Seafood Promotional Council shall be deemed to continue as members in uninterrupted service since the date of their initial appointment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filling of Vacancies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 206(e) of the Fish and Seafood Promotion Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4005/e"},"text":"16 U.S.C. 4005(e)","children":[],"tail":"), any vacancy on the National Fish and Seafood Promotion Act [Promotional Council] not filled as of "},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":", shall be filled within 60 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
