{"tag":"section","attrib":{"id":"id7784a8cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhhh–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"410hhhh–4"},"text":"§ 410hhhh–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"1987-12-23"},"text":"December 23, 1987","children":[],"tail":", the Secretary shall develop and submit to the Congress a general management plan for the use and development of the historical park and the preservation district. Such plan shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7784a8cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhhh–4/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be prepared in accordance with section ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":", and shall be consistent with the purposes of this subchapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7784a8cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhhh–4/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include consideration of the economic feasibility and interpretive necessity of providing a transportation system for visitor use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7784a8ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhhh–4/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the preservation and interpretation of Plains High School (referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410hhhh/b/2/E"},"text":"section 410hhhh(b)(2)(E) of this title","children":[],"tail":") including appropriate use by the town of Plains."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Following a determination of the appropriate uses of the Plains High School for the town of Plains, the Secretary may enter into a cooperative agreement with the town concerning its use of the high school.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7784a8cf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/206/s5"},"text":"Pub. L. 100–206, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-23"},"text":"Dec. 23, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1436"},"text":"101 Stat. 1436","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/341/s2/b/4"},"text":"Pub. L. 116–341, § 2(b)(4)","children":[],"tail":", (5), "},{"tag":"date","attrib":{"date":"2021-01-13"},"text":"Jan. 13, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5132"},"text":"134 Stat. 5132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7784a8d0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7784a8d1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7784a8d2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In par. (1), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":"” substituted for “section 12(b) of the Act entitled “An Act to improve the administration of the national park system by the Secretary, and to clarify the authorities applicable to the system, and for other purposes”, approved "},{"tag":"date","attrib":{"date":"1970-08-18"},"text":"August 18, 1970","children":[],"tail":" (16 U.S.C. la–1 et seq.)” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/e"},"text":"Pub. L. 113–287, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3272"},"text":"128 Stat. 3272","children":[],"tail":", which Act enacted Title 54, National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7784a8d3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/341/s2/b/4"},"text":"Pub. L. 116–341, § 2(b)(4)","children":[],"tail":", (5), made identical amendments, substituting “historical park” for “historic site” in introductory provisions. See Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410hhhh"},"text":"section 410hhhh of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
