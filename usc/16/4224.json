{"tag":"section","attrib":{"id":"id79ebe3cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4224"},"text":null,"children":[{"tag":"num","attrib":{"value":"4224"},"text":"§ 4224.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties and enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ebe3cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4224/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever knowingly violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4223"},"text":"section 4223 of this title","children":[],"tail":" shall, upon conviction, be fined under title 18 or imprisoned for not more than one year, or both."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ebe3cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4224/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4223"},"text":"section 4223 of this title","children":[],"tail":" may be assessed a civil penalty by the Secretary of not more than $5,000 for each such violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ebe3ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4224/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for assessment of civil penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Proceedings for the assessment of a civil penalty under this section shall be conducted in accordance with the procedures provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1540/a"},"text":"section 1540(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ebe3cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4224/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to appropriations, penalties collected under this section may be used by the Secretary of the Treasury to pay rewards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4225"},"text":"section 4225 of this title","children":[],"tail":" and, to the extent not used to pay such rewards, shall be deposited by the Secretary of the Treasury into the Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ebe3d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4224/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, the Secretary of the Treasury, and the Secretary of the department in which the Coast Guard is operating shall enforce this subchapter in the same manner such Secretaries carry out enforcement activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1540/e"},"text":"section 1540(e) of this title","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1540/c"},"text":"Section 1540(c) of this title","children":[],"tail":" shall apply to actions arising under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ebe3d1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/478/tII/s2204"},"text":"Pub. L. 100–478, title II, § 2204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-07"},"text":"Oct. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2320"},"text":"102 Stat. 2320","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79ebe3d2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79ebe3d3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id79ebe3d4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
