{"tag":"section","attrib":{"id":"id79e72940-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4007"},"text":null,"children":[{"tag":"num","attrib":{"value":"4007"},"text":"§ 4007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person may make voluntary payments to assist the National Council to carry out its annual marketing and promotion plan and annual budget. The Secretary shall deposit such payments into the Fund.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79e72941-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659/tII/s208"},"text":"Pub. L. 99–659, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3720"},"text":"100 Stat. 3720","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
