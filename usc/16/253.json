{"tag":"section","attrib":{"id":"id77208ef3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s253"},"text":null,"children":[{"tag":"num","attrib":{"value":"253"},"text":"§ 253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apportionment of income among counties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The income of each county receiving moneys from the Olympic National Forest, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s500"},"text":"section 500 of this title","children":[],"tail":", shall be proportional to the total area of each county in the Olympic National Forest and the Olympic National Park combined."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77208ef4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-29/ch812/s3"},"text":"June 29, 1938, ch. 812, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1242"},"text":"52 Stat. 1242","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
