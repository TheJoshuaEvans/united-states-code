{"tag":"section","attrib":{"id":"id7a0add2d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407"},"text":null,"children":[{"tag":"num","attrib":{"value":"6407"},"text":"§ 6407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coral Reef Stewardship Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0add2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall seek to enter into an agreement with the National Fish and Wildlife Foundation (in this section referred to as the “Foundation”), authorizing the Foundation to receive, hold, and administer funds received under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0add2f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0add30-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation shall establish an account, which shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0add31-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be known as the “Coral Reef Stewardship Fund” (in this section referred to as the “Fund”); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0add32-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the successor to the account known before ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", as the Coral Reef Conservation Fund and administered through a public-private partnership with the Foundation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0add33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall deposit funds received under this section into the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0add34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Fund shall be available solely to support coral reef stewardship activities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0add35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further the purposes of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0add36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are consistent with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a0add37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Coral Reef Resilience Strategy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0add38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coral reef action plans in effect, if any, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6404"},"text":"section 6404 of this title","children":[],"tail":" covering a coral reef or ecologically significant component of a coral reef to be impacted by such activities, if applicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0add39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of amounts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0add3a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall invest such portion of the Fund as is not required to meet current withdrawals in interest-bearing obligations of the United States or in obligations guaranteed as to both principal and interest by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0add3b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest and proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest on, and the proceeds from the sale or redemption of, any obligations held in the Fund shall be credited to and form a part of the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0add3c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of performance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall conduct a continuing review of all deposits into, and disbursements from, the Fund. Each review shall include a written assessment concerning the extent to which the Foundation has implemented the goals and requirements of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0add3d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0add3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Coral Reef Resilience Strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0add3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization to solicit donations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0add40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to an agreement entered into under subsection (a), the Foundation may accept, receive, solicit, hold, administer, and use any gift (including, notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", donations of services) to further the purposes of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0add41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits in Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", any funds received as a gift shall be deposited and maintained in the Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0add42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6407/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under an agreement entered into pursuant to subsection (a), and subject to the availability of appropriations, the Administrator may transfer funds appropriated for such purposes to carry out this chapter to the Foundation. Amounts received by the Foundation under this subsection may be used for matching, in whole or in part, contributions (whether in money, services, or property) made to the Foundation by private persons, State or local government agencies, or covered Native entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0add43-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s208"},"text":"Pub. L. 106–562, title II, § 208","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/a"},"text":"Pub. L. 117–263, div. J, title C, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3939"},"text":"136 Stat. 3939","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0add44-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0add45-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a0add46-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6407, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s208"},"text":"Pub. L. 106–562, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2804"},"text":"114 Stat. 2804","children":[],"tail":", required submission of reports documenting the effectiveness of the coral reef conservation grant program and describing activities undertaken to implement the national coral reef strategy, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/a"},"text":"Pub. L. 117–263, div. J, title C, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3931"},"text":"136 Stat. 3931","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
