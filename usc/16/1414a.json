{"tag":"section","attrib":{"id":"id792ab71c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1414a"},"text":"§ 1414a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792ab71d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792ab71e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in consultation with the Marine Mammal Commission and the Inter-American Tropical Tuna Commission, conduct a study of the effect of intentional encirclement (including chase) on dolphins and dolphin stocks incidentally taken in the course of purse seine fishing for yellowfin tuna in the eastern tropical Pacific Ocean. The study, which shall commence on ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"October 1, 1997","children":[],"tail":", shall consist of abundance surveys as described in paragraph (2) and stress studies as described in paragraph (3), and shall address the question of whether such encirclement is having a significant adverse impact on any depleted dolphin stock in the eastern tropical Pacific Ocean."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab71f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population abundance surveys","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The abundance surveys under this subsection shall survey the abundance of such depleted stocks and shall be conducted during each of the calendar years 1998, 1999, and 2000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab720-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stress studies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The stress studies under this subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792ab721-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of relevant stress-related research and a 3-year series of necropsy samples from dolphins obtained by commercial vessels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792ab722-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 1-year review of relevant historical demographic and biological data related to dolphins and dolphin stocks referred to in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792ab723-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an experiment involving the repeated chasing and capturing of dolphins by means of intentional encirclement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab724-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No later than 90 days after publishing the finding under subsection (g)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1385"},"text":"section 1385 of this title","children":[],"tail":", the Secretary shall complete and submit a report containing the results of the research described in this subsection to the United States Senate Committee on Commerce, Science, and Transportation and the United States House of Representatives Committees on Resources and on Commerce, and to the Inter-American Tropical Tuna Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792ab725-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792ab726-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to conducting the research described in subsection (a), the Secretary shall, in consultation with the Marine Mammal Commission and in cooperation with the nations participating in the International Dolphin Conservation Program and the Inter-American Tropical Tuna Commission, undertake or support appropriate scientific research to further the goals of the International Dolphin Conservation Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab727-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific areas of research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Research carried out under paragraph (1) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792ab728-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects to devise cost-effective fishing methods and gear so as to reduce, with the goal of eliminating, the incidental mortality and serious injury of marine mammals in connection with commercial purse seine fishing in the eastern tropical Pacific Ocean;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792ab729-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects to develop cost-effective methods of fishing for mature yellowfin tuna without setting nets on dolphins or other marine mammals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792ab72a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects to carry out stock assessments for those marine mammal species and marine mammal stocks taken in the purse seine fishery for yellowfin tuna in the eastern tropical Pacific Ocean, including species or stocks not within waters under the jurisdiction of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792ab72b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects to determine the extent to which the incidental take of nontarget species, including juvenile tuna, occurs in the course of purse seine fishing for yellowfin tuna in the eastern tropical Pacific Ocean, the geographic location of the incidental take, and the impact of that incidental take on tuna stocks and nontarget species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792ab72c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792ab72d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There are authorized to be appropriated to the Secretary the following amounts, to be used by the Secretary to carry out the research described in subsection (a):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792ab72e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,000,000 for fiscal year 1998.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792ab72f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000,000 for fiscal year 1999.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792ab730-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,000,000 for fiscal year 2000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792ab731-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 for fiscal year 2001.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab732-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1414a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the amount authorized to be appropriated under paragraph (1), there are authorized to be appropriated to the Secretary for carrying out this section $3,000,000 for each of the fiscal years 1998, 1999, 2000, and 2001.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792ab733-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tIII/s304"},"text":"Pub. L. 92–522, title III, § 304","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/42/s6/c"},"text":"Pub. L. 105–42, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-15"},"text":"Aug. 15, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1133"},"text":"111 Stat. 1133","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792ab734-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792ab735-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id792ab736-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/s304"},"text":"section 304 of Pub. L. 92–522","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1414"},"text":"section 1414 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/42"},"text":"Pub. L. 105–42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id792ab737-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id792ab738-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Commerce of House of Representatives changed to Committee on Energy and Commerce of House of Representatives, and jurisdiction over matters relating to securities and exchanges and insurance generally transferred to Committee on Financial Services of House of Representatives by House Resolution No. 5, One Hundred Seventh Congress, ","children":[{"tag":"date","attrib":{"date":"2001-01-03"},"text":"Jan. 3, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
