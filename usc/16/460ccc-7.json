{"tag":"section","attrib":{"id":"id77f4ce6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ccc–7"},"text":"§ 460ccc–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinated management","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate the management of the conservation area with that of surrounding State and Federal lands in such a manner as best to meet the present and future needs of the American people.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77f4ce70-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/621/s9"},"text":"Pub. L. 101–621, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3345"},"text":"104 Stat. 3345","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
