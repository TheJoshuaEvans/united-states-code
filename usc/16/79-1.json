{"tag":"section","attrib":{"id":"id76f7f8be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s79–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"79–1"},"text":"§ 79–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Yosemite National Park; expansion of reservoir capacity","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, no Federal lands may be used for the expansion of the capacity of any reservoir which is located within the boundaries of Yosemite National Park unless Congress enacts specific statutory authorization after ","children":[{"tag":"date","attrib":{"date":"1988-10-31"},"text":"October 31, 1988","children":[],"tail":", for such expansion."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76fa68bf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/563/s6"},"text":"Pub. L. 100–563, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2830"},"text":"102 Stat. 2830","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
