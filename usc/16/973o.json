{"tag":"section","attrib":{"id":"id78de6b8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973o"},"text":null,"children":[{"tag":"num","attrib":{"value":"973o"},"text":"§ 973o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of fees, penalties, forfeitures, and other moneys","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To the extent required by the Treaty, an amount equivalent to the total value of any fine, penalty, or other amount collected as a result of any action, judicial or otherwise, taken pursuant to sections 973e and 973f of this title shall be paid by the United States through the Secretary of State to the Administrator as soon as reasonably possible following the date that such amount is collected.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78de6b8e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/330/s17"},"text":"Pub. L. 100–330, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-07"},"text":"June 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/600"},"text":"102 Stat. 600","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIV/s8425"},"text":"Pub. L. 119–60, div. H, title LXXXIV, § 8425","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1919"},"text":"139 Stat. 1919","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78de6b8f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78de6b90-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78de6b91-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" struck out “Article 4 of” after “extent required by”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
