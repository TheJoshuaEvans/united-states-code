{"tag":"section","attrib":{"id":"id77a883cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459a"},"text":null,"children":[{"tag":"num","attrib":{"value":"459a"},"text":"§ 459a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of donations; acquisition of property by purchase and condemnation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to accept donations of land, interests in land, buildings, structures, and other property, within the boundaries of said national seashore recreational area as determined and fixed hereunder and donations of funds for the purchase and maintenance thereof, the title and evidence of title to lands acquired to be satisfactory to the Secretary of the Interior: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That he may acquire on behalf of the United States under any donated funds by purchase, when purchasable at prices deemed by him reasonable, otherwise by condemnation under the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"section 3113 of title 40","children":[],"tail":", such tracts of land within the said national seashore recreational area as may be necessary for the completion thereof."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a883d0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-08-17/ch687/s2"},"text":"Aug. 17, 1937, ch. 687, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/669"},"text":"50 Stat. 669","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1940-06-29/ch459/s1"},"text":"June 29, 1940, ch. 459, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/702"},"text":"54 Stat. 702","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77a883d1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77a883d2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77a883d3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"Section 3113 of title 40","children":[],"tail":"” substituted in text for “the Act of "},{"tag":"date","attrib":{"date":"1888-08-01"},"text":"August 1, 1888","children":[],"tail":"” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77a883d4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77a883d5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “national seashore recreational area” substituted in text for “national seashore” pursuant to act ","children":[{"tag":"date","attrib":{"date":"1940-06-29"},"text":"June 29, 1940","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
