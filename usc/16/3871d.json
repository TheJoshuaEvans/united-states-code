{"tag":"section","attrib":{"id":"id79e26e59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d"},"text":null,"children":[{"tag":"num","attrib":{"value":"3871d"},"text":"§ 3871d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e26e5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall use to carry out the program, to the maximum extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e26e5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $425,000,000 for fiscal year 2026;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $450,000,000 for fiscal year 2027;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $450,000,000 for fiscal year 2028;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $450,000,000 for fiscal year 2029;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $450,000,000 for fiscal year 2030; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $450,000,000 for fiscal year 2031.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e26e61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under subsection (a) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e26e62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds made available for the program under subsection (a), the Secretary shall allocate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e26e63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the funds to projects based on a State or multistate competitive process administered by the Secretary at the local level with the advice of the applicable State technical committees established under subchapter VI; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the funds to projects for critical conservation areas designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871f"},"text":"section 3871f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e26e65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e26e66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), none of the funds made available for the program, including for a partnership agreement funded through an alternative funding arrangement or grant agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871c/d"},"text":"section 3871c(d) of this title","children":[],"tail":", may be used to pay for the administrative expenses of eligible partners."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project development and outreach","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under a partnership agreement that is not funded through an alternative funding arrangement or grant agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871c/d"},"text":"section 3871c(d) of this title","children":[],"tail":", the Secretary may advance reasonable amounts of funding for not longer than 90 days for technical assistance to eligible partners to conduct project development and outreach activities in a project area, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26e68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing outreach and education to producers for potential participation in the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing baseline metrics to support the development of the assessment required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871b/c/1/E"},"text":"section 3871b(c)(1)(E) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance to producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e26e6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e26e6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the time of project selection, the Secretary shall identify and make publicly available the amount that the Secretary shall use to provide technical assistance under the terms of the partnership agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall limit costs of the Secretary for technical assistance to costs specific and necessary to carry out the objectives of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871d/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third-party providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and implement strategies to encourage third-party technical service providers to provide technical assistance to eligible partners pursuant to a partnership agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e26e6f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1271D"},"text":"Pub. L. 99–198, title XII, § 1271D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2401"},"text":"Pub. L. 113–79, title II, § 2401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/749"},"text":"128 Stat. 749","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2705"},"text":"Pub. L. 115–334, title II, § 2705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4598"},"text":"132 Stat. 4598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/tII/s21001/c/7"},"text":"Pub. L. 117–169, title II, § 21001(c)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2017"},"text":"136 Stat. 2017","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10601/b"},"text":"Pub. L. 119–21, title I, § 10601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/107"},"text":"139 Stat. 107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e26e70-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e26e71-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79e26e72-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “The Secretary shall use $300,000,000 of the funds of the Commodity Credit Corporation for each of fiscal years 2019 through 2031 to carry out the program.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":" substituted “2031” for “2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2705/1"},"text":"Pub. L. 115–334, § 2705(1)","children":[],"tail":", substituted “$300,000,000” for “$100,000,000” and “2019 through 2023” for “2014 through 2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2705/2"},"text":"Pub. L. 115–334, § 2705(2)","children":[],"tail":"–(4)(A), redesignated subsec. (d) as (c), struck out “and acres” after “funds” and “and reserved for the program under subsection (c)” after “under subsection (a)” in introductory provisions, and struck out former subsec. (c) which related to reservation of additional funding and acres for each of fiscal years 2014 through 2018."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2705/4/B"},"text":"Pub. L. 115–334, § 2705(4)(B)","children":[],"tail":", substituted “50 percent of the funds to projects based on a State or multistate competitive process administered by the Secretary at the local level with the advice of the applicable State technical committees” for “25 percent of the funds and acres to projects based on a State competitive process administered by the State Conservationist, with the advice of the State technical committee” and inserted “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2705/4/C"},"text":"Pub. L. 115–334, § 2705(4)(C)","children":[],"tail":"–(E), redesignated par. (3) as (2), substituted “50 percent of the funds” for “35 percent of the funds and acres”, and struck out former par. (2) which read as follows: “40 percent of the funds and acres to projects based on a national competitive process to be established by the Secretary; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2705/5"},"text":"Pub. L. 115–334, § 2705(5)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, substituted “Except as provided in paragraph (2), none of the funds made available for the program, including for a partnership agreement funded through an alternative funding arrangement or grant agreement under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871c/d"},"text":"section 3871c(d) of this title","children":[],"tail":",” for “None of the funds made available or reserved for the program”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2705/3"},"text":"Pub. L. 115–334, § 2705(3)","children":[],"tail":", redesignated subsec. (e) as (d). Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2705/6"},"text":"Pub. L. 115–334, § 2705(6)","children":[],"tail":", added subsec. (e). Former subsec. (e) redesignated (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
