{"tag":"section","attrib":{"id":"id7839eed1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544"},"text":null,"children":[{"tag":"num","attrib":{"value":"544"},"text":"§ 544.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Columbia River Gorge National Scenic Area; definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in sections 544 to 544p of this title, the term—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7839eed2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “adversely affect” or “adversely affecting” means, except as used in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s544m"},"text":"section 544m of this title","children":[],"tail":", a reasonable likelihood of more than moderate adverse consequences for the scenic, cultural, recreation or natural resources of the scenic area, the determination of which is based on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7839eed3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the context of a proposed action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eed4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intensity of a proposed action, including the magnitude and duration of an impact and the likelihood of its occurrence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eed5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relationship between a proposed action and other similar actions which are individually insignificant but which may have cumulatively significant impacts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eed6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proven mitigation measures which the proponent of an action will implement as part of the proposal to reduce otherwise significant affects to an insignificant level;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eed7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “agricultural lands” means lands designated as agricultural lands pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s544d"},"text":"section 544d of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eed8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Commission” means the Columbia River Gorge Commission established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s544c"},"text":"section 544c of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eed9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “counties” means Hood River, Multnomah, and Wasco Counties, Oregon; and Clark, Klickitat, and Skamania Counties, Washington;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eeda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Dodson/Warrendale Special Purchase Unit” means the Dodson/Warrendale Special Purchase Unit established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s544b"},"text":"section 544b of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eedb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “forest lands” means lands designated as forest lands pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s544d"},"text":"section 544d of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eedc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian tribes” means the Nez Perce Tribe, the Confederated Tribes and Bands of the Yakima Indian Nation,","children":[{"tag":"ref","attrib":{"idref":"fn002425"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002425"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name notes below."}],"tail":" the Confederated Tribes of the Warm Springs of Oregon, and the Confederated Tribes of the Umatilla Indian Reservation;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eedd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “interim guidelines” means any interim guidelines developed by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s544h"},"text":"section 544h of this title","children":[],"tail":", and any amendment, revision, or variance;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eede-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “land use ordinance” or “ordinance” means any ordinance adopted by a county or by the Commission pursuant to sections 544 to 544p of this title, and includes any amendment to, revision of, or variance from such ordinance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eedf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “major development actions” means any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7839eee0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subdivisions, partitions and short plat proposals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eee1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any permit for siting or construction outside urban areas of multifamily residential, industrial or commercial facilities, except such facilities as are included in the recreation assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eee2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exploration, development and production of mineral resources unless such exploration, development or production can be conducted without disturbing the surface of any land within the boundaries of a special management area or is for sand, gravel and crushed rock used for the construction, maintenance or reconstruction of roads within the special management areas used for the production of forest products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eee3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permits for siting or construction within a special management area of any residence or other related major structure on any parcel of land less than forty acres in size;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eee4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “management plan” means the scenic area management plan adopted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s544d"},"text":"section 544d of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eee5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “open spaces” means unimproved lands not designated as agricultural lands or forest lands pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s544d"},"text":"section 544d of this title","children":[],"tail":" and designated as open space pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s544d"},"text":"section 544d of this title","children":[],"tail":". Open spaces include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7839eee6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scenic, cultural, and historic areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eee7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fish and wildlife habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eee8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lands which support plant species that are endemic to the scenic area or which are listed as rare, threatened or endangered species pursuant to State or Federal Endangered Species Acts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eee9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/l/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ecologically and scientifically significant natural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eeea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/l/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outstanding scenic views and sites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eeeb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/l/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water areas and wetlands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eeec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/l/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" archaeological sites, Indian burial grounds and village sites, historic trails and roads and other areas which are culturally or historically significant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eeed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/l/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential and existing recreation resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839eeee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/l/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal and State wild, scenic, and recreation waterways;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eeef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “recreation assessment” means the recreation assessment adopted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s544d"},"text":"section 544d of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eef0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “residential development” means the permitting for siting or construction of any residence or other related major structure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eef1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/o"},"text":null,"children":[{"tag":"num","attrib":{"value":"o"},"text":"(o)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “scenic area” means the Columbia River Gorge National Scenic Area established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s544b"},"text":"section 544b of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eef2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/p"},"text":null,"children":[{"tag":"num","attrib":{"value":"p"},"text":"(p)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eef3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/q"},"text":null,"children":[{"tag":"num","attrib":{"value":"q"},"text":"(q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “special management areas” means areas within the scenic area established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s544b"},"text":"section 544b of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eef4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/r"},"text":null,"children":[{"tag":"num","attrib":{"value":"r"},"text":"(r)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “States” means the States of Oregon and Washington; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839eef5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544/s"},"text":null,"children":[{"tag":"num","attrib":{"value":"s"},"text":"(s)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “urban areas” means those areas within the scenic area identified as urban areas on the map referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s544b/e"},"text":"section 544b(e) of this title","children":[],"tail":" or within the boundaries of an urban area as revised pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s544b/f"},"text":"section 544b(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7839eef6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/663/s2"},"text":"Pub. L. 99–663, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4274"},"text":"100 Stat. 4274","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7839eef7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7839eef8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7839eef9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Federal Endangered Species Acts, referred to in subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3), are classified principally to chapter 35 (§ 1531 et seq.) of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7839eefa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7839eefb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/435"},"text":"Pub. L. 103–435","children":[],"tail":", §17, "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4573"},"text":"108 Stat. 4573","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/435"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Redesignation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Confederated Tribes and Bands of the Yakima Indian Nation shall be known and designated as the ‘Confederated Tribes and Bands of the Yakama Indian Nation’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reference in a law (including any regulation), map, document, paper, or other record of the United States to Confederated Tribes and Bands of the Yakima Indian Nation referred to in subsection (a) shall be deemed to be a reference to the ‘Confederated Tribes and Bands of the Yakama Indian Nation’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/434/tXII/s1204/g"},"text":"Pub. L. 103–434, title XII, § 1204(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4557"},"text":"108 Stat. 4557","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tVIII/s8204/a"},"text":"Pub. L. 116–9, title VIII, § 8204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/819"},"text":"133 Stat. 819","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/9/tVIII/s8204/a"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Redesignation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Confederated Tribes and Bands of the Yakama Indian Nation shall be known and designated as the ‘Confederated Tribes and Bands of the Yakama Nation’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reference in a law, map, regulation, document, paper, or other record of the United States to the Confederated Tribes and Bands of the Yakima Indian Nation referred to in subsection (a) shall be deemed to be a reference to the ‘Confederated Tribes and Bands of the Yakama Nation’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7839eefc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/663/s1"},"text":"Pub. L. 99–663, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4274"},"text":"100 Stat. 4274","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/663/s1"},"text":"“This Act [enacting this section and sections 544a to 544p of this title and amending sections 1274 and 1276 of this title] may be referred to as the ‘Columbia River Gorge National Scenic Area Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
