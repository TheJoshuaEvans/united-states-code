{"tag":"section","attrib":{"id":"id77eda378-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xx–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"460xx–2"},"text":"§ 460xx–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77eda379-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xx–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No later than 2 years after ","children":[{"tag":"date","attrib":{"date":"1988-11-18"},"text":"November 18, 1988","children":[],"tail":", the Secretary shall develop a comprehensive plan for the long-range management and protection of the conservation area. The plan shall be developed with full opportunity for public participation and comment, and shall contain provisions designed to assure protection of the riparian area and the aquatic, wildlife, archeological, paleontological, scientific, cultural, educational, and recreation resources and values of the conservation area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77eda37a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xx–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in the comprehensive plan referred to in subsection (a), develop recommendations to Congress on whether additional lands should be included in the conservation area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77eda37b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xx–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into cooperative agreements with appropriate State and local agencies, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1737/b"},"text":"section 1737(b) of title 43","children":[],"tail":", to better implement the plan developed pursuant to subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77eda37c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xx–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to assist in the development of appropriate management strategies for the conservation area, the Secretary may authorize research on matters including the environmental, biological, hydrological, and cultural resources of the conservation area, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1737/a"},"text":"section 1737(a) of title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77eda37d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/696/tI/s103"},"text":"Pub. L. 100–696, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4572"},"text":"102 Stat. 4572","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
