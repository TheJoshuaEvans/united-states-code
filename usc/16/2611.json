{"tag":"section","attrib":{"id":"id799d4f21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2611"},"text":null,"children":[{"tag":"num","attrib":{"value":"2611"},"text":"§ 2611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are to encourage—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799d4f22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2611/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conservation of energy supplied by electric utilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799d4f23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2611/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the optimization of the efficiency of use of facilities and resources by electric utilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799d4f24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2611/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equitable rates to electric consumers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799d4f25-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617/tI/s101"},"text":"Pub. L. 95–617, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3120"},"text":"92 Stat. 3120","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799d4f26-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","c