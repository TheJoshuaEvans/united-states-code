{"tag":"section","attrib":{"id":"id7a3103e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031"},"text":null,"children":[{"tag":"num","attrib":{"value":"8031"},"text":"§ 8031.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Working Group on IUU fishing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3103e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a collaborative interagency working group on maritime security and IUU fishing (referred to in this chapter as the “Working Group”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3103e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the Working Group shall be composed of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3103e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 chair, who shall rotate between the Secretary of the Department in which the Coast Guard is operating, acting through the Commandant of the Coast Guard, the Secretary of State, and the National Oceanographic and Atmospheric Administration, acting through the Administrator, on a 3-year term;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3103e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 2 deputy chairs, who shall be appointed by their respective agency heads and shall be from a different Department than that of the chair, from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3103e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3103e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3103e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Oceanic and Atmospheric Administration;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3103e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 12 members, who shall be appointed by their respective agency heads, from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3103ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3103eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Navy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3103ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Agency for International Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3103ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Fish and Wildlife Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3103ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3103ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3103f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" U.S. Customs and Border Protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3103f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" U.S. Immigration and Customs Enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3103f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Trade Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3103f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3103f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Food and Drug Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3103f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/3/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Labor;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3103f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more members from the intelligence community (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of title 50","children":[],"tail":"), who shall be appointed by the Director of National Intelligence; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3103f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 5 members, who shall be appointed by the President, from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3103f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Security Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3103f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Council on Environmental Quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3103fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3103fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Science and Technology Policy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3103fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the United States Trade Representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3103fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Working Group shall ensure an integrated, Federal Government-wide response to IUU fishing globally, including by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3103fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the coordination of Federal agencies to identify, interdict, investigate, prosecute, and dismantle IUU fishing operations and organizations perpetrating and knowingly benefitting from IUU fishing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3103ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing areas for increased interagency information sharing on matters related to IUU fishing and related crimes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310400-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing standards for information sharing related to maritime enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310401-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximizing the utility of the import data collected by the members of the Working Group by harmonizing data standards and entry fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310402-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing a strategy to determine how military assets and intelligence can contribute to enforcement strategies to combat IUU fishing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310403-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing maritime domain awareness relating to IUU fishing and related crimes and developing a strategy to leverage awareness for enhanced enforcement and prosecution actions against IUU fishing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310404-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the adoption and implementation of the Port State Measures Agreement in relevant countries and assessing the capacity and training needs in such countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310405-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outlining a strategy to coordinate, increase, and use shiprider agreements between the Department of Defense or the Coast Guard and relevant countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310406-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing cooperation with partner governments to combat IUU fishing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310407-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying opportunities for increased information sharing between Federal agencies and partner governments working to combat IUU fishing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310408-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consulting and coordinating with the seafood industry and nongovernmental stakeholders that work to combat IUU fishing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310409-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the work of collaborative international initiatives to make available certified data from state authorities about vessel and vessel-related activities related to IUU fishing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31040a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the identification and certification procedures to address IUU fishing in accordance with the High Seas Driftnet Fishing Moratorium Protection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1826d"},"text":"16 U.S.C. 1826d","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31040b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8031/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publishing annual reports summarizing nonsensitive information about the Working Group’s efforts to investigate, enforce, and prosecute groups and individuals engaging in IUU fishing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a31040c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3551"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3551","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2005"},"text":"133 Stat. 2005","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIII/s11331/a"},"text":"Pub. L. 117–263, div. K, title CXIII, § 11331(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4099"},"text":"136 Stat. 4099","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a31040d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a31040e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a31040f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this subtitle”, meaning subtitle C of title XXXV of div. C of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1997"},"text":"133 Stat. 1997","children":[],"tail":", known as the Maritime Security and Fisheries Enforcement Act and also as the Maritime SAFE Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s8001"},"text":"section 8001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The High Seas Driftnet Fishing Moratorium Protection Act, referred to in subsec. (c)(13), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tVI"},"text":"Pub. L. 104–43, title VI","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/391"},"text":"109 Stat. 391","children":[],"tail":", which enacted sections 1826d to 1826g of this title and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1826d"},"text":"section 1826d of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1995 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a310410-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(4) to (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added par. (4) and redesignated former pars. (4) to (13) as (5) to (14), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a310411-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a310412-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prohibition on Aggregated Catch Data for Certain Species","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIII/s11331/b"},"text":"Pub. L. 117–263, div. K, title CXIII, § 11331(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4099"},"text":"136 Stat. 4099","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dK/tCXIII/s11331/b"},"text":"“Beginning not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], for the purposes of compliance with respect to Northern red snapper under the Seafood Import Monitoring Program, the Secretary may not allow an aggregated harvest report of such species, regardless of vessel size.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of terms as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11331/b"},"text":"section 11331(b) of Pub. L. 117–263","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/s11329"},"text":"section 11329 of div. K of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1885a"},"text":"section 1885a of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
