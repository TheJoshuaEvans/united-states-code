{"tag":"section","attrib":{"id":"id7a29feba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7502"},"text":null,"children":[{"tag":"num","attrib":{"value":"7502"},"text":"§ 7502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes and agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a29febb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purposes of this chapter are to better understand and utilize the oceans, coasts, and Great Lakes of the United States, and ensure present and future generations will benefit from the full range of ecological, economic, social, and recreational opportunities, security, and services these resources are capable of providing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29febc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator and the Foundation may enter into such agreements as may be necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a29febd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dO/tIX/s903"},"text":"Pub. L. 114–113, div. O, title IX, § 903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3031"},"text":"129 Stat. 3031","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
