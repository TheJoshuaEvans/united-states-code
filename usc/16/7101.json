{"tag":"section","attrib":{"id":"id7a22d275-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7101"},"text":null,"children":[{"tag":"num","attrib":{"value":"7101"},"text":"§ 7101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a22d276-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to stabilize and transition payments to counties to provide funding for schools and roads that supplements other available funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d277-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to make additional investments in, and create additional employment opportunities through, projects that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a22d278-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7101/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a22d279-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7101/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the maintenance of existing infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a22d27a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7101/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement stewardship objectives that enhance forest ecosystems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a22d27b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7101/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restore and improve land health and water quality;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d27c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7101/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enjoy broad-based support; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d27d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7101/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have objectives that may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a22d27e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7101/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" road, trail, and infrastructure maintenance or obliteration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a22d27f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7101/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soil productivity improvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a22d280-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7101/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","childre