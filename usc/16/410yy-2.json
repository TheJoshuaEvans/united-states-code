{"tag":"section","attrib":{"id":"id776364a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"410yy–2"},"text":"§ 410yy–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id776364a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general; administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776364a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby established as a unit of the National Park System the Keweenaw National Historical Park in and near Calumet and Hancock, Michigan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall administer the park in accordance with the provisions of this subchapter, and the provisions of law generally applicable to units of the National Park System, including the Act entitled “An Act to establish a National Park Service, and for other purposes”, approved ","children":[{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":", 2–4),"},{"tag":"ref","attrib":{"idref":"fn002137"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002137"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and the Act entitled “An Act to provide for the preservation of historic American sites, buildings, objects and antiquities of national significance, and for other purposes”, approved "},{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s461"},"text":"16 U.S.C. 461","children":[],"tail":" et seq.)."},{"tag":"ref","attrib":{"idref":"fn002137"},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776364a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundaries and map","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776364a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The boundaries of the park shall be as generally depicted on the map entitled “Keweenaw National Historical Park, Michigan”, numbered NHP–KP/20012–B and dated June, 1992. Such map shall be on file and available for public inspection in the office of the National Park Service, Department of the Interior, Washington, District of Columbia, and the office of the village council, Calumet, Michigan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776364a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-27"},"text":"October 27, 1992","children":[],"tail":", the Secretary shall publish in 