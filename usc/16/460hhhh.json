{"tag":"section","attrib":{"id":"id781157ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh"},"text":null,"children":[{"tag":"num","attrib":{"value":"460hhhh"},"text":"§ 460hhhh.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Numunaa Nobe National Conservation Area","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id781157af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id781157b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Conservation Area” means the Numunaa Nobe National Conservation Area established by paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “management plan” means the management plan for the Conservation Area developed under paragraph (3)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781157b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id781157b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To conserve, protect, and enhance for the benefit and enjoyment of present and future generations the cultural, archaeological, natural, wilderness, scientific, geological, historical, biological, wildlife, educational, recreational, and scenic resources of the Conservation Area, subject to valid existing rights, there is established the Numunaa Nobe National Conservation Area in the State of Nevada, to be administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area included","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id781157b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Conservation Area shall consist of approximately 160,224 acres of public land in Churchill County, Nevada, as generally depicted on the map entitled “Churchill County Proposed Fallon Range Training Complex Modernization and Lands Bill” and dated ","children":[{"tag":"date","attrib":{"date":"2022-11-30"},"text":"November 30, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id781157b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map described in clause (i) shall be on file and available for public inspection in the appropriate offices of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781157b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id781157b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall administer the Conservation Area in a manner that conserves, protects, and enhances the resources of the Conservation Area—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id781157ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id781157bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id781157bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id781157bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/3/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other applicable law; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id781157be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a component of the National Landscape Conservation System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id781157c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary shall develop a management plan for the Conservation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id781157c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the management plan, the Secretary shall consult with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id781157c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate Federal, State, Tribal, and local governmental entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id781157c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id781157c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The management plan shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id781157c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/3/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the appropriate uses of the Conservation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id781157c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/3/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with paragraph (5), authorize the use of motor vehicles in the Conservation Area, where appropriate, including for the maintenance of existing roads; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id781157c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/3/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate any provision of an applicable land and resource management plan that the Secretary considers to be appropriate, to include the Search and Rescue Training Cooperative Agreement between the Bureau of Land Management and the Naval Strike and Air Warfare Training Center dated ","children":[{"tag":"date","attrib":{"date":"1998-07-06"},"text":"July 6, 1998","children":[],"tail":", and the Carson City District BLM Administrative Guide to Military Activities on and Over the Public Lands dated "},{"tag":"date","attrib":{"date":"2012-01-25"},"text":"January 25, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781157c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allow only those uses of the Conservation Area that the Secretary determines would further the purposes of the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781157c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motorized vehicles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as needed for administrative purposes, planned military activities authorized by paragraph (3)(B)(iii)(III), or to respond to an emergency, the use of motorized vehicles in the Conservation Area shall be permitted only on roads and trails designated for the use of motorized vehicles by the management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781157ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id781157cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, all public land in the Conservation Area is withdrawn from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id781157cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all forms of entry, appropriation, and disposal under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id781157cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id781157ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disposition under all laws relating to mineral and geothermal leasing or mineral materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary acquires mineral or other interests in a parcel of land within the Conservation Area after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the parcel is withdrawn from operation of the laws referred to in subparagraph (A) on the date of acquisition of the parcel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781157d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting, fishing, and trapping","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id781157d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), nothing in this section affects the jurisdiction of the State of Nevada with respect to fish and wildlife, including hunting, fishing, and trapping in the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id781157d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may designate by regulation areas in which, and establish periods during which, no hunting, fishing, or trapping will be permitted in the Conservation Area, for reasons of public safety, administration, or compliance with applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id781157d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except in an emergency, the Secretary shall consult with the appropriate State agency and notify the public before taking any action under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781157d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of land included in the Conservation Area on which the Secretary permitted, as of ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", livestock grazing, the livestock grazing shall be allowed to continue, subject to applicable laws (including regulations)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781157d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No buffer zones","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id781157d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section creates a protective perimeter or buffer zone around the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities outside Conservation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fact that an activity or use on land outside the Conservation Area can be seen or heard within the Conservation Area shall not preclude the activity or use outside the boundary of the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781157d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002392"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002392"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Two pars. (10) have been enacted."}],"tail":" Military overflights"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section restricts or precludes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id781157da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-level overflights of military aircraft over the Conservation Area, including military overflights that can be seen or heard within the Conservation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flight testing and evaluation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the designation or creation of new units of special use airspace, or the establishment of military flight training routes, over the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781157dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhhh/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Effect on water rights"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section constitutes an express or implied reservation of any water rights with respect to the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id781157de-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dB/tXXIX/s2903/a"},"text":"Pub. L. 117–263, div. B, title XXIX, § 2903(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3034"},"text":"136 Stat. 3034","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id781157df-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id781157e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id781157e1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in par. (3)(A)(i)(II), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
