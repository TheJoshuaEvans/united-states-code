{"tag":"section","attrib":{"id":"id7760f3e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ww–1"},"text":"§ 410ww–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of historic properties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7760f3e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of properties within park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within the boundaries of the park the Secretary shall, subject to the availability of appropriated funds, acquire Hawthorn Hill, the Wright Company factory, the Wright Cycle Company Building and Hoover Block, and may acquire other properties, or interests therein, referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ww/b"},"text":"section 410ww(b) of this title","children":[],"tail":", by donation, purchase with donated or appropriated funds, exchange, or transfer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f3e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to enter into cooperative agreements with other Federal agencies, State and local public bodies, and private interests and organizations relating to the preservation, development, use, and interpretation of properties within the boundaries of the park in order to contribute to the appropriate use and management of such properties consistent with the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f3e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to enter into a cooperative agreement with a partner or partners, including the Wright Family Foundation, to operate and provide programming for Hawthorn Hill and charge reasonable fees notwithstanding any other provision of law, which may be used to defray the costs of park operation and programming.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f3ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Cooperative agreements under this section shall provide, whenever appropriate, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7760f3eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public may have access to any such property at specified reasonable times for purposes of viewing such property or the exhibits or attending programs established by the Secretary under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f3ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may make such improvements to any such property as the Secretary deems necessary after consultation with the Aviation Heritage Foundation to enhance the public use and enjoyment of such property and programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7760f3ed-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/419/tI/s102"},"text":"Pub. L. 102–419, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2142"},"text":"106 Stat. 2142","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7117/b"},"text":"Pub. L. 111–11, title VII, § 7117(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1204"},"text":"123 Stat. 1204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7760f3ee-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7760f3ef-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7760f3f0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7117/b/1"},"text":"Pub. L. 111–11, § 7117(b)(1)","children":[],"tail":", inserted “Hawthorn Hill, the Wright Company factory,” before “the Wright Cycle Company Building”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7117/b/2"},"text":"Pub. L. 111–11, § 7117(b)(2)","children":[],"tail":", redesignated last sentence as subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7117/b/3"},"text":"Pub. L. 111–11, § 7117(b)(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7117/b/2"},"text":"Pub. L. 111–11, § 7117(b)(2)","children":[],"tail":", redesignated last sentence of subsec. (b) as (d), inserted heading, and substituted “Cooperative agreements under this section” for “Such agreements” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7117/b/4"},"text":"Pub. L. 111–11, § 7117(b)(4)","children":[],"tail":", substituted “Aviation Heritage Foundation” for “Commission”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
