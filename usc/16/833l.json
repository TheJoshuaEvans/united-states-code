{"tag":"section","attrib":{"id":"id78c1e2eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s833l"},"text":null,"children":[{"tag":"num","attrib":{"value":"833l"},"text":"§ 833l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of Indian lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In aid of the construction of the Fort Peck project, there is granted to the United States, subject to the provisions of sections 833","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" to 833p of this title, such right, title, and interest of the Indians as may be required in and to such tribal and allotted lands as may be designated by the Secretary of the Interior from time to time for the construction, operation, and maintenance of electric transmission lines and other works of the project or for the relocation or reconstruction of properties made necessary by the construction of the project."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78c1e2ec-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-04-23/ch199/s1"},"text":"Apr. 23, 1946, ch. 199, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/118"},"text":"60 Stat. 118","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78c1e2ed-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78c1e2ee-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78c1e2ef-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of act ","children":[{"tag":"date","attrib":{"date":"1938-05-18"},"text":"May 18, 1938","children":[],"tail":", which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id78c1e2f0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id78c1e2f1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
