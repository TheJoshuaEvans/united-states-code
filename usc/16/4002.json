{"tag":"section","attrib":{"id":"id79e728df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4002"},"text":null,"children":[{"tag":"num","attrib":{"value":"4002"},"text":"§ 4002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional statement of purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this chapter is to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e728e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen the competitive position of the United States commercial fishing industry in the domestic and international marketplace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the development and utilization of all species of fish available for harvest by the United States fishing industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the utilization of domestically-produced fish through enhancement of markets, promotion, and public relations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4002/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help the United States fishing industry develop methods to improve quality and efficiency in the marketplace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4002/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educate and inform consumers on the use of fish;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4002/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop better coordination of fisheries marketing and promotion activities with commercial fisheries research and development programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4002/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educate and inform the public about the nutritional value of fish in the diet.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e728e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659/tII/s203"},"text":"Pub. L. 99–659, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3716"},"text":"100 Stat. 3716","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e728e8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e728e9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79e728ea-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659"},"text":"Pub. L. 99–659","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3715"},"text":"100 Stat. 3715","children":[],"tail":", which is classified principally to this chapter. For complete classification of title II to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4001"},"text":"section 4001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
