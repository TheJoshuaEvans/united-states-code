{"tag":"section","attrib":{"id":"id7a382f90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8424"},"text":null,"children":[{"tag":"num","attrib":{"value":"8424"},"text":"§ 8424.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration of overnight campsites","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a382f91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8424/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a382f92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8424/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Recreation Area” means the recreation area and grounds associated with the recreation area on the map entitled “Ouachita National Forest Camping Restoration” and dated ","children":[{"tag":"date","attrib":{"date":"2023-11-30"},"text":"November 30, 2023","children":[],"tail":", on file with the Forest Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382f93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8424/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a382f94-6992-11f1-ab3f-8b4c043