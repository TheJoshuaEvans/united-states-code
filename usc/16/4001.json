{"tag":"section","attrib":{"id":"id79e728d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4001"},"text":null,"children":[{"tag":"num","attrib":{"value":"4001"},"text":"§ 4001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e728d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commercial fishing industry of the United States significantly contributes to the national economy, and could make a greater contribution if fish resources within the United States Exclusive Economic Zone were more fully utilized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commercial fisheries of the United States provide significant employment in coastal areas and in processing and distribution centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fish contribute an important nutritional component to the American diet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4001/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased consumption of seafood in the United States could significantly lower the risk of many cardiovascular diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4001/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federally supported development programs for commercial fisheries are unable to meet present and future marketing needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4001/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" many fish species are underutilized by the United States fishing industry because of underdeveloped markets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4001/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States fishing industry has the potential to expand greatly its contribution to interstate and foreign commerce, favorably affecting the balance of trade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e728da-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659/tII/s202"},"text":"Pub. L. 99–659, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3715"},"text":"100 Stat. 3715","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e728db-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79e728dc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79e728dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659/tII/s201"},"text":"Pub. L. 99–659, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3715"},"text":"100 Stat. 3715","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/659/tII/s201"},"text":"“This title [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s713c–3"},"text":"section 713c–3 of Title 15","children":[],"tail":", Commerce and Trade] may be cited as the ‘Fish and Seafood Promotion Act of 1986’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79e728de-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report to Congress on Fish and Seafood Promotion","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659/tII/s219"},"text":"Pub. L. 99–659, title II, § 219","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3731"},"text":"100 Stat. 3731","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/659/tII/s219"},"text":"“The Secretary shall, not later than ","children":[{"tag":"date","attrib":{"date":"1989-03-01"},"text":"March 1, 1989","children":[],"tail":", submit to the Congress a report on the effectiveness of the implementation of this title [enacting this chapter and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s713c–3"},"text":"section 713c–3 of Title 15","children":[],"tail":", Commerce and Trade] in achieving the purposes of this title.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
