{"tag":"section","attrib":{"id":"id79dffd84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d"},"text":null,"children":[{"tag":"num","attrib":{"value":"3865d"},"text":"§ 3865d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79dffd85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligible land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not use program funds for the purposes of acquiring an easement on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dffd86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lands owned by an agency of the United States, other than land held in trust for Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffd87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lands owned in fee title by a State, including an agency or a subdivision of a State, or a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffd88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land subject to an easement or deed restriction which, as determined by the Secretary, provides similar protection as would be provided by enrollment in the program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffd89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lands where the purposes of the program would be undermined due to on-site or off-site conditions, such as risk of hazardous substances, permitted or existing rights of way, infrastructure development, or adjacent land uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dffd8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating applications under the program, the Secretary may give priority to land that is currently enrolled in the conservation reserve program in a contract that is set to expire within 1 year and—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dffd8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an agricultural land easement, is grassland that would benefit from protection under a long-term easement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffd8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a wetland reserve easement, is a wetland or related area with the highest wetland functions and value and is likely to return to production after the land leaves the conservation reserve program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dffd8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subordination, exchange, modification, and termination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dffd8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may subordinate any interest in land, or portion of such interest, administered by the Secretary (including for the purposes of utilities and energy transmission services) either directly or on behalf of the Commodity Credit Corporation under the program if the Secretary determines that the subordination—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dffd8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases conservation values or has a limited negative effect on conservation values;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffd90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimally affects the acreage subject to the interest in land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffd91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the public interest or furthers the practical administration of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffd92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification and exchange","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dffd93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may approve a modification or exchange of any interest in land, or portion of such interest, administered by the Secretary, either directly or on behalf of the Commodity Credit Corporation under the program if the Secretary determines that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dffd94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no reasonable alternative exists and the effect on the interest in land is avoided or minimized to the extent practicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffd95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the modification or exchange—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79dffd96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results in equal or increased conservation values;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dffd97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results in equal or greater economic value to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dffd98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the original intent of the easement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dffd99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/2/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the purposes of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dffd9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/2/A/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the public interest or furthers the practical administration of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffd9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In modifying or exchanging an interest in land, or portion of such interest, under this paragraph, the Secretary may not increase any payment to an eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffd9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may approve a termination of any interest in land, or portion of such interest, administered by the Secretary, directly or on behalf of the Commodity Credit Corporation under the program if the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dffd9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" termination is in the interest of the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffd9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the United States will be fully compensated for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dffd9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of the interest in land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffda0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any costs relating to the termination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffda1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any damages determined appropriate by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffda2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the termination will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dffda3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address a compelling public need for which there is no practicable alternative even with avoidance and minimization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffda4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further the practical administration of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffda5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall obtain consent from the landowner and eligible entity, if applicable, for any subordination, exchange, modification, or termination of interest in land, or portion of such interest, under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffda6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least 90 days before taking any termination action described in paragraph (3), the Secretary shall provide written notice of such action to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dffda7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land enrolled in other programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dffda8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation reserve program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may terminate or modify a contract entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831/a"},"text":"section 3831(a) of this title","children":[],"tail":" if eligible land that is subject to such contract is enrolled in an easement under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3865c/b"},"text":"section 3865c(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffda9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with the provisions of subtitle H of title II of the Agricultural Act of 2014, land enrolled in the wetlands reserve program, grassland reserve program, or farmland protection program on the day before ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", shall be considered enrolled in the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffdaa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural land easements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A farmer or rancher who owns eligible land subject to an agricultural land easement may enter into a contract under subpart B of part I of subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dffdab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with certain requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not provide assistance under this subchapter to an eligible entity or owner of eligible land unless the eligible entity or owner agrees, during the crop year for which the assistance is provided—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dffdac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with applicable conservation requirements under subchapter II; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffdad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with applicable wetland protection requirements under subchapter III.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79dffdae-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1265D"},"text":"Pub. L. 99–198, title XII, § 1265D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2301/a"},"text":"Pub. L. 113–79, title II, § 2301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/742"},"text":"128 Stat. 742","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2605"},"text":"Pub. L. 115–334, title II, § 2605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4591"},"text":"132 Stat. 4591","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79dffdaf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79dffdb0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79dffdb1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Agricultural Act of 2014, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/649"},"text":"128 Stat. 649","children":[],"tail":". Subtitle H (§§ 2701–2713) of title II of the Act amended sections 3801, 3811, and 3842 of this title, repealed sections 3830, 3831a, 3837 to 3837f, 3838h to 3838j, 3838n to 3838q, 3839 to 3839d, 3839aa–9, 3839bb–1, 3839bb–3, and 3839bb–4 of this title, and enacted provisions set out as notes under sections 3801, 3831a, 3837, 3838h, 3838n, 3839aa–9, 3839bb–1, 3839bb–4, and 3843 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of Title 7","children":[],"tail":", Agriculture, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79dffdb2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2605/1"},"text":"Pub. L. 115–334, § 2605(1)","children":[],"tail":", substituted “permitted” for “proposed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2605/2"},"text":"Pub. L. 115–334, § 2605(2)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which allowed the Secretary to subordinate, exchange, modify, or terminate interests in land subject to certain determination, consultation, and notice requirements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2605/3/A"},"text":"Pub. L. 115–334, § 2605(3)(A)","children":[],"tail":", substituted “enrolled in an easement under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3865c/b"},"text":"section 3865c(b) of this title","children":[],"tail":"” for “transferred into the program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2605/3/B"},"text":"Pub. L. 115–334, § 2605(3)(B)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
