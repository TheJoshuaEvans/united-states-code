{"tag":"section","attrib":{"id":"id7a0167a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5607"},"text":null,"children":[{"tag":"num","attrib":{"value":"5607"},"text":"§ 5607.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultative committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0167a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5607/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State and the Secretary, shall jointly establish a consultative committee to advise the Secretaries on issues related to the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0167a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5607/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0167aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5607/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The membership of the Committee shall include representatives from the New England and Mid-Atlantic Fishery Management Councils, the States represented on those Councils, the Atlantic States Marine Fisheries Commission, the fishing industry, the seafood processing industry, and others knowledgeable and experienced in the conservation and management of fisheries in the Northwest Atlantic Ocean.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5607/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and Reappointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the consultative committee shall serve for a term of 2 years and shall be eligible for reappointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0167ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5607/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of committee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the consultative committee may attend—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0167ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5607/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all public meetings of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5607/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other meetings to which they are invited by the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5607/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all nonexecutive meetings of the United States Commissioners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0167b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5607/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to the consultative committee established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0167b1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tII/s208"},"text":"Pub. L. 104–43, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/380"},"text":"109 Stat. 380","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/327/tV/s507"},"text":"Pub. L. 114–327, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1996"},"text":"130 Stat. 1996","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/125"},"text":"Pub. L. 117–286, § 4(a)(125)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4319"},"text":"136 Stat. 4319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0167b2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0167b3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a0167b4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/s507/1"},"text":"Pub. L. 114–327, § 507(1)","children":[],"tail":", substituted “2” for “two”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/s507/2"},"text":"Pub. L. 114–327, § 507(2)","children":[],"tail":", struck out “General Council or the Fisheries” before “Commission;”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
