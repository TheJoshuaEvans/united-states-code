{"tag":"section","attrib":{"id":"id785b58d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s610"},"text":null,"children":[{"tag":"num","attrib":{"value":"610"},"text":"§ 610.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permits to cut and remove timber; citizens of Washington County and Kane County, Utah","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be lawful for the Secretary of the Interior to grant permits under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s607"},"text":"section 607 of this title","children":[],"tail":", to citizens of Washington County and of Kane County, Utah, to cut timber on the public lands of the counties of Mohave and Coconino, Arizona, for agricultural, mining, or other domestic purposes, and remove the timber so cut to said Washington County and Kane County, Utah."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id785b58d1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1891-03-03/ch561/s8"},"text":"Mar. 3, 1891, ch. 561, § 8","children":[],"tail":" (part), as added "},{"tag":"ref","attrib":{"href":"/us/act/1922-02-27/ch82"},"text":"Feb. 27, 1922, ch. 82","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/398"},"text":"42 Stat. 398","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id785b58d2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id785b58d3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id785b58d4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is derived from act ","children":[{"tag":"date","attrib":{"date":"1922-02-27"},"text":"Feb. 27, 1922","children":[],"tail":", which recites that it amends section 8 of act "},{"tag":"date","attrib":{"date":"1891-03-03"},"text":"Mar. 3, 1891","children":[],"tail":", which is the source of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s607"},"text":"section 607 of this title","children":[],"tail":", by adding this section thereto. Section 8 of act "},{"tag":"date","attrib":{"date":"1891-03-03"},"text":"Mar. 3, 1891","children":[],"tail":", is classified to sections 607, 608 to 611a of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
