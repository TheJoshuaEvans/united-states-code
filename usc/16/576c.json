{"tag":"section","attrib":{"id":"id78484669-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s576c"},"text":null,"children":[{"tag":"num","attrib":{"value":"576c"},"text":"§ 576c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental National Forest Reforestation Fund; establishment; duration; authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary of Agriculture shall establish a “Supplemental National Forest Reforestation Fund”, and transfer to that fund beginning with the fiscal year, commencing ","children":[{"tag":"date","attrib":{"date":"1972-07-01"},"text":"July 1, 1972","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1987-09-30"},"text":"September 30, 1987","children":[],"tail":", such amounts as may be appropriated therefor. There is hereby authorized to be appropriated for such purpose for each of the fiscal years during such period the sum of $65,000,000."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7848466a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/421/s1"},"text":"Pub. L. 92–421, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-18"},"text":"Sept. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/678"},"text":"86 Stat. 678","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/273/s2/9"},"text":"Pub. L. 94–273, § 2(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-21"},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/375"},"text":"90 Stat. 375","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7848466b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7848466c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7848466d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/273"},"text":"Pub. L. 94–273","children":[],"tail":" substituted “September” for “June”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
