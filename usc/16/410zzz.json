{"tag":"section","attrib":{"id":"id777d7c5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410zzz"},"text":null,"children":[{"tag":"num","attrib":{"value":"410zzz"},"text":"§ 410zzz.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to preserve in public ownership historically significant properties associated with the life and cultural achievements of Augustus Saint-Gaudens, the Secretary of the Interior may acquire, by donation from the Saint-Gaudens Memorial, a corporation, the sites and structures comprising the Saint-Gaudens Memorial situated at Cornish, New Hampshire, and by donation or purchase with donated funds not to exceed three acres of adjacent lands which the Secretary of the Interior deems necessary for the purposes of this subchapter, together with any works of art, furnishings, reproductions, and other properties within the structures and on the memorial grounds.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id777d7c5d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/543/s1"},"text":"Pub. L. 88–543, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-31"},"text":"Aug. 31, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/749"},"text":"78 Stat. 749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777d7c5e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777d7c5f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id777d7c60-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This subchapter is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/543"},"text":"Pub. L. 88–543","children":[],"tail":", as amended. "},{"tag":"ref","attrib":{"href":"/us/pl/88/543"},"text":"Pub. L. 88–543","children":[],"tail":" is also listed in a table of National Historic Sites set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320101"},"text":"section 320101 of Title 54","children":[],"tail":", National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id777d7c61-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id777d7c62-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Designation of Saint-Gaudens National Historical Park","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2201/a"},"text":"Pub. L. 116–9, title II, § 2201(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/733"},"text":"133 Stat. 733","children":[],"tail":", 734, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/9/tII/s2201/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Saint-Gaudens National Historic Site shall be known and designated as the ‘Saint-Gaudens National Historical Park’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reference in any law, regulation, document, record, map, or other paper of the United States to the Saint-Gaudens National Historic Site shall be considered to be a reference to the ‘Saint-Gaudens National Historical Park’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
