{"tag":"section","attrib":{"id":"id7727ba78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s284"},"text":null,"children":[{"tag":"num","attrib":{"value":"284"},"text":"§ 284.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; statement of purposes; description; acquisition of property; acreage limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of establishing in the National Capital area a park for the performing arts and related educational programs, and for recreation use in connection therewith, the Secretary of the Interior is authorized to establish, develop, improve, operate, and maintain the Wolf Trap National Park for the Performing Arts in Fairfax County, Virginia. The park shall encompass the portions of the property formerly known as Wolf Trap Farm and Symphony Hill in Fairfax County, Virginia, to be donated for park purposes to the United States, and such additional lands or interests therein as the Secretary may acquire for purposes of the park by donation or purchase with donated or appropriated funds, the aggregate of which shall not exceed one hundred and forty-five acres.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7727ba79-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/671/s1"},"text":"Pub. L. 89–671, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/950"},"text":"80 Stat. 950","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/219/s1/a/1"},"text":"Pub. L. 107–219, § 1(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1330"},"text":"116 Stat. 1330","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7727ba7a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7727ba7b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7727ba7c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/219"},"text":"Pub. L. 107–219","children":[],"tail":" substituted “Wolf Trap National Park for the Performing Arts” for “Wolf Trap Farm Park”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7727ba7d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7727ba7e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/671/s12"},"text":"Section 12 of Pub. L. 89–671","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/97/310"},"text":"Pub. L. 97–310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-14"},"text":"Oct. 14, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1458"},"text":"96 Stat. 1458","children":[],"tail":", and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/219/s1/a/1"},"text":"Pub. L. 107–219, § 1(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1330"},"text":"116 Stat. 1330","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/219/s1/a/1"},"text":"“This Act [enacting this subchapter] may be referred to as the ‘Wolf Trap National Park for the Performing Arts Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7727ba7f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Park Future; Report to Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/671/s13"},"text":"Pub. L. 89–671, § 13","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/101/636/s3"},"text":"Pub. L. 101–636, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4587"},"text":"104 Stat. 4587","children":[],"tail":", directed Secretary, acting jointly with the Foundation, to conduct a study and analysis of the operations and management practices being used to carry out the purposes of this subchapter and to submit, not later than 2 years after "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", a report of such study and analysis to Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
