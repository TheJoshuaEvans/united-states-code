{"tag":"section","attrib":{"id":"id79f581aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4728"},"text":null,"children":[{"tag":"num","attrib":{"value":"4728"},"text":"§ 4728.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Brown tree snake control program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Task Force shall, within the program developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4722/a"},"text":"section 4722(a) of this title","children":[],"tail":", undertake a comprehensive, environmentally sound program in coordination with regional, territorial, State and local entities to control the brown tree snake (Boiga irregularis) in Guam and other areas where the species is established outside of its historic range."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79f581ab-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646/tI/s1209"},"text":"Pub. L. 101–646, title I, § 1209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4772"},"text":"104 Stat. 4772","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/h/1"},"text":"Pub. L. 104–332, § 2(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4091"},"text":"110 Stat. 4091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIII/s11327/e/5"},"text":"Pub. L. 117–263, div. K, title CXIII, § 11327(e)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4098"},"text":"136 Stat. 4098","children":[],"tail":".)"}],"tail":"\n"},{"tag":"note