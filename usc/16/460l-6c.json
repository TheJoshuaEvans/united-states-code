{"tag":"section","attrib":{"id":"id77c051ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c"},"text":null,"children":[{"tag":"num","attrib":{"value":"460l–6c"},"text":"§ 460l–6c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admission, entrance, and recreation fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77c051ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77c051ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area of concentrated public use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “area of concentrated public use” means an area administered by the Secretary that meets each of the following criteria:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77c051ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The area is managed primarily for outdoor recreation purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c051f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Facilities and services necessary to accommodate heavy public use are provided in the area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c051f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The area contains at least 1 major recreation attraction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c051f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public access to the area is provided in such a manner that admission fees can be efficiently collected at 1 or more centralized locations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c051f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boat launching facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “boat launching facility” includes any boat launching facility, regardless of whether specialized facilities or services, such as mechanical or hydraulic boat lifts or facilities, are provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c051f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Campground","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “campground” means any campground where a majority of the following amenities are provided, as determined by the Secretary:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77c051f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tent or trailer spaces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c051f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Drinking water.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c051f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An access road.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c051f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Refuse containers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c051f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Toilet facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c051fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The personal collection of recreation use fees by an employee or agent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c051fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reasonable visitor protection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c051fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If campfires are permitted in the campground, simple devices for containing the fires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c051fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c051fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to impose fees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may charge—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77c051ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" admission or entrance fees at national monuments, national volcanic monuments, national scenic areas, and areas of concentrated public use administered by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c05200-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recreation use fees at lands administered by the Secretary in connection with the use of specialized outdoor recreation sites, equipment, services, and facilities, including visitors’ centers, picnic tables, boat launching facilities, and campgrounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c05201-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–6c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the admission, entrance, and recreation fees authorized to be imposed under this section shall be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77c05202-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tI/s1401"},"text":"Pub. L. 103–66, title I, § 1401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/331"},"text":"107 Stat. 331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77c05203-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77c05204-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77c05205-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agricultural Reconciliation Act of 1993 and as part of the Omnibus Budget Reconciliation Act of 1993, and not as part of the Land and Water Conservation Fund Act of 1965.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
