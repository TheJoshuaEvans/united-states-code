{"tag":"section","attrib":{"id":"id77fe4565-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460mmm–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"460mmm–7"},"text":"§ 460mmm–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public access","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fe4566-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460mmm–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall continue to allow private landowners reasonable access to inholdings in the Conservation Area and Wilderness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fe4567-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460mmm–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Glade Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall continue to allow public right of access, including commercial vehicles, to Glade Park, Colorado, in accordance with the decision in Board of County Commissioners of Mesa County v. Watt (634 F. Supp. 1265 (D.Colo.; ","children":[{"tag":"date","attrib":{"date":"1986-05-02"},"text":"May 2, 1986","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fe4568-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/353/s9"},"text":"Pub. L. 106–353, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-24"},"text":"Oct. 24, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1380"},"text":"114 Stat. 1380","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
