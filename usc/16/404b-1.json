{"tag":"section","attrib":{"id":"id773d3eeb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s404b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"404b–1"},"text":"§ 404b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of Great Onyx and Crystal Caves","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized, in his discretion, to exclude the Great Onyx Cave and the Crystal Cave, or either of them, from the maximum boundaries of the said park, and the area required for general development of the said park by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s404b"},"text":"section 404b of this title","children":[],"tail":", is modified accordingly."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id773d3eec-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-08-28/ch873/s2"},"text":"Aug. 28, 1937, ch. 873, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/871"},"text":"50 Stat. 871","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id773d3eed-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id773d3eee-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id773d3eef-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Eventual Acquisition of Great Onyx and Crystal Caves","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Eventual acquisition of Great Onyx and Crystal Caves, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s404b–2"},"text":"section 404b–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
