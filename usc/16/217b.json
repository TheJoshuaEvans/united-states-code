{"tag":"section","attrib":{"id":"id7714a856-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s217b"},"text":null,"children":[{"tag":"num","attrib":{"value":"217b"},"text":"§ 217b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abraham Lincoln Birthplace National Historical Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7714a857-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s217b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Abraham Lincoln Birthplace National Historic Site in the State of Kentucky shall be known and designated as the “Abraham Lincoln Birthplace National Historical Park”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7714a858-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s217b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in a law, map, regulation, document, paper, or other record of the United States to the Abraham Lincoln Birthplace National Historic Site shall be deemed to be a reference to the “Abraham Lincoln Birthplace National Historical Park”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7714a859-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7114"},"text":"Pub. L. 111–11, title VII, § 7114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1202"},"text":"123 Stat. 1202","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
