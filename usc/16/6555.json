{"tag":"section","attrib":{"id":"id7a12098c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6555"},"text":null,"children":[{"tag":"num","attrib":{"value":"6555"},"text":"§ 6555.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The authority provided to each Secretary under this subchapter is supplemental to, and not in lieu of, any authority provided to the Secretaries under any other law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a12098d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tIV/s405"},"text":"Pub. L. 108–148, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1911"},"text":"117 Stat. 1911","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
