{"tag":"section","attrib":{"id":"id787597fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s675"},"text":null,"children":[{"tag":"num","attrib":{"value":"675"},"text":"§ 675.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Norbeck Wildlife Preserve; establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is designated as the Norbeck Wildlife Preserve such areas, not exceeding forty-six thousand acres, of the Harney National Forest, and adjoining or in the vicinity of the Custer State Park, in the State of South Dakota, as should, in the opinion of the President of the United States, be set aside for the protection of game animals and birds, and be recognized as a breeding place therefor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id787597fe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-05/ch247/s1"},"text":"June 5, 1920, ch. 247, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/986"},"text":"41 Stat. 986","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1924-06-07/ch324"},"text":"June 7, 1924, ch. 324","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/632"},"text":"43 Stat. 632","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-06/ch620/s1"},"text":"Oct. 6, 1949, ch. 620, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/708"},"text":"63 Stat. 708","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787597ff-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78759800-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78759801-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"As enacted by act ","children":[{"tag":"date","attrib":{"date":"1920-06-05"},"text":"June 5, 1920","children":[],"tail":", this section authorized the President to designate areas not exceeding 30,000 acres, but by amendment by act "},{"tag":"date","attrib":{"date":"1924-06-07"},"text":"June 7, 1924","children":[],"tail":", the President was authorized, upon recommendation of the Secretary of Agriculture, to enlarge the area by proclamation to embrace a total of not to exceed 46,000 acres and the provisions of sections 676 to 678 of this title, apply with equal force to the additional area."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78759802-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id78759803-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Custer State Park Game Sanctuary” changed to “Norbeck Wildlife Preserve” by act ","children":[{"tag":"date","attrib":{"date":"1949-10-06"},"text":"Oct. 6, 1949","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id78759804-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id78759805-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Harney National Forest abolished and its lands transferred to and consolidated with those of Black Hills National Forest by Public Land Order No. 1016 of ","children":[{"tag":"date","attrib":{"date":"1954-10-04"},"text":"Oct. 4, 1954","children":[],"tail":", 19 F.R. 6500."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78759806-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Presidential Designation","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Areas comprising the Norbeck Wildlife Preserve, formerly known as the Custer State Park Game Sanctuary, were designated by Proclamations of ","children":[{"tag":"date","attrib":{"date":"1920-10-09"},"text":"Oct. 9, 1920","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/41/1805"},"text":"41 Stat. 1805","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1925-01-08"},"text":"Jan. 8, 1925","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/43/1981"},"text":"43 Stat. 1981","children":[],"tail":"), and "},{"tag":"date","attrib":{"date":"1929-01-14"},"text":"Jan. 14, 1929","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/45/2985"},"text":"45 Stat. 2985","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
