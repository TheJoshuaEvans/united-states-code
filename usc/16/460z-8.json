{"tag":"section","attrib":{"id":"id77d36498-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460z–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"460z–8"},"text":"§ 460z–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mining restriction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The lands within the recreation area, subject to valid existing rights, are hereby withdrawn from location, entry, and patent under the United States mining laws and from disposition under all laws pertaining to mineral leasing and all amendments thereto.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77d36499-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/260/s10"},"text":"Pub. L. 92–260, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-03-23"},"text":"Mar. 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/101"},"text":"86 Stat. 101","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
