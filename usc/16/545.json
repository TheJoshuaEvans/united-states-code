{"tag":"section","attrib":{"id":"id783ea967-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s545"},"text":null,"children":[{"tag":"num","attrib":{"value":"545"},"text":"§ 545.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mount Pleasant National Scenic Area; purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of sections 545 and 545a of this title with respect to the Mount Pleasant National Scenic Area are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id783ea968-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s545/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure appropriate protection and preservation of the scenic quality, water quality, natural characteristics, and water resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783ea969-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s545/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect and manage vegetation to provide wildlife and fish habitat, consistent with paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783ea96a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s545/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide areas that may develop characteristics of old-growth forests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783ea96b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s545/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a variety of recreation opportunities that are not inconsistent with the preceding purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id783ea96c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/314/s2"},"text":"Pub. L. 103–314, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1703"},"text":"108 Stat. 1703","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIX/s915"},"text":"Pub. L. 104–127, title IX, § 915","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1187"},"text":"110 Stat. 1187","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id783ea96d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id783ea96e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id783ea96f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" substituted “Mount Pleasant National Scenic Area” for “George Washington National Forest Mount Pleasant Scenic Area” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id783ea970-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id783ea971-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/314/s1"},"text":"Pub. L. 103–314, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1703"},"text":"108 Stat. 1703","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIX/s915"},"text":"Pub. L. 104–127, title IX, § 915","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1187"},"text":"110 Stat. 1187","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/127/tIX/s915"},"text":"“This Act [enacting sections 545 and 545a of this title] may be cited as the ‘Mount Pleasant National Scenic Area Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
