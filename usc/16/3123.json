{"tag":"section","attrib":{"id":"id79a935ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3123"},"text":null,"children":[{"tag":"num","attrib":{"value":"3123"},"text":"§ 3123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic reports","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Within four years after ","children":[{"tag":"date","attrib":{"date":"1980-12-02"},"text":"December 2, 1980","children":[],"tail":", and within every three-year period thereafter, the Secretary, in consultation with the Secretary of Agriculture, shall prepare and submit a report to the President of the Senate and the Speaker of the House of Representatives on the implementation of this subchapter. The report shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a935f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3123/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the results of the monitoring undertaken by the Secretary as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3116"},"text":"section 3116 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a935f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3123/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of fish and wildlife populations on public lands that are subject to subsistence uses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a935f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3123/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the nature and extent of subsistence uses and other uses of fish and wildlife on the public lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a935f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3123/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role of subsistence uses in the economy and culture of rural Alaska;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a935f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3123/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comments on the Secretary’s report by the State, the local advisory councils and regional advisory councils established by the Secretary or the State pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3115"},"text":"section 3115 of this title","children":[],"tail":", and other appropriate persons and organizations;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a935f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3123/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of those actions taken, or which may need to be taken in the future, to permit the opportunity for continuation of activities relating to subsistence uses on the public lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a935f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3123/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other recommendations the Secretary deems appropriate.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A notice of the report shall be published in the Federal Register and the report shall be made available to the public.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a935f7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487/tVIII/s813"},"text":"Pub. L. 96–487, title VIII, § 813","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2428"},"text":"94 Stat. 2428","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a935f8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a935f9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79a935fa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in this section relating to submitting, within every three-year period, a report on the implementation of this subchapter to the President of the Senate and the Speaker of the House of Representatives, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 112 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
