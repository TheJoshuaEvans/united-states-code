{"tag":"section","attrib":{"id":"id77fe4489-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–47"},"text":"§ 460lll–47.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fe448a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fe448b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hiring","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3503"},"text":"section 3503 of title 5","children":[],"tail":", and subject to paragraph (2), the Secretary may—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77fe448c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint, hire, and discharge officers and employees to administer the Recreation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fe448d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay the officers and employees at levels that are commensurate with levels at other units of the National Forest System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe448e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim retention of eligible employees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77fe448f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a period of not less than 5 months after the effective date of transfer to the Forest Service—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77fe4490-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all eligible employees shall be retained in the employment of the Tennessee Valley Authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77fe4491-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those eligible employees shall be considered to be placed on detail to the Secretary and shall be subject to the direction of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77fe4492-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall reimburse the Tennessee Valley Authority for the amount of the basic pay and all other compensation of those eligible employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fe4493-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide eligible employees a written notice of not less than 60 days before termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fe4494-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination for cause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) does not preclude a termination for cause during the period described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fe4495-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications for transfer and appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible employee shall have the right to apply for employment by the Secretary under procedures for transfer and appointment of Federal employees outside the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fe4496-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hiring by Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fe4497-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), in filling personnel positions within the Recreation Area, the Secretary shall follow all laws (including regulations) and policies applicable to the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe4498-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification and hiring","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1), the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77fe4499-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall notify all eligible employees of all openings for positions with the Forest Service at the Recreation Area before notifying other individuals or considering applications by other individuals for the positions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fe449a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after applications by eligible employees have received consideration, if any positions remain unfilled, shall notify other individuals of the openings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe449b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompetitive appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other placement of career transition programs authorized by the Office of Personnel Management of the United States Department of Agriculture, the Secretary may noncompetitively appoint eligible employees to positions in the Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe449c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except to the extent that an eligible employee that is appointed by the Secretary may be otherwise compensated for the period of service as an employee of the Tennessee Valley Authority, that period of service shall be treated as a period of service as an employee of the Secretary for the purposes of probation, career tenure, time-in-grade, and leave.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fe449d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer to positions in other units of Tennessee Valley Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Tennessee Valley Authority—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fe449e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall notify all eligible employees of all openings for positions in other units of the Tennessee Valley Authority before notifying other individuals or considering applications by other individuals for the positions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe449f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after applications by eligible employees have received consideration, if any positions remain unfilled, shall notify other individuals of the openings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fe44a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee benefit transition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fe44a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memorandum of understanding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77fe44a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the heads of the Office of Personnel Management, the Tennessee Valley Authority and the Tennessee Valley Authority Retirement System shall enter into a memorandum of understanding providing for the transition for all eligible employees of compensation made available through the Tennessee Valley Authority Retirement System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fe44a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In deciding on the terms of the memorandum of understanding, the Secretary and the heads of the Office of Personnel Management, the Tennessee Valley Authority and the Tennessee Valley Authority Retirement System shall meet and consult with and give full consideration to the views of employees and representatives of the employees of the Tennessee Valley Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe44a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible employees that are transferred to other units of TVA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible employee that is transferred to another unit of the Tennessee Valley Authority shall experience no interruption in coverage for or reduction of any retirement, health, leave, or other employee benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe44a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible employees that are hired by the Secretary","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77fe44a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Level of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide to an eligible employee that is hired by the Forest Service a level of retirement and health benefits that is equivalent to the level to which the eligible employee would have been entitled if the eligible employee had remained an employee of the Tennessee Valley Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fe44a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of retirement benefits","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77fe44a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Eligible employees hired by the Forest Service shall become members of the Civil Service Retirement System (CSRS) Offset Plan and shall have the option to transfer into the Federal Employees Retirement System (FERS) within six months of their date of transfer. Such employees shall have the option at any time to receive credit in CSRS Offset or FERS for all of their TVA service in accordance with applicable procedures. Any deposits necessary to receive credit for such service shall be considered transfers to a qualified plan for purposes of favorable tax treatment of such amount under title 26.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77fe44a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding shortfall","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id77fe44aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For all eligible employees that are not part of the Civil Service Retirement System, the Tennessee Valley Authority shall meet any funding shortfall resulting from the transfer of retirement benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77fe44ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall notify the Tennessee Valley Authority Board of the cost associated with the transfer of retirement benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77fe44ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/3/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Tennessee Valley Authority shall fully compensate the Secretary for the costs associated with the transfer of retirement benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77fe44ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/3/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No interruption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible employee that is hired by the Forest Service and is eligible for Civil Service Retirement shall not experience any interruption in retirement benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fe44ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No interruption","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible employee that is hired by the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77fe44af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall experience no interruption in coverage for any health, leave, or other employee benefit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77fe44b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be entitled to carry over any leave time accumulated during employment by the Tennessee Valley Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fe44b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8411/b/3"},"text":"section 8411(b)(3) of title 5","children":[],"tail":", except to the extent that an eligible employee may be otherwise compensated (including the provision of retirement benefits in accordance with the memorandum of understanding) for the period of service as an employee of the Tennessee Valley Authority, that period of service shall be treated as a period of service as an employee of the U.S. Department of Agriculture for all purposes relating to the Federal employment of the eligible employee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe44b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible employees that are discharged not for cause","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77fe44b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Level of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The parties to the memorandum of understanding shall have authority to deem any applicable requirement to be met, to make payments to an employee, or take any other action necessary to provide to an eligible employee that is discharged as being excess to the needs of the Tennessee Valley Authority or the Secretary and not for cause and that does not accept an offer of employment from the Secretary, an optimum level of retirement and health benefits that is equivalent to the level that has been afforded employees discharged in previous reductions in force by the Tennessee Valley Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fe44b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible employee that is discharged as being excess to the needs of the Tennessee Valley Authority or the Secretary and not for cause shall, at a minimum be entitled to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77fe44b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at the option of the eligible employee—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id77fe44b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lump-sum equal to $1,000, multiplied by the number of years of service of the eligible employee (but not less that $15,000 nor more than $25,000);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77fe44b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lump-sum payment equal to the amount of pay earned by the eligible employee for the last 26 weeks of the eligible employee’s service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77fe44b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/4/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deemed addition of 5 years to the age and the years of service of an eligible employee;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77fe44b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 15 months of health benefits for employees and dependents at the same level provided as of the date of transfer pursuant to section 460","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–41 of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77fe44ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 week of pay per year of service as provided by the Tennessee Valley Authority Retirement System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77fe44bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lump-sum payment of all accumulated annual leave;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77fe44bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unemployment compensation in accordance with State law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77fe44bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/4/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible pension benefits as provided by the Tennessee Valley Authority Retirement System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77fe44be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/4/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retraining assistance provided by the Tennessee Valley Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fe44bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–47/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shortfall","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the board of directors of the Tennessee Valley Authority Retirement System determines that the cost of providing the benefits described in subparagraphs (A) and (B) would have a negative impact on the overall retirement system, the Tennessee Valley Authority shall be required to meet any funding shortfalls.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fe44c0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s547"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 547]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–321.)"}],"tail":"\n"}],"tail":null}
