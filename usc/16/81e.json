{"tag":"section","attrib":{"id":"id76ff24a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s81e"},"text":null,"children":[{"tag":"num","attrib":{"value":"81e"},"text":"§ 81e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property; condemnation proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to accept donations of land, interest in land, buildings, structures, and other property within the boundaries of said park as determined and fixed hereunder and donations of funds for the purchase and/or maintenance thereof, the evidence of title to such lands to be satisfactory to the Secretary of the Interior: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That he may acquire on behalf of the United States by purchase when purchasable at prices deemed by him reasonable, otherwise by condemnation under the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"section 3113 of title 40","children":[],"tail":", such tracts of land within the said park as may be necessary for the completion thereof: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That condemnation proceedings herein provided for shall not be had, exercised, or resorted to as to lands belonging to the Association for the Preservation of Virginia Antiquities, a corporation chartered under the laws of Virginia, or to the city of Williamsburg, Virginia, or to any other lands in said city except such lands as may be required for a right-of-way not exceeding two hundred feet in width through the city of Williamsburg to connect with highways or parkways leading from Williamsburg to Jamestown and to Yorktown."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76ff24a8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-07-03/ch837/s3"},"text":"July 3, 1930, ch. 837, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/856"},"text":"46 Stat. 856","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-05/ch525/s2"},"text":"June 5, 1936, ch. 525, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1483"},"text":"49 Stat. 1483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id76ff24a9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id76ff24aa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id76ff24ab-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"Section 3113 of title 40","children":[],"tail":"” substituted in text for “the Act of "},{"tag":"date","attrib":{"date":"1888-08-01"},"text":"August 1, 1888","children":[],"tail":" (U.S.C., title 40, secs. 257, 258; "},{"tag":"ref","attrib":{"href":"/us/stat/25/357"},"text":"25 Stat. 357","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s443b"},"text":"section 443b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id76ff24ac-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id76ff24ad-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1936-06-05"},"text":"June 5, 1936","children":[],"tail":", changed “Colonial National Monument” to “Colonial National Historical Park.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
