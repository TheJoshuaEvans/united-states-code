{"tag":"section","attrib":{"id":"id7797ba9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430uu–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"430uu–2"},"text":"§ 430uu–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of land; exclusion from Beaverhead National Forest; administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7797ba9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430uu–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior may acquire by donation, purchase, exchange, or otherwise, lands and interests in lands within the area described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s430uu–1"},"text":"section 430uu–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7797ba9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430uu–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any lands described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s430uu–1"},"text":"section 430uu–1 of this title","children":[],"tail":" that are a part of the Beaverhead National Forest on "},{"tag":"date","attrib":{"date":"1963-05-17"},"text":"May 17, 1963","children":[],"tail":", are hereby excluded from the forest and added to the Big Hole National Battlefield."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7797ba9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430uu–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lands included in the Big Hole National Battlefield pursuant to sections 430uu to 430uu–4 of this title shall be administered in accordance with the pr