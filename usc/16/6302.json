{"tag":"section","attrib":{"id":"id7a062307-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302"},"text":null,"children":[{"tag":"num","attrib":{"value":"6302"},"text":"§ 6302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a062308-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CITES","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “CITES” means the Convention on International Trade in Endangered Species of Wild Fauna and Flora, done at Washington ","children":[{"tag":"date","attrib":{"date":"1973-03-03"},"text":"March 3, 1973","children":[],"tail":" (27 UST 1087; TIAS 8249), including its appendices."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a062309-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “conservation”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a06230a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means the use of methods and procedures necessary to prevent the diminution of, and to sustain viable populations of, a species; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a06230b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes all activities associated with wildlife management, such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a06230c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conservation, protection, restoration, acquisition, and management of habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a06230d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in-situ research and monitoring of populations and habitats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a06230e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in the development, implementation, and improvement of management plans for managed habitat ranges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a06230f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforcement and implementation of CITES;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a062310-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforcement and implementation of domestic laws relating to resource management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a062311-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and operation of sanctuaries for members of a species rescued from the illegal trade in live animals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a062312-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training of local law enforcement officials in the interdiction and prevention of the illegal killing of great apes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a062313-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs for the rehabilitation of members of a species in the wild and release of the members into the wild in ways which do not threaten existing wildlife populations by causing displacement or the introduction of disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a062314-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/2/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conflict resolution initiatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a062315-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/2/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community outreach and education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a062316-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/2/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening the capacity of local communities to implement conservation programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a062317-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Fund” means the Great Ape Conservation Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6304"},"text":"section 6304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a062318-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great ape","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “great ape” means a chimpanzee, gorilla, bonobo, orangutan, or gibbon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a062319-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multinational Species Conservation Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Multinational Species Conservation Fund” means such fund as established in title I of the Department of the Interior and Related Agencies Appropriations Act, 1999, under the heading “","children":[{"tag":"inline","attrib":{},"text":"multinational species conservation fund","children":[],"tail":"” ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4246"},"text":"16 U.S.C. 4246","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a06231a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6302/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a06231b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/411/s3"},"text":"Pub. L. 106–411, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1790"},"text":"114 Stat. 1790","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a06231c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a06231d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a06231e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title I of the Department of the Interior and Related Agencies Appropriations Act, 1999, referred to in par. (5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tI"},"text":"Pub. L. 105–277, div. A, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–232. Provisions under the heading “"},{"tag":"inline","attrib":{},"text":"multinational species conservation fund","children":[],"tail":"” in "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/e/tI"},"text":"Pub. L. 105–277, § 101(e) [title I]","children":[],"tail":" appear at "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-237"},"text":"112 Stat. 2681–237","children":[],"tail":", and are classified in part to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4246"},"text":"section 4246 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
