{"tag":"section","attrib":{"id":"id77c2c31b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–34"},"text":null,"children":[{"tag":"num","attrib":{"value":"460l–34"},"text":"§ 460l–34.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of authorized purposes of reclamation projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77c2c31c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–34/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this part shall be construed to change, modify, or expand the authorized purposes of any Reclamation project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c2c31d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–34/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The expansion or modification of a recreational facility constructed under this part shall not increase the capital repayment responsibilities or operation and maintenance expenses of the beneficiaries of authorized purposes of the associated Reclamation project. The term “beneficiaries” does not include those entities who sign agreements or enter into contracts for recreation facilities pursuant to the Federal Water Project Recreation Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460"},"text":"16 U.S.C. 460","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–12 et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77c2c31e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXXVIII/s2806"},"text":"Pub. L. 102–575, title XXVIII, § 2806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4693"},"text":"106 Stat. 4693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77c2c31f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77c2c320-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77c2c321-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in text, was in the original “this title”, meaning title XXVIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575"},"text":"Pub. L. 102–575","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4690"},"text":"106 Stat. 4690","children":[],"tail":", which enacted sections 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–31 to 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–34 of this title and amended sections 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–13 to 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–15 and 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–18 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Water Project Recreation Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/72"},"text":"Pub. L. 89–72","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-09"},"text":"July 9, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/213"},"text":"79 Stat. 213","children":[],"tail":", which is classified principally to part C (§ 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–12 et seq.) of this subchapter. For complete classification of this Act to the Code, see Short Title note set out under section 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–12 of this title and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
