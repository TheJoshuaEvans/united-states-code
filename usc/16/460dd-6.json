{"tag":"section","attrib":{"id":"id77da8faa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dd–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"460dd–6"},"text":"§ 460dd–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Easements and rights-of-way","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall grant easements and rights-of-way on a nondiscriminatory basis upon, over, under, across, or along any component of the recreation area unless he finds that the route of such easements and rights-of-way would have significant adverse effects on the administration of the recreation area.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77da8fab-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/593/s7"},"text":"Pub. L. 92–593, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1312"},"text":"86 Stat. 1312","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
