{"tag":"section","attrib":{"id":"id7a1df130-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873"},"text":null,"children":[{"tag":"num","attrib":{"value":"6873"},"text":"§ 6873.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data consolidation and publication","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1df131-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal waterway restrictions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2025-12-26"},"text":"December 26, 2025","children":[],"tail":", each of the Secretaries, to the maximum extent practicable, shall digitize and make publicly available online, as applicable, geographic information system data that includes, with respect to Federal waterway restrictions—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1df132-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" status information with respect to the conditions under which Federal waterways are open or closed to entry or watercraft, including watercraft inspection, decontamination requirements, low-elevation aircraft, or diving;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df133-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dates on which Federal waterways are seasonally closed to entry or watercraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df134-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the areas of Federal waterways with restrictions on motorized propulsion, horsepower, or fuel type;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df135-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the areas of Federal waterways with anchoring restrictions, no wake zones, exclusion zones, danger areas, or vessel speed restrictions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df136-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal waterway restrictions on the direction of travel, including upstream or downstream travel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df137-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the uses, including by watercraft, that are restricted on each area of a Federal waterway, including the permissibility of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1df138-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" canoes and other paddlecraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df139-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rafts and driftboats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df13a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motorboats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df13b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal watercraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df13c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" airboats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df13d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amphibious aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df13e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hovercraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df13f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversnow vehicles and other motorized vehicles on frozen bodies of water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df140-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a/6/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oceangoing ships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df141-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a/6/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" swimming; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df142-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/a/6/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other applicable recreational activities, as determined to be appropriate by the Secretaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1df143-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal waterway access and navigation information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2025-12-26"},"text":"December 26, 2025","children":[],"tail":", each of the Secretaries, to the maximum extent practicable, shall digitize and make publicly available online, as applicable, geographic information system data that includes, with respect to Federal waterway access and navigation information—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1df144-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1df145-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of boat ramps, portages, and fishing access sites under the authority of the Federal land or water management agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df146-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of the dates on which the facilities and sites identified under subparagraph (A) are open or closed, as applicable; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df147-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bathymetric information and depth charts, as feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1df148-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal fishing restrictions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2025-12-26"},"text":"December 26, 2025","children":[],"tail":", each of the Secretaries, to the maximum extent practicable, shall digitize and make publicly available online geographic information system data that describes, with respect to Federal fishing restrictions—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a206149-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the location and geographic boundaries of Federal fishing restrictions on recreational and commercial fishing, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a20614a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full or partial closures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a20614b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no-take zones; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a20614c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal fishing restrictions within or surrounding marine protected areas;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a20614d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal fishing restrictions on the use of specific types of equipment or bait; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a20614e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal requirements with respect to catch and release.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a20614f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries shall develop a process to allow members of the public to submit questions or comments regarding the information described in subsections (a) and (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a206150-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries, to the maximum extent practicable, shall update—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a206151-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the data described in subsections (a) and (b) not less frequently than 2 times per year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a206152-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the data described in subsection (c) in real time as changes go into effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a206153-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to irrigation canals and flowage easements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a206154-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6873/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any geographic information system data made publicly available under this section shall not disclose information regarding the nature, location, character, or ownership of historic, paleontological, or archaeological resources, consistent with applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a206155-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/62/s4"},"text":"Pub. L. 119–62, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1980"},"text":"139 Stat. 1980","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
