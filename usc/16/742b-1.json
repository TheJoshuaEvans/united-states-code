{"tag":"section","attrib":{"id":"id788af412-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s742b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"742b–1"},"text":"§ 742b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Director for Wildlife and Sport Fish Restoration Programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id788af413-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s742b–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the United States Fish and Wildlife Service of the Department of the Interior the position of Assistant Director for Wildlife and Sport Fish Restoration Programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id788af414-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s742b–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Superior","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Director for Wildlife and Sport Fish Restoration Programs shall report directly to the Director of the United States Fish and Wildlife Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id788af415-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s742b–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Director for Wildlife and Sport Fish Restoration Programs shall be responsible for the administration, management, and oversight of the Federal Assistance Program for State Wildlife and Sport Fish Restoration under the Pittman-Robertson Wildlife Restoration Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s669"},"text":"16 U.S.C. 669","children":[],"tail":" et seq.) and the Dingell-Johnson Sport Fish Restoration Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s777"},"text":"16 U.S.C. 777","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id788af416-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/408/tI/s132"},"text":"Pub. L. 106–408, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1775"},"text":"114 Stat. 1775","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788af417-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788af418-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id788af419-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Pittman-Robertson Wildlife Restoration Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-02/ch899"},"text":"act Sept. 2, 1937, ch. 899","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/917"},"text":"50 Stat. 917","children":[],"tail":", also known as the Federal Aid in Wildlife Restoration Act, which is classified generally to chapter 5B (§ 669 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s669"},"text":"section 669 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Dingell-Johnson Sport Fish Restoration Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-09/ch658"},"text":"act Aug. 9, 1950, ch. 658","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/430"},"text":"64 Stat. 430","children":[],"tail":", also known as the Federal Aid in Fish Restoration Act and the Fish Restoration and Management Projects Act, which is classified generally to chapter 10B (§ 777 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s777"},"text":"section 777 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
