{"tag":"section","attrib":{"id":"id774b6f76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410x"},"text":null,"children":[{"tag":"num","attrib":{"value":"410x"},"text":"§ 410x.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums, but not more than $13,900,000, as may be needed for the acquisition of lands and interests in lands and for development of the Minute Man National Historical Park, of which not more than $10,900,000 shall be used for acquisition purposes, and in addition thereto, such sums as may be needed for its administration and maintenance. For fiscal years after fiscal year 1991, there is authorized to be appropriated an additional $15,000,000 for development and an additional $7,300,000 for acquisition of lands and interests in lands.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id774b6f77-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/321/s6"},"text":"Pub. L. 86–321, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-21"},"text":"Sept. 21, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/592"},"text":"73 Stat. 592","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/548/s2"},"text":"Pub. L. 91–548, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-14"},"text":"Dec. 14, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1437"},"text":"84 Stat. 1437","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/488/s2/4/s3"},"text":"Pub. L. 102–488, § 2(4)[(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3136"},"text":"106 Stat. 3136","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id774b6f78-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id774b6f79-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id774b6f7a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/488"},"text":"Pub. L. 102–488","children":[],"tail":" inserted at end “For fiscal years after fiscal year 1991, there is authorized to be appropriated an additional $15,000,000 for development and an additional $7,300,000 for acquisition of lands and interests in lands.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/548"},"text":"Pub. L. 91–548","children":[],"tail":" substituted “$13,900,000” for “$8,000,000” and “$10,900,000” for “$5,000,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
