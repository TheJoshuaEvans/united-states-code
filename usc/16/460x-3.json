{"tag":"section","attrib":{"id":"id77cea9c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460x–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"460x–3"},"text":"§ 460x–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sleeping Bear Dunes National Lakeshore Advisory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77cea9c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460x–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established a Sleeping Bear Dunes National Lakeshore Advisory Commission. The Commission shall cease to exist twenty years after the establishment of the lakeshore pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460x–1"},"text":"section 460x–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77cea9c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460x–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership; appointment; term of office; recommendation or designation of appointees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall be composed of ten members, each appointed for a term of two years by the Secretary, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77cea9c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460x–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four members to be appointed from recommendations made by the counties in which the lakeshore is situated, two members to represent each such county;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cea9c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460x–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four members to be appointed from recommendations made by the Governor of the State of Michigan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cea9c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460x–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members to be designated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77cea9c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460x–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman; vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate one member to be Chairman. Any vacancy in the Commission shall be filled in the same manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77cea9c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460x–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and expenses; vouchers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Commission shall serve without compensation as such. The Secretary is authorized to pay the expenses reasonably incurred by the Commission in carrying out its responsibilities under this subchapter on vouchers signed by the Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77cea9c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460x–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation of Secretary with Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or his designee shall consult with the Commission with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77cea9ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460x–3/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" matters relating to the development of the lakeshore and with respect to the provisions of sections 460x–8, 460x–11, and 460x–12 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cea9cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460x–3/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" matters relating to the implementation of the General Management Plan provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460x–5/b"},"text":"section 460x–5(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77cea9cc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/479/s4"},"text":"Pub. L. 91–479, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-21"},"text":"Oct. 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1076"},"text":"84 Stat. 1076","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/558"},"text":"Pub. L. 100–558","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-28"},"text":"Oct. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2796"},"text":"102 Stat. 2796","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77cea9cd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77cea9ce-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77cea9cf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/558/s1/1"},"text":"Pub. L. 100–558, § 1(1)","children":[],"tail":", substituted “twenty” for “ten”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/558/s1/2"},"text":"Pub. L. 100–558, § 1(2)","children":[],"tail":", amended subsec. (e) generally, designating existing provisions as par. (1) and adding par. (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
