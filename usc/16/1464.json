{"tag":"section","attrib":{"id":"id7942ab95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1464"},"text":null,"children":[{"tag":"num","attrib":{"value":"1464"},"text":"§ 1464.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7942ab96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1464/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sums appropriated to Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary, to remain available until expended—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7942ab97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1464/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for grants under sections 1455, 1455a, and 1456b of this title—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7942ab98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1464/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $47,600,000 for fiscal year 1997;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ab99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1464/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $49,000,000 for fiscal year 1998; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ab9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1464/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,500,000 for fiscal year 1999; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942ab9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1464/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1461"},"text":"section 1461 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7942ab9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1464/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,400,000 for fiscal year 1997;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ab9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1464/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,500,000 for fiscal year 1998; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ab9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1464/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,600,000 for fiscal year 1999.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942ab9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1464/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal funds received from other sources shall not be used to pay a coastal state’s share of costs under section 1455 or 1456b of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942aba0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1464/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reversion to Secretary of unobligated State funds; availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any grant, or portion of a grant, made to a State under any section of this chapter which is not obligated by such State during the fiscal year, or during the second fiscal year after the fiscal year, for which it was first authorized to be obligated by such State shall revert to the Secretary. The Secretary shall add such reverted amount to those funds available for grants under the section for such reverted amount was originally made available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7942aba1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454/tIII/s318"},"text":"Pub. L. 89–454, title III, § 318","children":[],"tail":", formerly § 315, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/583"},"text":"Pub. L. 92–583","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1289"},"text":"86 Stat. 1289","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/612/s1/3"},"text":"Pub. L. 93–612, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1974"},"text":"88 Stat. 1974","children":[],"tail":"; renumbered § 318 and amended "},{"tag":"