{"tag":"section","attrib":{"id":"id7a03b232-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6105"},"text":null,"children":[{"tag":"num","attrib":{"value":"6105"},"text":"§ 6105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Secretary","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out this chapter, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a03b233-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6105/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop guidelines for the solicitation of proposals for projects eligible for financial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6104"},"text":"section 6104 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b234-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6105/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage submission of proposals for projects eligible for financial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6104"},"text":"section 6104 of this title","children":[],"tail":", particularly proposals from relevant wildlife management authorities;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b235-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6105/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select proposals for financial assistance that satisfy the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6104"},"text":"section 6104 of this title","children":[],"tail":", giving preference to proposals that address conservation needs not adequately addressed by existing efforts and that are supported by relevant wildlife management authorities; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b236-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6105/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generally implement this chapter in accordance with its purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a03b237-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/247/s6"},"text":"Pub. L. 106–247, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-20"},"text":"July 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/595"},"text":"114 Stat. 595","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
