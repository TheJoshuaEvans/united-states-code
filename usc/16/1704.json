{"tag":"section","attrib":{"id":"id795cea3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1704"},"text":null,"children":[{"tag":"num","attrib":{"value":"1704"},"text":"§ 1704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id795cea40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects for preservation of non-Federal public lands and waters; “States” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior and the Secretary of Agriculture shall jointly establish a program under which grants shall be made to States to assist them in meeting the cost of projects for the employment of young men and women to develop, preserve, and maintain non-Federal public lands and waters within the States. For purposes of this section, the term “States” includes the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, the Trust Territory of the Pacific Islands, and American Samoa.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795cea41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirements for grants; approval by Secretaries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795cea42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No grant may be made under this section unless an application therefor has been submitted to, and approved by, the Secretary of the Interior and the Secretary of Agriculture. Such application shall be in such form, and submitted in such manner, as the Secretaries shall jointly by regulation prescribe, and shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id795cea43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1704/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances satisfactory to the Secretaries that individuals employed under the project for which the application is submitted shall (i) have attained the age of fifteen but not attained the age of nineteen, (ii) be permanent residents of the United States or its territories, possessions, or the Trust Territory of the Pacific Islands, (iii) be employed without regard to the personnel laws, rules, and regulations applicable to full-time employees of the applicant, (iv) be employed for a period of not more than ninety days in any calendar year, and (v) be employed without regard to their sex or social, economic, or racial classification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795cea44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1704/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretaries may jointly by regulation prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretaries may approve applications which they determine (A) to meet the requirements of paragraph (1), and (B) are for projects which will further the development, preservation, or maintenance of non-Federal public lands or waters within the jurisdiction of the applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795cea46-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on the amount of grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795cea47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1704/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of any grant under this section shall be determined jointly by the Secretaries, except that no grant for any project may exceed 80 per centum of the cost (as determined by the Secretaries) of such project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments under grants under this section may be made in advance or by way of reimbursement and at such intervals and on such conditions as the Secretaries find necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795cea49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Thirty per centum of the sums appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1706"},"text":"section 1706 of this title","children":[],"tail":" for any fiscal year shall be made available for grants under this section for such fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id795cea4a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/378/tI/s104"},"text":"Pub. L. 91–378, title I, § 104","children":[],"tail":", formerly § 4, "},{"tag":"date","attrib":{"date":"1970-08-13"},"text":"Aug. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/796"},"text":"84 Stat. 796","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/597"},"text":"Pub. L. 92–597","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1320"},"text":"86 Stat. 1320","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/408"},"text":"Pub. L. 93–408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-03"},"text":"Sept. 3, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1067"},"text":"88 Stat. 1067","children":[],"tail":"; renumbered title I, § 104, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s105/1"},"text":"Pub. L. 103–82, title I, § 105(1)","children":[],"tail":", (3), (5), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/848"},"text":"107 Stat. 848","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795cea4b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id795cea4c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id795cea4d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s105/5"},"text":"Pub. L. 103–82, § 105(5)","children":[],"tail":", made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1706"},"text":"section 1706 of this title","children":[],"tail":" to reflect renumbering of corresponding section of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/408"},"text":"Pub. L. 93–408","children":[],"tail":" substituted “jointly establish a program” for “jointly establish a pilot grant program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/579"},"text":"Pub. L. 92–579","children":[],"tail":" substituted provisions relating to pilot grant program for State projects for provisions relating to Secretarial reports."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id795cea4e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id795cea4f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id795cea50-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id795cea51-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
