{"tag":"section","attrib":{"id":"id7a147aed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e"},"text":null,"children":[{"tag":"num","attrib":{"value":"6591e"},"text":"§ 6591e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Categorical exclusion for greater sage-grouse and mule deer habitat","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a147aee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a147aef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered vegetation management activity","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a147af0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered vegetation management activity” means any activity described in subparagraph (B) that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a147af1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a147af2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is carried out on National Forest System land administered by the Forest Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a147af3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is carried out on public land administered by the Bureau of Land Management;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147af4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to public land, meets the objectives of the order of the Secretary of the Interior numbered 3336 and dated ","children":[{"tag":"date","attrib":{"date":"2015-01-05"},"text":"January 5, 2015","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147af5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conforms to an applicable forest plan or land use plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147af6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" protects, restores, or improves greater sage-grouse or mule deer habitat in a sagebrush steppe ecosystem as described in—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a147af7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Circular 1416 of the United States Geological Survey entitled “Restoration Handbook for Sagebrush Steppe Ecosystems with Emphasis on Greater Sage-Grouse Habitat—Part 1. Concepts for Understanding and Applying Restoration” (2015); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a147af8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the habitat guidelines for mule deer published by the Mule Deer Working Group of the Western Association of Fish and Wildlife Agencies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147af9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" will not permanently impair—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a147afa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the natural state of the treated area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a147afb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outstanding opportunities for solitude;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a147afc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/v/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outstanding opportunities for primitive, unconfined recreation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a147afd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/v/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic opportunities consistent with multiple-use management; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a147afe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/v/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identified values of a unit of the National Landscape Conservation System;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147aff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a147b00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/vi/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restores native vegetation following a natural disturbance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a147b01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/vi/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prevents the expansion into greater sage-grouse or mule deer habitat of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7a147b02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/vi/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" juniper, pinyon pine, or other associated conifers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a147b03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/vi/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonnative or invasive vegetation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a147b04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/vi/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces the risk of loss of greater sage-grouse or mule deer habitat from wildfire or any other natural disturbance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a147b05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/vi/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides emergency stabilization of soil resources after a natural disturbance; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides for the conduct of restoration treatments that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a147b07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/vii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximize the retention of old-growth and large trees, as appropriate for the forest type;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a147b08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/vii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the best available scientific information to maintain or restore the ecological integrity, including maintaining or restoring structure, function, composition, and connectivity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a147b09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/vii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are developed and implemented through a collaborative process that—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7a147b0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/vii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes multiple interested persons representing diverse interests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a147b0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/vii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"subitem","attrib":{"id":"id7a147b0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/vii/III/bb/AA"},"text":null,"children":[{"tag":"num","attrib":{"value":"AA"},"text":"(AA)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is transparent and nonexclusive; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subitem","attrib":{"id":"id7a147b0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/vii/III/bb/BB"},"text":null,"children":[{"tag":"num","attrib":{"value":"BB"},"text":"(BB)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements for a resource advisory committee under subsections (c) through (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7125"},"text":"section 7125 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a147b0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/A/vii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include the implementation of a proposal that complies with the eligibility requirements of the Collaborative Forest Landscape Restoration Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7303/b"},"text":"section 7303(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147b0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An activity referred to in subparagraph (A) is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a147b10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manual cutting and removal of juniper trees, pinyon pine trees, other associated conifers, or other nonnative or invasive vegetation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mechanical mastication, cutting, or mowing, mechanical piling and burning, chaining, broadcast burning, or yarding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" removal of cheat grass, medusa head rye, or other nonnative, invasive vegetation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collection and seeding or planting of native vegetation using a manual, mechanical, or aerial method;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seeding of nonnative, noninvasive, ruderal vegetation only for the purpose of emergency stabilization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" targeted use of an herbicide, subject to the condition that the use shall be in accordance with applicable legal requirements, Federal agency procedures, and land use plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" targeted livestock grazing to mitigate hazardous fuels and control noxious and invasive weeds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" temporary removal of wild horses or burros in the area in which the activity is being carried out to ensure treatment objectives are met;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in coordination with the affected permit holder, modification or adjustment of permissible usage under an annual plan of use of a grazing permit issued by the Secretary concerned to achieve restoration treatment objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" installation of new, or modification of existing, fencing or water sources intended to control use or improve wildlife habitat; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary maintenance of, repairs to, rehabilitation of, or reconstruction of an existing permanent road or construction of temporary roads to accomplish the activities described in this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147b1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered vegetation management activity” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a147b1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity conducted in a wilderness area or wilderness study area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity for the construction of a permanent road or permanent trail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity conducted on Federal land on which, by Act of Congress or Presidential proclamation, the removal of vegetation is restricted or prohibited;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity conducted in an area in which activities under subparagraph (B) would be inconsistent with the applicable land and resource management plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity conducted in an inventoried roadless area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a147b21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary concerned","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretary concerned” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a147b22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, with respect to National Forest System land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147b23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior, with respect to public land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a147b24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary road","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “temporary road” means a road that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a147b25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" authorized—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a147b26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a contract, permit, lease, other written authorization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to an emergency operation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147b28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not intended to be part of the permanent transportation system of a Federal department or agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147b29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not necessary for long-term resource management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147b2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" designed in accordance with standards appropriate for the intended use of the road, taking into consideration—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a147b2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b2d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impacts to land and resources; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147b2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" managed to minimize—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a147b2f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" erosion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b30-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/a/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the introduction or spread of invasive species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a147b31-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Categorical exclusion","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a147b32-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary concerned shall develop a categorical exclusion (as defined in section 1508.4 of title 40, Code of Federal Regulations (or a successor regulation)) for covered vegetation management activities carried out to protect, restore, or improve habitat for greater sage-grouse or mule deer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a147b33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing and administering the categorical exclusion under paragraph (1), the Secretary concerned shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a147b34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147b35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to National Forest System land, apply the extraordinary circumstances procedures under section 220.6 of title 36, Code of Federal Regulations (or successor regulations), in determining whether to use the categorical exclusion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147b36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to public land, apply the extraordinary circumstances procedures under section 46.215 of title 43, Code of Federal Regulations (or successor regulations), in determining whether to use the categorical exclusion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147b37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a147b38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative efficacy of landscape-scale habitat projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the likelihood of continued declines in the populations of greater sage-grouse and mule deer in the absence of landscape-scale vegetation management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b3a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for habitat restoration activities after wildfire or other natural disturbances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a147b3b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of covered vegetative management activities within the range of greater sage-grouse and mule deer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the categorical exclusion developed under subsection (b) is used to implement a covered vegetative management activity in an area within the range of both greater sage-grouse and mule deer, the covered vegetative management activity shall protect, restore, or improve habitat concurrently for both greater sage-grouse and mule deer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a147b3c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term monitoring and maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before commencing any covered vegetation management activity that is covered by the categorical exclusion under subsection (b), the Secretary concerned shall develop a long-term monitoring and maintenance plan, covering at least the 20-year period beginning on the date of commencement, to ensure that management of the treated area does not degrade the habitat gains secured by the covered vegetation management activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a147b3d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of vegetative material","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to applicable local restrictions, any vegetative material resulting from a covered vegetation management activity that is covered by the categorical exclusion under subsection (b) may be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a147b3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" used for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a147b3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fuel wood; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147b40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other products; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a147b41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" piled or burned, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a147b42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment for temporary roads","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a147b43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (a)(1)(B)(xi), any temporary road constructed in carrying out a covered vegetation management activity that is covered by the categorical exclusion under subsection (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a147b44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be used by the Secretary concerned for the covered vegetation management activity for not more than 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147b45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be decommissioned by the Secretary concerned not later than 3 years after the earlier of the date on which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a147b46-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the temporary road is no longer needed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147b47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project is completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a147b48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A treatment under paragraph (1) shall include reestablishing native vegetative cover—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a147b49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as soon as practicable; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147b4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 10 years after the date of completion of the applicable covered vegetation management activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a147b4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a147b4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project size","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered vegetation management activity that is covered by the categorical exclusion under subsection (b) may not exceed 4,500 acres.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a147b4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591e/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered vegetation management activity carried out on National Forest System land that is covered by the categorical exclusion under subsection (b) shall be limited to areas designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6591a/b"},"text":"section 6591a(b) of this title","children":[],"tail":", as of "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail