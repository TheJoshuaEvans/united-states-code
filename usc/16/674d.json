{"tag":"section","attrib":{"id":"id787597fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s674d"},"text":null,"children":[{"tag":"num","attrib":{"value":"674d"},"text":"§ 674d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated out of any moneys in the Treasury not otherwise appropriated such sums as Congress shall from time to time deem necessary to carry out the purposes of sections 674a to 674c of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id787597fc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1931-03-03/ch439/s4"},"text":"Mar. 3, 1931, ch. 439, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1510"},"text":"46 Stat. 1510","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
