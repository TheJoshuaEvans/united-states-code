{"tag":"section","attrib":{"id":"id79f7cc12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002"},"text":null,"children":[{"tag":"num","attrib":{"value":"5002"},"text":"§ 5002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cc13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Anadromous stocks” means stocks of species listed in the Annex to the Convention that migrate into the Convention area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cc14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Anadromous fish” means fish of the species listed in the Annex to the Convention that migrate into the Convention area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cc15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Authorized officer” means a law enforcement official authorized to enforce this chapter under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5008/a"},"text":"section 5008(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cc16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Commission” means the North Pacific Anadromous Fish Commission provided for by article VIII of the Convention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cc17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Convention” means the Convention for the Conservation of Anadromous Stocks of the North Pacific Ocean, signed in Moscow, ","children":[{"tag":"date","attrib":{"date":"1992-02-11"},"text":"February 11, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cc18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Convention area” means the waters of the North Pacific Ocean and its adjacent seas, north of 33 degrees North Latitude,","children":[{"tag":"ref","attrib":{"idref":"fn002805"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002805"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" beyond 200 nautical miles from the baselines from which the breadth of the territorial sea is measured."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cc19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Directed fishing” means fishing targeted at a particular species or stock of fish.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cc1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Ecologically related species” means living marine species which are associated with anadromous stocks found in the Convention area, including, but not restricted to, both predators and prey of anadromous fish.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cc1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Enforcement officer” means a law enforcement official authorized by any Party to enforce this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cc1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Exclusive economic zone” means the zone established by Proclamation Numbered 5030, dated ","children":[{"tag":"date","attrib":{"date":"1983-03-10"},"text":"March 10, 1983","children":[],"tail":". For purposes of applying this chapter, the inner boundary of that zone is a line coterminous with the seaward boundary of each of the coastal States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cc1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Fish” means finfish, mollusks, crustaceans, and all other forms of marine animal and plant life other than marine mammals and birds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cc1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Fishing” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cc1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the catching, taking, or harvesting of fish, or any other activity that can reasonably be expected to result in the catching, taking, or harvesting of fish; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cc20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any operation at sea in preparation for or in direct support of any activity described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cc21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Fishing vessel” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cc22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any vessel engaged in catching fish within the Convention area or in processing or transporting fish loaded in the Convention area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cc23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any vessel outfitted to engage in any activity described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cc24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any vessel supporting a vessel described in subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cc25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Incidental taking” means catching, taking, or harvesting a species or stock of fish while conducting directed fishing for another species or stock of fish.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cc26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Party” means Canada, Japan, the Russian Federation, the United States, and any other nation that may accede to the Convention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cc27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cc28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5002/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States Section” means the United States Commissioners of the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f7cc29-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567/tVIII/s803"},"text":"Pub. L. 102–567, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4309"},"text":"106 Stat. 4309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tVIII/s8003"},"text":"Pub. L. 102–587, title VIII, § 8003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5098"},"text":"106 Stat. 5098","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/43/tIV/s404/b"},"text":"Pub. L. 104–43, title IV, § 404(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/391"},"text":"109 Stat. 391","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/562/tIII/s304/a"},"text":"Pub. L. 106–562, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2806"},"text":"114 Stat. 2806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f7cc2a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f7cc2b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79f7cc2c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Proclamation Numbered 5030, dated ","children":[{"tag":"date","attrib":{"date":"1983-03-10"},"text":"March 10, 1983","children":[],"tail":", referred to in par. (10), is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453"},"text":"section 1453 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79f7cc2d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567"},"text":"Pub. L. 102–567","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":" enacted substantially identical sections. Title VIII of "},{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/562"},"text":"Pub. L. 106–562","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79f7cc2e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Par. (13)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43"},"text":"Pub. L. 104–43","children":[],"tail":" amended subpar. (C) generally. Prior to amendment, subpar. (C) read as follows: “any vessel described in subparagraph (A) or (B).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
