{"tag":"section","attrib":{"id":"id77e1bbe6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ii–5"},"text":"§ 460ii–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chattahoochee River National Recreation Area Advisory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77e1bbe7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; duties; membership: voting members and Park Superintendent as nonvoting member; Chairman","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby established the Chattahoochee River National Recreation Area Advisory Commission (hereinafter in this subchapter referred to as the “Advisory Commission”) to advise the Secretary regarding the management and operation of the area, protection of resources with ","children":[{"tag":"ref","attrib":{"idref":"fn002333"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002333"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “within”."}],"tail":" the recreation area, and the priority of lands to be acquired within the recreation area. The Advisory Commission shall be composed of the following thirteen voting members appointed by the Secretary:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e1bbe8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" four members appointed from among individuals recommended by local governments—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e1bbe9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom shall be recommended by the Board of County Commissioners of Forsyth County;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e1bbea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom shall be recommended by the Board of County Commissioners of Fulton County;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e1bbeb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom shall be recommended by the Board of County Commissioners of Cobb County; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e1bbec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom shall be recommended by the Board of County Commissioners of Gwinnett County;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e1bbed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member appointed from among individuals recommended by the Governor of Georgia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e1bbee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member appointed from among individuals recommended by the Atlanta Regional Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e1bbef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four members appointed from among individuals recommended by a coalition of citizens public interest groups, recreational users, and environmental organizations concerned with the protection and preservation of the Chattahoochee River;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e1bbf0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member appointed from among individuals recommended by the Business Council of Georgia or by a local chamber of commerce in the vicinity of the recreation area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e1bbf1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members who represent the general public, at least one of whom shall be a resident of one of the counties referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In addition, the Park Superintendent for the recreation area shall serve as a nonvoting member of the Advisory Commission. The Advisory Commission shall designate one of its members as Chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e1bbf2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of office; reappointment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e1bbf3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), members of the Advisory Commission shall serve for terms of three years. Any voting member of the Advisory Commission may be reappointed for one additional three-year term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e1bbf4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The members first appointed under paragraph (1) shall serve for a term of one year. The members first appointed under paragraphs (2), (3), (5), and (6) shall serve for a term of two years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e1bbf5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Commission shall meet on a regular basis. Notice of meetings and agenda shall be published in local newspapers which have a distribution which generally covers the area affected by the park. Commission meetings shall be held at locations and in such a manner as to insure adequate public involvement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e1bbf6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Commission shall serve without compensation as such, but the Secretary may pay expenses reasonably incurred in carrying out their responsibilities under this subchapter on vouchers signed by the Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e1bbf7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ii–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Commission shall terminate on the date ten years after ","children":[{"tag":"date","attrib":{"date":"1984-10-30"},"text":"October 30, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77e1bbf8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/344/tI/s106"},"text":"Pub. L. 95–344, title I, § 106","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/568/s1/f"},"text":"Pub. L. 98–568, § 1(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2931"},"text":"98 Stat. 2931","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/154/s2/e/5"},"text":"Pub. L. 106–154, § 2(e)(5)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1739"},"text":"113 Stat. 1739","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77e1bbf9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77e1bbfa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77e1bbfb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/154/s2/e/5"},"text":"Pub. L. 106–154, § 2(e)(5)","children":[],"tail":", substituted “this subchapter” for “this subchapter and chapter 43 of this title” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/154/s2/e/6"},"text":"Pub. L. 106–154, § 2(e)(6)","children":[],"tail":", substituted “this subchapter” for “this subchapter and chapter 43 of this title”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
