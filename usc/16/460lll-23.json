{"tag":"section","attrib":{"id":"id77fbfaf6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–23"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–23"},"text":"§ 460lll–23.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fbfaf7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–23/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall charge reasonable fees, in consultation with the Advisory Board and consistent with the Federal Lands Recreation Enhancement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6801"},"text":"16 U.S.C. 6801","children":[],"tail":" et seq.), for admission to and the use of the designated sites, or for activities, within the Recreation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfaf8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–23/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether to charge fees, the Secretary may consider the costs of collection weighed against potential income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfaf9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–23/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"ta