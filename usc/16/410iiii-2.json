{"tag":"section","attrib":{"id":"id77871919-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"410iiii–2"},"text":"§ 410iiii–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the Civil Rights in Education: Brown v. Board of Education National Historical Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7787191a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established as a unit of the National Park System the Brown v. Board of Education National Historical Park in the State of Kansas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7787191b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The historical park shall consist of the Monroe Elementary School site in the city of Topeka, Shawnee County, Kansas, as generally depicted on a map entitled “Brown v. Board of Education National Historic Site,” numbered Appendix A and dated June 1992. Such map shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7787191c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary adjustment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7787191d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the land described in subsection (b), the historical park shall include the land and interests in land, as generally depicted on the map entitled “Brown v. Board of Education National Historical Park Boundary Additions and Affiliated Areas”, numbered 462/178,449, and dated February 2022, and more particularly described as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7787191e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–2/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Summerton High School site in Summerton, Clarendon County, South Carolina;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7787191f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–2/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former Scott’s Branch High School site in Summerton, Clarendon County, South Carolina; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77871920-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–2/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approximately 1 acre of land adjacent to Monroe Elementary School in Topeka, Shawnee County, Kansas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77871921-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map described in paragraph (1) shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77871922-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/525/tI/s103"},"text":"Pub. L. 102–525, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-26"},"text":"Oct. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3439"},"text":"106 Stat. 3439","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/123"},"text":"Pub. L. 117–123","children":[],"tail":", §§ 2(c)(2)–(4), 3(e), "},{"tag":"date","attrib":{"date":"2022-05-12"},"text":"May 12, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1196"},"text":"136 Stat. 1196","children":[],"tail":", 1198.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77871923-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77871924-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77871925-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/123/s2/c/3"},"text":"Pub. L. 117–123, § 2(c)(3)","children":[],"tail":", substituted “Historical Park” for “Historic Site” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/123/s2/c/2"},"text":"Pub. L. 117–123, § 2(c)(2)","children":[],"tail":", substituted “National Historical Park” for “National Historic Site”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/123/s2/c/4"},"text":"Pub. L. 117–123, § 2(c)(4)","children":[],"tail":", substituted “historical park” for “historic site”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/123/s3/e"},"text":"Pub. L. 117–123, § 3(e)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
