{"tag":"section","attrib":{"id":"id772c7622-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s346"},"text":null,"children":[{"tag":"num","attrib":{"value":"346"},"text":"§ 346.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to exchange, in his discretion, alienated lands in Zion National Park for unappropriated and unreserved public lands of equal value and approximately equal area in the State of Utah outside of said park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id772c7623-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-06-07/ch305/s3"},"text":"June 7, 1924, ch. 305, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/594"},"text":"43 Stat. 594","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
