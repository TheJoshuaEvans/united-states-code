{"tag":"section","attrib":{"id":"id79b51d6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3343"},"text":null,"children":[{"tag":"num","attrib":{"value":"3343"},"text":"§ 3343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction with fishery conservation and management provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b51d70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3343/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed as affecting the provisions of title III of the Magnuson-Stevens Fishery Conservation and Management Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1851"},"text":"16 U.S.C. 1851","children":[],"tail":" et seq.] as it applies with respect to fishery management plans and their application to any fishery, except that the Pacific Fishery Management Council shall ensure that existing and future fishery management plans are consistent with any recommended program approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3311"},"text":"section 3311 of this title","children":[],"tail":" and any enhancement plan under subchapter III."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b51d71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3343/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fleet mobility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce in coordination with the Pacific Fishery Management Council in its salmon management plan shall ensure that the fishing effort reduction that results from the fleet adjustment program of subchapter IV and the license moratorium of the State of Washington is not replaced by new fishing effort from outside such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b51d72-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/561/tI/s142"},"text":"Pub. L. 96–561, title I, § 142","children":[],"tail":", title II, § 238(b), "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3286"},"text":"94 Stat. 3286","children":[],"tail":", 3300; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII/s211/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II, § 211(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–41.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b51d73-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79b51d74-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79b51d75-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Magnuson-Stevens Fishery Conservation and Management Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/331"},"text":"90 Stat. 331","children":[],"tail":". Title III of the Act is classified generally to subchapter IV (§ 1851 et seq.) of chapter 38 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79b51d76-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “Magnuson-Stevens Fishery” for “Magnuson Fishery”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/561/s238/b"},"text":"Pub. L. 96–561, § 238(b)","children":[],"tail":", substituted “Magnuson Fishery Conservation and Management Act” for “Fishery Conservation and Management Act of 1976”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79b51d77-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79b51d78-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII/s211/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II, § 211(b)]","children":[],"tail":", "},{"tag":"d