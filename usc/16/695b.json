{"tag":"section","attrib":{"id":"id7877e1dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s695b"},"text":null,"children":[{"tag":"num","attrib":{"value":"695b"},"text":"§ 695b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain statutes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Sections 715g to 715i and 715","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" to 715n of this title are made applicable for the purposes of sections 695 to 695c of this title in the same manner and to the same extent as though they were enacted as part of sections 695 to 695c of this title, except that lands acquired hereunder may be administered primarily as wildlife management areas not subject to the prohibition against the taking of birds or nests or the eggs thereof, as contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s715i"},"text":"section 715i of this title","children":[],"tail":", and hunting thereon may be regulated, at the option of the Fish and Game Commission of the State of California, in such cooperative manner as is deemed necessary to carry out the purposes of sections 695 to 695c of this title subject, however, to the provisions of the Migratory Bird Treaty Act of "},{"tag":"date","attrib":{"date":"1918-07-03"},"text":"July 3, 1918","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s703"},"text":"16 U.S.C. 703","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7877e1dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-05-18/ch303/s3"},"text":"May 18, 1948, ch. 303, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/239"},"text":"62 Stat. 239","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7877e1de-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7877e1df-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7877e1e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Migratory Bird Treaty Act of ","children":[{"tag":"date","attrib":{"date":"1918-07-03"},"text":"July 3, 1918","children":[],"tail":", referred to in text, is "},{"tag":"ref","attrib":{"href":"/us/act/1918-07-03/ch128"},"text":"act July 3, 1918, ch. 128","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/755"},"text":"40 Stat. 755","children":[],"tail":", which is classified generally to subchapter II of chapter 7 (§ 703 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s710"},"text":"section 710 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 715","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" and 715m of this title, referred to in text, were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/89/669/s7/d"},"text":"Pub. L. 89–669, § 7(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/930"},"text":"80 Stat. 930","children":[],"tail":". See section 668d(f) and (e) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
