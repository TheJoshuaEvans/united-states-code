{"tag":"section","attrib":{"id":"id79d68752-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24"},"text":null,"children":[{"tag":"num","attrib":{"value":"3839aa–24"},"text":"§ 3839aa–24.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d68753-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To achieve the conservation goals of a contract under the conservation stewardship program, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d68754-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the program available to eligible producers on a continuous enrollment basis with 1 or more ranking periods, 1 of which shall occur in the first quarter of each fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68755-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify not less than 5 priority resource concerns in a particular watershed or other appropriate region or area within a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68756-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a science-based stewardship threshold for each priority resource concern identified under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d68757-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation to States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall allocate funding to States for enrollment, based—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d68758-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primarily on each State’s proportion of eligible land to the total acreage of eligible land in all States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68759-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" also on consideration of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d6875a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent and magnitude of the conservation needs associated with agricultural production in each State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d6875b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which implementation of the program in the State is, or will be, effective in helping producers address those needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d6875c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other considerations to achieve equitable geographic distribution of funds, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d6875d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation stewardship payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d6875e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide annual payments under the program to compensate the producer for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d6875f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" installing and adopting additional conservation activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68760-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving, maintaining, and managing conservation activities in place at the agricultural operation of the producer at the time the contract offer is accepted by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68761-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the annual payment shall be determined by the Secretary and based, to the maximum extent practicable, on the following factors:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d68762-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs incurred by the producer associated with planning, design, materials, installation, labor, management, maintenance, or training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68763-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Income forgone by the producer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68764-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expected conservation benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68765-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which priority resource concerns will be addressed through the installation and adoption of conservation activities on the agricultural operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68766-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The level of stewardship in place at the time of application and maintained over the term of the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68767-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The degree to which the conservation activities will be integrated across the entire agricultural operation for all applicable priority resource concerns over the term of the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68768-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other factors as are determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68769-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A payment to a producer under this subsection shall not be provided for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d6876a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the design, construction, or maintenance of animal waste storage or treatment facilities or associated waste transport or transfer devices for animal feeding operations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d6876b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conservation activities for which there is no cost incurred or income forgone to the producer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d6876c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery of payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making payments under this subsection, the Secretary shall, to the extent practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d6876d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prorate conservation performance over the term of the contract so as to accommodate, to the extent practicable, producers earning equal annual payments in each fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d6876e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such payments as soon as practicable after October 1 of each fiscal year for activities carried out in the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d6876f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment for cover crop activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a payment under this subsection for cover crop activities shall be not less than 125 percent of the annual payment amount determined by the Secretary under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d68770-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental payments for resource-conserving crop rotations and advanced grazing management","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d68771-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d68772-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced grazing management","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “advanced grazing management” means the use of a combination of grazing practices (as determined by the Secretary), which may include management-intensive rotational grazing, that provide for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d68773-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved soil health and carbon sequestration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d68774-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drought resilience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d68775-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wildlife habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d68776-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wildfire mitigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d68777-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control of invasive plants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d68778-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water quality improvement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68779-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management-intensive rotational grazing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “management-intensive rotational grazing” means a strategic, adaptively managed multipasture grazing system in which animals are regularly and systematically moved to fresh pasture in a manner that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d6877a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximizes the quantity and quality of forage growth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d6877b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves manure distribution and nutrient cycling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d6877c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases carbon sequestration from greater forage harvest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d6877d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves the quality and quantity of cover for wildlife;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d6877e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides permanent cover to protect the soil from erosion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d6877f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves water quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68780-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resource-conserving crop rotation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “resource-conserving crop rotation” means a crop rotation that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d68781-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes at least 1 resource-conserving crop (as defined by the Secretary);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d68782-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces erosion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d68783-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves soil fertility and tilth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d68784-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interrupts pest cycles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d68785-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" builds soil organic matter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d68786-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/1/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in applicable areas, reduces depletion of soil moisture or otherwise reduces the need for irrigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68787-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide additional payments to producers that, in participating in the program, agree to adopt or improve, manage, and maintain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d68788-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resource-conserving crop rotations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68789-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced grazing management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d6878a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a payment described in paragraph (2), a producer shall agree to adopt or improve, manage, and maintain resource-conserving crop rotations or advanced grazing management for the term of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d6878b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An additional payment provided under paragraph (2) shall be not less than 150 percent of the annual payment amount determined by the Secretary under subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d6878c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment for comprehensive conservation plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d6878d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of comprehensive conservation plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “comprehensive conservation plan” means a conservation plan that meets or exceeds the stewardship threshold for each priority resource concern identified by the Secretary under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d6878e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment for comprehensive conservation plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide a 1-time payment to a producer that develops a comprehensive conservation plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d6878f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall determine the amount of payment under paragraph (2) based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d68790-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of priority resource concerns addressed in the comprehensive conservation plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68791-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of types of land uses included in the comprehensive conservation plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d68792-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person or legal entity may not receive, directly or indirectly, payments under the program that, in the aggregate, exceed $200,000 under all contracts entered into during fiscal years 2019 through 2023, excluding funding arrangements with Indian tribes, regardless of the number of contracts entered into under the program by the person or legal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d68793-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specialty crop and organic producers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that outreach and technical assistance are available, and program specifications are appropriate to enable specialty crop and organic producers to participate in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d68794-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organic certification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d68795-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a transparent means by which producers may initiate organic certification under the Organic Foods Production Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6501"},"text":"7 U.S.C. 6501","children":[],"tail":" et seq.) while participating in a contract under the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68796-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d68797-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Using funds made available for the program for each of fiscal years 2019 through 2031, the Secretary shall allocate funding to States to support organic production and transition to organic production through paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68798-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall determine the allocation to a State under subparagraph (A) based on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d68799-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of certified and transitioning organic operations within the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d6879a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of acres of certified and transitioning organic production within the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d6879b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall promulgate regulations that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d6879c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe such other rules as the Secretary determines to be necessary to ensure a fair and reasonable application of the limitations established under subsection (f); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d6879d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise enable the Secretary to carry out the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d6879e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Streamlining and coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent feasible, the Secretary shall provide for streamlined and coordinated procedures for the program and the environmental quality incentives program under subpart A, including applications, contracting, conservation planning, conservation practices, and related administrative procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d6879f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Soil health","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent feasible, the Secretary shall manage the program to enhance soil health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d687a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–24/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each fiscal year, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report describing the payment rates for conservation activities offered to producers under the program and an analysis of whether payment rates can be reduced for the most expensive conservation activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d687a1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1240L"},"text":"Pub. L. 99–198, title XII, § 1240L","children":[],"tail":", formerly § 1238G, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2301/a/2"},"text":"Pub. L. 110–234, title II, § 2301(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1045"},"text":"122 Stat. 1045","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title II, § 2301(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1773; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2101/a"},"text":"Pub. L. 113–79, title II, § 2101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/726"},"text":"128 Stat. 726","children":[],"tail":"; renumbered § 1240L and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII"},"text":"Pub. L. 115–334, title II","children":[],"tail":", §§ 2301(b), 2308(d), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4551"},"text":"132 Stat. 4551","children":[],"tail":", 4566; "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/tII/s21001/c/4"},"text":"Pub. L. 117–169, title II, § 21001(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2017"},"text":"136 Stat. 2017","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79d687a2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79d687a3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79d687a4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Organic Foods Production Act of 1990, referred to in subsec. (h)(1), is title XXI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3935"},"text":"104 Stat. 3935","children":[],"tail":", which is classified generally to chapter 94 (§ 6501 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6501"},"text":"section 6501 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79d687a5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3838g"},"text":"section 3838g of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79d687a6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (h)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":" substituted “2031” for “2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/d/1"},"text":"Pub. L. 115–334, § 2308(d)(1)","children":[],"tail":", substituted “allocate funding” for “allocate acres” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/d/2"},"text":"Pub. L. 115–334, § 2308(d)(2)","children":[],"tail":", (3), redesignated subsec. (d) as (c) and struck out former subsec. (c). Prior to amendment, text of subsec. (c) read as follows: “During the period beginning on "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2022-09-30"},"text":"September 30, 2022","children":[],"tail":", the Secretary shall, to the maximum extent practicable—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) enroll in the program an additional 10,000,000 acres for each fiscal year; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) manage the program to achieve a national average rate of $18 per acre, which shall include the costs of all financial assistance, technical assistance, and any other expenses associated with enrollment or participation in the program.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/d/4"},"text":"Pub. L. 115–334, § 2308(d)(4)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/d/3"},"text":"Pub. L. 115–334, § 2308(d)(3)","children":[],"tail":", (5)(A), redesignated subsec. (e) as (d) and inserted “and advanced grazing management” after “crop rotations” in heading. Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/d/5/D"},"text":"Pub. L. 115–334, § 2308(d)(5)(D)","children":[],"tail":", inserted par. designation, heading, and introductory provisions, added subpars. (A) and (B), designated existing provisions of par. (1) as subpar. (C), and, in subpar. (C), substituted “The term” for “In this subsection, the term”, redesignated former subpars. (A) to (D) and (E) of par. (1) as cls. (i) to (iv) and (vi), respectively, realigned margins, and added cl. (v)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/d/5/C"},"text":"Pub. L. 115–334, § 2308(d)(5)(C)","children":[],"tail":", redesignated par. (4) as (1). Former par. (1) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/d/5/C"},"text":"Pub. L. 115–334, § 2308(d)(5)(C)","children":[],"tail":", (E), redesignated par. (1) as (2), substituted “agree to adopt or improve, manage, and maintain—” for “agree to adopt or improve resource-conserving crop rotations to achieve beneficial crop rotations as appropriate for the eligible land of the producers.”, and added subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/d/5/B"},"text":"Pub. L. 115–334, § 2308(d)(5)(B)","children":[],"tail":", struck out par. (2). Text read as follows: “The Secretary shall determine whether a resource-conserving crop rotation is a beneficial crop rotation eligible for additional payments under paragraph (1) based on whether the resource-conserving crop rotation is designed to provide natural resource conservation and production benefits.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/d/5/F"},"text":"Pub. L. 115–334, § 2308(d)(5)(F)","children":[],"tail":", substituted “paragraph (2)” for “paragraph (1)” and “agree to adopt or improve, manage, and maintain resource-conserving crop rotations or advanced grazing management for the term of the contract” for “agree to adopt and maintain beneficial resource-conserving crop rotations for the term of the contract”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/d/5/G"},"text":"Pub. L. 115–334, § 2308(d)(5)(G)","children":[],"tail":", added par. (4). Former par. (4) redesignated (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/d/6"},"text":"Pub. L. 115–334, § 2308(d)(6)","children":[],"tail":", added subsec. (e). Former subsec. (e) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/d/7"},"text":"Pub. L. 115–334, § 2308(d)(7)","children":[],"tail":", substituted “2019 through 2023” for “2014 through 2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/d/8"},"text":"Pub. L. 115–334, § 2308(d)(8)","children":[],"tail":", substituted “Organic certification” for “Coordination with organic certification” in subsec. heading, designated existing provisions as par. (1) and inserted par. heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (j) to (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/d/9"},"text":"Pub. L. 115–334, § 2308(d)(9)","children":[],"tail":", added subsecs. (j) to ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" amended section generally. Prior to amendment, section related to duties of the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
