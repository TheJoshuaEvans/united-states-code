{"tag":"section","attrib":{"id":"id79369dc2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1445c"},"text":"§ 1445c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dr. Nancy Foster Scholarship Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79369dc3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and administer through the National Ocean Service the Dr. Nancy Foster Scholarship Program. Under the program, the Secretary shall award graduate education scholarships in oceanography, marine biology or maritime archeology, to be known as Dr. Nancy Foster Scholarships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369dc4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Dr. Nancy Foster Scholarship Program are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79369dc5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recognize outstanding scholarship in oceanography, marine biology, or maritime archeology, particularly by women and members of minority groups; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369dc6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage independent graduate level research in oceanography, marine biology, or maritime archeology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369dc7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Dr. Nancy Foster Scholarship—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79369dc8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be used to support graduate studies in oceanography, marine biology, or maritime archeology at a graduate level institution of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369dc9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be awarded in accordance with guidelines issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369dca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of each Dr. Nancy Foster Scholarship shall be provided directly to a recipient selected by the Secretary upon receipt of certification that the recipient will adhere to a specific and detailed plan of study and research approved by a graduate level institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369dcb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount available each fiscal year to carry out this chapter, the Secretary shall award 1 percent as Dr. Nancy Foster Scholarships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369dcc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarship repayment requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require an individual receiving a scholarship under this section to repay the full amount of the scholarship to the Secretary if the Secretary determines that the individual, in obtaining or using the scholarship, engaged in fraudulent conduct or failed to comply with any term or condition of the scholarship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369dcd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maritime archeology defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section the term “maritime archeology” includes the curation, preservation, and display of maritime artifacts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79369dce-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tIII/s318"},"text":"Pub. L. 92–532, title III, § 318","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/513/s18"},"text":"Pub. L. 106–513, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2392"},"text":"114 Stat. 2392","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79369dcf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79369dd0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79369dd1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For similar provisions relating to the Dr. Nancy Foster Scholarship Program, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1445c–1"},"text":"section 1445c–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
