{"tag":"section","attrib":{"id":"id79d416d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"3839aa–21"},"text":"§ 3839aa–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subpart:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d416d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural operation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “agricultural operation” means all eligible land, whether or not contiguous, that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d416d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the effective control of a producer at the time the producer enters into a contract under the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated with equipment, labor, management, and production or cultivation practices that are substantially separate from other agricultural operations, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d416d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d416d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “conservation activities” means conservation systems, practices, or management measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “conservation activities” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d416db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" structural measures, vegetative measures, and land management measures, including agriculture drainage management systems, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d416dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning needed to address a priority resource concern;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d416dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of a comprehensive conservation plan, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–24/e/1"},"text":"section 3839aa–24(e)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d416de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soil health planning, including planning to increase soil organic matter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d416df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities that will assist a producer to adapt to, or mitigate against, increasing weather volatility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d416e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation stewardship plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “conservation stewardship plan” means a plan that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d416e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies and inventories priority resource concerns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes benchmark data and conservation objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes conservation activities to be implemented, managed, or improved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a schedule and evaluation plan for the planning, installation, and management of the new and existing conservation activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d416e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible land","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d416e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible land” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d416e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private or tribal land on which agricultural commodities, livestock, or forest-related products are produced; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d416e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lands associated with the land described in clause (i) on which priority resource concerns could be addressed through a contract under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible land” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d416ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cropland;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d416eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grassland;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d416ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rangeland;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d416ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pasture land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d416ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonindustrial private forest land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d416ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/4/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other land in agricultural areas (including cropped woodland, marshes, and agricultural land used or capable of being used for the production of livestock), as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d416f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority resource concern","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “priority resource concern” means a natural resource concern or problem, as determined by the Secretary, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d416f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is identified at the national, State, or local level as a priority for a particular area of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represents a significant concern in a State or region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is likely to be addressed successfully through the implementation of conservation activities under this program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d416f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the conservation stewardship program established by this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d416f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stewardship threshold","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “stewardship threshold” means the level of management required, as determined by the Secretary, to conserve and improve the quality and condition of a natural resource through the use of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d416f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quality criteria under a resource management system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" predictive analytics tools or models developed or approved by the Natural Resources Conservation Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data from past and current enrollment in the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–21/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other methods that measure conservation and improvement in priority resource concerns, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d416fa-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1240I"},"text":"Pub. L. 99–198, title XII, § 1240I","children":[],"tail":", formerly § 1238D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2301/a/2"},"text":"Pub. L. 110–234, title II, § 2301(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref