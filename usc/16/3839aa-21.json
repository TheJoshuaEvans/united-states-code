:[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on existing contracts and agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The cessation of effectiveness under paragraph (2) [enacting provisions set out as a note under former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3838d"},"text":"section 3838d of this title","children":[],"tail":"] shall not affect—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the validity or terms of any contract entered into by the Secretary [of Agriculture] under subchapter B of chapter 2 of subtitle D of title XII of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3838d"},"text":"16 U.S.C. 3838d","children":[],"tail":" et seq.) before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":"], or any payments, modifications, or technical assistance required to be made in connection with the contract; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subparagraph (D), any agreement entered into by the Secretary under the regional conservation partnership program under subtitle I of title XII of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871"},"text":"16 U.S.C. 3871","children":[],"tail":" et seq.) on or before "},{"tag":"date","attrib":{"date":"2018-09-30"},"text":"September 30, 2018","children":[],"tail":", under which conservation stewardship program acres and associated funding have been allocated to the agreement for the purpose of entering into a contract under subchapter B of chapter 2 of subtitle D of title XII of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3838d"},"text":"16 U.S.C. 3838d","children":[],"tail":" et seq.) (as in effect on the day before the date of enactment of this Act)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension permitted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraph (2), the Secretary may extend for 1 year a contract described in subparagraph (A)(i) if that contract expires on or before ","children":[{"tag":"date","attrib":{"date":"2019-12-31"},"text":"December 31, 2019","children":[],"tail":", under the terms and payment rate of the existing contract and in accordance with subchapter B of chapter 2 of subtitle D of title XII of the Food Security Act of 1985 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3838d"},"text":"16 U.S.C. 3838d","children":[],"tail":" et seq.) (as in effect on the day before the date of enactment of this Act)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Renewal not permitted.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subparagraph (A), and subject to clause (ii), the Secretary may not renew a contract or agreement described in that subparagraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may renew a contract described in subparagraph (A)(i)—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if that contract expires on or after ","children":[{"tag":"date","attrib":{"date":"2019-12-31"},"text":"December 31, 2019","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"“(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the terms of the conservation stewardship program under subchapter B of chapter 4 of subtitle D of title XII of the Food Security Act of 1985 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–21"},"text":"16 U.S.C. 3839aa–21","children":[],"tail":" et seq.] (as added by subsections (a)(2) and (b)); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"“(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the limitation on funding for that subchapter under section 1241 of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3841"},"text":"16 U.S.C. 3841","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"RCPP contracts.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of acreage","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of an agreement described in subparagraph (A)(ii), the Secretary may provide an amount of funding that is equivalent to the value of any acres covered by the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funds and acres not obligated","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an agreement described in subparagraph (A)(ii) to which program acres and associated funding have been allocated but not yet obligated to enter into a contract under subchapter B of chapter 2 of subtitle D of title XII of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3838d"},"text":"16 U.S.C. 3838d","children":[],"tail":" et seq.) (as in effect on the day before the date of enactment of this Act)—"}],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall modify the agreement to authorize the entrance into a contract under subchapter B of chapter 4 of subtitle D of title XII of the Food Security Act of 1985 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–21"},"text":"16 U.S.C. 3839aa–21","children":[],"tail":" et seq.] (as added by subsections (a)(2) and (b)); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"“(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funds associated with the conservation stewardship program acres allocated under that agreement, on modification under subclause (I), may be used to enter into conservation stewardship program contracts with producers under subchapter B of chapter 4 of subtitle D of title XII of the Food Security Act of 1985 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–21"},"text":"16 U.S.C. 3839aa–21","children":[],"tail":" et seq.] (as added by subsections (a)(2) and (b))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract administration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraphs (3)(C) and (3)(D)(ii)(II), the Secretary shall administer each contract and agreement described in clauses (i) and (ii) of paragraph (3)(A) until the expiration of the contract or agreement in accordance with the regulations to carry out the conservation stewardship program under subchapter B of chapter 2 of subtitle D of title XII of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3838d"},"text":"16 U.S.C. 3838d","children":[],"tail":" et seq.) (as in effect on the day before the date of enactment of this Act) that are in effect on the day before that date of enactment."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraphs (1) and (2), any funds made available from the Commodity Credit Corporation under section 1241(a)(4) of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3841/a/4"},"text":"16 U.S.C. 3841(a)(4)","children":[],"tail":") for fiscal years 2014 through 2018 shall be available to carry out—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contract or agreement described in paragraph (3)(A)(i) for fiscal year 2019;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contract or agreement described in paragraph (3)(A)(ii);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contract extended under paragraph (3)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contract or agreement under subchapter B of chapter 4 of subtitle D of title XII of the Food Security Act of 1985 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–21"},"text":"16 U.S.C. 3839aa–21","children":[],"tail":" et seq.] (as added by subsections (a)(2) and (b)).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79d41702-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effect on Existing Contracts by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2101/b"},"text":"Pub. L. 113–79, title II, § 2101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/728"},"text":"128 Stat. 728","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/79/tII/s2101/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by this section [amending sections 3838d to 3838g of this title] shall not affect the validity or terms of any contract entered into by the Secretary of Agriculture under subchapter B of chapter 2 of subtitle D of title XII of the Food Security Act of 1985 ([former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3838d"},"text":"16 U.S.C. 3838d","children":[],"tail":" et seq.) before the date of enactment of the Agricultural Act of 2014 ["},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":"], or any payments required to be made in connection with the contract."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conservation stewardship program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds made available under section 1241(a)(4) of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3841/a/4"},"text":"16 U.S.C. 3841(a)(4)","children":[],"tail":") (as amended by "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2601/a"},"text":"section 2601(a) of this title","children":[],"tail":") may be used to administer and make payments to program participants that enrolled into contracts during any of fiscal years 2009 through 2013.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
