{"tag":"section","attrib":{"id":"id7925fc90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1388"},"text":null,"children":[{"tag":"num","attrib":{"value":"1388"},"text":"§ 1388.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marine mammal cooperative agreements in Alaska","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7925fc91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1388/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into cooperative agreements with Alaska Native organizations to conserve marine mammals and provide co-management of subsistence use by Alaska Natives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7925fc92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1388/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Agreements entered into under this section may include grants to Alaska Native organizations for, among other purposes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7925fc93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1388/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting and analyzing data on marine mammal populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7925fc94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1388/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring the harvest of marine mammals for subsistence use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7925fc95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1388/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participating in marine mammal research conducted by the Federal Government, States, academic institutions, and private organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7925fc96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1388/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing marine mammal co-management structures with Federal and State agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7925fc97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1388/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of jurisdiction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section is intended or shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7925fc98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1388/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as authorizing any expansion or change in the respective jurisdiction of Federal, State, or tribal governments over fish and wildlife resources; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7925fc99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1388/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as altering in any respect the existing political or legal status of Alaska Natives, or the governmental or jurisdictional status of Alaska Native communities or Alaska Native entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7925fc9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1388/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for the purposes of carrying out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7925fc9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1388/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,500,000 to the Secretary of Commerce for each of the fiscal years 1994, 1995, 1996, 1997, 1998, and 1999; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7925fc9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1388/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 to the Secretary of the Interior for each of the fiscal years 1994, 1995, 1996, 1997, 1998, and 1999.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The amounts authorized to be appropriated under this subsection are in addition to the amounts authorized to be appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1384"},"text":"section 1384 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7925fc9d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tI/s119"},"text":"Pub. L. 92–522, title I, § 119","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/238/s19"},"text":"Pub. L. 103–238, § 19","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/559"},"text":"108 Stat. 559","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
