{"tag":"section","attrib":{"id":"id770194d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s81k"},"text":null,"children":[{"tag":"num","attrib":{"value":"81k"},"text":"§ 81k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized, in his discretion, to accept on behalf of the United States from the York County School Board, State of Virginia, title to approximately one-half acre of land in Nelson District, York County, Virginia, situated within the authorized boundaries of the Colonial National Historical Park, and in exchange therefor to convey by deed, on behalf of the United States, to the school board approximately one-half acre of land of approximately equal value situated within the Colonial National Historical Park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id770194d7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-23/ch999"},"text":"Sept. 23, 1950, ch. 999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/979"},"text":"64 Stat. 979","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id770194d8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id770194d9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id770194da-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-07-03/ch837"},"text":"act July 3, 1930, ch. 837","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/855"},"text":"46 Stat. 855","children":[],"tail":", which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
