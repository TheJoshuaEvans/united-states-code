{"tag":"section","attrib":{"id":"id7a38307c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8452"},"text":null,"children":[{"tag":"num","attrib":{"value":"8452"},"text":"§ 8452.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadband internet connectivity at developed recreation sites","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a38307d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8452/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary and the Chief of the Forest Service shall enter into an agreement with the Secretary of Commerce to foster the installation or construction of broadband internet infrastructure at developed recreation sites on Federal recreational lands and waters to establish broadband internet connectivity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a38307e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8452/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the availability of appropriations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38307f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8452/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a383080-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8452/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", and annually thereafter through fiscal year 2031, the Secretary and the Chief of the Forest Service, in coordination with States and local communities, shall make publicly available—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a383081-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8452/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the highest priority developed recreation sites, as determined under subsection (c), on Federal recreational lands and waters that lack broadband internet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383082-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8452/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent practicable, an estimate of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a383083-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8452/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost to equip each of those sites with broadband internet infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383084-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8452/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual cost to operate that infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383085-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8452/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a list of potential—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a383086-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8452/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" barriers to operating the infrastructure described in paragraph (2)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383087-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8452/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods to recover the costs of that operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a383088-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8452/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting developed recreation sites for the list described in subsection (b)(1), the Secretary and the Chief of the Forest Service shall give priority to developed recreation sites—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a383089-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8452/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at which broadband internet infrastructure has not been constructed due to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a38308a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8452/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geographic challenges; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38308b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8452/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location having an insufficient number of nearby permanent residents, despite high seasonal or daily visitation levels; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38308c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8452/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are located in an economically distressed county that could benefit significantly from developing the outdoor recreation economy of the county.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a38308d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s142"},"text":"Pub. L. 118–234, title I, § 142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2864"},"text":"138 Stat. 2864","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
