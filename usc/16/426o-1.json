{"tag":"section","attrib":{"id":"id778e4495-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s426o–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"426o–1"},"text":"§ 426o–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id778e4496-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s426o–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation of plan for Redoubt Brannan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, on or before ","children":[{"tag":"date","attrib":{"date":"1992-02-01"},"text":"February 1, 1992","children":[],"tail":", prepare a plan for the preservation and interpretation of Redoubt Brannan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id778e4497-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s426o–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Update of General Management Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, on or before ","children":[{"tag":"date","attrib":{"date":"1993-03-31"},"text":"March 31, 1993","children":[],"tail":", update the General Management Plan for the Stones River National Battlefield."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id778e4498-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s426o–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to provide technical assistance to the city and to Rutherford County in the development of zoning ordinances and other land use controls that would help preserve historically significant areas adjacent to the battlefield.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id778e4499-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s426o–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minor boundary revisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the planning activities conducted under subsections (a) and (b) of this section show a need for minor revisions of the boundaries indicated on the map referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s426n"},"text":"section 426n of this title","children":[],"tail":", the Secretary may, following timely notice in writing to the Committee on Natural Resources of the United States House of Representatives and to the Committee on Energy and Natural Resources of the United States Senate of his intention to do so and providing an opportunity for public comment, make such minor revisions by publication of a revised boundary map or other description in the Federal Register."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id778e449a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/205/s3"},"text":"Pub. L. 100–205, § 3","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/225/s1/4"},"text":"Pub. L. 102–225, § 1(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-11"},"text":"Dec. 11, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1683"},"text":"105 Stat. 1683","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s6/d/15"},"text":"Pub. L. 103–437, § 6(d)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4584"},"text":"108 Stat. 4584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778e449b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id778e449c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id778e449d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/205/s3"},"text":"section 3 of Pub. L. 100–205","children":[],"tail":" was renumbered section 4 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s426p"},"text":"section 426p of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id778e449e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Natural Resources” for “Interior and Insular Affairs” after “Committee on”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
