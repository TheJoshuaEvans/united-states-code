{"tag":"section","attrib":{"id":"id7826db92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s504"},"text":null,"children":[{"tag":"num","attrib":{"value":"504"},"text":"§ 504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchases of tree seeds, cones, forage plant seed, and nursery stock for national forests","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":" shall not apply to any purchase by the Forest Service of forest-tree seed or cones or of forage plant seed when the amount involved does not exceed $10,000, nor to any purchase of forest-tree nursery stock when the amount involved does not exceed $500, whenever, in the discretion of the Secretary of Agriculture, such method is in the public interest."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7826db93-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-06-30/ch131"},"text":"June 30, 1914, ch. 131","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/429"},"text":"38 Stat. 429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-04-24/ch97/s2"},"text":"Apr. 24, 1950, ch. 97, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/83"},"text":"64 Stat. 83","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7826db94-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7826db95-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7826db96-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In text, “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"” substituted for “section 3709, Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"41 U.S.C. 5","children":[],"tail":"),” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7826db97-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-04-24"},"text":"Apr. 24, 1950","children":[],"tail":", increased open market purchase limitation from $500 to $10,000 on forest-tree seed or cones or forage plant seed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
