{"tag":"section","attrib":{"id":"id7a1df086-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6810"},"text":null,"children":[{"tag":"num","attrib":{"value":"6810"},"text":"§ 6810.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1df087-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6810/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to use volunteers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use volunteers, as appropriate, to collect recreation fees and sell recreation passes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1df088-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6810/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver or discount of fees; site-specific agency pass","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In exchange for volunteer services, the Secretary may waive or discount an entrance fee, standard amenity recreation fee, or an expanded amenity recreation fee that would otherwise apply to the volunteer or issue to the volunteer a site-specific agency pass authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6804/c"},"text":"section 6804(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1df089-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6810/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Parks and Federal Recreational Lands Pass","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with the guidelines issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6804/a/7"},"text":"section 6804(a)(7) of this title","children":[],"tail":", the Secretaries may issue a National Parks and Federal Recreational Lands Pass to a volunteer in exchange for significant volunteer services performed by the volunteer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1df08a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6810/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional multientity passes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may issue a regional multientity pass authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6804/d"},"text":"section 6804(d) of this title","children":[],"tail":" to a volunteer in exchange for significant volunteer services performed by the volunteer, if the regional multientity pass agreement under which the regional multientity pass was established provides for the issuance of the pass to volunteers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1df08b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dJ/tVIII/s811"},"text":"Pub. L. 108–447, div. J, title VIII, § 811","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3389"},"text":"118 Stat. 3389","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1df08c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1df08d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a1df08e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6804"},"text":"Section 6804 of this title","children":[],"tail":", referred to in subsecs. (b) to (d), was in the original a reference to section 5, and was translated as meaning "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dJ/tVIII/s805"},"text":"section 805 of title VIII of div. J of Pub. L. 108–447","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
