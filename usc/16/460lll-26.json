{"tag":"section","attrib":{"id":"id77fbfb15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–26"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–26"},"text":"§ 460lll–26.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative authorities and gifts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fbfb16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–26/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish and Wildlife Service","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfb17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–26/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77fbfb18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–26/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to such terms and conditions as the Secretary may prescribe, the Secretary may issue a special use authorization to the United States Fish and Wildlife Service for the management by the Service of facilities and land agreed on by the Secretary and the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fbfb19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–26/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77fbfb1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–26/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Reasonable admission and use fees may be charged for all areas administered by the United States Fish and Wildlife Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77fbfb1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–26/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fees shall be deposited in accordance with section 460","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–24 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–26/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Secretary of the Interior may cooperate or act jointly on activities such as population monitoring and inventory of fish and wildlife with emphasis on migratory birds and endangered and threatened species, environmental education, visitor services, conservation demonstration projects and scientific research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–26/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subordination of fish and wildlife activities to overall management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The management and use of areas and facilities under permit to the United States Fish and Wildlife Service as authorized pursuant to this section shall be subordinate to the overall management of the Recreation Area as directed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–26/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the management, maintenance, operation, and interpretation of the Recreation Area and its facilities, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfb1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–26/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make grants and enter into contracts and cooperative agreements with Federal agencies, governmental units, nonprofit organizations, corporations, and individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–26/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept gifts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2269"},"text":"section 2269 of title 7","children":[],"tail":" notwithstanding that the donor conducts business with any agency of the Department of Agriculture or is regulated by the Secretary of Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–26/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memoranda of understanding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may, for purposes of carrying out this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfb22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–26/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into memoranda of understanding with State or local government entities, including law enforcement, as appropriate, to clarify jurisdictional matters, such as road management, policing, and other functions that are typically performed by the entity on non-Federal land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–26/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available on a public website of the Department of Agriculture any memoranda of understanding entered into under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fbfb24-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s526"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 526]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–316; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tII/s201/f"},"text":"Pub. L. 117–328, div. DD, title II, § 201(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5583"},"text":"136 Stat. 5583","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77fbfb25-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77fbfb26-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77fbfb27-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (c), was in the original “this Act” and was translated as reading “this title”, meaning section 101(e) [title V] of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", known as The Land Between the Lakes Protection Act of 1998, which is classified generally to this subchapter. For complete classification of this Act to the Code, see Short Title note set out under section 460"},{"tag":"i","attrib":{},"text":"lll","children":[],"tail":" of this title and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77fbfb28-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
