{"tag":"section","attrib":{"id":"id7851bc6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"583k–2"},"text":"§ 583k–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Forest System Trails Volunteer and Partnership Strategy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7851bc70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2016-11-28"},"text":"November 28, 2016","children":[],"tail":", the Secretary shall publish in the Federal Register a strategy to significantly increase the role of volunteers and partners in trail maintenance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy required by subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7851bc72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" augment and support the capabilities of Federal employees to carry out or contribute to trail maintenance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide meaningful opportunities for volunteers and partners to carry out trail maintenance in each region of the Forest Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the barriers to increased volunteerism and partnerships in trail maintenance identified by volunteers, partners, and others;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize increased volunteerism and partnerships in trail maintenance in those regions with the most severe trail maintenance needs, and where trail maintenance backlogs are jeopardizing access to National Forest lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aim to increase trail maintenance by volunteers and partners by 100 percent by the date that is 5 years after ","children":[{"tag":"date","attrib":{"date":"2016-11-28"},"text":"November 28, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a component of the strategy, the Secretary shall study opportunities to improve trail maintenance by addressing opportunities to use fire crews in trail maintenance activities in a manner that does not jeopardize firefighting capabilities, public safety, or resource protection. Upon a determination that trail maintenance would be advanced by use of fire crews in trail maintenance, the Secretary shall incorporate these proposals into the strategy, subject to such terms and conditions as the Secretary determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteer liability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7851bc79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2016-11-28"},"text":"November 28, 2016","children":[],"tail":", the Secretary shall adopt regulations implementing this section. These regulations shall ensure that the financial risk from claims or liability associated with volunteers undertaking trail maintenance is shared by all administrative units."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop the strategy in consultation with volunteer and partner trail maintenance organizations, a broad array of outdoor recreation stakeholders, and other relevant stakeholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteer and partnership coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require each administrative unit to develop a volunteer and partner coordination implementation plan for the strategy which clearly defines roles and responsibilities for the administrative unit and district staff, and includes strategies to ensure sufficient coordination, assistance, and support for volunteers and partners to improve trail maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7851bc7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prepare a report on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7851bc7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the strategy in addressing the trail maintenance backlog;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7851bc80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increase in volunteerism and partnership efforts on trail maintenance as a result of the strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7851bc81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the miles of National Forest System trails maintained by volunteers and partners, and the approximate value of the volunteer and partnership efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7851bc82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the stewardship credits for outfitters and guides pilot program described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s583k–5"},"text":"section 583k–5 of this title","children":[],"tail":" that includes the number of participating sites, total amount of the credits offered, estimated value of trail maintenance performed, and suggestions for revising the program; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7851bc83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/g/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for further increasing volunteerism and partnerships in trail maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2016-11-28"},"text":"November 28, 2016","children":[],"tail":", the Secretary shall submit the report required by paragraph (1) to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7851bc85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture, Nutrition, and Forestry and the Committee on Energy and Natural Resources of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7851bc86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–2/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture and the Committee on Natural Resources of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7851bc87-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/245/s4"},"text":"Pub. L. 114–245, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-11-28"},"text":"Nov. 28, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/991"},"text":"130 Stat. 991","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7851bc88-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7851bc89-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7851bc8a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/245/s4"},"text":"section 4 of Pub. L. 114–245","children":[],"tail":". Subsec. (d)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/245/s4"},"text":"section 4 of Pub. L. 114–245","children":[],"tail":" amended former "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s558c"},"text":"section 558c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
