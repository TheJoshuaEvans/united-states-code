{"tag":"section","attrib":{"id":"id79d41641-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"3839aa–4"},"text":"§ 3839aa–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of producers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To receive payments under the program, a producer shall agree—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d41642-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–4/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement an environmental quality incentives program plan (including a comprehensive nutrient management plan, if applicable) that describes conservation and environmental purposes to be achieved through 1 or more practices that are approved by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d41643-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–4/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to conduct any practices on the enrolled land that would tend to defeat the purposes of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d41644-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–4/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on the violation of a term or condition of the contract at anytime the producer has control of the land—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d41645-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–4/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the Secretary determines that the violation warrants termination of the contract—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d41646-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–4/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to forfeit all rights to receive payments under the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d41647-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–4/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to refund to the Secretary all or a portion of the payments received by the owner or operator under the contract, including any interest on the payments, as determined by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d41648-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–4/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary determines that the violation does not warrant termination of the contract, to refund to the Secretary, or accept adjustments to, the payments provided to the owner or operator, as the Secretary determines to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d41649-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–4/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the transfer of the right and interest of the producer in land subject to the contract, unless the transferee of the right and interest agrees with the Secretary to assume all obligations of the contract, to refund all payments received under the program, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d4164a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–4/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to supply information as required by the Secretary to determine compliance with the program plan and requirements of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d4164b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–4/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with such additional provisions as the Secretary determines are necessary to carry out the program plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d4164c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1240D"},"text":"Pub. L. 99–198, title XII, § 1240D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tII/s2301"},"text":"Pub. L. 107–171, title II, § 2301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/256"},"text":"116 Stat. 256","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2505"},"text":"Pub. L. 110–234, title II, § 2505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1062"},"text":"122 Stat. 1062","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tai