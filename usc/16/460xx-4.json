{"tag":"section","attrib":{"id":"id77eda385-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xx–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"460xx–4"},"text":"§ 460xx–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire lands or interests in lands within the boundaries of the conservation area by exchange, purchase, or donation, except that any lands or interests therein owned by the State or local government may be acquired by donation or exchange only. Any purchase or exchange of lands to be added to the conservation area shall require the consent of the owner of those lands or rights.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77eda386-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/696/tI/s105"},"text":"Pub. L. 100–696, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4573"},"text":"102 Stat. 4573","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77eda387-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77eda388-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77eda389-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Land Exchange and Conservation in Arizona","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to land exchange and conservation in southeastern Arizona, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539p"},"text":"section 539p of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
