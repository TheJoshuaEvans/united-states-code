{"tag":"section","attrib":{"id":"id79e99a7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4203"},"text":null,"children":[{"tag":"num","attrib":{"value":"4203"},"text":"§ 4203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e99a7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4203/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in the conservation and protection of the African elephant by supporting the conservation programs of African countries and the CITES Secretariat; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e99a7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4203/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide financial resources for those programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e99a80-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/478/tII/s2004"},"text":"Pub. L. 100–478, title II, § 2004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-07"},"text":"Oct. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2316"},"text":"102 Stat. 2316","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
