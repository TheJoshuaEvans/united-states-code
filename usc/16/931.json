{"tag":"section","attrib":{"id":"id78d4f53b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s931"},"text":null,"children":[{"tag":"num","attrib":{"value":"931"},"text":"§ 931.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, the term—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78d4f53c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s931/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Convention” means the Convention on Great Lakes Fisheries between the United States of America and Canada signed at Washington, ","children":[{"tag":"date","attrib":{"date":"1954-09-10"},"text":"September 10, 1954","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d4f53d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s931/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Commission” means the Great Lakes Fishery Commission provided for by article II of the convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d4f53e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s931/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States Section” means the United States Commissioners on the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d4f53f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s931/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Great Lakes State” means any of the following States: Illinois, Indiana, Michigan, Minnesota, New York, Ohio, Pennsylvania, or Wisconsin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d4f540-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s931/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Great Lakes” means any of the following bodies of water: Lake Ontario (including the Saint Lawrence River from Lake Ontario to the forty-fifth parallel of latitude), Lake Erie, Lake Huron (including Lake Saint Clair), Lake Michigan, or Lake Superior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78d4f541-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-06-04/ch358/s2"},"text":"June 4, 1956, ch. 358, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/242"},"text":"70 Stat. 242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78d4f542-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78d4f543-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id78d4f544-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1956-06-04/ch358/s1"},"text":"Act June 4, 1956, ch. 358, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/242"},"text":"70 Stat. 242","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1956-06-04/ch358/s1"},"text":"“That this Act [enacting this chapter] may be cited as the ‘Great Lakes Fishery Act of 1956’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"id78d4f545-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1956-06-04/ch358/s14"},"text":"Act June 4, 1956, ch. 358, § 14","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/244"},"text":"70 Stat. 244","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1956-06-04/ch358/s14"},"text":"“If any provision of this Act [this chapter] or the application of such provision to any circumstances or persons shall be held invalid, the validity of the remainder of the Act and the applicability of such provision to other circumstances or persons shall not be affected thereby”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
