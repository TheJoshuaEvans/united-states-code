{"tag":"section","attrib":{"id":"id7987cb8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1870"},"text":null,"children":[{"tag":"num","attrib":{"value":"1870"},"text":"§ 1870.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required possession of descending devices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7987cb8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1870/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Require gear in the Gulf reef fish fishery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for a person on board a commercial or recreational vessel to fish for Gulf reef fish in the Gulf of Mexico Exclusive Economic Zone without possessing on board the vessel a venting tool or a descending device that is rigged and ready for use while fishing is occurring.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7987cb8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1870/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this section shall be interpreted to affect any program or activity carried out by the Gulf Coast Ecosystem Restoration Council established by the Resources and Ecosystems Sustainability, Tourist Opportunities, and Revived Economies of the Gulf Coast States Act of 2012 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1321"},"text":"33 U.S.C. 1321","children":[],"tail":" note), or any project contained in an approved Restoration Plan developed by any Natural Resources Damage Assessment Trustee Implementation Group to reduce post-release mortality from barotrauma in Gulf of Mexico Reef Fish Recreational Fisheries."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7987cb8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1870/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7987cb8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1870/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Descending device","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “descending device” means an instrument that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7987cb90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1870/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will release fish at a depth sufficient for the fish to be able to recover from the effects of barotrauma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7987cb91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1870/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a weighted hook, lip clamp, or box that will hold the fish while it is lowered to depth, or another device determined to be appropriate by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7987cb92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1870/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is capable of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7987cb93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1870/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" releasing the fish automatically;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7987cb94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1870/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" releasing the fish by actions of the operator of the device; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7987cb95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1870/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowing the fish to escape on its own.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7987cb96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1870/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venting tool","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “venting tool” has the meaning given to it by the Gulf of Mexico Fishery Management Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7987cb97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1870/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gulf reef fish","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Gulf reef fish” means any fish chosen by the Gulf of Mexico Fishery Management Council that is in the reef Fishery Management Plan for the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7987cb98-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265/tIII/s321"},"text":"Pub. L. 94–265, title III, § 321","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/340/s3/a"},"text":"Pub. L. 116–340, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-13"},"text":"Jan. 13, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5128"},"text":"134 Stat. 5128","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7987cb99-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id7987cb9a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section five years after ","children":[{"tag":"date","attrib":{"date":"2021-01-13"},"text":"Jan. 13, 2021","children":[],"tail":", see Effective and Termination Dates note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7987cb9b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7987cb9c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Resources and Ecosystems Sustainability, Tourist Opportunities, and Revived Economies of the Gulf Coast States Act of 2012, referred to in subsec. (b), is subtitle F (§ 1601 et seq.) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI"},"text":"Pub. L. 112–141, div. A, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/588"},"text":"126 Stat. 588","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1321"},"text":"section 1321 of Title 33","children":[],"tail":", Navigation and Navigable Waters. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c)(3), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/331"},"text":"90 Stat. 331","children":[],"tail":", known as the Magnuson-Stevens Fishery Conservation and Management Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7987cb9d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7987cb9e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-01-13"},"text":"Jan. 13, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/340/s3/c"},"text":"section 3(c) of Pub. L. 116–340","children":[],"tail":", set out as an Effective and Termination Dates of 2021 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1858"},"text":"section 1858 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/340/s3/e"},"text":"Pub. L. 116–340, § 3(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-13"},"text":"Jan. 13, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5129"},"text":"134 Stat. 5129","children":[],"tail":", provided in part that the termination of this section by section 3(e)(3) is effective five years after "},{"tag":"date","attrib":{"date":"2021-01-13"},"text":"Jan. 13, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
