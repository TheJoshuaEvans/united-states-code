{"tag":"section","attrib":{"id":"id782e075d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539j"},"text":null,"children":[{"tag":"num","attrib":{"value":"539j"},"text":"§ 539j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bowen Gulch Protection Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id782e075e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id782e075f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby established in the Arapaho National Forest, Colorado, the Bowen Gulch Protection Area (hereinafter in this Act referred to as the “protection area”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id782e0760-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The protection area shall consist of certain lands in the Arapaho National Forest, Colorado, which comprise approximately 11,600 acres, as generally depicted as “Area A” on a map entitled “Bowen Gulch Additions to Never Summer Wilderness Proposal”, dated January, 1993.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id782e0761-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer the protection area in accordance with this section and the laws and regulations generally applicable to the National Forest System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id782e0762-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to valid existing rights, all lands within the protection area are hereby withdrawn from all forms of entry, appropriation, or disposal under the public land laws, from location, entry, and patent under the mining laws, and from disposition under the mineral and geothermal leasing laws, including all amendments thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id782e0763-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No developed campgrounds shall be constructed within the protection area. After ","children":[{"tag":"date","attrib":{"date":"1993-08-13"},"text":"August 13, 1993","children":[],"tail":", no new roads or trails may be constructed within the protection area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id782e0764-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539j/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timber harvesting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No timber harvesting shall be allowed within the protection area except to the extent that would be permitted in wilderness under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1133/d/1"},"text":"section 1133(d)(1) of this title","children":[],"tail":" for necessary control of fire, insects, and diseases, and for public safety."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id782e0765-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539j/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motorized travel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Motorized travel shall be permitted within the protection area only on those designated trails and routes existing as of ","children":[{"tag":"date","attrib":{"date":"1991-07-01"},"text":"July 1, 1991","children":[],"tail":", and only during periods of adequate snow cover. At all other times, mechanized, non-motorized travel shall be permitted within the protection area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id782e0766-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539j/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the revision of the Land and Resource Management Plan for the Arapaho National Forest, the Forest Service shall develop a management plan for the protection area, after providing for public comment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id782e0767-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/77/s6"},"text":"Pub. L. 103–77, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-13"},"text":"Aug. 13, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/761"},"text":"107 Stat. 761","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id782e0768-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id782e0769-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id782e076a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/77"},"text":"Pub. L. 103–77","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-13"},"text":"Aug. 13, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/756"},"text":"107 Stat. 756","children":[],"tail":", known as the Colorado Wilderness Act of 1993. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539i"},"text":"section 539i of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id782e076b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id782e076c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Arapaho National Forest Boundary Adjustment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1002"},"text":"Pub. L. 116–9, title I, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/587"},"text":"133 Stat. 587","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/9/tI/s1002"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The boundary of the Arapaho National Forest in the State of Colorado is adjusted to incorporate the approximately 92.95 acres of land generally depicted as ‘The Wedge’ on the map entitled ‘Arapaho National Forest Boundary Adjustment’ and dated ","children":[{"tag":"date","attrib":{"date":"2013-11-06"},"text":"November 6, 2013","children":[],"tail":", and described as lots three, four, eight, and nine of section 13, Township 4 North, Range 76 West, Sixth Principal Meridian, Colorado. A lot described in this subsection may be included in the boundary adjustment only after the Secretary of Agriculture obtains written permission for such action from the lot owner or owners."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bowen Gulch Protection Area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Agriculture shall include all Federal land within the boundary described in subsection (a) in the Bowen Gulch Protection Area established under section 6 of the Colorado Wilderness Act of 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539j"},"text":"16 U.S.C. 539j","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Land and Water Conservation Fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s200306/a/2/B/i"},"text":"section 200306(a)(2)(B)(i) of title 54","children":[],"tail":", United States Code, the boundaries of the Arapaho National Forest, as modified under subsection (a), shall be considered to be the boundaries of the Arapaho National Forest as in existence on "},{"tag":"date","attrib":{"date":"1965-01-01"},"text":"January 1, 1965","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Motorized Use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section opens privately owned lands within the boundary described in subsection (a) to public motorized use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to Non-Federal Lands","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding the provisions of section 6(f) of the Colorado Wilderness Act of 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539j/f"},"text":"16 U.S.C. 539j(f)","children":[],"tail":") regarding motorized travel, the owners of any non-Federal lands within the boundary described in subsection (a) who historically have accessed their lands through lands now or hereafter owned by the United States within the boundary described in subsection (a) shall have the continued right of motorized access to their lands across the existing roadway.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id782e076d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/77/s1/b"},"text":"Pub. L. 103–77, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-13"},"text":"Aug. 13, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/756"},"text":"107 Stat. 756","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/77/s1/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this Act [see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539i"},"text":"section 539i of this title","children":[],"tail":"] with reference to lands in the National Forest System, the term ‘the Secretary’ means the Secretary of Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this Act with respect to lands not in the National Forest System, the term ‘the Secretary’ means the Secretary of the Interior.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
