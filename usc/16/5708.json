{"tag":"section","attrib":{"id":"id7a01681f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5708"},"text":null,"children":[{"tag":"num","attrib":{"value":"5708"},"text":"§ 5708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative matters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a016820-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of Panel members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Panel members and alternate Panel members who are not State or Federal employees shall receive compensation at the daily rate of GS–15 of the General Schedule when engaged in the actual performance of duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016821-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel and other expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Travel and other necessary expenses shall be paid for all Panel members, alternate Panel members, United States members of the Joint Technical Committee, and members of the Advisory Committee when engaged in the actual performance of duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016822-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status as Federal employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except for officials of the United States Government, individuals described in subsection (b) shall not be considered to be Federal employees while engaged in the actual performance of duties, except for the purposes of injury compensation or tort claims liability as provided in chapter 81 of title 5 and chapter 71 ","children":[{"tag":"ref","attrib":{"idref":"fn002816"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002816"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be chapter “171”."}],"tail":" of title 28."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a016823-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tVII/s709"},"text":"Pub. L. 104–43, title VII, § 709","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/395"},"text":"109 Stat. 395","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a016824-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a016825-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a016826-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (a), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
