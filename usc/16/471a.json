{"tag":"section","attrib":{"id":"id781af442-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s471a"},"text":null,"children":[{"tag":"num","attrib":{"value":"471a"},"text":"§ 471a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest reserves in New Mexico and Arizona restricted","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No forest reservation shall be created, nor shall any additions be made to one created prior to ","children":[{"tag":"date","attrib":{"date":"1926-06-15"},"text":"June 15, 1926","children":[],"tail":", within the limits of the States of New Mexico and Arizona except by Act of Congress."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id781af443-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-06-15/ch587"},"text":"June 15, 1926, ch. 587","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/745"},"text":"44 Stat. 745","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id781af444-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id781af445-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id781af446-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Forest reservation, referred to in text, probably should be “national forest”. See ","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"act Mar. 4, 1907, ch. 2907","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1269"},"text":"34 Stat. 1269","children":[],"tail":", which provided that forest reserves shall hereafter be known as national forests."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
