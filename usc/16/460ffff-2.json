{"tag":"section","attrib":{"id":"id7811576b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ffff–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ffff–2"},"text":"§ 460ffff–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7811576c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ffff–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", in accordance with subsections (b) and (c), the Secretary shall develop a comprehensive plan for the long-term management of the Scenic Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7811576d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ffff–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the management plan, the Secretary shall consult with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7811576e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ffff–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate State, Tribal, and local governmental entities, including Inyo County and the Tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7811576f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ffff–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilities, including Southern California Edison Company and the Los Angeles Department of Water and Power;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78115770-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ffff–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Alabama Hills Stewardship Group; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78115771-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ffff–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78115772-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ffff–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with this subchapter, the management plan shall include provisions for maintenance of existing public utility and other rights-of-way within the Scenic Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78115773-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ffff–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the management plan, in accordance with this section, the Secretary may allow casual use mining limited to the use of hand tools, metal detectors, hand-fed dry washers, vacuum cleaners, gold pans, small sluices, and similar items.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78115774-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ffff–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pending completion of the management plan, the Secretary shall manage the Scenic Area in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460ffff–1/b"},"text":"section 460ffff–1(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78115775-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tXIV/s1403"},"text":"Pub. L. 103–433, title XIV, § 1403","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1441"},"text":"Pub. L. 116–9, title I, § 1441","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/709"},"text":"133 Stat. 709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78115776-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78115777-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id78115778-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","childre