{"tag":"section","attrib":{"id":"id787a52a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698m–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"698m–1"},"text":"§ 698m–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Big Cypress National Preserve Addition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id787a52a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698m–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id787a52a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698m–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieve the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s698f"},"text":"section 698f of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787a52a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698m–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete the preserve in conjunction with the planned construction of Interstate Highway 75; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787a52aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698m–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insure appropriately managed use and access to the Big Cypress Watershed in the State of Florida,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Big Cypress National Preserve Addition is established.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787a52ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698m–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location; boundaries; publication in Federal Register","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Big Cypress National Preserve Addition (referred to in sections 698f to 698m–4 of this title as the “Addition”) shall comprise approximately 146,000 acres as generally depicted on the map entitled Big Cypress National Preserve Addition, dated April, 1987, and numbered 176–91000C, which shall be on file and available for public inspection in the Office of the National Park Service, Department of the Interior, Washington, D.C., and shall be filed with appropriate offices of Collier County in the State of Florida. The Secretary shall, as soon as practicable, publish a detailed description of the boundaries of the Addition in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787a52ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698m–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation; management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The area within the boundaries depicted on the map referred to in subsection (b) shall be known as the “Big Cypress National Preserve Addition” and shall be managed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s698i"},"text":"section 698i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787a52ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698m–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion of land acquisition; time","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of administering the Addition and notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s698g/c"},"text":"section 698g(c) of this title","children":[],"tail":", it is the express intent of the Congress that the Secretary should substantially complete the land acquisition program contemplated with respect to the Addition in not more than five years after "},{"tag":"date","attrib":{"date":"1988-04-29"},"text":"April 29, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id787a52ae-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/440/s9"},"text":"Pub. L. 93–440, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/301/s3/a"},"text":"Pub. L. 100–301, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-29"},"text":"Apr. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/444"},"text":"102 Stat. 444","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
