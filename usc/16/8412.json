{"tag":"section","attrib":{"id":"id7a35e624-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412"},"text":null,"children":[{"tag":"num","attrib":{"value":"8412"},"text":"§ 8412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identifying opportunities for recreation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a35e625-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory and assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e626-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a35e627-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an inventory and assessment of recreation resources for Federal recreational lands and waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e628-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop the inventory and assessment with support from public comment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e629-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update the inventory and assessment as the Secretary concerned determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e62a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unique recreation values","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An inventory and assessment conducted under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a35e62b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recognize—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a35e62c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any unique recreation values and recreation opportunities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a35e62d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas of concentrated recreational use; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e62e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify, list, and map recreation resources by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a35e62f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" type of recreation opportunity and type of natural or artificial recreation infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a35e630-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent available, the level of use of the recreation resource as of the date of the inventory; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a35e631-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying, to the extent practicable, any trend relating to recreation opportunities or use at a recreation resource identified under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e632-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any recreation resource inventoried under paragraph (1), the Secretary concerned shall assess—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a35e633-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance needs of, and expenses necessary to administer, the recreation resource;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e634-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the suitability for developing, expanding, or enhancing the recreation resource; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e635-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of the current management of the recreation resource.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e636-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, the Secretary concerned shall use or incorporate existing applicable research and planning decisions and processes in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e637-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8412/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a35e638-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s112"},"text":"Pub. L. 118–234, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2838"},"text":"138 Stat. 2838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a35e639-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a35e63a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a35e63b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s112"},"text":"section 112 of Pub. L. 118–234","children":[],"tail":". Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/s112"},"text":"section 112 of Pub. L. 118–234","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s200103"},"text":"section 200103 of Title 54","children":[],"tail":", National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
