{"tag":"section","attrib":{"id":"id7a35e63f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421"},"text":null,"children":[{"tag":"num","attrib":{"value":"8421"},"text":"§ 8421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biking on long-distance trails","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a35e640-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of long-distance trails","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretaries shall identify—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e641-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not fewer than 10 long-distance bike trails that make use of trails and roads in existence on ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e642-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not fewer than 10 areas in which there is an opportunity to develop or complete a trail that would qualify as a long-distance bike trail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e643-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e644-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a process to allow members of the public to comment regarding the identification of trails and areas under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e645-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the identification, development, and completion of long-distance bike trails in a geographically equitable manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e646-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maps, signage, and promotional materials","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any long-distance bike trail identified under subsection (a), the Secretary concerned may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e647-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish and distribute maps, install signage, and issue promotional materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e648-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with stakeholders to leverage any non-Federal resources necessary for the stewardship, development, or completion of trails.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e649-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretaries, in partnership with interested organizations, shall prepare and publish a report that lists the trails identified under subsection (a), including a summary of public comments received in accordance with the process developed under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e64a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict avoidance with other uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before identifying a long-distance bike trail under subsection (a), the Secretary concerned shall ensure the long-distance bike trail—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e64b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" minimizes conflict with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a35e64c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the uses, before ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", of any trail or road that is part of that long-distance bike trail;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e64d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiple-use areas where biking, hiking, horseback riding, or use by pack and saddle stock are existing uses on ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e64e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes for which any trail was or is established under the National Trails System Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1241"},"text":"16 U.S.C. 1241","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e64f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any area managed under the Wilderness Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e650-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with land use and management plans of the Federal recreational lands and waters that are part of that long-distance bike trail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e651-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eminent domain or condemnation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretaries may not use eminent domain or condemnation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e652-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e653-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-distance bike trail","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “long-distance bike trail” means a continuous route, consisting of 1 or more trails or rights-of-way, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a35e654-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not less than 80 miles in length;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e655-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primarily makes use of dirt or natural surface trails;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e656-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may require connections along paved or other improved roads;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e657-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include Federal recreational lands where mountain biking or related activities are not consistent with management requirements for those Federal recreational lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e658-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/g/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, makes use of trails and roads that were on Federal recreational lands on or before ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e659-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8421/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretaries” means the Secretary of the Interior and the Secretary of Agriculture, acting jointly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a35e65a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s121"},"text":"Pub. L. 118–234, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2842"},"text":"138 Stat. 2842","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a35e65b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a35e65c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a35e65d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Trails System Act, referred to in subsec. (e)(1)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/543"},"text":"Pub. L. 90–543","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-02"},"text":"Oct. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/919"},"text":"82 Stat. 919","children":[],"tail":", which is classified generally to chapter 27 (§ 1241 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1241"},"text":"section 1241 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Wilderness Act, referred to in subsec. (e)(1)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/577"},"text":"Pub. L. 88–577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-03"},"text":"Sept. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/890"},"text":"78 Stat. 890","children":[],"tail":", which is classified generally to chapter 23 (§ 1131 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"section 1131 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
