{"tag":"section","attrib":{"id":"id795cea55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1706"},"text":null,"children":[{"tag":"num","attrib":{"value":"1706"},"text":"§ 1706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated amounts not to exceed $60,000,000 for each fiscal year, which amounts shall be made available to the Secretary of the Interior and the Secretary of Agriculture to carry out the purposes of this subchapter. Notwithstanding any other provision of law, funds appropriated for any fiscal year to carry out this subchapter shall remain available for obligation and expenditure until the end of the fiscal year following the fiscal year for which appropriated.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id795cea56-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/378/tI/s106"},"text":"Pub. L. 91–378, title I, § 106","children":[],"tail":", formerly § 6, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/597"},"text":"Pub. L. 92–597","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1321"},"text":"86 Stat. 1321","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/408"},"text":"Pub. L. 93–408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-03"},"text":"Sept. 3, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1068"},"text":"88 Stat. 1068","children":[],"tail":"; renumbered title I, § 106, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s105/1"},"text":"Pub. L. 103–82, title I, § 105(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/848"},"text":"107 Stat. 848","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795cea57-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id795cea58-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id795cea59-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s105/2"},"text":"Pub. L. 103–82, § 105(2)","children":[],"tail":", substituted “subchapter” for “chapter” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/408"},"text":"Pub. L. 93–408","children":[],"tail":" substituted authorization of appropriation of amount not exceeding $60,000,000 for each fiscal year for authorization of appropriation of amounts not exceeding $30,000,000 for fiscal year ending "},{"tag":"date","attrib":{"date":"1973-06-30"},"text":"June 30, 1973","children":[],"tail":" and $60,000,000 for fiscal year ending "},{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id795cea5a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id795cea5b-6992-11f1-ab3f-