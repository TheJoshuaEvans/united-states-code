{"tag":"section","attrib":{"id":"id78de6b7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973m"},"text":null,"children":[{"tag":"num","attrib":{"value":"973m"},"text":"§ 973m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fisheries-related assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary and the Secretary of State may provide assistance to a Pacific Island Party to benefit such Pacific Island Party from the development of fisheries resources and the operation of fishing vessels that are licensed pursuant to the Treaty, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78de6b80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78de6b81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and capacity building opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78de6b82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973m/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitation of the implementation of private sector activities or partnerships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78de6b83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973m/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities as determined appropriate by the Secretary and the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78de6b84-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/330/s15"},"text":"Pub. L. 100–330, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-07"},"text":"June 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/600"},"text":"102 Stat. 600","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIV/s8423"},"text":"Pub. L. 119–60, div. H, title LXXXIV, § 8423","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1918"},"text":"139 Stat. 1918","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78de6b85-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78de6b86-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78de6b87-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “The United States tuna industry shall provide $250,000 annually in technical assistance, including provision of assistance by technicians, in response to requests coordinated through the Administrator. The Secretary of State shall designate an entity to coordinate the provision of such technical assistance as provided by the United States tuna industry and to provide an annual report to the Secretary of State regarding the provision of such technical assistance.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
