attrib":{"id":"id778718ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id778718eb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/525/tI/s101"},"text":"Pub. L. 102–525, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-26"},"text":"Oct. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3438"},"text":"106 Stat. 3438","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/123"},"text":"Pub. L. 117–123","children":[],"tail":", §§ 2(c)(2), (4), 3(b), "},{"tag":"date","attrib":{"date":"2022-05-12"},"text":"May 12, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1196"},"text":"136 Stat. 1196","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778718ec-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id778718ed-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id778718ee-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/123/s3/b/1"},"text":"Pub. L. 117–123, § 3(b)(1)","children":[],"tail":", substituted “In this subchapter:” for “As used in this subchapter—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/123/s3/b/5"},"text":"Pub. L. 117–123, § 3(b)(5)","children":[],"tail":", added par. (1). Former par. (1) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/123/s3/b/2"},"text":"Pub. L. 117–123, § 3(b)(2)","children":[],"tail":"–(4), inserted heading, substituted “The term” for “the term”, and subsequently redesignated par. (1) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/123/s3/b/3"},"text":"Pub. L. 117–123, § 3(b)(3)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/123/s2/c/2"},"text":"Pub. L. 117–123, § 2(c)(2)","children":[],"tail":", (4), substituted “historical park” for “historic site” and “National Historical Park” for “National Historic Site”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/123/s3/b/4"},"text":"Pub. L. 117–123, § 3(b)(4)","children":[],"tail":", redesignated par. (1) as (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id778718ef-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id778718f0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/123/s1"},"text":"Pub. L. 117–123, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-05-12"},"text":"May 12, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1196"},"text":"136 Stat. 1196","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/123/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410iiii–5"},"text":"section 410iiii–5 of this title","children":[],"tail":", amending this section and sections 410iiii–1 to 410iiii–4 and 410iiii–6 of this title, and enacting provisions set out as notes under this section] may be cited as the ‘Brown v. Board of Education National Historical Park Expansion and Redesignation Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id778718f1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Redesignation of the Brown v. Board of Education National Historical Park; References","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/123/s2/a"},"text":"Pub. L. 117–123, § 2(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2022-05-12"},"text":"May 12, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1196"},"text":"136 Stat. 1196","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/123/s2/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Brown v. Board of Education National Historic Site established by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/525/s103/a"},"text":"section 103(a) of Public Law 102–525","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/106/3439"},"text":"106 Stat. 3439","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410iiii–2/a"},"text":"16 U.S.C. 410iiii–2(a)","children":[],"tail":"] shall be known and designated as the ‘Brown v. Board of Education National Historical Park’."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reference in any law, regulation, document, record, map, or other paper of the United States to the Brown v. Board of Education National Historic Site shall be considered to be a reference to the ‘Brown v. Board of Education National Historical Park’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id778718f2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose for Expansion of the Brown v. Board of Education National Historical Park and Establishment of Affiliated Areas","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/123/s3/a"},"text":"Pub. L. 117–123, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-05-12"},"text":"May 12, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1196"},"text":"136 Stat. 1196","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/123/s3/a"},"text":"“The purpose of this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410iiii–5"},"text":"section 410iiii–5 of this title","children":[],"tail":" and amending this section and sections 410iiii–1 to 410iiii–4 and 410iiii–6 of this title] is to honor the civil rights stories of struggle, perseverance, and activism in the pursuit of education equity.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
