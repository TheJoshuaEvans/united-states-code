{"tag":"section","attrib":{"id":"id77afaf80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459h"},"text":null,"children":[{"tag":"num","attrib":{"value":"459h"},"text":"§ 459h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gulf Islands National Seashore","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77afaf81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to preserve for public use and enjoyment certain areas possessing outstanding natural, historic, and recreational values, the Secretary of the Interior (hereinafter referred to as the “Secretary”) may establish and administer the Gulf Islands National Seashore (hereinafter referred to as the “seashore”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77afaf82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77afaf83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The seashore shall comprise the areas described in paragraphs (2) and (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77afaf84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas included in boundary plan numbered NS–GI–7100J","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The areas described in this paragraph are the following gulf coast islands and mainland areas, together with adjacent water areas as generally depicted on the drawing entitled “Proposed Boundary Plan, Proposed Gulf Islands National Seashore,” numbered NS–GI–7100J, and dated December 1970:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77afaf85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459h/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ship, Petit Bois, and Horn Islands in Mississippi;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77afaf86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459h/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eastern portion of Perdido Key in Florida;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77afaf87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459h/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Santa Rosa Island in Florida;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77afaf88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459h/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Naval Live Oaks Reservation in Florida;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77afaf89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459h/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fort Pickens and the Fort Pickens State Park in Florida; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77afaf8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459h/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tract of land in the Pensacola Naval Air Station in Florida that includes the Coast Guard Station and Lighthouse, Fort San Carlos, Fort Barrancas, and Fort Redoubt and sufficient surrounding land for proper administration and protection of the historic resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77afaf8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cat Island","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon its acquisition by the Secretary, the area described in this paragraph is the parcel consisting of approximately 2,000 acres of land on Cat Island, Mississippi, as generally depicted on the map entitled “Boundary Map, Gulf Islands National Seashore, Cat Island, Mississippi”, numbered 635/80085, and dated ","children":[{"tag":"date","attrib":{"date":"1999-11-09"},"text":"November 9, 1999","children":[],"tail":" (referred to in sections 459h to 459h–10 of this title "},{"tag":"ref","attrib":{"idref":"fn002284"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002284"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" as the “Cat Island Map”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77afaf8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459h/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Cat Island Map shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77afaf8d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/660/s1"},"text":"Pub. L. 91–660, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1967"},"text":"84 Stat. 1967","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s137/a"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 137(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–231.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77afaf8e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77afaf8f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77afaf90-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 459h to 459h–10 of this title, referred to in subsec. (b)(3), was in the original “this title”, and was translated as reading “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/660"},"text":"Pub. L. 91–660","children":[],"tail":", which enacted sections 459h to 459h–10 of this title, to reflect the probable intent of Congress, because "},{"tag":"ref","attrib":{"href":"/us/pl/91/660"},"text":"Pub. L. 91–660","children":[],"tail":" does not contain titles."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77afaf91-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" inserted section catchline and subsec. (a) designation and heading, substituted “In order” for “That, in order”, inserted subsec. (b) designation and heading, added par. (1), inserted par. (2) designation and heading and substituted “The areas described in this paragraph are” for “The seashore shall comprise”, redesignated former pars. (1) to (6) as subpars. (A) to (F), respectively, of par. (2), realigned margins, and added pars. (3) and (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
