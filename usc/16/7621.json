{"tag":"section","attrib":{"id":"id7a29ff43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7621"},"text":null,"children":[{"tag":"num","attrib":{"value":"7621"},"text":"§ 7621.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a29ff44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7621/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2016-10-07"},"text":"October 7, 2016","children":[],"tail":", and biennially thereafter by June 1 of each year in which a report is required, the Secretary of State, in consultation with the Secretary of the Interior and the Secretary of Commerce, shall submit to Congress a report that lists each country determined by the Secretary of State to be a focus country within the meaning of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29ff45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7621/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In each report required under subsection (a), the Secretary of State, in consultation with the Secretary of the Interior and the Secretary of Commerce, shall also list each country determined by the Secretary of State to be a country of concern within the meaning of this chapter ","children":[{"tag":"ref","attrib":{"idref":"fn002860"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002860"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29ff46-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7621/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure for removing countries from list","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Concurrently with the first report required under this section and submitted after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary of State, in consultation with the Secretary of the Interior and the Secretary of Commerce, shall publish in the Federal Register a procedure for removing from the list described in subsection (b) any country that no longer meets the definition of country of concern under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7601/4"},"text":"section 7601(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29ff47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7621/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall cease to have force or effect on ","children":[{"tag":"date","attrib":{"date":"2028-09-30"},"text":"September 30, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a29ff48-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/231/tII/s201"},"text":"Pub. L. 114–231, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"Oct. 7, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/952"},"text":"130 Stat. 952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIX/s5943/c/1"},"text":"Pub. L. 117–263, div. E, title LIX, § 5943(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3470"},"text":"136 Stat. 3470","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a29ff49-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id7a29ff4a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section on ","children":[{"tag":"date","attrib":{"date":"2028-09-30"},"text":"Sept. 30, 2028","children":[],"tail":", see subsec. (d) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a29ff4b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a29ff4c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/231"},"text":"Pub. L. 114–231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"Oct. 7, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/949"},"text":"130 Stat. 949","children":[],"tail":", known as the Eliminate, Neutralize, and Disrupt Wildlife Trafficking Act of 2016, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7601"},"text":"section 7601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a29ff4d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5943/c/1/A"},"text":"Pub. L. 117–263, § 5943(c)(1)(A)","children":[],"tail":", substituted “biennially thereafter by June 1 of each year in which a report is required” for “annually thereafter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5943/c/1/B"},"text":"Pub. L. 117–263, § 5943(c)(1)(B)","children":[],"tail":", substituted “shall also list each country determined by the Secretary of State to be a country of concern within the meaning of this chapter” for “shall identify each country of concern listed in the report the government of which has actively engaged in or knowingly profited from the trafficking of endangered or threatened species.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5943/c/1/C"},"text":"Pub. L. 117–263, § 5943(c)(1)(C)","children":[],"tail":", added subsecs. (c) and (d) and struck out former subsec. (c). Prior to amendment, text of subsec. (c) read as follows: “This section shall terminate on the date that is 5 years after "},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"October 7, 2016","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
