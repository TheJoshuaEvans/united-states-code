{"tag":"section","attrib":{"id":"id773f884a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s406d–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"406d–4"},"text":"§ 406d–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of other lands by Secretary of the Interior","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to accept the donation of the following-described lands, which lands, upon acceptance by the United States, shall become a part of the national park:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"sixth principal meridian","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Township 41 north, range 116 west: Section 3, lots 1 and 2.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Containing seventy-eight and ninety-three one-hundredths acres, more or less.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id773f884b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-14/ch950/s7"},"text":"Sept. 14, 1950, ch. 950, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/852"},"text":"64 Stat. 852","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id773f884c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id773f884d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id773f884e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"R