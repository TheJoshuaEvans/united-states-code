{"tag":"section","attrib":{"id":"id76fcda53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s79q"},"text":null,"children":[{"tag":"num","attrib":{"value":"79q"},"text":"§ 79q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pledge of full faith and credit of United States for payment of compensation for lands, etc., taken","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Congress further acknowledges and directs that the full faith and credit of the United States is pledged to the prompt payment of just compensation as provided for by the fifth amendment to the Constitution of the United States for those lands and properties taken by this Act.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76fcda54-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/250/tI/s108"},"text":"Pub. L. 95–250, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-27"},"text":"Mar. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/172"},"text":"92 Stat. 172","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id76fcda55-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id76fcda56-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id76fcda57-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/250"},"text":"Pub. L. 95–250","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-27"},"text":"Mar. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/163"},"text":"92 Stat. 163","children":[],"tail":", which, insofar as classified to the Code, enacted sections 79c–1 and 79k to 79q of this title, amended former section 1a–1 and sections 79b and 79c of this title, and enacted provisions set out and formerly set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s79k"},"text":"section 79k of this title","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id76fcda58-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/545"},"text":"Pub. L. 90–545","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-02"},"text":"Oct. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/931"},"text":"82 Stat. 931","children":[],"tail":", which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
