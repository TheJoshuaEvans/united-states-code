{"tag":"section","attrib":{"id":"id78438b08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s554d"},"text":null,"children":[{"tag":"num","attrib":{"value":"554d"},"text":"§ 554d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreation facilities for employees of Forest Service and their immediate families","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not to exceed $100,000 annually of funds available to the Forest Service may be expended for providing recreation facilities, equipment, and services for use by employees of the Service located at isolated situations and, where deemed to be in the public interest, by members of the immediate families of such employees.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78438b09-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/869/s3"},"text":"Pub. L. 87–869, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1157"},"text":"76 Stat. 1157","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/512/tII"},"text":"Pub. L. 101–512, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1944"},"text":"104 Stat. 1944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78438b0a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78438b0b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78438b0c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/512"},"text":"Pub. L. 101–512","children":[],"tail":" substituted “$100,000” for “$35,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
