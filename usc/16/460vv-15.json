{"tag":"section","attrib":{"id":"id77eb320c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vv–15"},"text":null,"children":[{"tag":"num","attrib":{"value":"460vv–15"},"text":"§ 460vv–15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to such limitations, conditions, or regulations as he may prescribe, the Secretary of Agriculture shall permit grazing on lands within the Ouachita National Forest, Le Flore County, Oklahoma.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77eb320d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/499/s17"},"text":"Pub. L. 100–499, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-18"},"text":"Oct. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2499"},"text":"102 Stat. 2499","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
