{"tag":"section","attrib":{"id":"id786e6c30-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"669h–1"},"text":"§ 669h–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Firearm and bow hunter education and safety program grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id786e6c31-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id786e6c32-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the revenues covered into the fund, $7,500,000 for each of fiscal years 2001 and 2002, and $8,000,000 for fiscal year 2003 and each fiscal year thereafter, shall be apportioned among the States in the manner specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s669c/c"},"text":"section 669c(c) of this title","children":[],"tail":" by the Secretary of the Interior and used to make grants to the States to be used for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id786e6c33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a State that has not used all of the funds apportioned to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s669c/c"},"text":"section 669c(c) of this title","children":[],"tail":" for the fiscal year in the manner described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s669g/b"},"text":"section 669g(b) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id786e6c34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enhancement of hunter education programs, hunter and sporting firearm safety programs, and hunter development programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id786e6c35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enhancement of interstate coordination and development of hunter education and shooting range programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id786e6c36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enhancement of bow hunter and archery education, safety, and development programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id786e6c37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enhancement of construction or development of firearm shooting ranges and archery ranges, and the updating of safety features of firearm shooting ranges and archery ranges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id786e6c38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enhancement of hunter recruitment and recreational shooter recruitment; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id786e6c39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a State that has used all of the funds apportioned to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s669c/c"},"text":"section 669c(c) of this title","children":[],"tail":" for the fiscal year in the manner described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s669g/b"},"text":"section 669g(b) of this title","children":[],"tail":", any use authorized by this chapter (including hunter safety programs and the construction, operation, and maintenance of public target ranges)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id786e6c3a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under paragraph (1), a State shall not be required to use more than the amount described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s669g/b"},"text":"section 669g(b) of this title","children":[],"tail":" for hunter safety programs and the construction, operation, and maintenance of public target ranges."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id786e6c3b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of additional amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount apportioned to a State for any fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s669c/b"},"text":"section 669c(b) of this title","children":[],"tail":", the State may elect to allocate not more than 10 percent, to be combined with the amount apportioned to the State under paragraph (1) for that fiscal year, for acquiring land for, expanding, or constructing a public target range."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id786e6c3c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id786e6c3d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Federal share of the cost of any activity carried out using a grant under this section shall not exceed 75 percent of the total cost of the activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id786e6c3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public target range construction or expansion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of acquiring land for, expanding, or constructing a public target range in a State on Federal or non-Federal land pursuant to this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s669g/b"},"text":"section 669g(b) of this title","children":[],"tail":" shall not exceed 90 percent of the cost of the activity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id786e6c3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of availability; reapportionment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id786e6c40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of availability","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id786e6c41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), amounts made available and apportioned for grants under this section shall remain available only for the fiscal year for which the amounts are apportioned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id786e6c42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts provided for acquiring land for, constructing, or expanding a public target range shall remain available for expenditure and obligation during the 5-fiscal-year period beginning on October 1 of the first fiscal year for which the amounts are made available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id786e6c43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reapportionment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the end of the period of availability under paragraph (1), the Secretary of the Interior shall apportion amounts made available that have not been used to make grants under this section among the States described in subsection (a)(1)(B) for use by those States in accordance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id786e6c44-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-02/ch899/s10"},"text":"Sept. 2, 1937, ch. 899, § 10","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/408/tI/s112/2"},"text":"Pub. L. 106–408, title I, § 112(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1766"},"text":"114 Stat. 1766","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/17/s4/c"},"text":"Pub. L. 116–17, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-05-10"},"text":"May 10, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/867"},"text":"133 Stat. 867","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tV/s501/f"},"text":"Pub. L. 116–94, div. P, title V, § 501(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3193"},"text":"133 Stat. 3193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id786e6c45-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id786e6c46-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id786e6c47-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 10 of act ","children":[{"tag":"date","attrib":{"date":"1937-09-02"},"text":"Sept. 2, 1937","children":[],"tail":", was renumbered section 12 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s669i"},"text":"section 669i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id786e6c48-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1)(A)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" added cl. (v)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/17/s4/c/1"},"text":"Pub. L. 116–17, § 4(c)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/17/s4/c/2"},"text":"Pub. L. 116–17, § 4(c)(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “The Federal share of the cost of any activity carried out with a grant under this section shall not exceed 75 percent of the total cost of the activity.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/17/s4/c/3"},"text":"Pub. L. 116–17, § 4(c)(3)","children":[],"tail":", designated existing provisions as subpar. (A), inserted heading, substituted “Except as provided in subparagraph (B), amounts made” for “Amounts made”, and added subpar. (B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
