{"tag":"section","attrib":{"id":"id79fcac91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5155"},"text":null,"children":[{"tag":"num","attrib":{"value":"5155"},"text":"§ 5155.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing studies of striped bass populations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79fcac92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5155/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of carrying out this chapter, the Secretaries shall conduct continuing, comprehensive studies of Atlantic striped bass stocks. These studies shall include, but shall not be limited to, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fcac93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5155/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Annual stock assessments, using fishery-dependent and fishery-independent data, for the purposes of extending the long-term population record generated by the annual striped bass study conducted by the Secretaries before 1994 and understanding the population dynamics of Atlantic striped bass.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcac94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5155/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Investigations of the causes of fluctuations in Atlantic striped bass populations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcac95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5155/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Investigations of the effects of water quality, land use, and other environmental factors on the recruitment, spawning potential, mortality, and abundance of Atlantic striped bass populations, including the Delaware River population.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcac96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5155/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Investigations of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79fcac97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5155/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interactions between Atlantic striped bass and other fish, including bluefish, menhaden, mackerel, and other forage fish or possible competitors, stock assessments of these species, to the extent appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fcac98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5155/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects of interspecies predation and competition on the recruitment, spawning potential mortality, and abundance of Atlantic striped bass.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fcac99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5155/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Socio-economic study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries, in consultation with with ","children":[{"tag":"ref","attrib":{"idref":"fn002810"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002810"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" the Atlantic States Marine Fisheries Commission, shall conduct a study of the socio-economic benefits of the Atlantic striped bass resource. The Secretaries shall issue a report to the Congress concerning the findings of this study no later than "},{"tag":"date","attrib":{"date":"1998-09-30"},"text":"September 30, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fcac9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5155/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries shall make biennial reports to the Congress and to the Commission concerning the progress and findings of studies conducted under subsection (a) and shall make those reports public. Such reports shall, to the extent appropriate, contain recommendations of actions which could be taken to encourage the sustainable management of Atlantic striped bass.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fcac9b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/613/s6"},"text":"Pub. L. 98–613, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-31"},"text":"Oct. 31, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3190"},"text":"98 Stat. 3190","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/146/s2"},"text":"Pub. L. 105–146, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-16"},"text":"Dec. 16, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2675"},"text":"111 Stat. 2675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fcac9c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79fcac9d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79fcac9e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/146"},"text":"Pub. L. 105–146","children":[],"tail":" amended section catchline and text generally, substituting provisions relating to continuing studies of striped bass populations for provisions relating to comprehensive annual surveys."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
