{"tag":"section","attrib":{"id":"id79b2ab98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3231"},"text":null,"children":[{"tag":"num","attrib":{"value":"3231"},"text":"§ 3231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas subject to national need recommendation process","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The process contained in this subchapter shall apply to all public lands within Alaska except for lands within units of the National Park System and the Arctic National Wildlife Refuge.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79b2ab99-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487/tXV/s1501"},"text":"Pub. L. 96–487, title XV, § 1501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2549"},"text":"94 Stat. 2549","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
