{"tag":"section","attrib":{"id":"id7a2eb972-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7803"},"text":null,"children":[{"tag":"num","attrib":{"value":"7803"},"text":"§ 7803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority and responsibility of the Secretary of State","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of State may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2eb973-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7803/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive and transmit, on behalf of the United States, reports, requests, recommendations, proposals, decisions, and other communications of and to the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb974-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7803/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the Secretary, act upon, or refer to other appropriate authority, any communication pursuant to paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb975-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7803/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the concurrence of the Secretary, and in accordance with the South Pacific Fishery Resources Convention, object to decisions of the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2eb976-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/tII/s203"},"text":"Pub. L. 114–327, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1989"},"text":"130 Stat. 1989","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
