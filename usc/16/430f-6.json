{"tag":"section","attrib":{"id":"id7792ffac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"430f–6"},"text":"§ 430f–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corinth Unit of the Shiloh National Military Park; findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7792ffad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7792ffae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in 1996, Congress authorized the establishment and construction of a center—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7792ffaf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the interpretation of the Siege and Battle of Corinth and other Civil War actions in the area in and around the city of Corinth, Mississippi; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7792ffb0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to enhance public understanding of the significance of the Corinth campaign and the Civil War relative to the western theater of operations, in cooperation with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7792ffb1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State or local governmental entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7792ffb2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7792ffb3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7792ffb4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corinth Battlefield was ranked as a priority 1 battlefield having critical need for coordinated nationwide action by the year 2000 by the Civil War Sites Advisory Commission in its report on Civil War Battlefields of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7792ffb5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a national interest in protecting and preserving sites of historic significance associated with the Civil War; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7792ffb6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the States of Mississippi and Tennessee and their respective local units of government—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7792ffb7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the authority to prevent or minimize adverse uses of these historic resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7792ffb8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can play a significant role in the protection of the historic resources related to the Civil War battles fought in the area in and around the city of Corinth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7792ffb9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of sections 430f–6 to 430f–12 of this title are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7792ffba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to establish the Corinth Unit of the Shiloh National Military Park—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7792ffbb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the city of Corinth, Mississippi; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7792ffbc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the State of Tennessee;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7792ffbd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to direct the Secretary of the Interior to manage, protect, and interpret the resources associated with the Civil War Siege and the Battle of Corinth that occurred in and around the city of Corinth, in cooperation with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7792ffbe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State of Mississippi;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7792ffbf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State of Tennessee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7792ffc0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the city of Corinth, Mississippi;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7792ffc1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other public entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7792ffc2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7792ffc3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to authorize a special resource study to identify other Civil War sites in and around the city of Corinth that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7792ffc4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the themes of the Siege and Battle of Corinth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7792ffc5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the criteria for designation as a unit of the National Park System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7792ffc6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–6/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are considered appropriate for inclusion in the Unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7792ffc7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/271/s2"},"text":"Pub. L. 106–271, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-09-22"},"text":"Sept. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/792"},"text":"114 Stat. 792","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7792ffc8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7792ffc9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7792ffca-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/271/s1"},"text":"Pub. L. 106–271, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-09-22"},"text":"Sept. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/792"},"text":"114 Stat. 792","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/271/s1"},"text":"“This Act [enacting this section and sections 430f–7 to 430f–12 of this title] may be cited as the ‘Corinth Battlefield Preservation Act of 2000’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
