{"tag":"section","attrib":{"id":"id782469fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b"},"text":null,"children":[{"tag":"num","attrib":{"value":"497b"},"text":"§ 497b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ski area permits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id782469fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law applicable to permits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of the Act of ","children":[{"tag":"date","attrib":{"date":"1915-03-04"},"text":"March 4, 1915","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s497"},"text":"16 U.S.C. 497","children":[],"tail":") notwithstanding, the term and acreage of permits for the operation of ski areas and associated facilities on National Forest System lands shall on and after "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":", be governed by this section and other applicable law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id782469ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture (hereinafter referred to as “the Secretary”) is authorized to issue permits (hereinafter referred to as “ski area permits”) for the use and occupancy of suitable lands within the National Forest System for skiing and other snow sports and recreational uses authorized by this section. A ski area permit—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78246a00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be issued for a term not to exceed 40 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78246a01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall ordinarily be issued for a term of 40 years (unless the Secretary determines that the facilities or operations are of a scale or nature as are not likely to require long-term financing or operation), or that there are public policy reasons specific to a particular permit for a shorter term;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78246a02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall encompass such acreage as the Secretary determines sufficient and appropriate to accommodate the permittee’s needs for ski operations and appropriate ancillary facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78246a03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be renewed at the discretion of the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78246a04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be cancelled by the Secretary in whole or in part for any violation of the permit terms or conditions, for nonpayment of permit fees, or upon the determination by the Secretary in his planning for the uses of the national forests that the permitted area is needed for higher public purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78246a05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be modified from time to time by the Secretary to accommodate changes in plans or operations in accordance with the provisions of applicable law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78246a06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be subject to such reasonable terms and conditions as the Secretary deems appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78246a07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be subject to a permit fee based on fair market value in accordance with applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78246a08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other recreational uses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78246a09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the terms of a ski area permit issued pursuant to subsection (b), the Secretary may authorize a ski area permittee to provide such other seasonal or year-round natural resource-based recreational activities and associated facilities (in addition to skiing and other snow-sports) on National Forest System land subject to a ski area permit as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78246a0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each activity and facility authorized by the Secretary under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78246a0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage outdoor recreation and enjoyment of nature;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78246a0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent practicable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78246a0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" harmonize with the natural environment of the National Forest System land on which the activity or facility is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78246a0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be located within the developed portions of the ski area;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78246a0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to such terms and conditions as the Secretary determines to be appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78246a10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be authorized in accordance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78246a11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable land and resource management plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78246a12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable laws (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78246a13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities and facilities that may, in appropriate circumstances, be authorized under paragraph (1) include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78246a14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" zip lines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78246a15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mountain bike terrain parks and trails;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78246a16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" frisbee golf courses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78246a17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ropes courses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78246a18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities and facilities that are prohibited under paragraph (1) include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78246a19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tennis courts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78246a1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water slides and water parks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78246a1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" swimming pools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78246a1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" golf courses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78246a1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amusement parks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78246a1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not authorize any activity or facility under paragraph (1) if the Secretary determines that the authorization of the activity or facility would result in the primary recreational purpose of the ski area permit to be a purpose other than skiing and other snow-sports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78246a1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the acreage encompassed by a ski area permit under subsection (b)(3), the Secretary shall not consider the acreage necessary for activities and facilities authorized under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78246a20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on existing authorized activities and facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection affects any activity or facility authorized by a ski area permit in effect on ","children":[{"tag":"date","attrib":{"date":"2011-11-07"},"text":"November 7, 2011","children":[],"tail":", during the term of the permit."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78246a21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2011-11-07"},"text":"November 7, 2011","children":[],"tail":", the Secretary shall promulgate regulations to implement this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78246a22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s497b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction with Secretary’s duties under other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be deemed to amend, modify or otherwise affect the Secretary’s duties under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) and the Forest and Rangeland Renewable Resources Planning Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1600"},"text":"16 U.S.C. 1600","children":[],"tail":" et seq.), including his duties to involve the public in his decisionmaking and planning for the national forests."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78246a23-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/522/s3"},"text":"Pub. L. 99–522, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3000"},"text":"100 Stat. 3000","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/46/s3"},"text":"Pub. L. 112–46, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-07"},"text":"Nov. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/538"},"text":"125 Stat. 538","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78246a24-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78246a25-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78246a26-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1915-03-04"},"text":"March 4, 1915","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s497"},"text":"16 U.S.C. 497","children":[],"tail":"), referred to in subsec. (a), is "},{"tag":"ref","attrib":{"href":"/us/act/1915-03-04/ch144"},"text":"act Mar. 4, 1915, ch. 144","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/1086"},"text":"38 Stat. 1086","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section, referred to in subsecs. (a), (b), and (e), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/522"},"text":"Pub. L. 99–522","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3000"},"text":"100 Stat. 3000","children":[],"tail":", known as the National Forest Ski Area Permit Act of 1986, which enacted this section and notes set out under this section. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Forest and Rangeland Renewable Resources Planning Act of 1974, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/378"},"text":"Pub. L. 93–378","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-17"},"text":"Aug. 17, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/476"},"text":"88 Stat. 476","children":[],"tail":", which is classified generally to subchapter I (§ 1600 et seq.) of chapter 36 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1600"},"text":"section 1600 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78246a27-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/46/s3/1"},"text":"Pub. L. 112–46, § 3(1)","children":[],"tail":", substituted “ski areas and associated facilities” for “nordic and alpine ski areas and facilities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/46/s3/2"},"text":"Pub. L. 112–46, § 3(2)","children":[],"tail":", substituted “skiing and other snow sports and recreational uses authorized by this section” for “nordic and alpine skiing operations and purposes” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/46/s3/4"},"text":"Pub. L. 112–46, § 3(4)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/46/s3/5"},"text":"Pub. L. 112–46, § 3(5)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d). Prior to amendment, text read as follows: “Within one year after "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":", the Secretary shall promulgate rules and regulations to implement the provisions of this section, and shall, to the extent practicable and with the consent of existing permit holders, convert all existing ski area permits or leases on National Forest System lands into ski area permits which conform to the provisions of this section within 3 years of "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/46/s3/3"},"text":"Pub. L. 112–46, § 3(3)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/46/s3/6"},"text":"Pub. L. 112–46, § 3(6)","children":[],"tail":", substituted “the National Environmental Policy Act of 1969 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) and the Forest and Rangeland Renewable Resources Planning Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1600"},"text":"16 U.S.C. 1600","children":[],"tail":" et seq.)” for “the National Environmental Policy Act, or the Forest and Rangelands Renewable Resources Planning Act as amended by the National Forest Management Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/46/s3/3"},"text":"Pub. L. 112–46, § 3(3)","children":[],"tail":", redesignated subsec. (d) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78246a28-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id78246a29-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/46/s1"},"text":"Pub. L. 112–46, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-07"},"text":"Nov. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/538"},"text":"125 Stat. 538","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/46/s1"},"text":"“This Act [amending this section and enacting provisions set out as notes under this section] may be cited as the ‘Ski Area Recreational Opportunity Enhancement Act of 2011’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id78246a2a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/522/s1"},"text":"Pub. L. 99–522, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3000"},"text":"100 Stat. 3000","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/522/s1"},"text":"“This Act [enacting this section and provisions set out as a note below] may be cited as the ‘National Forest Ski Area Permit Act of 1986’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78246a2b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effect","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/46/s4"},"text":"Pub. L. 112–46, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-07"},"text":"Nov. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/540"},"text":"125 Stat. 540","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/46/s4"},"text":"“Nothing in the amendments made by this Act [amending this section] establishes a legal preference for the holder of a ski area permit to provide activities and associated facilities authorized by section 3(c) of the National Forest Ski Area Permit Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s497b/c"},"text":"16 U.S.C. 497b(c)","children":[],"tail":") (as amended by section 3).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78246a2c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purposes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/46/s2"},"text":"Pub. L. 112–46, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-07"},"text":"Nov. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/538"},"text":"125 Stat. 538","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/46/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The purpose of this Act [see Short Title of 2011 Amendment note above] is to amend the National Forest Ski Area Permit Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s497b"},"text":"16 U.S.C. 497b","children":[],"tail":")—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable snow-sports (other than nordic and alpine skiing) to be permitted on National Forest System land subject to ski area permits issued by the Secretary of Agriculture under section 3 of the National Forest Ski Area Permit Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s497b"},"text":"16 U.S.C. 497b","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to clarify the authority of the Secretary of Agriculture to permit appropriate additional seasonal or year-round recreational activities and facilities on National Forest System land subject to ski area permits issued by the Secretary of Agriculture under section 3 of the National Forest Ski Area Permit Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s497b"},"text":"16 U.S.C. 497b","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/522/s2"},"text":"Pub. L. 99–522, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3000"},"text":"100 Stat. 3000","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/522/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The purposes of this Act [see Short Title note above] are to—","children":[],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a unified and modern permitting process for nordic and alpine ski areas on national forest lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for ski area permits which more closely reflect the acreage and other physical requirements of modern ski area development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a permit system which will be more commensurate with the long-term construction, financing, and operation needs of ski areas on national forest lands.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
