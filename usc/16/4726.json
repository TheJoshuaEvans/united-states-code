{"tag":"section","attrib":{"id":"id79f5819e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4726"},"text":null,"children":[{"tag":"num","attrib":{"value":"4726"},"text":"§ 4726.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f5819f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4726/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force shall provide timely advice to the Secretary of State concerning aquatic nuisance species that infest waters shared with other countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f581a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4726/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, in consultation with the Task Force, is encouraged to initiate negotiations with the governments of foreign countries concerning the planning and implementation of prevention, monitoring, research, education, and control programs related to aquatic nuisance species infesting shared water resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f581a1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646/tI/s1206"},"text":"Pub. L. 101–646, title I, § 1206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4771"},"text":"104 Stat. 4771","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/h/1"},"text":"Pub. L. 104–332, § 2(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4091"},"text":"110 Stat. 4091","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f581a2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f581a3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79f581a4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332"},"text":"Pub. L. 104–332","children":[],"tail":" made technical amendment to "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/s1206"},"text":"Pub. L. 101–646, § 1206","children":[],"tail":", which enacted this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
