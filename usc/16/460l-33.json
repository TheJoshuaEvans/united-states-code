{"tag":"section","attrib":{"id":"id77c2c2ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33"},"text":null,"children":[{"tag":"num","attrib":{"value":"460l–33"},"text":"§ 460l–33.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of reclamation lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77c2c300-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77c2c301-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon a determination that any such fee, charge, or commission is reasonable and appropriate, the Secretary acting through the Commissioner of Reclamation, is authorized to establish—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77c2c302-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" filing fees for applications and other documents concerning entry upon and use of Reclamation lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c2c303-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recreation user fees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c2c304-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charges or commissions for the use of Reclamation lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c2c305-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, acting through the Commissioner of Reclamation, shall promulgate such regulations as the Secretary determines to be necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77c2c306-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the provisions of this section and section 460","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–34 of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c2c307-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure the protection, comfort, and well-being of the public (including the protection of public safety) with respect to the use of Reclamation lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c2c308-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure the protection of resource values.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c2c309-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Commissioner of Reclamation, is authorized to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77c2c30a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and maintain on a continuing basis an inventory of resources and uses made of Reclamation lands and resources, keep records of such inventory, and make such records available to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c2c30b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ascertain the boundaries of Reclamation lands and provide a means for public identification (including, where appropriate, providing signs and maps).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c2c30c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77c2c30d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77c2c30e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002303"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002303"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" The Secretary, acting through the Commissioner of Reclamation, is authorized to develop, maintain, and revise resource management plans for Reclamation lands."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c2c30f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each plan described in subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77c2c310-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be consistent with applicable laws (including any applicable statute, regulation, or Executive order);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77c2c311-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be developed in consultation with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id77c2c312-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/c/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such heads of Federal and non-Federal departments or agencies as the Secretary determines to be appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77c2c313-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/c/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authorized beneficiaries (as determined by the Secretary) of any Reclamation project included in the plan; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77c2c314-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be developed with appropriate public participation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c2c315-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each plan described in subparagraph (A) shall provide for the development, use, conservation, protection, enhancement, and management of resources of Reclamation lands in a manner that is compatible with the authorized purposes of the Reclamation project associated with the Reclamation lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c2c316-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460l–33/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonreimbursable funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds expended by the Secretary in carrying out the provisions of this part shall be nonreimbursable under the Federal reclamation laws (the Act of ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/32/388"},"text":"32 Stat. 388","children":[],"tail":", chapter 1093; "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"43 U.S.C. 371","children":[],"tail":"),"},{"tag":"ref","attrib":{"idref":"fn002304"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002304"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" and Acts supplementary thereto and amendatory thereof)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77c2c317-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXXVIII/s2805"},"text":"Pub. L. 102–575, title XXVIII, § 2805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4692"},"text":"106 Stat. 4692","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77c2c318-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77c2c319-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77c2c31a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in subsec. (d), was in the original “this title”, meaning title XXVIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575"},"text":"Pub. L. 102–575","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4690"},"text":"106 Stat. 4690","children":[],"tail":", which enacted sections 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–31 to 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–34 of this title and amended sections 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–13 to 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–15 and 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–18 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", referred to in subsec. (d), is "},{"tag":"ref","attrib":{"href":"/us/act/1902-06-17/ch1093"},"text":"act June 17, 1902, ch. 1093","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/388"},"text":"32 Stat. 388","children":[],"tail":", popularly known as the Reclamation Act, which is classified generally to chapter 12 (§ 371 et seq.) of Title 43, Public Lands. However, "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of Title 43","children":[],"tail":" is "},{"tag":"ref","attrib":{"href":"/us/act/1924-12-05/ch4/s4"},"text":"act Dec. 5, 1924, ch. 4, § 4","children":[],"tail":", subsec. A, "},{"tag":"ref","attrib":{"href":"/us/stat/43/701"},"text":"43 Stat. 701","children":[],"tail":". For complete classification of act "},{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
