{"tag":"section","attrib":{"id":"id79ebe401-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4246"},"text":null,"children":[{"tag":"num","attrib":{"value":"4246"},"text":"§ 4246.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multinational Species Conservation Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In fiscal year 1999 and thereafter, donations to provide assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5304"},"text":"section 5304 of this title","children":[],"tail":", part I of the African Elephant Conservation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4211"},"text":"16 U.S.C. 4211","children":[],"tail":" et seq.), and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4264"},"text":"section 4264 of this title","children":[],"tail":" shall be deposited to this Fund and shall be available without further appropriation: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That in fiscal year 1999 and thereafter, all penalties received by the United States under section 2204 of the African Elephant Conservation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4224"},"text":"16 U.S.C. 4224","children":[],"tail":") which are not used to pay rewards under section 2205 of the African Elephant Conservation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4225"},"text":"16 U.S.C. 4225","children":[],"tail":") shall be deposited to this Fund to provide assistance under section 2101 of the African Elephant Conservation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4211"},"text":"16 U.S.C. 4211","children":[],"tail":") and shall be available without further appropriation: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That in fiscal year 1999 and thereafter, not more than three percent of amounts appropriated to this Fund may be used by the Secretary of the Interior to administer the Fund."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79ebe402-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tI"},"text":"Pub. L. 105–277, div. A, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–237; "},{"tag":"ref","attrib":{"href":"/us/pl/107/111/s6/b"},"text":"Pub. L. 107–111, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2096"},"text":"115 Stat. 2096","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/112/s6/b"},"text":"Pub. L. 107–112, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2098"},"text":"115 Stat. 2098","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/141/s5/b/1"},"text":"Pub. L. 107–141, § 5(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-02-12"},"text":"Feb. 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/14"},"text":"116 Stat. 14","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79ebe403-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79ebe404-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79ebe405-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The African Elephant Conservation Act, referred to in text, is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/478"},"text":"Pub. L. 100–478","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-07"},"text":"Oct. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2315"},"text":"102 Stat. 2315","children":[],"tail":". Part I of the Act is classified generally to subchapter I (§ 4211 et seq.) of this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4201"},"text":"section 4201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79ebe406-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of the Interior and Related Agencies Appropriations Act, 1999, and also as part of the Omnibus Consolidated and Emergency Supplemental Appropriations Act, 1999, and not as part of the African Elephant Conservation Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79ebe407-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/141"},"text":"Pub. L. 107–141","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s5304"},"text":"section 5304 of this title","children":[],"tail":", part I of the African Elephant Conservation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4211"},"text":"16 U.S.C. 4211","children":[],"tail":" et seq.), and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4264"},"text":"section 4264 of this title","children":[],"tail":"” for “section 5304 of the Rhinoceros and Tiger Conservation Act of 1994, part I of the African Elephant Conservation Act, and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4265"},"text":"section 4265 of this title","children":[],"tail":"”, “section 2204 of the African Elephant Conservation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4224"},"text":"16 U.S.C. 4224","children":[],"tail":")” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4224"},"text":"16 U.S.C. 4224","children":[],"tail":"”, “section 2205 of the African Elephant Conservation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4225"},"text":"16 U.S.C. 4225","children":[],"tail":")” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4225"},"text":"16 U.S.C. 4225","children":[],"tail":"”, and “section 2101 of the African Elephant Conservation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4211"},"text":"16 U.S.C. 4211","children":[],"tail":")” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4211"},"text":"16 U.S.C. 4211","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/111"},"text":"Pub. L. 107–111","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/107/112"},"text":"Pub. L. 107–112","children":[],"tail":" amended section identically, substituting “Rhinoceros and Tiger Conservation Act of 1994, part I” for “Rhinoceros and Tiger Conservation Act, subchapter I”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
