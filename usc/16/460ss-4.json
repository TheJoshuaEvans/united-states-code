{"tag":"section","attrib":{"id":"id77e677cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ss–4"},"text":"§ 460ss–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77e677cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memorandum of agreement ","children":[{"tag":"ref","attrib":{"idref":"fn002340"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002340"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (b) has been enacted."}],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to strengthen and facilitate the enforcement of Area fishery harvesting regulations, the Secretary shall enter into a memorandum of agreement with the California Department of Fish and Game. Such agreement shall specify the enforcement activities within the Area for which the respective agencies of the Department of ","children":[{"tag":"ref","attrib":{"idref":"fn002341"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002341"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “of the”."}],"tail":" Interior and the California Department of Fish and Game are responsible and shall contain such provisions as are necessary to ensure the coordinated implementation of Federal and State enforcement activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77e677ce-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/552/s5"},"text":"Pub. L. 99–552, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3085"},"text":"100 Stat. 3085","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
