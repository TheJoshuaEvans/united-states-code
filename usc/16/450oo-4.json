{"tag":"section","attrib":{"id":"id77a61303-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450oo–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"450oo–4"},"text":"§ 450oo–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment preferences","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall, insofar as practicable, give first preference to employment of recognized members of the Minnesota Chippewa Tribe in the performance of any construction, maintenance, or any other service within the monument for which they are qualified.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a61304-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/910/s5"},"text":"Pub. L. 85–910, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1753"},"text":"72 Stat. 1753","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
