{"tag":"section","attrib":{"id":"id76ff248b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s81a"},"text":null,"children":[{"tag":"num","attrib":{"value":"81a"},"text":"§ 81a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location and boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized and directed to make an examination of Jamestown Island, parts of the city of Williamsburg, and the Yorktown battlefield, all in the State of Virginia, and areas for highways to connect said island, city, and battlefield with a view to determining the area or areas thereof desirable for inclusion in the said Colonial National Historical Park, not to exceed two thousand five hundred acres of the said battlefield or five hundred feet in width as to such connecting areas, and upon completion thereof he shall make appropriate recommendations to the President, who shall establish the boundaries of said national park by proclamation: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the boundaries so established may be enlarged or diminished by subsequent proclamation or proclamations of the President upon the recommendations of the Secretary of the Interior, any such enlargement only to include lands donated to the United States or purchased by the United States without resort to condemnation."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76ff248c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-07-03/ch837/s2"},"text":"July 3, 1930, ch. 837, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/855"},"text":"46 Stat. 855","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-05/ch525/s2"},"text":"June 5, 1936, ch. 525, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1483"},"text":"49 Stat. 1483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id76ff248d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id76ff248e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id76ff248f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s443a"},"text":"section 443a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id76ff2490-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id76ff2491-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1936-06-05"},"text":"June 5, 1936","children":[],"tail":", changed “Colonial National Monument” to “Colonial National Historical Park”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id76ff2492-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id76ff2493-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Boundaries of Park","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Boundaries were established by Presidential Proc. No. 1929, ","children":[{"tag":"date","attrib":{"date":"1930-12-30"},"text":"Dec. 30, 1930","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/3041"},"text":"46 Stat. 3041","children":[],"tail":", and Proc. No. 2055, "},{"tag":"date","attrib":{"date":"1933-08-22"},"text":"Aug. 22, 1933","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1706"},"text":"48 Stat. 1706","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
