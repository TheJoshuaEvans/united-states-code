{"tag":"section","attrib":{"id":"id78438af3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s554"},"text":null,"children":[{"tag":"num","attrib":{"value":"554"},"text":"§ 554.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest supervisors and rangers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Forest supervisors and rangers shall be selected, when practicable, from qualified citizens of the States or Territories in which the national forests, respectively, are situated.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78438af4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1905-02-01/ch288/s3"},"text":"Feb. 1, 1905, ch. 288, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/628"},"text":"33 Stat. 628","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78438af5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78438af6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78438af7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“National forests” substituted in text for “reserves” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"act Mar. 4, 1907, ch. 2907","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1269"},"text":"34 Stat. 1269","children":[],"tail":", which provided that forest reserves shall hereafter be known as national forests."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
