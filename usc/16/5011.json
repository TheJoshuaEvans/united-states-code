{"tag":"section","attrib":{"id":"id79fa3b92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5011"},"text":null,"children":[{"tag":"num","attrib":{"value":"5011"},"text":"§ 5011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79fa3b93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated from time to time such sums as may be necessary for carrying out the purposes and provisions of the Convention and this chapter, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fa3b94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5011/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary travel expenses of the United States Commissioners or Alternate Commissioners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3b95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5011/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States’ share of the joint expenses of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fa3b96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such funds as shall be made available to the Secretary of Commerce for research and related activities shall be expended to carry out the program of the Commission in accordance with the recommendations of the United States Section and to carry out other research and observer programs pursuant to the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fa3b97-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567/tVIII/s812"},"text":"Pub. L. 102–567, title VIII, § 812","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4316"},"text":"106 Stat. 4316","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tVIII/s8012"},"text":"Pub. L. 102–587, title VIII, § 8012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5105"},"text":"106 Stat. 5105","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/562/tIII/s304/a"},"text":"Pub. L. 106–562, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2806"},"text":"114 Stat. 2806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fa3b98-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79fa3b99-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79fa3b9a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"te