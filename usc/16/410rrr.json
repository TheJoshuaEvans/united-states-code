{"tag":"section","attrib":{"id":"id777b3185-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr"},"text":null,"children":[{"tag":"num","attrib":{"value":"410rrr"},"text":"§ 410rrr.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First State National Historical Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id777b3186-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b3187-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historical park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “historical park” means the First State National Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b3188-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “map” means the map with pages numbered 1–6 entitled “First State National Historical Park, New Castle, Kent, Sussex Counties, DE and Delaware County, PA, Proposed Boundary”, numbered T19/80,000G, and dated October 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b3189-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777b318a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b318b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redesignation of First State National Monument","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b318c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The First State National Monument is redesignated as the First State National Historical Park, as generally depicted on the map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b318d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds available for purposes of the First State National Monument shall be available for purposes of the historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b318e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any references in a law, regulation, document, record, map, or other paper of the United States to the First State National Monument shall be considered to be a reference to the historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b318f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the historical park are to preserve, protect, and interpret the nationally significant cultural and historic resources that are associated with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b3190-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early Dutch, Swedish, and English settlement of the Colony of Delaware and portions of the Colony of Pennsylvania; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b3191-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the role of Delaware—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777b3192-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the birth of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b3193-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the first State to ratify the Constitution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b3194-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of additional historic sites","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to sites included in the historical park (as redesignated by paragraph (1)(A)) as of ","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"December 19, 2014","children":[],"tail":", the Secretary may include the following sites within the boundary of the historical park, as generally depicted on the map:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b3195-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fort Christina National Historic Landmark in New Castle County, Delaware, as depicted on page 3 of 6 of the map.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b3196-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Old Swedes Church National Historic Landmark in New Castle County, Delaware, as depicted on page 3 of 6 of the map.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b3197-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" John Dickinson Plantation National Historic Landmark in Kent County, Delaware, as depicted on page 5 of 6 of the map.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b3198-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ryves Holt House in Sussex County, Delaware, as depicted on page 6 of 6 of the map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777b3199-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b319a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall administer the historical park in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b319b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b319c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the laws generally applicable to units of the National Park System, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777b319d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Park System Organic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":" et seq.); "},{"tag":"ref","attrib":{"idref":"fn002185"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002185"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b319e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s461"},"text":"16 U.S.C. 461","children":[],"tail":" et seq.)."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b319f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b31a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777b31a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), the Secretary may acquire all or a portion of any of the sites described in subsection (b)(3), including easements or other interests in land, by purchase from a willing seller, donation, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b31a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donation only","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire only by donation all or a portion of the property identified as “Area for Potential Addition by Donation” on page 2 of 6 of the map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b31a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No land or interest land may be acquired for inclusion in the historical park by condemnation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On acquisition of land or an interest in land under subparagraph (A), the boundary of the historical park shall be adjusted to reflect the acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpretive tours","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide interpretive tours to sites and resources in the State that are located outside the boundary of the historical park and associated with the purposes for which the historical park is established, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b31a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fort Casimir;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" DeVries Monument;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amstel House;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dutch House; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Zwaanendael Museum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b31ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into a cooperative agreement with the State of Delaware, political subdivisions of the State of Delaware, institutions of higher education, nonprofit organizations, and individuals to mark, interpret, and restore nationally significant historic or cultural resources within the boundaries of the historical park, if the cooperative agreement provides for reasonable public access to the resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing requirement","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777b31ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the total cost of any activity carried out under a cooperative agreement entered into under subparagraph (A) shall be not more than 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b31af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share may be in the form of in-kind contributions or goods or services fairly valued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b31b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 fiscal years after the date on which funds are made available to carry out this paragraph, the Secretary shall complete a management plan for the historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The management plan shall be prepared in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":" and other applicable laws."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777b31b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National landmark study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b31b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after the date on which funds are made available to carry out this section, the Secretary shall complete a study assessing the historical significance of additional properties in the State of Delaware that are associated with the purposes of historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rrr/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The study prepared under paragraph (1) shall include an assessment of the potential for designating the additional properties as National Historic Landmarks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777b31b6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXX/s3033"},"text":"Pub. L. 113–291, div. B, title XXX, § 3033","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3775"},"text":"128 Stat. 3775","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777b31b7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777b31b8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id777b31b9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Nat