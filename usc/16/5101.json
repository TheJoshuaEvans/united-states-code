{"tag":"section","attrib":{"id":"id79fa3ba2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5101"},"text":null,"children":[{"tag":"num","attrib":{"value":"5101"},"text":"§ 5101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79fa3ba3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fa3ba4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coastal fishery resources that migrate, or are widely distributed, across the jurisdictional boundaries of two or more of the Atlantic States and of the Federal Government are of substantial commercial and recreational importance and economic benefit to the Atlantic coastal region and the Nation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3ba5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increased fishing pressure, environmental pollution, and the loss and alteration of habitat have reduced severely certain Atlantic coastal fishery resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3ba6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5101/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Because no single governmental entity has exclusive management authority for Atlantic coastal fishery resources, harvesting of such resources is frequently subject to disparate, inconsistent, and intermittent State and Federal regulation that has been detrimental to the conservation and sustainable use of such resources and to the interests of fishermen and the Nation as a whole.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3ba7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5101/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The responsibility for managing Atlantic coastal fisheries rests with the States, which carry out a cooperative program of fishery oversight and management through the Atlantic States Marine Fisheries Commission. It is the responsibility of the Federal Government to support such cooperative interstate management of coastal fishery resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3ba8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5101/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The failure by one or more Atlantic States to fully implement a coastal fishery management plan can affect the status of Atlantic coastal fisheries, and can discourage other States from fully implementing coastal fishery management plans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3ba9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5101/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is in the national interest to provide for more effective Atlantic State fishery resource conservation and management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fa3baa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this chapter is to support and encourage the development, implementation, and enforcement of effective interstate conservation and management of Atlantic coastal fishery resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fa3bab-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206/tVIII/s802"},"text":"Pub. L. 103–206, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2447"},"text":"107 Stat. 2447","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/555/tI/s122/b/1/A"},"text":"Pub. L. 106–555, title I, § 122(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2766"},"text":"114 Stat. 2766","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fa3bac-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79fa3bad-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79fa3bae-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this title”, meaning title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206"},"text":"Pub. L. 103–206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2447"},"text":"107 Stat. 2447","children":[],"tail":", which is classified principally to this chapter. For complete classification of title VIII to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79fa3baf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/555"},"text":"Pub. L. 106–555","children":[],"tail":", which directed amendment of par. (3) of this section by substituting “such resources is” for “such resources in”, was executed by making the substitution in par. (3) of subsec. (a), to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79fa3bb0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79fa3bb1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/555/tI/s121"},"text":"Pub. L. 106–555, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2766"},"text":"114 Stat. 2766","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/555/tI/s121"},"text":"“This subtitle [subtitle B (§§ 121, 122) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/555"},"text":"Pub. L. 106–555","children":[],"tail":", amending this section and sections 5102, 5103, 5106, and 5107a to 5108 of this title and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s5107"},"text":"section 5107 of this title","children":[],"tail":"] may be cited as the ‘Atlantic Coastal Fisheries Act of 2000’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79fa3bb2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206/tVIII/s801"},"text":"Pub. L. 103–206, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2447"},"text":"107 Stat. 2447","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/206/tVIII/s801"},"text":"“This title [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4107"},"text":"section 4107 of this title","children":[],"tail":" and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1851"},"text":"section 1851 of this title","children":[],"tail":"] may be cited as the ‘Atlantic Coastal Fisheries Cooperative Management Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
