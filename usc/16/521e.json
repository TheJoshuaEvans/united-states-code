{"tag":"section","attrib":{"id":"id78294c30-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521e"},"text":null,"children":[{"tag":"num","attrib":{"value":"521e"},"text":"§ 521e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small parcels and road rights-of-way","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The National Forest System lands which may be sold, exchanged, or interchanged under sections 521c to 521i of this title are those the sale or exchange of which is not practicable under any other authority of the Secretary, which have a value as determined by the Secretary of not more than $500,000, and which are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78294c31-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parcels of forty acres or less which are interspersed with or adjacent to lands which have been transferred out of Federal ownership under the mining laws and which are determined by the Secretary, because of location or size, not to be subject to efficient administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78294c32-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parcels of ten acres or less which are encroached upon by improvements occupied or used under claim or color of title by persons to whom no advance notice was given that the improvements encroached or would encroach upon such parcels, and who in good faith relied upon an erroneous survey, title search, or other land description indicating that there was not such encroachment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78294c33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" road rights-of-way, reserved or acquired, which are substantially surrounded by lands not owned by the United States and which are no longer needed by the United States, subject to the first right of abutting landowners to acquire such rights-of-way;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78294c34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" parcels of 40 acres or less that are determined by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78294c35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be physically isolated from other Federal land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78294c36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be inaccessible; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78294c37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to have lost National Forest character;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78294c38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parcels of 10 acres or less that are not eligible for conveyance under paragraph (2) but are encroached on by a permanent habitable improvement for which there is no evidence that the encroachment was intentional or negligent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78294c39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parcels used as a cemetery (including a parcel of not more than 1 acre adjacent to the parcel used as a cemetery), a landfill, or a sewage treatment plant under a special use authorization issued or otherwise authorized by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78294c3a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/465/s3"},"text":"Pub. L. 97–465, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2535"},"text":"96 Stat. 2535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8621/a"},"text":"Pub. L. 115–334, title VIII, § 8621(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4852"},"text":"132 Stat. 4852","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78294c3b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78294c3c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78294c3d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8621/a"},"text":"Pub. L. 115–334, § 8621(a)","children":[],"tail":", substituted “$500,000” for “$150,000” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8621/b"},"text":"Pub. L. 115–334, § 8621(b)","children":[],"tail":", added pars. (4) to (6)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
