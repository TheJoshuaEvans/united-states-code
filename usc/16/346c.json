{"tag":"section","attrib":{"id":"id772c763c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s346c"},"text":null,"children":[{"tag":"num","attrib":{"value":"346c"},"text":"§ 346c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to administer Zion National Park as hereby established in accordance with his authority over the park heretofore granted by the Congress and in accordance with the general laws governing areas of the national park system.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id772c763d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-07-11/ch568/s2"},"text":"July 11, 1956, ch. 568, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/527"},"text":"70 Stat. 527","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
