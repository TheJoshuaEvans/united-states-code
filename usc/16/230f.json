{"tag":"section","attrib":{"id":"id771bd416-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230f"},"text":null,"children":[{"tag":"num","attrib":{"value":"230f"},"text":"§ 230f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delta Region Preservation Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id771bd417-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established the Delta Region Preservation Commission (hereinafter referred to as the “Commission”), which shall consist of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id771bd418-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members appointed by the Governor of the State of Louisiana;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd419-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members appointed by the Secretary from recommendations submitted by the President of Jefferson Parish;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd41a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members appointed by the Secretary from recommendations submitted by the Jefferson Parish Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd41b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230f/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members appointed by the Secretary from recommendations submitted by the mayor of the city of New Orleans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd41c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230f/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member appointed by the Secretary from recommendations submitted by the commercial fishing industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd41d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230f/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three members appointed by the Secretary from recommendations submitted by local citizen conservation organizations in the delta region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd41e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230f/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member appointed by the Chairman of the National Endowment for the Arts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd41f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230f/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002041"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002041"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. There are two pars. designated “(8)”."}],"tail":" two members appointed by the Secretary from recommendations submitted by the Police Jury of Saint Bernard Parish."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd420-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230f/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" one member who shall have experience as a folklorist and who is familiar with the cultures of the Mississippi Delta Region appointed by the Secretary of the Smithsonian Institution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id771bd421-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Commission shall serve without compensation as such. The Secretary is authorized to pay the expenses reasonably incurred by the non-Federal members of the Commission in carrying out their duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id771bd422-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The function of the Commission shall be to advise the Secretary in the selection of sites for inclusion in the park, in the development and implementation of a general management plan, and in the development and implementation of a comprehensive interpretive program of the natural, historic, and cultural resources of the region. The Commission shall inform interested members of the public, the State of Louisiana and its political subdivisions, and interested Federal agencies with respect to existing and proposed actions and programs having a material effect on the perpetuation of a high-quality natural and cultural environment in the delta region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id771bd423-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Majority voting; generally; single parish or municipality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall act and advise by affirmative vote of a majority of its members: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That any recommendation of the Commission that affects the use or development, or lack thereof, of property located solely within a single parish or municipality shall have the concurrence of a majority of the members appointed from recommendations submitted by such parish or municipality."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id771bd424-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ex officio members; staff support and technical services; termination date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Directors of the Heritage Conservation and Recreation Service and the National Park Service shall serve as ex officio members of the Commission and provide such staff support and technical services as may be necessary to carry out the functions of the Commission. The Commission shall terminate twenty years from ","children":[{"tag":"date","attrib":{"date":"1978-11-10"},"text":"November 10, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id771bd425-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/tIX/s907"},"text":"Pub. L. 95–625, title IX, § 907","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3537"},"text":"92 Stat. 3537","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/87/tIV/s401/q/3"},"text":"Pub. L. 96–87, title IV, § 401(q)(3)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1979-10-12"},"text":"Oct. 12, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/666"},"text":"93 Stat. 666","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/250/s1/c"},"text":"Pub. L. 100–250, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-02-16"},"text":"Feb. 16, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/16"},"text":"102 Stat. 16","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/355/s2"},"text":"Pub. L. 100–355, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-28"},"text":"June 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/667"},"text":"102 Stat. 667","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id771bd426-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id771bd427-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id771bd428-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/355/s2/1"},"text":"Pub. L. 100–355, § 2(1)","children":[],"tail":", (2), which directed that in par. (6) “region;” be substituted for “region; and” and that in par. (7) “Arts; and” be substituted for “Arts.” could not be executed because of prior amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/96/87/s401/q/3"},"text":"section 401(q)(3) of Pub. L. 96–87","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/355/s2/3"},"text":"Pub. L. 100–355, § 2(3)","children":[],"tail":", added par. (8) relating to appointment of member with experience as folklorist familiar with cultures of Mississippi Delta Region."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/250"},"text":"Pub. L. 100–250","children":[],"tail":" substituted “twenty” for “ten”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/87/s401/q/3"},"text":"Pub. L. 96–87, § 401(q)(3)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/87/s401/q/4"},"text":"Pub. L. 96–87, § 401(q)(4)","children":[],"tail":", provided that the Commission terminate ten years from "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"November 10, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id771bd429-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id771bd42a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/s2"},"text":"section 2 of Pub. L. 95–625","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s45f"},"text":"section 45f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
