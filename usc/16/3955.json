{"tag":"section","attrib":{"id":"id79e4b89d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3955"},"text":null,"children":[{"tag":"num","attrib":{"value":"3955"},"text":"§ 3955.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e4b89e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3955/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority project and conservation planning expenditures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the total amount appropriated during a given fiscal year to carry out this chapter, 70 percent shall be available, and shall remain available until expended, for the purposes of making expenditures—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e4b89f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3955/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not to exceed the aggregate amount of $5,000,000 annually to assist the Task Force in the preparation of the list required under this chapter and the plan required under this chapter, including preparation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e4b8a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3955/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preliminary assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b8a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3955/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general or site-specific inventories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b8a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3955/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reconnaissance, engineering or other studies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b8a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3955/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preliminary design work; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b8a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3955/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other studies as may be necessary to identify and evaluate the feasibility of coastal wetland restoration projects;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b8a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3955/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out coastal wetlands restoration projects in accordance with the priorities set forth on the list prepared under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b8a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3955/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out wetlands restoration projects in accordance with the priorities set forth in the restoration plan prepared under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b8a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3955/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make grants not to exceed $2,500,000 annually or $10,000,000 in total, to assist the agency designated by the State in development of the Coastal Wetlands Conservation Plan pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e4b8a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3955/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coastal wetlands conservation grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the total amount appropriated during a given fiscal year to carry out this chapter, 15 percent shall be available, and shall remain available to the Director, for purposes of making grants—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e4b8a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3955/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any coastal State, except States eligible to receive funding under subsection (a), to carry out coastal wetlands conservation projects in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3954"},"text":"section 3954 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b8aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3955/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the amount of $2,500,000 in total for an assessment of the status, condition, and trends of wetlands in the State of Texas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e4b8ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3955/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" North American wetlands conservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the total amount appropriated during a given fiscal year to carry out this chapter, 15 percent shall be available to, and shall remain available until expended by, the Secretary of the Interior for allocation to carry out wetlands conservation projects in coastal wetlands ecosystems in any coastal State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4407"},"text":"section 4407 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e4b8ac-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646/tIII/s306"},"text":"Pub. L. 101–646, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4786"},"text":"104 Stat. 4786","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/375/s5"},"text":"Pub. L. 103–375, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-19"},"text":"Oct. 19, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3495"},"text":"108 Stat. 3495","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dC/tI/s114/a"},"text":"Pub. L. 108–447, div. C, title I, § 114(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2944"},"text":"118 Stat. 2944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e4b8ad-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e4b8ae-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79e4b8af-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s114/a/1"},"text":"Pub. L. 108–447, § 114(a)(1)","children":[],"tail":", struck out “, not to exceed $70,000,000,” before “shall be available” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s114/a/2"},"text":"Pub. L. 108–447, § 114(a)(2)","children":[],"tail":", struck out “, not to exceed $15,000,000” before “shall be available” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s114/a/3"},"text":"Pub. L. 108–447, § 114(a)(3)","children":[],"tail":", struck out “, not to exceed $15,000,000,” before “shall be available”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/375"},"text":"Pub. L. 103–375","children":[],"tail":" inserted “in coastal wetlands ecosystems” after “wetlands conservation projects”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
