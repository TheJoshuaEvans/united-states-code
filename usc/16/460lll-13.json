{"tag":"section","attrib":{"id":"id77fbfac0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–13"},"text":"§ 460lll–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to States and counties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fbfac1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments in lieu of taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Land within the Recreation Area shall be subject to the provisions for payments in lieu of taxes under chapter 69 of title 31.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfac2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All amounts received from charges, use fees, and natural resource utilization, including timber and agricultural receipts, shall not be subject to distribution to States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s500"},"text":"section 500 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfac3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments by the Tennessee Valley Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After the transfer of administrative jurisdiction is made under section 460","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–41 of this title—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfac4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–13/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Tennessee Valley Authority shall continue to calculate the amount of payments to be made to States and counties under section 831","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfac5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–13/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each State (including, for the purposes of this subsection, the State of Kentucky, the State of Tennessee, and any other State) that receives a payment under that section shall continue to calculate the amounts to be distributed to the State and local governments, as though the transfer had not been made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fbfac6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s513"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 513]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–313.)"}],"tail":"\n"}],"tail":null}
