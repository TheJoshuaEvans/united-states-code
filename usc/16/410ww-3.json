{"tag":"section","attrib":{"id":"id7760f3f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ww–3"},"text":"§ 410ww–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall study the following properties to determine the feasibility and suitability of including them within the park:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7760f3f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–3/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Properties within the Wright-Dunbar Historic District.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f3fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–3/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wright Company Factory, Dayton, Ohio. A report of the study of such properties shall be submitted as part of the general management plan required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ww–2"},"text":"section 410ww–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7760f3fb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/419/tI/s104"},"text":"Pub. L. 102–419, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2142"},"text":"106 Stat. 2142","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
