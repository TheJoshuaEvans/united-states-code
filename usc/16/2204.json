{"tag":"section","attrib":{"id":"id79986cba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2204"},"text":null,"children":[{"tag":"num","attrib":{"value":"2204"},"text":"§ 2204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding and administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79986cbb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such funds as may be necessary to carry out the purposes of this chapter, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79986cbc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Set-aside for fencing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts made available under subsection (a) for a fiscal year, 25 percent shall be set aside until April 1 of that fiscal year for the repair or replacement of fencing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79986cbd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2204/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Commodity Credit Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In implementing this chapter, the Secretary may use the facilities, services, and authorities of the Commodity Credit Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79986cbe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2204/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation shall not make any expenditures to carry out the provisions of this chapter unless funds specifically appropriated for such purpose have been transferred to it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79986cbf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/334/tIV/s404"},"text":"Pub. L. 95–334, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-04"},"text":"Aug. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/434"},"text":"92 Stat. 434","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2403/a/2/A"},"text":"Pub. L. 115–334, title II, § 2403(a)(2)(A)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4571"},"text":"132 Stat. 4571","children":[],"tail":", 4572.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79986cc0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79986cc1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2403/e"},"text":"Pub. L. 115–334, § 2403(e)","children":[],"tail":", inserted section catchline; designated first, third, and fourth sentences as subsecs. (a), (c), and (d), respectively, and inserted headings; in subsec. (a), inserted “, to remain available until expended” before period at end; in subsec. (c), substituted “In implementing this chapter” for “In implementing the provisions of this chapter”; in subsec. (d), substituted “The Commodity Credit Corporation” for “The Corporation”; added subsec. (b); and struck out former second sentence which read as follows: “Such funds shall remain available until expended.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2403/a/2/A"},"text":"Pub. L. 115–334, § 2403(a)(2)(A)","children":[],"tail":", substituted “Secretary” for“Secretary of Agriculture” in third sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79986cc2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79986cc3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/334/s406"},"text":"section 406 of Pub. L. 95–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
