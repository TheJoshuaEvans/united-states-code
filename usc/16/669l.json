{"tag":"section","attrib":{"id":"id786e6c94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669l"},"text":null,"children":[{"tag":"num","attrib":{"value":"669l"},"text":"§ 669l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Value of land","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, any institution eligible to receive Federal funds under the Agricultural Research, Extension, and Education Reform Act of 1998 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7601"},"text":"7 U.S.C. 7601","children":[],"tail":" et seq.) shall be allowed to use the value of any land owned by the institution as an in-kind match to satisfy any cost sharing requirement under this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id786e6c95-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-02/ch899/s13"},"text":"Sept. 2, 1937, ch. 899, § 13","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/188/tIII/s303/2"},"text":"Pub. L. 116–188, title III, § 303(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/941"},"text":"134 Stat. 941","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id786e6c96-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id786e6c97-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id786e6c98-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Agricultural Research, Extension, and Education Reform Act of 1998, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185"},"text":"Pub. L. 105–185","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/523"},"text":"112 Stat. 523","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id786e6c99-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 13 of act ","children":[{"tag":"date","attrib":{"date":"1937-09-02"},"text":"Sept. 2, 1937","children":[],"tail":", was renumbered section 14 and is set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s669"},"text":"section 669 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
