{"tag":"section","attrib":{"id":"id7839ef01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b"},"text":null,"children":[{"tag":"num","attrib":{"value":"544b"},"text":"§ 544b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of scenic area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7839ef02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National scenic area","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7839ef03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby established the Columbia River Gorge National Scenic Area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839ef04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Boundaries.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7839ef05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), the boundaries of the scenic area shall be generally depicted on the map entitled “Boundary Map, Columbia River Gorge National Scenic Area,” numbered NSA–001 sheets 1 and 2, and dated September 1986, which shall be on file and available for public inspection in the offices of the Commission and of the Chief, Forest Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7839ef06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The scenic area shall not include the approximately 29 acres of land owned by the Port of Camas-Washougal in the South ½ of Section 16, Township 1 North, Range 4 East, and the North ½ of Section 21, Township 1 North, Range 4 East, Willamete ","children":[{"tag":"ref","attrib":{"idref":"fn002426"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002426"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Willamette”."}],"tail":" Meridian, Clark County, Washington, that consists of—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7839ef07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the approximately 19 acres of Port land acquired from the Corps of Engineers under the Second Supplemental Appropriations Act, 1984 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/396"},"text":"Public Law 98–396","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7839ef08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the approximately 10 acres of adjacent Port land to the west of the land described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839ef09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special management areas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7839ef0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The following areas within the boundaries of the scenic area are hereby designated “Special Management Areas”: Gates of the Columbia River Gorge; Wind Mountain; Burdoin Mountain; and Rowena.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839ef0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The boundaries of the special management areas designated by paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7839ef0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be generally depicted on the map entitled “Special Management Areas, Columbia River Gorge National Scenic Area”, numbered SMA–002 sheets 1 through 17, and dated September 1986, which shall be on file and available for public inspection in the offices of the Commission and of the Chief, Forest Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7839ef0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include all islands within the boundaries of the scenic area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839ef0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modification of boundaries","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The boundaries of the special management areas are modified as depicted on a map dated ","children":[{"tag":"date","attrib":{"date":"2000-09-20"},"text":"September 20, 2000","children":[],"tail":", which shall be on file and available for public inspection in the office of the Chief of the Forest Service in Washington, District of Columbia, and copies shall be available in the office of the Commission, and the headquarters of the scenic area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839ef0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of special management area boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Commission, may make minor revisions in the boundaries of special management areas after publication of notice to that effect in the Federal Register and submission of notice thereof to the Committee on Energy and Natural Resources of the United States Senate and the Committees on Agriculture and Natural Resources of the United States House of Representatives. Such notice shall be published and submitted at least sixty days before the revision is made. Notice of final action regarding such revision shall also be published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839ef10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dodson/Warrendale Special Purchase Unit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7839ef11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby established the Dodson/Warrendale Special Purchase Unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839ef12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The boundaries of the Dodson/Warrendale Special Purchase Unit shall be generally depicted on the map entitled “Dodson/Warrendale Special Purchase Unit, Columbia River Gorge National Scenic Area”, numbered SPU–003 sheet 1, and dated September 1986, which shall be on file and available for public inspection in the offices of the Commission and of the Chief, Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839ef13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Urban areas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7839ef14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The following cities and towns are hereby designated as “Urban Areas”: Cascade Locks, Hood River, Mosier, and The Dalles, Oregon; and Bingen, Carson, Dallesport, Home Valley, Lyle, North Bonneville, Stevenson, White Salmon, and Wishram, Washington.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839ef15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The boundaries of urban areas shall be generally depicted on the map entitled, “Urban Areas, Columbia River Gorge National Scenic Area”, numbered UA–004 sheets 1 through 11, and dated September 1986, which shall be on file and available for public inspection in the offices of the Commission and of the Chief, Forest Service. The boundaries of urban areas designated in this subsection may be revised pursuant to the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839ef16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of urban area boundaries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7839ef17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon application of a county and in consultation with the Secretary, the Commission may make minor revisions to the boundaries of any urban area identified in subsection (e) of this section. A majority vote of two-thirds of the members of the Commission, including a majority of the members appointed from each State, shall be required to approve any revision of urban area boundaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7839ef18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commission may revise the boundaries of an urban area only if it finds that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7839ef19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a demonstrable need exists to accommodate long-range urban population growth requirements or economic needs consistent with the management plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7839ef1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revision of urban area boundaries would be consistent with the standards established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s544d"},"text":"section 544d of this title","children":[],"tail":" and the purposes of sections 544 to 544p of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7839ef1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revision of urban area boundaries would result in maximum efficiency of land uses within and on the fringe of existing urban areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7839ef1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544b/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revision of urban area boundaries would not result in the significant reduction of agricultural lands, forest lands, or open spaces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7839ef1d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/663/s4"},"text":"Pub. L. 99–663, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4276"},"text":"100 Stat. 4276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s6/d/34"},"text":"Pub. L. 103–437, § 6(d)(34)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4585"},"text":"108 Stat. 4585","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tIII/s354/a"},"text":"Pub. L. 105–277, div. A, § 101(e) [title III, § 354(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–303; "},{"tag":"ref","attrib":{"href":"/us/pl/106/31/tV/s5004/3"},"text":"Pub. L. 106–31, title V, § 5004(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-05-21"},"text":"May 21, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/110"},"text":"113 Stat. 110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/291/tIII/s346/d"},"text":"Pub. L. 106–291, title III, § 346(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-11"},"text":"Oct. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1000"},"text":"114 Stat. 1000","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7839ef1e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7839ef1f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7839ef20-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Second Supplemental Appropriations Act, 1984, referred to in subsec. (a)(2)(B)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/396"},"text":"Pub. L. 98–396","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-22"},"text":"Aug. 22, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1369"},"text":"98 Stat. 1369","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7839ef21-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/291/s346/d/1"},"text":"Pub. L. 106–291, § 346(d)(1)","children":[],"tail":", substituted “by paragraph (1)” for “in this section” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/291/s346/d/2"},"text":"Pub. L. 106–291, § 346(d)(2)","children":[],"tail":", which directed amendment of subsec. (b)(2) by adding at the end a par. (3), was executed by adding par. (3) after subsec. (b)(2), to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/31"},"text":"Pub. L. 106–31","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":". See 1998 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/31"},"text":"Pub. L. 106–31","children":[],"tail":", inserted par. (2) heading, designated existing provisions as subpar. (A), inserted heading, and substituted “Except as provided in subparagraph (B), the boundaries” for “The boundaries”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Natural Resources” for “Interior and Insular Affairs” after “Committees on Agriculture and”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7839ef22-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7839ef23-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/31/tV/s5004/4"},"text":"Pub. L. 106–31, title V, § 5004(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-05-21"},"text":"May 21, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/110"},"text":"113 Stat. 110","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/31/tV/s5004/4"},"text":"“The amendments made by paragraphs (1), (2), and (3) of this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1374"},"text":"section 1374 of this title","children":[],"tail":"], shall take effect as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Public Law 105–277","children":[],"tail":" on the date of its enactment ["},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7839ef24-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Intent of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tIII/s354/b"},"text":"Pub. L. 105–277, div. A, § 101(e) [title III, § 354(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–303, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dA/s101/e/tIII/s354/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendment made by subsection (a) [amending this section]—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is intended to achieve the intent of Congress set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/396"},"text":"Public Law 98–396","children":[],"tail":" [see Tables for classification]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not intended to set a precedent regarding adjustment or amendment of any boundaries of the Columbia River Gorge National Scenic Area or any other provisions of the Columbia River Gorge National Scenic Area Act [see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s544"},"text":"section 544 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
