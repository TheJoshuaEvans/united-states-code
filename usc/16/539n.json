{"tag":"section","attrib":{"id":"id78353332-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n"},"text":null,"children":[{"tag":"num","attrib":{"value":"539n"},"text":"§ 539n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crystal Springs Watershed Special Resources Management Unit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78353333-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78353334-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On completion of the land exchange under section 1206(a)(2),","children":[{"tag":"ref","attrib":{"idref":"fn002416"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002416"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" there shall be established a special resources management unit in the State consisting of certain Federal land managed by the Forest Service, as generally depicted on the map entitled “Crystal Springs Watershed Special Resources Management Unit”, dated June 2006 (referred to in this section as the “map”), to be known as the “Crystal Springs Watershed Special Resources Management Unit” (referred to in this section as the “Management Unit”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78353335-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of certain land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Management Unit does not include any National Forest System land otherwise covered by subparagraph (A) that is designated as wilderness by section 1202.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78353336-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78353337-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid rights in existence on ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", the Federal land designated as the Management Unit is withdrawn from all forms of—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id78353338-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/1/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entry, appropriation, or disposal under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78353339-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/1/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7835333a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/1/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disposition under all laws pertaining to mineral and geothermal leasing or mineral materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7835333b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Clause (i)(I) does not apply to the parcel of land generally depicted as “HES 151” on the map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7835333c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Management Unit are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7835333d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure the protection of the quality and quantity of the Crystal Springs watershed as a clean drinking water source for the residents of Hood River County, Oregon; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7835333e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow visitors to enjoy the special scenic, natural, cultural, and wildlife values of the Crystal Springs watershed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7835333f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map and legal description","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78353340-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of legal description","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", the Secretary shall file a map and a legal description of the Management Unit with—"}],"tail":null},{"tag":"clause","attrib":{"id":"id78353341-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Natural Resources of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78353342-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Natural Resources of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78353343-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Force of law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description filed under subparagraph (A) shall have the same force and effect as if included in this subtitle, except that the Secretary may correct typographical errors in the map and legal description.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78353344-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description filed under subparagraph (A) shall be on file and available for public inspection in the appropriate offices of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78353345-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78353346-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78353347-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" administer the Management Unit—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78353348-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/4/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the laws (including regulations) and rules applicable to units of the National Forest System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78353349-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/4/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the purposes described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7835334a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only allow uses of the Management Unit that are consistent with the purposes described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7835334b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fuel reduction in proximity to improvements and primary public roads","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To protect the water quality, water quantity, and scenic, cultural, natural, and wildlife values of the Management Unit, the Secretary may conduct fuel reduction and forest health management treatments to maintain and restore fire-resilient forest structures containing late successional forest structure characterized by large trees and multistoried canopies, as ecologically appropriate, on National Forest System land in the Management Unit—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7835334c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in any area located not more than 400 feet from structures located on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7835334d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Forest System land; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7835334e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private land adjacent to National Forest System land;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7835334f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any area located not more than 400 feet from the Cooper Spur Road, the Cloud Cap Road, or the Cooper Spur Ski Area Loop Road; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78353350-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on any other National Forest System land in the Management Unit, with priority given to activities that restore previously harvested stands, including the removal of logging slash, smaller diameter material, and ladder fuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78353351-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, the following activities shall be prohibited on National Forest System land in the Management Unit:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78353352-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" New road construction or renovation of existing non-System roads, except as necessary to protect public health and safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78353353-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Projects undertaken for the purpose of harvesting commercial timber (other than activities relating to the harvest of merchantable products that are byproducts of activities conducted to further the purposes described in paragraph (2)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78353354-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commercial livestock grazing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78353355-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The placement of new fuel storage tanks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78353356-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except to the extent necessary to further the purposes described in paragraph (2), the application of any toxic chemicals (other than fire retardants), including pesticides, rodenticides, or herbicides.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78353357-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest road closures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78353358-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the Secretary may provide for the closure or gating to the general public of any Forest Service road within the Management Unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78353359-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section requires the Secretary to close the road commonly known as “Cloud Cap Road”, which shall be administered in accordance with otherwise applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7835335a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private land","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7835335b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section affects the use of, or access to, any private property within the area identified on the map as the “Crystal Springs Zone of Contribution” by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7835335c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owners of the private property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7835335d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guests to the private property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7835335e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is encouraged to work with private landowners who have agreed to cooperate with the Secretary to further the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7835335f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of land","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78353360-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire from willing landowners any land located within the area identified on the map as the “Crystal Springs Zone of Contribution”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78353361-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539n/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion in Management Unit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the date of acquisition, any land acquired under subparagraph (A) shall be incorporated in, and be managed as part of, the Management Unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78353362-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tI/s1205/a"},"text":"Pub. L. 111–11, title I, § 1205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1014"},"text":"123 Stat. 1014","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78353363-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78353364-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78353365-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1206(a)(2), referred to in par. (1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s1206/a/2"},"text":"section 1206(a)(2) of Pub. L. 111–11","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1018"},"text":"123 Stat. 1018","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1202, referred to in par. (1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s1202"},"text":"section 1202 of Pub. L. 111–11","children":[],"tail":", which enacted provisions listed in a table of National Memorials set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320301"},"text":"section 320301 of Title 54","children":[],"tail":", National Park Service and Rela