{"tag":"section","attrib":{"id":"id7888aae7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s729"},"text":null,"children":[{"tag":"num","attrib":{"value":"729"},"text":"§ 729.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Price per acre","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall not pay for any land or land and water a price which shall exceed an average cost of $10 per acre: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That this provision shall not apply to any land or land and water prior to "},{"tag":"date","attrib":{"date":"1928-05-12"},"text":"May 12, 1928","children":[],"tail":", acquired or contracted for under the provisions of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7888aae8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-06-07/ch346/s10"},"text":"June 7, 1924, ch. 346, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/652"},"text":"43 Stat. 652","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-03-04/ch558"},"text":"Mar. 4, 1925, ch. 558","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1354"},"text":"43 Stat. 1354","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1928-05-12/ch534"},"text":"May 12, 1928, ch. 534","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/502"},"text":"45 Stat. 502","children":[],"tail":"; 1939 Reorg. Plan No. II, § 4 (f), eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2731, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1433"},"text":"53 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7888aae9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7888aaea-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7888aaeb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of this section, which authorized an appropriation of $1,500,000 for the acquisition of authorized areas and for all necessary expenses thereto, were omitted. The text set out above constituted the first and second provisos to the omitted provisions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7888aaec-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1928—Act ","children":[{"tag":"date","attrib":{"date":"1928-05-12"},"text":"May 12, 1928","children":[],"tail":", substituted “which shall exceed an average cost of $10 per acre” for “which when added to the price of land or land and water theretofore purchased, shall exceed an average cost of $5 per acre”, and inserted proviso making the provision of this section inapplicable to any land or land and water prior to "},{"tag":"date","attrib":{"date":"1928-05-12"},"text":"May 12, 1928","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1925—Act ","children":[{"tag":"date","attrib":{"date":"1925-03-04"},"text":"Mar. 4, 1925","children":[],"tail":", substituted proviso for restriction on availability of money for acquisition of areas."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7888aaed-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id7888aaee-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of functions of Secretary of Agriculture to Secretary of the Interior by Reorg. Plan No. II of 1939, see Transfer of Functions note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s723"},"text":"section 723 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
