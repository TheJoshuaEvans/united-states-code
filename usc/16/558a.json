{"tag":"section","attrib":{"id":"id78438b51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s558a"},"text":null,"children":[{"tag":"num","attrib":{"value":"558a"},"text":"§ 558a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this Act is to leverage volunteer engagement to supplement projects that are carried out by the Secretaries to fulfill the missions of the Forest Service and the Bureau of Land Management and are accomplished with appropriated funds.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78438b52-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/300/s2"},"text":"Pub. L. 92–300, § 2","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tIII/s341"},"text":"Pub. L. 118–234, title III, § 341","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2913"},"text":"138 Stat. 2913","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78438b53-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78438b54-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78438b55-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/300"},"text":"Pub. L. 92–300","children":[],"