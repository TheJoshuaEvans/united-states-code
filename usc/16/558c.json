{"tag":"section","attrib":{"id":"id78438b63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s558c"},"text":null,"children":[{"tag":"num","attrib":{"value":"558c"},"text":"§ 558c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretaries are authorized to recruit, train, and accept without regard to the civil service and classification laws, rules, or regulations the services of individuals without compensation as volunteers for or in aid of recreation access, trail construction or maintenance, facility construction or maintenance, educational uses (including outdoor classroom construction or maintenance), interpretive functions, visitor services, conservation measures and development, or other activities in and related to areas administered by the Secretaries. In carrying out this section, the Secretaries shall consider referrals of prospective volunteers made by the Corporation for National and Community Service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78438b64-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/300/s4"},"text":"Pub. L. 92–300, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tIII/s341"},"text":"Pub. L. 118–234, title III, § 341","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2913"},"text":"138 Stat. 2913","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78438b65-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78438b66-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b"