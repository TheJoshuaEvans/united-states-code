{"tag":"section","attrib":{"id":"id780a533b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"460yyy–2"},"text":"§ 460yyy–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of the Conservation Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id780a533c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780a533d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall manage the Conservation Area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780a533e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that conserves, protects, and enhances the resources and values of the Conservation Area, including the resources and values described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460yyy–1/a"},"text":"section 460yyy–1(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a533f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id780a5340-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780a5341-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780a5342-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780a5343-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall only allow uses of the Conservation Area that are consistent with the protection of the cave resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780a5344-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In administering the Conservation Area, the Secretary shall provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780a5345-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conservation and protection of the natural and unique features and environs for scientific, educational, and other appropriate public uses of the Conservation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a5346-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public access, as appropriate, while providing for the protection of the cave resources and for public safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a5347-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continuation of other existing uses or other new uses of the Conservation Area that do not impair the purposes for which the Conservation Area is established;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a5348-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management of the surface area of the Conservation Area in accordance with the Fort Stanton Area of Critical Environmental Concern Final Activity Plan dated March, 2001, or any amendments to the plan, consistent with this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a5349-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific investigation and research opportunities within the Conservation Area, including through partnerships with colleges, universities, schools, scientific institutions, researchers, and scientists to conduct research and provide educational and interpretive services within the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780a534a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, all Federal surface and subsurface land within the Conservation Area and all land and interests in the land that are acquired by the United States after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", for inclusion in the Conservation Area, are withdrawn from—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id780a534b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all forms of entry, appropriation, or disposal under the general land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780a534c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780a534d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation under the mineral leasing and geothermal leasing laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780a534e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780a534f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", the Secretary shall develop a comprehensive plan for the long-term management of the Conservation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780a5350-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The management plan shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780a5351-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the appropriate uses and management of the Conservation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a5352-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate, as appropriate, decisions contained in any other management or activity plan for the land within or adjacent to the Conservation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a5353-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration any information developed in studies of the land and resources within or adjacent to the Conservation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a5354-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a cooperative agreement with Lincoln County, New Mexico, to address the historical involvement of the local community in the interpretation and protection of the resources of the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780a5355-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and interpretive facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780a5356-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may establish facilities for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780a5357-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of scientific research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a5358-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interpretation of the historical, cultural, scientific, archaeological, natural, and educational resources of the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780a5359-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, in a manner consistent with this subchapter, enter into cooperative agreements with the State of New Mexico and other institutions and organizations to carry out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780a535a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter constitutes an express or implied reservation of any water right.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id780a535b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tII/s2203"},"text":"Pub. L. 111–11, title II, § 2203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1100"},"text":"123 Stat. 1100","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id780a535c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id780a535d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id780a535e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in subsec. (a)(1)(B)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
