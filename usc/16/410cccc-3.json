{"tag":"section","attrib":{"id":"id777fece8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410cccc–3"},"text":"§ 410cccc–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Golden Spike National Historical Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id777fece9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777fecea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Park” means the Golden Spike National Historical Park designated by subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777feceb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the program to commemorate and interpret the Transcontinental Railroad authorized under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fecec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary, acting through the Director of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777feced-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transcontinental railroad","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Transcontinental Railroad” means the approximately 1,912-mile continuous railroad constructed between 1863 and 1869 extending from Council Bluffs, Iowa, to San Francisco, California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777fecee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redesignation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777fecef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redesignation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Golden Spike National Historic Site designated ","children":[{"tag":"date","attrib":{"date":"1957-04-02"},"text":"April 2, 1957","children":[],"tail":", and placed under the administration of the National Park Service under sections 410cccc to 410cccc–2 of this title, shall be known and designated as the “Golden Spike National Historical Park”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fecf0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in a law, map, regulation, document, paper, or other record of the United States to the Golden Spike National Historic Site shall be considered to be a reference to the “Golden Spike National Historical Park”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777fecf1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transcontinental Railroad commemoration and program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777fecf2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary shall establish within the National Park Service a program to commemorate and interpret the Transcontinental Railroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fecf3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before establishing the Program, the Secretary shall conduct a study of alternatives for commemorating and interpreting the Transcontinental Railroad that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777fecf4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a historical assessment of the Transcontinental Railroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fecf5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the identification of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777fecf6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing National Park System land and affiliated areas, land managed by other Federal agencies, and Federal programs that may be related to preserving, commemorating, and interpreting the Transcontinental Railroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777fecf7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any properties relating to the Transcontinental Railroad—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id777fecf8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are designated as, or could meet the criteria for designation as, National Historic Landmarks; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id777fecf9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are included, or eligible for inclusion, on the National Register of Historic Places;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777fecfa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any objects relating to the Transcontinental Railroad that have educational, research, or interpretative value; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777fecfb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any governmental programs and nongovernmental programs of an educational, research, or interpretive nature relating to the Transcontinental Railroad; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fecfc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777fecfd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporating the resources identified under subparagraph (B) into the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777fecfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate ways to enhance historical research, education, interpretation, and public awareness of the Transcontinental Railroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fecff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after the date on which funds are made available to carry out the study under paragraph (2), the Secretary shall submit to the Committee on Natural Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a report containing the findings and recommendations of the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fed00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Freight railroad operations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Program shall not include any properties that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777fed01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used in active freight railroad operations (or other ancillary purposes); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fed02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonably anticipated to be used for freight railroad operations in the future.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fed03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of the program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Program under this subsection, the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777fed04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall produce and disseminate appropriate education materials relating to the history, construction, and legacy of the Transcontinental Railroad, such as handbooks, maps, interpretive guides, or electronic information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fed05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into appropriate cooperative agreements and memoranda of understanding and provide technical assistance to the heads of other Federal agencies, States, units of local government, regional governmental bodies, and private entities to further the purposes of the Program and this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fed06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777fed07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create and adopt an official, uniform symbol or device to identify the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777fed08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/c/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue guidance for the use of the symbol or device created and adopted under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777fed09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programmatic agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777fed0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall seek to enter into a programmatic agreement with the Utah State Historic Preservation Officer to add to the list of undertakings eligible for streamlined review under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s306108"},"text":"section 306108 of title 54","children":[],"tail":" certain uses that would have limited physical impact to land in the Park."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fed0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The programmatic agreement entered into under paragraph (1) shall be developed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777fed0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with applicable laws (including regulations); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fed0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with adjacent landowners, Indian Tribes, and other interested parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fed0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777fed0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider any application for uses covered by the programmatic agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fed10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 60 days after the receipt of an application described in subparagraph (A), approve the application, if the Secretary determines the application is consistent with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777fed11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programmatic agreement entered into under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777fed12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable laws (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777fed13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cccc–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Invasive species","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with, and seek to coordinate with, adjacent landowners to address the treatment of invasive species adjacent to, and within the boundaries of, the Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777fed14-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2205"},"text":"Pub. L. 116–9, title II, § 2205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/738"},"text":"133 Stat. 738","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777fed15-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777fed16-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id777fed17-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the John D. Dingell, Jr. Conservation, Management, and Recreation Act, and not as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/102"},"text":"Pub. L. 89–102","children":[],"tail":" which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id777fed18-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id777fed19-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2"},"text":"section 2 of Pub. L. 116–9","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
