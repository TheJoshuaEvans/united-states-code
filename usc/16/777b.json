{"tag":"section","attrib":{"id":"id7896db61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777b"},"text":null,"children":[{"tag":"num","attrib":{"value":"777b"},"text":"§ 777b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To carry out the provisions of this chapter for fiscal years after ","children":[{"tag":"date","attrib":{"date":"1984-09-30"},"text":"September 30, 1984","children":[],"tail":", there are authorized to be appropriated from the Sport Fish Restoration and Boating Trust Fund established by "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9504/a"},"text":"section 9504(a) of title 26","children":[],"tail":" the amounts paid, transferred, or otherwise credited to that Trust Fund, except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9504/c"},"text":"section 9504(c) of title 26","children":[],"tail":". For purposes of the provision of the Act of "},{"tag":"date","attrib":{"date":"1951-08-31"},"text":"August 31, 1951","children":[],"tail":", which refers to this section, such amounts shall be treated as the amounts that are equal to the revenues described in this section. The appropriation made under the provisions of this section for each fiscal year shall continue available during succeeding fiscal years. So much of such appropriation apportioned to any State for any fiscal year as remains unexpended at the close thereof is authorized to be made available for expenditure in that State until the close of the succeeding fiscal year. Any amount apportioned to any State under the provisions of this chapter which is unexpended or unobligated at the end of the period during which it is available for expenditure on any project is authorized to be made available for expenditure by the Secretary of the Interior to supplement the 58.012 percent of the balance of each annual appropriation to be apportioned among the States, as provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s777c/c"},"text":"section 777c(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7896db62-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-09/ch658/s3"},"text":"Aug. 9, 1950, ch. 658, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/431"},"text":"64 Stat. 431","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1014/a/2"},"text":"Pub. L. 98–369, div. A, title X, § 1014(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1015"},"text":"98 Stat. 1015","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tX/s10112/a"},"text":"Pub. L. 109–59, title X, § 10112(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1927"},"text":"119 Stat. 1927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tX/s10001/a"},"text":"Pub. L. 114–94, div. A, title X, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1619"},"text":"129 Stat. 1619","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7896db63-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attri