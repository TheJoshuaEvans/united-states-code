{"tag":"section","attrib":{"id":"id7774064f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"410iii–8"},"text":"§ 410iii–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation of Cedar Creek and Belle Grove National Historical Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77740650-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouragement of conservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Commission shall encourage conservation of the historic and natural resources within and in proximity of the Park by landowners, local governments, organizations, and businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77740651-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical assistance to local governments, in cooperative efforts which complement the values of the Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77740652-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation by Federal agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any Federal entity conducting or supporting activities directly affecting the Park shall consult, cooperate, and, to the maximum extent practicable, coordinate its activities with the Secretary in a manner that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77740653-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–8/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the purposes of this subchapter and the standards and criteria established pursuant to the general management plan developed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410iii–6"},"text":"section 410iii–6 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77740654-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–8/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not likely to have an adverse effect on the resources of the Park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77740655-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–8/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is likely to provide for full public participation in order to consider the views of all interested parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77740656-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/373/s10"},"text":"Pub. L. 107–373, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3108"},"text":"116 Stat. 3108","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
