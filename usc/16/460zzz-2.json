{"tag":"section","attrib":{"id":"id780c9c76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"460zzz–2"},"text":"§ 460zzz–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dominguez Canyon Wilderness Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id780c9c77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with the Wilderness Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.), the approximately 66,280 acres of public land in Mesa, Montrose, and Delta Counties, Colorado, as generally depicted on the Map, is designated as wilderness and as a component of the National Wilderness Preservation System, to be known as the “Dominguez Canyon Wilderness Area”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9c78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of Wilderness","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Wilderness shall be managed by the Secretary in accordance with the Wilderness Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.) and this subchapter, except that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9c79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference in the Wilderness Act to the effective date of that Act shall be considered to be a reference to ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9c7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference in the Wilderness Act to the Secretary of Agriculture shall be considered to be a reference to the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id780c9c7b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tII/s2403"},"text":"Pub. L. 111–11, title II, § 2403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1103"},"text":"123 Stat. 1103","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id780c9c7c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id780c9c7d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id780c9c7e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Wilderness Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/577"},"text":"Pub. L. 88–577","children":[],"tail":", "},{"tag"