{"tag":"section","attrib":{"id":"id7716f191-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s227"},"text":null,"children":[{"tag":"num","attrib":{"value":"227"},"text":"§ 227.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of areas for Government reclamation projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever consistent with the primary purposes of such park, the Secretary of the Interior is authorized to permit the utilization of those areas formerly within the Lake Mead National Recreation Area immediately prior to ","children":[{"tag":"date","attrib":{"date":"1975-01-03"},"text":"January 3, 1975","children":[],"tail":", and added to the park by sections 228a to 228j of this title, which may be necessary for the development and maintenance of a Government reclamation project."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7716f192-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1919-02-26/ch44/s7"},"text":"Feb. 26, 1919, ch. 44, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/1178"},"text":"40 Stat. 1178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/620/s9/b"},"text":"Pub. L. 93–620, § 9(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2091"},"text":"88 Stat. 2091","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7716f193-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7716f194-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7716f195-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/620"},"text":"Pub. L. 93–620","children":[],"tail":" substituted provisions authorizing utilization of areas formerly within Lake Mead National Recreation Area and added to the Grand Canyon National Park by sections 228a to 228j of this title, for provisions authorizing utilization of areas within the Park."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
