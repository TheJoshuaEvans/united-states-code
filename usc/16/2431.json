{"tag":"section","attrib":{"id":"id799adde8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2431"},"text":null,"children":[{"tag":"num","attrib":{"value":"2431"},"text":"§ 2431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799adde9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2431/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799addea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2431/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Convention on the Conservation of Antarctic Marine Living Resources establishes international mechanisms and creates legal obligations necessary for the protection and conservation of Antarctic marine living resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799addeb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2431/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Convention incorporates an innovative ecosystem approach to the management of Antarctic marine living resources, including standards designed to ensure the health of the individual populations and species and to maintain the health of the Antarctic marine ecosystem as a whole;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799addec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2431/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Convention serves important United States environmental and resource management interests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799added-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2431/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Convention represents an important contribution to United States long term legal and political objectives of maintenance of Antarctica as an area of peaceful international cooperation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799addee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2431/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States basic and directed research programs concerning the marine living resources of the Antarctic are essential to achieve the United States goal of effective implementation of the objectives of the Convention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799addef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2431/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States has important security, economic, and environmental interests in developing and maintaining a fleet of icebreaking vessels capable of operating effectively in the heavy ice regions of Antarctica.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799addf0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2431/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this chapter is to provide the legislative authority necessary to implement, with respect to the United States, the Convention on the Conservation of Antarctic Marine Living Resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799addf1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623/tIII/s302"},"text":"Pub. L. 98–623, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3398"},"text":"98 Stat. 3398","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799addf2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id799addf3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id799addf4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623/tIII/s301"},"text":"Pub. L. 98–623, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3398"},"text":"98 Stat. 3398","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/623/tIII/s301"},"text":"“This title [enacting this chapter] may be cited as the ‘Antarctic Marine Living Resources Convention Act of 1984’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
