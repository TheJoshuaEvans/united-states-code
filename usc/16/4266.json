{"tag":"section","attrib":{"id":"id79ebe45b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4266"},"text":null,"children":[{"tag":"num","attrib":{"value":"4266"},"text":"§ 4266.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ebe45c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4266/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Fund $5,000,000 for each of fiscal years 2025 through 2029 to carry out this chapter, which may remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ebe45d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4266/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of amounts available each fiscal year to carry out this chapter, the Secretary may expend not more than 3 percent or $100,000, whichever is greater, to pay the administrative expenses necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ebe45e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/96/s8"},"text":"Pub. L. 105–96, § 8","children":[],"tail":", formerly § 7, "},{"tag":"date","attrib":{"date":"1997-11-19"},"text":"Nov. 19, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2153"},"text":"111 Stat. 2153","children":[],"tail":"; renumbered § 8 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/141"},"text":"Pub. L. 107–141","children":[],"tail":", §§ 2–4, "},{"tag":"date","attrib":{"date":"2002-02-12"},"text":"Feb. 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/13"},"text":"116 Stat. 13","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/133/s2/b"},"text":"Pub. L. 110–133, § 2(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2007-12-06"},"text":"Dec. 6, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1362"},"text":"121 Stat. 1362","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tVII/s7001/c/1/B"},"text":"Pub. L. 116–9, title VII, § 7001(c)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/784"},"text":"133 Stat. 784","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLIII/s5304/b"},"text":"Pub. L. 118–159, div. E, title LIII, § 5304(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2445"},"text":"138 Stat. 2445","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79ebe45f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79ebe460-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79ebe461-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “2025 through 2029” for “2019 through 2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9"},"text":"Pub. L. 116–9","children":[],"tail":" substituted “2019 through 2023” for “2007 through 2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/133/s2/c"},"text":"Pub. L. 110–133, § 2(c)","children":[],"tail":", substituted “2007 through 2012” for “2001, 2002, 2003, 2004, 2005, 2006, and 2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/133/s2/b"},"text":"Pub. L. 110–133, § 2(b)","children":[],"tail":", substituted “$100,000” for “$80,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/141/s3"},"text":"Pub. L. 107–141, § 3","children":[],"tail":", designated existing provisions as subsec. (a), inserted heading, substituted “There is authorized” for “There are authorized”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/141/s2"},"text":"Pub. L. 107–141, § 2","children":[],"tail":", substituted “2001, 2002, 2003, 2004, 2005, 2006, and 2007” for “1998, 1999, 2000, 2001, and 2002”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
