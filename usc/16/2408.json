{"tag":"section","attrib":{"id":"id799addbc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2408"},"text":null,"children":[{"tag":"num","attrib":{"value":"2408"},"text":"§ 2408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal offenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799addbd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person is guilty of an offense if he willfully commits any act prohibited by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2403/a"},"text":"section 2403(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799addbe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Punishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any offense described in subsection (a) is punishable by a fine of $10,000, or imprisonment for not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799addbf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2408/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses under other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A conviction under subsection (a) for any act shall not be deemed to preclude a conviction for such act under any other law, includi