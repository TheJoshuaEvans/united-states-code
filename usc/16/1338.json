{"tag":"section","attrib":{"id":"id79155a58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1338"},"text":null,"children":[{"tag":"num","attrib":{"value":"1338"},"text":"§ 1338.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79155a59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1338/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations; penalties; trial","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79155a5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1338/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully removes or attempts to remove a wild free-roaming horse or burro from the public lands, without authority from the Secretary, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79155a5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1338/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" converts a wild free-roaming horse or burro to private use, without authority from the Secretary, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79155a5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1338/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maliciously causes the death or harassment of any wild free-roaming horse or burro, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79155a5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1338/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1333/e"},"text":"section 1333(e) of this title","children":[],"tail":", processes or permits to be processed into commercial products the remains of a wild free-roaming horse or burro, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79155a5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1338/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sells, directly or indirectly, a wild free-roaming horse or burro maintained on private or leased land pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1334"},"text":"section 1334 of this title","children":[],"tail":", or the remains thereof, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79155a5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1338/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully violates a regulation issued pursuant to this chapter,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be subject to a fine of not more than $2,000, or imprisonment for not more than one year, or both. Any person so charged with such violation by the Secretary may be tried and sentenced by any United States commissioner or magistrate judge designated for that purpose by the court by which he was appointed, in the same manner and subject to the same conditions as provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3401"},"text":"section 3401 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79155a60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1338/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arrest; appearance for examination or trial; warrants: issuance and execution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any employee designated by the Secretary of the Interior or the Secretary of Agriculture shall have power, without warrant, to arrest any person committing in the presence of such employee a violation of this chapter or any regulation made pursuant thereto, and to take such person immediately for examination or trial before an officer or court of competent jurisdiction, and shall have power to execute any warrant or other process issued by an officer or court of competent jurisdiction to enforce the provisions of this chapter or regulations made pursuant thereto. Any judge of a court established under the laws of the United States, or any United States magistrate judge may, within his respective jurisdiction, upon proper oath or affirmation showing probable cause, issue warrants, in all such cases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79155a61-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/195/s8"},"text":"Pub. L. 92–195, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-15"},"text":"Dec. 15, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/650"},"text":"85 Stat. 650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s321"},"text":"Pub. L. 101–650, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5117"},"text":"104 Stat. 5117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dE/tI/s142/b"},"text":"Pub. L. 108–447, div. E, title I, § 142(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3071"},"text":"118 Stat. 3071","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79155a62-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79155a63-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79155a64-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":" inserted “except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1333/e"},"text":"section 1333(e) of this title","children":[],"tail":",” before “processes or permits”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79155a65-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id79155a66-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States magistrate judge” and “magistrate judge” substituted for “United States magistrate” and “magistrate”, respectively, in text pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/s321"},"text":"section 321 of Pub. L. 101–650","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s631"},"text":"section 631 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
