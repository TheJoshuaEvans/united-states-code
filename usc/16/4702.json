{"tag":"section","attrib":{"id":"id79f30f58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702"},"text":null,"children":[{"tag":"num","attrib":{"value":"4702"},"text":"§ 4702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f30f59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “aquatic nuisance species” means a nonindigenous species that threatens the diversity or abundance of native species or the ecological stability of infested waters, or commercial, agricultural, aquacultural or recreational activities dependent on such waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Assistant Secretary” means the Assistant Secretary of the Army (Civil Works);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “ballast water” means any water and associated sediments used to manipulate the trim and stability of a vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Director” means the Director of the United States Fish and Wildlife Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “exclusive economic zone” means the Exclusive Economic Zone of the United States established by Proclamation Number 5030, dated ","children":[{"tag":"date","attrib":{"date":"1983-03-10"},"text":"March 10, 1983","children":[],"tail":", and the equivalent zone of Canada;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “environmentally sound” methods, efforts, actions or programs means methods, efforts, actions or programs to prevent introductions or control infestations of aquatic nuisance species that minimize adverse impacts to the structure and function of an ecosystem and adverse effects on non-target organisms and ecosystems and emphasize integrated pest management techniques and nonchemical measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Great Lakes” means Lake Ontario, Lake Erie, Lake Huron (including Lake St. Clair), Lake Michigan, Lake Superior, and the connecting channels (Saint Mary’s River, Saint Clair River, Detroit River, Niagara River, and Saint Lawrence River to the Canadian Border), and includes all other bodies of water within the drainage basin of such lakes and connecting channels.","children":[{"tag":"ref","attrib":{"idref":"fn002797"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002797"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Great Lakes region” means the 8 States that border on the Great Lakes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian tribe” means any Indian tribe, band, nation, or other organized group or community, including any Alaska Native village or regional corporation (as defined in or established pursuant to the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.)) that is recognized as eligible for the special programs and services provided by the United States to Indians because of their status as Indians;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “interstate organization” means an entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f30f63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" established by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f30f64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/10/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an interstate compact that is approved by Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f30f65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/10/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal statute; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f30f66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/10/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a treaty or other international agreement with respect to which the United States is a party; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30f67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f30f68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/10/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that represents 2 or more—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79f30f69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/10/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States or political subdivisions thereof; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79f30f6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/10/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribes; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f30f6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/10/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that represents—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79f30f6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/10/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more States or political subdivisions thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79f30f6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/10/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more Indian tribes; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f30f6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/10/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that represents the Federal Government and 1 or more foreign governments; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30f6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has jurisdiction over, serves as forum for coordinating, or otherwise has a role or responsibility for the management of, any land or other natural resource;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “nonindigenous species” means any species or other viable biological material that enters an ecosystem beyond its historic range, including any such organism transferred from one country into another;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of the department in which the Coast Guard is operating;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means each of the several States, the District of Columbia, American Samoa, Guam, Puerto Rico, the Northern Mariana Islands, and the Virgin Islands of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “recreational vessel” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1362"},"text":"section 1362 of title 33","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Task Force” means the Aquatic Nuisance Species Task Force established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4721"},"text":"section 4721 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “territorial sea” means the belt of the sea measured from the baseline of the United States determined in accordance with international law, as set forth in Presidential Proclamation Number 5928, dated ","children":[{"tag":"date","attrib":{"date":"1988-12-27"},"text":"December 27, 1988","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Under Secretary” means the Under Secretary of Commerce for Oceans and Atmosphere;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “waters of the United States” means the navigable waters and the territorial sea of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4702/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “unintentional introduction” means an introduction of nonindigenous species that occurs as the result of activities other than the purposeful or intentional introduction of the species involved, such as the transport of nonindigenous species in ballast or in water used to transport fish, mollusks or crustaceans for aquaculture or other purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f30f79-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646/tI/s1003"},"text":"Pub. L. 101–646, title I, § 1003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4762"},"text":"104 Stat. 4762","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/580/tIII/s302/b/2"},"text":"Pub. L. 102–580, title III, § 302(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-31"},"text":"Oct. 31, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4839"},"text":"106 Stat. 4839","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/a/2"},"text":"Pub. L. 104–332, § 2(a)(2)","children":[],"tail":", (h)(1), (3), "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4074"},"text":"110 Stat. 4074","children":[],"tail":", 4091; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIII/s11327/a"},"text":"Pub. L. 117–263, div. K, title CXIII, § 11327(a)","children":[],"tail":", (e)(2), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4096"},"text":"136 Stat. 4096","children":[],"tail":", 4098.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f30f7a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f30f7b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79f30f7c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, which, to reflect the probable intent of Congress, was translated as reading “this title” meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646"},"text":"Pub. L. 101–646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4761"},"text":"104 Stat. 4761","children":[],"tail":", known as the Nonindigenous Aquatic Nuisance Prevention and Control Act of 1990, which is classified principally to this chapter. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4701"},"text":"section 4701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Proclamation Number 5030, referred to in par. (5), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453"},"text":"section 1453 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Alaska Native Claims Settlement Act, referred to in par. (9), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Presidential Proclamation Number 5928, referred to in par. (16), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79f30f7d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11327/e/2"},"text":"Pub. L. 117–263, § 11327(e)(2)","children":[],"tail":", substituted “Canadian” for “Canandian”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (13) to (19). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11327/a"},"text":"Pub. L. 117–263, § 11327(a)","children":[],"tail":", added pars. (13) and (14) and redesignated former pars. (13) to (17) as (15) to (19), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/h/1"},"text":"Pub. L. 104–332, § 2(h)(1)","children":[],"tail":", (3), made technical amendment to "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/s1003"},"text":"Pub. L. 101–646, § 1003","children":[],"tail":", which enacted this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/a/2/A"},"text":"Pub. L. 104–332, § 2(a)(2)(A)","children":[],"tail":", redesignated par. (2) as (1) and struck out former par. (1) which read as follows: “ ‘appropriate Committees’ means the Committee on Public Works and Transportation and the Committee on Merchant Marine and Fisheries in the House of Representatives and the Committee on Environment and Public Works and Committee on Commerce, Science, and Transportation in the Senate; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/a/2/B"},"text":"Pub. L. 104–332, § 2(a)(2)(B)","children":[],"tail":", substituted “ ‘Assistant Secretary’ means” for “ ‘assistant Secretary’ means”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/a/2/A"},"text":"Pub. L. 104–332, § 2(a)(2)(A)","children":[],"tail":", redesignated par. (3) as (2). Former par. (2) redesignated (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/a/2/A"},"text":"Pub. L. 104–332, § 2(a)(2)(A)","children":[],"tail":", redesignated pars. (4) to (8) as (3) to (7), respectively. Former par. (3) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/a/2/D"},"text":"Pub. L. 104–332, § 2(a)(2)(D)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/a/2/A"},"text":"Pub. L. 104–332, § 2(a)(2)(A)","children":[],"tail":", redesignated par. (8) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (9), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/a/2/D"},"text":"Pub. L. 104–332, § 2(a)(2)(D)","children":[],"tail":", added pars. (9) and (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/a/2/C"},"text":"Pub. L. 104–332, § 2(a)(2)(C)","children":[],"tail":", redesignated pars. (9) and (10) as (11) and (12), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (11) to (17). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/a/2/C"},"text":"Pub. L. 104–332, § 2(a)(2)(C)","children":[],"tail":", redesignated pars. (9) to (15) as (11) to (17), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/580"},"text":"Pub. L. 102–580","children":[],"tail":" inserted “the Committee on Public Works and Transportation and” after “means”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79f30f7e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id79f30f7f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
