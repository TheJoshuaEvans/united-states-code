{"tag":"section","attrib":{"id":"id792d27f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421d"},"text":"§ 1421d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unusual mortality event activity funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792d27f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury an interest bearing fund to be known as the “Marine Mammal Unusual Mortality Event Fund”, which shall consist of amounts deposited into the Fund under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d27f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts in the Fund shall be available only for use by the Secretary, in consultation with the Secretary of the Interior, and dispersed among claimants based on budgets approved by the Secretary prior to expenditure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d27f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make advance, partial, or progress payments under contracts or other funding mechanisms for property, supplies, salaries, services, and travel costs incurred in acting in accordance with the contingency plan issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421c/b"},"text":"section 1421c(b) of this title","children":[],"tail":" or under the direction of an Onsite Coordinator for an unusual mortality event designated under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421c/a/2/B/iii"},"text":"section 1421c(a)(2)(B)(iii) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d27fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for reimbursing any stranding network participant for costs incurred in the collection, preparation, analysis, and transportation of marine mammal tissues and samples collected with respect to an unusual mortality event for the Tissue Bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d27fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the care and maintenance of a marine mammal seized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1374/c/2/D"},"text":"section 1374(c)(2)(D) of this title","children":[],"tail":"; and "},{"tag":"ref","attrib":{"idref":"fn002638"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002638"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The “; and” probably should be a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d27fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits into Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be deposited into the Fund—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d27fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts appropriated to the Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d27fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other amounts appropriated to the Secretary for use with respect to unusual mortality events; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d27ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts received by the United States in the form of gifts, devises, and bequests under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d2800-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out this subchapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1374/c/2/D"},"text":"section 1374(c)(2)(D) of this title","children":[],"tail":", the Secretary may accept, solicit, and use the services of volunteers, and may accept, solicit, receive, hold, administer, and use gifts, devises, and bequests."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792d2801-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tIV/s405"},"text":"Pub. L. 92–522, title IV, § 405","children":[],"tail":", formerly title III, § 305, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tIII/s3003/a"},"text":"Pub. L. 102–587, title III, § 3003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5064"},"text":"106 Stat. 5064","children":[],"tail":"; renumbered title IV, § 405, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/238"},"text":"Pub. L. 103–238","children":[],"tail":", §§ 6, 16(b), 24(b), (c)(2), "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/542"},"text":"108 Stat. 542","children":[],"tail":", 559, 565, 566; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIV/s10403"},"text":"Pub. L. 117–263, div. J, title CIV, § 10403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3983"},"text":"136 Stat. 3983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792d2802-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792d2803-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id792d2804-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) related to uses of amounts in the Marine Mammal Unusual Mortality Event Fund and payment of pending claims."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/238/s16/b"},"text":"Pub. L. 103–238, § 16(b)","children":[],"tail":", substituted “an interest bearing fund” for “a fund”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/238/s24/c/2"},"text":"Pub. L. 103–238, § 24(c)(2)","children":[],"tail":", made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421c/b"},"text":"section 1421c(b) of this title","children":[],"tail":" to reflect renumbering of corresponding section of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/238/s6/1"},"text":"Pub. L. 103–238, § 6(1)","children":[],"tail":", added cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/238/s6/2"},"text":"Pub. L. 103–238, § 6(2)","children":[],"tail":", inserted “and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1374/c/2/D"},"text":"section 1374(c)(2)(D) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
