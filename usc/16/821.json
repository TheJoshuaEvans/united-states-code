{"tag":"section","attrib":{"id":"id78a5333e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s821"},"text":null,"children":[{"tag":"num","attrib":{"value":"821"},"text":"§ 821.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State laws and water rights unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing contained in this chapter shall be construed as affecting or intending to affect or in any way to interfere with the laws of the respective States relating to the control, appropriation, use, or distribution of water used in irrigation or for municipal or other uses, or any vested right acquired therein.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78a5333f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"June 10, 1920, ch. 285","children":[],"tail":", pt. I, § 27, "},{"tag":"ref","attrib":{"href":"/us/stat/41/1077"},"text":"41 Stat. 1077","children":[],"tail":"; renumbered pt. I, "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-26/ch687"},"text":"Aug. 26, 1935, ch. 687","children":[],"tail":", title II, § 212, "},{"tag":"ref","attrib":{"href":"/us/stat/49/847"},"text":"49 Stat. 847","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
