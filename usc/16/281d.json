{"tag":"section","attrib":{"id":"id77254a2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s281d"},"text":null,"children":[{"tag":"num","attrib":{"value":"281d"},"text":"§ 281d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; notice in Federal Register; administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When the Secretary of the Interior determines that he has acquired title to, or interest in, sufficient properties or determines that he has entered into appropriate cooperative agreements with owners of non-Federal properties, or any combination thereof including the designation of sites already in Federal ownership, he shall by publication in the Federal Register establish the Nez Perce National Historical Park and thereafter administer the Federal property under his administrative jurisdiction in accordance with the Act of ","children":[{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":" et seq.),"},{"tag":"ref","attrib":{"idref":"fn002055"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002055"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" as amended and supplemented."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77254a2c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/19/s5"},"text":"Pub. L. 89–19, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-05-15"},"text":"May 15, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/110"},"text":"79 Stat. 110","children":[],"tail":".)"}],"tail