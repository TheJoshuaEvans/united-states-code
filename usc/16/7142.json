{"tag":"section","attrib":{"id":"id7a278d29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7142"},"text":null,"children":[{"tag":"num","attrib":{"value":"7142"},"text":"§ 7142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a278d2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7142/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A participating county, including any applicable agencies of the participating county, shall use county funds, in accordance with this subchapter, only—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a278d2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7142/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out activities under the Firewise Communities program to provide to homeowners in fire-sensitive ecosystems education on, and assistance with implementing, techniques in home siting, home construction, and home landscaping that can increase the protection of people and property from wildfires;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a278d2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7142/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to reimburse the participating county for search and rescue and other emergency services, including firefighting and law enforcement patrols, that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a278d2d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7142/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performed on Federal land after the date on which the use was approved under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a278d2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7142/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid for by the participating county;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a278d2f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7142/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cover training costs and equipment purchases directly related to the emergency services described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a278d30-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7142/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and carry out community wildfire protection plans in coordination with the appropriate Secretary concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a278d31-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7142/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide or expand access to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a278d32-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7142/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" broadband telecommunications services at local schools; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a278d33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7142/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technology and connectivity necessary for students to use a digital learning tool at or outside of a local school campus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a278d34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7142/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A participating county shall use county funds for a use described in subsection (a) only after a 45-day public comment period, at the beginning of which the participating county shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a278d35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7142/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish in any publications of local record a proposal that describes the proposed use of the county funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a278d36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7142/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the proposal to any resource advisory committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7125"},"text":"section 7125 of this title","children":[],"tail":" for the participating county."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a278d37-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/393/tIII/s302"},"text":"Pub. L. 106–393, title III, § 302","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tVI/s601/a"},"text":"Pub. L. 110–343, div. C, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3909"},"text":"122 Stat. 3909","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dF/tI/s100101/a/9"},"text":"Pub. L. 112–141, div. F, title I, § 100101(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/906"},"text":"126 Stat. 906","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/tIV/s402"},"text":"Pub. L. 115–141, div. O, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1079"},"text":"132 Stat. 1079","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tXII/s41202/e"},"text":"Pub. L. 117–58, div. D, title XII, § 41202(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1134"},"text":"135 Stat. 1134","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a278d38-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a278d39-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}]