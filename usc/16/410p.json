{"tag":"section","attrib":{"id":"id7746b49a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410p"},"text":null,"children":[{"tag":"num","attrib":{"value":"410p"},"text":"§ 410p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7746b49b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated such sums, but not more than $22,000,000 in all, as are required for the acquisition of land, water, and interests therein held in private ownership within the boundaries of Everglades National Park as fixed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410i"},"text":"section 410i of this title","children":[],"tail":" and outside the area described in sections 410e to 410h of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7746b49c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the amount authorized in subsection (a) of this section there is authorized to be appropriated such amount, not in excess of $700,200, as is necessary for the acquisition, in accordance with the provisions of sections 410i to 410p of this title, of the following described privately owned lands:","children":[{"tag":"p","attrib":{},"text":"Sections 3, 4, and 5; section 6, less the west half of the northwest quarter; sections 7, 8, 9, and 10; north half of section 15; and sections 17 and 18, all in township 59 south, range 37 east, Tallahassee meridian.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7746b49d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/482/s8"},"text":"Pub. L. 85–482, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-02"},"text":"July 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/286"},"text":"72 Stat. 286","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/88"},"text":"Pub. L. 91–88","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-10-17"},"text":"Oct. 17, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/134"},"text":"83 Stat. 134","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/428/s1"},"text":"Pub. L. 91–428, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-09-26"},"text":"Sept. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/885"},"text":"84 Stat. 885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7746b49e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7746b49f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7746b4a0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/428"},"text":"Pub. L. 91–428","children":[],"tail":" substituted “$22,000,000” for “$2,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/88"},"text":"Pub. L. 91–88","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
