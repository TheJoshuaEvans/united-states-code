{"tag":"section","attrib":{"id":"id79345465-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443"},"text":null,"children":[{"tag":"num","attrib":{"value":"1443"},"text":"§ 1443.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Destruction or loss of, or injury to, sanctuary resources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79345466-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79345467-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability to United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who destroys, causes the loss of, or injures any sanctuary resource is liable to the United States for an amount equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79345468-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of response costs and damages resulting from the destruction, loss, or injury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79345469-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest on that amount calculated in the manner described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2705"},"text":"section 2705 of title 33","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7934546a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability in rem","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vessel used to destroy, cause the loss of, or injure any sanctuary resource shall be liable in rem to the United States for response costs and damages resulting from such destruction, loss, or injury. The amount of that liability shall constitute a maritime lien on the vessel and may be recovered in an action in rem in any district court of the United States that has jurisdiction over the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7934546b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person is not liable under this subsection if that person establishes that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7934546c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the destruction or loss of, or injury to, the sanctuary resource was caused solely by an act of God, an act of war, or an act or omission of a third party, and the person acted with due care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7934546d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the destruction, loss, or injury was caused by an activity authorized by Federal or State law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7934546e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the destruction, loss, or injury was negligible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7934546f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limits to liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in sections 4281–4289 of the Revised Statutes of the United States or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s30706"},"text":"section 30706 of title 46","children":[],"tail":" shall limit the liability of any person under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79345470-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response actions and damage assessment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79345471-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may undertake or authorize all necessary actions to prevent or minimize the destruction or loss of, or injury to, sanctuary resources, or to minimize the imminent risk of such destruction, loss, or injury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79345472-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Damage assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall assess damages to sanctuary resources in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1432/6"},"text":"section 1432(6) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79345473-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions for response costs and damages","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79345474-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General, upon request of the Secretary, may commence a civil action against any person or vessel who may be liable under subsection (a) for response costs and damages. The Secretary, acting as trustee for sanctuary resources for the United States, shall submit a request for such an action to the Attorney General whenever a person may be liable for such costs or damages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79345475-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An action under this subsection may be brought in the United States district court for any district in which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79345476-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant is located, resides, or is doing business, in the case of an action against a person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79345477-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is located, in the case of an action against a vessel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79345478-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the destruction of, loss of, or injury to a sanctuary resource occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79345479-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of recovered amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Response costs and damages recovered by the Secretary under this section shall be retained by the Secretary in the manner provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9607/f/1"},"text":"section 9607(f)(1) of title 42","children":[],"tail":", and used as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7934547a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts recovered by the United States for costs of response actions and damage assessments under this section shall be used, as the Secretary considers appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7934547b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reimburse the Secretary or any other Federal or State agency that conducted those activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7934547c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after reimbursement of such costs, to restore, replace, or acquire the equivalent of any sanctuary resource.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7934547d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All other amounts recovered shall be used, in order of priority—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7934547e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restore, replace, or acquire the equivalent of the sanctuary resources that were the subject of the action, including for costs of monitoring and the costs of curation and conservation of archeological, historical, and cultural sanctuary resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7934547f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restore degraded sanctuary resources of the national marine sanctuary that was the subject of the action, giving priority to sanctuary resources and habitats that are comparable to the sanctuary resources that were the subject of the action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79345480-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restore degraded sanctuary resources of other national marine sanctuaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79345481-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal-State coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts recovered under this section with respect to sanctuary resources lying within the jurisdiction of a State shall be used under paragraphs (2)(A) and (B) in accordance with the court decree or settlement agreement and an agreement entered into by the Secretary and the Governor of that State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79345482-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1443/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An action for response costs or damages under subsection (c) shall be barred unless the complaint is filed within 3 years after the date on which the Secretary completes a damage assessment and restoration plan for the sanctuary resources to which the action relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79345483-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tIII/s312"},"text":"Pub. L. 92–532, title III, § 312","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/627/tII/s204/a"},"text":"Pub. L. 100–627, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3215"},"text":"102 Stat. 3215","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tII"},"text":"Pub. L. 102–587, title II","children":[],"tail":", §§ 2107(d), 2110, "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5044"},"text":"106 Stat. 5044","children":[],"tail":", 5045; "},{"tag":"ref","attrib":{"href":"/us/pl/104/283/s9/e"},"text":"Pub. L. 104–283, § 9(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3367"},"text":"110 Stat. 3367","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/513"},"text":"Pub. L. 106–513","children":[],"tail":", §§ 13, 19(c), "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2389"},"text":"114 Stat. 2389","children":[],"tail":", 2393.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79345484-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79345485-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79345486-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 4281–4289 of the Revised Statutes of the United States, referred to in subsec. (a)(4), were classified to sections 181 to 188 of the former Appendix to Title 46, Shipping, and section 175 of former Title 46. Sections 4281 to 4287 and 4289 of the Revised Statutes were repealed and restated in chapter 305 of Title 46, Shipping, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":", §§ 6(c), 19, "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1509"},"text":"120 Stat. 1509","children":[],"tail":", 1710. Section 4288 of the Revised Statutes (section 175 of former Title 46) was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1940-10-09/ch777/s7"},"text":"act Oct. 9, 1940, ch. 777, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/1028"},"text":"54 Stat. 1028","children":[],"tail":". For disposition of sections of the former Appendix to Title 46, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of Title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79345487-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a)(4), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s30706"},"text":"section 30706 of title 46","children":[],"tail":"” substituted for “"},{"tag":"ref","attrib":{"href":"/us/act/1893-02-13/s3"},"text":"section 3 of the Act of February 13, 1893","children":[],"tail":",” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/c"},"text":"Pub. L. 109–304, § 18(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1709"},"text":"120 Stat. 1709","children":[],"tail":", which Act enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s30706"},"text":"section 30706 of Title 46","children":[],"tail":", Shipping."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79345488-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s19/c"},"text":"Pub. L. 106–513, § 19(c)","children":[],"tail":", amended par. (1) heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s13/a"},"text":"Pub. L. 106–513, § 13(a)","children":[],"tail":", designated existing provisions as par. (1), struck out “in the United States district court for the appropriate district” after “civil action”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s13/b"},"text":"Pub. L. 106–513, § 13(b)","children":[],"tail":", added pars. (1) and (2) and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Response costs and damage assessments","children":[],"tail":".—Twenty percent of amounts recovered under this section, up to a maximum balance of $750,000, shall be used to finance response actions and damage assessments by the Secretary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Restoration, replacement, management, and improvement","children":[],"tail":".—Amounts remaining after the operation of paragraph (1) shall be used, in order of priority—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) to restore, replace, or acquire the equivalent of the sanctuary resources which were the subject of the action;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) to manage and improve the national marine sanctuary within which are located the sanctuary resources which were the subject of the action; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) to manage and improve any other national marine sanctuary.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s13/c"},"text":"Pub. L. 106–513, § 13(c)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/283"},"text":"Pub. L. 104–283","children":[],"tail":" made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2110/d"},"text":"Pub. L. 102–587, § 2110(d)","children":[],"tail":". See 1992 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2110/a"},"text":"Pub. L. 102–587, § 2110(a)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “"},{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—Subject to paragraph (3), any person who destroys, causes the loss of, or injures any sanctuary resource is liable to the United States for response costs and damages resulting from such destruction, loss, or injury.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2110/b"},"text":"Pub. L. 102–587, § 2110(b)","children":[],"tail":", inserted at end “The amount of that liability shall constitute a maritime lien on the vessel and may be recovered in an action in rem in any district court of the United States that has jurisdiction over the vessel.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2110/c"},"text":"Pub. L. 102–587, § 2110(c)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2110/d"},"text":"Pub. L. 102–587, § 2110(d)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/283"},"text":"Pub. L. 104–283","children":[],"tail":", inserted “or authorize” after “undertake”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2107/d/1"},"text":"Pub. L. 102–587, § 2107(d)(1)","children":[],"tail":", struck out “and civil penalties under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1437"},"text":"section 1437 of this title","children":[],"tail":"” after “Secretary under this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":", §§ 2107(d)(2), 2110(e), redesignated par. (4) as (3), inserted “the court decree or settlement agreement and” after “in accordance with”, and struck out former par. (3) which read as follows: “Amounts recovered under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1437"},"text":"section 1437 of this title","children":[],"tail":" in the form of civil penalties shall be used by the Secretary in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1437/e"},"text":"section 1437(e) of this title","children":[],"tail":" and paragraphs (2)(B) and (C) of this subsection.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79345489-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7934548a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/627/tII/s204/c"},"text":"Pub. L. 100–627, title II, § 204(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3217"},"text":"102 Stat. 3217","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/627/tII/s204/c"},"text":"“Amounts in the form of damages received by the United States after ","children":[{"tag":"date","attrib":{"date":"1986-11-30"},"text":"November 30, 1986","children":[],"tail":", for destruction or loss of, or injury to, a sanctuary resource (as that term is defined in section 302(8) of the Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1432/8"},"text":"16 U.S.C. 1432(8)","children":[],"tail":"] (as amended by this Act)) shall be subject to section 312 of the Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1443"},"text":"16 U.S.C. 1443","children":[],"tail":"] (as amended by this Act).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
