{"tag":"section","attrib":{"id":"id79e99a1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4103"},"text":null,"children":[{"tag":"num","attrib":{"value":"4103"},"text":"§ 4103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apportionment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e99a1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time when apportionments made","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated under section 4107(a) ","children":[{"tag":"ref","attrib":{"idref":"fn002786"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002786"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title shall be apportioned by the Secretary among the States on October 1 of each fiscal year, or as soon thereafter as practicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e99a1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apportionment formula","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of funds apportioned to each State shall be determined by the Secretary as the ratio which the equally weighted average of the volume and value of fishery resources harvested by domestic commercial fishermen and received within such State during the 3 most recent calendar years for which data satisfactory to the Secretary are available bears to the total equally weighted average of the volume and value of all fishery resources harvested by domestic commercial fishermen received within all of the States during those calendar years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e99a1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e99a1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No State may receive an apportionment under subsection (b) for either fiscal year 1987 or fiscal year 1988 which is less than one-half of one percent of the total amount of funds available for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e99a1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For any fiscal year after fiscal year 1988, no State that, under the apportionment formula in subsection (b), has a ratio of one-third of one percent or higher may receive an apportionment for any fiscal year which is less than one percent of the total amount of funds available for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e99a20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4103/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For any fiscal year after fiscal year 1988, no State may receive an apportionment under this section for any fiscal year if that State’s ratio under the apportionment formula in subsection (b) is less than one-third of one percent, unless the State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e99a21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4103/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is signatory to an interstate fishery compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e99a22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4103/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has entered into an agreement with the Secretary or the Secretary of the Interior under which the personnel, services, and equipment of the State and the Federal agency concerned will be made mutually available for the enforcement of Federal and State laws pertaining to the protection of fishery resources which are managed under an interstate fishery management plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e99a23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4103/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" borders one or more of the Great Lakes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e99a24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4103/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has entered into an interstate cooperative fishery management agreement and has in effect an interstate fisheries management or interstate fisheries research program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e99a25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4103/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No State that, under the apportionment formula in subsection (b), has a ratio of less than one-third of one percent and meets any of the requirements set forth in paragraph (1)(A), (B), (C), or (D) may receive an apportionment for any fiscal year which is less than one-half of one percent of the total amount of funds available for apportionment for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e99a26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4103/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No State may receive an apportionment for any fiscal year under this section which is more than 6 percent of the total amount of funds available for apportionment for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e99a27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unused apportionments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any part of an apportionment for any fiscal year to any State—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e99a28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4103/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not obligated during that year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e99a29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4103/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which the State notifies the Secretary that it does not wish to receive that part; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e99a2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4103/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is returned to the Secretary by the State,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may not be considered to be apportioned to that State and shall be added to such funds as are appropriated pursuant to section 4107(a) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title for the next fiscal year (and shall be treated as having been appropriated for such next year) for apportionment under subsection (a). Any notification or return of funds referred to in paragraph (2) or (3) by a State is irrevocable."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e99a2b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659/tIII/s304"},"text":"Pub. L. 99–659, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3733"},"text":"100 Stat. 3733","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/627/tV/s501"},"text":"Pub. L. 101–627, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4462"},"text":"104 Stat. 4462","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e99a2c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e99a2d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79e99a2e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4107"},"text":"Section 4107 of this title","children":[],"tail":", referred to in subsecs. (a) and (d), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dS/tII/s204/a"},"text":"Pub. L. 117–328, div. S, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5270"},"text":"136 Stat. 5270","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79e99a2f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (c)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/627"},"text":"Pub. L. 101–627","children":[],"tail":" inserted “which are managed under an interstate fishery management plan” before semicolon at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79e99a30-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79e99a31-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"Oct. 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/659/s310"},"text":"section 310 of Pub. L. 99–659","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4101"},"text":"section 4101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
