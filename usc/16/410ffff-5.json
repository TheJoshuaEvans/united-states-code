{"tag":"section","attrib":{"id":"id7784a872-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ffff–5"},"text":"§ 410ffff–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out the purposes of this subchapter, except that not more than $4,000,000 may be appropriated for the acquisition of real and personal property.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7784a873-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/485/s7"},"text":"Pub. L. 101–485, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-31"},"text":"Oct. 31, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1173"},"text":"104 Stat. 1173","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/363/s1/b"},"text":"Pub. L. 105–363, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3296"},"text":"112 Stat. 3296","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7784a874-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7784a875-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7784a876-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/363"},"text":"Pub. L. 105–363","children":[],"tail":" substituted “$4,000,000” for “$1,500,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
