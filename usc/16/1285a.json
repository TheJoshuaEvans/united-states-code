{"tag":"section","attrib":{"id":"id7912e8cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1285a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1285a"},"text":"§ 1285a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease of Federal lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7912e8ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1285a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary; restrictive covenants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where appropriate in the discretion of the Secretary, he may lease federally owned land (or any interest therein) which is within the boundaries of any component of the National Wild and Scenic Rivers System and which has been acquired by the Secretary under this chapter. Such lease shall be subject to such restrictive covenants as may be necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7912e8cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1285a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offer to prior owner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any land to be leased by the Secretary under this section shall be offered first for such lease to the person who owned such land immediately before its acquisition by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7912e8d0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/542/s14A"},"text":"Pub. L. 90–542, § 14A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tVII/s764"},"text":"Pub. L. 95–625, title VII, § 764","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3534"},"text":"92 Stat. 3534","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
