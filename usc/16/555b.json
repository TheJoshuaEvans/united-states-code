{"tag":"section","attrib":{"id":"id78438b19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s555b"},"text":null,"children":[{"tag":"num","attrib":{"value":"555b"},"text":"§ 555b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Street improvements; availability of Forest Service funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds available to the Forest Service shall be available for expenses of, or payment of assessment for, construction of sidewalks, curbs, or street paving along the boundary of Government-owned residential or otherwise improved lots.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78438b1a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/869/s9"},"text":"Pub. L. 87–869, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1157"},"text":"76 Stat. 1157","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
