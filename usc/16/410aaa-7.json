{"tag":"section","attrib":{"id":"id7765ae3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–7"},"text":"§ 410aaa–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In preparing the maps and legal descriptions required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410aaa–3"},"text":"section 410aaa–3 of this title","children":[],"tail":" and section 602 of this Act, the Secretary shall adjust the boundaries of the Death Valley National Park and Death Valley National Park Wilderness so as to exclude from such National Park and Wilderness the lands generally depicted on the map entitled “Porter Mine (Panamint Range) Exclusion Area” dated June 1994."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7765ae3f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tIII/s308"},"text":"Pub. L. 103–433, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4487"},"text":"108 Stat. 4487","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7765ae40-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7765ae41-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7765ae42-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 602 of this Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/s602"},"text":"section 602 of Pub. L. 103–433","children":[],"tail":", title VI, "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4496"},"text":"108 Stat. 4496","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7765ae43-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7765ae44-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Death Valley National Park Boundary Revision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1431/a"},"text":"Pub. L. 116–9, title I, § 1431(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/699"},"text":"133 Stat. 699","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/9/tI/s1431/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The boundary of Death Valley National Park is adjusted to include—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the approximately 28,923 acres of Bureau of Land Management land in San Bernardino County, California, abutting the southern end of the Death Valley National Park that lies between Death Valley National Park to the north and Ft. Irwin Military Reservation to the south and which runs approximately 34 miles from west to east, as depicted on the map entitled ‘Death Valley National Park Proposed Boundary Addition-Bowling Alley’, numbered 143/128,605A, and dated ","children":[{"tag":"date","attrib":{"date":"2018-11-01"},"text":"November 1, 2018","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the approximately 6,369 acres of Bureau of Land Management land in Inyo County, California, located in the northeast area of Death Valley National Park that is within, and surrounded by, land under the jurisdiction of the Director of the National Park Service, as depicted on the map entitled ‘Death Valley National Park Proposed Boundary Addition-Crater’, numbered 143/100,079D, and dated ","children":[{"tag":"date","attrib":{"date":"2018-11-01"},"text":"November 1, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Map","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maps described in paragraphs (1) and (2) of subsection (a) shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall administer any land added to Death Valley National Park under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of Death Valley National Park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with applicable laws (including regulations); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into a memorandum of understanding with Inyo County, California, to permit operationally feasible, ongoing access to and use (including material storage and excavation) of existing gravel pits along Saline Valley Road within Death Valley National Park for road maintenance and repairs in accordance with applicable laws (including regulations).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For defintion of “Secretary” as used in section 1431(a)–(c) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9"},"text":"Pub. L. 116–9","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/s1401"},"text":"section 1401 of Pub. L. 116–9","children":[],"tail":", set out as a Definitions note below.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7765ae45-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1401"},"text":"Pub. L. 116–9, title I, § 1401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/692"},"text":"133 Stat. 692","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/9/tI/s1401"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this subtitle [subtitle E (§§ 1401–1461) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9"},"text":"Pub. L. 116–9","children":[],"tail":", enacting subchapters CXLII and CXLIII of this chapter and sections 410aaa–28, 410aaa–81 to 410aaa–81c, and 410aaa–91 of this title, amending sections 410aaa–75, 410aaa–77, 410aaa–82, and 1274 of this title, repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410aaa–81"},"text":"section 410aaa–81 of this title","children":[],"tail":", enacting provisions set out as notes under this section and sections 410aaa, 410aaa–22, 410aaa–56, 670g of this title, amending provisions set out as notes under sections 410aaa and 410aaa–82 of this title, and enacting and amending provisions listed in a table of Wilderness Areas set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"section 1132 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conservation area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Conservation Area’ means the California Desert Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘Secretary’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary [of the Interior], with respect to land administered by the Department of the Interior; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, with respect to National Forest System land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘State’ means the State of California.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
