{"tag":"section","attrib":{"id":"id77230096-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s271e"},"text":null,"children":[{"tag":"num","attrib":{"value":"271e"},"text":"§ 271e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to President","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Within three years from ","children":[{"tag":"date","attrib":{"date":"1971-11-12"},"text":"November 12, 1971","children":[],"tail":", the Secretary of the Interior shall report to the President, in accordance with section 1132(c) and (d) of this title, his recommendations as to the suitability or nonsuitability of any area within the national park for preservation as wilderness, and any designation of any such area as a wilderness shall be accomplished in accordance with said section 1132(c) and (d) of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77230097-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/590/s6"},"text":"Pub. L. 88–590, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/154/s1/d"},"text":"Pub. L. 92–154, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-11-12"},"text":"Nov. 12, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/421"},"text":"85 Stat. 421","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
