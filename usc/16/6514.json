{"tag":"section","attrib":{"id":"id7a0fbf7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514"},"text":null,"children":[{"tag":"num","attrib":{"value":"6514"},"text":"§ 6514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental analysis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0fbf7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized hazardous fuel reduction projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this subchapter, the Secretary shall conduct authorized hazardous fuel reduction projects in accordance with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fbf7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Environmental Policy Act of 1969 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbf7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fbf80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental assessment or environmental impact statement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prepare an environmental assessment or an environmental impact statement pursuant to section 102(2) of the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2"},"text":"42 U.S.C. 4332(2)","children":[],"tail":") for each authorized hazardous fuel reduction project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fbf81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of alternatives","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fbf82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d), in the environmental assessment or environmental impact statement prepared under subsection (b), the Secretary shall study, develop, and describe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fbf83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed agency action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbf84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alternative of no action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbf85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an additional action alternative, if the additional alternative—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a0fbf86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is proposed during scoping or the collaborative process under subsection (f); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0fbf87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the purpose and need of the project, in accordance with regulations promulgated by the Council on Environmental Quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbf88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple additional alternatives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If more than 1 additional alternative is proposed under paragraph (1)(C), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fbf89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select which additional alternative to consider, which is a choice that is in the sole discretion of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbf8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a written record describing the reasons for the selection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fbf8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative analysis process for projects in wildland-urban interface","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fbf8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposed agency action and 1 action alternative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For an authorized hazardous fuel reduction project that is proposed to be conducted in the wildland-urban interface, the Secretary is not required to study, develop, or describe more than the proposed agency action and 1 action alternative in the environmental assessment or environmental impact statement prepared pursuant to section 102(2) of the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2"},"text":"42 U.S.C. 4332(2)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbf8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposed agency action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), but subject to paragraph (3), if an authorized hazardous fuel reduction project proposed to be conducted in the wildland-urban interface is located no further than 1½ miles from the boundary of an at-risk community, the Secretary is not required to study, develop, or describe any alternative to the proposed agency action in the environmental assessment or environmental impact statement prepared pursuant to section 102(2) of the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2"},"text":"42 U.S.C. 4332(2)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbf8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposed agency action and community wildfire protection plan alternative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an authorized hazardous fuel reduction project described in paragraph (2), if the at-risk community has adopted a community wildfire protection plan and the proposed agency action does not implement the recommendations in the plan regarding the general location and basic method of treatments, the Secretary shall evaluate the recommendations in the plan as an alternative to the proposed agency action in the environmental assessment or environmental impact statement prepared pursuant to section 102(2) of the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2"},"text":"42 U.S.C. 4332(2)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fbf8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice and meeting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fbf90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide notice of each authorized hazardous fuel reduction project in accordance with applicable regulations and administrative guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbf91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public meeting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the preparation stage of each authorized hazardous fuel reduction project, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fbf92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a public meeting at an appropriate location proximate to the administrative unit of the Federal land on which the authorized hazardous fuel reduction project will be conducted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbf93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advance notice of the location, date, and time of the meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fbf94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to encourage meaningful public participation during preparation of authorized hazardous fuel reduction projects, the Secretary shall facilitate collaboration among State and local governments and Indian tribes, and participation of interested persons, during the preparation of each authorized fuel reduction project in a manner consistent with the Implementation Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fbf95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental analysis and public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with section 102(2) of the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2"},"text":"42 U.S.C. 4332(2)","children":[],"tail":") and the applicable regulations and administrative guidelines, the Secretary shall provide an opportunity for public comment during the preparation of any environmental assessment or environmental impact statement for an authorized hazardous fuel reduction project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fbf96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6514/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decision document","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall sign a decision document for authorized hazardous fuel reduction projects and provide notice of the final agency actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0fbf97-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tI/s104"},"text":"Pub. L. 108–148, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1897"},"text":"117 Stat. 1897","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0fbf98-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0fbf99-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a0fbf9a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
