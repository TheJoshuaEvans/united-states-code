{"tag":"section","attrib":{"id":"id77930010-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"430f–13"},"text":"§ 430f–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shiloh National Military Park boundary adjustment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77930011-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77930012-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliated area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “affiliated area” means the Parker’s Crossroads Battlefield established as an affiliated area of the National Park System by subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77930013-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Park” means Shiloh National Military Park, a unit of the National Park System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77930014-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas to be added to Shiloh National Military Park","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77930015-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The boundary of the Park is modified to include the areas that are generally depicted on the map entitled “Shiloh National Military Park, Proposed Boundary Adjustment”, numbered 304/80,011, and dated July 2014, and which are comprised of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77930016-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fallen Timbers Battlefield.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77930017-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Russell House Battlefield.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77930018-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Davis Bridge Battlefield.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77930019-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire the land described in paragraph (1) by donation, purchase from willing sellers with donated or appropriated funds, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7793001a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any land acquired under this subsection shall be administered as part of the Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7793001b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of affiliated area","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7793001c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Parker’s Crossroads Battlefield in the State of Tennessee is established as an affiliated area of the National Park System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7793001d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of affiliated area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The affiliated area shall consist of the area generally depicted within the “Proposed Boundary” on the map entitled “Parker’s Crossroads Battlefield, Proposed Boundary”, numbered 903/80,073, and dated July 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7793001e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The affiliated area shall be managed in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7793001f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77930020-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any law generally applicable to units of the National Park System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77930021-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The City of Parkers Crossroads and the Tennessee Historical Commission shall jointly be the management entity for the affiliated area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77930022-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical assistance and enter into cooperative agreements with the management entity for the purpose of providing financial assistance for the marketing, marking, interpretation, and preservation of the affiliated area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77930023-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited role of the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section authorizes the Secretary to acquire property at the affiliated area or to assume overall financial responsibility for the operation, maintenance, or management of the affiliated area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77930024-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General management plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77930025-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the management entity, shall develop a general management plan for the affiliated area in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77930026-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–13/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after the date on which funds are made available to carry out this section, the Secretary shall submit to the Committee on Natural Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate the general management plan developed under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77930027-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2101"},"text":"Pub. L. 116–9, title II, § 2101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/723"},"text":"133 Stat. 723","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77930028-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77930029-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7793002a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2"},"text":"section 2 of Pub. L. 116–9","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
