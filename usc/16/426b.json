{"tag":"section","attrib":{"id":"id778bd437-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s426b"},"text":null,"children":[{"tag":"num","attrib":{"value":"426b"},"text":"§ 426b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be the duty of the commission, acting under the direction of the Secretary of the Interior, to inspect the battlefield of Stones River, Tennessee, and to carefully study the available records and historical data with respect to the location and movement of all troops which engaged in the battle of Stones River, and the important events connected therewith, with a view of preserving and marking such field for historical and professional military study.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778bd438-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-03/ch374/s3"},"text":"Mar. 3, 1927, ch. 374, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1399"},"text":"44 Stat. 1399","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778bd439-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id778bd43a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id778bd43b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision of act ","children":[{"tag":"date","attrib":{"date":"1927-03-03"},"text":"Mar. 3, 1927","children":[],"tail":", authorizing the submission of a report by the commission to the Secretary of War not later than "},{"tag":"date","attrib":{"date":"1927-12-01"},"text":"Dec. 1, 1927","children":[],"tail":", and describing the contents of such report was omitted as executed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id778bd43c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id778bd43d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of administrative functions of park, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s426"},"text":"section 426 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
