{"tag":"section","attrib":{"id":"id780a52fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx"},"text":null,"children":[{"tag":"num","attrib":{"value":"460xxx"},"text":"§ 460xxx.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beaver Dam Wash National Conservation Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id780a52fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to conserve, protect, and enhance for the benefit and enjoyment of present and future generations the ecological, scenic, wildlife, recreational, cultural, historical, natural, educational, and scientific resources of the Beaver Dam Wash National Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780a52fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780a52ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “management plan” means the management plan for the National Conservation Area developed by the Secretary under subsection (d)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780a5300-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Conservation Area","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “National Conservation Area” means the Beaver Dam Wash National Conservation Area that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780a5301-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consists of approximately 68,083 acres of public land in the County, as generally depicted on the Beaver Dam Wash National Conservation Area Map; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a5302-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is established by subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780a5303-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to valid existing rights, there is established in the State the Beaver Dam Wash National Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780a5304-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780a5305-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", and in accordance with paragraph (2), the Secretary shall develop a comprehensive plan for the long-term management of the National Conservation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780a5306-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the management plan required under paragraph (1), the Secretary shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780a5307-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate State, tribal, and local governmental entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a5308-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780a5309-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motorized vehicles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the management plan required under paragraph (1), the Secretary shall incorporate the restrictions on motorized vehicles described in subsection (e)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780a530a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780a530b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall manage the National Conservation Area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780a530c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that conserves, protects, and enhances the resources of the National Conservation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a530d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id780a530e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780a530f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780a5310-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other applicable law (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780a5311-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall only allow uses of the National Conservation Area that the Secretary determines would further the purpose described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780a5312-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motorized vehicles","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780a5313-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except in cases in which motorized vehicles are needed for administrative purposes, or to respond to an emergency, the use of motorized vehicles in the National Conservation Area shall be permitted only on roads designated by the management plan for the use of motorized vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a5314-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirement relating to certain areas located in the National Conservation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the requirement described in subparagraph (A), with respect to the areas designated on the Beaver Dam Wash National Conservation Area Map as “Designated Road Areas”, motorized vehicles shall be permitted only on the roads identified on such map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780a5315-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The grazing of livestock in the National Conservation Area, where established before ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", shall be permitted to continue—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780a5316-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id780a5317-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/e/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such reasonable regulations, policies, and practices as the Secretary considers necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780a5318-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/e/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable law (including regulations); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a5319-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner consistent with the purpose described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780a531a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildland fire operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section prohibits the Secretary, in cooperation with other Federal, State, and local agencies, as appropriate, from conducting wildland fire operations in the National Conservation Area, consistent with the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780a531b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation of acquired land and interests","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any land or interest in land that is located in the National Conservation Area that is acquired by the United States shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780a531c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" become part of the National Conservation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780a531d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be managed in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780a531e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a531f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a5320-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other applicable law (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780a5321-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780a5322-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, all Federal land located in the National Conservation Area is withdrawn from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780a5323-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all forms of entry, appropriation, and disposal under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a5324-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patenting under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780a5325-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation of the mineral leasing, mineral materials, and geothermal leasing laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780a5326-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xxx/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary acquires additional land that is located in the National Conservation Area after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", the land is withdrawn from operation of the laws referred to in paragraph (1) on the date of acquisition of the land."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id780a5327-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tI/s1975"},"text":"Pub. L. 111–11, title I, § 1975","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1083"},"text":"123 Stat. 1083","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id780a5328-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id780a5329-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id780a532a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in subsecs. (e)(1)(B)(i) and (f)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id780a532b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id780a532c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s1971"},"text":"section 1971 of Pub. L. 111–11","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460www"},"text":"section 460www of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
