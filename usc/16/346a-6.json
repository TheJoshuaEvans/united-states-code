{"tag":"section","attrib":{"id":"id772c7635-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s346a–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"346a–6"},"text":"§ 346a–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of administrative jurisdiction to National Park Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Administrative jurisdiction over the land identified as the Watchman Wilderness on the Northeastern Washington County Wilderness Map is hereby transferred to the National Park Service, to be included in, and administered as part of Zion National Park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id772c7636-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tI/s1972/d"},"text":"Pub. L. 111–11, title I, § 1972(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1080"},"text":"123 Stat. 1080","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id772c7637-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id772c7638-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id772c7639-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Northeastern Washington County Wilderness Map”, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s1971"},"text":"section 1971 of Pub. L.