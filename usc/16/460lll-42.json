{"tag":"section","attrib":{"id":"id77fbfb58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–42"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–42"},"text":"§ 460lll–42.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States that, to the maximum extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfb59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–42/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer of jurisdiction over the Recreation Area from the Tennessee Valley Authority to the Secretary should be effected in an efficient and cost-effective manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–42/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" due consideration should be given to minimizing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77fbfb5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–42/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disruption of the personal lives of the Tennessee Valley Authority and Forest Service employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fbfb5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–42/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adverse impacts on permittees, contractees, and others owning or operating businesses affected by the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fbfb5d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s542"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 542]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–318.)"}],"tail":"\n"}],"tail":null}
