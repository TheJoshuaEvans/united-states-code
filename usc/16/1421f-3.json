{"tag":"section","attrib":{"id":"id792d2891-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421f–3"},"text":"§ 1421f–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792d2892-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of appropriate committees of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d2893-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2894-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Environment and Public Works of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2895-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Natural Resources of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2896-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Science, Space, and Technology of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d2897-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health MAP status report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d2898-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Administrator of the National Oceanic and Atmospheric Administration, in consultation with the Marine Mammal Commission, the Secretary of the Interior, and the National Ocean Research Leadership Council, shall submit to the appropriate committees of Congress a report describing the status of the Health MAP."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2899-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d289a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed evaluation of the data made publicly available through the Health MAP;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d289b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed list of any gaps in data collected pursuant to the Health MAP, a description of the reasons for those gaps, and recommended actions to close those gaps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f989c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the effectiveness of using the website of the Observation System as the platform to collect, organize, visualize, archive, and disseminate marine mammal stranding and health data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f989d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of publications, presentations, or other relevant work product resulting from, or produced in collaboration with, the Health MAP;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f989e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of emerging marine mammal health concerns and the applicability of those concerns to human health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f989f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the feasibility of the Observation System being used as an alert system during stranding events, entanglement events, and unusual mortality events for the stranding network, Observation System partners, Health MAP partners, Federal and State agencies, and local and Tribal governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f98a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the use of Health MAP data to predict broader ecosystem events and changes that may impact marine mammal or human health and specific examples of proven or potential uses of Observation System data for those purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f98a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations for the Health MAP with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id792f98a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/b/2/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" filling any identified data gaps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792f98a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/b/2/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards that could be used to improve data quality, accessibility, transmission, interoperability, and sharing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792f98a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/b/2/H/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other strategies that would contribute to the effectiveness and usefulness of the Health MAP; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792f98a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/b/2/H/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding levels needed to maintain and improve the Health MAP.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792f98a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data gap analysis","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792f98a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after the date on which the report required under subsection (b)(1) is submitted, and every 10 years thereafter, the Administrator of the National Oceanic and Atmospheric Administration, in consultation with the Marine Mammal Commission and the Director of the United States Fish and Wildlife Service, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792f98a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make publicly available a report on the data gap analysis described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f98a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a briefing to the appropriate committees of Congress concerning that data gap analysis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f98aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The data gap analysis under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792f98ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an overview of existing participants within a marine mammal stranding network;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f98ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of coverage needs and participant gaps within a network;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f98ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of data and reporting gaps from members of a network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f98ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of how stranding and health data are shared and made available to scientists, academics, State, local, and Tribal governments, and the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792f98af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marine mammal response capabilities in the Arctic","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792f98b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Administrator of the National Oceanic and Atmospheric Administration, the Director of the United States Fish and Wildlife Service, and the Director of the United States Geologic Survey, in consultation with the Marine Mammal Commission, shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792f98b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make publicly available a report describing the response capabilities for sick and injured marine mammals in the Arctic regions of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f98b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a briefing to the appropriate committees of Congress on that report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f98b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arctic","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Arctic” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4111"},"text":"section 4111 of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f98b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792f98b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description, developed in consultation with the Fish and Wildlife Service of the Department of the Interior, of all marine mammal stranding agreements in place for the Arctic region of the United States, including species covered, response capabilities, facilities and equipment, and data collection and analysis capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f98b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of State and local government agencies that have personnel trained to respond to marine mammal strandings in the Arctic region of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f98b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of potential response and data collection partners and sources of local information and knowledge, including Alaska Native people and villages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f98b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of spatial and temporal trends in marine mammal strandings and unusual mortality events that are correlated with changing environmental conditions in the Arctic region of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f98b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of training and other resource needs to meet emerging response requirements in the Arctic region of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f98ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of oiled marine mammal response and rehabilitation capabilities in the Arctic region of the United States, including personnel, equipment, facilities, training, and husbandry capabilities, and an assessment of factors that affect response and rehabilitation success rates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f98bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–3/d/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations to address future stranding response needs for marine mammals in the Arctic region of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792f98bc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tIV/s408B"},"text":"Pub. L. 92–522, title IV, § 408B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIV/s10408/a"},"text":"Pub. L. 117–263, div. J, title CIV, § 10408(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3990"},"text":"136 Stat. 3990","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
