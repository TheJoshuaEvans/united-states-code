{"tag":"section","attrib":{"id":"id795a79e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1681"},"text":null,"children":[{"tag":"num","attrib":{"value":"1681"},"text":"§ 1681.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional statement of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this subchapter is to develop, demonstrate, and make available information on feasible methods that have potential for commercial application to increase and improve utilization, in residential, commercial, and industrial or powerplant applications, of wood residues resulting from timber harvesting and forest protection and management activities occurring on public and private forest lands, and from the manufacture of forest products, including woodpulp.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id795a79e9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/554/s2"},"text":"Pub. L. 96–554, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-19"},"text":"Dec. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3257"},"text":"94 Stat. 3257","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795a79ea-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id795a79eb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id795a79ec-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/554/s9"},"text":"Pub. L. 96–554, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-19"},"text":"Dec. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3259"},"text":"94 Stat. 3259","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/554/s9"},"text":"“This Act [enacting this subchapter and enacting a provision set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1600"},"text":"section 1600 of this title","children":[],"tail":"] shall become effective "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"October 1, 1981","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id795a79ed-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/554"},"text":"Pub. L. 96–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-19"},"text":"Dec. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3257"},"text":"94 Stat. 3257","children":[],"tail":", as the Wood Residue Utilization Act of 1980, see Short Title of 1980 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1600"},"text":"section 1600 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
