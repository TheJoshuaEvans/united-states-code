{"tag":"section","attrib":{"id":"id78863a58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718s"},"text":null,"children":[{"tag":"num","attrib":{"value":"718s"},"text":"§ 718s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic stamp requirements; recognition of electronic stamp","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78863a59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stamp requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require an electronic stamp issued by a State under this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78863a5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718s/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to have the same format as any other license, validation, or privilege the State issues under the automated licensing system of the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718s/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to specify identifying features of the licensee that are adequate to enable Federal, State, and other law enforcement officers to identify the holder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78863a5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition of electronic stamp","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any electronic stamp issued by a State under this subchapter shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78863a5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718s/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bestow upon the licensee the same privileges as are bestowed by an actual stamp;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718s/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be recognized nationally as a valid Federal migratory bird hunting and conservation stamp; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718s/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize the licensee to hunt migratory waterfowl in any other State, in accordance with the laws of the other State governing that hunting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78863a60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718s/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An electronic stamp issued by a State shall be valid through the first June 30 that occurs after the date of issuance of the electronic stamp by the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78863a61-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/239/s6"},"text":"Pub. L. 113–239, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2849"},"text":"128 Stat. 2849","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/25/s2/c"},"text":"Pub. L. 118–25, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-19"},"text":"Dec. 19, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/130"},"text":"137 Stat. 130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78863a62-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78863a63-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78863a64-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/25/s2/c/1"},"text":"Pub. L. 118–25, § 2(c)(1)","children":[],"tail":", substituted “shall—” for “shall, during the effective period of the electronic stamp—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/25/s2/c/2"},"text":"Pub. L. 118–25, § 2(c)(2)","children":[],"tail":", substituted “through the first June 30 that occurs after the date of issuance of the electronic stamp by the State” for “for a period agreed to by the State and the Secretary, which shall not exceed 45 days”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
