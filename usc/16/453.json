{"tag":"section","attrib":{"id":"id77a883a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s453"},"text":null,"children":[{"tag":"num","attrib":{"value":"453"},"text":"§ 453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations of land for park purposes near or adjacent to National Forest Reserve in North Carolina","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to accept for park purposes any lands and rights-of-way, including the Grandfather Mountain, near or adjacent to the Government national forest in western North Carolina.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a883a7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-06-12/ch27/s1"},"text":"June 12, 1917, ch. 27, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/152"},"text":"40 Stat. 152","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77a883a8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77a883a9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77a883aa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government national forest” substituted in text for “Government forest reserve” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"act Mar. 4, 1907, ch. 2907","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1269"},"text":"34 Stat. 1269","children":[],"tail":", which provided that forest reserves shall hereafter be known as national forests."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
