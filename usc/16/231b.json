{"tag":"section","attrib":{"id":"id771bd44f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s231b"},"text":null,"children":[{"tag":"num","attrib":{"value":"231b"},"text":"§ 231b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized, in his discretion, to acquire in behalf of the United States, through donations or by purchase at prices deemed by him reasonable, or by condemnation in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"section 3113 of title 40","children":[],"tail":", lands, buildings, structures, and other property, or interests therein, located within the boundaries of the Chalmette Unit of the Jean Lafitte National Historical Park and Preserve as fixed and determined by this subchapter, the title to such property and interests to be satisfactory to the Secretary of the Interior, and to accept donations of funds for the acquisition and maintenance thereof: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That payment for such property or interests shall be made solely from donated funds."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id771bd450-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-10/ch640/s3"},"text":"Aug. 10, 1939, ch. 640, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1342"},"text":"53 Stat. 1342","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tIX/s909"},"text":"Pub. L. 95–625, title IX, § 909","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3538"},"text":"92 Stat. 3538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7105/f/1/B"},"text":"Pub. L. 111–11, title VII, § 7105(f)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1193"},"text":"123 Stat. 1193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id771bd451-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id771bd452-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id771bd453-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"Section 3113 of title 40","children":[],"tail":"” substituted in text for “the Act of "},{"tag":"date","attrib":{"date":"1888-08-01"},"text":"August 1, 1888","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/25/357"},"text":"25 Stat. 357","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id771bd454-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id771bd455-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Jean Lafitte National Historical Park and Preserve” substituted for “Jean Lafitte National Historical Park” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Chalmette Unit of the Jean Lafitte National Historical Park” substituted for “Chalmette National Historical Park” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Pub. L. 95–625","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
