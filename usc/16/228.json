{"tag":"section","attrib":{"id":"id7716f196-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s228"},"text":null,"children":[{"tag":"num","attrib":{"value":"228"},"text":"§ 228.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Buildings on privately owned lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where privately owned lands within the said park lie within three hundred feet of the rim of the Grand Canyon no building, tent, fence, or other structure shall be erected on the park lands lying between said privately owned lands and the rim.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7716f197-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1919-02-26/ch44/s8"},"text":"Feb. 26, 1919, ch. 44, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/1178"},"text":"40 Stat. 1178","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
