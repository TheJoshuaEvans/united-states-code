{"tag":"section","attrib":{"id":"id79369e1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1447c"},"text":"§ 1447c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional research plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79369e1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and amendment of regional plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79369e20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Board shall develop a comprehensive 4-year marine research plan for the region for which the Board is responsible, and shall amend the plan at such times as the Board considers necessary to reflect changing conditions, but no less frequently than once every 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and consideration of national plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the development and amendment of its research plan, the Board shall consider findings and recommendations of the national plan developed pursuant to the National Ocean Pollution Planning Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1701"},"text":"33 U.S.C. 1701","children":[],"tail":" et seq.)."},{"tag":"ref","attrib":{"idref":"fn002647"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002647"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369e22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such marine research plan shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79369e23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an overview of the environmental quality conditions in the coastal and marine waters of the region and expected trends in these conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive inventory and description of all marine research related to water quality and ecosystem health expected to be conducted in the region during the 4-year term of the research plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement and explanation of the marine research needs and priorities applicable to the marine and coastal waters of the region over the upcoming 10-year period with emphasis on the upcoming 3-to-5 year period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of how the plan will incorporate existing marine, coastal, and estuarine research and management in the region, including activities pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of title 33","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1461"},"text":"section 1461 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a general description of marine research and monitoring objectives and timetables for achievement through the funding of projects under this chapter during the 4-year period covered by the plan so as to meet the priorities specified in the plan in accordance with paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369e28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan review and approval","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79369e29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When a Board has developed a marine research plan, including amendments thereto, the Board shall submit the plan to the Administrator of the National Oceanic and Atmospheric Administration and the Administration of the Environmental Protection Agency, who shall jointly determine whether the plan meets the requirements of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for approval or disapproval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the National Oceanic and Atmospheric Administration and the Administrator of the Environmental Protection Agency, shall jointly approve or disapprove such research plan within 120 days after receiving the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369e2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action after disapproval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of disapproval of such research plan, the Administrator of the National Oceanic and Atmospheric Administration and the Administrator of the Environmental Protection Agency shall jointly notify the appropriate Board in writing, stating in detail the revisions necessary to obtain approval of the plan. Such Administrators shall approve or disapprove the revised plan within 90 days after receiving the revised plan from the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79369e2c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tIV/s404"},"text":"Pub. L. 92–532, title IV, § 404","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/593/tIII/s301"},"text":"Pub. L. 101–593, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2966"},"text":"104 Stat. 2966","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79369e2d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79369e2e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79369e2f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Ocean Pollution Planning Act of 1978, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/273"},"text":"Pub. L. 95–273","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-05-08"},"text":"May 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/228"},"text":"92 Stat. 228","children":[],"tail":", which was classified generally to chapter 31 (§ 1701 et seq.) of Title 33, Navigation and Navigable Waters, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/102/567/tII/s204"},"text":"Pub. L. 102–567, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4282"},"text":"106 Stat. 4282","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
