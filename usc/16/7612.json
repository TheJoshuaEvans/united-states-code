{"tag":"section","attrib":{"id":"id7a29ff33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7612"},"text":null,"children":[{"tag":"num","attrib":{"value":"7612"},"text":"§ 7612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of United States policy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29ff34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7612/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take immediate actions to stop the illegal global trade in wildlife and wildlife products and associated transnational organized crime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7612/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide technical and other forms of assistance to help focus countries halt the poaching of elephants, rhinoceroses, and other imperiled species and end the illegal trade in wildlife and wildlife products, including by providing training and assistance in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a29ff36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7612/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wildlife protection and management of wildlife populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29ff37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7612/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anti-poaching and effective management of protected areas including community managed and privately-owned lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29ff38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7612/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local engagement of security forces in anti-poaching responsibilities, where appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29ff39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7612/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wildlife trafficking investigative techniques, including forensic tools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29ff3a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7612/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transparency and corruption issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29ff3b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7612/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management, tracking, and inventory of confiscated wildlife contraband;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29ff3c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7612/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demand reduction strategies in countries that lack the means and resources to conduct them; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29ff3d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7612/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bilateral and multilateral agreements and cooperation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7612/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to employ appropriate assets and resources of the United States Government in a coordinated manner to curtail poaching and disrupt and dismantle illegal wildlife trade networks and the financing of those networks in a manner appropriate for each focus country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7612/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to build upon the National Strategy and Implementation Plan to further combat wildlife trafficking in a holistic manner and guide the response of the United States Government to ensure progress in the fight against wildlife trafficking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7612/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recognize the ties of wildlife trafficking to broader forms of transnational organized criminal activities, including trafficking, and where applicable, to focus on those crimes in a coordinated, cross-cutting manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a29ff41-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/231/tI/s102"},"text":"Pub. L. 114–231, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"Oct. 7, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/951"},"text":"130 Stat. 951","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
