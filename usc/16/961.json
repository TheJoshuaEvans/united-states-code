{"tag":"section","attrib":{"id":"id78d9b0d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s961"},"text":null,"children":[{"tag":"num","attrib":{"value":"961"},"text":"§ 961.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There is hereby authorized to be appropriated from time to time, out of any moneys in the Treasury not otherwise appropriated, such sums as may be necessary to carry out the provisions of each convention and of this chapter, including—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78d9b0d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s961/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contributions to each commission for the United States share of any joint expenses of the commission and the expenses of the United States Commissioners and their staff, including personal services in the District of Columbia and elsewhere;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d9b0d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s961/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel expenses without regard to the Standardized Government Travel Regulations, as amended, subchapter I of chapter 57 of title 5, or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5731/a"},"text":"section 5731(a) of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d9b0d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s961/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" printing and binding without regard to ","children":[{"tag":"ref","a