{"tag":"section","attrib":{"id":"id7a1ba74f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6804a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6804a"},"text":"§ 6804a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of Federal, State, and local recreation passes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1ba750-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6804a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1ba751-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6804a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To improve the availability of Federal, State, and local outdoor recreation passes, the Secretaries are encouraged to coordinate with States and counties regarding the availability of Federal, State, and local recreation passes to allow a purchaser to buy a Federal recreation pass, State recreation pass, and local recreation pass in a single transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ba752-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6804a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Included passes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Passes covered by the program established under paragraph (1) include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1df043-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6804a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an America the Beautiful—the National Parks and Federal Recreational Lands Pass under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6804"},"text":"section 6804 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df044-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6804a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any pass covering any fees charged by participating States and counties for entrance and recreational use of parks and public land in the participating States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1df045-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6804a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements with States and counties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1df046-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6804a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries, after consultation with the States and counties, may enter into agreements with States and counties to coordinate the availability of passes as described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df047-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6804a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revenue from pass sales","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Agreements between the Secretaries, States, and counties entered into pursuant to this section shall ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1df048-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6804a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds from the sale of State or local passes are transferred to the appropriate State agency or county government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df049-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6804a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds from the sale of Federal passes are transferred to the appropriate Federal agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df04a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6804a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fund transfers are completed by the end of a fiscal year for all pass sales occurring during the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1df04b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dJ/tVIII/s805A"},"text":"Pub. L. 108–447, div. J, title VIII, § 805A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tIII/s321/a"},"text":"Pub. L. 118–234, title III, § 321(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2909"},"text":"138 Stat. 2909","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
