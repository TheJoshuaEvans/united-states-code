{"tag":"section","attrib":{"id":"id799ade44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2438"},"text":null,"children":[{"tag":"num","attrib":{"value":"2438"},"text":"§ 2438.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal offenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799ade45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2438/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person is guilty of an offense if that person commits any act prohibited by paragraph (4), (5), (6), or (7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2435"},"text":"section 2435 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799ade46-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2438/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Punishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any offense described in subsection (a) is punishable by a fine of $50,000, or imprisonment for not more than ten years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799ade47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2438/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses under other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A conviction under subsection (a) for any act shall not be deemed to preclude a conviction for such act under any other law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799ade48-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623/tIII/s309"},"text":"Pub. L. 98–623, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3403"},"text":"98 Stat. 3403","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
