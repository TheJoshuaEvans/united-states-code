{"tag":"section","attrib":{"id":"id7a3aa07d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8471"},"text":null,"children":[{"tag":"num","attrib":{"value":"8471"},"text":"§ 8471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa07e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8471/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accessible trail","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “accessible trail” means a trail that meets the requirements for a trail under the Architectural Barriers Act accessibility guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa07f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8471/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Architectural Barriers Act accessibility guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Architectural Barriers Act accessibility guidelines” means the accessibility guidelines set forth in appendices C and D to part 1191 of title 36, Code of Federal Regulations (or successor regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa080-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8471/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistive technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “assistive technology” means any item, piece of equipment, or product system, whether acquired commercially, modified, or customized, that is used to increase, maintain, or improve functional capabilities of individuals with disabilities, particularly with participating in outdoor recreation activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa081-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8471/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gold Star Family member","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Gold Star Family member” means an individual described in section 3.3 of Department of Defense Instruction 1348.36.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa082-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8471/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outdoor constructed feature","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “outdoor constructed feature” has the meaning given such term in appendix C to part 1191 of title 36, Code of Federal Regulations (or successor regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa083-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8471/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterans organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “veterans organization” means a service provider with outdoor recreation experience that serves members of the Armed Forces, veterans, or Gold Star Family members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3aa084-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tII/s201"},"text":"Pub. L. 118–234, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2880"},"text":"138 Stat. 2880","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
