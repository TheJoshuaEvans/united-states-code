{"tag":"section","attrib":{"id":"id784d00e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s580c"},"text":null,"children":[{"tag":"num","attrib":{"value":"580c"},"text":"§ 580c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchases of experimental materials, special devices, test models, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":" shall not apply to purchases by the Forest Service of (1) materials to be tested or upon which experiments are to be made or (2) special devices, test models, or parts thereof, to be used (a) for experimentation to determine their suitability for or adaptability to accomplishment of the work for which designed or (b) in the designing or developing of new equipment: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That not to exceed $50,000 may be expended in any one fiscal year pursuant to this authority and not to exceed $10,000 on any one item or purchase."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id784d00e4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-04-24/ch97/s3"},"text":"Apr. 24, 1950, ch. 97, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/83"},"text":"64 Stat. 83","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id784d00e5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id784d00e6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id784d00e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In text, “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"” substituted for “section 3709, Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"41 U.S.C. 5","children":[],"tail":"),” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
