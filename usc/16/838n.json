{"tag":"section","attrib":{"id":"id78c90f94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n"},"text":null,"children":[{"tag":"num","attrib":{"value":"838n"},"text":"§ 838n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Columbia Basin power management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78c90f95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78c90f96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Account” means the account established by subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c90f97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Bonneville Power Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c90f98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Canadian Entitlement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Canadian Entitlement” means the downstream power benefits that Canada is entitled to under Article V of the Treaty Relating to Cooperative Development of the Water Resources of the Columbia River Basin, signed at Washington ","children":[{"tag":"date","attrib":{"date":"1961-01-17"},"text":"January 17, 1961","children":[],"tail":" (15 UST 1555; TIAS 5638)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78c90f99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission coordination and expansion","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78c90f9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury an account for the purposes of making expenditures to increase bilateral transfers of renewable electric generation between the western United States and Canada.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c90f9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78c90f9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may make expenditures from the Account for activities to improve electric power system coordination by constructing electric power transmission facilities within the western United States that directly or indirectly facilitate non-carbon emitting electric power transactions between the western United States and Canada.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78c90f9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) shall be effective after the later of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78c90f9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2024-09-16"},"text":"September 16, 2024","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78c90f9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the Canadian entitlement value calculation is terminated or reduced to the actual electric power value to the United States, as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c90fa0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall consult with relevant electric utilities in Canada and appropriate regional transmission planning organizations in considering the construction of transmission activities under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c90fa1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Account a nonreimburseable amount equal to the aggregated amount of the Canadian Entitlement during the 5-year period preceding ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78c90fa2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increased hydroelectric capacity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78c90fa3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner of Reclamation shall rehabilitate and enhance the John W. Keys III Pump Generating Plant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78c90fa4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to replace obsolete equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78c90fa5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain reliability and improve efficiency in system performance and operation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78c90fa6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create more hydroelectric power capacity in the Pacific Northwest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78c90fa7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure the availability of water for irrigation in the event that Columbia River water flows from British Columbia into the United States are insufficient after ","children":[{"tag":"date","attrib":{"date":"2024-09-16"},"text":"September 16, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c90fa8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $100,000,000, which shall be nonreimburseable, to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78c90fa9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power coordination study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78c90faa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall conduct a study considering the potential hydroelectric power value to the Pacific Northwest of increasing the coordination of the operation of hydroelectric and water storage facilities on rivers located in the United States and Canada.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c90fab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study conducted under paragraph (1) shall analyze—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78c90fac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projected changes to the Pacific Northwest electricity supply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78c90fad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential reductions in greenhouse gas emissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78c90fae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any potential need to increase transmission capacity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78c90faf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other factor the Administrator considers to be relevant for increasing bilateral coordination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c90fb0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the study under paragraph (1), the Administrator shall coordinate, to the extent practicable, with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78c90fb1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ","children":[{"tag":"ref","attrib":{"idref":"fn002554"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002554"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “the” probably should not appear."}],"tail":" British Columbia or a crown corporation owned by British Columbia;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78c90fb2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78c90fb3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commissioner of Reclamation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78c90fb4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any public utility districts that operate hydroelectric projects on the mainstem of the Columbia River.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c90fb5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838n/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $10,000,000, which shall be nonreimburseable, to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78c90fb6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tI/s40113"},"text":"Pub. L. 117–58, div. D, title I, § 40113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/947"},"text":"135 Stat. 947","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78c90fb7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78c90fb8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78c90fb9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Infrastructure Investment and Jobs Act, and not as part of the Federal Columbia River Transmission System Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78c90fba-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78c90fbb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
