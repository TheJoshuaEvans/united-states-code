{"tag":"section","attrib":{"id":"id7a0adde7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415"},"text":null,"children":[{"tag":"num","attrib":{"value":"6415"},"text":"§ 6415.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0adde8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0adde9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alaska Native Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Alaska Native Corporation” has the meaning given the term “Native Corporation” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602"},"text":"section 1602 of title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0addea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate congressional committees” means the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Natural Resources of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0addeb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “conservation” means the use of methods and procedures necessary to preserve or sustain native corals and associated species as diverse, viable, and self-perpetuating coral reef ecosystems with minimal impacts from invasive species, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0addec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all activities associated with resource management, such as monitoring, assessment, protection, restoration, sustainable use, management of habitat, and maintenance or augmentation of genetic diversity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0added-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mapping;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0addee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific expertise and technical assistance in the development and implementation of management strategies for marine protected areas and marine resources required by Federal law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0addef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0addf0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conflict resolution initiatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0addf1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community outreach and education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0addf2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotion of safe and ecologically sound navigation and anchoring.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0addf3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coral","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “coral” means species of the phylum Cnidaria, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0addf4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all species of the orders Antipatharia (black corals), Scleractinia (stony corals), Alcyonacea (soft corals, organ pipe corals, gorgonians), and Helioporacea (blue coral), of the class Anthozoa; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0addf5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all species of the order Anthoathecata (fire corals and other hydrocorals) of the class Hydrozoa.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0addf6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coral products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “coral products” means any living or dead specimens, parts, or derivatives, or any product containing specimens, parts, or derivatives, of any species of coral.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0addf7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coral reef","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “coral reef” means calcium carbonate structures in the form of a reef or shoal, composed in whole or in part by living coral, skeletal remains of coral, crustose coralline algae, and other associated sessile marine plants and animals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0addf8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coral reef ecosystem","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “coral reef ecosystem” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0addf9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" corals and other geographically and ecologically associated marine communities of other reef organisms (including reef plants and animals) associated with coral reef habitat; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0addfa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the biotic and abiotic factors and processes that control or significantly affect coral calcification rates, tissue growth, reproduction, recruitment, abundance, coral-algal symbiosis, and biodiversity in such habitat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0addfb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coral reef ecosystem services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “coral reef ecosystem services” means the attributes and benefits provided by coral reef ecosystems including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0addfc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection of coastal beaches, structures, and infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0addfd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" habitat for organisms of economic, ecological, biomedical, medicinal, and cultural value;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0addfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving as centers for the promulgation, performance, and training of cultural practices representative of traditional ecological knowledge; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0addff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aesthetic value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered Native entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered Native entity” means a Native entity with interests in a coral reef ecosystem.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered reef manager","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered reef manager” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0ade02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a management unit of a covered State with jurisdiction over a coral reef ecosystem;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a covered State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a coral reef stewardship partnership under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6405"},"text":"section 6405 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered State” means Florida, Hawaii, and the territories of American Samoa, the Commonwealth of the Northern Mariana Islands, Guam, Puerto Rico, and the United States Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal reef manager","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0ade07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal reef manager” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a0ade08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/13/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a management unit of a Federal agency specified in subparagraph (B) with lead management jurisdiction over a coral reef ecosystem; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0ade09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/13/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a coral reef stewardship partnership under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6405/c"},"text":"section 6405(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agencies specified","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Federal agency specified in this subparagraph is one of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a0ade0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/13/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0ade0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/13/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Park Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0ade0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/13/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Fish and Wildlife Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0ade0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/13/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Insular Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interested stakeholder groups","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “interested stakeholder groups” means any of the following with interest in an applicable coral reef or ecologically significant unit of a coral reef:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0ade11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A commercial or recreational fisherman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/15/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A recreationalist.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/15/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Federal, State, Tribal, or local government unit with related jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/15/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An institution of higher education (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"section 1001(a) of title 20","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002824"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002824"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. A closing parenthesis probably should precede the period."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/15/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nongovernmental organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Coral Reef Resilience Strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Coral Reef Resilience Strategy” means the National Coral Reef Resilience Strategy in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6403"},"text":"section 6403 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Native entity” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0ade19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/17/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Indian Tribe (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/17/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Alaska Native Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/17/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Hawaiian Home Lands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/17/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Hawaiian Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/17/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Native Hawaiian organization (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7517"},"text":"section 7517 of title 20","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “nonprofit organization” means any corporation, trust, association, cooperative, or other organization, not including an institution of higher education, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0ade1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/18/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is operated primarily for scientific, educational, service, charitable, or similar purposes in the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/18/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not organized primarily for profit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/18/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses net proceeds to maintain, improve, or expand the operations of the organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “restoration” means the use of methods and procedures necessary to enhance, rehabilitate, recreate, or create a functioning coral reef or coral reef ecosystem, in whole or in part, within suitable waters of the historical geographic range of such ecosystems, to provide ecological, economic, cultural, or coastal resiliency services associated with healthy coral reefs and benefit native populations of coral reef organisms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resilience","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “resilience” means the capacity for corals within their native range, coral reefs, or coral reef ecosystems to resist and recover from natural and human disturbances, and maintain structure and function to provide coral reef ecosystem services, as determined by clearly identifiable, measurable, and science-based standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0ade26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/22/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State of the United States that contains a coral reef ecosystem within its seaward boundaries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/22/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" American Samoa, the Commonwealth of the Northern Mariana Islands, Guam, Puerto Rico, or the United States Virgin Islands; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/22/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other territory or possession of the United States or separate sovereign in free association with the United States that contains a coral reef ecosystem within its seaward boundaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stewardship","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “stewardship”, with respect to a coral reef, includes conservation, restoration, and public outreach and education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6415/24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"(24)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task Force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Task Force” means the United States Coral Reef Task Force established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6451"},"text":"section 6451 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0ade2b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s216"},"text":"Pub. L. 106–562, title II, § 216","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/a"},"text":"Pub. L. 117–263, div. J, title C, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3948"},"text":"136 Stat. 3948","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
