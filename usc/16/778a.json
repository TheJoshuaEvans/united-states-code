{"tag":"section","attrib":{"id":"id789bbd9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s778a"},"text":null,"children":[{"tag":"num","attrib":{"value":"778a"},"text":"§ 778a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of lands; construction of buildings; employment of personnel; cooperation with other agencies; publication of results","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out the provisions of this chapter, the Secretary of Agriculture is authorized (1) to acquire by purchase, condemnation, or otherwise such suitable lands, to construct such buildings, to acquire such equipment and apparatus, and to employ such officers and employees as he deems necessary; (2) to cooperate with State and other institutions and agencies upon such terms and conditions as he determines to be appropriate; and (3) to make public the results of such research and experiments conducted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s778"},"text":"section 778 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id789bbd9d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/342/s2"},"text":"Pub. L. 85–342, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-03-15"},"text":"Mar. 15, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/35"},"text":"72 Stat. 35","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s889/a/2"},"text":"Pub. L. 104–127, title VIII, § 889(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1180"},"text":"110 Stat. 1180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id789bbd9e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id789bbd9f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id789bbda0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" substituted “the Secretary of Agriculture is authorized” for “the Secretary of the Interior is authorized”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
