{"tag":"section","attrib":{"id":"id789bbda1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s778b"},"text":null,"children":[{"tag":"num","attrib":{"value":"778b"},"text":"§ 778b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with Secretary of the Interior","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to cooperate in carrying out the provisions of this chapter by furnishing such information and assistance as may be requested by the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id789bbda2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/342/s3"},"text":"Pub. L. 85–342, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-03-15"},"text":"Mar. 15, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/35"},"text":"72 Stat. 35","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s889/a/3"},"text":"Pub. L. 104–127, title VIII, § 889(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1180"},"text":"110 Stat. 1180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id789bbda3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id789bbda4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id789bbda5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" substituted “the Secretary of the Interior” for “The Department of Agriculture” and “requested by the Secretary of Agriculture” for “requested by the Secretary of the Interior”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
