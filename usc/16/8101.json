{"tag":"section","attrib":{"id":"id7a33744e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8101"},"text":null,"children":[{"tag":"num","attrib":{"value":"8101"},"text":"§ 8101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a33744f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a337450-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wetlands, tidal marshes, and agricultural lands provide significant cultural, economic, and ecological benefits to the Nation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a337451-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The South American nutria (Myocastor coypus) is directly contributing to substantial marsh loss on Federal, State, and private land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a337452-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8101/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Traditional harvest methods to control or eradicate nutria have failed. Consequently, marsh loss, loss of public and private wetlands, and loss of agricultural lands are accelerating.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a337453-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8101/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The nutria eradication and control pilot program authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/322"},"text":"Public Law 105–322","children":[],"tail":" is to develop new and effective methods for eradication of nutria."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a337454-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this chapter is to authorize the Secretary of the Interior to provide financial assistance to any State that has demonstrated the need for a program to implement measures to eradicate or control nutria and restore marshland damaged by nutria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a337455-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/16/s2"},"text":"Pub. L. 108–16, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-23"},"text":"Apr. 23, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/621"},"text":"117 Stat. 621","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/186/s1/1"},"text":"Pub. L. 116–186, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/901"},"text":"134 Stat. 901","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a337456-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a337457-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a337458-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/322"},"text":"Public Law 105–322","children":[],"tail":", referred to in subsec. (a)(4), is "},{"tag":"ref","attrib":{"href":"/us/pl/105/322"},"text":"Pub. L. 105–322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3027"},"text":"112 Stat. 3027","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/16"},"text":"Pub. L. 108–16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-23"},"text":"Apr. 23, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/621"},"text":"117 Stat. 621","children":[],"tail":", known as the Nutria Eradication and Control Act of 2003, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a337459-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/186/s1/1/A/i"},"text":"Pub. L. 116–186, § 1(1)(A)(i)","children":[],"tail":", substituted “Wetlands, tidal marshes, and agricultural lands” for “Wetlands and tidal marshes of the Chesapeake Bay and in Louisiana”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/186/s1/1/A/ii"},"text":"Pub. L. 116–186, § 1(1)(A)(ii)","children":[],"tail":", struck out “in Maryland and Louisiana” after “substantial marsh loss”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/186/s1/1/A/iii"},"text":"Pub. L. 116–186, § 1(1)(A)(iii)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “Traditional harvest methods to control or eradicate nutria have failed in Maryland and have had limited success in the eradication of nutria in Louisiana. Consequently, marsh loss is accelerating.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/186/s1/1/B"},"text":"Pub. L. 116–186, § 1(1)(B)","children":[],"tail":", substituted “any State that has demonstrated the need” for “the State of Maryland and the State of Louisiana”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a33745a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a33745b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/16/s1"},"text":"Pub. L. 108–16, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-23"},"text":"Apr. 23, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/621"},"text":"117 Stat. 621","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/16/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Nutria Eradication and Control Act of 2003’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
