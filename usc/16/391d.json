{"tag":"section","attrib":{"id":"id77313126-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s391d"},"text":null,"children":[{"tag":"num","attrib":{"value":"391d"},"text":"§ 391d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change in name of part of Hawaii National Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1961-09-22"},"text":"September 22, 1961","children":[],"tail":", the portion of the Hawaii National Park situated on the island of Hawaii, established and administered pursuant to sections 391, 393, and 394 of this title, as amended and supplemented, shall be known as the Hawaiʻi Volcanoes National Park."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77313127-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/278"},"text":"Pub. L. 87–278","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-22"},"text":"Sept. 22, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/577"},"text":"75 Stat. 577","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/510/s3/a/1"},"text":"Pub. L. 106–510, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2363"},"text":"114 Stat. 2363","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77313128-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77313129-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7731312a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/510"},"text":"Pub. L. 106–510","children":[],"tail":" substituted “Hawaiʻi Volcanoes National Park” for “Hawaii Volcanoes National Park”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7731312b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7731312c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/510/s3/a/2"},"text":"Pub. L. 106–510, § 3(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2363"},"text":"114 Stat. 2363","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/510/s3/a/2"},"text":"“Any reference in any law (other than this Act [see Tables for classification]), regulation, document, record, map, or other paper of the United States to ‘Hawaii Volcanoes National Park’ shall be considered a reference to ‘Hawaiʻi Volcanoes National Park’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
