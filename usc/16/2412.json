{"tag":"section","attrib":{"id":"id799adddd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2412"},"text":null,"children":[{"tag":"num","attrib":{"value":"2412"},"text":"§ 2412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to existing treaties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed as contravening or superseding the provisions of any international treaty, convention, or agreement, if such treaty, convention, or agreement is in force with respect to the United States on ","children":[{"tag":"date","attrib":{"date":"1978-10-28"},"text":"October 28, 1978","children":[],"tail":", or of any statute which implements any such treaty, convention, or agreement."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id799addde-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/541/s13"},"text":"Pub. L. 95–541, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-28"},"text":"Oct. 28, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2056"},"text":"92 Stat. 2056","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
