{"tag":"section","attrib":{"id":"id78e34d9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1012a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1012a"},"text":"§ 1012a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to any other funds made available by this chapter, of the funds of the Commodity Credit Corporation, the Secretary shall make available to carry out this chapter $150,000,000 for fiscal year 2026 and each fiscal year thereafter, to remain available until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78e34d9c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-04/ch656/s15"},"text":"Aug. 4, 1954, ch. 656, § 15","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2401/c"},"text":"Pub. L. 115–334, title II, § 2401(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4570"},"text":"132 Stat. 4570","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10601/e"},"text":"Pub. L. 119–21, title I, § 10601(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/108"},"text":"139 Stat. 108","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78e34d9d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78e34d9e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78e34d9f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “$150,000,000 for fiscal year 2026 and each fiscal year thereafter, to remain available until expended” for “$50,000,000 for fiscal year 2019 and each fiscal year thereafter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
