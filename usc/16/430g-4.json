{"tag":"section","attrib":{"id":"id7793003a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"430g–4"},"text":"§ 430g–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gettysburg National Military Park boundary revision","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7793003b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands included in park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In furtherance of the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s430g"},"text":"section 430g of this title","children":[],"tail":", the Gettysburg National Military Park (hereafter in sections 430g–4 to 430g–10 of this title referred to as the “park”) shall on and after "},{"tag":"date","attrib":{"date":"1990-08-17"},"text":"August 17, 1990","children":[],"tail":", comprise the lands and interests in lands within the bound­ary generally depicted as “Park Boundary” on the map entitled “Gettysburg National Military Park Boundary Map”, numbered NPS 305/80034–B, and dated March 1990, which shall be on file and available for public inspection in the Office of the Director of the National Park Service, Department of the Interior."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7793003c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the land identified in subsection (a), the park shall also include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7793003d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property commonly known as the Wills House located in the Borough of Gettysburg and identified as Tract P02–1 on the map entitled “Gettysburg National Military Park” numbered MARO 305/80,011 Segment 2, and dated April 1981, revised ","children":[{"tag":"date","attrib":{"date":"1999-05-14"},"text":"May 14, 1999","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7793003e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the properties depicted as “Proposed Addition” on the map entitled “Gettysburg National Military Park Proposed Boundary Addition”, numbered 305/80,045, and dated January, 2010 (2 sheets), including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7793003f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–4/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property commonly known as the “Gettysburg Train Station”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77930040-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–4/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property located adjacent to Plum Run in Cumberland Township.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77930041-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands excluded from park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Lands and interests in lands outside of the boundary so depicted as “Park Boundary” on the maps referred to in subsections (a) and (b) are hereby excluded from the park and shall be disposed of in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s430g–5/c"},"text":"section 430g–5(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77930042-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/377/s1"},"text":"Pub. L. 101–377, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-17"},"text":"Aug. 17, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/464"},"text":"104 Stat. 464","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/290/s1"},"text":"Pub. L. 106–290, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-10"},"text":"Oct. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/921"},"text":"114 Stat. 921","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXX/s3034/a"},"text":"Pub. L. 113–291, div. B, title XXX, § 3034(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3777"},"text":"128 Stat. 3777","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77930043-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77930044-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77930045-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “include—” for “include”, designated remainder of existing provisions as par. (1), substituted “; and” for period at end, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/290/s1/2"},"text":"Pub. L. 106–290, § 1(2)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/290/s1/1"},"text":"Pub. L. 106–290, § 1(1)","children":[],"tail":", (3), redesignated subsec. (b) as (c) and substituted “maps referred to in subsections (a) and (b)” for “map referred to in subsection (a)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
