{"tag":"section","attrib":{"id":"id77e677cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ss–5"},"text":"§ 460ss–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77e677d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Department of the Interior during the period beginning ","children":[{"tag":"date","attrib":{"date":"1986-10-01"},"text":"October 1, 1986","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2006-09-30"},"text":"September 30, 2006","children":[],"tail":", $21,000,000 for the design, construction, operation, and maintenance of the program and for the payment of travel expenses under sections 460ss–2(j) and 460ss–3(i) of this title. Monies appropriated under this subsection shall remain available until expended or "},{"tag":"date","attrib":{"date":"2006-10-01"},"text":"October 1, 2006","children":[],"tail":", whichever first occurs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e677d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e677d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the cost of the development and implementation of the program must be provided by one or more non-Federal sources on a basis considered by the Secretary to be timely and appropriate. For purposes of this subsection, the term “non-Federal source” includes a State or local government, any private entity, and any individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to cash outlays, the Secretary shall consider as financial contributions by a non-Federal source the value of inkind contributions and real and personal property provided by the source for purposes of implementing the program. Valuations made by the Secretary under this paragraph are final and not subject to judicial review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–5/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraph (2), inkind contributions may be in the form of, but are not limited to, personal services rendered by volunteers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–5/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall by regulation establish—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e677d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–5/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training, experience, and other qualifications which such volunteers must have in order for their services to be considered as inkind contributions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e677d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–5/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the standards under which the Secretary will determine the value of inkind contributions and real and personal property for purposes of paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–5/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not consider the expenditure, either directly or indirectly, with respect to the program of Federal moneys received by a State or local government to be a financial contribution by a non-Federal source to carry out the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77e677d9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/552/s6"},"text":"Pub. L. 99–552, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3085"},"text":"100 Stat. 3085","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/653/tVI/s603/3"},"text":"Pub. L. 100–653, title VI, § 603(3)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1988-11-14"},"text":"Nov. 14, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3830"},"text":"102 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77e677da-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77e677db-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77e677dc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/653/s603/3"},"text":"Pub. L. 100–653, § 603(3)","children":[],"tail":", inserted “and for the payment of travel expenses under sections 460ss–2(j) and 460ss–3(i) of this title” before period at end of first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/653/s603/4"},"text":"Pub. L. 100–653, § 603(4)","children":[],"tail":", struck out “in carrying out surveys, censuses, and other scientific studies” after “volunteers”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
