{"tag":"section","attrib":{"id":"id7778c09b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410nnn–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"410nnn–4"},"text":"§ 410nnn–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In furtherance of the purposes of this subchapter, the Secretary is authorized to enter into cooperative agreements with the United States of Mexico, in accordance with existing international agreements, and with other owners of Mexican-American War properties within the United States of America for the purposes of conducting joint research and interpretive planning for the historical park and related Mexican-American War sites. Interpretive information and programs shall reflect historical data and perspectives of both countries and the series of historical events associated with the Mexican-American War.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7778c09c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/304/s6"},"text":"Pub. L. 102–304, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-06-23"},"text":"June 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/257"},"text":"106 Stat. 257","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7113/a/3/C"},"text":"Pub. L. 111–11, title VII, § 7113(a)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1202"},"text":"123 Stat. 1202","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7778c09d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7778c09e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7778c09f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":" substituted “historical park” for “historic site”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
