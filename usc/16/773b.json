{"tag":"section","attrib":{"id":"id789491bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773b"},"text":null,"children":[{"tag":"num","attrib":{"value":"773b"},"text":"§ 773b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance or rejection of Commission recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State, with the concurrence of the Secretary, may accept or reject, on behalf of the United States, recommendations made by the Commission in accordance with article III of the Convention and paragraphs 14 and 15 of the annex to the Convention.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id789491c0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/176/s4"},"text":"Pub. L. 97–176, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-05-17"},"text":"May 17, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/79"},"text":"96 Stat. 79","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
