{"tag":"section","attrib":{"id":"id77f71914-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"460hhh–3"},"text":"§ 460hhh–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77f71915-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Chief of the Forest Service, shall manage the Recreation Area in accordance with the laws, rules, and regulations pertaining to the National Forest System and this subchapter to provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77f71916-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conservation of scenic, scientific, historic, cultural, and other values contributing to public enjoyment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f71917-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conservation of fish and wildlife populations and habitat, including the use of prescribed fire to improve or maintain habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f71918-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of watersheds and the maintenance of free flowing streams and the quality of ground and surface waters in accordance with applicable law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f71919-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–3/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public outdoor recreation benefits, including, but not limited to, hunting, fishing, trapping, hiking, horseback riding, backpacking, rock climbing, camping, and nature study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f7191a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–3/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wilderness areas as designated by Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f7191b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–3/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management and use of natural resources in a manner compatible with the purposes for which the Recreation Area is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f7191c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting, trapping, and fishing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77f7191d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary shall permit hunting, trapping, fishing, and habitat management within the Recreation Area in accordance with the laws of the United States and the State of Nevada.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f7191e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Nevada Department of Wildlife, may designate zones where and periods when hunting, trapping, or fishing shall not be permitted for reasons of public safety, administration, or public use and enjoyment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f7191f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The grazing of livestock on Federal lands may be permitted to continue pursuant to Federal law and subject to such reasonable regulations, policies, and practices as the Secretary considers necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f71920-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preventive measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall preclude such reasonable measures as the Secretary considers necessary to protect the land and resources from fire or insect or disease infestation in the Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77f71921-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/63/s5"},"text":"Pub. L. 103–63, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-04"},"text":"Aug. 4, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/298"},"text":"107 Stat. 298","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
