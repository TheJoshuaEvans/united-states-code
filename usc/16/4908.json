{"tag":"section","attrib":{"id":"id79f7cbb7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4908"},"text":null,"children":[{"tag":"num","attrib":{"value":"4908"},"text":"§ 4908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Call for information","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Within one month after ","children":[{"tag":"date","attrib":{"date":"1992-10-23"},"text":"October 23, 1992","children":[],"tail":", the Secretary shall issue a call for information on the wild bird conservation program of each country that exports exotic birds, by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cbb8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4908/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publishing a notice in the Federal Register requesting submission of such information to the Secretary by all interested persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cbb9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4908/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitting a written request for such information through the Secretary of State to each country that exports exotic birds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f7cbba-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tI/s109"},"text":"Pub. L. 102–440, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2229"},"text":"106 Stat. 2229","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
