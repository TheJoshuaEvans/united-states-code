{"tag":"section","attrib":{"id":"id7797ba51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430kk"},"text":null,"children":[{"tag":"num","attrib":{"value":"430kk"},"text":"§ 430kk.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wilson’s Creek National Battlefield: establishment and acquisition of lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7797ba52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430kk/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment, initial boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall acquire, by gift, purchase, condemnation, or otherwise, the lands (together with any improvements thereon) comprising the Wilson’s Creek Battlefield site near Springfield, Missouri, and any other lands adjacent to such site which in his opinion are necessary or desirable to carry out the purposes of sections 430kk to 430mm of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7797ba53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430kk/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of boundaries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7797ba54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430kk/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional land","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7797ba55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430kk/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The boundaries of the Wilson’s Creek National Battlefield are revised to include lands and interests therein consisting of six parcels totaling 615 acres and identified as parcels “1, 2, 3, 4, 5, and 6” on the map entitled “Wilson’s Creek National Battlefield Proposed Boundary”, numbered 410/80,037 and dated ","children":[{"tag":"date","attrib":{"date":"2004-01-27"},"text":"January 27, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7797ba56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430kk/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Newtonia Battlefield addition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The boundary of the Wilson’s Creek National Battlefield is revised to include the approximately 25 acres of land identified as “Proposed Addition” on the map entitled “Wilson’s Creek National Battlefield Proposed Boundary Modification”, numbered 410/177,379, and dated July 2022.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7797ba57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430kk/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of maps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maps described in subparagraphs (A) and (B) shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7797ba58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430kk/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Errors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior may correct any clerical or typographical error in a map described in subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7797ba59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430kk/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of acquisition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior may acquire the land described in subparagraphs (A) and (B) of paragraph (1) by donation, by purchase from willing sellers with donated or appropriated funds, or by exchange. The Secretary may acquire by the same methods personal property associated with, and appropriate for, interpretation of Wilson’s Creek National Battlefield.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7797ba5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430kk/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to private property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in sections 430kk to 430mm of this title shall be construed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7797ba5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430kk/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require any private property owner to allow public access (including Federal, State, or local government access) to such private property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7797ba5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430kk/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modify any provision of Federal, State, or local law with regard to public access to or use of private property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7797ba5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430kk/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The revision of the boundaries of the Wilson’s Creek National Battlefield by subsection (b) shall not be considered to create any liability for, or to have any effect on any liability under any other law of, any owner of private property with respect to any person injured on that private property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7797ba5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430kk/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition of authority to control land use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in sections 430kk to 430mm of this title shall be construed to modify the authority of Federal, State, or local governments to regulate land use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7797ba5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430kk/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of private property owners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in sections 430kk to 430mm of this title shall be construed to require the owner of any private property located within the boundaries of the Wilson’s Creek National Battlefield to participate in, or be associated with, the National Battlefield.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7797ba60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430kk/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of expansion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The boundaries of the Wilson’s Creek National Battlefield, as revised by subsection (b), represent the area within which Federal funds appropriated for the purpose of sections 430kk to 430mm of this title may be expended. The boundary revision shall not be construed to provide any nonexisting regulatory authority on land use within the National Battlefield or its viewshed by the Secretary or the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7797ba61-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/434/s1"},"text":"Pub. L. 86–434, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-04-22"},"text":"Apr. 22, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/76"},"text":"74 Stat. 76","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/394/s2/a"},"text":"Pub. L. 108–394, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2247"},"text":"118 Stat. 2247","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tVI/s616"},"text":"Pub. L. 117–328, div. DD, title VI, § 616","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5604"},"text":"136 Stat. 5604","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7797ba62-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7797ba63-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7797ba64-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s616/1"},"text":"Pub. L. 117–328, § 616(1)","children":[],"tail":", inserted par. heading; designated first sentence as subpar. (A) and inserted heading; designated second sentence as subpar. (C), inserted heading, and substituted “The maps described in subparagraphs (A) and (B)” for “The map”; and added subpars. (B) and (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s616/2"},"text":"Pub. L. 117–328, § 616(2)","children":[],"tail":", inserted heading and substituted “The Secretary of the Interior may acquire the land described in subparagraphs (A) and (B) of paragraph (1)” for “The Secretary is authorized to acquire the lands referred to in paragraph (1)” in first sentence and “Wilson’s Creek National Battlefield” for “the park” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/394"},"text":"Pub. L. 108–394","children":[],"tail":" inserted section catchline, designated existing provisions as subsec. (a), inserted heading, and added subsecs. (b) to (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7797ba65-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7797ba66-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/394/s1"},"text":"Pub. L. 108–394, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2247"},"text":"118 Stat. 2247","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/394/s1"},"text":"“This Act [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s430mm"},"text":"section 430mm of this title","children":[],"tail":"] may be cited as the ‘Wilson’s Creek National Battlefield Boundary Adjustment Act of 2004’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
