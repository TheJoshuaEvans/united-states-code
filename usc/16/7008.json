{"tag":"section","attrib":{"id":"id7a22d258-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7008"},"text":null,"children":[{"tag":"num","attrib":{"value":"7008"},"text":"§ 7008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative matters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a22d259-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7008/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Individuals appointed under section 7002, 7003, 7004, or 7005 of this title, other than officers or employees of the United States Government, shall not be considered to be Federal employees while performing such service, except for purposes of injury compensation or tort claims liability as provided in chapter 81 of title 5 and chapter 171 of title 28.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a22d25a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7008/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a22d25b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7008/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), an individual appointed under this chapter shall receive no compensation for the individual’s service as a representative, alternate representative, scientific expert, or advisory panel member under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d25c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7008/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific review group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), the Secretary may employ and fix the compensation of an individual appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7003/a"},"text":"section 7003(a) of this title","children":[],"tail":" to serve as a scientific expert on the scientific review group who is not employed by the United States Government, a State government, or an Indian tribal government in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a22d25d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7008/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (d), the Secretary shall pay the necessary travel expenses of individuals appointed under this chapter in accordance with the Federal Travel Regulations and sections 5701, 5702, 5704 through 5708, and 5731 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a22d25e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7008/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint appointees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the 2 independent members of the scientific review group and the 2 public advisors to the scientific review group jointly appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7003/c"},"text":"section 7003(c) of this title","children":[],"tail":", and the 1 independent member to the joint technical committee jointly appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7004/b"},"text":"section 7004(b) of this title","children":[],"tail":", the Secretary may pay up to 50 percent of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a22d25f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7008/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any compensation paid to such individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d260-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7008/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the necessary travel expenses of such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a22d261-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479/tVI/s609"},"text":"Pub. L. 109–479, title VI, § 609","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3647"},"text":"120 Stat. 3647","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/348/tIII/s302/b"},"text":"Pub. L. 111–348, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3672"},"text":"124 Stat. 3672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a22d262-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a22d263-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a22d264-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/348"},"text":"Pub. L. 111–348","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “Individuals appointed under section 7002, 7003, 7004, or 7005 of this title who are serving as such Commissioners, other than officers or employees of the United States Government, shall be considered to be Federal employees while performing such service, only for purposes of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) injury compensation under chapter 81 of title 5;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) requirements concerning ethics, conflicts of interest, and corruption as provided under title 18; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) any other criminal or civil statute or regulation governing the conduct of Federal employees.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
