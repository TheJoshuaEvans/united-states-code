{"tag":"section","attrib":{"id":"id78759807-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s676"},"text":null,"children":[{"tag":"num","attrib":{"value":"676"},"text":"§ 676.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting, trapping, killing, or capturing game on Norbeck Wildlife Preserve unlawful","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When such areas have been designated as provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s675"},"text":"section 675 of this title","children":[],"tail":", hunting, trapping, killing, or capturing of game animals and birds upon the lands of the United States within the limits of said areas shall be unlawful, except under such regulations as may be prescribed from time to time by the Secretary of Agriculture. It is the purpose of this section to protect from trespass the public lands of the United States and the game animals and birds which may be thereon, and not to interfere with the operation of the local game laws as affecting private or State lands."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78759808-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-05/ch247"},"text":"June 5, 1920, ch. 247","children":[],"tail":", §§ 2, 3, "},{"tag":"ref","attrib":{"href":"/us/stat/41/986"},"text":"41 Stat. 986","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645/s11"},"text":"June 25, 1948, ch. 645, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/860"},"text":"62 Stat. 860","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78759809-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7875980a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7875980b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"First sentence of section is from section 2 and the last from section 3 of act ","children":[{"tag":"date","attrib":{"date":"1920-06-05"},"text":"June 5, 1920","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7875980c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1948—Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", struck out penal provisions. See "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s41"},"text":"section 41 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7875980d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7875980e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1948 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 20 of act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", provided that the amendment made by that act is effective "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":"."}],"tail":"\n"}],"tail":"