{"tag":"section","attrib":{"id":"id777194c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"410fff–9"},"text":"§ 410fff–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of lands within and adjacent to Curecanti National Recreation Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id777194c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"1999-10-21"},"text":"October 21, 1999","children":[],"tail":", the Secretary, acting through the Director of the National Park Service, shall conduct a study concerning land protection and open space within and adjacent to the area administered as the Curecanti National Recreation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777194c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study required to be completed under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777194c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the natural, cultural, recreational and scenic resource value and character of the land within and surrounding the Curecanti National Recreation Area (including open vistas, wildlife habitat, and other public benefits);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777194c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify practicable alternatives that protect the resource value and character of the land within and surrounding the Curecanti National Recreation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777194c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend a variety of economically feasible and viable tools to achieve the purposes described in paragraphs (1) and (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777194c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimate the costs of implementing the approaches recommended by the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777194ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years from ","children":[{"tag":"date","attrib":{"date":"1999-10-21"},"text":"October 21, 1999","children":[],"tail":", the Secretary shall submit a report to Congress that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id777194cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains the findings of the study required by subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777194cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes recommendations to Congress with respect to the findings of the study required by subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777194cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes recommendations to Congress regarding action that may be taken with respect to the land described in the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777194ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of additional land and interests in land","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777194cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to the completion of the study required by subsection (a), the Secretary may acquire certain private land or interests in land as depicted on the Map entitled “Proposed Additions to the Curecanti National Recreation Area”, dated 01/25/99, totaling approximately 1,065 acres and entitled “Hall and Fitti properties”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777194d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of acquisition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777194d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Land or an interest in land under paragraph (1) may be acquired by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777194d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777194d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase with donated or appropriated funds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777194d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777194d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No land or interest in land may be acquired without the consent of the owner of the land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777194d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary revisions following acquisition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Following the acquisition of land under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777194d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revise the boundary of the Curecanti National Recreation Area to include newly-acquired land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777194d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–9/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer newly-acquired land according to applicable laws (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777194d9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/76/s11"},"text":"Pub. L. 106–76, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-21"},"text":"Oct. 21, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1131"},"text":"113 Stat. 1131","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
