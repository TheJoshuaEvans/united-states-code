{"tag":"section","attrib":{"id":"id77fbfad8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–22"},"text":"§ 460lll–22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fbfad9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the date of transfer pursuant to section 460","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–41 of this title, the Secretary shall establish the Land Between the Lakes Advisory Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfada-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Board shall be composed of 13 members, of whom—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfadb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 4 individuals shall be appointed by the Secretary, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77fbfadc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 residents of the State of Kentucky; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fbfadd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 residents of the State of Tennessee;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfade-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 individuals shall be appointed by the Kentucky Fish and Wildlife Commissioner or designee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfadf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 individual shall be appointed by the Tennessee Fish and Wildlife Commission or designee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfae0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 individuals shall be appointed by appropriate officials of each of the 3 counties containing the Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfae1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfae2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of a member of the Advisory Board shall be 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfae3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonconsecutive terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Advisory Board may serve multiple terms, but may not serve consecutive terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfae4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Regional Forester shall serve as chairperson of the Advisory Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfae5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe the rules of procedure for the Advisory Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfae6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Board shall advise the Secretary on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfae7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means of promoting public participation for the land and resource management plan for the Recreation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfae8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfae9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual work plan for recreation and environment education areas in the Recreation Area, including the heritage program, with the nonappropriated amounts in the Land Between the Lakes Management Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfaea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual forest management and harvest plan for the Recreation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfaeb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Land Between the Lakes Management Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfaec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfaed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Board shall meet at least twice each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfaee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A meeting of the Advisory Board shall be open to the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfaef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chairperson, through the placement of notices in local news media, on a public website of the Department of Agriculture, and by other appropriate means shall give 2 weeks’ public notice of each meeting of the Advisory Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfaf0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minutes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish the minutes of each meeting of the Advisory Board on a public website of the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfaf1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–22/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/a"},"text":"Section 1013(a) of title 5","children":[],"tail":" shall not apply to the Advisory Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fbfaf2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s522"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 522]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–314; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/94"},"text":"Pub. L. 117–286, § 4(a)(94)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4316"},"text":"136 Stat. 4316","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tII/s201/c"},"text":"Pub. L. 117–328, div. DD, title II, § 201(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5582"},"text":"136 Stat. 5582","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77fbfaf3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77fbfaf4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77fbfaf5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s201/c/1/A"},"text":"Pub. L. 117–328, § 201(c)(1)(A)","children":[],"tail":", substituted “13” for “17” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s201/c/1/B"},"text":"Pub. L. 117–328, § 201(c)(1)(B)","children":[],"tail":"–(D), redesignated par. (6) as (4) and struck out former par. (4) which read as follows: “2 individuals shall be appointed by the Governor of the State of Tennessee;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s201/c/1/B"},"text":"Pub. L. 117–328, § 201(c)(1)(B)","children":[],"tail":", struck out par. (5) which read as follows: “2 individuals shall be appointed by the Governor of the State of Kentucky; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s201/c/1/D"},"text":"Pub. L. 117–328, § 201(c)(1)(D)","children":[],"tail":", redesignated par. (6) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s201/c/2"},"text":"Pub. L. 117–328, § 201(c)(2)","children":[],"tail":", added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “Members of the Advisory Board may not succeed themselves.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s201/c/3/A"},"text":"Pub. L. 117–328, § 201(c)(3)(A)","children":[],"tail":", substituted “shall advise” for “may advise” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s201/c/3/B"},"text":"Pub. L. 117–328, § 201(c)(3)(B)","children":[],"tail":"–(D), added pars. (3) to (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s201/c/4/A"},"text":"Pub. L. 117–328, § 201(c)(4)(A)","children":[],"tail":", substituted “twice each year” for “biannually”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s201/c/4/B"},"text":"Pub. L. 117–328, § 201(c)(4)(B)","children":[],"tail":", inserted “, on a public website of the Department of Agriculture,” before “and by”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s201/c/4/C"},"text":"Pub. L. 117–328, § 201(c)(4)(C)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/a"},"text":"Section 1013(a) of title 5","children":[],"tail":"” for “Section 14(a)(2) of the Federal Advisory Committee Act (5 U.S.C. App.)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
