{"tag":"section","attrib":{"id":"id77740663-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"410iii–11"},"text":"§ 410iii–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Roles of key partner organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77740664-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In recognition that central portions of the Park are presently owned and operated for the benefit of the public by key partner organizations, the Secretary shall acknowledge and support the continued participation of these partner organizations in the management of the Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77740665-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Park partners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Roles of the current key partners include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77740666-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–11/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cedar Creek Battlefield Foundation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Cedar Creek Battlefield Foundation may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77740667-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–11/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to own, operate, and manage the lands acquired by the Foundation within the Park;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77740668-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–11/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to conduct reenactments and other events within the Park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77740669-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–11/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer ownership interest in portions of their land to the National Park Service by donation, sale, or other means that meet the legal requirements of National Park Service land acquisitions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7774066a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–11/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Trust for Historic Preservation and Belle Grove Incorporated","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Trust for Historic Preservation and Belle Grove Incorporated may continue to own, operate, and manage Belle Grove Plantation and its structures and grounds within the Park boundary. Belle Grove Incorporated may continue to own the house and grounds known as Bowman’s Fort or Harmony Hall for the purpose of permanent preservation, with a long-term goal of opening the property to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7774066b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–11/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shenandoah County","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Shenandoah County may continue to own, operate, and manage the Keister park site within the Park for the benefit of the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7774066c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–11/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Park community partners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall cooperate with the Park’s adjacent historic towns of Strasburg and Middletown, Virginia, as well as Frederick, Shenandoah, and Warren counties in furthering the purposes of the Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7774066d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–11/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shenandoah Valley Battlefields Foundation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Shenandoah Valley Battlefields Foundation may continue to administer and manage the Shenandoah Valley Battlefields National Historic District in partnership with the National Park Service and in accordance with the Management Plan for the District in which the Park is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7774066e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/373/s13"},"text":"Pub. L. 107–373, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3109"},"text":"116 Stat. 3109","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
