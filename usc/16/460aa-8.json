{"tag":"section","attrib":{"id":"id77d364dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aa–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"460aa–8"},"text":"§ 460aa–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal-State water rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The jurisdiction of the State and the United States over waters of any stream included in the recreation area shall be determined by established principles of law. Under the provisions of this subchapter, any taking by the United States of a water right which is vested under either State or Federal law at the time of enactment of this subchapter shall entitle the owner thereof to just compensation. Nothing in this subchapter shall constitute an express or implied claim or denial on the part of the Federal Government as to exemption from State water laws.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77d364de-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/400/s9"},"text":"Pub. L. 92–400, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-22"},"text":"Aug. 22, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/614"},"text":"86 Stat. 614","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77d364df-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77d364e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77d364e1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Time of enactment of this subchapter, referred to in text, means ","children":[{"tag":"date","attrib":{"date":"1972-08-22"},"text":"Aug. 22, 1972","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/92/400"},"text":"Pub. L. 92–400","children":[],"tail":", which enacted this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
