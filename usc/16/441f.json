{"tag":"section","attrib":{"id":"id779c9c90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s441f"},"text":null,"children":[{"tag":"num","attrib":{"value":"441f"},"text":"§ 441f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment and redefinition of boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to establish a more appropriate boundary for the Badlands National Park and to consolidate Federal land ownership therein, the Secretary of the Interior, in his discretion, is authorized to adjust and redefine the exterior boundaries of the national park by appropriate reductions or additions of land: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the total acreage of the national park, as revised pursuant to sections 441f to 441i of this title, shall not exceed its area of approximately one hundred fifty-four thousand one hundred and nineteen acres as of "},{"tag":"date","attrib":{"date":"1952-05-07"},"text":"May 7, 1952","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id779c9c91-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-05-07/ch244/s1"},"text":"May 7, 1952, ch. 244, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/65"},"text":"66 Stat. 65","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tVI/s611"},"text":"Pub. L. 95–625, title VI, § 611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3521"},"text":"92 Stat. 3521","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id779c9c92-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id779c9c93-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id779c9c94-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the monument’s approximately 154,119 acre area as of “","children":[{"tag":"date","attrib":{"date":"1952-05-07"},"text":"May 7, 1952","children":[],"tail":"” was substituted for a reference in the original to the monument’s “present” area."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id779c9c95-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id779c9c96-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “Park” and “park” substituted in text for “Monument” and “monument”, respectively, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/s611"},"text":"Pub. L. 95–625, § 611","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s441e–1"},"text":"section 441e–1 of this title","children":[],"tail":" and which redesignated Badlands National Monument as Badlands National Park."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
