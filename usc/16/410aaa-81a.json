{"tag":"section","attrib":{"id":"id776a6944-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81a"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–81a"},"text":"§ 410aaa–81a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of land to Anza-Borrego Desert State Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id776a6945-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On termination of all mining claims to the land described in subsection (b), the Secretary shall transfer the land described in that subsection to the State of California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a6946-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The land referred to in subsection (a) is certain Bureau of Land Management land in San Diego County, California, comprising approximately 934 acres, as generally depicted on the map entitled “Proposed Table Mountain Wilderness Study Area Transfer to the State” and dated ","children":[{"tag":"date","attrib":{"date":"2018-11-07"},"text":"November 7, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a6947-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776a6948-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The land transferred under subsection (a) shall be managed in accordance with the provisions of the California Wilderness Act (California Public Resources Code sections 5093.30–5093.40).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a6949-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, the land transferred under subsection (a) is withdrawn from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776a694a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all forms of entry, appropriation, or disposal under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a694b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a694c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disposition under all laws relating to mineral and geothermal leasing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a694d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reversion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the State ceases to manage the land transferred under subsection (a) as part of the State Park System or in a manner inconsistent with the California Wilderness Act (California Public Resources Code sections 5093.30–5093.40), the land shall revert to the Secretary at the discretion of the Secretary, to be managed as a Wilderness Study Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id776a694e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tVII/s712"},"text":"Pub. L. 103–433, title VII, § 712","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1451"},"text":"Pub. L. 116–9, title I, § 1451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/710"},"text":"133 Stat. 710","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id776a694f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id776a6950-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id776a6951-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/s103"},"text":"Section 103 of Pub. L. 103–433","children":[],"tail":" provided in part that in this subchapter “Secretary” means the Secretary of the Interior."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
