{"tag":"section","attrib":{"id":"id7a03b212-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104"},"text":null,"children":[{"tag":"num","attrib":{"value":"6104"},"text":"§ 6104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a03b213-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program to provide financial assistance for projects to promote the conservation of neotropical migratory birds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a03b214-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project applicants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project proposal may be submitted by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a03b215-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual, corporation, partnership, trust, association, or other private entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b216-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer, employee, agent, department, or instrumentality of the Federal Government, of any State, municipality, or political subdivision of a State, or of any foreign government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b217-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, municipality, or political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b218-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other entity subject to the jurisdiction of the United States or of any foreign country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b219-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an international organization (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s288"},"text":"section 288 of title 22","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a03b21a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project proposals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be considered for financial assistance for a project under this chapter, an applicant shall submit a project proposal that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a03b21b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a03b21c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the individual responsible for the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a03b21d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a succinct statement of the purposes of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a03b21e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the qualifications of individuals conducting the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a03b21f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the funds and time necessary to complete the project, including sources and amounts of matching funds;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b220-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates that the project will enhance the conservation of neotropical migratory bird species in the United States, Canada, Latin America, or the Caribbean;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b221-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes mechanisms to ensure adequate local public participation in project development and implementation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b222-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains assurances that the project will be implemented in consultation with relevant wildlife management authorities and other appropriate government officials with jurisdiction over the resources addressed by the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b223-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates sensitivity to local historic and cultural resources and complies with applicable laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b224-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes how the project will promote sustainable, effective, long-term programs to conserve neotropical migratory birds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b225-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides any other information that the Secretary considers to be necessary for evaluating the proposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a03b226-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of assistance for a project under this chapter shall submit to the Secretary such periodic reports as the Secretary considers to be necessary. Each report shall include all information required by the Secretary for evaluating the progress and outcome of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a03b227-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a03b228-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of each project shall be not greater than 33.3 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b229-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a03b22a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share required to be paid for a project shall not be derived from any Federal grant program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a03b22b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of payment","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a03b22c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects in the United States and Canada","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share required to be paid for a project carried out in the United States or Canada shall be paid in cash.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a03b22d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6104/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects in Latin America and the Caribbean","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share required to be paid for a project carried out in Latin America or the Caribbean may be paid in cash or in kind.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a03b22e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/247/s5"},"text":"Pub. L. 106–247, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-20"},"text":"July 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/594"},"text":"114 Stat. 594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/363/tIII/s302/d"},"text":"Pub. L. 109–363, title III, § 302(d)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2076"},"text":"120 Stat. 2076","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/51/s2/a"},"text":"Pub. L. 118–51, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1005"},"text":"138 Stat. 1005","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a03b22f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a03b230-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a03b231-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/51"},"text":"Pub. L. 118–51","children":[],"tail":" substituted “33.3 percent” for “25 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/363/s302/d"},"text":"Pub. L. 109–363, § 302(d)","children":[],"tail":", inserted “Canada,” after “United States,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/363/s302/e"},"text":"Pub. L. 109–363, § 302(e)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) ","children":[{"tag":"inline","attrib":{},"text":"Projects in the united states","children":[],"tail":".—The non-Federal share required to be paid for a project carried out in the United States shall be paid in cash."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) ","children":[{"tag":"inline","attrib":{},"text":"Projects in foreign countries","children":[],"tail":".—The non-Federal share required to be paid for a project carried out in a foreign country may be paid in cash or in kind.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
