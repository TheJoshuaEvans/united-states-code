{"tag":"section","attrib":{"id":"id784d0125-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s580p"},"text":null,"children":[{"tag":"num","attrib":{"value":"580p"},"text":"§ 580p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Woodsy Owl” and “Smokey Bear” characters and names; definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this Act—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id784d0126-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s580p/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Woodsy Owl” means the name and representation of a fanciful owl, who wears slacks (forest green when colored), a belt (brown when colored), and a Robin Hood style hat (forest green when colored) with a feather (red when colored), and who furthers the slogan, “Give a Hoot, Don’t Pollute”, originated by the Forest Service of the United States Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id784d0127-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s580p/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Smokey Bear” means the name and character “Smokey Bear” originated by the Forest Service of the United States Department of Agriculture in cooperation with the Association of State Foresters and the Advertising Council.","children":[{"tag":"ref","attrib":{"idref":"fn002454"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002454"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id784f7228-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s580p/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id784f7229-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/318/s1"},"text":"Pub. L. 93–318, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-06-22"},"text":"June 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/244"},"text":"88 Stat. 244","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id784f722a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id784f722b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id784f722c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/318"},"text":"Pub. L. 93–318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-06-22"},"text":"June 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/244"},"text":"88 Stat. 244","children":[],"tail":", which enacted sections 580p, 580p–1, 580p–3, and 580p–4 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s711a"},"text":"section 711a of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s580p–2"},"text":"section 580p–2 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s711"},"text":"section 711 of Title 18","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id784f722d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s488b–3"},"text":"section 488b–3 of Title 31","children":[],"tail":" prior to the general revision and enactment of Title 31, Money and Finance, by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s1"},"text":"Pub. L. 97–258, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/877"},"text":"96 Stat. 877","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
