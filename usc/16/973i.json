{"tag":"section","attrib":{"id":"id78de6b4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973i"},"text":null,"children":[{"tag":"num","attrib":{"value":"973i"},"text":"§ 973i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings by Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78de6b4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order of vessel to leave waters upon failure to submit to jurisdiction of Pacific Island Party; procedure applicable","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Following any investigation conducted in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s973h/b"},"text":"section 973h(b) of this title","children":[],"tail":", the Secretary, with the concurrence of the Secretary of State, and upon the request of the Pacific Island Party concerned, may order a fishing vessel which has not submitted to the jurisdiction of that Pacific Island Party to leave immediately the Licensing Area and all Closed Areas upon making a finding—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78de6b4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that the fishing vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78de6b50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973i/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while fishing in the Licensing Area did not have a license under the Treaty to fish in the Licensing Area, and that under the Treaty, such fishing is not authorized to be conducted in the Licensing Area without a license;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78de6b51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973i/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was involved in any incident in which an Authorized Officer, Authorized Party Officer, or observer was allegedly assaulted with resultant bodily harm, physically threatened, forcefully resisted, refused boarding, or subjected to physical intimidation or physical interference in the performance of duties as authorized by this chapter or the Treaty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78de6b52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973i/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not made full payment within 60 days of any amount due as a result of a final judgment or other final determination deriving from a violation in waters under the jurisdiction of a Pacific Island Party; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78de6b53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973i/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was not represented by an agent for service of process in accordance with the Treaty; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78de6b54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that there is probable cause to believe that the fishing vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78de6b55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973i/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was used in violation of paragraph (3) of section 973c(a) or paragraph (2) or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s973c/b"},"text":"section 973c(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78de6b56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973i/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used an aircraft in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s973c/b/6"},"text":"section 973c(b)(6) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78de6b57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973i/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was involved in an incident in which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s973c/a/5"},"text":"section 973c(a)(5) of this title","children":[],"tail":" was violated."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78de6b58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order of vessel to leave waters where Pacific Island Party investigating alleged Treaty infringement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon being advised by the Secretary of State that proper notification to Parties has been made under the Treaty that a Pacific Island Party is investigating an alleged infringement of the Treaty by a vessel in waters under the jurisdiction of such Pacific Island Party, the Secretary shall order the vessel to leave such waters until the Secretary of State notifies the Secretary that such order is no longer necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78de6b59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rescission of orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall rescind any order issued on the basis of a finding under subsection (a)(1)(C) or (D) of this section as soon as the Secretary determines that the facts underlying the finding do not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78de6b5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on judicial review of orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No order issued in accordance with this section is subject to judicial review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78de6b5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973i/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of orders by Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon a request by the Secretary, the Attorney General shall commence a civil action for appropriate relief, including permanent or temporary injunction, to enforce any order issued by the Secretary under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78de6b5c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/330/s11"},"text":"Pub. L. 100–330, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-07"},"text":"June 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/598"},"text":"102 Stat. 598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/350/s4/3"},"text":"Pub. L. 100–350, § 4(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/660"},"text":"102 Stat. 660","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIV/s8419"},"text":"Pub. L. 119–60, div. H, title LXXXIV, § 8419","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1917"},"text":"139 Stat. 1917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78de6b5d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78de6b5e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78de6b5f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8419/a/1"},"text":"Pub. L. 119–60, § 8419(a)(1)","children":[],"tail":", struck out “, all Limited Areas,” after “the Licensing Area”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8419/a/2/A"},"text":"Pub. L. 119–60, § 8419(a)(2)(A)","children":[],"tail":", struck out “paragraph 2 of Article 3 of” after “and that under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8419/a/2/B"},"text":"Pub. L. 119–60, § 8419(a)(2)(B)","children":[],"tail":", substituted “under the jurisdiction” for “within the Treaty Area”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8419/a/3/A"},"text":"Pub. L. 119–60, § 8419(a)(3)(A)","children":[],"tail":", substituted “paragraph (3) of section 973c(a) or paragraph (2) or (3) of section 973c(b)” for “section 973c(a)(4), (a)(5), (b)(2), or (b)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8419/a/3/B"},"text":"Pub. L. 119–60, § 8419(a)(3)(B)","children":[],"tail":", substituted “section 973c(b)(6)” for “section 973c(b)(7)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8419/a/3/C"},"text":"Pub. L. 119–60, § 8419(a)(3)(C)","children":[],"tail":", substituted “section 973c(a)(5)” for “section 973c(a)(7)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8419/b"},"text":"Pub. L. 119–60, § 8419(b)","children":[],"tail":", struck out “paragraph 7 of Article 5 of” after “Parties has been made under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/350"},"text":"Pub. L. 100–350","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s973c/a/7"},"text":"section 973c(a)(7) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s973c/b/7"},"text":"section 973c(b)(7) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
