{"tag":"section","attrib":{"id":"id77f71908-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"460hhh–1"},"text":"§ 460hhh–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77f71909-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserve scenic, scientific, historic, cultural, natural, wilderness, watershed, riparian, wildlife, threatened and endangered species, and other values contributing to public enjoyment and biological diversity in the Spring Mountains of Nevada;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f7190a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure appropriate conservation and management of natural and recreation resources in the Spring Mountains; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f7190b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–1/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the development of public recreation opportunities in the Spring Mountains for the enjoyment of present and future generations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77f7190c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/63/s3"},"text":"Pub. L. 103–63, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-04"},"text":"Aug. 4, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/297"},"text":"107 Stat. 297","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
