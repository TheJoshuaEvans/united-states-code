{"tag":"section","attrib":{"id":"id77fe4546-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460mmm–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"460mmm–5"},"text":"§ 460mmm–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maps and legal descriptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fe4547-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460mmm–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2000-10-24"},"text":"October 24, 2000","children":[],"tail":", the Secretary shall submit to Congress a copy of the Map and a legal description of the Conservation Area and of the Wilderness."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fe4548-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460mmm–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Force and effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Map and legal descriptions shall have the same force and effect as if included in this subchapter, except that the Secretary may correct clerical and typographical errors in the Map and the legal descriptions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fe4549-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460mmm–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Copies of the Map and the legal descriptions shall be on file and available for public inspection in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fe454a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460mmm–5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Director of the Bureau of Land Management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe454b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460mmm–5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Grand Junction District Office of the Bureau of Land Management in Colorado;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe454c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460mmm–5/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate office of the Bureau of Land Management in Colorado, if the Grand Junction District Office is not deemed the appropriate office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fe454d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460mmm–5/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate office of the Bureau of Land Management in Utah.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fe454e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460mmm–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map controlling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to section 460mmm–4(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3) "},{"tag":"ref","attrib":{"idref":"fn002377"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002377"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “460mmm–4("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(5)”."}],"tail":" of this title, in the case of a discrepancy between the Map and the descriptions, the Map shall control."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fe454f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/353/s7"},"text":"Pub. L. 106–353, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-24"},"text":"Oct. 24, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1379"},"text":"114 Stat. 1379","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
