{"tag":"section","attrib":{"id":"id784f72bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"582a–8"},"text":"§ 582a–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive forestry, natural resources, and environmental grants program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id784f72bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture (hereafter referred to in this section as the “Secretary”) shall establish a competitive forestry, natural resources, and environmental grant program to award grants for the conduct of research or forest restoration as described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id784f72bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under subsection (a), an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id784f72be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a State agricultural experiment station, a college or university, a research institution or organization, a Federal agency, a private organization, or a corporation that has a demonstrable capacity to conduct forestry, natural resources, and environmental research as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id784f72bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to the Secretary, an application at such time, in such manner, and containing such information as the Secretary shall require, including the proposed use of the amounts that may be received under a grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id784f72c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id784f72c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding the initial grants under subsection (a) the Secretary shall give priority to applicants who will use such grants for research concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id784f72c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the biology of forest organisms, including physiology, genetic mechanisms, and biotechnology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id784f72c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ecosystem function and management, including forest ecosystem research, biodiversity, forest productivity, pest management, water resources, and alternative silvicultural systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id784f72c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wood as a raw material, including forest products and harvesting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id784f72c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" human forest interactions, including outdoor recreation, public policy formulation, economics, sociology, and administrative behavior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id784f72c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international trade, competition, and cooperation related to forest products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id784f72c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative native crops, products, and services that can be produced from renewable natural resources associated with privately held forest lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id784f72c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" viable economic production and marketing systems for alternative natural resource products and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id784f72c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic and environmental benefits of various conservation practices on forest lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id784f72ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" genetic tree improvement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id784f72cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" market expansion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id784f72cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest restoration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants may be used to support programs that restore forest tree species native to American forests that may have suffered severe levels of mortality caused by non-native insects, plant pathogens, or others pests.","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id784f72cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required component of forest restoration strategy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To receive a grant under this subsection, an eligible institution shall demonstrate that it offers a program with a forest restoration strategy that incorporates not less than one of the following components:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id784f72ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Collection and conservation of native tree genetic material.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id784f72cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Production of propagules of native trees in numbers large enough for landscape scale restoration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id784f72d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Site preparation of former of native tree habitat.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id784f72d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Planting of native tree seedlings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id784f72d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Post-planting maintenance of native trees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id784f72d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award of grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award competitive grants under this subsection based on the degree to which the applicant addresses the following criteria:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id784f72d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Risk posed to the forests of that State by non-native pests, as measured by such factors as the number of such pests present in the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id784f72d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The proportion of the State’s forest composed of species vulnerable to non-native pests present in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id784f72d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The pests’ rate of spread via natural or human-assisted means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id784f72d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities and equipment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id784f72d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants made under this section may be used to update research facilities and equipment available to facilitate the conduct of state-of-the-art research in forestry, natural resources, and the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id784f72d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities and criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Cooperative Forestry Research Council appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s582a–4/b"},"text":"section 582a–4(b) of this title","children":[],"tail":", may develop criteria and priorities for the awarding of grants for use under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id784f72da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall request the Cooperative Forestry Research Council referred to in subsection (d)(2) to provide recommendations regarding grant priorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id784f72db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants under this section for periods of not to exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id784f72dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s582a–8/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id784f72dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXII/s1232"},"text":"Pub. L. 101–624, title XII, § 1232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3543"},"text":"104 Stat. 3543","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8708"},"text":"Pub. L. 115–334, title VIII, § 8708","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4882"},"text":"132 Stat. 4882","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id784f72de-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id784f72df-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id784f72e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Forest Stewardship Act of 1990 and as part of the Food, Agriculture, Conservation, and Trade Act of 1990, and not as part of the McIntire-Stennis Act of 1962 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id784f72e1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8708/1"},"text":"Pub. L. 115–334, § 8708(1)","children":[],"tail":", inserted “or forest restoration” after “research”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8708/2"},"text":"Pub. L. 115–334, § 8708(2)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) related to applicant priority based on use of grants for certain research areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
