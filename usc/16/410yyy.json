{"tag":"section","attrib":{"id":"id777d7c23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yyy"},"text":null,"children":[{"tag":"num","attrib":{"value":"410yyy"},"text":"§ 410yyy.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; acquisition of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When title to lands commonly known as the “Old Ocmulgee Fields”, upon which certain Indian mounds of great historical importance are located, comprising approximately two thousand acres, in and around the city of Macon, County of Bibb, State of Georgia, as shall be designated by the Secretary of the Interior, in the exercise of his judgment and discretion as necessary for national-monument purposes, shall have been vested in the United States, said area shall be set aside as a national monument, by proclamation of the President, and shall be known as the “Ocmulgee National Monument”: ","children":[{"tag":"ref","attrib":{"idref":"fn002192"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002192"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the United States shall not purchase by appropriation of public moneys any lands within the aforesaid area, but such lands shall be secured by the United States only by public or private donation."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id777d7c24-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-14/ch519/s1"},"text":"June 14, 1934, ch. 519, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/958"},"text":"48 Stat. 958","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777d7c25-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777d7c26-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id777d7c27-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s447a"},"text":"section 447a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id777d7c28-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id777d7c29-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ocmulgee National Monument was redesignated Ocmulgee Mounds National Historical Park by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2102/b/1"},"text":"Pub. L. 116–9, title II, § 2102(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/724"},"text":"133 Stat. 724","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410yyy–3/b/1"},"text":"section 410yyy–3(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id777d7c2a-6992-11