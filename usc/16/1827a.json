{"tag":"section","attrib":{"id":"id796ffd76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1827a"},"text":"§ 1827a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on sale of billfish","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id796ffd77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall offer for sale, sell, or have custody, control, or possession of for purposes of offering for sale or selling billfish or products containing billfish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796ffd78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1858/a"},"text":"section 1858(a) of this title","children":[],"tail":", a violation of this section shall be treated as an act prohibited by "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1857"},"text":"section 1857 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796ffd79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions for traditional fisheries and markets","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id796ffd7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) does not apply to billfish caught by US fishing vessels and landed and retained in the State of Hawaii or Pacific Insular Areas as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1802/35"},"text":"section 1802(35) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796ffd7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) does not apply to billfish landed by foreign fishing vessels in the Pacific Insular Areas when the foreign caught billfish is exported to non-US markets or retained within Hawaii and the Pacific Insular Areas for local consumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796ffd7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Billfish defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section the term “billfish”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id796ffd7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means any fish of the species—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id796ffd7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Makaira nigricans (blue marlin);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id796ffd7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Kajikia audax (striped marlin);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id796ffd80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Istiompax indica (black marlin);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id796ffd81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Istiophorus platypterus (sailfish);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id796ffd82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tetrapturus angustirostris (shortbill spearfish);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id796ffd83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Kajikia albida (white marlin);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id796ffd84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a/d/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tetrapturus georgii (roundscale spearfish);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id796ffd85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a/d/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tetrapturus belone (Mediterranean spearfish); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id796ffd86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a/d/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tetrapturus pfluegeri (longbill spearfish); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796ffd87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include the species Xiphias gladius (swordfish).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id796ffd88-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/183/s4"},"text":"Pub. L. 112–183, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-10-05"},"text":"Oct. 5, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1422"},"text":"126 Stat. 1422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/228/s1"},"text":"Pub. L. 115–228, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-02"},"text":"Aug. 2, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1628"},"text":"132 Stat. 1628","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id796ffd89-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id796ffd8a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id796ffd8b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Billfish Conservation Act of 2012 and not as part of the Magnuson-Stevens Fishery Conservation and Management Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id796ffd8c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/228"},"text":"Pub. L. 115–228","children":[],"tail":" inserted “and retained” after “landed”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id796ffd8d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id796ffd8e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/183/s2"},"text":"Pub. L. 112–183, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-10-05"},"text":"Oct. 5, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1422"},"text":"126 Stat. 1422","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/183/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds the following:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States carefully regulates its domestic fisheries for billfish and participates in international fishery management bodies in the Atlantic and Pacific.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Global billfish populations have declined significantly, however, because of overfishing primarily through retention of bycatch by non-United States commercial fishing fleets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ending the importation of foreign-caught billfish for sale in the United States aligns with U.S. management measures of billfish and protects the significant economic benefits to the U.S. economy of recreational fishing and marine commerce and the traditional cultural fisheries.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
