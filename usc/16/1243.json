{"tag":"section","attrib":{"id":"id78f3ef6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1243"},"text":null,"children":[{"tag":"num","attrib":{"value":"1243"},"text":"§ 1243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National recreation trails; establishment and designation; prerequisites","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78f3ef6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1243/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Interior, or the Secretary of Agriculture where lands administered by him are involved, may establish and designate national recreation trails, with the consent of the Federal agency, State, or political subdivision having jurisdiction over the lands involved, upon finding that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78f3ef70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1243/a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such trails are reasonably accessible to urban areas, and, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78f3ef71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1243/a/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such trails meet the criteria established in this chapter and such supplementary criteria as he may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78f3ef72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1243/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As provided in this section, trails within park, forest, and other recreation areas administered by the Secretary of the Interior or the Secretary of Agriculture or in other federally administered areas may be established and designated as “National Recreation Trails” by the appropriate Secretary and, when no Federal land acquisition is involved—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78f3ef73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1243/b/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trails in or reasonably accessible to urban areas may be designated as “National Recreation Trails” by the appropriate Secretary with the consent of the States, their political subdivisions, or other appropriate administering agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78f3ef74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1243/b/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trails within park, forest, and other recreation areas owned or administered by States may be designated as “National Recreation Trails” by the appropriate Secretary with the consent of the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78f3ef75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1243/b/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trails on privately owned lands may be designated “National Recreation Trails” by the appropriate Secretary with the written consent of the owner of the property involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78f3ef76-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/543/s4"},"text":"Pub. L. 90–543, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-02"},"text":"Oct. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/919"},"text":"82 Stat. 919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/11/tII/s204"},"text":"Pub. L. 98–11, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-03-28"},"text":"Mar. 28, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/43"},"text":"97 Stat. 43","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78f3ef77-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78f3ef78-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78f3ef79-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—Subsec. (b)(i), (ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/11/s204/1"},"text":"Pub. L. 98–11, § 204(1)","children":[],"tail":", substituted “appropriate Secretary” for “Secretary of the Interior”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/11/s204/2"},"text":"Pub. L. 98–11, § 204(2)","children":[],"tail":"–(4), added cl. (iii)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
