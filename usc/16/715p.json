{"tag":"section","attrib":{"id":"id7883c83c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715p"},"text":null,"children":[{"tag":"num","attrib":{"value":"715p"},"text":"§ 715p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation of State in enforcement of provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When any State shall, by suitable legislation, make provision adequately to enforce the provisions of this subchapter and all regulations promulgated thereunder, the Secretary of the Interior may so certify, and then and thereafter said State may cooperate with the Secretary of the Interior in the enforcement of this subchapter and the regulations thereunder.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7883c83d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-02-18/ch257/s17"},"text":"Feb. 18, 1929, ch. 257, § 17","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1225"},"text":"45 Stat. 1225","children":[],"tail":"; 1939 Reorg. Plan No. II, § 4(f), eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2731, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1433"},"text":"53 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7883c83e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7883c83f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id7883c840-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of functions of Secretary of Agriculture to Secretary of the Interior by Reorg. Plan No. II of 1939, see Transfer of Functions note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s715a"},"text":"section 715a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
