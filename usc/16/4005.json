{"tag":"section","attrib":{"id":"id79e7291d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4005"},"text":null,"children":[{"tag":"num","attrib":{"value":"4005"},"text":"§ 4005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions and duties of National Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e7291e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions and duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e7291f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4005/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to the Secretary, for the Secretary’s review and approval, an annual marketing and promotion plan which contains descriptions of consumer education, research, and other marketing and promotion activities of the National Council for the following year, including plans to coordinate the activities of councils established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4009"},"text":"section 4009 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e72920-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4005/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to the Secretary, for the Secretary’s review and approval, an annual budget of the anticipated expenses and disbursements of the National Council, including probable costs of consumer education, research, and other marketing and promotion plans or projects, and referenda under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4009"},"text":"section 4009 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e72921-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4005/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain accounting records of the receipt and disbursement of all funds entrusted to the National Council, subject to the Secretary’s right to review or inspect such records;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e72922-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4005/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain such books and records as the Secretary determines appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e72923-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4005/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to the Secretary from time to time such reports or proposals as the Secretary or the National Council determines appropriate for furthering the purposes and policies of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e72924-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4005/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each annual marketing and promotion plan shall be directed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e72925-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4005/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the general demand for fish and fish products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e72926-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4005/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging, expanding, or improving the marketing and promotion and utilization of fish and fish products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e72927-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4005/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the dissemination of data collected by consumer education, research, and other marketing promotion activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e72928-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4005/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on certain references","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consumer education and other marketing and promotion activities of the National Council shall contain no reference to a private brand or trade name and shall avoid use of deceptive acts or practices in behalf of fish or fish products or with respect to the quality, value, or use of any competing product or group of products. In addition, the National Council may not promote the consumption or purchase of a single or group of similar fish species (such as members of the same genera); except that the Council may use illustrations of a single or group of similar fish species in the course of promoting the generic consumption of fish and fish products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e72929-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4005/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Council may employ and determine the salary of an executive director, but such salary shall not exceed Senior Executive Service Level 6. The executive director shall have demonstrated expertise in the marketing and promotion of food products and may, without regard to the provisions of title 5, with the approval of the National Council, select and employ additional staff as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e7292a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4005/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding of referendum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Council may enter into agreements with applicants proposing to establish a council under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4009"},"text":"section 4009 of this title","children":[],"tail":" for the purposes of funding a referendum establishing the council. The National Council may enter into agreements with the councils established under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4009"},"text":"section 4009 of this title","children":[],"tail":" for the purpose of funding a referendum to establish quality standards, or a referendum to terminate any such council."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e7292b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4005/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Council may enter into agreements to develop and carry out activities authorized under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e7292c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4005/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of National Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Council shall cease to exist on ","children":[{"tag":"date","attrib":{"date":"1991-12-31"},"text":"December 31, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e7292d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659/tII/s206"},"text":"Pub. L. 99–659, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3718"},"text":"100 Stat. 3718","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/627/tVII/s701"},"text":"Pub. L. 101–627, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4463"},"text":"104 Stat. 4463","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e7292e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e7292f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79e72930-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Senior Executive Service, referred to in subsec. (d), see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79e72931-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/627"},"text":"Pub. L. 101–627","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1991-12-31"},"text":"December 31, 1991","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79e72932-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79e72933-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continuity of Council Functions, Contracts, and Personnel","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/627/tVII/s705"},"text":"Pub. L. 101–627, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4464"},"text":"104 Stat. 4464","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/627/tVII/s705"},"text":"“All current functions, contracts in force, and existing personnel of the National Fish and Seafood Promotional Council as of ","children":[{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":", are reauthorized and extended, and shall continue as if uninterrupted, notwithstanding section 206(g) of the Fish and Seafood Promotion Act of 1986 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4005/g"},"text":"16 U.S.C. 4005(g)","children":[],"tail":") as in effect on "},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
