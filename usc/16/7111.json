{"tag":"section","attrib":{"id":"id7a22d2d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111"},"text":null,"children":[{"tag":"num","attrib":{"value":"7111"},"text":"§ 7111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secure payments for States containing Federal land","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a22d2d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each of fiscal years 2008 through 2015 and 2017 through 2026, the Secretary of Agriculture shall calculate for each eligible State an amount equal to the sum of the products obtained by multiplying—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a22d2d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjusted share for each eligible county within the eligible State; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d2d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the full funding amount for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a22d2d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" County payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each of fiscal years 2008 through 2015 and 2017 through 2026, the Secretary of the Interior shall calculate for each eligible county that received a 50-percent payment during the eligibility period an amount equal to the product obtained by multiplying—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a22d2d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 50-percent adjusted share for the eligible county; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d2d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the full funding amount for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a22d2d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for fiscal year 2014 payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a22d2d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an eligible county in a State that will receive a share of the State payment for fiscal year 2014 has already received, or will receive, a share of the 25-percent payment for fiscal year 2014 distributed to the State before ","children":[{"tag":"date","attrib":{"date":"2015-04-16"},"text":"April 16, 2015","children":[],"tail":", the amount of the State payment shall be reduced by the amount of that eligible county’s share of the 25-percent payment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d2d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" County payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an eligible county that will receive a county payment for fiscal year 2014 has already received a 50-percent payment for that fiscal year, the amount of the county payment shall be reduced by the amount of the 50-percent payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a22d2da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for fiscal year 2017 payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a22d2db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an eligible county in a State that will receive a share of the State payment for fiscal year 2017 has already received, or will receive, a share of the 25-percent payment for fiscal year 2017 distributed to the State before ","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":", the amount of the State payment shall be reduced by the amount of the share of the eligible county of the 25-percent payment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d2dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" County payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an eligible county that will receive a county payment for fiscal year 2017 has already received a 50-percent payment for fiscal year 2017, the amount of the county payment shall be reduced by the amount of the 50-percent payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d2dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prompt payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 45 days after ","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":", the Secretary of the Treasury shall make all payments under this subchapter for fiscal year 2017."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a22d2de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for fiscal year 2024 and 2025 payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a22d2df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an eligible county in a State that will receive a share of the State payment for fiscal year 2024 or 2025 has already received, or will receive, a share of the 25-percent payment for that fiscal year distributed to the State before ","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":", the amount of the State payment shall be reduced by the amount of the share of the eligible county of the 25-percent payment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d2e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" County payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an eligible county that will receive a county payment for fiscal year 2024 or 2025 has already received a 50-percent payment for that fiscal year, the amount of the county payment shall be reduced by the amount of the 50-percent payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d2e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7111/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prompt payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 45 days after ","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":", the Secretary of the Treasury shall make all payments under this subchapter for each of fiscal years 2024 and 2025."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a22d2e2-6992-11f1-ab3f-8