{"tag":"section","attrib":{"id":"id773f886e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407d"},"text":null,"children":[{"tag":"num","attrib":{"value":"407d"},"text":"§ 407d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admission and guide fees exempt from tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any admission fee charged for entrance to Carlsbad Caverns and any fee charged for guide service therein shall be exempt from all taxes on admissions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id773f886f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-22/ch691/s1"},"text":"June 22, 1936, ch. 691, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1792"},"text":"49 Stat. 1792","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id773f8870-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id773f8871-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id773f8872-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1941-09-20/ch412/tV/s541/c"},"text":"Act Sept. 20, 1941, ch. 412, title V, § 541(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/710"},"text":"55 Stat. 710","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/act/1935-05-09/ch101/s1"},"text":"act May 9, 1935, ch. 101, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/207"},"text":"49 Stat. 207","children":[],"tail":", which had been classified to this section of the Code, “by striking out that part thereof” upon which this section was based. Said act "},{"tag":"date","attrib":{"date":"1941-09-20"},"text":"Sept. 20, 1941","children":[],"tail":", however, made no mention of act "},{"tag":"date","attrib":{"date":"1936-06-22"},"text":"June 22, 1936","children":[],"tail":", which reenacted those same provisions. Such act "},{"tag":"date","attrib":{"date":"1941-09-20"},"text":"Sept. 20, 1941","children":[],"tail":", was made effective on, and applicable only with respect to the period beginning with, "},{"tag":"date","attrib":{"date":"1941-10-01"},"text":"Oct. 1, 1941","children":[],"tail":", by section 550(a) thereof."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
