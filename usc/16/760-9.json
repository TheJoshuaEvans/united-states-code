{"tag":"section","attrib":{"id":"id78922021-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"760–9"},"text":"§ 760–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of fish hatchery in Pennsylvania","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to establish, construct, equip, operate, and maintain a new fish hatchery in the northwestern part of the State of Pennsylvania.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78922022-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/205/s1"},"text":"Pub. L. 86–205, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-08-25"},"text":"Aug. 25, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/430"},"text":"73 Stat. 430","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
