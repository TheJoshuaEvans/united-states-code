{"tag":"section","attrib":{"id":"id77230031-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s263"},"text":null,"children":[{"tag":"num","attrib":{"value":"263"},"text":"§ 263.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to accept donations of land, interests in land, buildings, structures, and other property within the boundaries of the said historical park as determined and fixed under this subchapter, and donations of funds for the purchase and maintenance thereof: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That he may acquire on behalf of the United States out of any donated funds, by purchase at prices deemed by him reasonable, or by condemnation under the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"section 3113 of title 40","children":[],"tail":", such tracts of land within said historical park as may be necessary for the completion thereof. The title to any lands or interests in lands to be acquired pursuant to this subchapter shall be satisfactory to the Secretary of the Interior."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77230032-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-06-11/ch304/s3"},"text":"June 11, 1940, ch. 304, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/263"},"text":"54 Stat. 263","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77230033-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77230034-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77230035-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"Section 3113 of title 40","children":[],"tail":"” substituted in text for “the Act of "},{"tag":"date","attrib":{"date":"1888-08-01"},"text":"August 1, 1888","children":[],"tail":"” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
