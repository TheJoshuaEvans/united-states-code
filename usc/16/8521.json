{"tag":"section","attrib":{"id":"id7a3d1156-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8521"},"text":null,"children":[{"tag":"num","attrib":{"value":"8521"},"text":"§ 8521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increasing youth recreation visits to Federal land","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3d1157-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8521/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretaries, acting jointly, shall develop and make public a strategy to increase the number of youth recreation visits to Federal recreational lands and waters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d1158-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8521/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A strategy developed under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3d1159-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8521/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3d115a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8521/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emphasize increased recreation opportunities on Federal recreational lands and waters for underserved youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3d115b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8521/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish objectives and quantifiable targets for increasing youth recreation visits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3d115c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8521/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the anticipated costs to achieve the objectives and meet the targets established under subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d115d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8521/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not establish any preference between similar recreation facilitated by noncommercial or commercial entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d115e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8521/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Update to strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after the date of the publication of the strategy required under subsection (a), and every 5 years thereafter, the Secretaries shall update the strategy and make public the update.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d115f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8521/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries may enter into contracts or cost-share agreements (including contracts or agreements for the acquisition of vehicles) to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3d1160-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tII/s231"},"text":"Pub. L. 118–234, title II, § 231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2890"},"text":"138 Stat. 2890","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
