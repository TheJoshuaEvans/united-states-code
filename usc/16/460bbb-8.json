tifier":"/us/usc/t16/s460bbb–8/b/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eight Mile Creek (from its headwaters to its confluence with the South Fork of the Smith River).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f25dfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–8/b/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Harrington Creek (from its headwaters to its confluence with the South Fork of the Smith River).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f25dff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–8/b/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prescott Fork of the Smith River (from its headwaters to its confluence with the South Fork of the Smith River).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f25e00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–8/b/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Buck Creek (from its headwaters to its confluence with the South Fork of the Smith River).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f25e01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lower Hurdygurdy Creek","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the Lower Hurdygurdy Creek (from Dry Lake to its confluence with the South Fork of the Smith River) there is established a streamside protection zone in which timber harvesting shall be prohibited except as permitted by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460bbb–3/a/7"},"text":"section 460bbb–3(a)(7) of this title","children":[],"tail":". Such zone shall extend one-eighth mile on either side of said Lower Hurdygurdy Creek."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f25e02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–8/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other restrictions on timber harvesting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall be in addition to, and not in lieu of, any restrictions on timber harvesting or other activities applicable to the streamside protection zones established by this section under any other applicable provision of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77f25e03-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/612/s11"},"text":"Pub. L. 101–612, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3219"},"text":"104 Stat. 3219","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77f25e04-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77f25e05-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77f25e06-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (d), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/612"},"text":"Pub. L. 101–612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3209"},"text":"104 Stat. 3209","children":[],"tail":", which is classified principally to this subchapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460bbb"},"text":"section 460bbb of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
