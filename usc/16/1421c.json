{"tag":"section","attrib":{"id":"id792d27cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421c"},"text":"§ 1421c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unusual mortality event response","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792d27d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d27d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Working group","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d27d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, acting through the Office, shall establish, in consultation with the Secretary of the Interior, a marine mammal unusual mortality event working group, consisting of individuals with knowledge and experience in marine science, marine mammal science, marine mammal veterinary and husbandry practices, marine conservation, and medical science, to provide guidance to the Secretary and the Secretary of the Interior for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id792d27d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining whether an unusual mortality event is occurring;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d27d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining, after an unusual mortality event has begun, if response actions with respect to that event are no longer necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d27d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing the contingency plan in accordance with subsection (b), to assist the Secretary in responding to unusual mortality events.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d27d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 10 of title 5 shall not apply to the marine mammal unusual mortality event working group established under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d27d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response timing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of the Interior, shall to the extent necessary and practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d27d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 24 hours after receiving notification from a stranding network participant that an unusual mortality event might be occurring, contact as many members as is possible of the unusual mortality event working group for guidance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d27d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" within 48 hours after receiving such notification—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id792d27da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a determination as to whether an unusual mortality event is occurring;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d27db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform the stranding network participant of that determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d27dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary has determined an unusual mortality event is occurring, designate an Onsite Coordinator for the event, in accordance with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d27dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contingency plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d27de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in consultation with the Secretary of the Interior and the unusual mortality event working group, and after an opportunity for public review and comment, issue a detailed contingency plan for responding to any unusual mortality event.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d27df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The contingency plan required under this subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d27e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of persons, including stranding network participants, at a regional, State, and local level, who can assist the Secretary in implementing a coordinated and effective response to an unusual mortality event;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d27e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of marine mammal tissues and analyses necessary to assist in diagnosing causes of unusual mortality events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d27e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training, mobilization, and utilization procedures for available personnel, facilities, and other resources necessary to conduct a rapid and effective response to unusual mortality events; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d27e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such requirements as are necessary to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id792d27e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize death of marine mammals in the wild and provide appropriate care of marine mammals during an unusual mortality event;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d27e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in identifying the cause or causes of an unusual mortality event;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d27e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the effects of an unusual mortality event on the size estimates of the affected populations of marine mammals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d27e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/b/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any roles played in an unusual mortality event by physical, chemical, and biological factors, including contaminants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d27e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Onsite coordinators","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d27e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d27ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, in consultation with the Secretary of the Interior, designate one or more Onsite Coordinators for an unusual mortality event, who shall make immediate recommendations to the stranding network participants on how to proceed with response activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d27eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Onsite Coordinator so designated shall be one or more appropriate Regional Directors of the National Marine Fisheries Service or the United States Fish and Wildlife Service, or their designees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d27ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, because of the wide geographic distribution, multiple species of marine mammals involved, or magnitude of an unusual mortality event, more than one Onsite Coordinator is designated, the Secretary shall, in consultation with the Secretary of the Interior, designate which of the Onsite Coordinators shall have primary responsibility with respect to the event.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d27ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d27ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An Onsite Coordinator designated under this subsection shall coordinate and direct the activities of all persons responding to an unusual mortality event in accordance with the contingency plan issued under subsection (b), except that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id792d27ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any matter that is not covered by the contingency plan, an Onsite Coordinator shall use his or her best professional judgment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d27f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contingency plan may be temporarily modified by an Onsite Coordinator, consulting as expeditiously as possible with the Secretary, the Secretary of the Interior, and the unusual mortality event working group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d27f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Onsite Coordinator may delegate to any qualified person authority to act as an Onsite Coordinator under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792d27f2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tIV/s404"},"text":"Pub. L. 92–522, title IV, § 404","children":[],"tail":", formerly title III, § 304, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tIII/s3003/a"},"text":"Pub. L. 102–587, title III, § 3003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5062"},"text":"106 Stat. 5062","children":[],"tail":"; renumbered title IV, § 404, "},{"tag":"ref","attrib":{"href":"/us/pl/103/238/s24/b"},"text":"Pub. L. 103–238, § 24(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/565"},"text":"108 Stat. 565","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/111"},"text":"Pub. L. 117–286, § 4(a)(111)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4317"},"text":"136 Stat. 4317","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792d27f3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792d27f4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id792d27f5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 App. U.S.C.)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
