{"tag":"section","attrib":{"id":"id79f30ffa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721"},"text":null,"children":[{"tag":"num","attrib":{"value":"4721"},"text":"§ 4721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Task Force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f30ffb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task Force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established an “Aquatic Nuisance Species Task Force”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f30ffc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Membership of the Task Force shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f30ffd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30ffe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f31000-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commandant of the United States Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f31001-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f31002-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f31003-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Park Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f31004-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Bureau of Land Management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f31005-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commissioner of Reclamation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f31006-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of any other Federal agency that the chairpersons designated under subsection (d) deem appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f31007-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ex officio members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chairpersons designated under subsection (d) shall invite representatives of the Great Lakes Commission, the Patrick Leahy Lake Champlain Basin Program, the Chesapeake Bay Program, the San Francisco Bay-Delta Estuary Program, and State agencies and other governmental entities to participate as ex officio members of the Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f31008-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairpersons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director and the Under Secretary shall serve as co-chairpersons of the Task Force and shall be jointly responsible, and are authorized to undertake such activities as may be necessary, for carrying out this subchapter in consultation and cooperation with the other members of the Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f31009-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memorandum of understanding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within six months of ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"November 29, 1990","children":[],"tail":", the Director and the Under Secretary shall develop a memorandum of understanding that describes the role of each in jointly carrying out this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f3100a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Task Force member shall coordinate any action to carry out this subchapter with any such action by other members of the Task Force, and regional, State and local entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f3100b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4721/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Observers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chairpersons designated under subsection (d) may invite representatives of nongovernmental entities to participate as observers of the Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f3100c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646/tI/s1201"},"text":"Pub. L. 101–646, title I, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4765"},"text":"104 Stat. 4765","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/182/tIII/s308/b"},"text":"Pub. L. 104–182, title III, § 308(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-06"},"text":"Aug. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1689"},"text":"110 Stat. 1689","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/e/2"},"text":"Pub. L. 104–332, § 2(e)(2)","children":[],"tail":", (h)(1), "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4085"},"text":"110 Stat. 4085","children":[],"tail":", 4091; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIII/s11327/b"},"text":"Pub. L. 117–263, div. K, title CXIII, § 11327(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4097"},"text":"136 Stat. 4097","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dO/tIV/s404/b"},"text":"Pub. L. 117–328, div. O, title IV, § 404(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5229"},"text":"136 Stat. 5229","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f3100d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f3100e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79f3100f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsecs. (d) to (f), was in the original “this subtitle”, meaning subtitle C (§§ 1201–1209) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646"},"text":"Pub. L. 101–646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4765"},"text":"104 Stat. 4765","children":[],"tail":", which enacted this subchapter and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s42"},"text":"section 42 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79f31010-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(7) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11327/c"},"text":"Pub. L. 117–263, § 11327(c)","children":[],"tail":", added pars. (7) to (9) and redesignated former par. (7) as (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" inserted “Patrick Leahy” before “Lake Champlain Basin Program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11327/b"},"text":"Pub. L. 117–263, § 11327(b)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/h/1"},"text":"Pub. L. 104–332, § 2(h)(1)","children":[],"tail":", made technical amendment to "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/s1201"},"text":"Pub. L. 101–646, § 1201","children":[],"tail":", which enacted this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/e/2/A"},"text":"Pub. L. 104–332, § 2(e)(2)(A)","children":[],"tail":", struck out “and” at end of par. (5), added par. (6), and redesignated former par. (6) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/e/2/B"},"text":"Pub. L. 104–332, § 2(e)(2)(B)","children":[],"tail":", inserted “the Chesapeake Bay Program, the San Francisco Bay-Delta Estuary Program,” before “and State agencies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/182"},"text":"Pub. L. 104–182","children":[],"tail":" inserted “, the Lake Champlain Basin Program,” after “Great Lakes Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79f31011-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id79f31012-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
