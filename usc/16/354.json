{"tag":"section","attrib":{"id":"id772c767e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s354"},"text":null,"children":[{"tag":"num","attrib":{"value":"354"},"text":"§ 354.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses; punishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person found guilty of violating any of the provisions of this subchapter shall be deemed guilty of a misdemeanor, and shall be subjected to a fine of not more than $500 or imprisonment not exceeding six months, or both, and be adjudged to pay all costs of the proceedings.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id772c767f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-02-26/ch121/s8"},"text":"Feb. 26, 1917, ch. 121, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/939"},"text":"39 Stat. 939","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
