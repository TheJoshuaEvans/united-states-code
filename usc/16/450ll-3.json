{"tag":"section","attrib":{"id":"id77a612ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ll–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"450ll–3"},"text":"§ 450ll–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77a612ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ll–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands added to Monument","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The boundary of the Booker T. Washington National Monument is modified to include the approximately 15 acres, as generally depicted on the map entitled “Boundary Map, Booker T. Washington National Monument, Franklin County, Virginia”, numbered BOWA 404/80,024, and dated February 2001. The map shall be on file and available for inspection in the appropriate offices of the National Park Service, Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a612ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ll–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of additional lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to acquire from willing owners the land or interests in land described in subsection (a) by donation, purchase with donated or appropriated funds, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a612ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ll–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of additional lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Lands added to the Booker T. Washington National Monument by subsection (a) shall be administered by the Secretary of the Interior as part of the monument in accordance with applicable laws and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77a612f0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-04-02/ch158/s5"},"text":"Apr. 2, 1956, ch. 158, § 5","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/215/s2"},"text":"Pub. L. 107–215, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1054"},"text":"116 Stat. 1054","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
