{"tag":"section","attrib":{"id":"id795f3410-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1727b"},"text":"§ 1727b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Youth Service Corps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id795f3411-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established within the Public Lands Corps a program to be known as the “Indian Youth Service Corps” that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795f3412-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrolls participants between the ages of 16 and 30, inclusive, and veterans age 35 or younger, a majority of whom are Indians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795f3413-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is established pursuant to an agreement between an Indian tribe and a qualified youth or conservation corps for the benefit of the members of the Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795f3414-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carries out appropriate conservation projects on eligible service land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795f3415-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into cooperative agreements with Indian tribes and qualified youth or conservation corps for the establishment and administration of the Indian Youth Service Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795f3416-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1727b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary of the Interior, in consultation with Indian tribes, shall issue guidelines for the management of the Indian Youth Service Corps, in accordance with this subchapter and any other applicable Federal laws."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id795f3417-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/378/tII/s210"},"text":"Pub. L. 91–378, title II, § 210","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tIX/s9003/g"},"text":"Pub. L. 116–9, title IX, § 9003(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/835"},"text":"133 Stat. 835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795f3418-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id795f3419-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id795f341a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (c), was in the original “this Act”, and was translated as reading “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/378"},"text":"Pub. L. 91–378","children":[],"tail":", known as the Public Lands Corps Act of 1993, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id795f341b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/379/s210"},"text":"section 210 of Pub. L. 91–379","children":[],"tail":" was renumbered section 212 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1729"},"text":"section 1729 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
