{"tag":"section","attrib":{"id":"id79fcad11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5302"},"text":null,"children":[{"tag":"num","attrib":{"value":"5302"},"text":"§ 5302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fcad12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assist in the conservation of rhinoceros and tigers by supporting the conservation programs of nations whose activities directly or indirectly affect rhinoceros and tiger populations, and the CITES Secretariat.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcad13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide financial resources for those programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcad14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To prohibit the sale, importation, and exportation of products intended for human consumption or application containing, or labeled or advertised as containing, any substance derived from any species of rhinoceros or tiger.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fcad15-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/391/s3"},"text":"Pub. L. 103–391, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4095"},"text":"108 Stat. 4095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/312/tIV/s403"},"text":"Pub. L. 105–312, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2959"},"text":"112 Stat. 2959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fcad16-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79fcad17-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79fcad18-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/312"},"text":"Pub. L. 105–312","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
