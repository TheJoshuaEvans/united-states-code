{"tag":"section","attrib":{"id":"id7723009c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s271g"},"text":null,"children":[{"tag":"num","attrib":{"value":"271g"},"text":"§ 271g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to carry out the purposes of this subchapter, not to exceed, however, $104,500 for the acquisition of lands and not to exceed $5,102,000 (April 1970 prices) for development, plus or minus such amounts, if any, as may be justified by reason of ordinary fluctuations in construction costs as indicated by engineering cost indexes applicable to the types of construction involved herein. The sums authorized in this section shall be available for acquisition and development in the areas added by this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7723009d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/590/s8"},"text":"Pub. L. 88–590, § 8","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/154/s1/d"},"text":"Pub. L. 92–154, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-11-12"},"text":"Nov. 12, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/421"},"text":"85 Stat. 421","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/578/tI/s101/12"},"text":"Pub. L. 94–578, title I, § 101(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2732"},"text":"90 Stat. 2732","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7723009e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7723009f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id772300a0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578"},"text":"Pub. L. 94–578","children":[],"tail":" substituted “$104,500” for “$16,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
