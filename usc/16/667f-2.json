{"tag":"section","attrib":{"id":"id786285d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667f–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"667f–2"},"text":"§ 667f–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of packaging and transporting expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With respect to all grain made available pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s667f–1"},"text":"section 667f–1 of this title","children":[],"tail":", the Commodity Credit Corporation shall be reimbursed by the Secretary of the Interior for its expenses in packaging and transporting such grain for purposes of sections 667f to 667f–3 of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id786285d2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-07-03/ch512/s3"},"text":"July 3, 1956, ch. 512, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/492"},"text":"70 Stat. 492","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id786285d3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id786285d4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id786285d5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s444"},"text":"section 444 of Title 7","children":[],"tail":", Agriculture, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
