{"tag":"section","attrib":{"id":"id79d687ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"3839bb"},"text":"§ 3839bb.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation of private grazing land","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d687cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this section to authorize the Secretary to provide a coordinated technical, educational, and related assistance program to conserve and enhance private grazing land resources and provide related benefits to all citizens of the United States by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d687d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a coordinated and cooperative Federal, State, and local grazing conservation program for management of private grazing land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening technical, educational, and related assistance programs that provide assistance to owners and managers of private grazing land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conserving and improving wildlife habitat on private grazing land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conserving and improving fish habitat and aquatic systems through grazing land conservation treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting and improving water quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the dependability and consistency of water supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and managing weed, noxious weed, and brush encroachment problems on private grazing land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrating conservation planning and management decisions by owners and managers of private grazing land, on a voluntary basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d687d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d687d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private grazing land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “private grazing land” means private, State-owned, tribally-owned, and any other non-federally owned rangeland, pastureland, grazed forest land, and hay land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d687dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private grazing land conservation assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d687dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to grazing landowners and others","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations for this section, the Secretary shall establish a voluntary program to provide technical, educational, and related assistance to owners and managers of private grazing land and public agencies, through local conservation districts, to enable the landowners, managers, and public agencies to voluntarily carry out activities that are consistent with this section, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d687de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining and improving private grazing land and the multiple values and uses that depend on private grazing land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing grazing land management technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" managing resources on private grazing land, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d687e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning, managing, and treating private grazing land resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d687e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring the long-term sustainability of private grazing land resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d687e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" harvesting, processing, and marketing private grazing land resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d687e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and managing weed, noxious weed, and brush encroachment problems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting and improving the quality and quantity of water yields from private grazing land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining and improving wildlife and fish habitat on private grazing land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing recreational opportunities on private grazing land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining and improving the aesthetic character of private grazing land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying the opportunities and encouraging the diversification of private grazing land enterprises; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging the use of sustainable grazing systems, such as year-round, rotational, or managed grazing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program elements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d687ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If funding is provided to carry out this section, it shall be provided through a specific line-item in the annual appropriations for the Natural Resources Conservation Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Personnel of the Department trained in pasture and range management shall be made available under the program to deliver and coordinate technical assistance and education to owners and managers of private grazing land, at the request of the owners and managers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under this section, the Secretary shall provide education and outreach activities through partnerships with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d687ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land-grant colleges and universities (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of title 7","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d687f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongovernmental organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d687f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing technical assistance self-help","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d687f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d687f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a severe lack of technical assistance for farmers and ranchers that graze livestock;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal budgetary constraints preclude any significant expansion, and may force a reduction of, current levels of technical support; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" farmers and ranchers have a history of cooperatively working together to address common needs in the promotion of their products and in the drainage of wet areas through drainage districts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of grazing demonstration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with paragraph (3), the Secretary may establish 2 grazing management demonstration districts at the recommendation of the grazing land conservation initiative steering committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d687f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within a reasonable time after the submission of a request of an organization of farmers or ranchers engaged in grazing, the Secretary shall propose that a grazing management district be established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms and conditions of the funding and operation of the grazing management district shall be proposed by the producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall approve the proposal if the Secretary determines that the proposal—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d687fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/d/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is reasonable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d687fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/d/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will promote sound grazing practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d687fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/d/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains provisions similar to the provisions contained in the beef promotion and research order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2903"},"text":"section 2903 of title 7","children":[],"tail":" in effect on "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The area proposed to be included in a grazing management district shall be determined by the Secretary on the basis of an application by farmers or ranchers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use authority under the Agricultural Adjustment Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s601"},"text":"7 U.S.C. 601","children":[],"tail":" et seq.), reenacted with amendments by the Agricultural Marketing Agreement Act of 1937, to operate, on a demonstration basis, a grazing management district."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68800-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The activities of a grazing management district shall be scientifically sound activities, as determined by the Secretary in consultation with a technical advisory committee composed of ranchers, farmers, and technical experts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d68801-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $60,000,000 for each of fiscal years 2002 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d68802-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1240M"},"text":"Pub. L. 99–198, title XII, § 1240M","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIII/s335"},"text":"Pub. L. 104–127, title III, § 335","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1002"},"text":"110 Stat. 1002","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tII/s2502/a"},"text":"Pub. L. 107–171, title II, § 2502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/264"},"text":"116 Stat. 264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2601"},"text":"Pub. L. 110–234, title II, § 2601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1068"},"text":"122 Stat. 1068","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title II, § 2601, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1796; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2501"},"text":"Pub. L. 113–79, title II, § 2501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/751"},"text":"128 Stat. 751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2404"},"text":"Pub. L. 115–334, title II, § 2404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4572"},"text":"132 Stat. 4572","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79d68803-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79d68804-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79d68805-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Agricultural Adjustment Act, referred to in subsec. (d)(3)(E), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-12/ch25"},"text":"act May 12, 1933, ch. 25","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/31"},"text":"48 Stat. 31","children":[],"tail":", which is classified generally to chapter 26 (§ 601 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s601"},"text":"section 601 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79d68806-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79d68807-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2404/1"},"text":"Pub. L. 115–334, § 2404(1)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2404/2"},"text":"Pub. L. 115–334, § 2404(2)","children":[],"tail":", substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" substituted “2018” for “2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s2601"},"text":"Pub. L. 110–246, § 2601","children":[],"tail":", substituted “2012” for “2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" amended section catchline and text generally. Prior to amendment, section required the Secretary to establish conservation farm option pilot programs for producers of wheat, feed grains, cotton, and rice."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79d68808-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79d68809-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
