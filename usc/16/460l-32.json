3/s371"},"text":"section 371 of Title 43","children":[],"tail":" is "},{"tag":"ref","attrib":{"href":"/us/act/1924-12-05/ch4/s4"},"text":"act Dec. 5, 1924, ch. 4, § 4","children":[],"tail":", subsec. A, "},{"tag":"ref","attrib":{"href":"/us/stat/43/701"},"text":"43 Stat. 701","children":[],"tail":". For complete classification of act "},{"tag":"date","attrib":{"date":"1902-06-17"},"text":"June 17, 1902","children":[],"tail":", to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
