{"tag":"section","attrib":{"id":"id7a120a4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b"},"text":null,"children":[{"tag":"num","attrib":{"value":"6591b"},"text":"§ 6591b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a120a4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d), a project described in subsection (b) that is conducted in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6591a/d"},"text":"section 6591a(d) of this title","children":[],"tail":" may be—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considered an action categorically excluded from the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Public Law 91–190","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt from the special administrative review process under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6515"},"text":"section 6515 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaborative restoration project","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project referred to in subsection (a) is a project to carry out forest restoration treatments that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a120a52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximizes the retention of old-growth and large trees, as appropriate for the forest type, to the extent that the trees promote stands that are resilient to insects and disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120a53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considers the best available scientific information to maintain or restore the ecological integrity, including maintaining or restoring structure, function, composition, and connectivity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120a54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is developed and implemented through a collaborative process that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a120a55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes multiple interested persons representing diverse interests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a120a56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a120a57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/b/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is transparent and nonexclusive; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a120a58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/b/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements for a resource advisory committee under subsections (c) through (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7125"},"text":"section 7125 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project under this subsection may carry out part of a proposal that complies with the eligibility requirements of the Collaborative Forest Landscape Restoration Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7303/b"},"text":"section 7303(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project size","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project under this section may not exceed 3000 acres.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project under this section shall be limited to areas—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a120a5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the wildland-urban interface; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120a5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Condition Classes 2 or 3 in Fire Regime Groups I, II, or III, outside the wildland-urban interface.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Roads","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a120a60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanent roads","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a120a61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project under this section shall not include the establishment of permanent roads.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a120a62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing roads","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may carry out necessary maintenance and repairs on existing permanent roads for the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120a63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary roads","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall decommission any temporary road constructed under a project under this section not later than 3 years after the date on which the project is completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a component of the National Wilderness Preservation System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal land on which, by Act of Congress or Presidential proclamation, the removal of vegetation is restricted or prohibited;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a congressionally designated wilderness study area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an area in which activities under subsection (a) would be inconsistent with the applicable land and resource management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest management plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All projects and activities carried out under this section shall be consistent with the land and resource management plan established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1604"},"text":"section 1604 of this title","children":[],"tail":" for the unit of the National Forest System containing the projects and activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice and scoping","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct public notice and scoping for any project or action proposed in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prepare an annual report on the use of categorical exclusions under this section that includes a description of all acres (or other appropriate unit) treated through projects carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", and each year thereafter, the Secretary shall submit the reports required under paragraph (1) to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a120a6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture, Nutrition, and Forestry of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120a6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Environment and Public Works of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120a70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120a71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Natural Resources of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120a72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591b/g/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government Accountability Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a120a73-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tVI/s603"},"text":"Pub. L. 108–148, title VI, § 603","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVIII/s8204"},"text":"Pub. L. 113–79, title VIII, § 8204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/916"},"text":"128 Stat. 916","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a120a74-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a120a75-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a120a76-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Public Law 91–190","children":[],"tail":", referred to in subsec. (a)(1), is "},{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", known as the National Environmental Policy Act of 1969, which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
