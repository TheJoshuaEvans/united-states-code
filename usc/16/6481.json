{"tag":"section","attrib":{"id":"id7a0d4e90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481"},"text":null,"children":[{"tag":"num","attrib":{"value":"6481"},"text":"§ 6481.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Susan L. Williams National Coral Reef Management Fellowship","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0d4e91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0d4e92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alaska Native Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Alaska Native Corporation” has the meaning given the term “Native Corporation” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602"},"text":"section 1602 of title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4e93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellow","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fellow” means a National Coral Reef Management Fellow.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4e94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fellowship” means the National Coral Reef Management Fellowship established in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4e95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered Native entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered Native entity” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6415"},"text":"section 6415 of this title","children":[],"tail":", as added by this division."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4e96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered State” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6415"},"text":"section 6415 of this title","children":[],"tail":", as added by this division."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4e97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Native entity” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6415"},"text":"section 6415 of this title","children":[],"tail":", as added by this division."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4e98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0d4e99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of fellowship program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0d4e9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a National Coral Reef Management Fellowship Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4e9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the fellowship are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0d4e9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage future leaders of the United States to develop additional coral reef management capacity in States and local communities with coral reefs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0d4e9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide management agencies of covered States and covered Native entities with highly qualified candidates whose education and work experience meet the specific needs of each covered State or covered Native entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0d4e9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide fellows with professional experience in management of coastal and coral reef resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0d4e9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0d4ea0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of the Interior, shall award a fellowship in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4ea1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of fellowship","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A fellowship awarded under this subsection shall be for a term of not more than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4ea2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of the Interior, shall award a fellowship to individuals who have demonstrated—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0d4ea3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an intent to pursue a career in marine services and outstanding potential for such a career;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0d4ea4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leadership potential, actual leadership experience, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0d4ea5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possession of a college or graduate degree in biological science, a college or graduate degree in resource management with experience that correlates with aptitude and interest for marine management, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0d4ea6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proficient writing and speaking skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0d4ea7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other attributes as the Secretary, in consultation with the Secretary of the Interior, considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0d4ea8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0d4ea9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the non-Federal share of the costs of a fellowship under this section shall be 25 percent of such costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4eaa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6481/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive the application of paragraph (1) to a fellowship if the Secretary finds that such waiver is necessary to support a project that the Secretary has identified as a high priority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0d4eab-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10031"},"text":"Pub. L. 117–263, div. J, title C, § 10031","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3955"},"text":"136 Stat. 3955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0d4eac-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0d4ead-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a0d4eae-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This division, referred to in subsec. (a)(4) to (6), is div. J of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3930"},"text":"136 Stat. 3930","children":[],"tail":". For complete classification of div. J to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
