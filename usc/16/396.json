{"tag":"section","attrib":{"id":"id7733a187-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s396"},"text":null,"children":[{"tag":"num","attrib":{"value":"396"},"text":"§ 396.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional lands; acceptance of title","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized, in his discretion and upon submission of evidence of satisfactory title to him, to accept, on behalf of the United States, title to the lands referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s391b"},"text":"section 391b of this title","children":[],"tail":" as may be deemed by him necessary or desirable for national-park purposes."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7733a188-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-20/ch530/s2"},"text":"June 20, 1938, ch. 530, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/784"},"text":"52 Stat. 784","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7733a189-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7733a18a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7733a18b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Hawaiʻi Volcanoes National Park","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Designation of portion of Hawaii National Park situated on island of Hawaii as Hawaiʻi Volcanoes National Park, effective ","children":[{"tag":"date