{"tag":"section","attrib":{"id":"id7a016798-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5606"},"text":null,"children":[{"tag":"num","attrib":{"value":"5606"},"text":"§ 5606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts and enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a016799-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5606/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is unlawful for any person or vessel that is subject to the jurisdiction of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a01679a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5606/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to violate any regulation issued under this chapter or any measure that is legally binding on the United States under the Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a01679b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5606/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to refuse to permit any authorized enforcement officer to board a fishing vessel that is subject to the person’s control for purposes of conducting any search, investigation, or inspection in connection with the enforcement of this chapter, any regulation issued under this chapter, or any measure that is legally binding on the United States under the Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a01679c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5606/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forcibly to assault, resist, oppose, impede, intimidate, or interfere with any authorized enforcement officer in the conduct of any search, investigation, or inspection described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a01679d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5606/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to resist a lawful arrest for any act prohibited by this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a01679e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5606/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ship, transport, offer for sale, sell, purchase, import, export, or have custody, control, or possession of, any fishery resources taken or retained in violation of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a01679f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5606/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to interfere with, delay, or prevent, by any means, the apprehension or arrest of another person, knowing that the other person has committed an act prohibited by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0167a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5606/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional prohibitions and enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For additional prohibitions relating to this chapter and enforcement of this chapter, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1826g"},"text":"section 1826g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0167a1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tII/s207"},"text":"Pub. L. 104–43, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/379"},"text":"109 Stat. 379","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/384/tII/s201/b/1"},"text":"Pub. L. 105–384, title II, § 201(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3451"},"text":"112 Stat. 3451","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/81/tI/s111"},"text":"Pub. L. 114–81, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/659"},"text":"129 Stat. 659","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/327/tV/s506"},"text":"Pub. L. 114–327, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1996"},"text":"130 Stat. 1996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0167a2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0167a3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a0167a4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327"},"text":"Pub. L. 114–327","children":[],"tail":" substituted “fishery resources” for “fish”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/81/s111/1"},"text":"Pub. L. 114–81, § 111(1)","children":[],"tail":", in section catchline, substituted “and enforcement” for “and penalties”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/81/s111/2"},"text":"Pub. L. 114–81, § 111(2)","children":[],"tail":", (3), inserted “, investigation,” before “or inspection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/81/s111/4"},"text":"Pub. L. 114–81, § 111(4)","children":[],"tail":", added subsec. (b) and struck out former subsecs. (b) to (f), which related to civil penalty, criminal penalty, civil forfeitures, enforcement, and jurisdiction of courts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/384"},"text":"Pub. L. 105–384","children":[],"tail":" substituted “section” for “sections”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a0167a5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id7a0167a6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
