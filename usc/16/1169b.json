{"tag":"section","attrib":{"id":"id78ef34b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1169b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1169b"},"text":"§ 1169b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of local entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other law to the contrary, the Secretary of Commerce shall, to the maximum extent practicable, carry out activities under subsection (a) ","children":[{"tag":"ref","attrib":{"idref":"fn002576"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002576"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and fulfill other obligations under Federal and State law relating to the Pribilof Islands, through grants or other agreements with local entities and residents of the Pribilof Islands, unless specialized skills are needed for an activity, and the Secretary specifies in writing that such skills are not available through local entities and residents of the Pribilof Islands."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78ef34b2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/702/tII/s212"},"text":"Pub. L. 89–702, title II, § 212","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s144/e/6/A/ii"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 144(e)(6)(A)(ii)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–248; "},{"tag":"ref","attrib":{"href":"/us/pl/106/562/tI/s106/a/2"},"text":"Pub. L. 106–562, title I, § 106(a)(2)","children":[],"tail":", "},{"tag":"dat