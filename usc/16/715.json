{"tag":"section","attrib":{"id":"id78817ec8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715"},"text":null,"children":[{"tag":"num","attrib":{"value":"715"},"text":"§ 715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This subchapter shall be known by the short title of “Migratory Bird Conservation Act.”","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78817ec9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-02-18/ch257/s1"},"text":"Feb. 18, 1929, ch. 257, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1222"},"text":"45 Stat. 1222","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78817eca-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78817ecb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id78817ecc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/215/s1"},"text":"Pub. L. 94–215, § 1","children":[],"tail":", Feb 17, 1976, "},{"tag":"ref","attrib":{"href":"/us/stat/90/189"},"text":"90 Stat. 189","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/215/s1"},"text":"“That this Act [amending sections 668dd, 715a, 715k–3, 715k–5, 718a, 718b, and 718d of this title] may be cited as the ‘Wetlands Loan Extension Act of 19