{"tag":"section","attrib":{"id":"id789bbdc0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s784"},"text":null,"children":[{"tag":"num","attrib":{"value":"784"},"text":"§ 784.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of prosecutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any violation of the provisions of this chapter shall be prosecuted in the district court of the United States of the district wherein the offender is found or into which he is first brought.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id789bbdc1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-08-15/ch253/s4"},"text":"Aug. 15, 1914, ch. 253, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/692"},"text":"38 Stat. 692","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
