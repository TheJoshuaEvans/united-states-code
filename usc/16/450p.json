{"tag":"section","attrib":{"id":"id779ee764-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450p"},"text":null,"children":[{"tag":"num","attrib":{"value":"450p"},"text":"§ 450p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property; donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to acquire on behalf of the United States out of any funds allotted and made available for this project by proper authority or out of any donated funds, by purchase at prices deemed by him reasonable, or by condemnation under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"section 3113 of title 40","children":[],"tail":", or to accept by donation, such land, interest in land, and/or buildings, structures, and other property within the boundaries of said national historic site as determined and fixed hereunder, and he is further authorized to accept donations of funds for the purchase and/or maintenance thereof."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id779ee765-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-29/ch801/s2"},"text":"Aug. 29, 1935, ch. 801, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/958"},"text":"49 Stat. 958","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/197/s1"},"text":"Pub. L. 88–197, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-12-11"},"text":"Dec. 11, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/349"},"text":"77 Stat. 349","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id779ee766-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id779ee767-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id779ee768-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Hereunder, referred to in text, means act ","children":[{"tag":"date","attrib":{"date":"1935-08-29"},"text":"Aug. 29, 1935","children":[],"tail":", which is classified to sections 450"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" to 450q of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id779ee769-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"Section 3113 of title 40","children":[],"tail":"” substituted in text for “the Act of "},{"tag":"date","attrib":{"date":"1888-08-01"},"text":"August 1, 1888","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/25/357"},"text":"25 Stat. 357","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id779ee76a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id779ee76b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Historic site” substituted in text for “monument” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/197"},"text":"Pub. L. 88–197","children":[],"tail":", which redesignated Andrew Johnson National Monument as Andrew Johnson National Historic Site."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
