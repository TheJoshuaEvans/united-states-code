{"tag":"section","attrib":{"id":"id789491a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773"},"text":null,"children":[{"tag":"num","attrib":{"value":"773"},"text":"§ 773.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter the term:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id789491a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Convention” means the Convention between the United States of America and Canada for the Preservation of the Halibut Fishery of the Northern Pacific Ocean and Bering Sea, signed at Ottawa, Canada on ","children":[{"tag":"date","attrib":{"date":"1953-03-02"},"text":"March 2, 1953","children":[],"tail":", as amended by the Protocol Amending the Convention, signed at Washington "},{"tag":"date","attrib":{"date":"1979-03-29"},"text":"March 29, 1979","children":[],"tail":", and includes the regulations promulgated thereunder."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789491a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Commission” means the International Pacific Halibut Commission provided for by article III of the Convention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789491a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Fishery conservation zone” means the fishery conservation zone of the United States established by section 1811 ","children":[{"tag":"ref","attrib":{"idref":"fn002507"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002507"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789491a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Convention waters” means the maritime areas off the west coast of the United States and Canada described in article I of the Convention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789491a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Halibut” means fish of the species Hippoglossus stenolepis inhabiting Convention waters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789491a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Fishing vessel” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id789491aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any vessel engaged in catching fish in Convention waters or in processing or transporting fish loaded in Convention waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789491ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any vessel outfitted to engage in any activity described in paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789491ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any vessel in normal support of any vessel described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789491ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id789491ae-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/176/s2"},"text":"Pub. L. 97–176, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-05-17"},"text":"May 17, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/78"},"text":"96 Stat. 78","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/251/tIII/s302/a"},"text":"Pub. L. 102–251, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-09"},"text":"Mar. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/64"},"text":"106 Stat. 64","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII/s211/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II, § 211(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–41.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id789491af-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id789491b0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/251/tIII"},"text":"Pub. L. 102–251, title III","children":[],"tail":", §§ 302(a), 308, "},{"tag":"date","attrib":{"date":"1992-03-09"},"text":"Mar. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/64"},"text":"106 Stat. 64","children":[],"tail":", 66, provided that, effective on the date on which the Agreement between the United States and the Union of Soviet Socialist Republics on the Maritime Boundary, signed "},{"tag":"date","attrib":{"date":"1990-06-01"},"text":"June 1, 1990","children":[],"tail":", enters into force for the United States, with authority to prescribe implementing regulations effective "},{"tag":"date","attrib":{"date":"1992-03-09"},"text":"Mar. 9, 1992","children":[],"tail":", but with no such regulation to be effective until the date on which the Agreement enters into force for the United States, section is amended by amending subsection (c) generally and adding subsection (h) to read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"(c) “Exclusive economic zone” means the zone established by Proclamation Numbered 5030, dated ","children":[{"tag":"date","attrib":{"date":"1983-03-10"},"text":"March 10, 1983","children":[],"tail":". For purposes of applying this subchapter, the inner boundary of that zone is a line coterminous with the seaward boundary of each of the coastal States."}],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"(h) “Special areas” means the areas referred to as eastern special areas in Article 3(1) of the Agreement between the United States of America and the Union of Soviet Socialist Republics on the Maritime Boundary, signed ","children":[{"tag":"date","attrib":{"date":"1990-06-01"},"text":"June 1, 1990","children":[],"tail":"; in particular, the term refers to those areas east of the maritime boundary, as defined in that Agreement, that lie within 200 nautical miles of the baselines from which the breadth of the territorial sea of Russia is measured but beyond 200 nautical miles of the baselines from which the breadth of the territorial sea of the United States is measured."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id789491b1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id789491b2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1811"},"text":"Section 1811 of this title","children":[],"tail":", referred to in subsec. (c), which established the fishery conservation zone, was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/99/659/tI/s101/b"},"text":"Pub. L. 99–659, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3706"},"text":"100 Stat. 3706","children":[],"tail":", and now relates to United States sovereign rights to fish and fishery management authority within the exclusive economic zone."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Proclamation Numbered 5030, referred to in subsec. (c), is Proc. No. 5030, ","children":[{"tag":"date","attrib":{"date":"1983-03-10"},"text":"Mar. 10, 1983","children":[],"tail":", 48 F.R. 10605, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453"},"text":"section 1453 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id789491b3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1811"},"text":"section 1811 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id789491b4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id789491b5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII/s211/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II, § 211(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–41, provided that the amendment made by that section is effective 15 days after "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id789491b6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/251/tIII/s308"},"text":"Pub. L. 102–251, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-09"},"text":"Mar. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/66"},"text":"106 Stat. 66","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/251/tIII/s308"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by section 301(e)(3) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1822"},"text":"section 1822 of this title","children":[],"tail":"] takes effect on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1992-03-09"},"text":"Mar. 9, 1992","children":[],"tail":"], and the amendments made by the other provisions of this title [amending this section and sections 773e, 1151, 1362, 1801, 1802, 1811, 1821, 1822, 1824, 1853, 1857, 1861, 3631, and 3636 of this title and sections 1122 and 1124a of Title 33, Navigation and Navigable Waters], except as provided in subsection (b), shall be effective on the date on which the Agreement between the United States and the Union of Soviet Socialist Republics on the Maritime Boundary, signed "},{"tag":"date","attrib":{"date":"1990-06-01"},"text":"June 1, 1990","children":[],"tail":", enters into force for the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Prescribe Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to prescribe regulations to implement the amendments made by this title shall be effective on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-03-09"},"text":"Mar. 9, 1992","children":[],"tail":"], but no such regulation may be effective until the date on which the Agreement described in subsection (a) enters into force for the United States.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id789491b7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/176/s1"},"text":"Pub. L. 97–176, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-05-17"},"text":"May 17, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/78"},"text":"96 Stat. 78","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/176/s1"},"text":"“That this Act [enacting this subchapter and repealing subchapter III of this chapter] may be cited as the ‘Northern Pacific Halibut Act of 1982’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
