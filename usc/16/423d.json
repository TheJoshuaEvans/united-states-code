{"tag":"section","attrib":{"id":"id77898a28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423d"},"text":null,"children":[{"tag":"num","attrib":{"value":"423d"},"text":"§ 423d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance and disposition of gifts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The commission, acting through the Secretary of the Interior, is authorized to receive gifts and contributions from States, Territories, societies, organizations, and individuals for the Petersburg National Battlefield: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That all contributions of money received shall be deposited in the Treasury of the United States and credited to a fund to be designated “Petersburg National Battlefield Fund”, which fund shall be applied to and expended under the direction of the Secretary of the Interior, for carrying out the provisions of sections 423, 423a, and 423b to 423h of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77898a29-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-07-03/ch746/s5"},"text":"July 3, 1926, ch. 746, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/822"},"text":"44 Stat. 822","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/603/s1"},"text":"Pub. L. 87–603, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-08-24"},"text":"Aug. 24, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/403"},"text":"76 Stat. 403","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77898a2a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77898a2b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77898a2c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Petersburg National Battlefield” substituted in text for “Petersburg National Military Park” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/603"},"text":"Pub. L. 87–603","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s423h–1"},"text":"section 423h–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id77898a2d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id77898a2e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of administrative functions of park, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s423"},"text":"section 423 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
