{"tag":"section","attrib":{"id":"id7a35e579-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210"},"text":null,"children":[{"tag":"num","attrib":{"value":"8210"},"text":"§ 8210.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of this chapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a35e57a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e57b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes any express or implied reserved water right in the United States for any purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e57c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects any water right in existence on ","children":[{"tag":"date","attrib":{"date":"2020-10-30"},"text":"October 30, 2020","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e57d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preempts or affects any State water law or interstate compact governing water; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e57e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects any Federal or State law in existence on ","children":[{"tag":"date","attrib":{"date":"2020-10-30"},"text":"October 30, 2020","children":[],"tail":", regarding water quality or water quantity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e57f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to acquire water rights or rights to property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Only a State, local government, or other non-Federal entity may acquire, under State law, water rights or rights to property with funds made available through ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8212"},"text":"section 8212 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e580-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e581-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects the authority, jurisdiction, or responsibility of a State to manage, control, or regulate fish and wildlife under the laws and regulations of the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e582-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizes the Secretary to control or regulate within a State the fishing or hunting of fish and wildlife.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e583-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on Indian Tribes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter abrogates, abridges, affects, modifies, supersedes, or alters any right of an Indian Tribe recognized by treaty or any other means, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e584-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement between the Indian Tribe and the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e585-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal law (including regulations);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e586-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Executive order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e587-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a judicial decree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e588-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjudication of water rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter diminishes or affects the ability of the Secretary to join an adjudication of rights to the use of water pursuant to subsection (a), (b), or (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s666"},"text":"section 666 of title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e589-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Commerce authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter affects the authority, jurisdiction, or responsibility of the Department of Commerce to manage, control, or regulate fish or fish habitats under the Magnuson-Stevens Fishery Conservation and Management Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"16 U.S.C. 1801","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e58a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other authorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e58b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private property protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter permits the use of funds made available to carry out this chapter to acquire real property or a real property interest without the written consent of each owner of the real property or real property interest, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e58c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mitigation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter authorizes the use of funds made available to carry out this chapter for fish and wildlife mitigation purposes under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a35e58d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e58e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Fish and Wildlife Coordination Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s661"},"text":"16 U.S.C. 661","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e58f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Water Resources Development Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662"},"text":"Public Law 99–662","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/100/4082"},"text":"100 Stat. 4082","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a35e590-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal law or court settlement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e591-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8210/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean Water Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter affects any provision of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.), including any definition in that Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a35e592-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188/tII/s210"},"text":"Pub. L. 116–188, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/936"},"text":"134 Stat. 936","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a35e593-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a35e594-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a35e595-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Magnuson-Stevens Fishery Conservation and Management Act, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/331"},"text":"90 Stat. 331","children":[],"tail":", which is classified principally to chapter 38 (§ 1801 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Water Pollution Control Act, referred to in subsec. (g)(2)(A), (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"act June 30, 1948, ch. 758","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/816"},"text":"86 Stat. 816","children":[],"tail":", which is classified generally to chapter 26 (§ 1251 et seq.) of Title 33, Navigation and Navigable Waters. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of Title 33","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Fish and Wildlife Coordination Act, referred to in subsec. (g)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-03-10/ch55"},"text":"act Mar. 10, 1934, ch. 55","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/401"},"text":"48 Stat. 401","children":[],"tail":", which is classified generally to sections 661 to 666c–1 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s661"},"text":"section 661 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Water Resources Development Act of 1986, referred to in subsec. (g)(2)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662"},"text":"Pub. L. 99–662","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4082"},"text":"100 Stat. 4082","children":[],"tail":". For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/662/s1/a"},"text":"section 1(a) of Pub. L. 99–662","children":[],"tail":", set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of Title 33","children":[],"tail":", Navigation and Navigable Waters, and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
