{"tag":"section","attrib":{"id":"id7703df27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s90d–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"90d–5"},"text":"§ 90d–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to carry out the purposes of this subchapter, but not more than $4,500,000 shall be appropriated for the acquisition of lands or interest in lands.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7703df28-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/544/tV/s506"},"text":"Pub. L. 90–544, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-02"},"text":"Oct. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/930"},"text":"82 Stat. 930","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/578/tI/s101/9"},"text":"Pub. L. 94–578, title I, § 101(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2732"},"text":"90 Stat. 2732","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7703df29-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7703df2a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7703df2b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578"},"text":"Pub. L. 94–578","children":[],"tail":" substituted “$4,500,000” for “$3,500,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
