{"tag":"section","attrib":{"id":"id77a1580b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"450cc"},"text":"§ 450cc.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Castle Clinton National Monument; establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to accept, on behalf of the United States, title to the site, comprising approximately one acre and situated in Battery Park, New York City, of the historic structure known as Castle Clinton, together with such structure and any other improvement on or appurtenant to such site. When title to such property is vested in the United States, it shall constitute the Castle Clinton National Monument.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a1580c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-12/ch954/s1"},"text":"Aug. 12, 1946, ch. 954, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/997"},"text":"60 Stat. 997","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77a1580d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77a1580e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77a1580f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Preservation and Administration of Castle Clinton National Monument","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Study by New York City National Shrines Advisory Board concerning preservation and administration of Castle Clinton National Monument, see ","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch779"},"text":"act Aug. 11, 1955, ch. 779","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/69/632"},"text":"69 Stat. 632","children":[],"tail":", which is classified as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s102303"},"text":"section 102303 of Title 54","children":[],"tail":", National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
