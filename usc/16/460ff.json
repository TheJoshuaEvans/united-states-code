{"tag":"section","attrib":{"id":"id77da8fe3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ff"},"text":"§ 460ff.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of preserving and protecting for public use and enjoyment, the historic, scenic, natural, and recreational values of the Cuyahoga River and the adjacent lands of the Cuyahoga Valley and for the purpose of providing for the maintenance of needed recreational open space necessary to the urban environment, the Cuyahoga Valley National Park, hereafter referred to as the “park”, shall be established within six months after ","children":[{"tag":"date","attrib":{"date":"1974-12-27"},"text":"December 27, 1974","children":[],"tail":". In the management of the park, the Secretary of the Interior (hereafter referred to as the “Secretary”) shall utilize the park resources in a manner which will preserve its scenic, natural, and historic setting while providing for the recreational and educational needs of the visiting public."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77da8fe4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/555/s1"},"text":"Pub. L. 93–555, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-27"},"text":"Dec. 27, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1784"},"text":"88 Stat. 1784","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/291/tI/s149/c"},"text":"Pub. L. 106–291, title I, § 149(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-11"},"text":"Oct. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/956"},"text":"114 Stat. 956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77da8fe5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77da8fe6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77da8fe7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/291"},"text":"Pub. L. 106–291","children":[],"tail":" substituted “National Park” for “National Recreation Area” and substituted “park” for “recreation area” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77da8fe8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77da8fe9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Redesignation of Cuyahoga Valley National Recreation Area","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/291/tI/s149/a"},"text":"Pub. L. 106–291, title I, § 149(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2000-10-11"},"text":"Oct. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/956"},"text":"114 Stat. 956","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/291/tI/s149/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Redesignation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Cuyahoga Valley National Recreation Area is redesignated as Cuyahoga Valley National Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reference in a law, map, regulation, document, paper, or other record of the United States to the Cuyahoga Valley National Recreation Area is deemed to be a reference to Cuyahoga Valley National Park.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
