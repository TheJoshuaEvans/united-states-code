{"tag":"section","attrib":{"id":"id784d00f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s580f"},"text":null,"children":[{"tag":"num","attrib":{"value":"580f"},"text":"§ 580f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Telephones for official use in private residences","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1348"},"text":"section 1348 of title 31","children":[],"tail":", appropriations for the protection and management of the national forests and other lands administered by the Forest Service shall be available to pay for telephone service installed in residences of employees and of persons cooperating with the Forest Service who reside within or near such lands when such installation is determined by the Secretary of Agriculture to be needed in protecting such lands: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That in addition to the monthly local service charge, the Government may pay only such tolls or other charges as are required strictly for the public business."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id784d00f5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-04-24/ch97/s10"},"text":"Apr. 24, 1950, ch. 97, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/85"},"text":"64 Stat. 85","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/464/s6"},"text":"Pub. L. 85–464, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-06-20"},"text":"June 20, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/217"},"text":"72 Stat. 217","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id784d00f6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id784d00f7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id784d00f8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1348"},"text":"Section 1348 of title 31","children":[],"tail":"” substituted in text for “"},{"tag":"ref","attrib":{"href":"/us/act/1912-08-23/s7"},"text":"section 7 of the Act of August 23, 1912","children":[],"tail":", as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s679"},"text":"31 U.S.C. 679","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id784d00f9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/464"},"text":"Pub. L. 85–464","children":[],"tail":" inserted “and other lands administered by the Forest Service” after “forests”, and substituted “residences of employees” for “residences of seasonal employees”, and “such lands” for “the national forests” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
