{"tag":"section","attrib":{"id":"id7a3aa11a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8502"},"text":null,"children":[{"tag":"num","attrib":{"value":"8502"},"text":"§ 8502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military Veterans Outdoor Recreation Liaisons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3aa11b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretaries and the Secretary of Veterans Affairs shall each establish within their Departments the position of Military Veterans Outdoor Recreation Liaison."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa11c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Military Veterans Outdoor Recreation Liaison shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa11d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the implementation of this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa11e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" implement recommendations identified by the Task Force on Outdoor Recreation for Veterans established under section 203 of the Veterans Comprehensive Prevention, Access to Care, and Treatment Act of 2020 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/214"},"text":"Public Law 116–214","children":[],"tail":"), including recommendations related to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa11f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8502/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying new opportunities to formalize coordination between the Department of Veterans Affairs, Department of Agriculture, Department of the Interior, and partner organizations regarding the use of Federal recreational lands and waters for facilitating health and wellness for veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa120-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8502/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing identified barriers that exist to providing veterans with opportunities to augment the delivery of services for health and wellness through the use of outdoor recreation on Federal recreational lands and waters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa121-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8502/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the use of Federal recreational lands and waters for promoting wellness and facilitating the delivery of health care and therapeutic interventions for veterans;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa122-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with Military Veterans Outdoor Recreation Liaisons at other Federal agencies and veterans organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa123-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8502/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote outdoor recreation experiences for veterans on Federal recreational lands and waters through new and innovative approaches.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3aa124-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tII/s222"},"text":"Pub. L. 118–234, title II, § 222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2887"},"text":"138 Stat. 2887","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3aa125-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3aa126-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a3aa127-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in subsec. (b)(1), was in the original “this subtitle” meaning subtitle B (§§ 221–226) of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234"},"text":"Pub. L. 118–234","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2886"},"text":"138 Stat. 2886","children":[],"tail":", which enacted this part and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6803"},"text":"section 6803 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 203 of the Veterans Comprehensive Prevention, Access to Care, and Treatment Act of 2020, also known as the Veterans COMPACT Act of 2020, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/214/s203"},"text":"section 203 of Pub. L. 116–214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-05"},"text":"Dec. 5, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1036"},"text":"134 Stat. 1036","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
