{"tag":"section","attrib":{"id":"id775e81e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rr"},"text":null,"children":[{"tag":"num","attrib":{"value":"410rr"},"text":"§ 410rr.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this subchapter is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id775e81e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rr/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recognize the multitheme history, including the cultural interaction among diverse groups of people, of the Pecos area and its “gateway” role between the Great Plains and the Rio Grande Valley, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id775e81e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rr/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the preservation and interpretation of the cultural and natural resources of the Forked Lightning Ranch by establishing the Pecos National Historical Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id775e81e3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/313/tII/s201"},"text":"Pub. L. 101–313, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-06-27"},"text":"June 27, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/278"},"text":"104 Stat. 278","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id775e81e4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id775e81e5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id775e81e6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/536/s1"},"text":"Pub. L. 101–536, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-08"},"text":"Nov. 8, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2368"},"text":"104 Stat. 2368","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/536/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410rr–7"},"text":"section 410rr–7 of this title","children":[],"tail":" and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410rr–7"},"text":"section 410rr–7 of this title","children":[],"tail":"] may be cited as the ‘Pecos National Historical Park Expansion Act of 1990’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
