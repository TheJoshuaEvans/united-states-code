{"tag":"section","attrib":{"id":"id7760f36c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu"},"text":null,"children":[{"tag":"num","attrib":{"value":"410uu"},"text":"§ 410uu.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renaming","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Mound City Group National Monument established by proclamation of the President (Proclamation No. 1653, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/42/2298"},"text":"42 Stat. 2298","children":[],"tail":") and expanded by "},{"tag":"ref","attrib":{"href":"/us/pl/96/607/s701"},"text":"section 701 of Public Law 96–607","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/94/3540"},"text":"94 Stat. 3540","children":[],"tail":"), shall, on and after "},{"tag":"date","attrib":{"date":"1992-05-27"},"text":"May 27, 1992","children":[],"tail":", be known as the “Hopewell Culture National Historical Park”. Any reference to the Mound City Group National Monument in any law, regulation, map, document, record, or other paper of the United States shall be considered to be a reference to the Hopewell Culture National Historical Park."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7760f36d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/294/s1"},"text":"Pub. L. 102–294, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-27"},"text":"May 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/185"},"text":"106 Stat. 185","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7760f36e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7760f36f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b