{"tag":"section","attrib":{"id":"id788639dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718e"},"text":null,"children":[{"tag":"num","attrib":{"value":"718e"},"text":"§ 718e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans and transfers, alteration, and reproduction of stamps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id788639dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person to whom has been sold a Migratory Bird Hunting and Conservation Stamp, validated as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s718a"},"text":"section 718a of this title","children":[],"tail":", shall loan or transfer such stamp to any person during the period of its validity; nor shall any person other than the person validating such stamp use it for any purpose during such period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id788639de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alteration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clauses (i) and (ii) of section 504(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(D) "},{"tag":"ref","attrib":{"idref":"fn002497"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002497"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “504(1)(D)”."}],"tail":" of title 18, no person shall alter, mutilate, imitate, or counterfeit any stamp authorized by this subchapter, or imitate or counterfeit any die, plate, or engraving therefor, or make, print, or knowingly use, sell, or have in his possession any such counterfeit, die, plate, or engraving."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id788639df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reproduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the provisions of subsection (b), or the prohibition in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s474"},"text":"section 474 of title 18","children":[],"tail":", or other provisions of law, the Secretary may authorize, with the concurrence of the Secretary of the Treasury,"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id788639e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the color reproduction, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id788639e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the black and white reproduction,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"of Migratory Bird Hunting and Conservation Stamps authorized by sections 718 to 718b, 718c, 718d, and 718f to 718h of this title, which otherwise satisfies the requirements of clauses (ii) and (iii) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s504/1"},"text":"section 504(1) of title 18","children":[],"tail":". Any such reproduction shall be subject to those terms and conditions deemed necessary by the Secretary by regulation or otherwise and any proceeds received by the Federal Government as a result of such reproduction shall be paid, after deducting expenses for marketing, into the Migratory Bird Conservation Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s718d"},"text":"section 718d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id788639e2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-03-16/ch71/s5"},"text":"Mar. 16, 1934, ch. 71, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/452"},"text":"48 Stat. 452","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-06-15/ch261"},"text":"June 15, 1935, ch. 261","children":[],"tail":", title I, § 5, "},{"tag":"ref","attrib":{"href":"/us/stat/49/380"},"text":"49 Stat. 380","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1077/a"},"text":"Pub. L. 98–369, div. A, title X, § 1077(a)","children":[],"tail":", (b)(3), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1054"},"text":"98 Stat. 1054","children":[],"tail":", 1055; "},{"tag":"ref","attrib":{"href":"/us/pl/100/653/tIII/s302"},"text":"Pub. L. 100–653, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-14"},"text":"Nov. 14, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3827"},"text":"102 Stat. 3827","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/266/s10/f"},"text":"Pub. L. 109–266, § 10(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-03"},"text":"Aug. 3, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/677"},"text":"120 Stat. 677","children":[],"tail":".)"}],"tail":"\n"},{"ta