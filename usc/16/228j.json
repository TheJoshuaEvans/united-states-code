{"tag":"section","attrib":{"id":"id771962cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s228j"},"text":null,"children":[{"tag":"num","attrib":{"value":"228j"},"text":"§ 228j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; availability of sums","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out the provisions of sections 228a to 228j of this title, not to exceed, however, $1,250,000, in the aggregate for the period of the five fiscal years beginning with the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":", for the acquisition of lands and property, and not to exceed $49,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":", $255,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":", $265,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", and $235,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1977-06-30"},"text":"June 30, 1977","children":[],"tail":", for development, plus or minus such amounts, if any, as may be justified by reason of ordinary fluctuations in construction costs as indicated by engineering cost indexes applicable to the types of construction involved herein. The sums authorized in this section shall be available for acquisition and development undertaken subsequent to "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"January 3, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id771962ce-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/620/s12"},"text":"Pub. L. 93–620, § 12","children":[],"tail":", formerly § 11, "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2093"},"text":"88 Stat. 2093","children":[],"tail":"; renumbered § 12, "},{"tag":"ref","attrib":{"href":"/us/pl/94/31"},"text":"Pub. L. 94–31","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-06-10"},"text":"June 10, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/172"},"text":"89 Stat. 172","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id771962cf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id771962d0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id771962d1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":", first appearing in text of section, was in the original “"},{"tag":"date","attrib":{"date":"1074-06-30"},"text":"June 30, 1074","children":[],"tail":"”. The typographical error was corrected to conform to the apparent intent of the Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
