{"tag":"section","attrib":{"id":"id77898aac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"424–1"},"text":"§ 424–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of land","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77898aad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior may acquire private land, easements, and buildings within the areas authorized for acquisition for the Chickamauga and Chattanooga National Military Park, by donation, purchase with donated or appropriated funds, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77898aae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Land, easements, and buildings described in subsection (a) may be acquired only from willing sellers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77898aaf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s424–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Land, easements, and buildings acquired by the Secretary under subsection (a) shall be administered by the Secretary as part of the park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77898ab0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-08-19/ch806/s12"},"text":"Aug. 19, 1890, ch. 806, § 12","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tI/s138"},"text":"Pub. L. 105–277, div. A, § 101(e) [title I, § 138]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–266.)"}],"tail":"\n"}],"tail":null}
