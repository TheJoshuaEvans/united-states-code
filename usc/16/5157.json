{"tag":"section","attrib":{"id":"id79fcaca8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5157"},"text":null,"children":[{"tag":"num","attrib":{"value":"5157"},"text":"§ 5157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public participation in preparation of management plans and amendments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79fcaca9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5157/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to ensure the opportunity for public participation in the preparation of management plans and amendments to management plans for Atlantic striped bass, the Commission shall prepare such plans and amendments in accordance with the standards and procedures established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5104/a/2"},"text":"section 5104(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fcacaa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5157/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall apply to management plans and amendments adopted by the Commission after the 6-month period beginning on ","children":[{"tag":"date","attrib":{"date":"1997-12-16"},"text":"December 16, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fcacab-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/613/s8"},"text":"Pub. L. 98–613, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-31"},"text":"Oct. 31, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3190"},"text":"98 Stat. 3190","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/146/s2"},"text":"Pub. L. 105–146, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-16"},"text":"Dec. 16, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2676"},"text":"111 Stat. 2676","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fcacac-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79fcacad-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79fcacae-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/146"},"text":"Pub. L. 105–146","children":[],"tail":" amended section catchline and text generally, substituting provisions relating to public participation in preparation of management plans and amendments for provisions requiring the Secretaries to review the existing Plan and report to the Commission and Committees of Congress on its adequacy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
