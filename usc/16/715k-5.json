{"tag":"section","attrib":{"id":"id7883c82a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715k–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"715k–5"},"text":"§ 715k–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No land shall be acquired with moneys from the migratory bird conservation fund ","children":[{"tag":"ref","attrib":{"idref":"fn002495"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002495"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" unless the acquisition thereof has been approved by the Governor of the State or appropriate State agency."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7883c82b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/383/s3"},"text":"Pub. L. 87–383, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-10-04"},"text":"Oct. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/813"},"text":"75 Stat. 813","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/205/s1/b"},"text":"Pub. L. 90–205, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/612"},"text":"81 Stat. 612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/215/s2/b"},"text":"Pub. L. 94–215, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-02-17"},"text":"Feb. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/189"},"text":"90 Stat. 189","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/200/s2"},"text":"Pub. L. 98–200, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-02"},"text":"Dec. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1378"},"text":"97 Stat. 1378","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/548/tI/s102"},"text":"Pub. L. 98–548, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-26"},"text":"Oct. 26, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2774"},"text":"98 Stat. 2774","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/645/tI/s101/b"},"text":"Pub. L. 99–645, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3584"},"text":"100 Stat. 3584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7883c82c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7883c82d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7883c82e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Migratory Bird Conservation Act which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7883c82f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/645"},"text":"Pub. L. 99–645","children":[],"tail":" struck out first three sentences which read as follows: “Funds appropriated pursuant to sections 715k–3 to 715k–5 of this title shall be treated as an advance, without interest, to the migratory bird conservation fund. Such appropriated funds, beginning on "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"October 1, 1986","children":[],"tail":", shall be repaid to the Treasury out of the migratory bird conservation fund, such repayment shall be made in annual amounts comprising 75 per centum of the moneys accruing annually to such fund. In the event the full amount authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s715k–3"},"text":"section 715k–3 of this title","children":[],"tail":" is appropriated before "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"October 1, 1986","children":[],"tail":", the repayment of such funds pursuant to this section shall begin with the next full fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/548"},"text":"Pub. L. 98–548","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"October 1, 1986","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1984-10-01"},"text":"October 1, 1984","children":[],"tail":"” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/200"},"text":"Pub. L. 98–200","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1984-10-01"},"text":"October 1, 1984","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":"” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/215"},"text":"Pub. L. 94–215","children":[],"tail":" substituted “on "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":"” for “with fiscal year 1977”, “before "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":"” for “prior to the end of the aforesaid fifteen-year period” and “year. No” for “year: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That no”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/205"},"text":"Pub. L. 90–205","children":[],"tail":" made minor structural changes and substituted “1977” for “1969” and “fifteen-year period” for “seven-year period”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
