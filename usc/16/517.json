{"tag":"section","attrib":{"id":"id7826dbdd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s517"},"text":null,"children":[{"tag":"num","attrib":{"value":"517"},"text":"§ 517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Title to lands to be acquired","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may do all things necessary to secure the safe title in the United States to the lands to be acquired under this Act, but no payment shall be made for any such lands until the title shall be satisfactory to the Attorney General or his designee and shall be vested in the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7826dbde-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-01/ch186/s8"},"text":"Mar. 1, 1911, ch. 186, § 8","children":[],"tail":" (part), "},{"tag":"ref","attrib":{"href":"/us/stat/36/962"},"text":"36 Stat. 962","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/393/s3"},"text":"Pub. L. 91–393, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-09-01"},"text":"Sept. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/835"},"text":"84 Stat. 835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7826dbdf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7826dbe0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7826dbe1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-01/ch186"},"text":"act Mar. 1, 1911, ch. 186","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/961"},"text":"36 Stat. 961","children":[],"tail":", popularly known as the Weeks Law, which enacted this section, former sections 513 and 514 of this title, and sections 515, 516, 517a to 519, 521, 552, and 563 of this title and amended sections 480 and 500 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s552"},"text":"section 552 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7826dbe2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was amended by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-12-11/ch5"},"text":"act Dec. 11, 1926, ch. 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/919"},"text":"44 Stat. 919","children":[],"tail":". The amendment added a proviso at the end of this section which is set out as "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s517a"},"text":"section 517a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7826dbe3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/393"},"text":"Pub. L. 91–393","children":[],"tail":" inserted “or his designee” after “Attorney General”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
