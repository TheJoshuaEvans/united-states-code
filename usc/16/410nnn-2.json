{"tag":"section","attrib":{"id":"id7778c090-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410nnn–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"410nnn–2"},"text":"§ 410nnn–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the National Park Service, shall manage the historical park in accordance with this subchapter and the provisions of law generally applicable to the National Park System, including the Act of ","children":[{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":" et seq.),"},{"tag":"ref","attrib":{"idref":"fn002179"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002179"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and the Act of "},{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/49/666"},"text":"49 Stat. 666","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn002179"},"text":"1","children":[],"tail":" The Secretary shall protect, manage, and administer the historical park for the purposes of preserving and interpreting the cultural and natural resources of the historical park and providing for the public understanding and appreciation of the historical park in such a manner as to perpetuate these qualities and values for future generations."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7778c091-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib