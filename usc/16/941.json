hat: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/67/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s941h"},"text":"section 941h of this title","children":[],"tail":"] may be cited as the ‘Great Lakes Fishery Research Reauthorization Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id78d4f594-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/287/s1"},"text":"Pub. L. 117–287, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4363"},"text":"136 Stat. 4363","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/287/s1"},"text":"“This Act [amending sections 941f and 941g of this title] may be cited as the ‘Great Lakes Fish and Wildlife Restoration Reauthorization Act of 2022’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id78d4f595-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/326/s1"},"text":"Pub. L. 109–326, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-11"},"text":"Oct. 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1761"},"text":"120 Stat. 1761","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/326/s1"},"text":"“This Act [amending sections 941b to 941g of this title and enacting provisions set out as notes under this section] may be cited as the ‘Great Lakes Fish and Wildlife Restoration Act of 2006’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id78d4f596-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/265/s1"},"text":"Pub. L. 105–265, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2358"},"text":"112 Stat. 2358","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/265/s1"},"text":"“This Act [amending this section and sections 941 to 941g of this title and enacting provisions set out as a note under this section] may be cited as the ‘Great Lakes Fish and Wildlife Restoration Act of 1998’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id78d4f597-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/537/tI/s1001"},"text":"Pub. L. 101–537, title I, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-08"},"text":"Nov. 8, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2370"},"text":"104 Stat. 2370","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/tII/s2001"},"text":"Pub. L. 101–646, title II, § 2001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4773"},"text":"104 Stat. 4773","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/h/1"},"text":"Pub. L. 104–332, § 2(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4091"},"text":"110 Stat. 4091","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/332/s2/h/1"},"text":"“This title [enacting this chapter] may be cited as the ‘Great Lakes Fish and Wildlife Restoration Act of 1990’.”","children":[],"tail":"\n Title II of "},{"tag":"ref","attrib":{"href":"/us/pl/101/646"},"text":"Pub. L. 101–646","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/265/s3/b"},"text":"Pub. L. 105–265, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2358"},"text":"112 Stat. 2358","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78d4f598-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continued Monitoring and Assessment of Study Findings and Recommendations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/326/s8"},"text":"Pub. L. 109–326, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-11"},"text":"Oct. 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1766"},"text":"120 Stat. 1766","children":[],"tail":", which required the Director of the United States Fish and Wildlife Service to monitor fish and wildlife resources of the Great Lakes Basin and to update findings and recommendations of the Great Lakes Fishery Resources Restoration Study, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tIII/s3901/h"},"text":"Pub. L. 114–322, title III, § 3901(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1851"},"text":"130 Stat. 1851","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78d4f599-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/326/s2"},"text":"Pub. L. 109–326, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-11"},"text":"Oct. 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1761"},"text":"120 Stat. 1761","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/326/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Great Lakes have fish and wildlife communities that are structurally and functionally changing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successful fish and wildlife management focuses on the lakes as ecosystems, and effective management requires the coordination and integration of efforts of many partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the national interest to undertake activities in the Great Lakes Basin that support sustainable fish and wildlife resources of common concern provided under the recommendations of the Great Lakes Regional Collaboration authorized under Executive Order 13340 (69 Fed. Reg. 29043; relating to the Great Lakes Interagency Task Force) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1268"},"text":"33 U.S.C. 1268","children":[],"tail":" note];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional actions and better coordination are needed to protect and effectively manage the fish and wildlife resources, and the habitats upon which the resources depend, in the Great Lakes Basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-10-11"},"text":"Oct. 11, 2006","children":[],"tail":"], actions are not funded that are considered essential to meet the goals and objectives in managing the fish and wildlife resources, and the habitats upon which the resources depend, in the Great Lakes Basin; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Great Lakes Fish and Wildlife Restoration Act [of 1990] (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s941"},"text":"16 U.S.C. 941","children":[],"tail":" et seq.) allows Federal agencies, States, and tribes to work in an effective partnership by providing the funding for restoration work.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/265/s2"},"text":"Pub. L. 105–265, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2358"},"text":"112 Stat. 2358","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/265/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Great Lakes Fishery Resources Restoration Study, for which a report was submitted to Congress in 1995, was a comprehensive study of the status, and the assessment, management, and restoration needs, of the fishery resources of the Great Lakes Basin, and was conducted through the joint effort of the United States Fish and Wildlife Service, State fish and wildlife resource management agencies, Indian tribes, and the Great Lakes Fishery Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the study—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" found that, although State, Provincial, Native American Tribal, and Federal agencies have made significant progress toward the goal of restoring a healthy fish community to the Great Lakes Basin, additional actions and better coordination are needed to protect and effectively manage the fisheries and related resources in the Great Lakes Basin; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommended actions that are not currently funded but are considered essential to meet goals and objectives in managing the resources of the Great Lakes Basin.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
