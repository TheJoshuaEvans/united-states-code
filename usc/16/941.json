{"tag":"section","attrib":{"id":"id78d4f589-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941"},"text":null,"children":[{"tag":"num","attrib":{"value":"941"},"text":"§ 941.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78d4f58a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Great Lakes have fish and wildlife communities that are structurally and functionally changing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d4f58b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successful fish and wildlife management focuses on the lakes as ecosystems, and effective management requires the coordination and integration of efforts of many partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d4f58c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional actions and better coordination are needed to protect and effectively manage the fish and wildlife resources, and the habitats on which the resources depend, in the Great Lakes Basin; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d4f58d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this chapter allows Federal agencies, States, and Indian tribes to work in an effective partnership by providing the funding for restoration work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78d4f58e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/537/tI/s1002"},"text":"Pub. L. 101–537, title I, § 1002","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tIII/s3901/b"},"text":"Pub. L. 114–322, title III, § 3901(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1848"},"text":"130 Stat. 1848","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78d4f58f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78d4f590-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id78d4f591-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 941, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/537/tI/s1002"},"text":"Pub. L. 101–537, title I, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-08"},"text":"Nov. 8, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2370"},"text":"104 Stat. 2370","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/tII/s2002"},"text":"Pub. L. 101–646, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/10