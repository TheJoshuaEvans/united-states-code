{"tag":"section","attrib":{"id":"id7a0ade31-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6452"},"text":null,"children":[{"tag":"num","attrib":{"value":"6452"},"text":"§ 6452.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The duties of the Task Force shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0ade32-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6452/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate, in cooperation with covered States, covered Native entities, Federal reef managers, covered reef managers, coral reef research centers designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6411/b"},"text":"section 6411(b) of this title","children":[],"tail":" (as added by this division), and other nongovernmental and academic partners as appropriate, activities regarding the mapping, monitoring, research, conservation, mitigation, and restoration of coral reefs and coral reef ecosystems;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6452/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to monitor and advise regarding implementation of the policy and Federal agency responsibilities set forth in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0ade34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6452/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Executive Order 13089 (63 Fed. Reg. 32701; relating to coral reef protection); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6452/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Coral Reef Resilience Strategy;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6452/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to work in coordination with the other members of the Task Force—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0ade37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6452/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assess the United States role in international trade and protection of coral species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6452/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage implementation of appropriate strategies and actions to promote conservation and sustainable use of coral reef resources worldwide; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6452/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collaborate with international communities successful in managing coral reefs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade3a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6452/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide technical assistance for the development and implementation, as appropriate, of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0ade3b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6452/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Coral Reef Resilience Strategy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade3c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6452/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coral reef action plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6404"},"text":"section 6404 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade3d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6452/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to produce a report each year, for submission to the appropriate congressional committees and publication on the public website of the Task Force, highlighting the status of the coral reef resources of a covered State on a rotating basis, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0ade3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6452/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of recent coral reef management and restoration activities undertaken in that State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6452/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" updated estimates of the direct and indirect economic activity supported by, and other benefits associated with, those coral reef resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0ade40-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10012"},"text":"Pub. L. 117–263, div. J, title C, § 10012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3952"},"text":"136 Stat. 3952","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0ade41-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0ade42-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a0ade43-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This division, referred to in par. (1), is div. J of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3930"},"text":"136 Stat. 3930","children":[],"tail":". For complete classification of div. J to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Executive Order 13089, referred to in par. (2)(A), is Ex. Ord. No. 13089, ","children":[{"tag":"date","attrib":{"date":"1998-06-11"},"text":"June 11, 1998","children":[],"tail":", 63 F.R. 32701, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6401"},"text":"section 6401 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6404"},"text":"Section 6404 of this title","children":[],"tail":", referred to in par. (4)(B), was in the original “section 205 of that Act” and was translated as meaning "},{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s205"},"text":"section 205 of title II of Pub. L. 106–562","children":[],"tail":", known as the Coral Reef Conservation Act of 2000, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
