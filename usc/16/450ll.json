{"tag":"section","attrib":{"id":"id77a612e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ll"},"text":null,"children":[{"tag":"num","attrib":{"value":"450ll"},"text":"§ 450ll.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Booker T. Washington National Monument; acquisition of site","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized and directed to acquire, on behalf of the United States, by gift, purchase, or condemnation, all right, title, and interest in and to the real property located at Booker Washington Birthplace, Virginia.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a612e1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-04-02/ch158/s1"},"text":"Apr. 2, 1956, ch. 158, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/86"},"text":"70 Stat. 86","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77a612e2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77a612e3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id77a612e4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/215/s1"},"text":"Pub. L. 107–215, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1054"},"text":"116 Stat. 1054","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/215/s1"},"text":"“This Act [enacting section 450","children":[{"tag":"i","attrib":{},"text":"ll","children":[],"tail":"–3 of this title] may be cited as the ‘Booker T. Washington National Monument Boundary Adjustment Act of 2002’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77a612e5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4 of act ","children":[{"tag":"date","attrib":{"date":"1956-04-02"},"text":"Apr. 2, 1956","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/92/272/tII/s201/2"},"text":"Pub. L. 92–272, title II, § 201(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-04-11"},"text":"Apr. 11, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/120"},"text":"86 Stat. 120","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/272/tII/s201/2"},"text":"“There are authorized to be appropriated such sums not to exceed $600,000 as may be necessary to carry out the provisions of this act [sections 450","children":[{"tag":"i","attrib":{},"text":"ll","children":[],"tail":" to 450"},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":"–2 of this title].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
