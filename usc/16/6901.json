{"tag":"section","attrib":{"id":"id7a20617a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901"},"text":null,"children":[{"tag":"num","attrib":{"value":"6901"},"text":"§ 6901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a20617b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1982 Convention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “1982 Convention” means the United Nations Convention on the Law of the Sea of 10 December 1982.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a20617c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Agreement” means the Agreement for the Implementation of the Provisions of the United Nations Convention on the Law of the Sea of 10 December 1982 relating to the Conservation and Management of Straddling Fish Stocks and Highly Migratory Fish Stocks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a20617d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Commission for the Conservation and Management of Highly Migratory Fish Stocks in the Western and Central Pacific Ocean established in accordance with this Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a20617e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Convention area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “convention area” means all waters of the Pacific Ocean bounded to the south and to the east by the following line:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"From the south coast of Australia due south along the 141th meridian of east longitude to its intersection with the 55th parallel of south latitude; thence due east along the 55th parallel of south latitude to its intersection with the 150th meridian of east longitude; thence due south along the 150th meridian of east longitude to its intersection with the 60th parallel of south latitude; thence due east along the 60th parallel of south latitude to its intersection with the 130th meridian of west longitude; thence due north along the 130th meridian of west longitude to its intersection with the 4th parallel of south latitude; thence due west along the 4th parallel of south latitude to its intersection with the 150th meridian of west longitude; thence due north along the 150th meridian of west longitude.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a20617f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive economic zone","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “exclusive economic zone” means the zone established by Presidential Proclamation Numbered 5030 of ","children":[{"tag":"date","attrib":{"date":"1983-03-10"},"text":"March 10, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a206180-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “fishing” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a206181-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" searching for, catching, taking, or harvesting fish;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a206182-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attempting to search for, catch, take, or harvest fish;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a206183-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaging in any other activity which can reasonably be expected to result in the locating, catching, taking, or harvesting of fish for any purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a206184-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" placing, searching for, or recovering fish aggregating devices or associated electronic equipment such as radio beacons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a206185-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any operations at sea directly in support of, or in preparation for, any activity described in subparagraphs (A) through (D), including transshipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a206186-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of any other vessel, vehicle, aircraft, or hovercraft, for any activity described in subparagraphs (A) through (E) except for emergencies involving the health and safety of the crew or the safety of a vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a206187-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishing vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fishing vessel” means any vessel used or intended for use for the purpose of fishing, including support ships, carrier vessels, and any other vessel directly involved in such fishing operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a206188-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Highly migratory fish stocks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “highly migratory fish stocks” means all fish stocks of the species listed in Annex 1 of the 1982 Convention, except sauries, occurring in the Convention Area,","children":[{"tag":"ref","attrib":{"idref":"fn002837"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002837"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" and such other species of fish as the Commission may determine."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a206189-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a20618a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of the Northern Mariana Islands, American Samoa, Guam, and any other commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a20618b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transhipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “transshipment” means the unloading of all or any of the fish on board a fishing vessel to another fishing vessel either at sea or in port.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a20618c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6901/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" WCPFC Convention; Western and Central Pacific Convention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “WCPFC Convention” and “Western and Central Pacific Convention” means the Convention on the Conservation and Management of the Highly Migratory Fish Stocks in the Western and Central Pacific Ocean, (including any annexes, amendments, or protocols which are in force, or have come into force, for the United States) which was adopted at Honolulu, Hawaii, on ","children":[{"tag":"date","attrib":{"date":"2000-09-05"},"text":"September 5, 2000","children":[],"tail":", by the Multilateral High Level Conference on the Highly Migratory Fish Stocks in the Western and Central Pacific Ocean."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a20618d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479/tV/s502"},"text":"Pub. L. 109–479, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3635"},"text":"120 Stat. 3635","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a20618e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a20618f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a206190-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Presidential Proclamation Numbered 5030, referred to in par. (5), is Proc. No. 5030, ","children":[{"tag":"date","attrib":{"date":"1983-03-10"},"text":"Mar. 10, 1983","children":[],"tail":", 48 F.R. 10605, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453"},"text":"section 1453 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a206191-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a206192-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479/tV/s501"},"text":"Pub. L. 109–479, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3635"},"text":"120 Stat. 3635","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/479/tV/s501"},"text":"“This title [enacting this chapter] may be cited as the ‘Western and Central Pacific Fisheries Convention Implementation Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
