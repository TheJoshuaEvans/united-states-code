{"tag":"section","attrib":{"id":"id7a2c48a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702"},"text":null,"children":[{"tag":"num","attrib":{"value":"7702"},"text":"§ 7702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States participation in the North Pacific Fisheries Convention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2c48a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Commissioners","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2c48a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of Commissioners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States shall be represented on the Commission by five United States Commissioners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c48a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of commissioners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioners shall be as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2c48a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment by the President","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2c48a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Two of the Commissioners shall be appointed by the President and shall be an officer or employee of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a2c48a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/a/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a2c48a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/a/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a2c48a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/a/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c48a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making each appointment under clause (i), the President shall select a Commissioner from among individuals who are knowledgeable or experienced concerning fisheries resources in the North Pacific Ocean.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c48aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" North Pacific Fishery Management Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"One Commissioner shall be the chairman of the North Pacific Fishery Management Council or a designee of such chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c48ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pacific Fishery Management Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"One Commissioner shall be the chairman of the Pacific Fishery Management Council or a designee of such chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c48ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Western Pacific Fishery Management Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"One Commissioner shall be the chairman of the Western Pacific Fishery Management Council or a designee of such chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2c48ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternate Commissioners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event of a vacancy in a position as a Commissioner appointed under subsection (a), the Secretary of State, in consultation with the Secretary, may designate from time to time and for periods of time considered appropriate an alternate Commissioner to the Commission. An alternate Commissioner may exercise all powers and duties of a Commissioner in the absence of a Commissioner appointed under subsection (a), and shall serve the remainder of the term of the absent Commissioner for which designated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2c48ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative matters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2c48af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual serving as a Commissioner, or an alternative Commissioner, other than an officer or employee of the United States Government, shall not be considered a Federal employee, except for the purposes of injury compensation or tort claims liability as provided in chapter 81 of title 5 and chapter 171 of title 28.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c48b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual serving as a Commissioner or an alternate Commissioner, although an officer of the United States while so serving, shall receive no compensation for the individual’s services as such Commissioner or alternate Commissioner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c48b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2c48b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall pay the necessary travel expenses of a Commissioner or an alternate Commissioner in accordance with the Federal Travel Regulations and sections 5701, 5702, 5704 through 5708, and 5731 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c48b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may reimburse the Secretary of State for amounts expended by the Secretary of State under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2c48b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2c48b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of permanent Advisory Committee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2c48b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established an advisory committee which shall be composed of 11 members appointed by the Secretary as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2c48b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member engaging in commercial fishing activities in the management area of the North Pacific Fishery Management Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c48b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member engaging in commercial fishing activities in the management area of the Pacific Fishery Management Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c48b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member engaging in commercial fishing activities in the management area of the Western Pacific Fishery Management Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c48ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members from the indigenous population of the North Pacific, including an Alaska Native, Native Hawaiian, or a native-born inhabitant of any State of the United States in the Pacific, and an individual from a Pacific Coast tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c48bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member that is a marine fisheries scientist that is a resident of a State the adjacent exclusive economic zone for which is bounded by the Convention Area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c48bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member nominated by the Governor of the State of Alaska.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c48bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member nominated by the Governor of the State of Hawaii.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c48be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member nominated by the Governor of the State of Washington.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c48bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member nominated by the Governor of the State of California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c48c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and privileges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Advisory Committee shall serve for a term of 2 years and shall be eligible for reappointment for not more than 3 consecutive terms. The Commissioners shall notify the Advisory Committee in advance of each meeting of the Commissioners. The Advisory Committee shall attend each meeting and shall examine and be heard on all proposed programs, investigations, reports, recommendations, and regulations of the Commissioners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c48c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2c48c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall determine its organization and prescribe its practices and procedures for carrying out its functions under this chapter, the North Pacific Fisheries Convention, and the Magnuson-Stevens Fishery Conservation and Management Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"16 U.S.C. 1801","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c48c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability of procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall publish and make available to the public a statement of its organization, practices, and procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c48c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Advisory Committee shall constitute a quorum to conduct business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c48c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Meetings of the Advisory Committee, except when in executive session, shall be open to the public. Prior notice of each non-executive meeting shall be made public in a timely fashion. The Advisory Committee shall not be subject to the Federal Advisory Committee Act (5 U.S.C. App.).","children":[{"tag":"ref","attrib":{"idref":"fn002862"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002862"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c48c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost savings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to reduce the cost of Advisory Committee meetings, the Advisory Committee shall, to the extent practicable, utilize teleconferences and webinars for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c48c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Secretary of State shall furnish the Advisory Committee with relevant information concerning fisheries resources and international fishery agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c48c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative matters","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2c48c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide to the Advisory Committee in a timely manner such administrative and technical support services as are necessary to function effectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c48ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation; status","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual appointed to serve as a member of the Advisory Committee—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2c48cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall serve without pay; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c48cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be considered a Federal employee, except for the purposes of injury compensation or tort claims liability as provided in chapter 81 of title 5 and chapter 171 of title 28.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c48cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2c48ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State may pay the necessary travel expenses of members of the Advisory Committee in carrying out the duties of the Advisory Committee in accordance with the Federal Travel Regulations and sections 5701, 5702, 5704 through 5708, and 5731 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c48cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7702/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may reimburse the Secretary of State for amounts expended by the Secretary of State under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2c48d0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/tI/s102"},"text":"Pub. L. 114–327, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1976"},"text":"130 Stat. 1976","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a2c48d1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a2c48d2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a2c48d3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Magnuson-Stevens Fishery Conservation and Management Act, referred to in subsec. (d)(1)(C)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/331"},"text":"90 Stat. 331","children":[],"tail":", which is classified principally to chapter 38 (§ 1801 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act, referred to in subsec. (d)(1)(C)(iv), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Pub. L. 92–463","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-06"},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/770"},"text":"86 Stat. 770","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was substantially repealed and restated in chapter 10 (§ 1001 et seq.) of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4197"},"text":"136 Stat. 4197","children":[],"tail":", 4361. For disposition of sections of the Act into chapter 10 of Title 5, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
