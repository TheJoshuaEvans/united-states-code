{"tag":"section","attrib":{"id":"id78e597b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1111"},"text":null,"children":[{"tag":"num","attrib":{"value":"1111"},"text":"§ 1111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from taxation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission shall not be subject to Federal, State, or municipal taxation in the United States on any real or personal property held by it or on any gift, bequest, or devise to it of any personal or real property, or on its income, whether from governmental appropriations, admission fees, concessions, or donations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78e597b7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/363/s12"},"text":"Pub. L. 88–363, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-07"},"text":"July 7, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/301"},"text":"78 Stat. 301","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
