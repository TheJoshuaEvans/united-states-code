{"tag":"section","attrib":{"id":"id792f98ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1423c"},"text":"§ 1423c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative management agreement; authority to delegate enforcement authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792f9900-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the United States Fish and Wildlife Service, may share authority under this subchapter for the management of the taking of polar bears for subsistence purposes with the Alaska Nanuuq Commission if such commission is eligible under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792f9901-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for the management authority described in subsection (a), the Alaska Nanuuq Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792f9902-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into a cooperative agreement with the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1388"},"text":"section 1388 of this title","children":[],"tail":" for the conservation of polar bears;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f9903-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meaningfully monitor compliance with this subchapter and the Agreement by Alaska Natives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f9904-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" administer its co-management program for polar bears in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792f9905-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f9906-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792f9907-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tV/s504"},"text":"Pub. L. 92–522, title V, § 504","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/tIX/s902/a"},"text":"Pub. L. 109–479, title IX, § 902(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3662"},"text":"120 Stat. 3662","children":[