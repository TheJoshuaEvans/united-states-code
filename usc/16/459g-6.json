{"tag":"section","attrib":{"id":"id77afaf71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459g–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"459g–6"},"text":"§ 459g–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation and designation as wilderness; review of area by Secretary; report to President","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On or before ","children":[{"tag":"date","attrib":{"date":"1978-01-01"},"text":"January 1, 1978","children":[],"tail":", the Secretary shall review the area within the seashore and shall report to the President, in accordance with section 1132(c) and (d) of this title, his recommendations as to the suitability or nonsuitability of any area within the seashore for preservation as wilderness, and any designation of any such areas as a wilderness shall be accomplished in accordance with section 1132(c) and (d) of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77afaf72-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/366/s7"},"text":"Pub. L. 89–366, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-10"},"text":"Mar. 10, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/35"},"text":"80 Stat. 35","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/477/tIV/s406/4"},"text":"Pub. L. 93–477, title IV, § 406(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-26"},"text":"Oct. 26, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1449"},"text":"88 Stat. 1449","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77afaf73-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77afaf74-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77afaf75-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/477"},"text":"Pub. L. 93–477","children":[],"tail":" substituted provisions authorizing review of area and report to the President by the Secretary with regard to suitability of area for preservation as wilderness for provisions authorizing appropriations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
