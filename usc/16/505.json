{"tag":"section","attrib":{"id":"id7826db9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s505"},"text":null,"children":[{"tag":"num","attrib":{"value":"505"},"text":"§ 505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of national forests established on land reserved for purposes of national defense; maintenance available","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where a national forest is established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s471/b"},"text":"section 471(b) of this title","children":[],"tail":" on land previously reserved for the Army or Navy for purposes of national defense the land shall remain subject to the unhampered use of the Department of the Army or Navy Department for said purposes and nothing in this section or "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s471/b"},"text":"section 471(b) of this title","children":[],"tail":" shall be construed to relinquish the authority over such lands for purposes of national defense now vested in the department for which the lands were formerly reserved. Any moneys available for the maintenance, improvement, protection, construction of highways and general administration of the national forests shall be available for expenditure on national forests created under this section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7826db9b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-06-07/ch348/s9"},"text":"June 7, 1924, ch. 348, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/655"},"text":"43 Stat. 655","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title II, § 205(a), "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7826db9c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7826db9d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7826db9e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on the second and third sentences of section 9 of act ","children":[{"tag":"date","attrib":{"date":"1924-06-07"},"text":"June 7, 1924","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s471/b"},"text":"Section 471(b) of this title","children":[],"tail":", referred to in text, was based on the first and fifth sentences of section 9 of the 1924 act, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/94/579/s704/a"},"text":"section 704(a) of Pub. L. 94–579","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s499"},"text":"Section 499 of this title","children":[],"tail":" is based in part on the fourth sentence of section 9 of the 1924 act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7826db9f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7826dba0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Department of War designated Department of the Army and title of Secretary of War changed to Secretary of the Army by section 205(a) of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/tII"},"text":"act July 26, 1947, ch. 343, title II","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":". Section 205(a) of act "},{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":", was repealed by section 53 of "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/641"},"text":"70A Stat. 641","children":[],"tail":". Section 1 of act "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", enacted “Title 10, Armed Forces” which in sections 3010 to 3013 continued military Department of the Army under administrative supervision of Secretary of the Army."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
