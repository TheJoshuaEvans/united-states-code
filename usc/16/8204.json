{"tag":"section","attrib":{"id":"id7a3374e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204"},"text":null,"children":[{"tag":"num","attrib":{"value":"8204"},"text":"§ 8204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish Habitat Partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3374e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to recommend","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may recommend to Congress the designation of Fish Habitat Partnerships in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3374e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of a Partnership shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3374e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to work with other regional habitat conservation programs to promote cooperation and coordination to enhance fish populations and fish habitats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to engage local and regional communities to build support for fish habitat conservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to involve diverse groups of public and private partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop collaboratively a strategic vision and achievable implementation plan that is scientifically sound;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to leverage funding from sources that support local and regional partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use adaptive management principles, including evaluation of project success and functionality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop appropriate local or regional habitat evaluation and assessment measures and criteria that are compatible with national habitat condition measures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement local and regional priority projects that improve conditions for fish and fish habitat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3374ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity seeking to be designated by Congress as a Partnership shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3374ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Board an application at such time, in such manner, and containing such information as the Board may reasonably require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demonstrate to the Board that the entity has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3374f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a focus on promoting the health of important fish and fish habitats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an ability to coordinate the implementation of priority projects that support the goals and national priorities set by the Board that are within the Partnership boundary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a self-governance structure that supports the implementation of strategic priorities for fish habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to develop local and regional relationships with a broad range of entities to further strategic priorities for fish and fish habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a strategic plan that details required investments for fish habitat conservation that addresses the strategic fish habitat priorities of the Partnership and supports and meets the strategic priorities of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to develop and implement fish habitat conservation projects that address strategic priorities of the Partnership and the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to develop fish habitat conservation priorities based on sound science and data, the ability to measure the effectiveness of fish habitat projects of the Partnership, and a clear plan as to how Partnership science and data components will be integrated with the overall Board science and data effort.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3374f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for recommendation to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board may recommend to Congress for designation an application for a Partnership submitted under subsection (c) if the Board determines that the applicant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3374f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the criteria described in subsection (c)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies representatives to provide support and technical assistance to the Partnership from a diverse group of public and private partners, which may include State or local governments, nonprofit entities, Indian Tribes, and private individuals, that are focused on conservation of fish habitats to achieve results across jurisdictional boundaries on public and private land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is organized to promote the health of important fish species and important fish habitats, including reservoirs, natural lakes, coastal and marine environments, coral reefs, and estuaries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies strategic fish and fish habitat priorities for the Partnership area in the form of geographical focus areas or key stressors or impairments to facilitate strategic planning and decision making;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is able to address issues and priorities on a nationally significant scale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3374fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes a governance structure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3374fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflects the range of all partners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3374ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotes joint strategic planning and decision making by the applicant;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a337500-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates completion of, or significant progress toward the development of, a strategic plan to address declines in fish populations, rather than simply treating symptoms, in accordance with the goals and national priorities established by the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a337501-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotes collaboration in developing a strategic vision and implementation program that is scientifically sound and achievable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a337502-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a337503-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than February 1 of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2020-10-30"},"text":"October 30, 2020","children":[],"tail":", and, subject to paragraph (3), each February 1 thereafter, the Board shall develop and submit to the appropriate congressional committees an annual report, to be entitled “Report to Congress on Future Fish Habitat Partnerships and Modifications”, that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a337504-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifies each entity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a337505-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements described in subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a337506-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board recommends to Congress for designation as a Partnership;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a337507-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes any proposed modifications to a Partnership previously designated by Congress under subsection (f); ","children":[{"tag":"ref","attrib":{"idref":"fn002871"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002871"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a337508-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to each entity recommended for designation as a Partnership, describes, to the maximum extent practicable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a337509-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/e/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose of the recommended Partnership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a33750a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/e/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the recommended Partnership fulfills the requirements described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a33750b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability; notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a33750c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the report publicly available, including on the internet; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a33750d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the appropriate congressional committees and the State agency of any State included in a recommended Partnership area written notification of the public availability of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a33750e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall only submit a report required under paragraph (1) in the fiscal years in which the Board is proposing modifications to, or new designations of, 1 or more Partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a33750f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation or modification of Partnership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a337510-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress shall have the exclusive authority to designate or modify a Partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a337511-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation or modification process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Partnership designation or modification the Board recommends to Congress shall be deemed to be approved by Congress if Congress does not pass a joint resolution of disapproval with respect to the designation or modification by the date that is 90 days after the date on which the relevant congressional committees receive such recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a337512-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing partnerships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a337513-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2020-10-30"},"text":"October 30, 2020","children":[],"tail":", any partnership receiving Federal funds as of "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"October 30, 2020","children":[],"tail":", shall be subject to a designation review by Congress in which Congress shall have the opportunity to designate the partnership under subsection (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a337514-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8204/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility for Federal funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A partnership referred to in paragraph (1) that Congress does not designate as described in that paragraph shall be ineligible to receive Federal funds under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a337515-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188/tII/s204"},"text":"Pub. L. 116–188, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/928"},"text":"134 Stat. 928","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/198/tII/s202"},"text":"Pub. L. 118–198, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2681"},"text":"138 Stat. 2681","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a337516-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a337517-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a337518-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s202/1/A"},"text":"Pub. L. 118–198, § 202(1)(A)","children":[],"tail":", inserted “, subject to paragraph (3),” after “"},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"October 30, 2020","children":[],"tail":", and” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s202/1/B"},"text":"Pub. L. 118–198, § 202(1)(B)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s202/2"},"text":"Pub. L. 118–198, § 202(2)","children":[],"tail":", amended subsec. (f) generally. Prior to amendment, text read as follows: “Congress shall have the exclusive authority to designate or modify a Partnership.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
