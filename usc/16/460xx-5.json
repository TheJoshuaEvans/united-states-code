{"tag":"section","attrib":{"id":"id77eda38a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460xx–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"460xx–5"},"text":"§ 460xx–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No later than five years after ","children":[{"tag":"date","attrib":{"date":"1988-11-18"},"text":"November 18, 1988","children":[],"tail":", and every ten years thereafter, the Secretary shall report to the Committee on Natural Resources of the House of Representatives and the Committee on Energy and Natural Resources of the United States Senate, on the implementation of this subchapter. Such report shall include a detailed statement on the condition of the resources within the conservation area and of the progress of the Bureau of Land Management in achieving the purposes of this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77eda38b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/696/tI/s106"},"text":"Pub. L. 100–696, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4573"},"text":"102 Stat. 4573","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s6/d/22"},"text":"Pub. L. 103–437, § 6(d)(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4584"},"text":"108 Stat. 4584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77eda38c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77eda38d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77eda38e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Natural Resources” for “Interior and Insular Affairs” after “Committee on”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
