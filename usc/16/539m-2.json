{"tag":"section","attrib":{"id":"id7832c229-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"539m–2"},"text":"§ 539m–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" T’uf Shur Bien Preservation Trust Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7832c22a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The T’uf Shur Bien Preservation Trust Area is established within the Cibola National Forest and the Sandia Mountain Wilderness as depicted on the map—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c22b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recognize and protect in perpetuity the rights and interests of the Pueblo in and to the Area, as specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–3/a"},"text":"section 539m–3(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c22c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve in perpetuity the national forest and wilderness character of the Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c22d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recognize and protect in perpetuity the longstanding use and enjoyment of the Area by the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c22e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration and applicable law","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c22f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall continue to administer the Area as part of the National Forest System subject to and consistent with the provisions of sections 539m to 539m–12 of this title affecting management of the Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c230-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Traditional or cultural uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Traditional or cultural uses by Pueblo members and members of other federally-recognized Indian tribes authorized to use the Area by the Pueblo under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–3/a/4"},"text":"section 539m–3(a)(4) of this title","children":[],"tail":" shall not be restricted except by—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c231-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Wilderness Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.) (including regulations promulgated under that Act) as in effect on "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"February 20, 2003","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c232-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable Federal wildlife protection laws, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–4/a/2"},"text":"section 539m–4(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c233-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Later enactments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that any law enacted or amended after ","children":[{"tag":"date","attrib":{"date":"2003-02-20"},"text":"February 20, 2003","children":[],"tail":", is inconsistent with sections 539m to 539m–12 of this title, the law shall not apply to the Area unless expressly made applicable by Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c234-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The use of the word “Trust” in the name of the Area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c235-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in recognition of the specific rights and interests of the Pueblo in the Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c236-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not confer on the Pueblo the ownership interest that exists in a case in which the Secretary of the Interior accepts the title to land held in trust for the benefit of an Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c237-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c238-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2003-02-20"},"text":"February 20, 2003","children":[],"tail":", the Secretary shall file the map and a legal description of the Area with the Committee on Resources of the House of Representatives and with the Committee on Energy and Natural Resources of the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c239-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description shall be on file and available for public inspection in the Office of the Chief of the Forest Service, Washington, District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c23a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The map and legal description filed under paragraph (1) shall have the same effect as if the map and legal description were included in sections 539m to 539m–12 of this title, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c23b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical and typographical errors shall be corrected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c23c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes that may be necessary under subsection (b), (d), or (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–7"},"text":"section 539m–7 of this title","children":[],"tail":" or subsection (b) or (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–11"},"text":"section 539m–11 of this title","children":[],"tail":" shall be made; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c23d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that the map and the language of sections 539m to 539m–12 of this title conflict, the language of sections 539m to 539m–12 of this title shall control.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c23e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No conveyance of title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No right, title, or interest of the United States in or to the Area or any part of the Area shall be conveyed to or exchanged with any person, trust, or governmental entity, including the Pueblo, without specific authorization of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c23f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited uses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c240-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c241-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no use prohibited by the Wilderness Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.) as of "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"February 20, 2003","children":[],"tail":", shall be permitted in the wilderness portion of the Area; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c242-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" none of the following uses shall be permitted in any portion of the Area:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7832c243-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Gaming or gambling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7832c244-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mineral production.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7832c245-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Timber production.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7832c246-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/e/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any new use to which the Pueblo objects under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–3/a/3"},"text":"section 539m–3(a)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c247-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mining claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Area is closed to the location of mining claims under section 2320 of the Revised Statutes (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s23"},"text":"30 U.S.C. 23","children":[],"tail":") (commonly known as the “Mining Law of 1872”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c248-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No modification of boundaries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Establishment of the Area shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c249-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affect the boundaries of or repeal or disestablish the Sandia Mountain Wilderness or the Cibola National Forest; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c24a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–2/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modify the existing boundary of the Pueblo grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7832c24b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tIV/s404"},"text":"Pub. L. 108–7, div. F, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/282"},"text":"117 Stat. 282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7832c24c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7832c24d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7832c24e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 539m to 539m–12 of this title, referred to in subsecs. (b)(1), (3) and (c)(3), was in the original “this title”, meaning title IV of div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/279"},"text":"117 Stat. 279","children":[],"tail":", which is classified generally to sections 539m to 539m–12 of this title. For complete classification of title IV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m"},"text":"section 539m of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Wilderness Act, referred to in subsecs. (b)(2)(A) and (e)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/577"},"text":"Pub. L. 88–577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-03"},"text":"Sept. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/890"},"text":"78 Stat. 890","children":[],"tail":", which is classified generally to chapter 23 (§ 1131 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"section 1131 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Mining Law of 1872, referred to in subsec. (e)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1872-05-10/ch152"},"text":"act May 10, 1872, ch. 152","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/91"},"text":"17 Stat. 91","children":[],"tail":", which was incorporated into the Revised Statutes of 1878 as R.S. §§ 2319 to 2328, 2331, 2333 to 2337, and 2344, which are classified to sections 22 to 24, 26 to 28, 29, 30, 33 to 35, 37, 39 to 42, and 47 of Title 30, Mineral Lands and Mining. For complete classification of such Revised Statutes sections to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7832c24f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7832c250-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
