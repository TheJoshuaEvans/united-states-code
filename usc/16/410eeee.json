{"tag":"section","attrib":{"id":"id77825d73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee"},"text":null,"children":[{"tag":"num","attrib":{"value":"410eeee"},"text":"§ 410eeee.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New River Gorge National Park and Preserve Designation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77825d74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “New River Gorge National Park and Preserve Designation Act”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77825d75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of New River Gorge National Park and New River Gorge National Preserve, West Virginia","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77825d76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redesignation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The New River Gorge National River established under section 1101 ","children":[{"tag":"ref","attrib":{"idref":"fn002199"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002199"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the National Parks and Recreation Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460m–15"},"text":"16 U.S.C. 460m–15","children":[],"tail":") shall be known and designated as the “New River Gorge National Park and Preserve”, consisting of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77825d77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the New River Gorge National Park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77825d78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the New River Gorge National Preserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77825d79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New River Gorge National Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The boundaries of the New River Gorge National Park referred to in paragraph (1)(A) shall be the boundaries depicted as “Proposed National Park Area” on the map entitled “New River Gorge National Park and Preserve Proposed Boundary”, numbered 637/163,199A, and dated September 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77825d7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New River Gorge National Preserve; boundary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The boundaries of the New River Gorge National Preserve referred to in paragraph (1)(B) shall be the boundaries depicted as “Proposed National Preserve Area” on the map entitled “New River Gorge National Park and Preserve Proposed Boundary”, numbered 637/163,199A, and dated September 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77825d7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77825d7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The New River Gorge National Park and Preserve shall be administered by the Secretary of the Interior (referred to in this section as the “Secretary”) in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77825d7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77825d7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the laws generally applicable to units of the National Park System, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77825d7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 100101(a), chapter 1003, and sections 100751(a), 100752, 100753, and 102101 of title 54; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77825d80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 3201 of title 54; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77825d81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title XI of the National Parks and Recreation Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460m–15"},"text":"16 U.S.C. 460m–15","children":[],"tail":" et seq.),"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" except that the provisions of section 1106 "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460m–20"},"text":"16 U.S.C. 460m–20","children":[],"tail":") relating to hunting shall not apply to the New River Gorge National Park."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77825d82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting and fishing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77825d83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Hunting within the New River Gorge National Preserve shall be administered by the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77825d84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the same manner as hunting was administered on the day before ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", in those portions of the New River Gorge National River designated as the New River Gorge National Preserve by subsection (b)(3); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77825d85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id77825d86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1106 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the National Parks and Recreation Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460m–20"},"text":"16 U.S.C. 460m–20","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77825d87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77825d88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Fishing within the New River Gorge National Park and Preserve shall be administered by the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77825d89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the same manner as fishing was administered within the New River Gorge National River on the day before ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77825d8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id77825d8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1106 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the National Parks and Recreation Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460m–20"},"text":"16 U.S.C. 460m–20","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77825d8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77825d8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section prohibits hunting, fishing, or trapping on private land in accordance with applicable State and Federal laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77825d8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77825d8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional land for national preserve","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77825d90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire land or any interest in land identified as “Proposed Additional Lands” on the map entitled “New River Gorge National Park and Preserve Proposed Boundary”, numbered 637/163,199A, and dated September 2020, by purchase from a willing seller, donation, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77825d91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary modification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On acquisition of any land or interest in land under clause (i), the Secretary shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id77825d92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modify the boundary of the New River Gorge National Preserve to reflect the acquisition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77825d93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer the land or interest in land in accordance with the laws applicable to the New River Gorge National Preserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77825d94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visitor parking","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77825d95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may acquire not more than 100 acres of land in the vicinity of the New River Gorge National Park and Preserve by purchase from a willing seller, donation, or exchange to provide for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id77825d96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" visitor parking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77825d97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved public access to the New River Gorge National Park and Preserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77825d98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On acquisition of the land under clause (i), the acquired land shall be administered as part of the New River Gorge National Park or the New River Gorge National Preserve, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77825d99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial recreational watercraft services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Commercial recreational watercraft services within the New River Gorge National Park and Preserve shall be administered by the Secretary in accordance with section 402 of the West Virginia National Interest River Conservation Act of 1987 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460m–15"},"text":"16 U.S.C. 460m–15","children":[],"tail":" "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/100/534"},"text":"Public Law 100–534","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77825d9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in a law, map, regulation, document, paper, or other record of the United States to the New River Gorge National River shall be considered to be a reference to the “New River Gorge National Park” or the “New River Gorge National Preserve”, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77825d9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77825d9c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tII/s202"},"text":"Pub. L. 116–260, div. FF, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3089"},"text":"134 Stat. 3089","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77825d9d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77825d9e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77825d9f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Parks and Recreation Act of 1978, referred to in subsecs. (b)(1) and (c)(1)(C), (2)(A)(ii)(I), (B)(ii)(I), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Pub. L. 95–625","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3467"},"text":"92 Stat. 3467","children":[],"tail":". Title XI of the Act was classified principally to subchapter LXXI–A (§ 460m–15 et seq.) of this chapter prior to transfer to this subchapter. Sections 1101 and 1106 of the Act were transferred to sections 410eeee–1 and 410eeee–6, respectively, of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 402 of the West Virginia National Interest River Conservation Act of 1987, referred to in subsec. (c)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/534/s402"},"text":"section 402 of Pub. L. 100–534","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460m–15"},"text":"section 460m–15 of this title","children":[],"tail":" prior to transfer and is now set out as a note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77825da0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the New River Gorge National Park and Preserve Designation Act and as part of the Consolidated Appropriations Act, 2021, and not as part of title XI of the National Parks and Recreation Act of 1978 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77825da1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id77825da2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/356/s1"},"text":"Pub. L. 107–356, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3013"},"text":"116 Stat. 3013","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/356/s1"},"text":"“This Act [amending this section and enacting provisions set out as a note under this section] may be cited as the ‘New River Gorge Boundary Act of 2002’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id77825da3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/534/s1"},"text":"Pub. L. 100–534, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-26"},"text":"Oct. 26, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2699"},"text":"102 Stat. 2699","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/534/s1"},"text":"“This Act [enacting sections 410eeee–12 to 410eeee–15 and 460ww to 460ww–5 of this title, amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1274"},"text":"section 1274 of this title","children":[],"tail":", and enacting provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1274"},"text":"section 1274 of this title","children":[],"tail":"] may be cited as the ‘West Virginia National Interest River Conservation Act of 1987’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77825da4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Land Exchange","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/356/s2/b"},"text":"Pub. L. 107–356, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3013"},"text":"116 Stat. 3013","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/356/s2/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Interior shall complete a fee simple land exchange in the vicinity of Beauty Mountain, Fayette County, West Virginia, to acquire a tract of land identified as NERI Tract Number 150–07 that lies adjacent to the boundary of the New River Gorge National River [now New River Gorge National Park and Preserve] in exchange for a tract of land identified as NERI Tract Number 150–08 located within such boundary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of exchanged lands","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon the completion of such land exchange—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the land acquired by the United States in the exchange shall be included in the boundaries, and administered as part, of the New River Gorge National River; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the land conveyed by the United States in the exchange shall be excluded from the boundaries, and shall not be administered as part, of the New River Gorge National River.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77825da5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"New, Gauley, Meadow, and Bluestone Rivers; Congressional Findings and Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/534/s2"},"text":"Pub. L. 100–534, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-26"},"text":"Oct. 26, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2699"},"text":"102 Stat. 2699","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/534/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The outstanding natural, scenic, cultural and recreational values of the segment of the New River in West Virginia within the boundaries of the New River Gorge National River [now New River Gorge National Park and Preserve] have been preserved and enhanced by its inclusion in the National Park System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The establishment of the New River Gorge National River has provided the basis for increased recreation and tourism activities in southern West Virginia due to its nationally recognized status and has greatly contributed to the regional economy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Certain boundary modifications to the New River Gorge National River are necessary to further protect the scenic resources within the river’s visual corridor and to provide for better management of the national park unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Several tributaries of the New River in West Virginia also possess remarkable and outstanding features of national significance. The segment of the Gauley River below Summersville Dam has gained national recognition as a premier whitewater recreation resource. The lower section of the Bluestone River and the lower section of the Meadow River possess remarkable and outstanding natural, scenic, and recreational values due to their predominantly undeveloped condition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Portions of several of the New River tributaries, including segments of the Gauley River, the Meadow River, and the Bluestone River are suitable for inclusion in the National Park System or the National Wild and Scenic Rivers System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is in the national interest to preserve the natural condition of certain segments of the New, Gauley, Meadow, and Bluestone Rivers in West Virginia and to enhance recreational opportunities available on the free-flowing segments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of this Act [see Short Title of 1988 Amendment note above] is to provide for the protection and enhancement of the natural, scenic, cultural, and recreational values on certain free-flowing segments of the New, Gauley, Meadow, and Bluestone Rivers in the State of West Virginia for the benefit and enjoyment of present and future generations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77825da6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coordination Among Recreational Resources","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/534/tIV/s401"},"text":"Pub. L. 100–534, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-26"},"text":"Oct. 26, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2707"},"text":"102 Stat. 2707","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/534/tIV/s401"},"text":"“Subject to existing authority, the Secretary of the Interior shall cooperate with, and assist, any regional authority comprised of representatives of West Virginia State authorities and local government authorities in or any combination of the foregoing Nicholas, Fayette, Raleigh, Summers, Greenbrier, and Mercer Counties, West Virginia, for the purposes of providing for coordinated development and promotion of recreation resources of regional or national significance which are located in southern West Virginia and management by State or Federal agencies, including State, local and National Park System units, State and National Forest System units, and historic sites.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77825da7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Special Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/534/tIV/s402"},"text":"Pub. L. 100–534, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-26"},"text":"Oct. 26, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2707"},"text":"102 Stat. 2707","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/534/tIV/s402"},"text":"“Subject to his responsibilities to protect the natural resources of the National Park System, the Secretary of the Interior shall enter into a cooperative agreement with the State of West Virginia providing for the State’s regulation, in accordance with State law, of persons providing commercial recreational watercraft services on units of the National Park System and components of the National Wild and Scenic Rivers System subject to this Act [see Short Title of 1988 Amendment note above].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77825da8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Consolidated Management","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/534/tIV/s404"},"text":"Pub. L. 100–534, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-26"},"text":"Oct. 26, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2708"},"text":"102 Stat. 2708","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/534/tIV/s404"},"text":"“In order to achieve the maximum economy and efficiency of operations in the administration of the National Park System units established or expanded pursuant to this Act [see Short Title of 1988 Amendment note above], the Secretary shall consolidate offices and personnel administering all such units to the extent practicable and shall utilize the existing facilities of the New River Gorge National River [now New River Gorge National Park and Preserve] to the extent practicable.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77825da9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"New Spending Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/534/tIV/s405"},"text":"Pub. L. 100–534, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-26"},"text":"Oct. 26, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2708"},"text":"102 Stat. 2708","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/534/tIV/s405"},"text":"“Any new spending authority which is provided under this Act [see Short Title of 1988 Amendment note above] shall be effective for any fiscal year only to the extent or in such amounts as provided in appropriation Acts.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
