{"tag":"section","attrib":{"id":"id78d4f530-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s917c"},"text":null,"children":[{"tag":"num","attrib":{"value":"917c"},"text":"§ 917c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiations with Mexico and Canada","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce, through the Secretary of State, shall immediately initiate negotiations for the purpose of developing appropriate bilateral agreements with Mexico and Canada for the protection and conservation of whales.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78d4f531-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/532/s5"},"text":"Pub. L. 94–532, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2492"},"text":"90 Stat. 2492","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
