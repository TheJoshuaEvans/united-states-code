{"tag":"section","attrib":{"id":"id78d7405e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s951"},"text":null,"children":[{"tag":"num","attrib":{"value":"951"},"text":"§ 951.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78d7405f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s951/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antigua Convention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Antigua Convention” means the Convention for the Strengthening of the Inter-American Tropical Tuna Commission Established by the 1949 Convention Between the United States of America and the Republic of Costa Rica, signed at Washington, ","children":[{"tag":"date","attrib":{"date":"2003-11-14"},"text":"November 14, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d74060-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s951/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Inter-American Tropical Tuna Commission provided for by the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d74061-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s951/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Convention","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Convention” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78d74062-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s951/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Convention for the Establishment of an Inter-American Tropical Tuna Commission, signed at Washington, ","children":[{"tag":"date","attrib":{"date":"1949-05-31"},"text":"May 31, 1949","children":[],"tail":", by the United States of America and the Republic of Costa Rica;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78d74063-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s951/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Antigua Convention, upon its entry into force for the United States, and any amendments thereto that are in force for the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78d74064-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s951/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" both such Conventions, as the context requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d74065-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s951/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means an individual, partnership, corporation, or association subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"i