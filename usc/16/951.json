ext":"76 Stat. 923","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/81/tII/s203"},"text":"Pub. L. 114–81, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/660"},"text":"129 Stat. 660","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78d74069-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78d7406a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78d7406b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/81"},"text":"Pub. L. 114–81","children":[],"tail":" amended section generally. Prior to amendment, section defined terms for this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/814"},"text":"Pub. L. 87–814","children":[],"tail":" substituted definition of “United States” for definition of “enforcement agency”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78d7406c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id78d7406d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-07/ch907/s14"},"text":"Act Sept. 7, 1950, ch. 907, § 14","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/780"},"text":"64 Stat. 780","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1950-09-07/ch907/s14"},"text":"“This Act [this chapter] shall take effect with respect to each of the conventions upon the entry into force of that convention, unless such entry into force shall be prior to the date of approval of this Act [","children":[{"tag":"date","attrib":{"date":"1950-09-07"},"text":"Sept. 7, 1950","children":[],"tail":"] in which case this Act [this chapter] shall take effect immediately.”"}],"tail":"\n The Costa Rican convention was ratified on "},{"tag":"date","attrib":{"date":"1950-03-03"},"text":"March 3, 1950","children":[],"tail":", and the Mexican convention on "},{"tag":"date","attrib":{"date":"1950-07-11"},"text":"July 11, 1950","children":[],"tail":". Therefore, the act took effect upon its approval on "},{"tag":"date","attrib":{"date":"1950-09-07"},"text":"Sept. 7, 1950","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id78d7406e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/81/tII/s201"},"text":"Pub. L. 114–81, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/660"},"text":"129 Stat. 660","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/81/tII/s201"},"text":"“This title [amending sections 951 to 953, 955, 957, 959, and 962 of this title and repealing chapter 16B of this title and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s972"},"text":"section 972 of this title","children":[],"tail":"] may be cited as the ‘Antigua Convention Implementing Act of 2015’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id78d7406f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-07/ch907/s1"},"text":"Act Sept. 7, 1950, ch. 907, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/777"},"text":"64 Stat. 777","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1950-09-07/ch907/s1"},"text":"“That this Act [enacting this chapter] may be cited as the ‘Tuna Conventions Act of 1950’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"id78d74070-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-07/ch907/s13"},"text":"Act Sept. 7, 1950, ch. 907, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/780"},"text":"64 Stat. 780","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1950-09-07/ch907/s13"},"text":"“If any provision of this Act [this chapter] or the application of such provision to any circumstances or persons shall be held invalid, the validity of the remainder of the Act and the applicability of such provision to other circumstances or persons shall not be affected thereby.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78d74071-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Landing of Catch of Fish by Foreign Vessels","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/814/s6"},"text":"Pub. L. 87–814, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-15"},"text":"Oct. 15, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/926"},"text":"76 Stat. 926","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/87/814/s6"},"text":"“Nothing in this Act [amending this section and sections 955 to 957, 959 of this title] shall be construed to amend or repeal the provisions of section 4311 of the Revised Statutes, as amended ([former] 46 U.S.C. [App.] 251) [see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55114"},"text":"46 U.S.C. 55114","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
