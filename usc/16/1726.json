{"tag":"section","attrib":{"id":"id795ceaf2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1726"},"text":null,"children":[{"tag":"num","attrib":{"value":"1726"},"text":"§ 1726.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and terms of service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id795ceaf3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1726/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Living allowances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide each participant in the Public Lands Corps and each resource assistant with a living allowance in an amount established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795ceaf4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1726/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide a Corps participant with an educational credit that may be applied toward a program of postsecondary education at an institution of higher education that agrees to award the credit for participation in the Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795ceaf5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1726/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of service","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795ceaf6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1726/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each participant in the Corps and each resource assistant shall agree to participate in the Corps or serve as a resource assistant, as the case may be, for such term of service as may be established by the Secretary enrolling or selecting the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795ceaf7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1726/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Youth Service Corps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the Indian Youth Service Corps established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1727b"},"text":"section 1727b of this title","children":[],"tail":", the Secretary shall establish the term of service of participants in consultation with the affected Indian tribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795ceaf8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1726/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hiring","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795ceaf9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1726/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id795ceafa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1726/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant to a member of the Public Lands Corps credit for time served with the Public Lands Corps, which may be used toward future Federal hiring; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795ceafb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1726/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to a former member of the Public Lands Corps noncompetitive hiring status for a period of not more than 2 years after the date on which the member’s service with the Public Lands Corps is complete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795ceafc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1726/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time-limited appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s9602"},"text":"section 9602 of title 5","children":[],"tail":", a former member of the Corps hired by the Secretary under paragraph (1)(B) for a time-limited appointment shall be considered to be appointed initially under open, competitive examination."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795ceafd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1726/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to qualified youth or conservation corps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The hiring and compensation standards described in this section shall apply to any individual participating in an appropriate conservation project through a qualified youth or conservation corps, including an individual placed through a contract or cooperative agreement, as approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id795ceafe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/378/tII/s207"},"text":"Pub. L. 91–378, title II, § 207","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s105/6"},"text":"Pub. L. 103–82, title I, § 105(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/852"},"text":"107 Stat. 852","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/e"},"text":"Pub. L. 109–154, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-30"},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2892"},"text":"119 Stat. 2892","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/289/tIII/s302/3"},"text":"Pub. L. 114–289, title III, § 302(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1487"},"text":"130 Stat. 1487","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tIX/s9003/e"},"text":"Pub. L. 116–9, title IX, § 9003(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/834"},"text":"133 Stat. 834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795ceaff-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id795ceb00-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id795ceb01-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s9003/e/1"},"text":"Pub. L. 116–9, § 9003(e)(1)","children":[],"tail":", substituted “Compensation and terms of service” for “Living allowances and terms of service” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s9003/e/3"},"text":"Pub. L. 116–9, § 9003(e)(3)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s9003/e/4"},"text":"Pub. L. 116–9, § 9003(e)(4)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s9003/e/2"},"text":"Pub. L. 116–9, § 9003(e)(2)","children":[],"tail":", redesignated subsec. (b) as (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s9003/e/5"},"text":"Pub. L. 116–9, § 9003(e)(5)","children":[],"tail":", designated existing provisions as par. (1) and inserted heading, redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, of par. (1) and realigned margins, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s9003/e/2"},"text":"Pub. L. 116–9, § 9003(e)(2)","children":[],"tail":", redesignated subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s9003/e/6"},"text":"Pub. L. 116–9, § 9003(e)(6)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289"},"text":"Pub. L. 114–289","children":[],"tail":" substituted “2 years” for “120 days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/e/1"},"text":"Pub. L. 109–154, § 2(e)(1)","children":[],"tail":", added subsec. (a) and struck out heading and text of former subsec. (a). Text read as follows: “The Secretary of the Interior and the Secretary of Agriculture shall provide each participant in the Public Lands Corps and each resource assistant with a living allowance in an amount not to exceed the maximum living allowance authorized by section 140(a)(3) of the National and Community Service Act of 1990 for participants in a national service program assisted under subtitle C of title I of such Act.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/e/2"},"text":"Pub. L. 109–154, § 2(e)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id795f33f2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id795f33f3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as an Effective Date of 1993 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
