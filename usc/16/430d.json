{"tag":"section","attrib":{"id":"id77908f80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430d"},"text":null,"children":[{"tag":"num","attrib":{"value":"430d"},"text":"§ 430d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repair of roads; historical markers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall open or repair such roads in such park as may be necessary, and ascertain and mark with tablets or otherwise, as he may determine, all lines of battle of the American troops and British troops engaged in the Battle of Kings Mountain and other historical points of interest pertaining to the battle which are within the boundaries of the park. The Secretary is authorized to employ such labor and services and to obtain such supplies and materials as may be necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77908f81-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1931-03-03/ch437/s5"},"text":"Mar. 3, 1931, ch. 437, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1508"},"text":"46 Stat. 1508","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77908f82-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id77908f83-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id77908f84-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of administrative functions of park, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s430a"},"text":"section 430a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
