{"tag":"section","attrib":{"id":"id79369de2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447"},"text":null,"children":[{"tag":"num","attrib":{"value":"1447"},"text":"§ 1447.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this chapter is to establish regional research programs, under effective Federal oversight, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79369de3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set priorities for regional marine and coastal research in support of efforts to safeguard the water quality and ecosystem health of each region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369de4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1447/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such research through grants and improved coordination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79369de5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tIV/s401"},"text":"Pub. L. 92–532, title IV, § 401","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/593/tIII/s301"},"text":"Pub. L. 101–593, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2963"},"text":"104 Stat. 2963","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
