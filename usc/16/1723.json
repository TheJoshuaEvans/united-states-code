{"tag":"section","attrib":{"id":"id795ceaa0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723"},"text":null,"children":[{"tag":"num","attrib":{"value":"1723"},"text":"§ 1723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public Lands Corps program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id795ceaa1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Public Lands Corps","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795ceaa2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Department of the Interior, the Department of Agriculture, and the Department of Commerce a corps, to be known as the “Public Lands Corps”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795ceaa3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection precludes the establishment of a public lands corps by the head of a Federal department or agency other than a department described in paragraph (1), in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795ceaa4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corps shall consist of individuals between the ages of 16 and 30, inclusive, and veterans age 35 or younger who are enrolled as participants in the Corps by the Secretary. To be eligible for enrollment in the Corps, an individual shall satisfy the criteria specified in paragraphs (1), (2), (4), and (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12591/a"},"text":"section 12591(a) of title 42","children":[],"tail":". The Secretary may enroll such individuals in the Corps without regard to the civil service and classification laws, rules, or regulations of the United States. The Secretary may establish a preference for the enrollment in the Corps of individuals who are economically, physically, or educationally disadvantaged."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795ceaa5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified youth or conservation corps","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795ceaa6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to enter into contracts and cooperative agreements with any qualified youth or conservation corps to perform appropriate conservation projects referred to in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795ceaa7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id795ceaa8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of entering into contracts and cooperative agreements under paragraph (1), the Secretary may give preference to qualified youth or conservation corps located in a specific area that have a substantial portion of members who are economically, physically, or educationally disadvantaged to carry out projects within the area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795ceaa9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out priority projects in a specific area, the Secretary shall, to the maximum extent practicable, give preference to qualified youth or conservation corps located in that specific area that have a substantial portion of members who are economically, physically, or educationally disadvantaged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795ceaaa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects to be carried out","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795ceaab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may utilize the Corps or any qualified youth or conservation corps to carry out appropriate conservation projects which the Secretary is authorized to carry out under other authority of law on public lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795ceaac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects on Indian lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appropriate conservation projects may also be carried out under this subchapter on Indian lands with the approval of the Indian tribe involved and on Hawaiian home lands with the approval of the Department of Hawaiian Home Lands of the State of Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795ceaad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster prevention or relief projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may authorize appropriate conservation projects and other appropriate projects to be carried out on Federal, State, local, or private land as part of a Federal disaster prevention or relief effort.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795ceaae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference for certain projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting appropriate conservation projects to be carried out under this subchapter, the Secretary shall give preference to those projects which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795ceaaf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will provide long-term benefits to the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795ceab0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will instill in the enrollee involved a work ethic and a sense of public service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795ceab1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be labor intensive;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795ceab2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can be planned and initiated promptly; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795ceab3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will provide academic, experiential, or environmental education opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795ceab4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each appropriate conservation project carried out under this subchapter on eligible service lands shall be consistent with the provisions of law and policies relating to the management and administration of such lands, with all other applicable provisions of law, and with all management, operational, and other plans and documents which govern the administration of the area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795ceab5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1723/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section authorizes the use of the Public Lands Corps for projects on or impacting real property owned by, operated by, or within the custody, control, or administrative jurisdiction of the Administrator of General Services without the express permission of the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id795ceab6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/378/tII/s204"},"text":"Pub. L. 91–378, title II, § 204","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s105/6"},"text":"Pub. L. 103–82, title I, § 105(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/850"},"text":"107 Stat. 850","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/b"},"text":"Pub. L. 109–154, § 2(b)","children":[],"tail":", (c), (g)(1), "},{"tag":"date","attrib":{"date":"2005-12-30"},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2891"},"text":"119 Stat. 2891","children":[],"tail":", 2893; "},{"tag":"ref","attrib":{"href":"/us/pl/114/289/tIII/s302/2"},"text":"Pub. L. 114–289, title III, § 302(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1487"},"text":"130 Stat. 1487","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tIX/s9003/b"},"text":"Pub. L. 116–9, title IX, § 9003(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/833"},"text":"133 Stat. 833","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795ceab7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id795ceab8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id795ceab9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (a)(2), was in the original “this Act”, and was translated as reading “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/378"},"text":"Pub. L. 91–378","children":[],"tail":", known as the Public Lands Corps Act of 1993, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id795ceaba-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s9003/b/1"},"text":"Pub. L. 116–9, § 9003(b)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “There is hereby established in the Department of the Interior and the Department of Agriculture a Public Lands Corps.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s9003/b/2"},"text":"Pub. L. 116–9, § 9003(b)(2)","children":[],"tail":", substituted “individuals between the ages of 16 and 30, inclusive, and veterans age 35 or younger” for “individuals between the ages of 16 and 30, inclusive,” and “paragraphs (1), (2), (4), and (5) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12591/a"},"text":"section 12591(a) of title 42","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12591/b"},"text":"section 12591(b) of title 42","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s9003/b/3"},"text":"Pub. L. 116–9, § 9003(b)(3)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289"},"text":"Pub. L. 114–289","children":[],"tail":" substituted “30” for “25”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/g/1/A"},"text":"Pub. L. 109–154, § 2(g)(1)(A)","children":[],"tail":", substituted “Corps by the Secretary” for “Corps by the Secretary of the Interior or the Secretary of Agriculture” and “Secretary may” for “Secretaries may” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/b"},"text":"Pub. L. 109–154, § 2(b)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, substituted “The Secretary is” for “The Secretary of the Interior and the Secretary of Agriculture are”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/c"},"text":"Pub. L. 109–154, § 2(c)","children":[],"tail":", designated first sentence as par. (1), inserted heading, and substituted “The Secretary may” for “The Secretary of the Interior and the Secretary of Agriculture may each” and “the Secretary” for “such Secretary”, designated second sentence as par. (2) and inserted heading, added par. (3), and struck out former third sentence which read “The Secretaries may also authorize appropriate conservation projects and other appropriate projects to be carried out on Federal, State, local, or private lands as part of disaster prevention or relief efforts in response to an emergency or major disaster declared by the President under the Robert T. Stafford Disaster Relief and Emergency Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/g/1/B"},"text":"Pub. L. 109–154, § 2(g)(1)(B)","children":[],"tail":", substituted “Secretary” for “Secretary of the Interior and the Secretary of Agriculture” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id795ceabb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id795ceabc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as an Effective Date of 1993 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
