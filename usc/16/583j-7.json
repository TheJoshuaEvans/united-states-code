{"tag":"section","attrib":{"id":"id7851bc3d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"583j–7"},"text":"§ 583j–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities of Foundation and United States Forest Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The activities of the Foundation authorized under the provisions of this Act shall be supplemental to and shall not preempt any authority or responsibility of the United States Forest Service under any other provision of law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7851bc3e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/593/tIV/s409"},"text":"Pub. L. 101–593, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2973"},"text":"104 Stat. 2973","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7851bc3f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7851bc40-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7851bc41-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/593"},"text":"Pub. L. 101–593","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2954"},"text":"104 Stat. 2954","children":[],"tail":", which enacted this subchapter, chapter 32A of this title, and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s777e–1"},"text":"section 777e–1 of this title","children":[],"tail":", amended sections 2910, 3702, 3709, 4403, and 4404 of this title, and enacted provisions listed in a table of National Environmental Centers set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s668dd"},"text":"section 668dd of this title","children":[],"tail":" and provisions set out in notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3701"},"text":"section 3701 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":", The Public Health and Welfare. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
