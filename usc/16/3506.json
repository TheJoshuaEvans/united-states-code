{"tag":"section","attrib":{"id":"id79be91eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3506"},"text":null,"children":[{"tag":"num","attrib":{"value":"3506"},"text":"§ 3506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of compliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79be91ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2024-11-25"},"text":"November 25, 2024","children":[],"tail":", the head of each Federal agency affected by this chapter shall revise or issue regulations and guidance as necessary to ensure compliance with the provisions of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79be91ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of each Federal agency affected by this chapter shall report and certify that each such agency is in compliance with the provisions of this chapter. Such reports and certifications shall be submitted annually to the Committees and the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79be91ee-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/348/s7"},"text":"Pub. L. 97–348, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-18"},"text":"Oct. 18, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1657"},"text":"96 Stat. 1657","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/591/s14"},"text":"Pub. L. 101–591, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2941"},"text":"104 Stat. 2941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/117/tI/s105/a"},"text":"Pub. L. 118–117, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-11-25"},"text":"Nov. 25, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1612"},"text":"138 Stat. 1612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79be91ef-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79be91f0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79be91f1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/117"},"text":"Pub. L. 118–117","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “Not later than 12 months after "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":", the head of each Federal agency affected by this chapter shall promulgate regulations to assure compliance with the provisions of this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/591"},"text":"Pub. L. 101–591","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The Director of the Office of Management and Budget shall, on behalf of each Federal agency concerned, make written certification that each such agency has complied with the provisions of this chapter during each fiscal year beginning after "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":". Such certification shall be submitted on an annual basis to the House of Representatives and the Senate pursuant to the schedule required under the Congressional Budget and Impoundment Control Act of 1974.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79be91f2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79be91f3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (b) of this section relating to annually submitting reports and certifications to the Committee on Resources of the House of Representatives and the Committee on Environment and Public Works of the Senate, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 42 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
