{"tag":"section","attrib":{"id":"id79e4b7e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3923"},"text":null,"children":[{"tag":"num","attrib":{"value":"3923"},"text":"§ 3923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on use of eminent domain in acquisitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The powers of condemnation or eminent domain shall not be used in the acquisition of wetlands under any provision of this chapter where such wetlands have been constructed for the purpose of farming or ranching, or result from conservation activities associated with farming or ranching.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79e4b7ea-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/645/tIII/s305"},"text":"Pub. L. 99–645, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3588"},"text":"100 Stat. 3588","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e4b7eb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e4b7ec-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79e4b7ed-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/645"},"text":"Pub. L. 99–645","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3582"},"text":"100 Stat. 3582","children":[],"tail":", known as the Emergency Wetlands Resources Act of 1986. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3901"},"text":"section 3901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
