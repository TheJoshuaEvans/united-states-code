{"tag":"section","attrib":{"id":"id7a2eb9d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7912"},"text":null,"children":[{"tag":"num","attrib":{"value":"7912"},"text":"§ 7912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal land open to hunting, fishing, and recreational shooting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2eb9d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), Federal land shall be open to hunting, fishing, and recreational shooting, in accordance with applicable law, unless the Secretary concerned closes an area in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7913"},"text":"section 7913 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2eb9d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of part","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter opens to hunting, fishing, or recreational shooting any land that is not open to those activities as of ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2eb9d6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tIV/s4102"},"text":"Pub. L. 116–9, title IV, § 4102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/757"},"text":"133 Stat. 757","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
