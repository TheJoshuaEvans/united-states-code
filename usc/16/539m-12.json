{"tag":"section","attrib":{"id":"id7835332d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"539m–12"},"text":"§ 539m–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out sections 539m to 539m–12 of this title, including such sums as are necessary for the Forest Service to carry out responsibilities of the Forest Service in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–11/c"},"text":"section 539m–11(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7835332e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tIV/s414"},"text":"Pub. L. 108–7, div. F, title IV, § 414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/294"},"text":"117 Stat. 294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7835332f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78353330-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78353331-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 539m to 539m–12 of this title, referred to in text, was in the original “this title”, meaning title IV of div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/279"},"text":"117 Stat. 279","children":[],"tail":", which is classified generally to sections 539m to 539m–12 of this title. For complete classification of title IV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m"},"text":"section 539m of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
