{"tag":"section","attrib":{"id":"id7a0167c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609"},"text":null,"children":[{"tag":"num","attrib":{"value":"5609"},"text":"§ 5609.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0167c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1982 Convention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “1982 Convention” means the United Nations Convention on the Law of the Sea of 10 December 1982.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized enforcement officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “authorized enforcement officer” means a person authorized to enforce this chapter, any regulation issued under this chapter, or any measure that is legally binding on the United States under the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the body provided for by Articles V, VI, XIII, XIV, and XV of the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commissioner” means a United States Commissioner to the Northwest Atlantic Fisheries Organization appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5601"},"text":"section 5601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Convention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Convention” means the Convention on Future Multilateral Cooperation in the Northwest Atlantic Fisheries, done at Ottawa on ","children":[{"tag":"date","attrib":{"date":"1978-10-24"},"text":"October 24, 1978","children":[],"tail":", and as amended on "},{"tag":"date","attrib":{"date":"2007-09-28"},"text":"September 28, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Convention Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Convention Area” means the waters of the Northwest Atlantic Ocean north of 35°00′ N and west of a line extending due north from 35°00′ N and 42°00′ W to 59°00′ N, thence due west to 44°00′ W, and thence due north to the coast of Greenland, and the waters of the Gulf of St. Lawrence, Davis Strait and Baffin Bay south of 78°10′ N.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Council” means the New England Fishery Management Council or the Mid-Atlantic Fishery Management Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishery resources","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0167c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fishery resources” means all fish, mollusks, and crustaceans, including any products thereof, within the Convention Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0167ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “fishery resources” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a0167cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sedentary species over which coastal States may exercise sovereign rights consistent with Article 77 of the 1982 Convention; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0167cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insofar as they are managed under other international treaties, anadromous and catadromous stocks and highly migratory species listed in Annex I of the 1982 Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishing activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0167ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fishing activities” means harvesting or processing fishery resources, or transhipping ","children":[{"tag":"ref","attrib":{"idref":"fn002814"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002814"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “transshipping”."}],"tail":" of fishery resources or products derived from fishery resources, or any other activity in preparation for, in support of, or related to the harvesting of fishery resources."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0167cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “fishing activities” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a0167d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual or attempted searching for or catching or taking of fishery resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0167d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity that can reasonably be expected to result in locating, catching, taking, or harvesting of fishery resources for any purpose; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0167d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/9/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any operation at sea in support of, or in preparation for, any activity described in this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0167d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fishing activities” does not include any operation related to emergencies involving the health and safety of crew members or the safety of a vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishing vessel","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0167d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fishing vessel” means a vessel that is or has been engaged in fishing activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0167d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fishing vessel” includes a fish processing vessel or a vessel engaged in transshipment or any other activity in preparation for or related to fishing activities, or in experimental or exploratory fishing activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Organization” means the Northwest Atlantic Fisheries Organization provided for by Article V of the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means any individual (whether or not a citizen or national of the United States), and any corporation, partnership, association, or other entity (whether or not organized or existing under the laws of any State).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Representative” means a United States Representative to the Northwest Atlantic Fisheries Scientific Council appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5601"},"text":"section 5601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Scientific Council” means the Scientific Council provided for by Articles V, VI, and VII of the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States of the United States, the District of Columbia, and any other commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5609/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transshipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “transshipment” means the unloading of all or any of the fishery resources on board a fishing vessel to another fishing vessel either at sea or in port.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0167de-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tII/s210"},"text":"Pub. L. 104–43, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/381"},"text":"109 Stat. 381","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/384/tII/s201/b/3"},"text":"Pub. L. 105–384, title II, § 201(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3451"},"text":"112 Stat. 3451","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/327/tV/s508"},"text":"Pub. L. 114–327, title V, § 508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1996"},"text":"130 Stat. 1996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0167df-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0167e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a0167e1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327"},"text":"Pub. L. 114–327","children":[],"tail":" amended section generally. Prior to amendment, section defined terms for this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/384"},"text":"Pub. L. 105–384","children":[],"tail":" substituted “Magnuson-Stevens Fishery” for “Magnuson Fishery”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
