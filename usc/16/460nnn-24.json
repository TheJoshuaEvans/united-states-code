{"tag":"section","attrib":{"id":"id7800b5ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–24"},"text":null,"children":[{"tag":"num","attrib":{"value":"460nnn–24"},"text":"§ 460nnn–24.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7800b5ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–24/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b5f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–24/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the land acquisitions authorized by part F, the Secretary may acquire other non-Federal lands and interests in lands located within the boundaries of the Cooperative Management and Protection Area or the Wilderness Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b5f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–24/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition methods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Lands may be acquired under this subsection only by voluntary exchange, donation, or purchase from willing sellers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b5f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–24/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of acquired lands","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b5f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–24/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraphs (2) and (3), lands or interests in lands acquired under subsection (a) or part F that are located within the boundaries of the Cooperative Management and Protection Area shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7800b5f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–24/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" become part of the Cooperative Management and Protection Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7800b5f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–24/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be managed pursuant to the laws applicable to the Cooperative Management and Protection Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b5f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–24/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands within Wilderness Area","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If lands or interests in lands acquired under subsection (a) or part F are within the boundaries of the Wilderness Area, the acquired lands or interests in lands shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7800b5f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–24/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" become part of the Wilderness Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7800b5f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–24/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be managed pursuant to part B and the other laws applicable to the Wilderness Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b5f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–24/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands within wilderness study area","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the lands or interests in lands acquired under subsection (a) or part F are within the boundaries of a wilderness study area, the acquired lands or interests in lands shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7800b5fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–24/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" become part of that wilderness study area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7800b5fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–24/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be managed pursuant to the laws applicable to that wilderness study area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b5fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–24/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appraisal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In appraising non-Federal land, development rights, or conservation easements for possible acquisition under this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn–42"},"text":"section 460nnn–42 of this title","children":[],"tail":", the Secretary shall disregard any adverse impacts on values resulting from the designation of the Cooperative Management and Protection Area or the Wilderness Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7800b5fd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399/tI/s114"},"text":"Pub. L. 106–399, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1662"},"text":"114 Stat. 1662","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
