{"tag":"section","attrib":{"id":"id7a29fe86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7406"},"text":null,"children":[{"tag":"num","attrib":{"value":"7406"},"text":"§ 7406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is unlawful for any person subject to the jurisdiction of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29fe87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7406/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to violate any provision of this chapter or the regulations issued under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7406/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to refuse to permit any authorized officer to board, search, or inspect a vessel that is subject to the person’s control in connection with the enforcement of this chapter or the regulations issued under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7406/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to submit false information pursuant to any requirement under this chapter or the regulations issued under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7406/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to commi