{"tag":"section","attrib":{"id":"id7a2c4926-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7708"},"text":null,"children":[{"tag":"num","attrib":{"value":"7708"},"text":"§ 7708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territorial participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall ensure participation in the Commission and its subsidiary bodies by the Commonwealth of the Northern Mariana Islands, American Samoa, and Guam to the extent allowed under United States law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a2c4927-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/tI/s108"},"text":"Pub. L. 114–327, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1984"},"text":"130 Stat. 1984","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
