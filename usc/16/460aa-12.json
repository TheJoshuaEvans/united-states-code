{"tag":"section","attrib":{"id":"id77d364e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aa–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"460aa–12"},"text":"§ 460aa–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; availability of land and water conservation fund money","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for the purposes of this subchapter not more than $47,802,000 for the acquisition of lands and interests in lands and not more than $26,241,000 for development. Money appropriated from the land and water conservation fund shall be available for the acquisition of lands, waters, and interests therein within the recreation area.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77d364e9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/400/s13"},"text":"Pub. L. 92–400, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-22"},"text":"Aug. 22, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/615"},"text":"86 Stat. 615","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tII/s202"},"text":"Pub. L. 95–625, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3473"},"text":"92 Stat. 3473","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77d364ea-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77d364eb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77d364ec-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Pub. L. 95–625","children":[],"tail":" increased land acquisition appropriations authorization to $47,802,000 from $19,802,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
