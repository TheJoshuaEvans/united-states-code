{"tag":"section","attrib":{"id":"id7883c87a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718a"},"text":null,"children":[{"tag":"num","attrib":{"value":"718a"},"text":"§ 718a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on taking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7883c87b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7883c87c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), no individual who has attained the age of 16 years shall take any migratory waterfowl unless, at the time of the taking, the individual carries on the person of the individual a valid Migratory Bird Hunting and Conservation Stamp, as an electronic stamp (as defined in section 718","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title) or validated by the signature of the individual written in ink across the face of the actual stamp (as defined in that section) prior to the time of the taking by the individual of the waterfowl."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7883c87d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No stamp described in paragraph (1) shall be required for the taking of migratory waterfowl—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7883c87e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by Federal or State agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7883c87f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for propagation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7883c880-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the resident owner, tenant, or sharecropper of the property, or officially designated agencies of the Department of the Interior, for the killing, under such restrictions as the Secretary may by regulation prescribe, of such waterfowl when found damaging crops or other property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7883c881-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a rural Alaska resident for subsistence uses (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3113"},"text":"section 3113 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7883c882-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Display of stamp","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any individual to whom a stamp has been sold under this subchapter shall, upon request, display the stamp for inspection to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7883c883-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any officer or employee of the Department of the Interior who is authorized to enforce this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7883c884-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any officer of any State or political subdivision of a State authorized to enforce State game laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7883c885-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other licenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section requires any individual to affix the Migratory Bird Hunting and Conservation Stamp to any other license prior to taking 1 or more migratory waterfowl.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7883c886-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-03-16/ch71/s1"},"text":"Mar. 16, 1934, ch. 71, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/451"},"text":"48 Stat. 451","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-06-15/ch261"},"text":"June 15, 1935, ch. 261","children":[],"tail":", title I, § 1, "},{"tag":"ref","attrib":{"href":"/us/stat/49/378"},"text":"49 Stat. 378","children":[],"tail":"; 1939 Reorg. Plan No. II, § 4(f), eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2731, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1433"},"text":"53 Stat. 1433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-30/ch782/s1"},"text":"July 30, 1956, ch. 782, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/722"},"text":"70 Stat. 722","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/215/s3/a"},"text":"Pub. L. 94–215, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-02-17"},"text":"Feb. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/189"},"text":"90 Stat. 189","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/266/s10/a"},"text":"Pub. L. 109–266, § 10(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-03"},"text":"Aug. 3, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/674"},"text":"120 Stat. 674","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/264/s4"},"text":"Pub. L. 113–264, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2940"},"text":"128 Stat. 2940","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/25/s2/d"},"text":"Pub. L. 118–25, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-19"},"text":"Dec. 19, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/130"},"text":"137 Stat. 130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7883c887-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7883c888-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7883c889-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/25"},"text":"Pub. L. 118–25","children":[],"tail":" inserted “as an electronic stamp (as defined in section 718"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title) or” after “Conservation Stamp,” and substituted “face of the actual stamp (as defined in that section)” for “face of the stamp”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/264"},"text":"Pub. L. 113–264","children":[],"tail":" added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/266"},"text":"Pub. L. 109–266","children":[],"tail":" amended section generally. Prior to amendment, section related to hunting and conservation stamp for taking migratory waterfowl."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/215"},"text":"Pub. L. 94–215","children":[],"tail":" substituted “hunting and conservation stamp” for “hunting stamp” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-07-30"},"text":"July 30, 1956","children":[],"tail":", substituted “no person who has attained the age of sixteen years”, for “no person over sixteen years of age”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1935—Act ","children":[{"tag":"date","attrib":{"date":"1935-06-15"},"text":"June 15, 1935","children":[],"tail":", substituted “validated by his signature written by himself in ink across the face of the stamp prior to his taking such birds” for “issued to him in the manner hereinafter provided,” and struck out provisions which authorized the Secretary of Agriculture to adopt and promulgate regulations for the protection of private property in the injury of crops."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7883c88a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id7883c88b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reorg. Plan No. II of 1939, set out in the Appendix to Title 5, Government Organization and Employees, transferred functions of Secretary of Agriculture relating to conservation of wildlife, game, and migratory birds to Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
