{"tag":"section","attrib":{"id":"id77719573-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"410hhh–4"},"text":"§ 410hhh–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Baca National Wildlife Refuge, Colorado","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77719574-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77719575-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77719576-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–4/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When the Secretary determines that sufficient land has been acquired to constitute an area that can be efficiently managed as a National Wildlife Refuge, the Secretary shall establish the Baca National Wildlife Refuge, as generally depicted on the map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77719577-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–4/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The establishment of the refuge under subparagraph (A) shall be effective upon publication of a notice of the Secretary’s determination in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77719578-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the Baca National Wildlife Refuge shall be to restore, enhance, and maintain wetland, upland, riparian, and other habitats for native wildlife, plant, and fish species in the San Luis Valley.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77719579-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map shall be on file and available for public inspection in the appropriate offices of the United States Fish and Wildlife Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7771957a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7771957b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–4/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer all lands and interests therein acquired within the boundaries of the national wildlife refuge in accordance with the National Wildlife Refuge System Administration Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s668dd"},"text":"16 U.S.C. 668dd","children":[],"tail":" et seq.) and the Act of "},{"tag":"date","attrib":{"date":"1962-09-28"},"text":"September 28, 1962","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460k"},"text":"16 U.S.C. 460k","children":[],"tail":" et seq.) (commonly known as the Refuge Recreation Act)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7771957c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–4/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In administering the Baca National Wildlife Refuge, the Secretary shall, to the maximum extent practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7771957d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–4/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emphasize migratory bird conservation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7771957e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–4/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration the role of the Refuge in broader landscape conservation efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7771957f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of water resources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In administering water resources for the national wildlife refuge, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77719580-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–4/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect and maintain irrigation water rights necessary for the protection of monument, park, preserve, and refuge resources and uses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77719581-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–4/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize, to the extent consistent with the protection of national wildlife refuge resources, adverse impacts on other water users; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77719582-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–4/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to any agreement in existence as of ","children":[{"tag":"date","attrib":{"date":"2009-03-11"},"text":"March 11, 2009","children":[],"tail":", and to the extent consistent with the purposes of the Refuge, use decreed water rights on the Refuge in approximately the same manner that the water rights have been used historically."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77719583-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/530/s6"},"text":"Pub. L. 106–530, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2530"},"text":"114 Stat. 2530","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/8/dE/tI/s117"},"text":"Pub. L. 111–8, div. E, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/724"},"text":"123 Stat. 724","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77719584-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77719585-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77719586-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Wildlife Refuge System Administration Act of 1966, referred to in subsec. (c)(1), consists of sections 4 and 5 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/669"},"text":"Pub. L. 89–669","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/927"},"text":"80 Stat. 927","children":[],"tail":", and is classified to sections 668dd and 668ee of this title. For further details, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s668dd"},"text":"section 668dd of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1962-09-28"},"text":"September 28, 1962","children":[],"tail":", referred to in subsec. (c)(1), is "},{"tag":"ref","attrib":{"href":"/us/pl/87/714"},"text":"Pub. L. 87–714","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-28"},"text":"Sept. 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/653"},"text":"76 Stat. 653","children":[],"tail":", popularly known as the Refuge Recreation Act, which is classified generally to subchapter LXVIII (§ 460k et seq.) of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77719587-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8/s117/1"},"text":"Pub. L. 111–8, § 117(1)","children":[],"tail":", substituted “Establishment and purpose” for “Establishment” in heading, designated existing provisions as par. (1) and inserted heading, redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, and inserted headings, substituted “The establishment of the refuge under subparagraph (A)” for “Such establishment” in subpar. (B), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8/s117/2"},"text":"Pub. L. 111–8, § 117(2)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8/s117/3"},"text":"Pub. L. 111–8, § 117(3)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
