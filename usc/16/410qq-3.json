{"tag":"section","attrib":{"id":"id775e81db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410qq–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410qq–3"},"text":"§ 410qq–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Native American Samoan” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter the term “native American Samoan” means a person who is a citizen or national of the United States and who is a lineal descendant of an inhabitant of the Samoan Islands on ","children":[{"tag":"date","attrib":{"date":"1900-04-18"},"text":"April 18, 1900","children":[],"tail":". For purposes of this subchapter, Swains Island shall be considered part of the Samoan Islands."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id775e81dc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/571/s4"},"text":"Pub. L. 100–571, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2882"},"text":"102 Stat. 2882","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
