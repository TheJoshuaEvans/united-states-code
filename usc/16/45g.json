{"tag":"section","attrib":{"id":"id76f5ae26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s45g"},"text":null,"children":[{"tag":"num","attrib":{"value":"45g"},"text":"§ 45g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Addition to Sequoia National Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id76f5ae27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s45g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2000-12-28"},"text":"December 28, 2000","children":[],"tail":", the Secretary of the Interior shall acquire by donation, purchase with donated or appropriated funds, or exchange, all interest in and to the land described in subsection (b) for addition to Sequoia National Park, California."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id76f5ae28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s45g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquired","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The land referred to in subsection (a) is the land depicted on the map entitled “Dillonwood”, numbered 102/80,044, and dated September 1999.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id76f5ae29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s45g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Addition to park","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon acquisition of the land under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id76f5ae2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s45g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of the Interior shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id76f5ae2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s45g/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modify the boundaries of Sequoia National Park to include the land within the park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id76f5ae2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s45g/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer the land as part of Sequoia National Park in accordance with all applicable laws; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id76f5ae2d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s45g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture shall modify the boundaries of the Sequoia National Forest to exclude the land from the forest boundaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id76f5ae2e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/574/s1"},"text":"Pub. L. 106–574, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-28"},"text":"Dec. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/3062"},"text":"114 Stat. 3062","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
