{"tag":"section","attrib":{"id":"id78032731-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ppp–3"},"text":"§ 460ppp–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78032732-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Bureau of Land Management, shall manage the conservation area in a manner that conserves, protects, and enhances its resources and values, including those resources and values specified in subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002387"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002387"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 460ppp–2(a) of this title, in accordance with this subchapter, the Federal Land Policy and Management Act of 1976 ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.), and other applicable provisions of law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78032733-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78032734-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain adequate access for the reasonable use and enjoyment of the conservation area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78032735-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide reasonable access to privately owned land or interests in land within the boundaries of the conservation area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78032736-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing public roads","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to maintain existing public access within the boundaries of the conservation area in a manner consistent with the purposes for which the conservation area was established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78032737-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78032738-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall only allow such uses of the conservation area as the Secretary finds will further the purposes for which the conservation area is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78032739-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Off-highway vehicle use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except where needed for administrative purposes or to respond to an emergency, use of motorized vehicles in the conservation area shall be permitted only on roads and trails and in other areas designated for use of motorized vehicles as part of the management plan prepared pursuant to subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7803273a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–3/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted events","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may continue to permit large-scale events in defined, low impact areas of the Black Rock Desert playa in the conservation area in accordance with the management plan prepared pursuant to subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7803273b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting, trapping, and fishing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be deemed to diminish the jurisdiction of the State of Nevada with respect to fish and wildlife management, including regulation of hunting and fishing, on public lands within the conservation area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7803273c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within three years following ","children":[{"tag":"date","attrib":{"date":"2000-12-21"},"text":"December 21, 2000","children":[],"tail":", the Secretary shall develop a comprehensive resource management plan for the long-term protection and management of the conservation area. The plan shall be developed with full public participation and shall describe the appropriate uses and management of the conservation area consistent with the provisions of this subchapter. The plan may incorporate appropriate decisions contained in any current management or activity plan for the area and may use information developed in previous studies of the lands within or adjacent to the conservation area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7803273d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–3/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where the Secretary of the Interior currently permits livestock grazing in the conservation area, such grazing shall be allowed to continue subject to all applicable laws, regulations, and executive orders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7803273e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–3/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visitor service facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish, in cooperation with other public or private entities as the Secretary may deem appropriate, visitor service facilities for the purpose of providing information about the historical, cultural, ecological, recreational, and other resources of the conservation area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7803273f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ppp–3/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Road maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within the conservation area the Secretary may permit the use of gravel pits for the maintenance of roads within the conservation area under the Materials Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s601"},"text":"30 U.S.C. 601","children":[],"tail":" et seq.) to the extent consistent with this subchapter and subject to such regulations, policies, and practices as the Secretary considers necessary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78032740-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s125"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 125 [§ 5]","children":[],"tail":"], "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–229, 2763A–354; "},{"tag":"ref","attrib":{"href":"/us/pl/107/63/tI/s135/b"},"text":"Pub. L. 107–63, title I, § 135(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-05"},"text":"Nov. 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/443"},"text":"115 Stat. 443","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78032741-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78032742-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78032743-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Materials Act of 1947, referred to in subsec. (h), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-31/ch406"},"text":"act July 31, 1947, ch. 406","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/681"},"text":"61 Stat. 681","children":[],"tail":", which is classified generally to subchapter I (§ 601 et seq.) of chapter 15 of Title 30, Mineral Lands and Mining. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s601"},"text":"section 601 of Title 30","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78032744-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/63"},"text":"Pub. L. 107–63","children":[],"tail":" added subsec. (h)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
