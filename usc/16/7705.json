{"tag":"section","attrib":{"id":"id7a2c48ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705"},"text":null,"children":[{"tag":"num","attrib":{"value":"7705"},"text":"§ 7705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2c48f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary and the Secretary of the department in which the Coast Guard is operating—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2c48f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall administer and enforce this chapter and any regulations issued under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c48f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may request and utilize on a reimbursed or nonreimbursed basis the assistance, services, personnel, equipment, and facilities of other Federal departments and agencies in the administration and enforcement of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2c48f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Secretary of the department in which the Coast Guard is operating shall prevent any person from violating this chapter with respect to fishing activities or the conservation of fisheries resources in the Convention Area in the same manner, by the same means, and with the same jurisdiction, powers, and duties as though sections 308 through 311 of the Magnuson-Stevens Fishery Conservation and Management Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1858"},"text":"16 U.S.C. 1858","children":[],"tail":", 1859, 1860, and 1861) were incorporated into and made a part of this chapter. Any person that violates this chapter is subject to the penalties and entitled to the privileges and immunities provided in the Magnuson-Stevens Fishery Conservation and Management Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"16 U.S.C. 1801","children":[],"tail":" et seq.) in the same manner, by the same means, and with the same jurisdiction, power, and duties as though sections 308 through 311 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1858"},"text":"16 U.S.C. 1858","children":[],"tail":", 1859, 1860, and 1861) were incorporated into and made a part of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2c48f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of the courts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2c48f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraphs (2) and (3), the district courts of the United States shall have jurisdiction over any case or controversy arising under this chapter, and any such court may at any time—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2c48f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter restraining orders or prohibitions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c48f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue warrants, process in rem, or other process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c48f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe and accept satisfactory bonds or other security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c48f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such other actions as are in the interest of justice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c48fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hawaii and Pacific insular areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of Hawaii or any possession of the United States in the Pacific Ocean, the appropriate court is the United States District Court for the District of Hawaii, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2c48fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of Guam and Wake Island, the appropriate court is the United States District Court for the District of Guam; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c48fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the Northern Mariana Islands, the appropriate court is the United States District Court for the District of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c48fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each violation shall be a separate offense and the offense is deemed to have been committed not only in the district where the violation first occurred, but also in any other district authorized by law. Any offense not committed in any district is subject to the venue provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3238"},"text":"section 3238 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2c48fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2c48ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any information submitted to the Secretary in compliance with any requirement under this chapter, and information submitted under any requirement of this chapter that may be necessary to implement the Convention, including information submitted before ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", shall be confidential and may not be disclosed, except—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2c4900-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a Federal employee who is responsible for administering, implementing, or enforcing this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c4901-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Commission, in accordance with requirements in the North Pacific Fisheries Convention and decisions of the Commission, and, insofar as possible, in accordance with an agreement with the Commission that prevents public disclosure of the identity or business of any person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c4902-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to State, Council, or marine fisheries commission employees pursuant to an agreement with the Secretary that prevents public disclosure of the identity or business of any person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c4903-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when required by court order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c4904-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the Secretary has obtained written authorization from the person submitting such information to release such information to another person for a reason not otherwise provided for in this paragraph, and such release does not violate other requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c4905-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2c4906-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the Secretary shall promulgate regulations regarding the procedures the Secretary considers necessary to preserve the confidentiality of information submitted under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c4907-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may release or make public information submitted under this chapter if the information is in any aggregate or summary form that does not directly or indirectly disclose the identity or business of any person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c4908-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7705/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be interpreted or construed to prevent the use for conservation and management purposes by the Secretary of any information submitted under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2c4909-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/tI/s105"},"text":"Pub. L. 114–327, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1980"},"text":"130 Stat. 1980","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a2c490a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a2c490b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a2c490c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Magnuson-Stevens Fishery Conservation and Management Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/331"},"text":"90 Stat. 331","children":[],"tail":", which is classified principally to chapter 38 (§ 1801 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
