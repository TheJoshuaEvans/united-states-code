{"tag":"section","attrib":{"id":"id7a120a1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591"},"text":null,"children":[{"tag":"num","attrib":{"value":"6591"},"text":"§ 6591.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest stands inventory and monitoring program to improve detection of and response to environmental threats","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a120a20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall carry out a comprehensive program to inventory, monitor, characterize, assess, and identify forest stands (with emphasis on hardwood forest stands) and potential forest stands—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in units of the National Forest System (other than those units created from the public domain); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on private forest land, with the consent of the owner of the land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issues to be addressed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the Secretary shall address issues including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early detection, identification, and assessment of environmental threats (including insect, disease, invasive species, fire, and weather-related risks and other episodic events);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loss or degradation of forests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" degradation of the quality forest stands caused by inadequate forest regeneration practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantification of carbon uptake rates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management practices that focus on preventing further forest degradation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early warning system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the Secretary shall develop a comprehensive early warning system for potential catastrophic environmental threats to forests to increase the likelihood that forest managers will be able to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" isolate and treat a threat before the threat gets out of control; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent epidemics, such as the American chestnut blight in the first half of the twentieth century, that could be environmentally and economically devastating to forests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2004 through 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a120a2d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tVI/s601"},"text":"Pub. L. 108–148, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1914"},"text":"117 Stat. 1914","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
