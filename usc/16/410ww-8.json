{"tag":"section","attrib":{"id":"id7760f419-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ww–8"},"text":"§ 410ww–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated such sums as may be necessary to carry out this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7760f41a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/419/tI/s109"},"text":"Pub. L. 102–419, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2143"},"text":"106 Stat. 2143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/356/s2/b"},"text":"Pub. L. 106–356, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-24"},"text":"Oct. 24, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1391"},"text":"114 Stat. 1391","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7760f41b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7760f41c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7760f41d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/356"},"text":"Pub. L. 106–356","children":[],"tail":" struck out “: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the amount to be appropriated for the operation, development or restoration of non-federally owned properties within the boundaries of the park shall not exceed $200,000” after “this part”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
