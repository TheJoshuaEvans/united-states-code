{"tag":"section","attrib":{"id":"id7845d57f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s559a"},"text":null,"children":[{"tag":"num","attrib":{"value":"559a"},"text":"§ 559a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reward for information leading to arrest and conviction for violating laws and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may pay rewards from appropriations available for the protection and management of the national forests, under such regulations as he may prescribe, for information leading to the arrest and conviction for violation of the laws and regulations relating to fires in or near national forests, or for the unlawful taking of, or injury to, Government property.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7845d580-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-09-21/ch412"},"text":"Sept. 21, 1944, ch. 412","children":[],"tail":", title II, § 201, "},{"tag":"ref","attrib":{"href":"/us/stat/58/736"},"text":"58 Stat. 736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7845d581-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7845d582-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7845d583-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as a part of the Department of Agriculture Organic Act of 1944.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
