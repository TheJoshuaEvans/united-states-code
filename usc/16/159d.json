{"tag":"section","attrib":{"id":"id770b0a8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s159d"},"text":null,"children":[{"tag":"num","attrib":{"value":"159d"},"text":"§ 159d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of General Philip Schuyler Mansion property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to accept all or any portion of the General Philip Schuyler Mansion property, real and personal, situated at Schuylerville, New York, comprising approximately fifty acres.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id770b0a8f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-22/ch594/s2"},"text":"June 22, 1948, ch. 594, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/571"},"text":"62 Stat. 571","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/460/s3"},"text":"Pub. L. 97–460, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2522"},"text":"96 Stat. 2522","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id770b0a90-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id770b0a91-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id770b0a92-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/460"},"text":"Pub. L. 97–460","children":[],"tail":" struck out provisions which authorized the Secretary of the Interior to accept donations of land, interests in land, buildings, structures, and other property in Saratoga County which properties, together with the General Philip Schuyler Mansion property, were to become part of Saratoga National Historical Park. See sections 159f and 159g of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
