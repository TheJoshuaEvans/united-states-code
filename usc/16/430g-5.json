{"tag":"section","attrib":{"id":"id77930046-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"430g–5"},"text":"§ 430g–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition and disposal of lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77930047-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77930048-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to acquire land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to acquire lands and interests in lands within the park by donation, purchase with donated or appropriated funds, exchange, or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77930049-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum Federal interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In acquiring lands and interests in lands under sections 430g–4 to 430g–10 of this title, the Secretary shall acquire the minimum Federal interests necessary to achieve the objectives identified for specific areas and the park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7793004a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of acquisition for certain land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), the Secretary may acquire the properties added to the park by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s430g–4/b/2"},"text":"section 430g–4(b)(2) of this title","children":[],"tail":" only by donation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7793004b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to convey freehold and leasehold interests within park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may convey lands and interests in lands within the park authorized in accordance with subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s102901"},"text":"section 102901 of title 54","children":[],"tail":", except that, notwithstanding subsection (d) of that section, the net proceeds from any such conveyance may be used, subject to appropriations, to acquire lands and interests within the park."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7793004c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyance of lands excluded from park","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7793004d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is authorized, in accordance with applicable existing law, to exchange Federal lands and interests excluded from the park pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s430g–4/c"},"text":"section 430g–4(c) of this title","children":[],"tail":" for the purpose of acquiring lands within the park boundary."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7793004e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any such Federal lands or interests are not exchanged within five years after ","children":[{"tag":"date","attrib":{"date":"1990-08-17"},"text":"August 17, 1990","children":[],"tail":", the Secretary may sell any or all such lands or interests to the highest bidder, in accordance with such regulations as the Secretary may prescribe, but any such conveyance shall be at not less than the fair market value of the land or interest, as determined by the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7793004f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–5/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All Federal lands and interests sold or exchanged pursuant to this subsection shall be subject to such terms and conditions as will assure the use of the property in a manner which, in the judgment of the Secretary, will protect the park and the Gettysburg Battlefield Historic District (hereafter in sections 430g–5 to 430g–10 of this title referred to as the “historic district”). Notwithstanding any other provision of law, the net proceeds from any such sale or exchange shall be used, subject to appropriations, to acquire lands and interests within the park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77930050-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relinquishment of legislative jurisdiction to Pennsylvania","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any lands over which the United States exercises exclusive or concurrent legislative jurisdiction and which are excluded from the park pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s430g–4/c"},"text":"section 430g–4(c) of this title","children":[],"tail":", the Secretary may relinquish to the State of Pennsylvania such exclusive or concurrent legislative jurisdiction by filing with the Governor a notice of relinquishment to take effect upon acceptance thereof, unless otherwise provided by the laws of the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77930051-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/377/s2"},"text":"Pub. L. 101–377, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-17"},"text":"Aug. 17, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/464"},"text":"104 Stat. 464","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/290/s2"},"text":"Pub. L. 106–290, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-10"},"text":"Oct. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/921"},"text":"114 Stat. 921","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXX/s3034/b"},"text":"Pub. L. 113–291, div. B, title XXX, § 3034(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3777"},"text":"128 Stat. 3777","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77930052-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77930053-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77930054-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s102901"},"text":"section 102901 of title 54","children":[],"tail":"” substituted for “subsection (a) of the Act of "},{"tag":"date","attrib":{"date":"1968-07-15"},"text":"July 15, 1968","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460"},"text":"16 U.S.C. 460","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–22)”, meaning “subsection (a) of "},{"tag":"ref","attrib":{"href":"/us/act/1968-07-15/s5"},"text":"section 5 of the Act of July 15, 1968","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460"},"text":"16 U.S.C. 460","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–22)”, on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/e"},"text":"Pub. L. 113–287, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3272"},"text":"128 Stat. 3272","children":[],"tail":", which Act enacted Title 54, National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77930055-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" designated first and second sentences as pars. (1) and (2), respectively, inserted par. headings, and added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsecs. (c)(1), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/290"},"text":"Pub. L. 106–290","children":[],"tail":" substituted “430g–4(c)” for “430g–4(b)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
