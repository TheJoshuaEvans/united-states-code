{"tag":"section","attrib":{"id":"id7942abfa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468"},"text":null,"children":[{"tag":"num","attrib":{"value":"1468"},"text":"§ 1468.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional Ocean Partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7942abfb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7942abfc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abfd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coastal State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “coastal State” has the meaning given the term “Coastal state” ","children":[{"tag":"ref","attrib":{"idref":"fn002656"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002656"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “ ‘coastal state’ ” as it appears in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453"},"text":"section 1453 of this title","children":[],"tail":"."}],"tail":" in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453"},"text":"section 1453 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian Tribe” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional Ocean Partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Regional Ocean Partnership” means a Regional Ocean Partnership designated under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942ac00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional Ocean Partnerships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7942ac01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A coastal State or Indian Tribe may form a partnership with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7942ac02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a coastal State that shares a common ocean or coastal area with the coastal State, without regard to whether the coastal States are contiguous; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ac03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" States—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7942ac04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that share a common ocean, coastal area, or watershed with the coastal State, without regard to whether the coastal States are contiguous; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7942ac05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that would contribute to the priorities of the partnership; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ac06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian Tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942ac07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A partnership formed under paragraph (1) may apply for designation as a Regional Ocean Partnership in such time and manner as determined appropriate by the Secretary if the partnership—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7942ac08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is established to coordinate the management of ocean, coastal, and Great Lakes resources among the members of the partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ac09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focuses on the environmental issues affecting the ocean, coastal, and Great Lakes areas of the members participating in the partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ac0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complements existing coastal and ocean management efforts of States and Indian Tribes on an interstate scale, focusing on shared regional priorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ac0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not have a regulatory function; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ac0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not duplicative of an existing Regional Ocean Partnership designated under paragraph (3), as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942ac0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of certain entities as Regional Ocean Partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following entities are designated as Regional Ocean Partnerships:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7942ac0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Gulf of Mexico Alliance, comprised of the States of Alabama, Florida, Louisiana, Mississippi, and Texas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ac0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Northeast Regional Ocean Council, comprised of the States of Maine, Vermont, New Hampshire, Massachusetts, Connecticut, and Rhode Island.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ac10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Mid-Atlantic Regional Council on the Ocean, comprised of the States of New York, New Jersey, Delaware, Maryland, and Virginia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ac11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The West Coast Ocean Alliance, comprised of the States of California, Oregon, and Washington and the coastal Indian Tribes therein.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942ac12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A partnership established under this section for the purposes described in subsection (d) with respect to a Great Lake may be known as a “Regional Coastal Partnership” or a “Regional Great Lakes Partnership”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942ac13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing bodies of Regional Ocean Partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Regional Ocean Partnership shall have a governing body that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7942ac14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be comprised, at a minimum, of voting members from each coastal state ","children":[{"tag":"ref","attrib":{"idref":"fn002657"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002657"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “coastal State”."}],"tail":" participating in the Regional Ocean Partnership, designated by the Governor of the coastal state; "},{"tag":"ref","attrib":{"idref":"fn002657"},"text":"2","children":[],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942ac15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include such other members as the partnership considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942ac16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Regional Ocean Partnership may perform the following functions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7942ac17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Promote coordination of the actions of the agencies of governments participating in the partnership with the actions of the appropriate officials of Federal agencies, State governments, and Indian Tribes in developing strategies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7942ac18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conserve living resources, increase valuable habitats, enhance coastal resilience and ocean management, promote ecological and economic health, and address such other issues related to the shared ocean, coastal, or Great Lakes areas as are determined to be a shared, regional priority by those states; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ac19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to manage regional data portals and develop associated data products for purposes that support the priorities of the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942ac1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In cooperation with appropriate Federal and State agencies, Indian Tribes, and local authorities, develop and implement specific action plans to carry out coordination goals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942ac1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinate and implement priority plans and projects, and facilitate science, research, modeling, monitoring, data collection, and other activities that support the goals of the partnership through the provision of grants and contracts under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942ac1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Engage, coordinate, and collaborate with relevant governmental entities and stakeholders to address ocean and coastal related matters that require interagency or intergovernmental solutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942ac1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Implement outreach programs for public information, education, and participation to foster stewardship of the resources of the ocean, coastal, and Great Lakes areas, as relevant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942ac1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Develop and make available, through publications, technical assistance, and other appropriate means, information pertaining to cross-jurisdictional issues being addressed through the coordinated activities of the partnership.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942ac1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Serve as a liaison with, and provide information to, international counterparts, as appropriate on priority issues for the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942ac20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination, consultation, and engagement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7942ac21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Regional Ocean Partnership shall maintain mechanisms for coordination, consultation, and engagement with the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7942ac22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ac23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian Tribes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ac24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nongovernmental entities, including academic organizations, nonprofit organizations, and private sector entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ac25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other federally mandated regional entities, including the Regional Fishery Management Councils, the regional associations of the National Integrated Coastal and Ocean Observation System, and relevant Marine Fisheries Commissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942ac26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1)(B) may be construed as affecting any requirement to consult with Indian Tribes under Executive Order 13175 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" note; relating to consultation and coordination with Indian Tribal Governments) or any other applicable law or policy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942ac27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and contracts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7942ac28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Regional Ocean Partnership may, in coordination with existing Federal, State, and Tribal management programs, from amounts made available to the partnership by the Administrator or the head of another Federal agency, subject to appropriations for such purpose, provide grants and enter into contracts for the purposes described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942ac29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes described in this paragraph include any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7942ac2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Monitoring the water quality and living resources of multistate ocean and coastal ecosystems and coastal communities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ac2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Researching and addressing the effects of natural and human-induced environmental changes on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7942ac2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ocean and coastal ecosystems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7942ac2d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coastal communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ac2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Developing and executing cooperative strategies that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7942ac2f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/f/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address regional data issues identified by the partnership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7942ac30-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/f/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will result in more effective management of common ocean and coastal areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942ac31-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7942ac32-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Administrator, in coordination with the Regional Ocean Partnerships, shall submit to Congress a report on the partnerships."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942ac33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required by paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7942ac34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the overall status of the work of the Regional Ocean Partnerships.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ac35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the effectiveness of the partnerships in supporting regional priorities relating to the management of common ocean, coastal, and Great Lakes areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7944f526-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the effectiveness of the strategies that the partnerships are supporting or implementing and the extent to which the priority needs of the regions covered by the partnerships are being met through such strategies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7944f527-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of how the efforts of the partnerships support or enhance Federal and State efforts consistent with the purposes of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7944f528-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/g/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such recommendations as the Administrator may have for improving—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7944f529-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/g/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts of the partnerships to support the purposes of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7944f52a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/g/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collective strategies that support the purposes of this title in coordination with all relevant Federal and State entities and Indian Tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7944f52b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/g/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The distribution of funds from each partnership for each fiscal year covered by the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7944f52c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of Federal funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts made available to the Regional Ocean Partnerships by the Administrator under this section, the head of any other Federal agency may provide grants to, enter into contracts with, or otherwise provide funding to such partnerships, subject to availability of appropriations for such purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7944f52d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section establishes any new legal or regulatory authority of the National Oceanic and Atmospheric Administration or of the Regional Ocean Partnerships, other than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7944f52e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority of the Administrator to provide amounts to the partnerships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7944f52f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority of the partnerships to provide grants and enter into contracts under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7944f530-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7944f531-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional Ocean Partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Administrator the following amounts to be made available to the Regional Ocean Partnerships or designated fiscal management entities of such partnerships to carry out activities of such partnerships under this title:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7944f532-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,100,000 for fiscal year 2023.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7944f533-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,202,000 for fiscal year 2024.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7944f534-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/j/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,306,040 for fiscal year 2025.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7944f535-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/j/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,412,160 for fiscal year 2026.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7944f536-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/j/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,520,404 for fiscal year 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7944f537-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available under this subsection shall be divided evenly among the Regional Ocean Partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7944f538-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1468/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal government participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administrator $1,000,000 for each of fiscal years 2023 through 2027 to be distributed to Indian Tribes for purposes of participation in or engagement with the Regional Ocean Partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7944f539-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCII/s10202"},"text":"Pub. L. 117–263, div. J, title CII, § 10202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3962"},"text":"136 Stat. 3962","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7944f53a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7944f53b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7944f53c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 13175, referred to in subsec. (e)(2), is Ex. Ord. No. 13175, ","children":[{"tag":"date","attrib":{"date":"2000-11-06"},"text":"Nov. 6, 2000","children":[],"tail":", 65 F.R. 67249, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of Title 25","children":[],"tail":", Indians."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This title, referred to in subsecs. (g)(2)(D), (E) and (j)(1), means title CII of division J of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", which enacted this section and provisions set out as a note below. For complete classification of title CII to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7944f53d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, and not as part of the Coastal Zone Management Act of 1972 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7944f53e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7944f53f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings; Purposes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCII/s10201"},"text":"Pub. L. 117–263, div. J, title CII, § 10201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3961"},"text":"136 Stat. 3961","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dJ/tCII/s10201"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ocean and coastal waters and the Great Lakes of the United States are foundational to the economy, security, global competitiveness, and well-being of the United States and continuously serve the people of the United States and other countries as an important source of food, energy, economic productivity, recreation, beauty, and enjoyment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Over many years, the resource productivity and water quality of the ocean, coastal, and Great Lakes areas of the United States have been diminished by pollution, increasing population demands, economic development, and natural and man-made hazard events, both acute and chronic.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ocean, coastal, and Great Lakes areas of the United States are managed by State and Federal resource agencies and Indian Tribes and regulated on an interstate and regional scale by various overlapping Federal authorities, thereby creating a significant need for interstate coordination to enhance regional priorities, including the ecological and economic health of those areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian Tribes have unique expertise and knowledge important for the stewardship of the ocean and coastal waters and the Great Lakes of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this title [enacting this section] are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To complement and expand cooperative voluntary efforts intended to manage, conserve, and restore ocean, coastal, and Great Lakes areas spanning across multiple State and Indian Tribe jurisdictions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To expand Federal support for monitoring, data management, restoration, research, and conservation activities in ocean, coastal, and Great Lakes areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To commit the United States to a comprehensive cooperative program to achieve improved water quality in, and improvements in the productivity of living resources of, oceans, coastal, and Great Lakes ecosystems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To authorize Regional Ocean Partnerships as intergovernmental coordinators for shared regional priorities among States and Indian Tribes relating to the collaborative management of the large marine ecosystems, thereby reducing duplication of efforts and maximizing opportunities to leverage support in the ocean and coastal regions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To empower States to take a lead role in managing oceans, coastal, and Great Lakes areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To incorporate rights of Indian Tribes in the management of oceans, coasts, and Great Lakes resources and provide resources to support Indian Tribe participation in and engagement with Regional Ocean Partnerships.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To enable Regional Ocean Partnerships, or designated fiscal management entities of such partnerships, to receive Federal funding to conduct the scientific research, conservation, and restoration activities, and priority coordination on shared regional priorities necessary to achieve the purposes described in paragraphs (1) through (6).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
