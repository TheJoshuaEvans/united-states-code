{"tag":"section","attrib":{"id":"id77825dd3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"410eeee–5"},"text":"§ 410eeee–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mineral lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77825dd4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mining; prohibition and limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, no surface mining of any kind shall be permitted on federally owned lands within the boundary of the national river where the subsurface estate is not federally owned. Underground mining on such lands may be permitted by the Secretary only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77825dd5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mining operation will have no significant adverse impact on the public use and enjoyment of the national river;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77825dd6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mining operation will disturb the minimum amount of surface necessary to extract the mineral; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77825dd7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the surface is not significantly disturbed, unless there is no technologically feasible alternative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77825dd8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timber harvesting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The harvesting of timber on federally owned lands within the national river boundary is prohibited, except insofar as it is necessary for the Secretary to remove trees for river access, historic sites, primitive campgrounds, scenic vistas, or as may be necessary from time to time for reasons of public health and safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77825dd9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action; jurisdiction; recovery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The owner of a mineral estate subject to this section who believes he has suffered a loss by operation of this section, may bring an action only in a United States district court to recover just compensation, which shall be awarded if the court finds that such loss constitutes a taking of property compensable under the Constitution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77825dda-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/tXI/s1105"},"text":"Pub. L. 95–625, title XI, § 1105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3546"},"text":"92 Stat. 3546","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77825ddb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77825ddc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77825ddd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460m–19"},"text":"section 460m–19 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
