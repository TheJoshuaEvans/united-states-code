{"tag":"section","attrib":{"id":"id76ff2469-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s80c"},"text":null,"children":[{"tag":"num","attrib":{"value":"80c"},"text":"§ 80c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motor-vehicle licenses for Sequoia National Park as applicable; limitation of privileges within park","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any motor-vehicle license issued for Sequoia National Park shall be applicable to Kings Canyon National Park, and vice versa: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That in order to insure the permanent preservation of the wilderness character of the Kings Canyon National Park the Secretary of the Interior may, in his discretion, limit the character and number of privileges that he may grant within the Kings Canyon National Park."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76ff246a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-03-04/ch40/s4"},"text":"Mar. 4, 1940, ch. 40, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/44"},"text":"54 Stat. 44","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-08-17/ch730"},"text":"Aug. 17, 1950, ch. 730","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/458"},"text":"64 Stat. 458","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id76ff246b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id76ff246c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id76ff246d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-08-17"},"text":"Aug. 17, 1950","children":[],"tail":", struck out last sentence which restricted concessionaires to a five-year term."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
