{"tag":"section","attrib":{"id":"id77a157ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450y–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"450y–4"},"text":"§ 450y–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property; donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon submission of title satisfactory to him, the Secretary of the Interior, on behalf of the United States, may accept lands and interests in lands which are within the memorial area but are not in Federal ownership and which are offered to the United States without cost.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a157af-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-08-18/ch365/s5"},"text":"Aug. 18, 1941, ch. 365, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/631"},"text":"55 Stat. 631","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
