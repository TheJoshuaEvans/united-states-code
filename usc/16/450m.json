{"tag":"section","attrib":{"id":"id779ee750-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450m"},"text":null,"children":[{"tag":"num","attrib":{"value":"450m"},"text":"§ 450m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of donations of lands and funds; acquisition of land","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to accept donations of land, interests in land and/or buildings, structures, and other property within the boundaries of said national monument as determined and fixed hereunder, and donations of funds for the purchase and/or maintenance thereof, the title and evidence of title to lands acquired to be satisfactory to the Secretary of the Interior: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That he may acquire on behalf of the United States out of any donated funds, by purchase at prices deemed by him reasonable, or by condemnation under the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"section 3113 of title 40","children":[],"tail":", such tracts of land within the said national monument as may be necessary for the completion thereof."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id779ee751-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-21/ch592/s2"},"text":"Aug. 21, 1935, ch. 592, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/666"},"text":"49 Stat. 666","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id779ee752-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id779ee753-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id779ee754-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Hereunder, referred to in text, means act ","children":[{"tag":"date","attrib":{"date":"1935-08-21"},"text":"Aug. 21, 1935","children":[],"tail":", which is classified to sections 450"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" to 450n of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id779ee755-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"Section 3113 of title 40","children":[],"tail":"” substituted in text for “the Act of "},{"tag":"date","attrib":{"date":"1888-08-01"},"text":"August 1, 1888","children":[],"tail":"” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
