{"tag":"section","attrib":{"id":"id78d74048-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s943"},"text":null,"children":[{"tag":"num","attrib":{"value":"943"},"text":"§ 943.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tissue bank","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78d74049-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s943/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate existing facilities for the storage, preparation, examination, and archiving of tissues from selected Great Lakes fish and wildlife, which shall be known as the “Great Lakes Fish and Wildlife Tissue Bank”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d7404a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s943/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, in consultation with appropriate Federal and State agencies and the Council of Great Lakes Research Managers, issue guidance, after an opportunity for public review and comment, for Great Lakes fish and wildlife tissue collection, preparation, archiving, quality control procedures, and access that will ensure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78d7404b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s943/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate uniform methods and standards for those activities to provide confidence in Great Lakes fish and wildlife tissue samples used for research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d7404c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s943/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation of procedures used for collecting, preparing, and archiving those samples; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d7404d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s943/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate scientific use of the tissues in the Great Lakes Fish and Wildlife Tissue Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78d7404e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tII/s202"},"text":"Pub. L. 102–440, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2233"},"text":"106 Stat. 2233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78d7404f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78d74050-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id78d74051-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tII/s201"},"text":"Pub. L. 102–440, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2233"},"text":"106 Stat. 2233","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/440/tII/s201"},"text":"“This title [enacting this chapter] may be cited as ‘The Great Lakes Fish and Wildlife Tissue Bank Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
