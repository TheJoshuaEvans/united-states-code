{"tag":"section","attrib":{"id":"id77a3c874-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ii–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"450ii–3"},"text":"§ 450ii–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey and report of mineral value","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized and directed, through the United States Bureau of Mines, the United States Geological Survey, and the National Park Service, to cause a survey to be made of the area within the revised boundaries of the Joshua Tree National Monument with a view to determining to what extent the said area is more valuable for minerals than for the National Monument purposes for which it was created. Report of said survey shall be filed with the President of the United States Senate and the Speaker of the House of Representatives on or before ","children":[{"tag":"date","attrib":{"date":"1951-02-01"},"text":"February 1, 1951","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a3c875-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-25/ch1030/s4"},"text":"Sept. 25, 1950, ch. 1030, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1035"},"text":"64 Stat. 1035","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/154/tI"},"text":"Pub. L. 102–154, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-13"},"text":"Nov. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1000"},"text":"105 Stat. 1000","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/285/s10/b"},"text":"Pub. L. 102–285, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/172"},"text":"106 Stat. 172","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77a3c876-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77a3c877-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77a3c878-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States Bureau of Mines” substituted in text for “Bureau of Mines” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/285/s10/b"},"text":"section 10(b) of Pub. L. 102–285","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of Title 30","children":[],"tail":", Mineral Lands and Mining. For provisions relating to closure and transfer of functions of the United States Bureau of Mines, see Transfer of Functions note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of Title 30","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States Geological Survey” substituted in text for “Geological Survey” pursuant to provision of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/154"},"text":"Pub. L. 102–154","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s31"},"text":"section 31 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77a3c879-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Joshua Tree National Monument","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Joshua Tree National Monument abolished and incorporated in Joshua Tree National Park, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410aaa–22"},"text":"section 410aaa–22 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
