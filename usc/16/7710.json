{"tag":"section","attrib":{"id":"id7a2c492a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7710"},"text":null,"children":[{"tag":"num","attrib":{"value":"7710"},"text":"§ 7710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated out of funds made available to the Secretary and the Secretary of State $300,000 for each of fiscal years 2017 through 2021 to carry out this chapter and to pay the United States contribution to the Commission under Article 12 of the North Pacific Fisheries Convention.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a2eb92b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/tI/s110"},"text":"Pub. L. 114–327, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1984"},"text":"130 Stat. 1984","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
