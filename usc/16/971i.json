{"tag":"section","attrib":{"id":"id78dc2198-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i"},"text":null,"children":[{"tag":"num","attrib":{"value":"971i"},"text":"§ 971i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research on Atlantic highly migratory species","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78dc2199-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78dc219a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Highly migratory species research and monitoring","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78dc219b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Within 6 months after ","children":[{"tag":"date","attrib":{"date":"1995-11-03"},"text":"November 3, 1995","children":[],"tail":", the Secretary of Commerce, in cooperation with the advisory committee established under section 4 of the Atlantic Tunas Convention Act of 1975 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s971b"},"text":"16 U.S.C. 971b","children":[],"tail":") and in consultation with the United States Commissioners on the International Commission for the Conservation of Atlantic Tunas (referred to elsewhere in this section as the “Commission”) and the Secretary of State, shall develop and implement a comprehensive research and monitoring program to support the conservation and management of Atlantic bluefin tuna and other highly migratory species that shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78dc219c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and define the range of stocks of highly migratory species in the Atlantic Ocean, including Atlantic bluefin tuna; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78dc219d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for appropriate participation by nations which are members of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78dc219e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The program shall provide for, but not be limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78dc219f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statistically designed cooperative tagging studies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78dc21a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" genetic and biochemical stock analyses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78dc21a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" population censuses carried out through aerial surveys of fishing grounds and known migration areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78dc21a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate observer coverage and port sampling of commercial and recreational fishing activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78dc21a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collection of comparable real-time data on commercial and recreational catches and landings through the use of permits, logbooks, landing reports for charter operations and fishing tournaments, and programs to provide reliable reporting of the catch by private anglers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78dc21a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies of the life history parameters of Atlantic bluefin tuna and other highly migratory species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78dc21a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integration of data from all sources and the preparation of data bases to support management decisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78dc21a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a cooperative research program on Atlantic billfish based on the Southeast Fisheries Science Center Atlantic Billfish Research Plan of 2002; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78dc21a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other research as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78dc21a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In developing a program under this section, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78dc21a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that personnel and resources of each regional research center shall have substantial participation in the stock assessments and monitoring of highly migratory species that occur in the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78dc21aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for comparable monitoring of all United States fishermen to which the Atlantic Tunas Convention Act of 1975 applies with respect to effort and species composition of catch and discards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78dc21ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with relevant Federal and State agencies, scientific and technical experts, commercial and recreational fishermen, and other interested persons, public and private, and shall publish a proposed plan in the Federal Register for the purpose of receiving public comment on the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78dc21ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971i/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through the Secretary of State, encourage other member nations to adopt a similar program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78dc21ad-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/339/s3"},"text":"Pub. L. 96–339, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-04"},"text":"Sept. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1070"},"text":"94 Stat. 1070","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/43/tIII/s302/b"},"text":"Pub. L. 104–43, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/382"},"text":"109 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/384/tII/s202/b/2"},"text":"Pub. L. 105–384, title II, § 202(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3453"},"text":"112 Stat. 3453","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/tIV/s405/b"},"text":"Pub. L. 109–479, title IV, § 405(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3633"},"text":"120 Stat. 3633","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78dc21ae-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78dc21af-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78dc21b0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Atlantic Tunas Convention Act of 1975, referred to in subsec. (b)(3)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/70"},"text":"Pub. L. 94–70","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-08-05"},"text":"Aug. 5, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/385"},"text":"89 Stat. 385","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s971"},"text":"section 971 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78dc21b1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a), which required the Secretary of Commerce to prepare and submit to Congress a biennial report on the level of taking of bluefin tuna by United States fishermen in the Convention area as defined in Article I of the International Convention for the Conservation of Atlantic Tunas, the status of bluefin tuna stocks within the Convention area and the trends in their population level, and related information resulting from implementation of the observer program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1827"},"text":"section 1827 of this title","children":[],"tail":", terminated, effective "},{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance. See, also, page 50 of House Document No. 103–7."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Atlantic Tunas Convention Act of 1975 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78dc21b2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(2)(H), (I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479"},"text":"Pub. L. 109–479","children":[],"tail":" added subpar. (H) and redesignated former subpar. (H) as (I)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/384"},"text":"Pub. L. 105–384","children":[],"tail":" inserted “of 1975” after “Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43"},"text":"Pub. L. 104–43","children":[],"tail":" amended section catchline generally, designated existing provisions as subsec. (a), inserted heading, struck out last sentence which read as follows: “There are authorized to be appropriated such sums as may be necessary to carry out this section.”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
