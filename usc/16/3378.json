{"tag":"section","attrib":{"id":"id79b9d74e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3378"},"text":null,"children":[{"tag":"num","attrib":{"value":"3378"},"text":"§ 3378.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b9d74f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3378/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on powers of States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to prevent the several States or Indian tribes from making or enforcing laws or regulations not inconsistent with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b9d750-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3378/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following provisions of law are repealed:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b9d751-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3378/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Act of ","children":[{"tag":"date","attrib":{"date":"1926-05-20"},"text":"May 20, 1926","children":[],"tail":" (commonly known as the Black Bass Act; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s851–856"},"text":"16 U.S.C. 851–856","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d752-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3378/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s667e"},"text":"Section 667e of this title","children":[],"tail":" and sections 43 and 44 of title 18 (commonly known as provisions of the Lacey Act)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d753-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3378/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 3054 and 3112 of title 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b9d754-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3378/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclaimers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall be construed as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b9d755-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3378/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repealing, superseding, or modifying any provision of Federal law other than those specified in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d756-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3378/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repealing, superseding, or modifying any right, privilege, or immunity granted, reserved, or established pursuant to treaty, statute, or executive order pertaining to any Indian tribe, band, or community; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d757-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3378/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enlarging or diminishing the authority of any State or Indian tribe to regulate the activities of persons within Indian reservations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b9d758-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3378/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel and transportation expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to pay from agency appropriations the travel expense of newly appointed special agents of the United States Fish and Wildlife Service and the transportation expense of household goods and personal effects from place of residence at time of selection to first duty station to the extent authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5724"},"text":"section 5724 of title 5","children":[],"tail":" for all such special agents appointed after "},{"tag":"date","attrib":{"date":"1977-01-01"},"text":"January 1, 1977","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b9d759-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3378/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interior appropriations budget proposal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall identify the funds utilized to enforce this chapter and any regulations thereto as a specific appropriations item in the Department of the Interior appropriations budget proposal to the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b9d75a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/79/s9/a"},"text":"Pub. L. 97–79, § 9(a)","children":[],"tail":"–(c), (g), (h), "},{"tag":"date","attrib":{"date":"1981-11-16"},"text":"Nov. 16, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1079"},"text":"95 Stat. 1079","children":[],"tail":", 1080.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b9d75b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79b9d75c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79b9d75d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Black Bass Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-20/ch346"},"text":"act May 20, 1926, ch. 346","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/576"},"text":"44 Stat. 576","children":[],"tail":", which was classified generally to chapter 13 (§ 851 et seq.) of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79b9d75e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) and (e) of this section were in the original subsecs. (g) and (h), respectively, of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/79/s9"},"text":"section 9 of Pub. L. 97–79","children":[],"tail":" and were redesignated for purposes of codification."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
