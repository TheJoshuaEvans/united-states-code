{"tag":"section","attrib":{"id":"id775e822a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410tt"},"text":null,"children":[{"tag":"num","attrib":{"value":"410tt"},"text":"§ 410tt.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that the Salt River Bay area of the north central coast of St. Croix, United States Virgin Islands—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id775e822b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410tt/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been inhabited, possibly as far back as 2000 B.C., and encompasses all major cultural periods in the United States Virgin Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id775e822c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410tt/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains the only ceremonial ball court ever discovered in the Lesser Antilles, village middens, and burial grounds which can provide evidence for the interpretation of Caribbean life prior to Columbus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id775e822d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410tt/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the only known site where members of the Columbus expeditions set foot on what is now United States territory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id775e822e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410tt/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was a focal point of various European attempts to colonize the area during the post-Columbian period and contains sites of Spanish, French, Dutch, English, and Danish settlements, including Fort Sale, one of the few remaining earthwork fortifications in the Western Hemisphere;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id775e822f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410tt/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" presents an outstanding opportunity to preserve and interpret Caribbean history and culture, including the impact of European exploration and settlement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id775e8230-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410tt/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been a national natural landmark since February 1980 and has been nominated for acquisition as a nationally significant wildlife habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id775e8231-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410tt/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains the largest remaining mangrove forest in the United States Virgin Islands and a variety of tropical marine and terrestrial ecosystems which should be preserved and kept unimpaired for the benefit of present and future generations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id775e8232-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410tt/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is worthy of a comprehensive preservation effort that should be carried out in partnership between the Federal Government and the Government of the United States Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id775e8233-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/247/tI/s102"},"text":"Pub. L. 102–247, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-02-24"},"text":"Feb. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/33"},"text":"106 Stat. 33","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id775e8234-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id775e8235-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id775e8236-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/247/s1"},"text":"Pub. L. 102–247, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-02-24"},"text":"Feb. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/33"},"text":"106 Stat. 33","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/247/s1"},"text":"“This Act [enacting this subchapter, sections 5204 to 5204c of Title 42, The Public Health and Welfare, and sections 1469e and 1973 of Title 48, Territories and Insular Possessions, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"section 5122 of Title 42","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1903"},"text":"section 1903 of Title 48","children":[],"tail":", enacting provisions set out as a note under this section, and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s301"},"text":"section 301 of Title 7","children":[],"tail":", Agriculture] may be cited as the ‘Omnibus Insular Areas Act of 1992’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/247/tI/s101"},"text":"Pub. L. 102–247, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-02-24"},"text":"Feb. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/33"},"text":"106 Stat. 33","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/247/tI/s101"},"text":"“This title [enacting this subchapter] may be cited as the ‘Salt River Bay National Historical Park and Ecological Preserve at St. Croix, Virgin Islands, Act of 1992’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
