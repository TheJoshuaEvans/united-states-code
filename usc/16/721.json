{"tag":"section","attrib":{"id":"id7888aaa9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s721"},"text":null,"children":[{"tag":"num","attrib":{"value":"721"},"text":"§ 721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title; “person” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter may be cited as “The Upper Mississippi River National Wildlife and Fish Refuge Act.” The term “person” as used therein includes an individual, partnership, association, or corporation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7888aaaa-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-06-07/ch346"},"text":"June 7, 1924, ch. 346","children":[],"tail":", §§ 1, 12, "},{"tag":"ref","attrib":{"href":"/us/stat/43/650"},"text":"43 Stat. 650","children":[],"tail":", 652; "},{"tag":"ref","attrib":{"href":"/us/pl/105/312/tII/s202/b"},"text":"Pub. L. 105–312, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2957"},"text":"112 Stat. 2957","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7888aaab-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7888aaac-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7888aaad-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is a combination provision, the first sentence being derived from section 1 and the last from section 12, of act ","children":[{"tag":"date","attrib":{"date":"1924-06-07"},"text":"June 7, 1924","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7888aaae-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/312"},"text":"Pub. L. 105–312","children":[],"tail":" substituted “National Wildlife” for “Wild Life”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
