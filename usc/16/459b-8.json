{"tag":"section","attrib":{"id":"id77aacd4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459b–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"459b–8"},"text":"§ 459b–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out the provisions of sections 459b to 459b–8 of this title; except that no more than $42,917,575 shall be appropriated for the acquisition of land and waters and improvements thereon, and interests therein, and incidental costs relating thereto, in accordance with the provisions of such sections.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77aacd4e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/126/s9"},"text":"Pub. L. 87–126, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-07"},"text":"Aug. 7, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/293"},"text":"75 Stat. 293","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/252"},"text":"Pub. L. 91–252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-05-14"},"text":"May 14, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/216"},"text":"84 Stat. 216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/141/s3"},"text":"Pub. L. 98–141, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-10-31"},"text":"Oct. 31, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/909"},"text":"97 Stat. 909","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77aacd4f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77aacd50-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77aacd51-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/141"},"text":"Pub. L. 98–141","children":[],"tail":" substituted “$42,917,575” for “$33,500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/252"},"text":"Pub. L. 91–252","children":[],"tail":" substituted “$33,500,000” for “$16,000,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
