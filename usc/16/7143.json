{"tag":"section","attrib":{"id":"id7a278d3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7143"},"text":null,"children":[{"tag":"num","attrib":{"value":"7143"},"text":"§ 7143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a278d3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than February 1 of the year after the year in which any county funds were expended by a participating county, the appropriate official of the participating county shall submit to the Secretary concerned a certification that the county funds expended in the applicable year have been used for the uses authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7142/a"},"text":"section 7142(a) of this title","children":[],"tail":", including a description of the amounts expended and the uses for which the amounts were expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a278d40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned shall review the certifications submitted under subsection (a) as the Secretary concerned determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a278d41-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/393/tIII/s303"},"tex