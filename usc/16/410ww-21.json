{"tag":"section","attrib":{"id":"id7760f41f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ww–21"},"text":"§ 410ww–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dayton Aviation Heritage Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7760f420-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Dayton Aviation Heritage Commission to assist Federal, State, and local authorities and the private sector in preserving and managing the historic resources in the Miami Valley, Ohio, associated with the Wright brothers, aviation, or Paul Laurence Dunbar.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f421-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall consist of 13 members as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7760f422-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members appointed by the Secretary, who shall have demonstrated expertise in aviation history, black history and literature, aviation technology, or historic preservation, at least one of whom shall represent the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f423-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members appointed by the Secretary after consideration of recommendations submitted by the Governor of the State of Ohio, who shall have demonstrated expertise in aviation history, black history and literature, aviation technology, or historic preservation, at least one of whom shall represent the Ohio Historical Society.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f424-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member appointed by the Secretary of Defense, who shall represent Wright-Patterson Air Force Base.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f425-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members appointed by the Secretary after consideration of recommendations submitted by the City Commission of Dayton, Ohio, at least one of whom shall reside near the core parcel of the park (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ww/b/1"},"text":"section 410ww(b)(1) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f426-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member appointed by the Secretary after consideration of recommendations submitted by the Board of Commissioners of Montgomery County, Ohio.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f427-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member appointed by the Secretary after consideration of recommendations submitted by the Board of Commissioners of Greene County, Ohio.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f428-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member appointed by the Secretary after consideration of recommendations submitted by the City Council of Fairborn, Ohio.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f429-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7760f42a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members shall be appointed for terms of 3 years. A member may be reappointed only 3 times unless such member was originally appointed to fill a vacancy pursuant to subsection (e)(1), in which case such member may be reappointed 4 times. A member may serve after the expiration of his term until a successor is appointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f42b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall appoint the first members of the Commission within 30 days after the date on which the Secretary has received all of the recommendations for appointment pursuant to subsections ","children":[{"tag":"ref","attrib":{"idref":"fn002135"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002135"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":" (b)(2), (4), (5), (6), and (7)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f42c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair and vice chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chair and vice chair of the Commission shall be elected by the members of the Commission. The terms of the chair and vice chair shall be 2 years. The vice chair shall serve as chair in the absence of the chair.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f42d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7760f42e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vacancy in the Commission shall be filled in the same manner in which the original appointment was made, except that the Secretary responsible for such appointment shall fill any such vacancy within 30 days after receiving a recommendation for the position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f42f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member appointed to fill a vacancy shall serve for the remainder of the term for which his predecessor was appointed. A member may serve after the expiration of his term until his successor has taken office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f430-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Commission then serving shall constitute a quorum, but a lesser number may hold hearings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f431-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall meet not less than 3 times a year at the call of the chair or a majority of its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f432-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7760f433-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), members of the Commission shall serve without pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f434-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Commission who are full-time officers or employees of the United States shall receive no additional pay by reason of their service on the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f435-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" While away from their homes or regular places of business in the performance of services for the Commission, members of the Commission shall be allowed travel expenses, including per diem in lieu of subsistence, in the same manner as persons employed intermittently in the Government service are allowed expenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f436-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/b"},"text":"Section 1013(b) of title 5","children":[],"tail":" shall not apply to the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f437-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–21/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall cease to exist on ","children":[{"tag":"date","attrib":{"date":"2004-01-01"},"text":"January 1, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7760f438-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/419/tII/s201"},"text":"Pub. L. 102–419, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2144"},"text":"106 Stat. 2144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/333/dI/tVIII/s811"},"text":"Pub. L. 104–333, div. I, title VIII, § 811","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-11-12"},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4189"},"text":"110 Stat. 4189","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/83"},"text":"Pub. L. 117–286, § 4(a)(83)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4315"},"text":"136 Stat. 4315","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7760f439-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7760f43a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7760f43b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “FACA” in heading and “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/b"},"text":"Section 1013(b) of title 5","children":[],"tail":"” for “Section 14(b) of the Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2), (4) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/333"},"text":"Pub. L. 104–333","children":[],"tail":" substituted “after consideration of recommendations” for “from recommendations” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
