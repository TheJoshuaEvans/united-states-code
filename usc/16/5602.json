{"tag":"section","attrib":{"id":"id7a016774-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5602"},"text":null,"children":[{"tag":"num","attrib":{"value":"5602"},"text":"§ 5602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for scientific advice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a016775-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Representative may not make a request or specification described in paragraph (1) or (2) of subsection (b), respectively, unless the Representative has first—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a016776-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5602/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consulted with the appropriate Regional Fishery Management Councils; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a016777-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5602/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received the consent of the Commissioners for that action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016778-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests and terms of reference described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requests and specifications referred to in subsection (a) are, respectively—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a016779-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5602/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any request, under Article VII(10)(b) of the Convention, that the Scientific Council consider and report on a question pertaining to the scientific basis for the management and conservation of fishery resources in waters under the jurisdiction of the United States within the Convention Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a01677a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5602/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any specification, under Article VII(11) of the Convention, of the terms of reference for the consideration of a question referred to the Scientific Council pursuant to Article VII(10)(b) of the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a01677b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tII/s203"},"text":"Pub. L. 104–43, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/378"},"text":"109 Stat. 378","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/327/tV/s503"},"text":"Pub. L. 114–327, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1995"},"text":"130 Stat. 1995","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a01677c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a01677d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a01677e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/s503/1"},"text":"Pub. L. 114–327, § 503(1)","children":[],"tail":", in introductory provisions, substituted “A Representative may” for “The Representatives may”, “described in paragraph (1) or (2) of subsection (b)” for “described in subsection (b)(1) or (2)”, and “the Representative has” for “the Representatives have”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/s503/2"},"text":"Pub. L. 114–327, § 503(2)","children":[],"tail":", substituted “VII(10)(b)” for “VII(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/s503/2"},"text":"Pub. L. 114–327, § 503(2)","children":[],"tail":",(3), substituted “VII(11)” for “VIII(2)” and “VII(10)(b)” for “VII(1)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
