{"tag":"section","attrib":{"id":"id7800b68a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–92"},"text":null,"children":[{"tag":"num","attrib":{"value":"460nnn–92"},"text":"§ 460nnn–92.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release from wilderness study area status","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Federal lands included in the Wildlands Juniper Management Area established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn–91"},"text":"section 460nnn–91 of this title","children":[],"tail":" are no longer subject to the requirement of "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1782/c"},"text":"section 1782(c) of title 43","children":[],"tail":" pertaining to managing the lands so as not to impair the suitability of the lands for preservation as wilderness."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7803268b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399/tV/s502"},"text":"Pub. L. 106–399, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1670"},"text":"114 Stat. 1670","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
