{"tag":"section","attrib":{"id":"id77fbfac7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–14"},"text":"§ 460lll–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest highways","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fbfac8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–14/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 204 ","children":[{"tag":"ref","attrib":{"idref":"fn002375"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002375"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 23, the road known as “The Trace” and every other paved road within the Recreation Area (including any road constructed to secondary standards) shall be considered to be a forest highway."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfac9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–14/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State responsibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfaca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–14/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The States shall be responsible for the maintenance of forest highways within the Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfacb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–14/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent provided by law, from funds appropriated to the Department of Transportation and available for purposes of highway construction and maintenance, the Secretary of Transportation shall reimburse the States for all or a portion of the costs of maintenance of forest highways in the Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fbfacc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s514"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 514]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–313.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77fbfacd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77fbface-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77fbfacf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s204"},"text":"Section 204 of title 23","children":[],"tail":", referred to in subsec. (a), was repealed and a new section 204 enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1119/a"},"text":"Pub. L. 112–141, div. A, title I, § 1119(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/473"},"text":"126 Stat. 473","children":[],"tail":", 489."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
