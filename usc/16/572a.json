{"tag":"section","attrib":{"id":"id7848464a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s572a"},"text":null,"children":[{"tag":"num","attrib":{"value":"572a"},"text":"§ 572a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits from timber purchasers to defray cost of scaling services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Forest Service may accept money from timber purchasers for deposit into the Treasury in the trust account, “Forest Service cooperative fund”, which moneys are made available for scaling services requested by purchasers in addition to those required by the Forest Service, and for refunds of amounts deposited in excess of the cost of such work.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7848464b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-09-21/ch412"},"text":"Sept. 21, 1944, ch. 412","children":[],"tail":", title II, § 210, "},{"tag":"ref","attrib":{"href":"/us/stat/58/737"},"text":"58 Stat. 737","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7848464c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7848464d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7848464e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as a part of the Department of Agriculture Organic Act of 1944.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
