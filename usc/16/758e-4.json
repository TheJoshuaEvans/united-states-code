{"tag":"section","attrib":{"id":"id78921ff6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s758e–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"758e–4"},"text":"§ 758e–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Central, Western, and South Pacific Ocean area” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in sections 758e to 758e–5 of this title, the term “Central, Western, and South Pacific Ocean” means that area of the Pacific Ocean between latitudes 30 degrees north to 30 degrees south and from longitudes 120 degrees east to 130 degrees west.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78921ff7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/444/s7"},"text":"Pub. L. 92–444, § 7","children":[],"tail":", formerly § 6, "},{"tag":"date","attrib":{"date":"1972-09-29"},"text":"Sept. 29, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/745"},"text":"86 Stat. 745","children":[],"tail":"; renumbered § 7, "},{"tag":"ref","attrib":{"href":"/us/pl/95/295/s1/4"},"text":"Pub. L. 95–295, § 1(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-16"},"text":"June 16, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/319"},"text":"92 Stat. 319","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
