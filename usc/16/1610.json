{"tag":"section","attrib":{"id":"id795807bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1610"},"text":null,"children":[{"tag":"num","attrib":{"value":"1610"},"text":"§ 1610.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of provisions by Secretary; utilization of information and data of other organizations; avoidance of duplication of planning, etc.; “renewable resources” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out this subchapter, the Secretary shall utilize information and data available from other Federal, State, and private organizations and shall avoid duplication and overlap of resource assessment and program planning efforts of other Federal agencies. The term “renewable resources” shall be construed to involve those matters within the scope of responsibilities and authorities of the Forest Service on ","children":[{"tag":"date","attrib":{"date":"1974-08-17"},"text":"August 17, 1974","children":[],"tail":" and on the date of enactment of any legislation amendatory or supplementary thereto."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id795807bd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/378/s12"},"text":"Pub. L. 93–378, § 12","children":[],"tail":", formerly § 11, "},{"tag":"date","attrib":{"date":"1974-08-17"},"text":"Aug. 17, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/480"},"text":"88 Stat. 480","children":[],"tail":", renumbered § 12 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/588"},"text":"Pub. L. 94–588","children":[],"tail":", §§ 2, 10, "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2949"},"text":"90 Stat. 2949","children":[],"tail":", 2957; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/tII/s208/b/2"},"text":"Pub. L. 115–141, div. O, title II, § 208(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1066"},"text":"132 Stat. 1066","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795807be-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id795807bf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id795807c0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “Secretary” for “Secretary of Agriculture”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/588/s10"},"text":"Pub. L. 94–588, § 10","children":[],"tail":", inserted “and on the date of enactment of any legislation amendatory or supplementary thereto”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id795807c1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id795807c2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of certain enforcement functions of Secretary or other official in Department of Agriculture under this subchapter to Federal Inspector, Office of Federal Inspector for Alaska Natural Gas Transportation System, and subsequent transfer to Secretary of Energy, then to Federal Coordinator for Alaska Natural Gas Transportation Projects, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1601"},"text":"section 1601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
