{"tag":"section","attrib":{"id":"id786285d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667f–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"667f–3"},"text":"§ 667f–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for mitigating losses caused by waterfowl depredation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to reimburse the Commodity Credit Corporation for its investment in the grain transferred pursuant to sections 667f to 667f–3 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7864cec7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-07-03/ch512/s4"},"text":"July 3, 1956, ch. 512, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/492"},"text":"70 Stat. 492","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7864cec8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7864cec9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7864ceca-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s445"},"text":"section 445 of Title 7","children":[],"tail":", Agriculture, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
