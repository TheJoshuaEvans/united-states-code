{"tag":"section","attrib":{"id":"id7a29fed1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7504"},"text":null,"children":[{"tag":"num","attrib":{"value":"7504"},"text":"§ 7504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible uses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a29fed2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund may be allocated by the Foundation to support programs and activities intended to better understand and utilize ocean and coastal resources, coastal infrastructure, and ecosystem services provided by natural systems such as coral reefs, including baseline scientific research, ocean observing, and other programs and activities carried out in coordination with Federal and State departments or agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29fed3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds for litigation or other purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No funds made available under this chapter may be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29fed4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fund litigation against the Federal Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fed5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fund the creation of national marine monuments and marine protected areas, marine spatial planning, or the National Ocean Policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a29fed6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dO/tIX/s905"},"text":"Pub. L. 114–113, div. O, title IX, § 905","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3032"},"text":"129 Stat. 3032","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/b"},"text":"Pub. L. 117–263, div. J, title C, § 10001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3951"},"text":"136 Stat. 3951","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a29fed7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a29fed8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a29fed9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “, coastal infrastructure, and ecosystem services provided by natural systems such as coral reefs” for “and coastal infrastructure”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
