{"tag":"section","attrib":{"id":"id7870b614-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s670d"},"text":null,"children":[{"tag":"num","attrib":{"value":"670d"},"text":"§ 670d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for funds; accounting to Comptroller General","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Department of Defense is held free from any liability to pay into the Treasury of the United States upon the operation of the program or programs authorized by this subchapter any funds which may have been or may hereafter be collected, received or expended pursuant to, and for the purposes of, this subchapter, and which collections, receipts and expenditures have been properly accounted for to the Comptroller General of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7870b615-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/797/tI/s104"},"text":"Pub. L. 86–797, title I, § 104","children":[],"tail":", formerly § 4, "},{"tag":"date","attrib":{"date":"1960-09-15"},"text":"Sept. 15, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/1053"},"text":"74 Stat. 1053","children":[],"tail":"; renumbered title I, § 104, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/452/s3/1"},"text":"Pub. L. 93–452, § 3(1)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1974-10-18"},"text":"Oct. 18, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1375"},"text":"88 Stat. 1375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tIII/s312/b/4"},"text":"Pub. L. 112–81, div. A, title III, § 312(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1353"},"text":"125 Stat. 1353","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7870b616-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7870b617-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7870b618-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" inserted section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/452/s3/4"},"text":"Pub. L. 93–452, § 3(4)","children":[],"tail":", substituted “title” for “Act” wherever appearing, which for purposes of codification was translated as “subchapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
