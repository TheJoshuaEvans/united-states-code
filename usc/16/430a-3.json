{"tag":"section","attrib":{"id":"id77908f74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430a–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"430a–3"},"text":"§ 430a–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of laws and regulations to acquired lands and interests therein","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Lands and interests therein acquired pursuant to sections 430a–1 to 430a–3 of this title shall thereupon become a part of the Kings Mountain National Military Park and be subject to all the laws and regulations applicable thereto.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77908f75-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/62/s3"},"text":"Pub. L. 86–62, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-06-23"},"text":"June 23, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/108"},"text":"73 Stat. 108","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
