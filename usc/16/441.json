{"tag":"section","attrib":{"id":"id779a2c68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s441"},"text":null,"children":[{"tag":"num","attrib":{"value":"441"},"text":"§ 441.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Badlands National Park; establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When a quantum, satisfactory to the Secretary of the Interior, of the privately owned lands lying within the area hereinafter described shall have been acquired and transferred to the United States for park purposes, without expense to the Federal Treasury, such areas are dedicated and set apart as a national park for the benefit and enjoyment of the people, under the name of the Badlands National Park: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the State of South Dakota shall have first constructed the highways hereinafter described."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id779a2c69-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-03-04/ch693/s1"},"text":"Mar. 4, 1929, ch. 693, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1553"},"text":"45 Stat. 1553","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tVI/s611"},"text":"Pub. L. 95–625, title VI, § 611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3521"},"text":"92 Stat. 3521","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id779a2c6a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id779a2c6b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id779a2c6c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Hereinafter, referred to in text, means act ","children":[{"tag":"date","attrib":{"date":"1929-03-04"},"text":"Mar. 4, 1929","children":[],"tail":" which is classified to sections 441 to 441e of this title. For classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id779a2c6d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id779a2c6e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “park” and “Park” substituted in text for “monument” and “Monument”, respectively, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/s611"},"text":"Pub. L. 95–625, § 611","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s441e–1"},"text":"section 441e–1 of this title","children":[],"tail":" and which redesignated the Badlands National Monument as the Badlands National Park."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id779a2c6f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Ben Reifel Visitor Center","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/512/tI"},"text":"Pub. L. 101–512, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1923"},"text":"104 Stat. 1923","children":[],"tail":", provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/512/tI"},"text":"“hereafter the Cedar Pass Visitor Center at Badlands National Park, South Dakota, shall be known as the Ben Reifel Visitor Center”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
