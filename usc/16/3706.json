{"tag":"section","attrib":{"id":"id79c3747e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3706"},"text":null,"children":[{"tag":"num","attrib":{"value":"3706"},"text":"§ 3706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits, report requirements, and petition of Attorney General for equitable relief","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79c3747f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s10101"},"text":"section 10101 of title 36","children":[],"tail":", the Foundation shall be treated as a Corporation in part B of subtitle II of title 36."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c37480-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall, as soon as practicable after the end of each fiscal year, transmit to the Committee on Resources of the House of Representatives and the Committee on Environment and Public Works of the Senate a report of its proceedings and activities during such year, including a full and complete statement of its receipts, expenditures, and investments; and a description of all acquisition and disposal of real property that is subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3703/e"},"text":"section 3703(e) of this title","children":[],"tail":". The report shall include a detailed statement of the recipient, amount, and purpose of each grant made by the Foundation in the fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c37481-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief with respect to certain Foundation acts or failure to act","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Foundation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c37482-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3706/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages in, or threatens to engage in, any act, practice, or policy that is inconsistent with its purposes set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3701/b"},"text":"section 3701(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c37483-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3706/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refuses, fails, or neglects to discharge its obligations under this chapter, or threatens to do so;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Attorney General of the United States may petition in the United States District Court for the District of Columbia for such equitable relief as may be necessary or appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c37484-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/244/s7"},"text":"Pub. L. 98–244, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-03-26"},"text":"Mar. 26, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/110"},"text":"98 Stat. 110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/240/s2/b/2"},"text":"Pub. L. 100–240, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-11"},"text":"Jan. 11, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1786"},"text":"101 Stat. 1786","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/408/tII/s205"},"text":"Pub. L. 106–408, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1780"},"text":"114 Stat. 1780","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c37485-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c37486-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79c37487-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s10101"},"text":"section 10101 of title 36","children":[],"tail":"” substituted for “the Act entitled ‘An Act for audit of accounts of private corporations established under Federal law’, approved "},{"tag":"date","attrib":{"date":"1964-08-30"},"text":"August 30, 1964","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/88/504"},"text":"Public Law 88–504","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s1101–110"},"text":"36 U.S.C. 1101–110","children":[],"tail":"3)” and “a corporation in part B of subtitle II of title 36” substituted for “a private corporation established under Federal law” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/105/225/s5/b"},"text":"Pub. L. 105–225, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1499"},"text":"112 Stat. 1499","children":[],"tail":", the first section of which enacted Title 36, Patriotic and National Observances, Ceremonies, and Organizations."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79c37488-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/408"},"text":"Pub. L. 106–408","children":[],"tail":" substituted “the Committee on Resources of the House of Representatives and the Committee on Environment and Public Works of the Senate” for “Congress” and inserted at end “The report shall include a detailed statement of the recipient, amount, and purpose of each grant made by the Foundation in the fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/240"},"text":"Pub. L. 100–240","children":[],"tail":" inserted “; and a description of all acquisition and disposal of real property that is subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3703/e"},"text":"section 3703(e) of this title","children":[],"tail":"” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79c37489-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id79c3748a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79c3748b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions of law requiring submittal to Congress of any annual, semiannual, or other regular periodic report listed in House Document No. 103–7 (in which a report required under subsec. (b) of this section is listed on page 203), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
