{"tag":"section","attrib":{"id":"id7792ffd4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"430f–8"},"text":"§ 430f–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Unit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7792ffd5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the States of Mississippi and Tennessee the Corinth Unit of the Shiloh National Military Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7792ffd6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition of Unit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Unit shall be comprised of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7792ffd7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–8/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approximately 950 acres, as generally depicted on the Map; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7792ffd8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–8/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any additional land that the Secretary determines to be suitable for inclusion in the Unit that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7792ffd9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–8/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is under the ownership of a public entity or nonprofit organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7792ffda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–8/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been identified by the Siege and Battle of Corinth National Historic Landmark Study, dated ","children":[{"tag":"date","attrib":{"date":"1991-01-08"},"text":"January 8, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7792ffdb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Map shall be on file and available for public inspection in the office of the Director of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7792ffdc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/271/s4"},"text":"Pub. L. 106–271, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-09-22"},"text":"Sept. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/793"},"text":"114 Stat. 793","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dF/tI/s127/2"},"text":"Pub. L. 110–161, div. F, title I, § 127(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2122"},"text":"121 Stat. 2122","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7792ffdd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7792ffde-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7792ffdf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161"},"text":"Pub. L. 110–161","children":[],"tail":" added par. (1) and struck out former par. (1) which read as follows: “the tract consisting of approximately 20 acres generally depicted as ‘Battery Robinett Boundary’ on the Map; and”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
