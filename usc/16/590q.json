{"tag":"section","attrib":{"id":"id78569de3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590q"},"text":null,"children":[{"tag":"num","attrib":{"value":"590q"},"text":"§ 590q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage; “State” defined; short title","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78569de4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This chapter shall apply to the States, the Commonwealth of Puerto Rico, Guam, American Samoa, the Northern Mariana Islands, and the Virgin Islands, and, as used in this chapter, the term “State” includes Puerto Rico, Guam, American Samoa, the Northern Mariana Islands, and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78569de5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This chapter may be cited as the “Soil Conservation and Domestic Allotment Act”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78569de6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-04-27/ch85/s17"},"text":"Apr. 27, 1935, ch. 85, § 17","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1936-02-29/ch104/s1"},"text":"Feb. 29, 1936, ch. 104, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1151"},"text":"49 Stat. 1151","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch339/s2"},"text":"July 26, 1947, ch. 339, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/494"},"text":"61 Stat. 494","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/70/s13/b"},"text":"Pub. L. 86–70, § 13(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-06-25"},"text":"June 25, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/143"},"text":"73 Stat. 143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/624"},"text":"Pub. L. 86–624","children":[],"tail":". § 8(b), "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/412"},"text":"74 Stat. 412","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/454/tVI/s601/d"},"text":"Pub. L. 98–454, title VI, § 601(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-05"},"text":"Oct. 5, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1736"},"text":"98 Stat. 1736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78569de7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78569de8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78569de9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/454"},"text":"Pub. L. 98–454","children":[],"tail":" inserted reference to Guam, American Samoa, and the Northern Mariana Islands in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/624"},"text":"Pub. L. 86–624","children":[],"tail":" substituted “States, the Commonwealth of Puerto Rico” for “States, the Territory of Hawaii, and the possessions of Puerto Rico”, and struck out “Hawaii” from definition of “State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/70"},"text":"Pub. L. 86–70","children":[],"tail":" substituted “the States, the Territory of Hawaii,” for “the United States, the Territories of Alaska and Hawaii”, and struck out “Alaska,” after “the term ‘State’ includes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1947—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":", included the Virgin Islands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78569dea-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"id78569deb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3 of act ","children":[{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":", repealed all laws in conflict therewith."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
