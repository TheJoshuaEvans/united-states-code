{"tag":"section","attrib":{"id":"id79dd8bf9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3846"},"text":null,"children":[{"tag":"num","attrib":{"value":"3846"},"text":"§ 3846.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79dd8bfa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3846/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate such regulations as are necessary to implement programs under this chapter, including such regulations as the Secretary determines to be necessary to ensure a fair and reasonable application of the limitations established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3844/f"},"text":"section 3844(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dd8bfb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3846/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking procedure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The promulgation of regulations and administration of programs under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dd8bfc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3846/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be carried out without regard to chapter 35 of title 44 (commonly known as the Paperwork Reduction Act); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8bfd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3846/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made as an interim rule effective on publication with an opportunity for notice and comment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dd8bfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3846/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional review of agency rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In promulgating regulations under this section, the Secretary shall use the authority provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s808"},"text":"section 808 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79dd8bff-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1246"},"text":"Pub. L. 99–198, title XII, § 1246","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2608"},"text":"Pub. L. 113–79, title II, § 2608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/761"},"text":"128 Stat. 761","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79dd8c00-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79dd8c01-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79dd8c02-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b), was in the original “this title”, meaning title XII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":", which enacted this chapter and former "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2005a"},"text":"section 2005a of this title","children":[],"tail":" and amended sections 590g, 2004, 2005, 2006, and 2009 of this title, sections 4207 and 4209 of Title 7, Agriculture, and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1981"},"text":"section 1981 of Title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79dd8c03-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3846, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1246"},"text":"Pub. L. 99–198, title XII, § 1246","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIV/s1444"},"text":"Pub. L. 101–624, title XIV, § 1444","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3602"},"text":"104 Stat. 3602","children":[],"tail":", directed Secretary to report to Congress on erodible land and wetland conservation program, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1011/a"},"text":"Pub. L. 104–66, title I, § 1011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","at