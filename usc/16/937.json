{"tag":"section","attrib":{"id":"id78d4f578-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s937"},"text":null,"children":[{"tag":"num","attrib":{"value":"937"},"text":"§ 937.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Section as agency of United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Section shall, for the purposes of these ","children":[{"tag":"ref","attrib":{"idref":"fn002560"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002560"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “those”."}],"tail":" provisions of title 28, relating to claims against the United States and tort claims procedure, be deemed to be an agency of the United States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78d4f579-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-06-04/ch358/s8"},"text":"June 4, 1956, ch. 358, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/243"},"text":"70 Stat. 243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78d4f57a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78d4f57b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78d4f57c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of title 28, relating to claims against the United States, referred to in text, include sections 1346(b), 2501 et seq., and 2671 et seq., of Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
