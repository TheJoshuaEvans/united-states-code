{"tag":"section","attrib":{"id":"id774de087-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22"},"text":null,"children":[{"tag":"num","attrib":{"value":"410cc–22"},"text":"§ 410cc–22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id774de088-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified property; manner of acquisition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id774de089-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is authorized to acquire the properties designated in paragraph (2) of this subsection, or any interest therein, by donation, purchase with donated or appropriated funds, condemnation, or otherwise. Any property or interest therein owned by the Commonwealth of Massachusetts or any political subdivision thereof may be acquired only by donation. The Secretary may initiate condemnation proceedings under this paragraph only after making every reasonable effort to acquire property through negotiations and purchase, and consulting with the Commission (if established) and the city council of Lowell.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id774de08a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The properties referred to in paragraph (1) of this subsection are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id774de08b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Linus Childs House, 63 Kirk Street.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id774de08c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The H and H Paper Company (commonly referred to as Boott Mill Boarding House), 42 French Street.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id774de08d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Old City Hall, 226 Merrimack Street.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id774de08e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Merrimack Gatehouse, 269 Merrimack Street.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id774de08f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Wannalancit Textile Company, 562 Suffolk Street.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id774de090-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The structures containing the Jade Pagoda and Solomon’s Yard Goods, 210 and 200 Merrimack Street.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id774de091-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The properties shown on the map identified in section 410cc–11(a)(3) ","children":[{"tag":"ref","attrib":{"idref":"fn002101"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002101"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title as follows:"}],"tail":null},{"tag":"clause","attrib":{"id":"id774de092-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/a/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 91 Pevey Street.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id774de093-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/a/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The portion of 607 Middlesex Place.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id774de094-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/a/2/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eagle Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id774de095-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/a/2/G/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The portion of 50 Payne Street.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id774de096-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/a/2/G/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 726 Broadway.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774de097-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other property; criteria for acquisition; manner of acquisition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Until the date on which the Commission conducts its first meeting, the Secretary may acquire any property within the park or preservation district not designated in subsection (a)(2) of this section, or any interest therein, if such property—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id774de098-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is identified in the report of the Lowell Historical Canal District Commission as a property which should be preserved, restored, managed, developed, or maintained in a manner consistent with the purpose of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id774de099-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is listed in the National Register of Historic Places, as maintained by the Secretary pursuant to chapter 3021 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s320102/c"},"text":"section 320102(c) of title 54","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id774de09a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by the Secretary to be of national significance;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and would be subject to demolition or major alteration in a manner inconsistent with the purposes of this subchapter unless acquired by the Secretary. Such property may be acquired only as provided in subsection (a)(1) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774de09b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Easements; manner of acquisition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire easements within the park for the purpose of carrying out this subchapter. Such easements may be acquired only as provided in subsection (a)(1) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774de09c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of land or interest in land","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id774de09d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may exchange any land or interest in land within the boundaries of the park for any land or interest in land owned by the Commonwealth of Massachusetts, the city of Lowell, or the University of Massachusetts Building Authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id774de09e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (3), an exchange under this subsection shall be subject to the laws, regulations, and policies applicable to exchanges of land administered by the National Park Service and any other terms and conditions that the Secretary determines to be necessary to protect the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id774de09f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–22/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Where facilities or infrastructure required for the management and operation of the Lowell National Historical Park exists on the Federal land to be exchanged, and the non-Federal land or interest in land to be exchanged is not of equal value, the values shall be equalized by the payment of cash to the Secretary. The Secretary shall not be required to equalize the values of any exchange conducted under this subsection if the land or interest in land received by the Federal Government exceeds the value of the Federal land or interest in land exchanged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id774de0a0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/290/tII/s202"},"text":"Pub. L. 95–290, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-05"},"text":"June 5, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/293"},"text":"92 Stat. 293","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/229/tIII/s312/2"},"text":"Pub. L. 110–229, title III, § 312(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-08"},"text":"May 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/769"},"text":"122 Stat. 769","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/182/s2"},"text":"Pub. L. 112–182, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-10-05"},"text":"Oct. 5, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1420"},"text":"126 Stat. 1420","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id774de0a1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id774de0a2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id774de0a3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410cc–11/a/3"},"text":"Section 410cc–11(a)(3) of this title","children":[],"tail":", referred to in subsec. (a)(2)(G), was in the original “subsection (101)(a)(3)” and was translated as meaning "},{"tag":"ref","attrib":{"href":"/us/pl/95/290/s101/a/3"},"text":"section 101(a)(3) of Pub. L. 95–290","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410cc–11/a/3"},"text":"section 410cc–11(a)(3) of this title","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id774de0a4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b)(2), “chapter 3021 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s320102/c"},"text":"section 320102(c) of title 54","children":[],"tail":"” substituted for “section 101(a) of the Act entitled ‘An Act to establish a program for the preservation of additional historic properties throughout the Nation, and for other purposes’, approved "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"October 15, 1966","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s470a"},"text":"16 U.S.C. 470a","children":[],"tail":"), and section 2(b) of the Act entitled ‘An Act to provide for the preservation of historic American sites, buildings, objects, and antiquities of national significance, and for other purposes’, approved "},{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s462"},"text":"16 U.S.C. 462","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/e"},"text":"Pub. L. 113–287, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3272"},"text":"128 Stat. 3272","children":[],"tail":", which Act enacted Title 54, National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id774de0a5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/182"},"text":"Pub. L. 112–182","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/229"},"text":"Pub. L. 110–229","children":[],"tail":" added subpar. (G)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
