{"tag":"section","attrib":{"id":"id795a7970-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1647"},"text":null,"children":[{"tag":"num","attrib":{"value":"1647"},"text":"§ 1647.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Federal programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id795a7971-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1647/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeal of statutory authorities relating to investigation, experiments, and tests in reforestation and forest products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1928-05-22"},"text":"May 22, 1928","children":[],"tail":", known as the McSweeney-McNary Act ("},{"tag":"ref","attrib":{"href":"/us/stat/45/699-702"},"text":"45 Stat. 699–702","children":[],"tail":", as amended; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s581"},"text":"16 U.S.C. 581","children":[],"tail":", 581a, 581b–581i), is hereby repealed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795a7972-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1647/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Force and effect of cooperative and other agreements under repealed statutory authorities relating to investigation, etc., in reforestation and forest products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Contracts and cooperative and other agreements under the McSweeney-McNary Act shall remain in effect until revoked or amended by their own terms or under other provisions of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795a7973-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1647/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of rules and regulations for implementation of provisions and coordination with agricultural research, extension, and teaching provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to issue such rules and regulations as the Secretary deems necessary to implement the provisions of this subchapter and to coordinate this subchapter with title XIV of the Food and Agriculture Act of 1977 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3101"},"text":"7 U.S.C. 3101","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795a7974-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1647/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds appropriated under repealed statutory authorities relating to investigation, etc., in reforestation and forest products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated under the authority of the McSweeney-McNary Act shall be available for expenditure for the programs authorized under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id795a7975-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/307/s8"},"text":"Pub. L. 95–307, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-30"},"text":"June 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/356"},"text":"92 Stat. 356","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795a7976-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id795a7977-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id795a7978-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Food and Agriculture Act of 1977, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113"},"text":"Pub. L. 95–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/913"},"text":"91 Stat. 913","children":[],"tail":". Title XIV of the Food and Agriculture Act of 1977, known as the “National Agricultural Research, Extension, and Teaching Policy Act of 1977”, is classified principally to chapter 64 (§ 3101 et seq.) of Title 7, Agriculture. For complete classification of this title to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3101"},"text":"section 3101 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
