{"tag":"section","attrib":{"id":"id77681ff4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–75"},"text":"§ 410aaa–75.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American uses and interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77681ff5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure access to areas designated under this Act by members of Indian Tribes for traditional cultural and religious purposes, consistent with applicable law, including ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/341"},"text":"Public Law 95–341","children":[],"tail":" (commonly known as the “American Indian Religious Freedom Act”) ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1996"},"text":"42 U.S.C. 1996","children":[],"tail":" [, 1996a])."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77681ff6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary closure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77681ff7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with applicable law, including ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/341"},"text":"Public Law 95–341","children":[],"tail":" (commonly known as the “American Indian Religious Freedom Act”) ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1996"},"text":"42 U.S.C. 1996","children":[],"tail":" [, 1996a]), and subject to paragraph (2), the Secretary, on request of an Indian Tribe or Indian religious community, shall temporarily close to general public use any portion of an area designated as a national monument, special management area, wild and scenic river, area of critical environmental concern, or National Park System unit under this Act (referred to in this subsection as a “designated area”) to protect the privacy of traditional cultural and religious activities in the designated area by members of the Indian Tribe or Indian religious community."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77681ff8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In closing a portion of a designated area under paragraph (1), the Secretary shall limit the closure to the smallest practicable area for the minimum period necessary for the traditional cultural and religious activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77681ff9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77681ffa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, in consultation with the Timbisha Shoshone Tribe and relevant Federal agencies, shall conduct a study, subject to the availability of appropriations, to identify lands suitable for a reservation for the Timbisha Shoshone Tribe that are located within the Tribe’s aboriginal homeland area within and outside the boundaries of the Death Valley National Monument and the Death Valley National Park, as described in part A of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77681ffb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1994-10-31"},"text":"October 31, 1994","children":[],"tail":", the Secretary shall submit a report to the Committee on Energy and Natural Resources and the Committee on Indian Affairs of the United States Senate, and the Committee on Natural Resources of the United States House of Representatives on the results of the study conducted under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77681ffc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal cultural resources management plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77681ffd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall develop and implement a Tribal cultural resources management plan to identify, protect, and conserve cultural resources of Indian Tribes associated with the Xam Kwatchan Trail network extending from Avikwaame (Spirit Mountain, Nevada) to Avikwlal (Pilot Knob, California)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77681ffe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall consult on the development and implementation of the Tribal cultural resources management plan under paragraph (1) with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77681fff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77682000-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chemehuevi Indian Tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77682001-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Hualapai Tribal Nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77682002-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Fort Mojave Indian Tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77682003-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Colorado River Indian Tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77682004-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Quechan Indian Tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77682005-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Cocopah Indian Tribe;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77682006-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Advisory Council on Historic Preservation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77682007-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State Historic Preservation Offices of Nevada, Arizona, and California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77682008-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resource protection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Tribal cultural resources management plan developed under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77682009-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be based on a completed Tribal cultural resources survey; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7768200a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include procedures for identifying, protecting, and preserving petroglyphs, ancient trails, intaglios, sleeping circles, artifacts, and other resources of cultural, archaeological, or historical significance in accordance with all applicable laws and policies, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7768200b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 2003 of title 54;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7768200c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/341"},"text":"Public Law 95–341","children":[],"tail":" (commonly known as the “American Indian Religious Freedom Act”) ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1996"},"text":"42 U.S.C. 1996","children":[],"tail":" [, 1996a]);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7768200d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Archaeological Resources Protection Act of 1979 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s470aa"},"text":"16 U.S.C. 470aa","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7768200e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Native American Graves Protection and Repatriation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"25 U.S.C. 3001","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7768200f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/d/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/141"},"text":"Public Law 103–141","children":[],"tail":" (commonly known as the “Religious Freedom Restoration Act of 1993”) ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000bb"},"text":"42 U.S.C. 2000bb","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77682010-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, all Federal land within the area administratively withdrawn and known as the “Indian Pass Withdrawal Area” is permanently withdrawn from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77682011-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all forms of entry, appropriation, or disposal under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77682012-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77682013-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–75/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" right-of-way leasing and disposition under all laws relating to minerals or solar, wind, or geothermal energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77682014-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tVII/s705"},"text":"Pub. L. 103–433, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4498"},"text":"108 Stat. 4498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1454"},"text":"Pub. L. 116–9, title I, § 1454","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/714"},"text":"133 Stat. 714","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77682015-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77682016-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77682017-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (a) and (b)(1), is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/s3"},"text":"section 3 of Pub. L. 103–433","children":[],"tail":", which is set out as a Definitions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410aaa"},"text":"section 410aaa of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The American Indian Religious Freedom Act, referred to in subsecs. (a), (b)(1), and (d)(3)(B)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/341"},"text":"Pub. L. 95–341","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-11"},"text":"Aug. 11, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/469"},"text":"92 Stat. 469","children":[],"tail":", which is classified to sections 1996 and 1996a of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1996"},"text":"section 1996 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Archaeological Resources Protection Act of 1979, referred to in subsec. (d)(3)(B)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/95"},"text":"Pub. L. 96–95","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-31"},"text":"Oct. 31, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/721"},"text":"93 Stat. 721","children":[],"tail":", which is classified generally to chapter 1B (§ 470aa et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s470aa"},"text":"section 470aa of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Native American Graves Protection and Repatriation Act, referred to in subsec. (d)(3)(B)(iv), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/601"},"text":"Pub. L. 101–601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3048"},"text":"104 Stat. 3048","children":[],"tail":", which is classified principally to chapter 32 (§ 3001 et seq.) of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"section 3001 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Religious Freedom Restoration Act of 1993, referred to in subsec. (d)(3)(B)(v), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/141"},"text":"Pub. L. 103–141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-16"},"text":"Nov. 16, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1488"},"text":"107 Stat. 1488","children":[],"tail":", which is classified principally to chapter 21B (§ 2000bb et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000bb"},"text":"section 2000bb of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77682018-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9"},"text":"Pub. L. 116–9","children":[],"tail":" added subsecs. (a), (b), (d), and (e), redesignated former subsec. (b) as (c), and struck out former subsec. (a) which related to access to park system units and wilderness areas by Indian people for traditional cultural and religious purposes."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id776a6909-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id776a690a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/s103"},"text":"Section 103 of Pub. L. 103–433","children":[],"tail":" provided in part that in this subchapter “Secretary” means the Secretary of the Interior."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
