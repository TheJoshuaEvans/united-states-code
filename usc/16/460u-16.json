{"tag":"section","attrib":{"id":"id77cc380c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–16"},"text":null,"children":[{"tag":"num","attrib":{"value":"460u–16"},"text":"§ 460u–16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Road construction cooperative agreements with landowners north of Little Calumet River; prevention of soil erosion; minimization of aural and visual impact","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into a cooperative agreement with the landowner of those lands north of the Little Calumet River between the Penn Central Railroad bridge within area II–E and “Crossing A” within area IV–C on the map referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460u–3"},"text":"section 460u–3 of this title","children":[],"tail":", dated October 1976, and numbered 626–9100."},{"tag":"ref","attrib":{"idref":"fn002311"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002311"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “September 1976, and numbered 626–91007.”"}],"tail":" Such agreement shall provide that any roadway constructed by the landowner south of United States Route 12 within such vicinity shall include grading, landscaping, and plantings of vegetation designed to prevent soil erosion and to minimize the aural and visual impacts of said construction, and of traffic on such roadway, as perceived from the Little Calumet River."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77cc380d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/761/s16"},"text":"Pub. L. 89–761, § 16","children":[],"tail":", formerly § 17, as added and renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/94/549/s1/8"},"text":"Pub. L. 94–549, § 1(8)","children":[],"tail":", (9), "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2531"},"text":"90 Stat. 2531","children":[],"tail":", 2533; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/583/s1/g"},"text":"Pub. L. 99–583, § 1(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-29"},"text":"Oct. 29, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3320"},"text":"100 Stat. 3320","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77cc380e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77cc380f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77cc3810-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/583"},"text":"Pub. L. 99–583","children":[],"tail":" inserted provisions relating to the map referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460u–3"},"text":"section 460u–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
