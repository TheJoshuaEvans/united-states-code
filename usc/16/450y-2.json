{"tag":"section","attrib":{"id":"id77a157a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450y–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"450y–2"},"text":"§ 450y–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing within memorial area","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior, under such regulations as shall be prescribed by him, which regulations shall be substantially similar to those now in effect, shall permit—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Grazing of livestock within the memorial area to the extent now permitted within the said area when such grazing will not interfere with recreational development authorized by sections 450y to 450y–4 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a157a3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-08-18/ch365/s3"},"text":"Aug. 18, 1941, ch. 365, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/631"},"text":"55 Stat. 631","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/429/s3/f"},"text":"Pub. L. 94–429, § 3(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-28"},"text":"Sept. 28, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1342"},"text":"90 Stat. 1342","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77a157a4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77a157a5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77a157a6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/429"},"text":"Pub. L. 94–429","children":[],"tail":" struck out designation “(a)” before “grazing of livestock” and struck out subsec. (b) which related to the surface use of the land within the memorial area for prospecting and mining."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77a157a7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77a157a8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Mining Rights Existing Prior to 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/429/s3"},"text":"Section 3 of Pub. L. 94–429","children":[],"tail":" provided in part that this section was amended as indicated in order to close area to entry and location under the Mining Law of 1872, subject to valid existing rights."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
