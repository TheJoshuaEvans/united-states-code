{"tag":"section","attrib":{"id":"id7a0adde0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6414"},"text":null,"children":[{"tag":"num","attrib":{"value":"6414"},"text":"§ 6414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0adde1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated to the Administrator $45,000,000 for each of fiscal years 2023 through 2027 to carry out this chapter which shall remain available until expended. Of such amounts, there is authorized to be appropriated for each such fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0adde2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6414/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $12,000,000 to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6406"},"text":"section 6406 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0adde3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6414/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,500,000 for activities authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6410"},"text":"section 6410 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0adde4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6414/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,500,000 to be provided to the cooperative institutes designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6411/a"},"text":"section 6411(a) of this title","children":[],"tail":" to carry out the functions described in such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0adde5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 10 percent of the amounts appropriated under subsection (a) may be used for program administration or overhead costs incurred by the National Oceanic and Atmospheric Administration or the Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0adde6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s215"},"text":"Pub. L. 106–562, title II, § 215","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/a"},"text":"Pub. L. 117–263, div. J, title C, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3947"},"text":"136 Stat. 3947","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
