{"tag":"section","attrib":{"id":"id79a209d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2708"},"text":null,"children":[{"tag":"num","attrib":{"value":"2708"},"text":"§ 2708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a209d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a209d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2708/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “small hydroelectric power project” means any hydroelectric power project which is located at the site of any existing dam, which uses the water power potential of such dam, and which has not more than 30,000 kilowatts of installed capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2708/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “electric cooperative” means any cooperative association eligible to receive loans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s904"},"text":"section 904 of title 7","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2708/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “industrial development agency” means any agency which is permitted to issue obligations the interest on which is excludable from gross income under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s103"},"text":"section 103 of title 26","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2708/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “project costs” means the cost of acquisiiton ","children":[{"tag":"ref","attrib":{"idref":"fn002731"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002731"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “acquisition”."}],"tail":" or construction of all facilities and services and the cost of acquisition of all land and interests in land used in the design and construction and operation of a small hydroelectric power project;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2708/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “nonprofit organization” means any organization described in section 501(c)(3) or 501(c)(4) of title 26 and exempt from tax under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/a"},"text":"section 501(a) of title 26","children":[],"tail":" (but only with respect to a trade or business carried on by such organization which is not an unrelated trade or business, determined by applying "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s513/a"},"text":"section 513(a) of title 26","children":[],"tail":" to such organization);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2708/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “existing dam” means any dam, the construction of which was completed or on ","children":[{"tag":"ref","attrib":{"idref":"fn002732"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002732"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “on or”."}],"tail":" before "},{"tag":"date","attrib":{"date":"2005-07-22"},"text":"July 22, 2005","children":[],"tail":", and which does not require any construction or enlargement of impoundment structures (other than repairs or reconstruction) in connection with the installation of any small hydroelectric power project;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2708/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “municipality” has the meaning provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s796"},"text":"section 796 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2708/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “person” has the meaning provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s796"},"text":"section 796 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a209de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The requirement in subsection (a)(1) that a project be located at the site of an existing dam in order to qualify as a small hydroelectric power project, and the other provisions of this chapter which require that a project be at or in connection with an existing dam (or utilize the potential of such dam) in order to be assisted under or included within such provisions, shall not be construed to exclude—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a209df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2708/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the definition contained in such subsection (a)(1), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2708/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from any other provision of this chapter,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any project which utilizes or proposes to utilize natural water features for the generation of electricity, without the need for any dam or impoundment, in a manner which (as determined by the Commission) will achieve the purposes of this chapter and will do so without any adverse effect upon such natural water features.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a209e1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617/tIV/s408"},"text":"Pub. L. 95–617, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3156"},"text":"92 Stat. 3156","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/294/tIV/s408/a"},"text":"Pub. L. 96–294, title IV, § 408(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/718"},"text":"94 Stat. 718","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s246"},"text":"Pub. L. 109–58, title II, § 246","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/679"},"text":"119 Stat. 679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a209e2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a209e3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79a209e4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Commission, referred to in subsec. (b), means the Federal Energy Regulatory Commission, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2602/3"},"text":"section 2602(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79a209e5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2005-07-22"},"text":"July 22, 2005","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1977-04-20"},"text":"April 20, 1977","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(3), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/s408/a"},"text":"Pub. L. 96–294, § 408(a)","children":[],"tail":", (c)(1), designated existing provisions as subsec. (a) and, as so designated, in par. (1) substituted “30,000” for “15,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/s408/c/2"},"text":"Pub. L. 96–294, § 408(c)(2)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
