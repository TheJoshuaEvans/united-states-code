{"tag":"section","attrib":{"id":"id7807e26b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu"},"text":null,"children":[{"tag":"num","attrib":{"value":"460uuu"},"text":"§ 460uuu.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mount Hood National Recreation Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7807e26c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To provide for the protection, preservation, and enhancement of recreational, ecological, scenic, cultural, watershed, and fish and wildlife values, there is established the Mount Hood National Recreation Area within the Mount Hood National Forest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e26d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Mount Hood National Recreation Area shall consist of certain Federal land managed by the Forest Service and Bureau of Land Management, comprising approximately 34,550 acres, as generally depicted on the maps entitled “National Recreation Areas—Mount Hood NRA”, “National Recreation Areas—Fifteenmile Creek NRA”, and “National Recreation Areas—Shellrock Mountain”, dated February 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e26e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map and legal description","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e26f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of legal description","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", the Secretary shall file a map and a legal description of the Mount Hood National Recreation Area with—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7807e270-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Natural Resources of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e271-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Natural Resources of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e272-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Force of law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description filed under paragraph (1) shall have the same force and effect as if included in this subtitle, except that the Secretary may correct typographical errors in the map and the legal description.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e273-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description filed under paragraph (1) shall be on file and available for public inspection in the appropriate offices of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e274-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e275-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7807e276-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" administer the Mount Hood National Recreation Area—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7807e277-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the laws (including regulations) and rules applicable to the National Forest System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7807e278-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the purposes described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e279-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only allow uses of the Mount Hood National Recreation Area that are consistent with the purposes described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e27a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any portion of a wilderness area designated by section 1202 ","children":[{"tag":"ref","attrib":{"idref":"fn002389"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002389"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" that is located within the Mount Hood National Recreation Area shall be administered in accordance with the Wilderness Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e27b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timber","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The cutting, sale, or removal of timber within the Mount Hood National Recreation Area may be permitted—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e27c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent necessary to improve the health of the forest in a manner that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7807e27d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maximizes the retention of large trees—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7807e27e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate to the forest type; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7807e27f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that the trees promote stands that are fire-resilient and healthy;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e280-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves the habitats of threatened, endangered, or sensitive species; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e281-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains or restores the composition and structure of the ecosystem by reducing the risk of uncharacteristic wildfire;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e282-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accomplish an approved management activity in furtherance of the purposes established by this section, if the cutting, sale, or removal of timber is incidental to the management activity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e283-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for de minimus personal or administrative use within the Mount Hood National Recreation Area, where such use will not impair the purposes established by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e284-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Road construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No new or temporary roads shall be constructed or reconstructed within the Mount Hood National Recreation Area except as necessary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e285-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect the health and safety of individuals in cases of an imminent threat of flood, fire, or any other catastrophic event that, without intervention, would cause the loss of life or property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e286-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct environmental cleanup required by the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e287-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow for the exercise of reserved or outstanding rights provided for by a statute or treaty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e288-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent irreparable resource damage by an existing road; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e289-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to rectify a hazardous road condition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e28a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, all Federal land within the Mount Hood National Recreation Area is withdrawn from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e28b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all forms of entry, appropriation, or disposal under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e28c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e28d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disposition under all laws relating to mineral and geothermal leasing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e28e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of administrative jurisdiction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e28f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Administrative jurisdiction over the Federal land described in paragraph (2) is transferred from the Bureau of Land Management to the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e290-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460uuu/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The land referred to in paragraph (1) is the approximately 130 acres of land administered by the Bureau of Land Management that is within or adjacent to the Mount Hood National Recreation Area and that is identified as “BLM Lands” on the map entitled “National Recreation Areas—Shellrock Mountain”, dated February 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7807e291-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tI/s1204"},"text":"Pub. L. 111–11, title I, § 1204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1013"},"text":"123 Stat. 1013","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7807e292-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7807e293-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7807e294-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subtitle, referred to in subsec. (c)(2), is subtitle C (§§ 1201–1207) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1007"},"text":"123 Stat. 1007","children":[],"tail":", which enacted this subchapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539n"},"text":"section 539n of this title","children":[],"tail":", amended sections 544k and 1274 of this title, enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1274"},"text":"section 1274 of this title","children":[],"tail":", enacted provisions listed in a table of National Memorials set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320301"},"text":"section 320301 of Title 54","children":[],"tail":", National Park Service and Related Programs, and enacted and amended provisions listed in a table of Wilderness Areas set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"section 1132 of this title","children":[],"tail":". For complete classification of subtitle C to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1202, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s1202"},"text":"section 1202 of Pub. L. 111–11","children":[],"tail":", which enacted provisions listed in a table of National Memorials set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320301"},"text":"section 320301 of Title 54","children":[],"tail":", National Park Service and Related Programs, and enacted and amended provisions listed in a table of Wilderness Areas set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"section 1132 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Wilderness Act, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/577"},"text":"Pub. L. 88–577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-03"},"text":"Sept. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/890"},"text":"78 Stat. 890","children":[],"tail":", which is classified generally to chapter 23 (§ 1131 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"section 1131 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7807e295-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7807e296-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tI/s1201"},"text":"Pub. L. 111–11, title I, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1007"},"text":"123 Stat. 1007","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/11/tI/s1201"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this subtitle [subtitle C (§§ 1201–1207) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":", see References in Text note above]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘State’ means the State of Oregon.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
