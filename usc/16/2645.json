{"tag":"section","attrib":{"id":"id79a20989-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2645"},"text":null,"children":[{"tag":"num","attrib":{"value":"2645"},"text":"§ 2645.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utility regulatory institute","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a2098a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2645/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make grants under this section to an institute established by the National Association of Regulatory Utility Commissioners to enable such institute to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a2098b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2645/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research on electric and gas utility regulatory policy issues,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2098c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2645/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop data processing and retrieval methods for electric and gas utility ratemaking, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2098d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2645/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform other functions directly related to assisting State regulatory authorities in carrying out their functions under State law and this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a2098e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2645/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under this section shall not be used to provide more than the following percentages of the cost to the institute of carrying out the activities specified in subsection (a):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a2098f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2645/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent for the fiscal year 1979; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20990-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2645/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 percent for the fiscal year 1980.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The remaining amounts expended by the institute may not be provided from Federal sources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a20991-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2645/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under this section may not be made subject to terms and conditions other than those the Secretary deems necessary for purposes of administering this section and for purposes of assuring that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a20992-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2645/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all information gathered by the institute is available to the Secretary, the Commission, and the public, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20993-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2645/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no portion of any such grant is used to support or oppose any legislative proposal except by means of testimony by representatives of the institute provided by invitation to a committee of Congress or of a State legislature.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a20994-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2645/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated not more than $2,000,000 for each of the fiscal years 1979 and 1980 for purposes of making grants under this section. No amounts may be appropriated for any fiscal year after the fiscal year 1980 to carry out the purposes of this section without a specific authorization of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a20995-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617/tVI/s603"},"text":"Pub. L. 95–617, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3165"},"text":"92 Stat. 3165","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a20996-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a20997-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79a20998-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617"},"text":"Pub. L. 95–617","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3117"},"text":"92 Stat. 3117","children":[],"tail":", known as the Public Utility Regulatory Policies Act of 1978. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2601"},"text":"section 2601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79a20999-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section was not enacted as part of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617"},"text":"Pub. L. 95–617","children":[],"tail":" which comprises this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
