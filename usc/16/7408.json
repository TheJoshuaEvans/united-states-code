{"tag":"section","attrib":{"id":"id7a29fea4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7408"},"text":null,"children":[{"tag":"num","attrib":{"value":"7408"},"text":"§ 7408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International cooperation and assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a29fea5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to developing nations and international organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with existing authority and the availability of funds, the Secretary shall provide appropriate assistance to developing nations and international organizations of which such nations are members to assist those nations in meeting their obligations under the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29fea6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel, services, equipment, and facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (a), the Secretary may, by agreement, on a reimbursable or nonreimbursable basis, utilize the personnel, services, equipment, and facilities of any Federal, State, local, or foreign government or any entity of any such government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a29fea7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/81/tIII/s309"},"text":"Pub. L. 114–81, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/669"},"text":"129 Stat. 669","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
