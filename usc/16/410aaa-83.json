{"tag":"section","attrib":{"id":"id776a69a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–83"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–83"},"text":"§ 410aaa–83.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the National Park Service and to the Bureau of Land Management to carry out this Act an amount not to exceed $36,000,000 over and above that provided in fiscal year 1994 for additional administrative and construction costs over the fiscal year 1995–1999 period, and $300,000,000 for all land acquisition costs. No funds in excess of these amounts may be used for construction, administration, or land acquisition authorized under this Act without a specific authorization in an Act of Congress enacted after ","children":[{"tag":"date","attrib":{"date":"1994-10-31"},"text":"October 31, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id776a69a7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tIX/s901"},"text":"Pub. L. 103–433, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4508"},"text":"108 Stat. 4508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id776a69a8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id776a69a9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id776a69aa-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/s3"},"text":"section 3 of Pub. L. 103–433","children":[],"tail":", which is set out as a Definitions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410aaa"},"text":"section 410aaa of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
