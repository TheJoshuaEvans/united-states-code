{"tag":"section","attrib":{"id":"id795807da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1613"},"text":null,"children":[{"tag":"num","attrib":{"value":"1613"},"text":"§ 1613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as he determines necessary and desirable to carry out the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id795807db-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/378/s15"},"text":"Pub. L. 93–378, § 15","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/588/s11"},"text":"Pub. L. 94–588, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2958"},"text":"90 Stat. 2958","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/tII/s208/b/2"},"text":"Pub. L. 115–141, div. O, title II, § 208(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1066"},"text":"132 Stat. 1066","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795807dc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id795807dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id795807de-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “Secretary” for “Secretary of Agriculture”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id795807df-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id795807e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of certain enforcement functions of Secretary or other official in Department of Agriculture under this subchapter to Federal Inspector, Office of Federal Inspector for Alaska Natural Gas Transportation System, and subsequent transfer to Secretary of Energy, then to Federal Coordinator for Alaska Natural Gas Transportation Projects, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1601"},"text":"section 1601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
