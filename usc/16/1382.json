{"tag":"section","attrib":{"id":"id792140d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1382"},"text":null,"children":[{"tag":"num","attrib":{"value":"1382"},"text":"§ 1382.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792140d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1382/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with any other Federal agency to the extent that such agency may be affected, shall prescribe such regulations as are necessary and appropriate to carry out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792140d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1382/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation by Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal agency is authorized and directed to cooperate with the Secretary, in such manner as may be mutually agreeable, in carrying out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792140d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1382/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts, leases, and cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into such contracts, leases, cooperative agreements, or other transactions as may be necessary to carry out the purposes of this subchapter or subchapter V and on such terms as he deems appropriate with any Federal or State agency, public or private institution, or other person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792140d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1382/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual review; suspension of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review annually the operation of each program in which the United States participates involving the taking of marine mammals on lands. If at any time the Secretary finds that any such program cannot be administered on lands owned by the United States or in which the United States has an interest in a manner consistent with the purposes of ","children":[{"tag":"ref","attrib":{"idref":"fn002626"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002626"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" policies of this chapter, he shall suspend the operation of that program and shall include in the annual report to the public and the Congress required under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1373/f"},"text":"section 1373(f) of this title","children":[],"tail":" his reasons for such suspension, together with recommendations for such legislation as he deems necessary and appropriate to resolve the problem."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792140d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1382/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Measures to alleviate impacts on strategic stocks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines, based on a stock assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1386"},"text":"section 1386 of this title","children":[],"tail":" or other significant new information obtained under this chapter, that impacts on rookeries, mating grounds, or other areas of similar ecological significance to marine mammals may be causing the decline or impeding the recovery of a strategic stock, the Secretary may develop and implement conservation or management measures to alleviate those impacts. Such measures shall be developed and implemented after consultation with the Marine Mammal Commission and the appropriate Federal agencies and after notice and opportunity for public comment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792140d6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tI/s112"},"text":"Pub. L. 92–522, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1042"},"text":"86 Stat. 1042","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/470/tII/s201/e"},"text":"Pub. L. 96–470, title II, § 201(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-19"},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2241"},"text":"94 Stat. 2241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tIII/s3004/a/3"},"text":"Pub. L. 102–587, title III, § 3004(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5067"},"text":"106 Stat. 5067","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/238"},"text":"Pub. L. 103–238","children":[],"tail":", §§ 7(a), 24(c)(11), "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/542"},"text":"108 Stat. 542","children":[],"tail":", 566.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792140d7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792140d8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id792140d9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/238/s24/c/11"},"text":"Pub. L. 103–238, § 24(c)(11)","children":[],"tail":", made technical amendment to reference to subchapter V of this chapter to reflect renumbering of corresponding title of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/238/s7/a"},"text":"Pub. L. 103–238, § 7(a)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":" inserted “or subchapter V” after “of this subchapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/470"},"text":"Pub. L. 96–470","children":[],"tail":" substituted “include in the annual report to the public and the Congress required under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1373/f"},"text":"section 1373(f) of this title","children":[],"tail":"” for “forthwith submit to Congress”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id792140da-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id792140db-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of the sixty-day period following ","children":[{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/522/s4"},"text":"section 4 of Pub. L. 92–522","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1361"},"text":"section 1361 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
