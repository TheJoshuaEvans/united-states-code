{"tag":"section","attrib":{"id":"id77254a08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s281a"},"text":null,"children":[{"tag":"num","attrib":{"value":"281a"},"text":"§ 281a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To implement this purpose the Secretary of the Interior may designate as the Nez Perce National Historical Park various component sites in Federal and non-Federal ownership relating to the early Nez Perce culture, the Lewis and Clark Expedition through the area, the fur trade, missionaries, gold mining and logging, the Nez Perce war of 1877, and such other sites as he finds will depict the role of the Nez Perce country in the westward expansion of the Nation. Sites to be so designated shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77254a09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s281a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tolo Lake, Idaho;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77254a0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s281a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Looking Glass’ 1877 Campsite, Idaho;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77254a0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s281a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Buffalo Eddy, Washington and Idaho;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77254a0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s281a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Traditional Crossing Near Doug ","children":[{"tag":"ref","attrib":{"idref":"fn002053"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002053"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Dug”."}],"tail":" Bar, Oregon and Idaho;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77254a0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s281a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Camas Meadows Battle Sites, Idaho;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77254a0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s281a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Joseph Canyon Viewpoint, Oregon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77254a0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s281a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Traditional Campsite at the Fork of the Lostine and Wallowa Rivers, Oregon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77254a10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s281a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Burial Site of Chief Joseph the Younger, Washington;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77254a11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s281a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nez Perce Campsites, Washington;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77254a12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s281a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Big Hole National Battlefield, Montana;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77254a13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s281a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Bear’s Paw Battleground, Montana;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77254a14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s281a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Canyon Creek, Montana; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77254a15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s281a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hasotino Village, Idaho;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"each as described in the National Park Service document entitled “Nez Perce National Historical Park Additions Study”, dated 1990 and Old Chief Joseph’s Gravesite and Cemetery, Oregon, as depicted on the map entitled “Nez Perce Additions”, numbered 429–20–018, and dated September, 1991. Lands added to the Big Hole National Battlefield, Montana, pursuant to paragraph (10) shall become part of, and be placed under the administrative jurisdiction of, the Big Hole National Battlefield, but may be interpreted in accordance with the purposes of this subchapter.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77254a16-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/19/s2"},"text":"Pub. L. 89–19, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-05-15"},"text":"May 15, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/110"},"text":"79 Stat. 110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/576/s2/2"},"text":"Pub. L. 102–576, § 2(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4770"},"text":"106 Stat. 4770","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77254a17-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77254a18-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77254a19-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/576"},"text":"Pub. L. 102–576","children":[],"tail":" inserted provision listing 13 sites to be designated as Nez Perce National Historical Park, as described in documents dated 1990 and 1991, and provision relating to lands added to Big Hole National Battlefield, Montana."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
