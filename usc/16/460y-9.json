{"tag":"section","attrib":{"id":"id77d3646f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460y–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"460y–9"},"text":"§ 460y–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77d36470-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460y–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated such sums as may be necessary to accomplish the purposes of this subchapter, but not to exceed $1,500,000 for the purchase of lands and interests in lands and not to exceed $3,500,000 for the construction and improvements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d36471-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460y–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to any amounts authorized to be appropriated under subsection (a), there are authorized to be appropriated for fiscal years beginning on or after ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":", for the acquisition of lands and interests in lands under this subchapter—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id77d36472-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460y–9/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the Land and Water Conservation Fund (established under the Land and Water Conservation Fund Act of 1965) ","children":[{"tag":"ref","attrib":{"idref":"fn002318"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002318"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" not to exceed $5,000,000, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d36473-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460y–9/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from any other sources an amount not to exceed the sum of (A) $5,000,000, and (B) an amount equal to the amount deposited in the Treasury under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460y–4/3/B"},"text":"section 460y–4(3)(B) of this title","children":[],"tail":" after "},{"tag":"date","attrib":{"date":"1978-08-20"},"text":"August 20, 1978","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such sums to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77d36474-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/476/s10"},"text":"Pub. L. 91–476, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-21"},"text":"Oct. 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1071"},"text":"84 Stat. 1071","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/352/s2/2"},"text":"Pub. L. 95–352, § 2(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1978-08-20"},"text":"Aug. 20, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/516"},"text":"92 Stat. 516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77d36475-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77d36476-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib"