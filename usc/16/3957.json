{"tag":"section","attrib":{"id":"id79e4b8b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957"},"text":null,"children":[{"tag":"num","attrib":{"value":"3957"},"text":"§ 3957.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental banks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e4b8b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", the Task Force shall, after public notice and opportunity for comment, issue guidelines for the use, maintenance, and oversight of environmental banks in Louisiana."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e4b8b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidelines issued pursuant to subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e4b8b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth procedures for establishment and approval of environmental banks subject to the approval of the heads of the appropriate Federal agencies responsible for implementation of Federal environmental laws for which mitigation credits may be used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b8b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish criteria for siting of environmental banks that enhance the resilience of coastal resources to inundation and coastal erosion in high priority areas, as identified within Federal or State restoration plans, including the restoration of resources within the scope of a project authorized for construction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b8b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish criteria that ensure environmental banks secure adequate financial assurances and legally enforceable protection for the land or resources that generate the credits from environmental banks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b8ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stipulate that credits from environmental banks may not be used for mitigation of impacts required under section 404 of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1342"},"text":"33 U.S.C. 1342","children":[],"tail":") "},{"tag":"ref","attrib":{"idref":"fn002784"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002784"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or the Endangered Species Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.) in an area where an existing mitigation bank approved pursuant to such laws within 5 years of enactment of the Water Resources Development Act of 2016 has credits available;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b8bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish performance criteria for environmental banks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b8bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish criteria and financial assurance for the operation and monitoring of environmental banks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e4b8bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental bank","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e4b8be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of environmental bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “environmental bank” means a project, project increment, or projects for purposes of restoring, creating, or enhancing natural resources at a designated site to establish mitigation credits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b8bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Mitigation credits created from environmental banks approved pursuant to this section may be used to satisfy existing liability under Federal environmental laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e4b8c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e4b8c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of Federal law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Guidelines developed under this section and mitigation carried out through an environmental bank established pursuant to such guidelines shall comply with all applicable requirements of Federal law (including regulations), including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e728c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e728c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Endangered Species Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e728c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Oil Pollution Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"33 U.S.C. 2701","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e728c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e728c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2283"},"text":"section 2283 of title 33","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e728c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section may be construed to affect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e728c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any authority, regulatory determination, or legal obligation in effect the day before ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e728c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the obligations or requirements of any Federal environmental law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e728ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3957/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No new environmental bank may be created or approved pursuant to this section after the date that is 14 years after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e728cb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646/tIII/s309"},"text":"Pub. L. 101–646, title III, § 309","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tIV/s5014"},"text":"Pub. L. 114–322, title IV, § 5014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1903"},"text":"130 Stat. 1903","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8382/c"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8382(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3828"},"text":"136 Stat. 3828","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tIII/s1303/c"},"text":"Pub. L. 118–272, div. A, title III, § 1303(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3114"},"text":"138 Stat. 3114","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e728cc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e728cd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79e728ce-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 404 of the Federal Water Pollution Control Act, referred to in subsec. (b)(4), is section 404 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"act June 30, 1948, ch. 758","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1344"},"text":"section 1344 of Title 33","children":[],"tail":", Navigation and Navigable Waters. "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1342"},"text":"Section 1342 of Title 33","children":[],"tail":" is section 402 of the Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Endangered Species Act, referred to in subsecs. (b)(4) and (d)(1)(B), probably means the Endangered Species Act of 1973, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/884"},"text":"87 Stat. 884","children":[],"tail":", which is classified principally to chapter 35 (§ 1531 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"section 1531 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Enactment of the Water Resources Development Act of 2016, referred to in subsec. (b)(4), means the enactment of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Water Pollution Control Act, referred to in subsec. (d)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"act June 30, 1948, ch. 758","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/816"},"text":"86 Stat. 816","children":[],"tail":", which is classified generally to chapter 26 (§ 1251 et seq.) of Title 33, Navigation and Navigable Waters. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of Title 33","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Oil Pollution Act of 1990, referred to in subsec. (d)(1)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/484"},"text":"104 Stat. 484","children":[],"tail":", which is classified principally to chapter 40 (§ 2701 et seq.) of Title 33, Navigation and Navigable Waters. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"section 2701 of Title 33","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (d)(1)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79e728cf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272"},"text":"Pub. L. 118–272","children":[],"tail":" substituted “14” for “12”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “12” for “10”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
