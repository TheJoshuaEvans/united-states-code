{"tag":"section","attrib":{"id":"id7832c2f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"539m–9"},"text":"§ 539m–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7832c2f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strict construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sections 539m to 539m–12 of this title recognize only enumerated rights and interests, and no additional rights, interests, obligations, or duties shall be created by implication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c2f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent there exist within the Area as of ","children":[{"tag":"date","attrib":{"date":"2003-02-20"},"text":"February 20, 2003","children":[],"tail":", any valid private property rights associated with private land that are not otherwise addressed in sections 539m to 539m–12 of this title, such rights are not modified or otherwise affected by sections 539m to 539m–12 of this title, nor is the exercise of any such right subject to the Pueblo’s right to withhold consent to new uses in the Area as set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–3/a/3/A"},"text":"section 539m–3(a)(3)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c2f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–9/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Not precedent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of sections 539m to 539m–12 of this title creating certain rights and interests in the National Forest System are uniquely suited to resolve the Pueblo’s claim and the geographic and societal situation involved, and shall not be construed as precedent for any other situation involving management of the National Forest System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c2f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–9/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish and wildlife","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–6/b/2/B"},"text":"section 539m–6(b)(2)(B) of this title","children":[],"tail":", nothing in sections 539m to 539m–12 of this title shall be construed as affecting the responsibilities of the State of New Mexico with respect to fish and wildlife, including the regulation of hunting, fishing, or trapping within the Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7832c2f7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tIV/s411"},"text":"Pub. L. 108–7, div. F, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/291"},"text":"117 Stat. 291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7832c2f8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7832c2f9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7832c2fa-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 539m to 539m–12 of this title, referred to in text, was in the original “this title”, meaning title IV of div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/279"},"text":"117 Stat. 279","children":[],"tail":", which is classified generally to sections 539m to 539m–12 of this title. For complete classification of title IV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m"},"text":"section 539m of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7832c2fb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/s411"},"text":"section 411 of div. F of Pub. L. 108–7","children":[],"tail":". Subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/s411"},"text":"section 411 of div. F of Pub. L. 108–7","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1746"},"text":"section 1746 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
