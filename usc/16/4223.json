{"tag":"section","attrib":{"id":"id79ebe3c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4223"},"text":null,"children":[{"tag":"num","attrib":{"value":"4223"},"text":"§ 4223.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4222/e"},"text":"section 4222(e) of this title","children":[],"tail":", it is unlawful for any person—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ebe3c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4223/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to import raw ivory from any country other than an ivory producing country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe3c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4223/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to export raw ivory from the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe3c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4223/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to import raw or worked ivory that was exported from an ivory producing country in violation of that country’s laws or of the CITES Ivory Control System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe3c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4223/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to import worked ivory, other than personal effects, from any country unless that country has certified that such ivory was derived from legal sources; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe3c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4223/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to import raw or worked ivory from a country for which a moratorium is in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4222"},"text":"section 4222 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ebe3ca-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/478/tII/s2203"},"text":"Pub. L. 100–478, title II, § 2203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-07"},"text":"Oct. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2320"},"text":"102 Stat. 2320","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
