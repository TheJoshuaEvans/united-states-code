{"tag":"section","attrib":{"id":"id7883c81d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715k–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"715k–3"},"text":"§ 715k–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for the preservation of wetlands and other waterfowl habitat","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to promote the conservation of migratory waterfowl and to offset or prevent the serious loss of important wetlands and other waterfowl habitat essential to the preservation of such waterfowl, there is authorized to be appropriated for the period beginning on ","children":[{"tag":"date","attrib":{"date":"1961-07-01"},"text":"July 1, 1961","children":[],"tail":", and ending when all amounts authorized to be appropriated have been expended, not to exceed $200,000,000."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7883c81e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/383/s1"},"text":"Pub. L. 87–383, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-10-04"},"text":"Oct. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/813"},"text":"75 Stat. 813","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/205/s1/a"},"text":"Pub. L. 90–205, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/612"},"text":"81 Stat. 612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/215/s2/a"},"text":"Pub. L. 94–215, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-02-17"},"text":"Feb. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/189"},"text":"90 Stat. 189","children":[],"tail":"; "},{"tag":"ref","attrib