.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7883c822-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/653"},"text":"Pub. L. 100–653","children":[],"tail":" substituted “when all amounts authorized to be appropriated have been expended” for “at the close of "},{"tag":"date","attrib":{"date":"1988-09-30"},"text":"September 30, 1988","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/645"},"text":"Pub. L. 99–645","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1988-09-30"},"text":"September 30, 1988","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/548"},"text":"Pub. L. 98–548","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1984-09-30"},"text":"September 30, 1984","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/200"},"text":"Pub. L. 98–200","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1984-09-30"},"text":"September 30, 1984","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1983-09-30"},"text":"September 30, 1983","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/215"},"text":"Pub. L. 94–215","children":[],"tail":" substituted “period beginning on "},{"tag":"date","attrib":{"date":"1961-07-01"},"text":"July 1, 1961","children":[],"t