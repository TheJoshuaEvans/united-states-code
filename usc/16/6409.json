{"tag":"section","attrib":{"id":"id7a0add5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6409"},"text":null,"children":[{"tag":"num","attrib":{"value":"6409"},"text":"§ 6409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coral Reef Disaster Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0add5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6409/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall seek to enter into an agreement with the National Fish and Wildlife Foundation (in this section referred to as the “Foundation”), authorizing the Foundation to receive, hold, and administer funds received under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0add5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6409/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0add5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6409/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall establish an account, to be known as the “Coral Reef Disaster Fund” (in this section referred to as the “Fund”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0add5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6409/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall deposit funds received under this section into the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0add5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6409/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Fund shall be available solely to support the long-term recovery of coral reefs from exigent circumstances described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6408/b"},"text":"section 6408(b) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0add60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6409/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in partnership with non-Federal stakeholders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0add61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6409/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in a manner that is consistent with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a0add62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6409/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Coral Reef Resilience Strategy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0add63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6409/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coral reef action plans in effect, if any, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6404"},"text":"section 6404 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0add64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6409/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of amounts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0add65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6409/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall invest such portion of the Fund as is not required to meet current withdrawals in interest-bearing obligations of the United States or in obligations guaranteed as to both principal and interest by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0add66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6409/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest and proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest on, and the proceeds from, the sale or redemption of, any obligations held in the Fund shall be credited to and form a part of the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0add67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6409/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of performance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall conduct continuing reviews of all deposits into, and disbursements from, the Fund. Each such review shall include a written assessment concerning the extent to which the Foundation has implemented the goals and requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0add68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6409/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization to solicit donations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0add69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6409/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to an agreement entered into under subsection (a), the Foundation may accept, receive, solicit, hold, administer, and use any gift (including, notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", donations of services) to further the purposes of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0add6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6409/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits in Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", any funds received as a gift shall be deposited and maintained in the Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0add6b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s210"},"text":"Pub. L. 106–562, title II, § 210","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/a"},"text":"Pub. L. 117–263, div. J, title C, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3941"},"text":"136 Stat. 3941","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0add6c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0add6d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a0add6e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6409, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s210"},"text":"Pub. L. 106–562, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2805"},"text":"114 Stat. 2805","children":[],"tail":", provided definitions for the chapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/a"},"text":"Pub. L. 117–263, div. J, title C, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3931"},"text":"136 Stat. 3931","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
