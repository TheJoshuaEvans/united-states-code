{"tag":"section","attrib":{"id":"id776a693a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–80"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–80"},"text":"§ 410aaa–80.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land appraisal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Lands and interests in lands acquired pursuant to this Act shall be appraised without regard to the presence of a species listed as threatened or endangered pursuant to the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id776a693b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tVII/s710"},"text":"Pub. L. 103–433, title VII, § 710","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4501"},"text":"108 Stat. 4501","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id776a693c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id776a693d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id776a693e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/s3"},"text":"section 3 of Pub. L. 103–433","children":[