{"tag":"section","attrib":{"id":"id78438af8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s554a"},"text":null,"children":[{"tag":"num","attrib":{"value":"554a"},"text":"§ 554a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees to be appointed without regard to political affiliations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Forest inspectors, superintendents, supervisors, surveyors, rangers, and fire patrol are to be hereafter appointed by the Secretary of Agriculture wholly with reference to their fitness and without regard for their political affiliations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78438af9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1898-07-07/ch571/s1"},"text":"July 7, 1898, ch. 571, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/673"},"text":"30 Stat. 673","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1905-02-01/ch288/s1"},"text":"Feb. 1, 1905, ch. 288, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/628"},"text":"33 Stat. 628","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78438afa-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78438afb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id78438afc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1905-02-01"},"text":"Feb. 1, 1905","children":[],"tail":", transferred certain functions with regard to the administration of public forests from Secretary of the Interior to Secretary of Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
