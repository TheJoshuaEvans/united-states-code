{"tag":"section","attrib":{"id":"id79a20a0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803"},"text":null,"children":[{"tag":"num","attrib":{"value":"2803"},"text":"§ 2803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Aquaculture Development Plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a20a10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a20a11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within eighteen months after ","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"September 26, 1980","children":[],"tail":", the Secretaries shall establish the National Aquaculture Development Plan."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20a12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In developing the Plan, and revisions thereto under subsection (d), beginning not later than six months after ","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"September 26, 1980","children":[],"tail":", the Secretary shall consult with the Secretary of Commerce and the Secretary of the Interior, other appropriate Federal officers, States, regional fishery management councils established under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1852"},"text":"section 1852 of this title","children":[],"tail":", and representatives of the aquaculture industry. In addition, the Secretary shall give interested persons and organizations an opportunity to comment during the development of the Plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a20a13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of Plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Plan shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a20a14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify aquatic species that the Secretaries determine to have significant potential for culturing on a commercial or other basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20a15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend actions to be taken by the public and private sectors (which may include, but are not limited to, research and development, technical assistance, demonstration, extension education, and training activities) that are necessary to achieve such potential;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20a16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" address, after taking into account the status of aquaculture regarding the aquatic species concerned—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a20a17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aquaculture facility design and operation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a20a18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water quality management,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a20a19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of waste products (including thermal effluents),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a20a1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nutrition and the development of economical feeds, including natural food sources,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a20a1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" life history, genetics, physiology, pathology, and disease control (including research regarding organisms that may not be harmful to fish and shellfish, but are injurious to humans),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a20a1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processing and market development,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a20a1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" production management and quality control, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a20a1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of adequate supplies of seed stock;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20a1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include, where appropriate, research programs on the effect of aquaculture on estuarine and other water areas and on the management of such areas for aquaculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20a20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include, where appropriate, programs to analyze, and formulate proposed resolutions of, the legal or regulatory constraints that may affect aquaculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20a21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include such other research and development, technical assistance, demonstration, extension education, and training programs as the Secretary deems necessary or appropriate to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In formulating the Plan, the Secretary shall, to the extent practicable, take into account any significant action that (i) has been, or is proposed to be, undertaken by any other Federal department or agency, any State agency, or any person, and (ii) may affect the implementation of the Plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a20a22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions and implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Plan shall specify—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a20a23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to those actions that the Secretary determines should be undertaken, the period of time within which each such action should be completed, in order to implement the Plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20a24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to each such action which of the Secretaries, acting individually, jointly, or collectively, has the responsibility for implementing the action.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The specifications of Secretarial responsibilities under paragraph (2) for implementing actions shall be determined on the basis of—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a20a25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/c/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the responsibilities conferred on the respective Secretaries by law or by any executive action having the effect of law (including, but not limited to, Reorganization Plan Numbered 4 of 1970);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a20a26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/c/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the experience, expertise, and other appropriate resources that the department of each such Secretary may have with respect to the action required under the activity concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a20a27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/c/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the concurrence of the Secretaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a20a28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of Plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries shall undertake periodic reviews of the operation and effectiveness of the Plan. If as a result of any such review, or the aquaculture assessment required under subsection (e), the Secretaries determine that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a20a29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any aquatic species not currently identified in the Plan has significant potential for aquaculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20a2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any action specified in the Plan is not being accomplished on a successful and timely basis; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20a2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any action specified in the Plan should be terminated because its objectives have been achieved or its projected benefits do not warrant further support;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretaries shall appropriately amend the Plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a20a2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing aquaculture assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries, through the coordinating group, shall undertake a continuing assessment of aquaculture in the United States for the purpose of maintaining, on a continuing basis—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a20a2d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a complete profile of the aquacultural industry with respect to the incidence, size, and status of commercial aquacultural enterprises;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20a2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of the private and public institutions and organizations involved in aquacultural research, extension, credit, and market development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20a2f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of the various aquatic species being cultured and a description of the status of commercial development of each of those species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20a30-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, the identification of aquacultural production regions, species, and markets that have significant potential for development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20a31-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a catalog describing all Federal programs and activities that directly or indirectly encourage, support, or assist aquaculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20a32-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2803/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of the economic, physical, legal, institutional, and social constraints that inhibit the development of aquaculture in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a20a33-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/362/s4"},"text":"Pub. L. 96–362, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1199"},"text":"94 Stat. 1199","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/561/tII/s238/b"},"text":"Pub. L. 96–561, title II, § 238(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3300"},"text":"94 Stat. 3300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVII/s1734"},"text":"Pub. L. 99–198, title XVII, § 1734","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1641"},"text":"99 Stat. 1641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII/s211/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II, § 211(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–41.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a20a34-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a20a35-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79a20a36-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Reorganization Plan Numbered 4 of 1970, referred to in subsec. (c)(A), is Reorg. Plan No. 4 of 1970, 35 F.R. 15627, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/84/2090"},"text":"84 Stat. 2090","children":[],"tail":", which is set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79a45327-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1852"},"text":"section 1852 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1734/1/A"},"text":"Pub. L. 99–198, § 1734(1)(A)","children":[],"tail":", (B), substituted “Secretary” for “Secretaries” wherever appearing and inserted provisions requiring consultations with the Secretary of Commerce and the Secretary of the Interior."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1734/1/C"},"text":"Pub. L. 99–198, § 1734(1)(C)","children":[],"tail":", struck out par. (3) which provided for the establishment of an advisory committee to assist in the initial development of the Plan."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1734/2"},"text":"Pub. L. 99–198, § 1734(2)","children":[],"tail":", inserted “to” after “determine” in par. (1), substituted “Secretary deems” for “Secretaries deem” in par. (6), and substituted “Secretary” for “Secretaries” in provisions following par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1734/3/A"},"text":"Pub. L. 99–198, § 1734(3)(A)","children":[],"tail":", substituted “Secretary determines” for “Secretaries determine”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1734/3/B"},"text":"Pub. L. 99–198, § 1734(3)(B)","children":[],"tail":"–(D), added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/561"},"text":"Pub. L. 96–561","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1852"},"text":"section 1852 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a45328-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79a45329-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII/s211/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II, § 211(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–41, provided that the amendment made by that section is effective 15 days after "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79a4532a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/561/tII/s238/b"},"text":"Pub. L. 96–561, title II, § 238(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3300"},"text":"94 Stat. 3300","children":[],"tail":", provided that the amendment made by that section is effective 15 days after "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
