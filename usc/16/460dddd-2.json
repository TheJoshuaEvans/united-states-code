{"tag":"section","attrib":{"id":"id780f0de0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"460dddd–2"},"text":"§ 460dddd–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" San Rafael Swell Recreation Area Advisory Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id780f0de1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall establish an advisory council, to be known as the “San Rafael Swell Recreation Area Advisory Council”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0de2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall advise the Secretary with respect to the preparation and implementation of the Management Plan for the Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0de3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be subject to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780f0de4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Advisory Committee Act (5 U.S.C. App.); ","children":[{"tag":"ref","attrib":{"idref":"fn002391"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002391"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0de5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1739"},"text":"section 1739 of title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0de6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall include 7 members, to be appointed by the Secretary, of whom, to the maximum extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780f0de7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent the Emery County Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0de8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent motorized recreational users;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0de9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–2/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent nonmotorized recreational users;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0dea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–2/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent permittees holding grazing allotments within the Recreation Area or wilderness areas designated in this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0deb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–2/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent conservation organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0dec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–2/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall have expertise in the historical uses of the Recreation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0ded-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–2/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall be appointed from the elected leadership of a Federally recognized Indian Tribe that has significant cultural or historical connections to, and expertise in, the landscape, archeological sites, or cultural sites within the County.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id780f0dee-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1223"},"text":"Pub. L. 116–9, title I, § 1223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/670"},"text":"133 Stat. 670","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id780f0def-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id780f0df0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id780f0df1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Pub. L. 92–463","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-06"},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/770"},"text":"86 Stat. 770","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was substantially repealed and restated in chapter 10 (§ 1001 et seq.) of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4197"},"text":"136 Stat. 4197","children":[],"tail":", 4361. For disposition of sections of the Act into chapter 10 of Title 5, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of Title 5","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This part, referred to in subsec. (d)(4), is part II (§§ 1211–1255) of subtitle C of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9"},"text":"Pub. L. 116–9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/667"},"text":"133 Stat. 667","children":[],"tail":", which enacted this subchapter, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1274"},"text":"section 1274 of this title","children":[],"tail":", enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1274"},"text":"section 1274 of this title","children":[],"tail":", and enacted provisions listed in a table of Wilderness Areas set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"section 1132 of this title","children":[],"tail":" and in a table of National Monuments set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320301"},"text":"section 320301 of Title 54","children":[],"tail":", National Parks Service and Related Programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
