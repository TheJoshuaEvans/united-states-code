{"tag":"section","attrib":{"id":"id780c9c87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"460zzz–4"},"text":"§ 460zzz–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of Conservation Area and Wilderness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id780c9c88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, all Federal land within the Conservation Area and the Wilderness and all land and interests in land acquired by the United States within the Conservation Area or the Wilderness is withdrawn from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9c89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all forms of entry, appropriation, or disposal under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9c8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9c8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation of the mineral leasing, mineral materials, and geothermal leasing laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9c8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9c8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing in Conservation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Secretary shall issue and administer any grazing leases or permits in the Conservation Area in accordance with the laws (including regulations) applicable to the issuance and administration of such leases and permits on other land under the jurisdiction of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9c8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing in Wilderness","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The grazing of livestock in the Wilderness, if established as of ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", shall be permitted to continue—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780c9c8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to any reasonable regulations, policies, and practices that the Secretary determines to be necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9c90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id780c9c91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1133/d/4"},"text":"section 1133(d)(4) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780c9c92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the guidelines set forth in Appendix A of the report of the Committee on Interior and Insular Affairs of the House of Representatives accompanying H.R. 2570 of the 101st Congress (H. Rept. 101–405).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9c93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No buffer zones","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9c94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter creates a protective perimeter or buffer zone around the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9c95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities outside Conservation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fact that an activity or use on land outside the Conservation Area can be seen or heard within the Conservation Area shall not preclude the activity or use outside the boundary of the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9c96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of land","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9c97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire non-Federal land within the boundaries of the Conservation Area or the Wilderness only through exchange, donation, or purchase from a willing seller.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9c98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Land acquired under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780c9c99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" become part of the Conservation Area and, if applicable, the Wilderness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9c9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be managed in accordance with this subchapter and any other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9c9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fire, insects, and diseases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to such terms and conditions as the Secretary determines to be desirable and appropriate, the Secretary may undertake such measures as are necessary to control fire, insects, and diseases—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9c9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the Wilderness, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1133/d/1"},"text":"section 1133(d)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9c9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in paragraph (1), in the Conservation Area in accordance with this subchapter and any other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9c9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall continue to provide private landowners adequate access to inholdings in the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9c9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Invasive species and noxious weeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with any applicable laws and subject to such terms and conditions as the Secretary determines to be desirable and appropriate, the Secretary may prescribe measures to control nonnative invasive plants and noxious weeds within the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9ca0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water rights","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9ca1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780c9ca2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects the use or allocation, in existence on ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", of any water, water right, or interest in water;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9ca3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects any vested absolute or decreed conditional water right in existence on ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", including any water right held by the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9ca4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects any interstate water compact in existence on ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9ca5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizes or imposes any new reserved Federal water rights; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9ca6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be considered to be a relinquishment or reduction of any water rights reserved or appropriated by the United States in the State on or before ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9ca7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wilderness water rights","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780c9ca8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that any water rights within the Wilderness required to fulfill the purposes of the Wilderness are secured in accordance with subparagraphs (B) through (G).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9ca9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State law","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id780c9caa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedural requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any water rights within the Wilderness for which the Secretary pursues adjudication shall be adjudicated, changed, and administered in accordance with the procedural requirements and priority system of State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780c9cab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of water rights","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id780c9cac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subclause (II), the purposes and other substantive characteristics of the water rights pursued under this paragraph shall be established in accordance with State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id780c9cad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subclause (I) and in accordance with this subchapter, the Secretary may appropriate and seek adjudication of water rights to maintain surface water levels and stream flows on and across the Wilderness to fulfill the purposes of the Wilderness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9cae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promptly, but not earlier than January 2009, appropriate the water rights required to fulfill the purposes of the Wilderness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9caf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not pursue adjudication for any instream flow water rights unless the Secretary makes a determination pursuant to subparagraph (E)(ii) or (F).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9cb0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative enforcement","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id780c9cb1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not pursue adjudication of any Federal instream flow water rights established under this paragraph if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id780c9cb2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2/E/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines, upon adjudication of the water rights by the Colorado Water Conservation Board, that the Board holds water rights sufficient in priority, amount, and timing to fulfill the purposes of the Wilderness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id780c9cb3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2/E/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has entered into a perpetual agreement with the Colorado Water Conservation Board to ensure the full exercise, protection, and enforcement of the State water rights within the Wilderness to reliably fulfill the purposes of the Wilderness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780c9cb4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjudication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that the provisions of clause (i) have not been met, the Secretary shall adjudicate and exercise any Federal water rights required to fulfill the purposes of the Wilderness in accordance with this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9cb5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insufficient water rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Colorado Water Conservation Board modifies the instream flow water rights obtained under subparagraph (E) to such a degree that the Secretary determines that water rights held by the State are insufficient to fulfill the purposes of the Wilderness, the Secretary shall adjudicate and exercise Federal water rights required to fulfill the purposes of the Wilderness in accordance with subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9cb6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to comply","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall promptly act to exercise and enforce the water rights described in subparagraph (E) if the Secretary determines that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id780c9cb7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State is not exercising its water rights consistent with subparagraph (E)(i)(I); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780c9cb8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreement described in subparagraph (E)(i)(II) is not fulfilled or complied with sufficiently to fulfill the purposes of the Wilderness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9cb9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water resource facility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780c9cba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law and subject to subparagraph (B), beginning on ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", neither the President nor any other officer, employee, or agent of the United States shall fund, assist, authorize, or issue a license or permit for the development of any new irrigation and pumping facility, reservoir, water conservation work, aqueduct, canal, ditch, pipeline, well, hydropower project, transmission, other ancillary facility, or other water, diversion, storage, or carriage structure in the Wilderness."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9cbb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subparagraph (A), the Secretary may allow construction of new livestock watering facilities within the Wilderness in accordance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id780c9cbc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1133/d/4"},"text":"section 1133(d)(4) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780c9cbd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the guidelines set forth in Appendix A of the report of the Committee on Interior and Insular Affairs of the House of Representatives accompanying H.R. 2570 of the 101st Congress (H. Rept. 101–405).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9cbe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation area water rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to water within the Conservation Area, nothing in this subchapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780c9cbf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizes any Federal agency to appropriate or otherwise acquire any water right on the mainstem of the Gunnison River; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9cc0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevents the State from appropriating or acquiring, or requires the State to appropriate or acquire, an instream flow water right on the mainstem of the Gunnison River.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9cc1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wilderness boundaries along Gunnison River","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780c9cc2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In areas in which the Gunnison River is used as a reference for defining the boundary of the Wilderness, the boundary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id780c9cc3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be located at the edge of the river; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780c9cc4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" change according to the river level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9cc5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/h/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion from Wilderness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Regardless of the level of the Gunnison River, no portion of the Gunnison River is included in the Wilderness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9cc6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9cc7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diminishes the jurisdiction of the State with respect to fish and wildlife in the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9cc8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imposes any Federal water quality standard upstream of the Conservation Area or within the mainstem of the Gunnison River that is more restrictive than would be applicable had the Conservation Area not been established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9cc9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–4/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Valid existing rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The designation of the Conservation Area and Wilderness is subject to valid rights in existence on ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id780c9cca-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tII/s2405"},"text":"Pub. L. 111–11, title II, § 2405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1104"},"text":"123 Stat. 1104","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
