{"tag":"section","attrib":{"id":"id79d41631-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3839aa–3"},"text":"§ 3839aa–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d41632-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop criteria for evaluating applications that will ensure that national, State, and local conservation priorities are effectively addressed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d41633-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization of applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating applications under this subpart, the Secretary shall prioritize applications—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d41634-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on their overall level of cost-effectiveness to ensure that the conservation practices and approaches proposed are the most efficient means of achieving the anticipated conservation benefits of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d41635-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on how effectively and comprehensively the project addresses the designated resource concern or resource concerns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d41636-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that best fulfill the purposes of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d41637-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–3/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that improve conservation practices or systems in place on the operation at the time the contract offer is accepted or that will complete a conservation system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d41638-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grouping of applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the greatest extent practicable, the Secretary shall group applications of similar crop or livestock operations for evaluation purposes or otherwise evaluate applications relative to other applications for similar farming operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d41639-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1240C"},"text":"Pub. L. 99–198, title XII, § 1240C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tII/s2301"},"text":"Pub. L. 107–171, title II, § 2301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/256"},"text":"116 Stat. 256","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2504"},"text":"Pub. L. 110–234, title II, § 2504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1062"},"text":"122 Stat. 1062","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title II, § 2504, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1790; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2204"},"text":"Pub. L. 113–79, title II, § 2204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/730"},"text":"128 Stat. 730","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2301/d/1/G"},"text":"Pub. L. 115–334, title II, § 2301(d)(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4554"},"text":"132 Stat. 4554","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79d4163a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79d4163b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"headin