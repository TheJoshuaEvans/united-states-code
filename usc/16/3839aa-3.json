","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “this subpart” for “this part” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s2204/1"},"text":"Pub. L. 113–79, § 2204(1)","children":[],"tail":", substituted “conservation” for “environmental” before “benefits”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s2204/2"},"text":"Pub. L. 113–79, § 2204(2)","children":[],"tail":", substituted “purposes of the program” for “purpose of the environmental quality incentives program specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa/1"},"text":"section 3839aa(1) of this title","children":[],"tail":"” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s2504"},"text":"Pub. L. 110–246, § 2504","children":[],"tail":", amended section generally. Prior to amendment, text read as follows: “In evaluating applications for cost-share payments and incentive payments, the Secretary shall accord a higher priority to assistance and payments that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) encourage the use by producers of cost-effective conservation practices; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) address national conservation priorities.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79d4163f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"