{"tag":"section","attrib":{"id":"id7a31034f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001"},"text":null,"children":[{"tag":"num","attrib":{"value":"8001"},"text":"§ 8001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a310350-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AIS","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “AIS” means Automatic Identification System (as defined in section 164.46 of title 33, Code of Federal Regulations, or a similar successor regulation).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310351-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Combined Maritime Forces","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Combined Maritime Forces” means the 33-nation naval partnership, originally established in February 2002, which promotes security, stability, and prosperity across approximately 3,200,000 square miles of international waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310352-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive economic zone","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a310353-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless otherwise specified by the President as being in the public interest in a writing published in the Federal Register, the term “exclusive economic zone” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a310354-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the area within a zone established by a maritime boundary that has been established by a treaty in force or a treaty that is being provisionally applied by the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a310355-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the absence of a treaty described in clause (i)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a310356-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a zone, the outer boundary of which is 200 nautical miles from the baseline from which the breadth of the territorial sea is measured; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a310357-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the distance between the United States and another country is less than 400 nautical miles, a zone, the outer boundary of which is represented by a line equidistant between the United States and the other country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a310358-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inner boundary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Without affecting any Presidential Proclamation with regard to the establishment of the United States territorial sea or exclusive economic zone, the inner boundary of the exclusive economic zone is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a310359-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of coastal States, a line coterminous with the seaward boundary of each such State (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1312"},"text":"section 1312 of title 43","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a31035a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the Commonwealth of Puerto Rico, a line that is 3 marine leagues from the coastline of the Commonwealth of Puerto Rico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a31035b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of American Samoa, the United States Virgin Islands, Guam, and the Northern Mariana Islands, a line that is 3 geographic miles from the coastlines of American Samoa, the United States Virgin Islands, Guam, or the Northern Mariana Islands, respectively; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a31035c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any possession of the United States not referred to in clause (ii) or (iii), the coastline of such possession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a31035d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph may be construed to diminish the authority of the Department of Defense, the Department of the Interior, or any other Federal department or agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31035e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “food security” means access to, and availability, utilization, and stability of, sufficient food to meet caloric and nutritional needs for an active and healthy life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31035f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Global record of fishing vessels, refrigerated transport vessels, and supply vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “global record of fishing vessels, refrigerated transport vessels, and supply vessels” means the Food and Agriculture Organization of the United Nations’ initiative to rapidly make available certified data from state authorities about vessels and vessel related activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310360-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" IUU fishing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “IUU fishing” means illegal fishing, unreported fishing, or unregulated fishing (as such terms are defined in paragraph 3 of the International Plan of Action to Prevent, Deter, and Eliminate Illegal, Unreported and Unregulated Fishing, adopted at the 24th Session of the Committee on Fisheries in Rome on ","children":[{"tag":"date","attrib":{"date":"2001-03-02"},"text":"March 2, 2001","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310361-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Port State Measures Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Port State Measures Agreement” means the Agreement on Port State Measures to Prevent, Deter, and Eliminate Illegal, Unreported, and Unregulated Fishing set forth by the Food and Agriculture Organization of the United Nations, done at Rome, Italy ","children":[{"tag":"date","attrib":{"date":"2009-11-22"},"text":"November 22, 2009","children":[],"tail":", and entered into force "},{"tag":"date","attrib":{"date":"2016-06-05"},"text":"June 5, 2016","children":[],"tail":", which offers standards for reporting and inspecting fishing activities of foreign-flagged fishing vessels at port."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310362-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority flag state","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “priority flag state” means a country selected in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8032/b/3"},"text":"section 8032(b)(3) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a310363-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whereby the flagged vessels of which actively engage in, knowingly profit from, or are complicit in IUU fishing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a310364-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is willing, but lacks the capacity, to monitor or take effective enforcement action against its fleet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310365-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority region","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “priority region” means a region selected in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8032/b/2"},"text":"section 8032(b)(2) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a310366-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is at high risk for IUU fishing activity or the entry of illegally caught seafood into the markets of countries in the region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a310367-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which countries lack the capacity to fully address the illegal activity described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310368-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional Fisheries Management Organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Regional Fisheries Management Organization” means an intergovernmental fisheries organization or arrangement, as appropriate, that has the competence to establish conservation and management measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310369-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seafood","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “seafood”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a31036a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means marine finfish, mollusks, crustaceans, and all other forms of marine animal and plant life, including those grown, produced, or reared through marine aquaculture operations or techniques; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a31036b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include marine mammals, turtles, or birds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31036c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transnational organized illegal activity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “transnational organized illegal activity” means criminal activity conducted by self-perpetuating associations of individuals who operate transnationally for the purpose of obtaining power, influence, or monetary or commercial gains, wholly or in part by illegal means, while protecting their activities through a pattern of corruption or violence or through a transnational organizational structure and the exploitation of transnational commerce or communication mechanisms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31036d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transshipment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “transshipment” means the use of refrigerated vessels that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a31036e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect catch from multiple fishing boats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a31036f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry the accumulated catches back to port; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a310370-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8001/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deliver supplies to fishing boats, which allows fishing vessels to remain at sea for extended periods without coming into port.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a310371-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3532"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1997"},"text":"133 Stat. 1997","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a310372-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a310373-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a310374-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this subtitle”, meaning subtitle C of title XXXV of div. C of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1997"},"text":"133 Stat. 1997","children":[],"tail":", known as the Maritime Security and Fisheries Enforcement Act and also as the Maritime SAFE Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a310375-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a310376-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3531"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1997"},"text":"133 Stat. 1997","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dC/tXXXV/s3531"},"text":"“This subtitle [subtitle C (§§ 3531–3572) of title XXXV of div. C of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":", enacting this chapter and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7103"},"text":"section 7103 of Title 22","children":[],"tail":", Foreign Relations and Intercourse] may be cited as the ‘Maritime Security and Fisheries Enforcement Act’ or the ‘Maritime SAFE Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
