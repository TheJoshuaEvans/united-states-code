{"tag":"section","attrib":{"id":"id792d282c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421f–1"},"text":"§ 1421f–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marine Mammal Rescue and Response Grant Program and Rapid Response Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792d282d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d282e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency assistance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d282f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “emergency assistance” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id792d2830-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" financial assistance provided to respond to, or that results from, a stranding event or entanglement event that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id792d2831-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/a/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" causes an immediate increase in the cost of a response, recovery, or rehabilitation that is greater than the usual cost of a response, recovery, or rehabilitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id792d2832-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/a/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is cyclical or endemic; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id792d2833-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/a/1/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves a marine mammal that is out of the normal range for that marine mammal; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d2834-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" financial assistance provided to respond to, or that results from, a stranding event or an entanglement event that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id792d2835-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/a/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable Secretary considers to be an emergency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id792d2836-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/a/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the concurrence of the applicable Secretary, a State, territorial, or Tribal Government considers to be an emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d2837-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “emergency assistance” does not include financial assistance to respond to an unusual mortality event.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2838-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1362/12/A"},"text":"section 1362(12)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2839-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stranding region","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “stranding region” means a geographic region designated by the applicable Secretary for purposes of administration of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d283a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" John H. Prescott Marine Mammal Rescue and Response Grant Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d283b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The applicable Secretary shall carry out a grant program, to be known as the “John H. Prescott Marine Mammal Rescue and Response Grant Program” (referred to in this section as the “grant program”), to award grants to eligible stranding network participants or stranding network collaborators, as described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d283c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the grant program are to provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d283d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recovery, care, or treatment of sick, injured, or entangled marine mammals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d283e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responses to marine mammal stranding events that require emergency assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d283f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection of data and samples from living or dead stranded marine mammals for scientific research or assessments regarding marine mammal health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d2840-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facility operating costs that are directly related to activities described in subparagraph (A), (B), or (C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d2841-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of stranding network capacity, including training for emergency response, where facilities do not exist or are sparse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2842-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract, grant, and cooperative agreement authority","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d2843-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The applicable Secretary may enter into a contract, grant, or cooperative agreement with any eligible stranding network participant or stranding network collaborator, as the Secretary determines to be appropriate, for the purposes described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d2844-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency award flexibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Following a request for emergency award flexibility and analysis of the merits of and necessity for such a request, the applicable Secretary may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id792d2845-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amend any contract, grant, or cooperative agreement entered into under this paragraph, including provisions concerning the period of performance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d2846-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waive the requirements under subsection (f) for grant applications submitted during the provision of emergency assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2847-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable distribution of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d2848-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure, to the extent practicable, that funds awarded under the grant program are distributed equitably among the stranding regions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d2849-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining priorities among the stranding regions under this paragraph, the Secretary may consider—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id792d284a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equitable distribution within the stranding regions, including the subregions (including, but not limited to, the Gulf of Mexico);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d284b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any episodic stranding, entanglement, or mortality events, except for unusual mortality events, that occurred in any stranding region in the preceding year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d284c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any data with respect to average annual stranding, entanglements, and mortality events per stranding region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d284d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the size of the marine mammal populations inhabiting a stranding region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d284e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importance of the region’s marine mammal populations to the well-being of indigenous communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d284f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/4/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conservation of protected, depleted, threatened, or endangered marine mammal species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d2850-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strandings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this program, priority is to be given to applications focusing on marine mammal strandings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2851-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a grant under the grant program, a stranding network participant shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d2852-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit an application in such form and manner as the applicable Secretary prescribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d2853-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in compliance with the data reporting requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421a/d"},"text":"section 1421a(d) of this title","children":[],"tail":" and any applicable reporting requirements of the United States Fish and Wildlife Service for species under its management jurisdiction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2854-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in consultation with the Marine Mammal Commission, a representative from each of the stranding regions, and other individuals who represent public and private organizations that are actively involved in rescue, rehabilitation, release, scientific research, marine conservation, and forensic science with respect to stranded marine mammals under that Department’s jurisdiction, develop criteria for awarding grants under their respective grant programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2855-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum grant amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant made under the grant program for a single award may exceed $150,000 in any 12-month period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2856-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs and expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary’s administrative costs and expenses related to reviewing and awarding grants under the grant program, in any fiscal year may not exceed the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d2857-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 percent of the amounts made available each fiscal year to carry out the grant program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d2858-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $80,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2859-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make publicly available a list of grant proposals for the upcoming fiscal year, funded grants, and requests for grant flexibility under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d285a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joseph R. Geraci Marine Mammal Rescue and Rapid Response Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d285b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States an interest-bearing fund, to be known as the “Joseph R. Geraci Marine Mammal Rescue and Rapid Response Fund” (referred to in this section as the “Rapid Response Fund”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d285c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Rapid Response Fund shall be available only for use by the Secretary to provide emergency assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d285d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d285e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d285f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated to carry out the grant program $7,000,000 for each of fiscal years 2023 through 2028, to remain available until expended, of which for each fiscal year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id792d2860-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $6,000,000 shall be made available to the Secretary of Commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d2861-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 shall be made available to the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d2862-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Derivation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds to carry out the activities under this section shall be derived from amounts authorized to be appropriated pursuant to subparagraph (A) that are enacted after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2863-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joseph R. Geraci Marine Mammal Rescue and Rapid Response Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Rapid Response Fund $500,000 for each of fiscal years 2023 through 2028.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d2864-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of donations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d2865-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of carrying out this section, the Secretary may solicit, accept, receive, hold, administer, and use gifts, devises, and bequests without any further approval or administrative action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2866-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monetary donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A monetary gift, devise, or bequest accepted by the Secretary under paragraph (1) shall be credited as discretionary offsetting collections to the currently applicable appropriation, account, or fund of the Department of Commerce and shall be made available for such purposes only to the extent and in the amounts provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d2867-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d2868-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of a project conducted with funds awarded under the grant program under this section shall be not less than 25 percent of such project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2869-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f–1/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In-kind contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may apply to the non-Federal share of a project conducted with a grant under this section the amount of funds, and the fair market value of property and services, provided by non-Federal sources and used for the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792d286a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tIV/s408"},"text":"Pub. L. 92–522, title IV, § 408","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/555/tII/s202/a/2"},"text":"Pub. L. 106–555, title II, § 202(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2767"},"text":"114 Stat. 2767","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIV/s10406/a"},"text":"Pub. L. 117–263, div. J, title CIV, § 10406(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3984"},"text":"136 Stat. 3984","children":[],"tail":", 3987.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792d286b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792d286c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id792d286d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/s408"},"text":"section 408 of Pub. L. 92–522","children":[],"tail":" was renumbered section 409, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421g"},"text":"section 1421g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id792d286e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10406/a/1"},"text":"Pub. L. 117–263, § 10406(a)(1)","children":[],"tail":", substituted “Marine Mammal Rescue and Response Grant Program and Rapid Response Fund” for “John H. Prescott Marine Mammal Rescue Assistance Grant Program” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10406/a/2"},"text":"Pub. L. 117–263, § 10406(a)(2)","children":[],"tail":", (4), added subsecs. (a) to (d) and struck out former subsecs. (a) to (d) which related to authorization of the John H. Prescott Marine Mammal Rescue Assistance Grant Program, grant applications, required consultations, and limitation of the grant amount, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10406/a/4"},"text":"Pub. L. 117–263, § 10406(a)(4)","children":[],"tail":", added subsec. (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10406/a/2"},"text":"Pub. L. 117–263, § 10406(a)(2)","children":[],"tail":", (3), redesignated subsec. (e) as (f) and struck out former subsec. (f). Prior to amendment, text of subsec. (f) read as follows: “Of amounts available each fiscal year to carry out this section, the Secretary may expend not more than 6 percent or $80,000, whichever is greater, to pay the administrative expenses necessary to carry out this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10406/b/1"},"text":"Pub. L. 117–263, § 10406(b)(1)","children":[],"tail":", substituted “a project conducted with funds awarded under the grant program under this section shall be not less than 25 percent of such project” for “the costs of an activity conducted with a grant under this section shall be 25 percent of such costs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10406/b/2"},"text":"Pub. L. 117–263, § 10406(b)(2)","children":[],"tail":", substituted “a project” for “an activity” and “the project” for “the activity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10406/a/2"},"text":"Pub. L. 117–263, § 10406(a)(2)","children":[],"tail":", struck out subsecs. (g) and (h) which defined “designated stranding region” and “Secretary” and authorized appropriations for fiscal years 2001 through 2003, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
