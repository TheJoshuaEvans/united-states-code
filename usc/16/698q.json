{"tag":"section","attrib":{"id":"id787cc3ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698q"},"text":null,"children":[{"tag":"num","attrib":{"value":"698q"},"text":"§ 698q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Little River Canyon National Preserve; establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id787cc3eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to protect and preserve the natural, scenic, recreational, and cultural resources of the Little River Canyon area in DeKalb and Cherokee Counties, Alabama, and to provide for the protection and public enjoyment of the resources, there is established the Little River Canyon National Preserve (referred to in sections 698q to 698t of this title as the “Preserve”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787cc3ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area included","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id787cc3ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Preserve shall consist of the lands, waters, and interests in lands and waters generally depicted on the boundary map entitled “Little River Canyon National Preserve”, numbered NA–LRNP–80,001C, and dated March 1992.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc3ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary expansion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The boundary of the Preserve is modified to include the land depicted on the map entitled “Little River Canyon National Preserve Proposed Boundary”, numbered 152/80,004, and dated December 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787cc3ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698q/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The maps referred to in subsection (b) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id787cc3f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698q/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be on file and available for public inspection in the offices of the National Park Service of the Department of the Interior in Washington, District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc3f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698q/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be filed with the appropriate offices of DeKalb and Cherokee Counties in the State of Alabama.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787cc3f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698q/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of description","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"1992-10-21"},"text":"October 21, 1992","children":[],"tail":", the Secretary of the Interior (referred to in sections 698q to 698t of this title as the “Secretary”) shall publish in the Federal Register a detailed description of the boundaries of the Preserve."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id787cc3f3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/427/s2"},"text":"Pub. L. 102–427, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-21"},"text":"Oct. 21, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2179"},"text":"106 Stat. 2179","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7103"},"text":"Pub. L. 111–11, title VII, § 7103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1190"},"text":"123 Stat. 1190","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787cc3f4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id787cc3f5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id787cc3f6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7103/1"},"text":"Pub. L. 111–11, § 7103(1)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7103/2"},"text":"Pub. L. 111–11, § 7103(2)","children":[],"tail":", substituted “maps” for “map” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id787cc3f7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id787cc3f8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/427/s1"},"text":"Pub. L. 102–427, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-21"},"text":"Oct. 21, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2179"},"text":"106 Stat. 2179","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/427/s1"},"text":"“This Act [enacting this section and sections 698r to 698t of this title] may be cited as the ‘Little River Canyon National Preserve Act of 1992’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
