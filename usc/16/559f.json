us/stat/100/3207-191"},"text":"100 Stat. 3207–191","children":[],"tail":", known as the National Forest System Drug Control Act of 1986, which enacted sections 559b to 559f of this title, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s841"},"text":"section 841 of Title 21","children":[],"tail":", Food and Drugs, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s559b"},"text":"section 559b of this title","children":[],"tail":". For complete classification of title XV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s559b"},"text":"section 559b of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
