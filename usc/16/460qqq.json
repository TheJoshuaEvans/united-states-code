{"tag":"section","attrib":{"id":"id78057058-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq"},"text":null,"children":[{"tag":"num","attrib":{"value":"460qqq"},"text":"§ 460qqq.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this subchapter is to establish the Sloan Canyon National Conservation Area to conserve, protect, and enhance for the benefit and enjoyment of present and future generations the cultural, archaeological, natural, wilderness, scientific, geological, historical, biological, wildlife, educational, and scenic resources of the Conservation Area.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78057059-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/282/tVI/s602"},"text":"Pub. L. 107–282, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-06"},"text":"Nov. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2009"},"text":"116 Stat. 2009","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7805705a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7805705b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7805705c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/282/s1"},"text":"Pub. L. 107–282, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-06"},"text":"Nov. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1994"},"text":"116 Stat. 1994","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/282/s1"},"text":"“This Act [enacting this subchapter, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460ccc–1"},"text":"section 460ccc–1 of this title","children":[],"tail":", enacting provisions set out as notes under this section and sections 460n–1, 460ccc–4, and 460qqq–1 of this title, enacting provisions listed in a table of National Wildlife Refuges set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s668dd"},"text":"section 668dd of this title","children":[],"tail":", and enacting and amending provisions listed in a table of Wilderness Areas set out under 1132 of this title] may be cited as the ‘Clark County Conservation of Public Land and Natural Resources Act of 2002’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/282/tVI/s601"},"text":"Pub. L. 107–282, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-06"},"text":"Nov. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2009"},"text":"116 Stat. 2009","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/282/tVI/s601"},"text":"“This title [enacting this subchapter] may be cited as the ‘Sloan Canyon National Conservation Area Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
