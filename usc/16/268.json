{"tag":"section","attrib":{"id":"id7723004f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s268"},"text":null,"children":[{"tag":"num","attrib":{"value":"268"},"text":"§ 268.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary to acquire lands for trailheads","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77230050-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s268/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the Act of ","children":[{"tag":"date","attrib":{"date":"1940-06-11"},"text":"June 11, 1940","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s261"},"text":"16 U.S.C. 261","children":[],"tail":" et seq.), the Secretary of the Interior is authorized to acquire by donation, purchase with donated or appropriated funds, or exchange not to exceed 10 acres of land or interests in land, which shall consist of those necessary lands for the establishment of trailheads to be located at White Rocks and Chadwell Gap."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77230051-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s268/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Lands and interests in lands acquired pursuant to subsection (a) shall be added to and administered as part of the Cumberland Gap National Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77230052-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/333/dI/tII/s216"},"text":"Pub. L. 104–333, div. I, title II, § 216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-11-12"},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4112"},"text":"110 Stat. 4112","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77230053-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77230054-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77230055-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The act of ","children":[{"tag":"date","attrib":{"date":"1940-06-11"},"text":"June 11, 1940","children":[],"tail":", referred to in subsec. (a), is "},{"tag":"ref","attrib":{"href":"/us/act/1940-06-11/ch304"},"text":"act June 11, 1940, ch. 304","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/262"},"text":"54 Stat. 262","children":[],"tail":", which is classified generally to this subchapter. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77230056-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Omnibus Parks and Public Lands Management Act of 1996, and not as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-06-11/ch304"},"text":"act June 11, 1940, ch. 304","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/262"},"text":"54 Stat. 262","children":[],"tail":", which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
