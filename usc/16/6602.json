{"tag":"section","attrib":{"id":"id7a16c4eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602"},"text":null,"children":[{"tag":"num","attrib":{"value":"6602"},"text":"§ 6602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a16c4ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CITES","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “CITES” means the Convention on International Trade in Endangered Species of Wild Fauna and Flora (27 UST 1087; TIAS 8249).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c4ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “conservation” means the use of all methods and procedures necessary to protect marine turtles, freshwater turtles, and tortoises, and the habitats of marine turtles, freshwater turtles, and tortoises, in foreign countries and territories of the United States under the jurisdiction of United States Fish and Wildlife Service programs, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c4ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection, restoration, and management of habitats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" onsite research and monitoring of populations, habitats, annual reproduction, and species population trends;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in the development, implementation, and improvement of national and regional management plans for habitat ranges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enforcement and implementation of CITES and laws of foreign countries—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a16c4f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect and manage populations and habitats; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a16c4f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent illegal trade of marine turtles;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" training of local law enforcement officials in the interdiction and prevention of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a16c4f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the illegal killing of marine turtles, freshwater turtles, and tortoises; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a16c4f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" illegal trade in marine turtles;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiatives to resolve conflicts between humans and marine turtles, freshwater turtles, and tortoises over habitats used by marine turtles, freshwater turtles, and tortoises;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community outreach and education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening of the ability of local communities to implement population and habitat conservation programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c4fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Freshwater turtle","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c4fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “freshwater turtle” means any member of the family Carettochelyidae, Chelidae, Chelydridae, Dermatemydidae, Emydidae, Geoemydidae, Kinosternidae, Pelomedusidae, Platysternidae, Podocnemididae, or Trionychidae.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “freshwater turtle” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a16c4fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any part, product, egg, or offspring of a turtle described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a16c4fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a carcass of such a turtle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c4ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Fund” means the Marine Turtle Conservation Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6604"},"text":"section 6604 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c500-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Habitat","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “habitat” means any marine turtle, freshwater turtle, or tortoise habitat (including a nesting habitat) that is under the jurisdiction of United States Fish and Wildlife Service programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c501-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marine turtle","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c502-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “marine turtle” means any member of the family Cheloniidae or Dermochelyidae.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c503-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “marine turtle” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a16c504-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any part, product, egg, or offspring of a turtle described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a16c505-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a carcass of such a turtle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c506-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multinational Species Conservation Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Multinational Species Conservation Fund” means the fund established under the heading “multinational species conservation fund” in title I of the Department of the Interior and Related Agencies Appropriations Act, 1999 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4246"},"text":"16 U.S.C. 4246","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c507-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c508-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territory of the United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “territory of the United States” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c509-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" American Samoa;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c50a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of the Northern Mariana Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c50b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of Puerto Rico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c50c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guam;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c50d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Virgin Islands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c50e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/9/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c50f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tortoise","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c510-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tortoise” means any member of the family Testudinidae.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c511-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tortoise” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a16c512-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/10/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any part, product, egg, or offspring of a tortoise described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a16c513-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6602/10/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a carcass of such a tortoise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a16c514-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/266/s3"},"text":"Pub. L. 108–266, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-02"},"text":"July 2, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/792"},"text":"118 Stat. 792","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tVII/s7001/c/3/B"},"text":"Pub. L. 116–9, title VII, § 7001(c)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/786"},"text":"133 Stat. 786","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a16c515-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a16c516-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a16c517-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title I of the Department of the Interior and Related Agencies Appropriations Act, 1999, referred to in par. (7), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tI"},"text":"Pub. L. 105–277, div. A, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–232. Provisions under the heading “"},{"tag":"inline","attrib":{},"text":"multinational species conservation fund","children":[],"tail":"” in "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/e/tI"},"text":"Pub. L. 105–277, § 101(e) [title I]","children":[],"tail":" appear at "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-237"},"text":"112 Stat. 2681–237","children":[],"tail":" and are classified in part to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4246"},"text":"section 4246 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a16c518-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/B/i/I"},"text":"Pub. L. 116–9, § 7001(c)(3)(B)(i)(I)","children":[],"tail":", substituted “marine turtles, freshwater turtles, and tortoises, and the habitats of marine turtles, freshwater turtles, and tortoises, in foreign countries and territories of the United States under the jurisdiction of United States Fish and Wildlife Service programs” for “nesting habitats of marine turtles in foreign countries and of marine turtles in those habitats” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(A) to (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/B/i/II"},"text":"Pub. L. 116–9, § 7001(c)(3)(B)(i)(II)","children":[],"tail":", struck out “nesting” wherever appearing before “habitats”, “populations”, and “habitat”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/B/i/III/aa"},"text":"Pub. L. 116–9, § 7001(c)(3)(B)(i)(III)(aa)","children":[],"tail":", substituted “countries—” for “countries to—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(D)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/B/i/III/bb"},"text":"Pub. L. 116–9, § 7001(c)(3)(B)(i)(III)(bb)","children":[],"tail":", inserted “to” before “protect” and struck out “nesting” before “populations” and before “habitats”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(D)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/B/i/III/cc"},"text":"Pub. L. 116–9, § 7001(c)(3)(B)(i)(III)(cc)","children":[],"tail":", inserted “to” before “prevent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(E)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/B/i/IV"},"text":"Pub. L. 116–9, § 7001(c)(3)(B)(i)(IV)","children":[],"tail":", substituted “turtles, freshwater turtles, and tortoises” for “turtles on nesting habitat”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/B/i/V"},"text":"Pub. L. 116–9, § 7001(c)(3)(B)(i)(V)","children":[],"tail":", substituted “turtles, freshwater turtles, and tortoises over habitats used by marine turtles, freshwater turtles, and tortoises” for “turtles over habitat used by marine turtles for nesting”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/B/i/VI"},"text":"Pub. L. 116–9, § 7001(c)(3)(B)(i)(VI)","children":[],"tail":", struck out “nesting” before “population” and before “habitat”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/B/ii"},"text":"Pub. L. 116–9, § 7001(c)(3)(B)(ii)","children":[],"tail":"–(v), added pars. (3), (5), (9), and (10) and redesignated former pars. (3) to (6) as (4), (6), (7), and (8), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
