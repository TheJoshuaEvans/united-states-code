{"tag":"section","attrib":{"id":"id7714a861-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s218a"},"text":null,"children":[{"tag":"num","attrib":{"value":"218a"},"text":"§ 218a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abraham Lincoln Birthplace National Historical Park, Kentucky","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7714a862-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s218a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon acquisition of the land known as Knob Creek Farm pursuant to subsection (b), the boundary of the Abraham Lincoln Birthplace National Historical Park, established by sections 211 to 214 of this title, is revised to include such land. Lands acquired pursuant to this section shall be administered by the Secretary of the Interior as part of the historic site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7714a863-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s218a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of Knob Creek Farm","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior may acquire, by donation only, the approximately 228 acres of land known as Knob Creek Farm in Larue County, Kentucky, as generally depicted on a map entitled “Knob Creek Farm Unit, Abraham Lincoln National Historic Site”, numbered 338/80,077, and dated October 1998. Such map shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7714a864-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s218a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior shall study the Knob Creek Farm in Larue County, Kentucky, and not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1998-11-06"},"text":"November 6, 1998","children":[],"tail":", submit a report to the Congress containing the results of the study. The purpose of the study shall be to:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7714a865-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s218a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identify significant resources associated with the Knob Creek Farm and the early boyhood of Abraham Lincoln.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7714a866-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s218a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evaluate the threats to the long-term protection of the Knob Creek Farm’s cultural, recreational, and natural resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7714a867-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s218a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Examine the incorporation of the Knob Creek Farm into the operations of the Abraham Lincoln Birthplace National Historical Park and establish a strategic management plan for implementing such incorporation. In developing the plan, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7714a868-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s218a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine infrastructure requirements and property improvements needed at Knob Creek Farm to meet National Park Service standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7714a869-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s218a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify current and potential uses of Knob Creek Farm for recreational, interpretive, and educational opportunities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7714a86a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s218a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" project costs and potential revenues associated with acquisition, development, and operation of Knob Creek Farm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7714a86b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s218a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7714a86c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/355/tV/s510"},"text":"Pub. L. 105–355, title V, § 510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-06"},"text":"Nov. 6, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3265"},"text":"112 Stat. 3265","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7114/b"},"text":"Pub. L. 111–11, title VII, § 7114(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1202"},"text":"123 Stat. 1202","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7714a86d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7714a86e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7714a86f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Abraham Lincoln Birthplace National Historical Park” substituted for “Abraham Lincoln Birthplace National Historic Site” in section catchline and in subsecs. (a) and (c)(3) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
