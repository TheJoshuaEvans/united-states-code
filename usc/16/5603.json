{"tag":"section","attrib":{"id":"id7a01677f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5603"},"text":null,"children":[{"tag":"num","attrib":{"value":"5603"},"text":"§ 5603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities of Secretary of State with respect to Convention","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of State may, on behalf of the Government of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a016780-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5603/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive and transmit reports, requests, recommendations, proposals, and other communications of and to the Organization and its subsidiary organs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a016781-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5603/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" object, or withdraw an objection, to the proposal of the Commission consistent with the procedures detailed in Articles XIV and XV of the Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a016782-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5603/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give or withdraw notice of intent not to be bound by a measure of the Commission consistent with the procedures detailed in Articles XIV and XV of the Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a016783-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5603/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" object or withdraw an objection to an amendment to the Convention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a016784-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5603/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" act upon, or refer to any other appropriate authority, any other communication referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a016785-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tII/s204"},"text":"Pub. L. 104–43, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/379"},"text":"109 Stat. 379","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/327/tV/s504"},"text":"Pub. L. 114–327, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1996"},"text":"130 Stat. 1996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a016786-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a016787-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a016788-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Pars. (2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327"},"text":"Pub. L. 114–327","children":[],"tail":" substituted “Commission consistent with the procedures detailed in Articles XIV and XV of the Convention” for “Fisheries Commission”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
