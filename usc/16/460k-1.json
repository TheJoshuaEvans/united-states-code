{"tag":"section","attrib":{"id":"id77c051b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460k–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"460k–1"},"text":"§ 460k–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of lands for recreational development; funds","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to acquire areas of land, or interests therein, which are suitable for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77c051b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460k–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incidental fish and wildlife-oriented recreational development,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c051b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460k–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of natural resources,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c051b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460k–1/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conservation of endangered species or threatened species listed by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1533"},"text":"section 1533 of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c051b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460k–1/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out two or more of the purposes set forth in paragraphs (1) through (3) of this section, and are adjacent to, or within, the said conservation areas, except that the acquisition of any land or interest therein pursuant to this section shall be accomplished only with such funds as may be appropriated therefor by the Congress or donated for such purposes, but such property shall not be acquired with funds obtained from the sale of Federal migratory bird hunting stamps.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Lands acquired pursuant to this section shall become a part of the particular conservation area to which they are adjacent.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77c051b7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/714/s2"},"text":"Pub. L. 87–714, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-28"},"text":"Sept. 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/653"},"text":"76 Stat. 653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/534"},"text":"Pub. L. 92–534","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-23"},"text":"Oct. 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1063"},"text":"86 Stat. 1063","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/205/s13/d"},"text":"Pub. L. 93–205, § 13(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/902"},"text":"87 Stat. 902","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77c051b8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77c051b9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77c051ba-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":" inserted references to the acquisition of interest in land the conservation of endangered species or threatened species listed by the Secretary pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1533"},"text":"section 1533 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/534"},"text":"Pub. L. 92–534","children":[],"tail":" substituted provisions authorizing the Secretary to acquire lands suitable for fish and wildlife oriented recreational development, or for the protection of natural resources and adjacent to conservation areas, for provisions authorizing the Secretary to acquire limited areas of land for recreational development adjacent to conservation areas in existence or approved by the Migratory Bird Conservation Commission as of "},{"tag":"date","attrib":{"date":"1962-09-28"},"text":"September 28, 1962","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77c051bb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77c051bc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1973 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/205/s16"},"text":"section 16 of Pub. L. 93–205","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"section 1531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
