{"tag":"section","attrib":{"id":"id78a53348-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a"},"text":null,"children":[{"tag":"num","attrib":{"value":"823a"},"text":"§ 823a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduit hydroelectric facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78a53349-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying conduit hydropower facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a5334a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A qualifying conduit hydropower facility shall not be required to be licensed under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a5334b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a5334c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person, State, or municipality proposing to construct a qualifying conduit hydropower facility shall file with the Commission a notice of intent to construct such facility. The notice shall include sufficient information to demonstrate that the facility meets the qualifying criteria.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a5334d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 15 days after receipt of a notice of intent filed under subparagraph (A), the Commission shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78a5334e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make an initial determination as to whether the facility meets the qualifying criteria; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78a5334f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Commission makes an initial determination, pursuant to clause (i), that the facility meets the qualifying criteria, publish public notice of the notice of intent filed under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a53350-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If, not later than 30 days after the date of publication of the public notice described in subparagraph (B)(ii)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78a53351-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity contests whether the facility meets the qualifying criteria, the Commission shall promptly issue a written determination as to whether the facility meets such criteria; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78a53352-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no entity contests whether the facility meets the qualifying criteria, the facility shall be deemed to meet such criteria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a53353-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a53354-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “conduit” means any tunnel, canal, pipeline, aqueduct, flume, ditch, or similar manmade water conveyance that is operated for the distribution of water for agricultural, municipal, or industrial consumption and not primarily for the generation of electricity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a53355-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “qualifying conduit hydropower facility” means a facility (not including any dam or other impoundment) that is determined or deemed under paragraph (2)(C) to meet the qualifying criteria.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a53356-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “qualifying criteria” means, with respect to a facility—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78a53357-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facility is constructed, operated, or maintained for the generation of electric power and uses for such generation only the hydroelectric potential of a non-federally owned conduit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78a53358-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facility has an installed capacity that does not exceed 40 megawatts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78a53359-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/a/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or before ","children":[{"tag":"date","attrib":{"date":"2013-08-09"},"text":"August 9, 2013","children":[],"tail":", the facility is not licensed under, or exempted from the license requirements contained in, this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a5335a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (c), the Commission may grant an exemption in whole or in part from the requirements of this subchapter, including any license requirements contained in this subchapter, to any facility (not including any dam or other impoundment) constructed, operated, or maintained for the generation of electric power which the Commission determines, by rule or order—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a5335b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilizes for such generation only the hydroelectric potential of a conduit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a5335c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an installed capacity that does not exceed 40 megawatts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a5335d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Federal and State agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making the determination under subsection (b) the Commission shall consult with the United States Fish and Wildlife Service ","children":[{"tag":"ref","attrib":{"idref":"fn002524"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002524"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" National Marine Fisheries Service "},{"tag":"ref","attrib":{"idref":"fn002524"},"text":"1","children":[],"tail":" and the State agency exercising administration over the fish and wildlife resources of the State in which the facility is or will be located, in the manner provided by the Fish and Wildlife Coordination Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s661"},"text":"16 U.S.C. 661","children":[],"tail":", et seq.), and shall include in any such exemption—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a5335e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such terms and conditions as the Fish and Wildlife Service ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" National Marine Fisheries Service "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and the State agency each determine are appropriate to prevent loss of, or damage to, such resources and to otherwise carry out the purposes of such Act, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a5335f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such terms and conditions as the Commission deems appropriate to insure that such facility continues to comply with the provisions of this section and terms and conditions included in any such exemption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a53360-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation of terms of exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any violation of a term or condition of any exemption granted under subsection (b) shall be treated as a violation of a rule or order of the Commission under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a53361-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for studies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission, in addition to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s803/e"},"text":"section 803(e) of this title","children":[],"tail":", shall establish fees which shall be paid by an applicant for a license or exemption for a project that is required to meet terms and conditions set by fish and wildlife agencies under subsection (c). Such fees shall be adequate to reimburse the fish and wildlife agencies referred to in subsection (c) for any reasonable costs incurred in connection with any studies or other reviews carried out by such agencies for purposes of compliance with this section. The fees shall, subject to annual appropriations Acts, be transferred to such agencies by the Commission for use solely for purposes of carrying out such studies and shall remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78a53362-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"June 10, 1920, ch. 285","children":[],"tail":", pt. I, § 30, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/617/tII/s213"},"text":"Pub. L. 95–617, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3148"},"text":"92 Stat. 3148","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/495/s7"},"text":"Pub. L. 99–495, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-16"},"text":"Oct. 16, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1248"},"text":"100 Stat. 1248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/23/s4/a"},"text":"Pub. L. 113–23, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-08-09"},"text":"Aug. 9, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/494"},"text":"127 Stat. 494","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tIII/s3002"},"text":"Pub. L. 115–270, title III, § 3002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3863"},"text":"132 Stat. 3863","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78a53363-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78a53364-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78a53365-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Fish and Wildlife Coordination Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-03-10/ch55"},"text":"act Mar. 10, 1934, ch. 55","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/401"},"text":"48 Stat. 401","children":[],"tail":", which is classified generally to sections 661 to 666c–1 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s661/a"},"text":"section 661(a) of this title","children":[],"tail":", Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s661"},"text":"section 661 of this title","children":[],"tail":", and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id78a53366-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 30 of act ","children":[{"tag":"date","attrib":{"date":"1920-06-10"},"text":"June 10, 1920","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s791"},"text":"section 791 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-26/ch687/tII/s212"},"text":"act Aug. 26, 1935, ch. 687, title II, § 212","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/847"},"text":"49 Stat. 847","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78a53367-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s3002/1"},"text":"Pub. L. 115–270, § 3002(1)","children":[],"tail":", substituted “30 days” for “45 days” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s3002/2"},"text":"Pub. L. 115–270, § 3002(2)","children":[],"tail":", substituted “40 megawatts” for “5 megawatts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/23/s4/a/1"},"text":"Pub. L. 113–23, § 4(a)(1)","children":[],"tail":", added subsecs. (a) and (b) and struck out former subsecs. (a) and (b) which authorized the Commission to grant exemptions from the requirements of this subchapter for certain hydroelectric facilities and prohibited the granting of exemptions to facilities with certain capacities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/23/s4/a/2"},"text":"Pub. L. 113–23, § 4(a)(2)","children":[],"tail":", substituted “subsection (b)” for “subsection (a)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/23/s4/a/3"},"text":"Pub. L. 113–23, § 4(a)(3)","children":[],"tail":", substituted “subsection (b)” for “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/495/s7/a"},"text":"Pub. L. 99–495, § 7(a)","children":[],"tail":", inserted provision setting the maximum installation capacity for exemptions under subsec. (a) at 40 megawatts in the case of a facility constructed, operated, and maintained by an agency or instrumentality of a State or local government solely for water supply for municipal purposes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/495/s7/b"},"text":"Pub. L. 99–495, § 7(b)","children":[],"tail":", which directed the insertion of “National Marine Fisheries Service” after “the Fish and Wildlife Service” in both places such term appears, was executed by inserting “National Marine Fisheries Service” after “the United States Fish and Wildlife Service” and “the Fish and Wildlife Service”, as the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/495/s7/c"},"text":"Pub. L. 99–495, § 7(c)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78a53368-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78a53369-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/495"},"text":"Pub. L. 99–495","children":[],"tail":" effective with respect to each license, permit, or exemption issued under this chapter after "},{"tag":"date","attrib":{"date":"1986-10-16"},"text":"Oct. 16, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/495/s18"},"text":"section 18 of Pub. L. 99–495","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s797"},"text":"section 797 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78a5336a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of Subsection (c)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/495/s8/c"},"text":"Pub. L. 99–495, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-16"},"text":"Oct. 16, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1251"},"text":"100 Stat. 1251","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/495/s8/c"},"text":"“Nothing in this Act [see Short Title of 1986 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s791a"},"text":"section 791a of this title","children":[],"tail":"] shall affect the application of section 30(c) of the Federal Power Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s823a/c"},"text":"16 U.S.C. 823a(c)","children":[],"tail":"] to any exemption issued after the enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-10-16"},"text":"Oct. 16, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
