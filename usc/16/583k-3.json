{"tag":"section","attrib":{"id":"id7851bc8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"583k–3"},"text":"§ 583k–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority trail maintenance program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7851bc8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with subsections (b) and (c), not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2016-11-28"},"text":"November 28, 2016","children":[],"tail":", the Secretary of Agriculture shall select no fewer than 9 and no more than 15 priority areas for increased trail maintenance accomplishments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Priority areas shall include a well-defined region on National Forest System land where the lack of trail maintenance has—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7851bc8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduced access to public land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" led to an increase, or risk of increase, in harm to natural resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jeopardized public safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resulted in trails being impassible by the intended managed users; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased future deferred trail maintenance costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting priority areas, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7851bc94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider any public input on priority areas received within 3 months of ","children":[{"tag":"date","attrib":{"date":"2016-11-28"},"text":"November 28, 2016","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the range of trail users (including motorized and non-motorized trail users); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include at least one priority area in each region of the United States Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increased trail maintenance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7851bc98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 6 months of the selection of priority areas under subsection (a), and in accordance with paragraph (2), the Secretary shall develop an approach to substantially increase trail maintenance accomplishments within each priority area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the approach under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7851bc9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider any public input on trail maintenance priorities and needs within any priority area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7851bc9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the costs and benefits of increased trail maintenance within each priority area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7851bc9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate partners and volunteers in the trail maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required trail maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Utilizing the approach developed under paragraph (1), the Secretary shall substantially increase trail maintenance within each priority area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regional volunteer and partnership coordinators may be responsible for assisting partner organizations in developing and implementing volunteer and partnership projects to increase trail maintenance within priority areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–3/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall periodically review the priority areas to determine whether revisions are necessary and may revise the priority areas, including the selection of new priority areas or removal of existing priority areas, at his sole discretion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7851bca0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/245/s5"},"text":"Pub. L. 114–245, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-11-28"},"text":"Nov. 28, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/993"},"text":"130 Stat. 993","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
