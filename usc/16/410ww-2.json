{"tag":"section","attrib":{"id":"id7760f3f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ww–2"},"text":"§ 410ww–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Park general management plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7760f3f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 complete fiscal years after ","children":[{"tag":"date","attrib":{"date":"1992-10-16"},"text":"October 16, 1992","children":[],"tail":", the Secretary, with the advice of the Commission, shall prepare and submit to the Congress a general management plan for the park which includes but is not limited to the information described in "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":", and which takes into account the preservation and development plan developed under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ww–22"},"text":"section 410ww–22 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f3f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Park partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The management plan shall identify partnership opportunities between the Secretary and other Federal, State, and local governments and the private sector for the development, use, and interpretation of properties within the park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7760f3f4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/419/tI/s103"},"text":"Pub. L. 102–419, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2142"},"text":"106 Stat. 2142","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7760f3f5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7760f3f6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7760f3f7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":"” substituted for “"},{"tag":"ref","attrib":{"href":"/us/act/1970-08-18/s12/b"},"text":"section 12(b) of the Act of August 18, 1970","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1a–7/b"},"text":"16 U.S.C. 1a–7(b)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/e"},"text":"Pub. L. 113–287, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3272"},"text":"128 Stat. 3272","children":[],"tail":", which Act enacted Title 54, National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"