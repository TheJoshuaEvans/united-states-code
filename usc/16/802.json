{"tag":"section","attrib":{"id":"id78a07886-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s802"},"text":null,"children":[{"tag":"num","attrib":{"value":"802"},"text":"§ 802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to accompany application for license; landowner notification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78a07887-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s802/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each applicant for a license under this chapter shall submit to the commission—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a07888-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s802/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such maps, plans, specifications, and estimates of cost as may be required for a full understanding of the proposed project. Such maps, plans, and specifications when approved by the commission shall be made a part of the license; and thereafter no change shall be made in said maps, plans, or specifications until such changes shall have been approved and made a part of such license by the commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a07889-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s802/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Satisfactory evidence that the applicant has complied with the requirements of the laws of the State or States within which the proposed project is to be located with respect to bed and banks and to the appropriation, diversion, and use of water for power purposes and with respect to the right to engage in the business of developing, transmitting and distributing power, and in any other business necessary to effect the purposes of a license under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a0788a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s802/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002519"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002519"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Codification note below."}],"tail":" Such additional information as the commission may require."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a0788b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s802/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon the filing of any application for a license (other than a license under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s808"},"text":"section 808 of this title","children":[],"tail":") the applicant shall make a good faith effort to notify each of the following by certified mail:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a0788c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s802/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who is an owner of record of any interest in the property within the bounds of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a0788d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s802/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any Federal, State, municipal or other local governmental agency likely to be interested in or affected by such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78a0788e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"June 10, 1920, ch. 285","children":[],"tail":", pt. I, § 9, "},{"tag":"ref","attrib":{"href":"/us/stat/41/1068"},"text":"41 Stat. 1068","children":[],"tail":"; renumbered pt. I, "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-26/ch687"},"text":"Aug. 26, 1935, ch. 687","children":[],"tail":", title II, § 212, "},{"tag":"ref","attrib":{"href":"/us/stat/49/847"},"text":"49 Stat. 847","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/495/s14"},"text":"Pub. L. 99–495, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-16"},"text":"Oct. 16, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1257"},"text":"100 Stat. 1257","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78a0788f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78a07890-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78a07891-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Former subsec. (c), included in the provisions designated as subsec. (a) by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/495"},"text":"Pub. L. 99–495","children":[],"tail":", has been editorially redesignated as par. (3) of subsec. (a) as the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78a07892-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/495"},"text":"Pub. L. 99–495","children":[],"tail":" designated existing provisions as subsec. (a), redesignated former subsecs. (a) and (b) as pars. (1) and (2) of subsec. (a), and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78a07893-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78a07894-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/495"},"text":"Pub. L. 99–495","children":[],"tail":" effective with respect to each license, permit, or exemption issued under this chapter after "},{"tag":"date","attrib":{"date":"1986-10-16"},"text":"Oct. 16, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/495/s18"},"text":"section 18 of Pub. L. 99–495","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s797"},"text":"section 797 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
