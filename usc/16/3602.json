{"tag":"section","attrib":{"id":"id79be9216-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3602"},"text":null,"children":[{"tag":"num","attrib":{"value":"3602"},"text":"§ 3602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States representation on Council and Commissions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79be9217-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and qualifications of Commissioners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States shall be represented on the Council and Commissions by three United States Commissioners to be appointed by the President to serve at his pleasure. Of such Commissioners, one shall be an official of the United States Government, and two shall be individuals (not officials of the United States Government) who are knowledgeable or experienced concerning the conservation and management of salmon of United States origin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79be9218-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternate Commissioners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, in consultation with the Secretary of Commerce and the Secretary of the Interior, may designate alternate United States Commissioners. In the absence of a Commissioner appointed under subsection (a) of this section, an alternate Commissioner may exercise at any meeting of the Organization, the Council, or any Commission all functions of such Commissioner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79be9219-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3602/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited Federal employee status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Individuals who serve as Commissioners and alternate Commissioners shall not receive any compensation for such service. Such individuals shall not be considered to be Federal employees while performing such service, except for purposes of injury compensation or tort claims liability as provided in chapter 81 of title 5 and chapter 171 of title 28.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79be921a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3602/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with other parties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out their functions under the Convention, the Commissioners may consult with the appropriate Regional Fishery Management Councils established by section 302 of the Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1852"},"text":"16 U.S.C. 1852","children":[],"tail":"), and may consult with such other interested parties as they consider appropriate. Chapter 10 of title 5 shall not apply to consultations described in this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79be921b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/389/tIII/s303"},"text":"Pub. L. 97–389, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-29"},"text":"Dec. 29, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1952"},"text":"96 Stat. 1952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/44/tI/s102/1"},"text":"Pub. L. 98–44, title I, § 102(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-07-12"},"text":"July 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/216"},"text":"97 Stat. 216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/117"},"text":"Pub. L. 117–286, § 4(a)(117)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4318"},"text":"136 Stat. 4318","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79be921c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79be921d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79be921e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App. et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/44"},"text":"Pub. L. 98–44","children":[],"tail":" substituted “shall not be considered” for “shall be considered”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
