{"tag":"section","attrib":{"id":"id795a7a0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1686"},"text":null,"children":[{"tag":"num","attrib":{"value":"1686"},"text":"§ 1686.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the term:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795a7a0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1686/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Anticipated cost of removal” means the projected cost of removal of wood residues from timber sales areas to points of prospective use, as determined by the Secretary at the time of advertisement of the timber sales contract in accordance with appropriate appraisal and sale procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795a7a0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1686/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Anticipated value” means the projected value of wood residues as fuel or other merchantable wood products, as determined by the Secretary at the time of advertisement of the timber sales contract in accordance with appropriate appraisal and sale procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795a7a0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1686/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Points of prospective use” means the locations where the wood residues are sold or otherwise put to use, as determined by the Secretary in accordance with appropriate appraisal and sale procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795a7a0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1686/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Person” means an individual, partnership, joint-stock company, corporation, association, trust, estate, or any other legal entity, or any agency of Federal or State government or of a political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795a7a0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1686/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795a7a10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1686/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Wood residues” includes, but is not limited to, logging slash, down timber material, woody plants, and standing live or dead trees which do not meet utilization standards because of size, species, merchantable volume, or economic selection criteria and which, in the case of live trees, are surplus to growing stock needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id795a7a11-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/554/s7"},"text":"Pub. L. 96–554, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-19"},"text":"Dec. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3258"},"text":"94 Stat. 3258","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795a7a12-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id795a7a13-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id795a7a14-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/554/s9"},"text":"section 9 of Pub. L. 96–554","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
