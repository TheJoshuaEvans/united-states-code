{"tag":"section","attrib":{"id":"id7892200e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"760–3"},"text":"§ 760–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of trout hatchery in Pisgah National Forest","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior, after consulting with the Secretary of Agriculture, shall establish, construct, equip, operate, and maintain a trout hatchery at an appropriate location on the Davidson River in the Pisgah National Forest, North Carolina.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7892200f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-06-18/ch404/s1"},"text":"June 18, 1956, ch. 404, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/292"},"text":"70 Stat. 292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78922010-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78922011-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78922012-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2 of act ","children":[{"tag":"date","attrib":{"date":"1956-06-18"},"text":"June 18, 1956","children":[],"tail":", authorized the appropriation of $375,000 to carry out the purposes of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
