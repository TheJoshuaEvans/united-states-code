{"tag":"section","attrib":{"id":"id7a016818-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5706"},"text":null,"children":[{"tag":"num","attrib":{"value":"5706"},"text":"§ 5706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority and responsibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a016819-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsible management entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State of Alaska Department of Fish and Game shall be the responsible management entity for the United States for the purposes of the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a01681a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The designation under subsection (a) shall not be considered to expand, diminish, or change the management authority of the State of Alaska or the Federal Government with respect to fishery resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a01681b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations of Panel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to recommendations made by the Panel to the responsible management entities in accordance with the Agreement, the Panel may make recommendations concerning the conservation and management of salmon originating in the Yukon River to the Department of the Interior, Department of Commerce, Department of State, North Pacific Fishery Management Council, and other Federal or State entities as appropriate. Recommendations by the Panel shall be advisory in nature.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a01681c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tVII/s707"},"text":"Pub. L. 104–43, title VII, § 707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/394"},"text":"109 Stat. 394","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
