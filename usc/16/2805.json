{"tag":"section","attrib":{"id":"id79a4534a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805"},"text":null,"children":[{"tag":"num","attrib":{"value":"2805"},"text":"§ 2805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of national activities regarding aquaculture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a4534b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established within the Office of Science and Technology Policy an interagency aquaculture coordinating group that shall, subject to subsection (f), operate as a Joint Subcommittee on Aquaculture of the Federal Coordinating Council on Science, Engineering, and Technology (hereinafter in this section referred to as the “Federal Council”) established by Executive Order 12039, dated ","children":[{"tag":"date","attrib":{"date":"1978-02-24"},"text":"February 24, 1978","children":[],"tail":". The coordinating group shall be composed of the following members or their designees:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a4534c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture, who shall be the permanent chairman of the coordinating group.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a4534d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a4534e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a4534f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a45350-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a45351-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a45352-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Engineers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a45353-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Small Business Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a45354-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Agency for International Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a45355-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman of the Tennessee Valley Authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a45356-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a45357-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Governor of the Farm Credit Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a45358-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The heads of such other Federal agencies as are deemed appropriate by the Director of the Office of Science and Technology Policy (hereinafter in this section referred to as the “Director”), after consultation with the coordinating group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a45359-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose and functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the coordinating group is to increase the overall effectiveness and productivity of Federal aquaculture research, transfer, and assistance programs. In fulfilling this purpose the coordinating group shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a4535a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the national needs for aquaculture research, transfer, and assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a4535b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the effectiveness and adequacy of Federal efforts to meet those national needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a4535c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake planning, coordination, and communication among Federal agencies engaged in the science, engineering, and technology of aquaculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a4535d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect, compile, and disseminate information on aquaculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a4535e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage joint programs among Federal agencies in areas of mutual interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a4535f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend to the Federal Council specific actions on issues, problems, plans, and programs in aquaculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a45360-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The coordinating group shall regularly report to the Chairman of the Federal Council on the coordinating group’s activities and on recommendations concerning Federal policies and programs related to aquaculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a45361-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal consistency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal department and agency that has functions or responsibilities with respect to aquaculture or has jurisdiction over any activity that affects, or that may affect, the achievement of the purpose and policy of this chapter, shall, in consultation with the coordinating group and to the maximum extent practicable, perform such function, responsibility, or activity in a manner that is consistent with the purpose and policy of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a45362-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2805/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions if Federal Council terminated","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If at any time after ","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"September 26, 1980","children":[],"tail":", the functions of the Federal Council are by executive action terminated or transferred to an agency other than the Office of Science and Technology Policy, the coordinating group shall carry out its purpose under the direction of the Director. In that event, the recommendations of the coordinating group referred to in subsection (b)(6) and the reports required under subsection (c) shall be made to the Director."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a45363-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/362/s6"},"text":"Pub. L. 96–362, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1203"},"text":"94 Stat. 1203","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVII/s1736"},"text":"Pub. L. 99–198, title XVII, § 1736","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1643"},"text":"99 Stat. 1643","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a45364-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a45365-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79a45366-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 12039, dated ","children":[{"tag":"date","attrib":{"date":"1978-02-24"},"text":"February 24, 1978","children":[],"tail":", referred to in subsec. (a), is Ex. Ord. No. 12039, "},{"tag":"date","attrib":{"date":"1978-02-24"},"text":"Feb. 24, 1978","children":[],"tail":", 43 F.R. 8095, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6601"},"text":"section 6601 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79a45367-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1736/1"},"text":"Pub. L. 99–198, § 1736(1)","children":[],"tail":", inserted “, who shall be the permanent chairman of the coordinating group”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1736/2"},"text":"Pub. L. 99–198, § 1736(2)","children":[],"tail":"–(4), struck out subsec. (c) which provided that each of the Secretaries or their designees, on such rotating basis as determined by the Director, shall serve as the chairman of the coordinating group, with the term of office of the chairman set at two years, redesignated subsecs. (d) to (f) as (c) to (e), respectively, and in subsec. (e), as redesignated, substituted “subsection (c)” for “subsection (d)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
