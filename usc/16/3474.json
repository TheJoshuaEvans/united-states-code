{"tag":"section","attrib":{"id":"id79b9d836-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3474"},"text":null,"children":[{"tag":"num","attrib":{"value":"3474"},"text":"§ 3474.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation incentives landowner education program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b9d837-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3474/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall establish a conservation incentives landowner education program (referred to in this section as the “program”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b9d838-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3474/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program shall provide information on Federal conservation programs available to landowners interested in undertaking conservation actions on the land of the landowners, including options under each conservation program available to achieve the conservation goals of the program, such as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b9d839-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3474/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fee title land acquisition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d83a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3474/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d83b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3474/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perpetual and term conservation easements or agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b9d83c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3474/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that the information provided under the program is made available to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b9d83d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3474/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interested landowners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d83e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3474/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b9d83f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3474/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which the Secretary contacts a landowner directly about participation in a Federal conservation program, the Secretary shall, in writing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b9d840-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3474/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the landowner of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d841-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3474/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available information on the conservation program options that may be available to the landowner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b9d842-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tIII/s3002"},"text":"Pub. L. 116–9, title III, § 3002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/756"},"text":"133 Stat. 756","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b9d843-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79b9d844-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79b9d845-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the John D. Dingell, Jr. Conservation, Management, and Recreation Act, and not as part of title XV of the Agriculture and Food Act of 1981 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79b9d846-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id79b9d847-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2"},"text":"section 2 of Pub. L. 116–9","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
