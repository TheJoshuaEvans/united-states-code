{"tag":"section","attrib":{"id":"id77fbfb6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–44"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–44"},"text":"§ 460lll–44.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fbfb6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–44/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreation Area records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall have access to all records of the Tennessee Valley Authority pertaining to the management of the Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–44/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Tennessee Valley Authority personnel records shall be made available to the Secretary, on request, to the extent the records are relevant to Forest Service administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–44/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Tennessee Valley Authority may prescribe terms and conditions on the availability of records to protect the confidentiality of private or proprietary information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–44/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land title records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Tennessee Valley Authority shall provide to the Secretary original records pertaining to land titles, surveys, and other records pertaining to transferred personal property and facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fbfb70-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s544"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 544]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–318.)"}],"tail":"\n"}],"tail":null}
