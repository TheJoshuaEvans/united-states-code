{"tag":"section","attrib":{"id":"id786e6c49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"669h–2"},"text":"§ 669h–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multistate conservation grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id786e6c4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id786e6c4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount for grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id786e6c4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $3,000,000 of the revenues covered into the fund for a fiscal year shall be available to the Secretary of the Interior for making multistate conservation project grants in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id786e6c4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability for hunter and recreational shooter grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $5,000,000 of the revenues covered into the fund from any tax imposed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4161/b"},"text":"section 4161(b) of title 26","children":[],"tail":" for a fiscal year shall be available to the Secretary exclusively for making hunter recruitment and recreational shooter recruitment grants that promote a national hunting and shooting sport recruitment program, including related communication and outreach activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id786e6c4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of availability; apportionment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id786e6c4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available under paragraph (1) shall remain available for making grants only for the first fiscal year for which the amount is made available and the following fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id786e6c50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apportionment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the end of the period of availability under subparagraph (A), the Secretary of the Interior shall apportion any amounts that remain available among the States in the manner specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s669c/b"},"text":"section 669c(b) of this title","children":[],"tail":" for use by the States in the same manner as funds apportioned under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s669c/b"},"text":"section 669c(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id786e6c51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id786e6c52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States or entities to be benefited","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project shall not be eligible for a grant under this section unless the project will benefit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id786e6c53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 26 States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id786e6c54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a majority of the States in a region of the United States Fish and Wildlife Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id786e6c55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regional association of State fish and game departments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id786e6c56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of submitted priority list of projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior may make grants under this section only for projects identified on a priority list of wildlife restoration projects described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id786e6c57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority list of projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A priority list referred to in paragraph (2) is a priority list of wildlife restoration projects that the Association of Fish and Wildlife Agencies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id786e6c58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prepares through a committee comprised of the heads of State fish and game departments (or their designees), in consultation with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id786e6c59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongovernmental organizations that represent conservation organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id786e6c5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sportsmen organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id786e6c5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industries that support or promote hunting, trapping, recreational shooting, bow hunting, or archery;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id786e6c5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approves by vote of a majority of the heads of State fish and game departments (or their designees); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id786e6c5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than October 1 of each fiscal year, submits to the Assistant Director for Wildlife and Sport Fish Restoration Programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id786e6c5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Director for Wildlife and Sport Fish Restoration Programs shall publish in the Federal Register each priority list submitted under paragraph (3)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id786e6c5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible grantees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id786e6c60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior may make a grant under this section only to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id786e6c61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or group of States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id786e6c62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Fish and Wildlife Service, or a State or group of States, for the purpose of carrying out the National Survey of Fishing, Hunting, and Wildlife-Associated Recreation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id786e6c63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (2), a nongovernmental organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id786e6c64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nongovernmental organizations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id786e6c65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any nongovernmental organization that applies for a grant under this section shall submit with the application to the Association of Fish and Wildlife Agencies a certification that the organization—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id786e6c66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not use the grant funds to fund, in whole or in part, any activity of the organization that promotes or encourages opposition to the regulated hunting or trapping of wildlife or to recreational shooting activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id786e6c67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will use the grant funds in compliance with subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id786e6c68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for certain activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any nongovernmental organization that is found to use grant funds in violation of subparagraph (A) shall return all funds received under this section and be subject to any other applicable penalties under law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id786e6c69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this section shall not be used, in whole or in part, for an activity, project, or program that promotes or encourages opposition to the regulated hunting or trapping of wildlife or to recreational shooting activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id786e6c6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669h–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to any activity carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id786e6c6b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-02/ch899/s11"},"text":"Sept. 2, 1937, ch. 899, § 11","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/408/tI/s113"},"text":"Pub. L. 106–408, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1767"},"text":"114 Stat. 1767","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tV/s501/g/1"},"text":"Pub. L. 116–94, div. P, title V, § 501(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3193"},"text":"133 Stat. 3193","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/101"},"text":"Pub. L. 117–286, § 4(a)(101)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4316"},"text":"136 Stat. 4316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id786e6c6c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id786e6c6d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id786e6c6e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 11 of act ","children":[{"tag":"date","attrib":{"date":"1937-09-02"},"text":"Sept. 2, 1937","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s669j"},"text":"section 669j of this title","children":[],"tail":" prior to repeal by act "},{"tag":"date","attrib":{"date":"1946-08-07"},"text":"Aug. 7, 1946","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id786e6c6f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s501/g/1/A"},"text":"Pub. L. 116–94, § 501(g)(1)(A)","children":[],"tail":", designated existing provisions as subpar. (A), inserted heading, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s501/g/1/B"},"text":"Pub. L. 116–94, § 501(g)(1)(B)","children":[],"tail":", struck out “International” before “Association” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s501/g/1/C"},"text":"Pub. L. 116–94, § 501(g)(1)(C)","children":[],"tail":", struck out “International” before “Association” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s501/g/1/D"},"text":"Pub. L. 116–94, § 501(g)(1)(D)","children":[],"tail":", inserted “or to recreational shooting activities” after “wildlife”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s501/g/1/E"},"text":"Pub. L. 116–94, § 501(g)(1)(E)","children":[],"tail":", inserted “or to recreational shooting activities” after “wildlife”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id786e6c70-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id786e6c71-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tV/s501/g/2"},"text":"Pub. L. 116–94, div. P, title V, § 501(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3193"},"text":"133 Stat. 3193","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/94/dP/tV/s501/g/2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 10 years after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"], the Secretary of the Interior, acting through the Director of the United States Fish and Wildlife Service, shall—"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and evaluate the effects of the funds made available under subparagraph (B) of section 11(a)(1) of the Pittman-Robertson Wildlife Restoration Act (","children":[{"tag":"ref","at