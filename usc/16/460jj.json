{"tag":"section","attrib":{"id":"id77e1bbfd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460jj"},"text":null,"children":[{"tag":"num","attrib":{"value":"460jj"},"text":"§ 460jj.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77e1bbfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460jj/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An area of land comprising approximately 35,235 acres located in Grand County, Colorado, within the Arapaho and the Roosevelt National Forests and the Colorado Big Thompson project (as generally depicted as the “Arapaho National Recreation Area” on a map entitled “Indian Peaks Wilderness Area and Arapaho National Recreation Area” and dated May 2007) is established as the Arapaho National Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e1bbff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460jj/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall administer the Arapaho National Recreation Area, in accordance with the laws and regulations applicable to the national forests, in such a manner as will best provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e1bc00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460jj/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public recreation and enjoyment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e1bc01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460jj/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conservation and development of the scenic, natural, historic, and pastoral values of the area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e1bc02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460jj/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management, utilization, and disposal of natural resources such as timber, grazing, and mineral resources so that their utilization will not substantially impair the purposes for which the recreation area is established; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e1bc03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460jj/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management of water quality in the recreation area consistent with the development of needed water supply and waste-water systems, including the control of aquatic vegetation in the streams, lakes, and reservoirs within the recreation area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e1bc04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460jj/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop an overall management plan for the Arapaho National Recreation Area. This plan shall be developed in consultation with State and local political subdivisions and other interested persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77e1bc05-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/450/s4"},"text":"Pub. L. 95–450, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-11"},"text":"Oct. 11, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1095"},"text":"92 Stat. 1095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tI/s1955/b"},"text":"Pub. L. 111–11, title I, § 1955(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1075"},"text":"123 Stat. 1075","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77e1bc06-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77e1bc07-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77e1bc08-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":" substituted “35,235 acres” for “thirty-six thousand two hundred thirty-five acres” and “and dated May 2007” for “, dated July 1978”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77e1bc09-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id77e1bc0a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/450/s1"},"text":"Pub. L. 95–450, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-11"},"text":"Oct. 11, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1095"},"text":"92 Stat. 1095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/450/s1"},"text":"“This Act [enacting this subchapter and enacting notes set out under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"section 1132 of this title","children":[],"tail":"] may be cited as the ‘Indian Peaks Wilderness Area, the Arapaho National Recreation Area and the Oregon Islands Wilderness Area Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77e1bc0b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Legislative Findings; Purposes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/450/s2"},"text":"Pub. L. 95–450, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-11"},"text":"Oct. 11, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1095"},"text":"92 Stat. 1095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/450/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds that it is in the national interest—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to include the land within the Arapaho and the Roosevelt National Forests known as the Indian Peaks Area in the National Wilderness Preservation System so as to protect the area’s enduring scenic and historic wilderness character and its unique wildlife and to preserve the area’s scientific, educational, recreational, and inspirational resources and challenges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create the Arapaho National Recreation Area within the Arapaho and the Roosevelt National Forests and the Colorado Big Thompson project so as to preserve and protect the natural, scenic, historic, pastoral, and wildlife resources of the area and to enhance the recreational opportunities provided.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
