{"tag":"section","attrib":{"id":"id78438aa6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551c"},"text":null,"children":[{"tag":"num","attrib":{"value":"551c"},"text":"§ 551c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning for fire protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78438aa7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteer firefighters","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries of Agriculture and the Interior shall annually offer training programs to certify volunteers for suppressing forest fires on National Forest System lands, National Park System lands and Bureau of Land Management public lands in the event that the appropriate Secretary determines that such volunteers are needed. In carrying out this subsection, the Secretaries should utilize existing authorities to train volunteer firefighters for use in fire emergencies. The Secretaries should assess the capabilities of educational institutions and other public and private organizations to provide such training programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78438aa8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Educational institutions” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, the term “educational institutions” shall include institutions established pursuant to the Act of ","children":[{"tag":"date","attrib":{"date":"1862-07-02"},"text":"July 2, 1862","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s301"},"text":"7 U.S.C. 301","children":[],"tail":" et seq., commonly known as the “Morrill Act”), or the Act of "},{"tag":"date","attrib":{"date":"1890-08-30"},"text":"August 30, 1890","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s321"},"text":"7 U.S.C. 321","children":[],"tail":" et seq., commonly known as the “Second Morrill Act”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78438aa9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mobilization of local equipment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"1990-05-09"},"text":"May 9, 1990","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78438aaa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture shall submit to the Congress information with respect to regions of the National Forest System, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78438aab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior shall submit to the Congress information with respect to the Bureau of Land Management public lands on a State-by-State basis and each region of the National Park System","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that documents mobilization plans that provide for the use of firefighting equipment in cases of fire emergencies that may occur in each such area that may be highly prone to disastrous forest fires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78438aac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presuppression needs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"1990-05-09"},"text":"May 9, 1990","children":[],"tail":", information from the Secretary of Agriculture on presuppression needs for each region of the National Forest System and information from the Secretary of the Interior on the presuppression needs for each region of the National Park System and for each State unit of the Bureau of Land Management shall be submitted to Congress. These reports shall include needs, including an estimate of the funds required, for fire prevention, fuel reduction, training and seasonal fire crews."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78438aad-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/286/tII/s203"},"text":"Pub. L. 101–286, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-09"},"text":"May 9, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/175"},"text":"104 Stat. 175","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78438aae-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78438aaf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78438ab0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1862-07-02"},"text":"July 2, 1862","children":[],"tail":", referred to in subsec. (b), is "},{"tag":"ref","attrib":{"href":"/us/act/1862-07-02/ch130"},"text":"act July 2, 1862, ch. 130","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/503"},"text":"12 Stat. 503","children":[],"tail":", popularly known as the Morrill Act and also as the First Morrill Act, which is classified generally to subchapter I (§ 301 et seq.) of chapter 13 of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s301"},"text":"section 301 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1890-08-30"},"text":"August 30, 1890","children":[],"tail":", referred to in subsec. (b), is "},{"tag":"ref","attrib":{"href":"/us/act/1890-08-30/ch841"},"text":"act Aug. 30, 1890, ch. 841","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/417"},"text":"26 Stat. 417","children":[],"tail":", popularly known as the Agricultural College Act of 1890 and also as the Second Morrill Act, which is classified generally to subchapter II (§ 321 et seq.) of chapter 13 of Title 7. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s321"},"text":"section 321 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78438ab1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78438ab2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Forest Service Large Airtanker and Aerial Asset Firefighting Recapitalization Pilot Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVIII/s8305"},"text":"Pub. L. 113–79, title VIII, § 8305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/925"},"text":"128 Stat. 925","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/79/tVIII/s8305"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the availability of appropriations, the Secretary [of Agriculture], acting through the Chief of the Forest Service, may establish a large airtanker and aerial asset lease program in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aircraft Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program described in subsection (a), the Secretary may enter into a multiyear lease contract for up to 5 aircraft that meet the criteria—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in the Forest Service document entitled ‘Large Airtanker Modernization Strategy’ and dated ","children":[{"tag":"date","attrib":{"date":"2012-02-10"},"text":"February 10, 2012","children":[],"tail":", for large airtankers; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined by the Secretary, for other aerial assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lease Terms","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term of any individual lease agreement into which the Secretary enters under this section shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" up to 5 years, inclusive of any options to renew or extend the initial lease term; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3903"},"text":"section 3903 of title 41","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No lease entered into under this section shall provide for the purchase of the aircraft by, or the transfer of ownership to, the Forest Service.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78438ab3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Forest Firefighting Planning and Cooperation; Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/286/tII/s201"},"text":"Pub. L. 101–286, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-09"},"text":"May 9, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/174"},"text":"104 Stat. 174","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/286/tII/s201"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the best interest of the Nation to take swift action to rehabilitate burned forests, and an assessment of the situation is necessary to accomplish this; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" volunteers should be trained to assist where possible.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
