{"tag":"section","attrib":{"id":"id798a153b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1881d"},"text":"§ 1881d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incidental harvest research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id798a153c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within nine months after ","children":[{"tag":"date","attrib":{"date":"1996-10-11"},"text":"October 11, 1996","children":[],"tail":", the Secretary shall, after consultation with the Gulf Council and South Atlantic Council, conclude the collection of information in the program to assess the impact on fishery resources of incidental harvest by the shrimp trawl fishery within the authority of such Councils. Within the same time period, the Secretary shall make available to the public aggregated summaries of information collected prior to "},{"tag":"date","attrib":{"date":"1994-06-30"},"text":"June 30, 1994","children":[],"tail":" under such program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798a153d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program concluded pursuant to subsection (a) shall provide for the identification of stocks of fish which are subject to significant incidental harvest in the course of normal shrimp trawl fishing activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798a153e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection and assessment of specific stock information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For stocks of fish identified pursuant to subsection (b), with priority given to stocks which (based upon the best available scientific information) are considered to be overfished, the Secretary shall conduct—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798a153f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program to collect and evaluate information on the nature and extent (including the spatial and temporal distribution) of incidental mortality of such stocks as a direct result of shrimp trawl fishing activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798a1540-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the status and condition of such stocks, including collection of information which would allow the estimation of life history parameters with sufficient accuracy and precision to support sound scientific evaluation of the effects of various management alternatives on the status of such stocks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798a1541-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program of information collection and evaluation for such stocks on the magnitude and distribution of fishing mortality and fishing effort by sources of fishing mortality other than shrimp trawl fishing activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798a1542-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bycatch reduction program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"1996-10-11"},"text":"October 11, 1996","children":[],"tail":", the Secretary shall, in cooperation with affected interests, and based upon the best scientific information available, complete a program to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id798a1543-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop technological devices and other changes in fishing operations necessary and appropriate to minimize the incidental mortality of bycatch in the course of shrimp trawl activity to the extent practicable, taking into account the level of bycatch mortality in the fishery on ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798a1544-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the ecological impacts and the benefits and costs of such devices and changes in fishing operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798a1545-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881d/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess whether it is practicable to utilize bycatch which is not avoidable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798a1546-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, within one year of completing the programs required by this section, submit a detailed report on the results of such programs to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Resources of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798a1547-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent practicable, any conservation and management measure implemented under this chapter to reduce the incidental mortality of bycatch in the course of shrimp trawl fishing shall be consistent with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798a1548-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881d/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures applicable to fishing throughout the range in United States waters of the bycatch species concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798a1549-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881d/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need to avoid any serious adverse environmental impacts on such bycatch species or the ecology of the affected area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id798a154a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265/tIV/s405"},"text":"Pub. L. 94–265, title IV, § 405","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/297/tII/s206"},"text":"Pub. L. 104–297, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3611"},"text":"110 Stat. 3611","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id798a154b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id798a154c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id798a154d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (f), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/331"},"text":"90 Stat. 331","children":[],"tail":", known as the Magnuson-Stevens Fishery Conservation and Management Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id798a154e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265/s405"},"text":"section 405 of Pub. L. 94–265","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s971"},"text":"section 971 of this title","children":[],"tail":" and enacted provisions formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s971"},"text":"section 971 of this title","children":[],"tail":", prior to being amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/104/297"},"text":"Pub. L. 104–297","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id798a154f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id798a1550-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
