{"tag":"section","attrib":{"id":"id78732694-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s670m"},"text":null,"children":[{"tag":"num","attrib":{"value":"670m"},"text":"§ 670m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian rights; State or Federal jurisdiction regulating Indian rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall enlarge or diminish or in any way affect (1) the rights of Indians or Indian tribes to the use of water or natural resources or their rights to fish, trap, or hunt wildlife as secured by statute, agreement, treaty, Executive order, or court decree; or (2) existing State or Federal jurisdiction to regulate those rights either on or off reservations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78732695-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/797/tII/s207"},"text":"Pub. L. 86–797, title II, § 207","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/452/s2"},"text":"Pub. L. 93–452, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-18"},"text":"Oct. 18, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1374"},"text":"88 Stat. 1374","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tIII/s312/b/13"},"text":"Pub. L. 112–81, div. A, title III, § 312(b)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1355"},"text":"125 Stat. 1355","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78732696-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78732697-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78732698-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" inserted section catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
