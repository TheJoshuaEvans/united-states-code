{"tag":"section","attrib":{"id":"id79dd8c77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3865a"},"text":"§ 3865a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dd8c78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural land easement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “agricultural land easement” means an easement or other interest in eligible land that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dd8c79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is conveyed for the purpose of protecting natural resources and the agricultural nature of the land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dd8c7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permits the landowner the right to continue agricultural production and related uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Buy-protect-sell transaction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dd8c7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “buy-protect-sell transaction” means a legal arrangement—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dd8c7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between an eligible entity and the Secretary relating to land that an eligible entity owns or is going to purchase prior to acquisition of an agricultural land easement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dd8c7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under which the eligible entity certifies to the Secretary that the eligible entity shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79dd8c7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"item","attrib":{"id":"id79dd8c80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/2/A/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold an agricultural land easement on that land, but transfer ownership of the land to a farmer or rancher that is not an eligible entity prior to or on acquisition of the agricultural land easement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79dd8c81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/2/A/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold an agricultural land easement on that land, but transfer ownership of the land to a farmer or rancher that is not an eligible entity in a timely manner and, subject to subparagraph (B), not later than 3 years after the date of acquisition of the agricultural land easement; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dd8c82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make an initial sale of the land subject to the agricultural land easement to a farmer or rancher at not more than agricultural value, plus any reasonable holding and transaction costs incurred by the eligible entity, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dd8c83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which the Secretary shall be reimbursed for the entirety of the Federal share of the cost of the agricultural land easement by the eligible entity if the eligible entity fails to transfer ownership under item (aa) or (bb), as applicable, of clause (ii)(I).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dd8c84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under subparagraph (A)(ii)(I)(bb), an eligible entity may transfer land later than 3 years after the date of acquisition of the agricultural land easement if the Secretary determines an extension of time is justified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dd8c86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency of State or local government or an Indian tribe (including a farmland protection board or land resource council established under State law); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dd8c87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an organization that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dd8c88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organized for, and at all times since the formation of the organization has been operated principally for, 1 or more of the conservation purposes specified in clause (i), (ii), (iii), or (iv) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s170/h/4/A"},"text":"section 170(h)(4)(A) of title 26","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dd8c89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" that is exempt from taxation under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/a"},"text":"section 501(a) of title 26","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dd8c8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" described in—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79dd8c8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/3/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (1) or (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s509/a"},"text":"section 509(a) of title 26","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dd8c8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/3/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s509/a/3"},"text":"section 509(a)(3) of title 26","children":[],"tail":" and is controlled by an organization described in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s509/a/2"},"text":"section 509(a)(2) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible land” means private or tribal land that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dd8c8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an agricultural land easement, agricultural land, including land on a farm or ranch—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dd8c8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is subject to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79dd8c90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pending offer for purchase of an agricultural land easement from an eligible entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dd8c91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a buy-protect-sell transaction;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dd8c92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79dd8c93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has prime, unique, or other productive soil;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dd8c94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that contains historical or archaeological resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dd8c95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enrollment of which would protect grazing uses and related conservation values by restoring and conserving land; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dd8c96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of which will further a State or local policy consistent with the purposes of the program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dd8c97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79dd8c98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cropland;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dd8c99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rangeland;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dd8c9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grassland or land that contains forbs, or shrubland for which grazing is the predominant use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dd8c9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/A/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located in an area that has been historically dominated by grassland, forbs, or shrubs and could provide habitat for animal or plant populations of significant ecological value;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dd8c9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/A/iii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pastureland; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dd8c9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/A/iii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonindustrial private forest land that contributes to the economic viability of an offered parcel or serves as a buffer to protect such land from development;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dd8c9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a wetland reserve easement, a wetland or related area, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dd8c9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" farmed or converted wetlands, together with adjacent land that is functionally dependent on that land, if the Secretary determines it—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79dd8ca0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is likely to be successfully restored in a cost-effective manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dd8ca1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will maximize the wildlife benefits and wetland functions and values;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dd8ca2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" cropland or grassland that was used for agricultural production prior to flooding from the natural overflow of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79dd8ca3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a closed basin lake and adjacent land that is functionally dependent upon it, if the State or other entity is willing to provide 50 percent share of the cost of an easement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dd8ca4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pothole and adjacent land that is functionally dependent on it;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dd8ca5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" farmed wetlands and adjoining lands that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79dd8ca6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are enrolled in the conservation reserve program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dd8ca7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the highest wetland functions and values, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dd8ca8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are likely to return to production after they leave the conservation reserve program;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dd8ca9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" riparian areas that link wetlands that are protected by easements or some other device that achieves the same purpose as an easement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dd8caa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other wetlands of an owner that would not otherwise be eligible, if the Secretary determines that the inclusion of such wetlands in a wetland reserve easement would significantly add to the functional value of the easement; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dd8cab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of either an agricultural land easement or a wetland reserve easement, other land that is incidental to land described in subparagraph (A) or (B), if the Secretary determines that it is necessary for the efficient administration of an easement under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8cac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “monitoring report” means a report, the contents of which are formulated and prepared by the holder of an agricultural land easement, that accurately documents whether the land subject to the agricultural land easement is in compliance with the terms and conditions of the agricultural land easement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8cad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the agricultural conservation easement program established by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8cae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wetland reserve easement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “wetland reserve easement” means a reserved interest in eligible land that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dd8caf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is defined and delineated in a deed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dd8cb0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" stipulates—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dd8cb1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rights, title, and interests in land conveyed to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dd8cb2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865a/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rights, title, and interests in land that are reserved to the landowner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79dd8cb3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1265A"},"text":"Pub. L. 99–198, title XII, § 1265A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2301/a"},"text":"Pub. L. 113–79, title II, § 2301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/732"},"text":"128 Stat. 732","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2602"},"text":"Pub. L. 115–334, title II, § 2602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4585"},"text":"132 Stat. 4585","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79dd8cb4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79dd8cb5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79dd8cb6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2602/1"},"text":"Pub. L. 115–334, § 2602(1)","children":[],"tail":", struck out “subject to an agricultural land easement plan, as approved by the Secretary” after “related uses”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2602/2"},"text":"Pub. L. 115–334, § 2602(2)","children":[],"tail":", (3), added par. (2) and redesignated former par. (2) as (3). Former par. (3) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2602/2"},"text":"Pub. L. 115–334, § 2602(2)","children":[],"tail":", redesignated par. (3) as (4). Former par. (4) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2602/4/A"},"text":"Pub. L. 115–334, § 2602(4)(A)","children":[],"tail":", inserted dash after “to”, subcl. (I) designation before “a pending”, and “or” at end, and added subcl. (II)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(B)(i)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2602/4/B"},"text":"Pub. L. 115–334, § 2602(4)(B)","children":[],"tail":", struck out “, as determined by the Secretary in consultation with the Secretary of the Interior at the local level” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2602/5"},"text":"Pub. L. 115–334, § 2602(5)","children":[],"tail":", added par. (5). Former par. (5) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2602/2"},"text":"Pub. L. 115–334, § 2602(2)","children":[],"tail":", redesignated pars. (4) and (5) as (6) and (7), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
