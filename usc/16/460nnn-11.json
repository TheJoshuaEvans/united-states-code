{"tag":"section","attrib":{"id":"id7800b59c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"460nnn–11"},"text":"§ 460nnn–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of Steens Mountain Cooperative Management and Protection Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7800b59d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate the Steens Mountain Cooperative Management and Protection Area consisting of approximately 425,550 acres of Federal land located in Harney County, Oregon, in the vicinity of Steens Mountain, as generally depicted on the map entitled “Steens Mountain Boundary Map” and dated ","children":[{"tag":"date","attrib":{"date":"2000-09-18"},"text":"September 18, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b59e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of map","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the general boundaries of the Cooperative Management and Protection Area, the map referred to in subsection (a) also depicts the general boundaries of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b59f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–11/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The no livestock grazing area described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn–23/e"},"text":"section 460nnn–23(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b5a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–11/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The mineral withdrawal area designated by part D.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b5a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–11/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The wildlands juniper management area established by part E.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7800b5a2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399/tI/s101"},"text":"Pub. L. 106–399, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1658"},"text":"114 Stat. 1658","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
