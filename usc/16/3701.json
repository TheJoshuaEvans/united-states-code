{"tag":"section","attrib":{"id":"id79c10404-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3701"},"text":null,"children":[{"tag":"num","attrib":{"value":"3701"},"text":"§ 3701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purposes of Foundation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79c10405-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the National Fish and Wildlife Foundation (hereinafter in this chapter referred to as the “Foundation”). The Foundation is a charitable and nonprofit corporation and is not an agency or establishment of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c10406-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Foundation are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c10407-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage, accept, and administer private gifts of property for the benefit of, or in connection with, the activities and services of the United States Fish and Wildlife Service and the National Oceanic and Atmospheric Administration, to further the conservation and management of fish, wildlife, plants, and other natural resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c10408-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to undertake and conduct such other activities as will further the conservation and management of the fish, wildlife, and plant resources of the United States, and its territories and possessions, for present and future generations of Americans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c10409-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3701/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to participate with, and otherwise assist, foreign governments, entities, and individuals in undertaking and conducting activities that will further the conservation and management of the fish, wildlife, and plant resources of other countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c1040a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/244/s2"},"text":"Pub. L. 98–244, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-03-26"},"text":"Mar. 26, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/107"},"text":"98 Stat. 107","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/240/s1/a"},"text":"Pub. L. 100–240, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-11"},"text":"Jan. 11, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1785"},"text":"101 Stat. 1785","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/232/tI/s102"},"text":"Pub. L. 103–232, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-11"},"text":"Apr. 11, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/336"},"text":"108 Stat. 336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/408/tII/s202"},"text":"Pub. L. 106–408, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1777"},"text":"114 Stat. 1777","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c1040b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c1040c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79c1040d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/408"},"text":"Pub. L. 106–408","children":[],"tail":" added par. (1) and struck out former par. (1) which read as follows: “to encourage, accept, and administer private gifts of property for the benefit of, or in connection with, the activities and services of the United States Fish and Wildlife Service and the National Oceanic and Atmospheric Administration;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/232"},"text":"Pub. L. 103–232","children":[],"tail":" inserted before semicolon at end “and the National Oceanic and Atmospheric Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/240"},"text":"Pub. L. 100–240","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79c1040e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79c1040f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/281/s1"},"text":"Pub. L. 110–281, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-21"},"text":"July 21, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2617"},"text":"122 Stat. 2617","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/281/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3702"},"text":"section 3702 of this title","children":[],"tail":"] may be cited as the ‘National Fish and Wildlife Foundation Establishment Act Amendment of 2008’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79c10410-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/363/tII/s201"},"text":"Pub. L. 109–363, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2075"},"text":"120 Stat. 2075","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/363/tII/s201"},"text":"“Th