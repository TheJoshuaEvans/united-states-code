":"112 Stat. 2681–50","children":[],"tail":", 2681–119, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dA/s101/b/tIX/s901"},"text":"“This title [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3703"},"text":"section 3703 of this title","children":[],"tail":" and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3703"},"text":"section 3703 of this title","children":[],"tail":"] may be cited as the ‘National Whale Conservation Fund Act of 1998’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79c10413-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/232/tI/s101"},"text":"Pub. L. 103–232, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-11"},"text":"Apr. 11, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/336"},"text":"108 Stat. 336","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/232/tI/s101"},"text":"“This title [amending this section and sections 3702 and 3709 of this title and enacting provisions listed in a table of National Environmental Centers set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s668dd"},"text":"section 668dd of this title","children":[],"tail":" and provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3702"},"text":"section 3702 of this title","children":[],"tail":"] may be cited as the ‘National Fish and Wildlife Foundation Improvement Act of 1994’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79c10414-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/593/tI/s110/a"},"text":"Pub. L. 101–593, title I, § 110(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2959"},"text":"104 Stat. 2959","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/593/tI/s110/a"},"text":"“This section [amending sections 3702 and 3709 of this title] may be cited as the ‘National Fish and Wildlife Foundation Establishment Act Amendments of 1990’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79c10415-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/244/s1"},"text":"Pub. L. 98–244, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-03-26"},"text":"Mar. 26, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/107"},"text":"98 Stat. 107","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/244/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘National Fish and Wildlife Foundation Establishment Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
