{"tag":"section","attrib":{"id":"id7a089410-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405"},"text":null,"children":[{"tag":"num","attrib":{"value":"6405"},"text":"§ 6405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coral reef stewardship partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a089411-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To further community-based stewardship of coral reefs, coral reef stewardship partnerships for Federal and non-Federal coral reefs may be established in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a089412-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall develop and adopt—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a089413-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for identifying individual coral reefs and ecologically significant units of coral reefs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a089414-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processes for adjudicating multiple applicants for stewardship of the same coral reef or ecologically significant unit of a reef to ensure no geographic overlap in representation among stewardship partnerships authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a089415-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership for Federal coral reefs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A coral reef stewardship partnership that has identified, as the subject of its stewardship activities, a coral reef or ecologically significant unit of a coral reef that is fully or partially under the management jurisdiction of any Federal agency specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6402/c"},"text":"section 6402(c) of this title","children":[],"tail":" shall, at a minimum, include the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a089416-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That Federal agency, a representative of which shall serve as chairperson of the coral reef stewardship partnership.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a089417-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State or county’s resource management agency to the extent that such partnership covers a reef within such States or county’s jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a089418-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A coral reef research center designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6411/b"},"text":"section 6411(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a089419-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nongovernmental organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a08941a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A covered Native entity culturally affiliated with the subject reef or ecologically significant unit, if any.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a08941b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other members as the partnership considers appropriate, such as interested stakeholder groups and covered Native entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a08941c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership for non-Federal coral reefs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a08941d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A coral reef stewardship partnership that has identified, as the subject of its stewardship activities, a coral reef or ecologically significant component of a coral reef that is not under the management jurisdiction of any Federal agency specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6402/c"},"text":"section 6402(c) of this title","children":[],"tail":" shall, at a minimum, include the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a08941e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State or county’s resource management agency or a covered Native entity, a representative of which shall serve as the chairperson of the coral reef stewardship partnership.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a08941f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A coral reef research center designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6411/b"},"text":"section 6411(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a089420-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nongovernmental organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a089421-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other members as the partnership considers appropriate, such as interested stakeholder groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a089422-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional members","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a089423-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), a coral reef stewardship partnership described in paragraph (1) may also include representatives of one or more Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a089424-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests; approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A representative of a Federal agency described in subparagraph (A) may become a member of a coral reef stewardship partnership described in paragraph (1) if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a089425-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the representative submits a request to become a member to the chairperson of the partnership referred to in paragraph (1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a089426-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairperson consents to the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a089427-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6405/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of Federal Advisory Committee Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act (5 U.S.C. App.) ","children":[{"tag":"ref","attrib":{"idref":"fn002823"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002823"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall not apply to coral reef stewardship partnerships under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a089428-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s206"},"text":"Pub. L. 106–562, title II, § 206","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/a"},"text":"Pub. L. 117–263, div. J, title C, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3937"},"text":"136 Stat. 3937","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a089429-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a08942a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a08942b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Pub. L. 92–463","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-06"},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/770"},"text":"86 Stat. 770","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was substantially repealed and restated in chapter 10 (§ 1001 et seq.) of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4197"},"text":"136 Stat. 4197","children":[],"tail":", 4361. For disposition of sections of the Act into chapter 10 of Title 5, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a08942c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6405, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s206"},"text":"Pub. L. 106–562, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2804"},"text":"114 Stat. 2804","children":[],"tail":", related to emergency assistance, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/a"},"text":"Pub. L. 117–263, div. J, title C, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3931"},"text":"136 Stat. 3931","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
