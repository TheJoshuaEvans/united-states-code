{"tag":"section","attrib":{"id":"id7a29fe8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7407"},"text":null,"children":[{"tag":"num","attrib":{"value":"7407"},"text":"§ 7407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a29fe90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7407/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing authorities and responsibilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29fe91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7407/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities and responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authorities and responsibilities under subsections (a), (b), and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1861"},"text":"section 1861 of this title","children":[],"tail":" and subsection (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1858"},"text":"section 1858 of this title","children":[],"tail":" and paragraphs (2), (3), and (7) of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2439/b"},"text":"section 2439(b) of this title","children":[],"tail":" shall apply with respect to enforcement of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7407/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Included vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of enforcing this chapter, any reference in such paragraphs and subsections to a “vessel” or “fishing vessel” includes all vessels as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7402/8"},"text":"section 7402(8) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7407/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of other provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such paragraphs and subsections apply to violations of this chapter and any regulations promulgated under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29fe94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7407/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29fe95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7407/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil administrative penalties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a29fe96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7407/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who is found by the Secretary (after notice and opportunity for a hearing in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s554"},"text":"section 554 of title 5","children":[],"tail":") to have committed an act prohibited under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7406"},"text":"section 7406 of this title","children":[],"tail":" shall be liable to the United States for a civil penalty. The amount of the civil penalty shall be consistent with the amount under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1858/a"},"text":"section 1858(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29fe97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7407/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compromise or other action by secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall have the same authority as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1858/e"},"text":"section 1858(e) of this title","children":[],"tail":" with respect to a violation of this chapter."},{"tag":"ref","attrib":{"idref":"fn002856"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002856"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7407/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In rem jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the conditions for in rem liability shall be consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1858/d"},"text":"section 1858(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7407/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action upon failure to pay assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person fails to pay an assessment of a civil penalty under this chapter after it has become a final and unappealable order, or after the appropriate court has entered final judgment in favor of the Secretary, the Secretary shall refer the matter to the Attorney General, who shall recover the amount assessed in any appropriate district court of the United States. In such action, the validity and appropriateness of the final order imposing the civil penalty shall not be subject to review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29fe9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7407/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29fe9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7407/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any foreign vessel (including its fishing gear, furniture, appurtenances, stores, and cargo) used, and any fish (or the fair market value thereof) imported or possessed in connection with or as ","children":[{"tag":"ref","attrib":{"idref":"fn002857"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002857"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The word “a” probably should appear."}],"tail":" result of the commission of any act prohibited by "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7406"},"text":"section 7406 of this title","children":[],"tail":" shall be subject to forfeiture under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1860"},"text":"section 1860 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7407/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of the customs laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All provisions of law relating to seizure, summary judgment, and judicial forfeiture and condemnation for violation of the customs laws, the disposition of the property forfeited or condemned or the proceeds from the sale thereof, the remission or mitigation of such forfeitures, and the compromise of claims shall apply to seizures and forfeitures incurred, or alleged to have been incurred, under the provisions of this chapter, insofar as applicable and not inconsistent with the provisions hereof. For seizures and forfeitures of property under this section by the Secretary, such duties as are imposed upon the customs officer or any other person with respect to the seizure and forfeiture of property under the customs law may be performed by such officers as are designated by the Secretary or, upon request of the Secretary, by any other agency that has authority to manage and dispose of seized property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fe9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7407/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section there is a rebuttable presumption that all fish, or components thereof, found on board a vessel that is used or seized in connection with a violation of this chapter (including any regulation promulgated under this chapter ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":") were taken, obtained, or retained as a result of IUU fishing or fishing-related activities in support of IUU fishing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29fe9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7407/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person (other than a foreign government agency, or entity wholly owned by a foreign government) who knowingly commits an act prohibited by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7406"},"text":"section 7406 of this title","children":[],"tail":" shall be subject to subsections (b) and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1859"},"text":"section 1859 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29fe9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7407/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of storage, care, and other costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person assessed a civil penalty for, or convicted of, any violation of this chapter (including any regulation promulgated under this chapter) and any claimant in a forfeiture action brought for such a violation, shall be liable for the reasonable costs incurred by the Secretary in storage, care, and maintenance of any property seized in connection with the violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a29fea0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/81/tIII/s308"},"text":"Pub. L. 114–81, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/668"},"text":"129 Stat. 668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a29fea1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a29fea2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a29fea3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(1)(B) and the second place appearing in subsec. (c)(3), was in the original “this Act” and was translated as meaning “this title” to reflect the probable intent of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
