2-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2"},"text":"section 2 of Pub. L. 116–9","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
