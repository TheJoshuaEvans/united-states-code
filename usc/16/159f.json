{"tag":"section","attrib":{"id":"id770b0a97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s159f"},"text":null,"children":[{"tag":"num","attrib":{"value":"159f"},"text":"§ 159f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enactment of revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to preserve certain lands historically associated with the Battle of Saratoga and to facilitate the administration and interpretation of the Saratoga National Historical Park (hereinafter in this Act referred to as “the park”), the boundary of the park is hereby revised to include the area generally depicted on the map entitled “Saratoga National Historical Park”, numbered 80,001, and dated ","children":[{"tag":"date","attrib":{"date":"1979-03-23"},"text":"March 23, 1979","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id770b0a98-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/460/s1"},"text":"Pub. L. 97–460, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2520"},"text":"96 Stat. 2520","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id770b0a99-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id770b0a9a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id770b0a9b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act,