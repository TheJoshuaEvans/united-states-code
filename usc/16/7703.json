{"tag":"section","attrib":{"id":"id7a2c48d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7703"},"text":null,"children":[{"tag":"num","attrib":{"value":"7703"},"text":"§ 7703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority and responsibility of the Secretary of State","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of State may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2c48d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7703/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive and transmit, on behalf of the United States, reports, requests, recommendations, proposals, decisions, and other communications of and to the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c48d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7703/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the Secretary, act upon, or refer to another appropriate authority, any communication received pursuant to paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c48d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7703/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the concurrence of the Secretary, and in accordance with the Convention, object to the decisions of the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c48d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7703/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request and utilize on a reimbursed or non-reimbursed basis the assistance, services, personnel, equipment, and facilities of other Federal departments and agencies, foreign governments or agencies, or international intergovernmental organizations, in the conduct of scientific research and other programs under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2c48d9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/tI/s103"},"text":"Pub. L. 114–327, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1979"},"text":"130 Stat. 1979","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
