{"tag":"section","attrib":{"id":"id79a4537d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2809"},"text":null,"children":[{"tag":"num","attrib":{"value":"2809"},"text":"§ 2809.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations for appropriations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of carrying out the provisions of this chapter, there are authorized to be appropriated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a4537e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2809/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Department of Agriculture, $1,000,000 for each of fiscal years 1991 through 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a4537f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2809/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Department of Commerce, $1,000,000 for each of fiscal years 1991 through 2023; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a45380-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2809/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Department of ","children":[{"tag":"ref","attrib":{"idref":"fn002734"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002734"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “of the”."}],"tail":" Interior, $1,000,000 for each of fiscal years 1991 through 2023."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Funds authorized by this section shall be in addition t