{"tag":"section","attrib":{"id":"id78863a1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718k"},"text":null,"children":[{"tag":"num","attrib":{"value":"718k"},"text":"§ 718k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of fees collected for Federal migratory bird permits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":", all fees collected for Federal migratory bird permits shall be available to the Secretary, without further appropriation, to be used for the expenses of the U.S. Fish and Wildlife Service in administering such Federal migratory bird permits, and shall remain available until expended."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78863a1b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tI"},"text":"Pub. L. 105–277, div. A, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–236.)"}],"tail":"\n"}],"tail":null}
