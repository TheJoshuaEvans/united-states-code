{"tag":"section","attrib":{"id":"id771962cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s228i–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"228i–1"},"text":"§ 228i–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to President","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Within two years from ","children":[{"tag":"date","attrib":{"date":"1975-01-03"},"text":"January 3, 1975","children":[],"tail":", the Secretary of the Interior shall report to the President, in accordance with section 1132(c) and (d) of this title, his recommendations as to the suitability or nonsuitability of any area within the national park for preservation as wilderness, and any designation of any such areas as a wilderness shall be accomplished in accordance with said section 1132(c) and (d) of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id771962cc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/620/s11"},"text":"Pub. L. 93–620, § 11","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/31"},"text":"Pub. L. 94–31","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-06-10"},"text":"June 10, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/172"},"text":"89 Stat. 172","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
