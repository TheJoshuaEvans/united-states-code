he Secretary of an election and failure to make an election."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s100101/a/3/C/ii/III"},"text":"Pub. L. 112–141, § 100101(a)(3)(C)(ii)(III)","children":[],"tail":", added subpar. (B). Former subpar. (B) redesignated subsec. (d)(1)(D)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a251c1b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a251c1c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"County Elections for Fiscal Year 2021 Under the Secure Rural Schools and Community Self-Determination Act of 2000","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/102/s1"},"text":"Pub. L. 117–102, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/48"},"text":"136 Stat. 48","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/102/s1"},"text":"“Sections 102(b)(1)(D), 102(d)(1)(F), and 102(d)(3)(D) of the Secure Rural Schools and Community Self-Determination Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7112/b/1/D"},"text":"16 U.S.C. 7112(b)(1)(D)","children":[],"tail":", 7112(d)(1)(F), 7112(d)(3)(D)) shall be applied for fiscal year 2021.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
