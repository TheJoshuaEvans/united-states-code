{"tag":"section","attrib":{"id":"id7a22d2e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112"},"text":null,"children":[{"tag":"num","attrib":{"value":"7112"},"text":"§ 7112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to States and counties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a22d2ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7113"},"text":"section 7113 of this title","children":[],"tail":", the Secretary of the Treasury shall pay to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a22d2eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a State or territory of the United States an amount equal to the sum of the amounts elected under subsection (b) by each county within the State or territory for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a22d2ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the county is eligible for the 25-percent payment, the share of the 25-percent payment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d2ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the share of the State payment of the eligible county; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d2ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a county an amount equal to the amount elected under subsection (b) by each county for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a22d2ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the county is eligible for the 50-percent payment, the 50-percent payment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d2f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the county payment for the eligible county.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a22d2f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to receive payment amount","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a22d2f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election; submission of results","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a22d2f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The election to receive a share of the State payment, the county payment, a share of the State payment and the county payment, a share of the 25-percent payment, the 50-percent payment, or a share of the 25-percent payment and the 50-percent payment, as applicable, shall be made at the discretion of each affected county by ","children":[{"tag":"date","attrib":{"date":"2013-08-01"},"text":"August 1, 2013","children":[],"tail":" (or as soon thereafter as the Secretary concerned determines is practicable), and August 1 of each second fiscal year thereafter, in accordance with paragraph (2), and transmitted to the Secretary concerned by the Governor of each eligible State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d2f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to transmit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an election for an affected county is not transmitted to the Secretary concerned by the date specified under subparagraph (A), the affected county shall be considered to have elected to receive a share of the State payment, the county payment, or a share of the State payment and the county payment, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d2f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of late payment for fiscal years 2014 and 2015","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The election otherwise required by subparagraph (A) shall not apply for fiscal year 2014 or 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d2f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for each of fiscal years 2017 through 2020","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The election otherwise required by subparagraph (A) shall not apply for each of fiscal years 2017 through 2020.","children":[{"tag":"ref","attrib":{"idref":"fn002848"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002848"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See County Elections for Fiscal Year 2021 Under the Secure Rural Schools and Community Self-Determination Act of 2000 note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d2f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for each of fiscal years 2024 and 2025","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The election otherwise required by subparagraph (A) shall not apply for each of fiscal years 2024 and 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d2f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of election","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a22d2f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A county election to receive a share of the 25-percent payment or 50-percent payment, as applicable, shall be effective for 2 fiscal years. If such two-fiscal year period included fiscal year 2013, the county election to receive a share of the 25-percent payment or 50-percent payment, as applicable, also shall be effective for fiscal years 2014 and 2015 and for each of fiscal years 2017 through 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d2fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full funding amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a county elects to receive a share of the State payment or the county payment in 2013, the election shall be effective for all subsequent fiscal years through fiscal year 2015 and for each of fiscal years 2017 through 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d2fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years 2024 and 2025","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The election described in paragraph (1)(A) applicable to a county in fiscal year 2023 shall be effective for each of fiscal years 2024 and 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d2fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of payment amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The payment to an eligible State or eligible county under this section for a fiscal year shall be derived from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a22d2fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts that are appropriated to carry out this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d2fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any revenues, fees, penalties, or miscellaneous receipts, exclusive of deposits to any relevant trust fund, special account, or permanent operating funds, received by the Federal Government from activities by the Bureau of Land Management or the Forest Service on the applicable Federal land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d2ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent of any shortfall, out of any amounts in the Treasury of the United States not otherwise appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a22d300-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution and expenditure of payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a22d301-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution method","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State that receives a payment under subsection (a) for Federal land described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7102/7/A"},"text":"section 7102(7)(A) of this title","children":[],"tail":" shall distribute the appropriate payment amount among the appropriate counties in the State in accordance with—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a22d302-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1908-05-23"},"text":"May 23, 1908","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s500"},"text":"16 U.S.C. 500","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d303-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-01/s13"},"text":"section 13 of the Act of March 1, 1911","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/36/963"},"text":"36 Stat. 963","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s500"},"text":"16 U.S.C. 500","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d304-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (d), payments received by a State under subsection (a) and distributed to counties in accordance with paragraph (1) shall be expended as required by the laws referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a22d305-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure rules for eligible counties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a22d306-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a22d307-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of portion in same manner as 25-percent payment or 50-percent payment, as applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (D), if an eligible county elects to receive its share of the State payment or the county payment, not less than 80 percent, but not more than 85 percent, of the funds shall be expended in the same manner in which the 25-percent payments or 50-percent payment, as applicable, are required to be expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d308-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election as to use of balance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (C), an eligible county shall elect to do 1 or more of the following with the balance of any funds not expended pursuant to subparagraph (A):","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a22d309-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reserve any portion of the balance for projects in accordance with subchapter II.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a22d30a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reserve any portion of the balance for projects in accordance with subchapter III.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a22d30b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Return the portion of the balance not reserved under clauses (i) and (ii) to the Treasury of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d30c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counties with major distributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of each eligible county to which $350,000 or more is distributed for any fiscal year pursuant to paragraph (1)(B) or (2)(B) of subsection (a), the eligible county shall elect to do 1 or more of the following with the balance of any funds not expended pursuant to subparagraph (A):","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a22d30d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reserve any portion of the balance for projects in accordance with subchapter II.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a22d30e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reserve not more than 7 percent of the total share for the eligible county of the State payment or the county payment for projects in accordance with subchapter III.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a22d30f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Return the portion of the balance not reserved under clauses (i) and (ii) to the Treasury of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d310-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counties with minor distributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of each eligible county to which less than $100,000 is distributed for any fiscal year pursuant to either or both of paragraphs (1)(B) and (2)(B) of subsection (a), the eligible county may elect to expend all the funds in the same manner in which the 25-percent payments or 50-percent payments, as applicable, are required to be expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d311-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of late payment for fiscal year 2014","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The election made by an eligible county under subparagraph (B), (C), or (D) for fiscal year 2013, or deemed to be made by the county under paragraph (3)(B) for that fiscal year, shall be effective for fiscal years 2014 and 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d312-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for each of fiscal years 2017 through 2020","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The election made by an eligible county under subparagraph (B), (C), or (D) for fiscal year 2013, or deemed to be made by the county under paragraph (3)(B) for that fiscal year, shall be effective for each of fiscal years 2017 through 2020.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d313-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for each of fiscal years 2024 and 2025","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The election made by an eligible county under subparagraph (B), (C), or (D) for fiscal year 2023, or deemed to be made by the county under paragraph (3)(B) for that fiscal year, shall be effective for each of fiscal years 2024 and 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d314-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a22d315-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds reserved by an eligible county under subparagraph (B)(i) or (C)(i) of paragraph (1) for carrying out projects under subchapter II shall be deposited in a special account in the Treasury of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d316-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts deposited under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a22d317-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be available for expenditure by the Secretary concerned, without further appropriation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a22d318-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available until expended in accordance with subchapter II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d319-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a22d31a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor of each eligible State shall notify the Secretary concerned of an election by an eligible county under this subsection not later than ","children":[{"tag":"date","attrib":{"date":"2012-09-30"},"text":"September 30, 2012","children":[],"tail":", and each September 30 thereafter for each succeeding fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d31b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to elect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Governor of an eligible State fails to notify the Secretary concerned of the election for an eligible county by the date specified in subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a22d31c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible county shall be considered to have elected to expend 80 percent of the funds in accordance with paragraph (1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a22d31d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remainder shall be available to the Secretary concerned to carry out projects in the eligible county to further the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7122/b"},"text":"section 7122(b) of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7123/c"},"text":"section 7123(c) of this title","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7124/a/5"},"text":"section 7124(a)(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d31e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of late payment for fiscal year 2014","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This paragraph does not apply for fiscal years 2014 and 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d31f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for each of fiscal years 2017 through 2020","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This paragraph does not apply for each of fiscal years 2017 through 2020.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d320-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for each of fiscal years 2024 and 2025","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This paragraph does not apply for each of fiscal years 2024 and 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a22d321-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The payments required under this section for a fiscal year shall be made as soon as practicable after the end of that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a22d322-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as supplemental funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a22d323-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds made available to an eligible county under this chapter may be used in lieu of, or to otherwise offset, a State funding source for a local school, facility, or educational purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d324-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7112/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of direct payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments to States made under this chapter and 25-percent payments made to States and Territories under the Acts of ","children":[{"tag":"date","attrib":{"date":"1908-05-23"},"text":"May 23, 1908","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1911-03-01"},"text":"March 1, 1911","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s500"},"text":"16 U.S.C. 500","children":[],"tail":"), shall continue to be made as direct payments and not as Federal financial assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a22d325-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/393/tI/s102"},"text":"Pub. L. 106–393, title I, § 102","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tVI/s601/a"},"text":"Pub. L. 110–343, div. C, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3896"},"text":"122 Stat. 3896","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dF/tI/s100101/a/2"},"text":"Pub. L. 112–141, div. F, title I, § 100101(a)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/905"},"text":"126 Stat. 905","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/40/s10/a/1/B"},"text":"Pub. L. 113–40, § 10(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/545"},"text":"127 Stat. 545","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/10/tV/s524/b"},"text":"Pub. L. 114–10, title V, § 524(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-04-16"},"text":"Apr. 16, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/179"},"text":"129 Stat. 179","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/tIV/s401/a/3/A"},"text":"Pub. L. 115–141, div. O, title IV, § 401(a)(3)(A)","children":[],"tail":"–(D), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","at