"attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s301/a/2/A/ii"},"text":"Pub. L. 116–94, § 301(a)(2)(A)(ii)","children":[],"tail":", substituted “for each of fiscal years 2017 through 2020” for “for fiscal years 2017 and 2018” in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s301/a/2/B/i"},"text":"Pub. L. 116–94, § 301(a)(2)(B)(i)","children":[],"tail":", substituted “for each of fiscal years 2017 through 2020” for “for fiscal years 2017 and 2018” in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s301/a/2/B/ii"},"text":"Pub. L. 116–94, § 301(a)(2)(B)(ii)","children":[],"tail":", substituted “for each of fiscal years 2017 through 2020” for “for fiscal years 2017 and 2018” in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/3/A/i"},"text":"Pub. L. 115–141, § 401(a)(3)(A)(i)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/3/A/ii"},"text":"Pub. L. 115–141, § 401(a)(3)(A)(ii)","children":[],"tail":", inserted “and for fiscal years 2017 and 2018” after “2015” in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/3/C/i"},"text":"Pub. L. 115–141, § 401(a)(3)(C)(i)","children":[],"tail":", substituted “any portion of the balance” for “not more than 7 percent of the total share for the eligible county of the State payment or the county payment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/3/C/ii"},"text":"Pub. L. 115–141, § 401(a)(3)(C)(ii)","children":[],"tail":", added subpar. (C) and struck out former subpar. (C). Prior to amendment, text read as follows: “In the case of each eligible county to which more than $100,000, but less than $350,000, is distributed for any fiscal year pursuant to either or both of paragraphs (1)(B) and (2)(B) of subsection (a), the eligible county, with respect to the balance of any funds not expended pursuant to subparagraph (A) for that fiscal year, shall—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) reserve any portion of the balance for—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(I) carrying out projects under subchapter II;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(II) carrying out projects under subchapter III; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(III) a combination of the purposes described in subclauses (I) and (II); or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) return the portion of the balance not reserved under clause (i) to the Treasury of the United States.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/3/B/i"},"text":"Pub. L. 115–141, § 401(a)(3)(B)(i)","children":[],"tail":", added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/3/B/ii/I"},"text":"Pub. L. 115–141, § 401(a)(3)(B)(ii)(I)","children":[],"tail":", substituted “purposes described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7122/b"},"text":"section 7122(b) of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7123/c"},"text":"section 7123(c) of this title","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7124/a/5"},"text":"section 7124(a)(5) of this title","children":[],"tail":"” for “purpose described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7122/b"},"text":"section 7122(b) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/3/B/ii/II"},"text":"Pub. L. 115–141, § 401(a)(3)(B)(ii)(II)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/3/D"},"text":"Pub. L. 115–141, § 401(a)(3)(D)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/10/s524/b/1"},"text":"Pub. L. 114–10, § 524(b)(1)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/10/s524/b/2/A"},"text":"Pub. L. 114–10, § 524(b)(2)(A)","children":[],"tail":", inserted at end “If such two-fiscal year period included fiscal year 2013, the county election to receive a share of the 25-percent payment or 50-percent payment, as applicable, also shall be effective for fiscal years 2014 and 2015.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/10/s524/b/2/B"},"text":"Pub. L. 114–10, § 524(b)(2)(B)","children":[],"tail":", substituted “fiscal year 2015” for “fiscal year 2013”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/10/s524/b/3/A"},"text":"Pub. L. 114–10, § 524(b)(3)(A)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/10/s524/b/3/B"},"text":"Pub. L. 114–10, § 524(b)(3)(B)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(1)(A). ","children":[