{"tag":"section","attrib":{"id":"id7931e26d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433"},"text":null,"children":[{"tag":"num","attrib":{"value":"1433"},"text":"§ 1433.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctuary designation standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7931e26e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may designate any discrete area of the marine environment as a national marine sanctuary and promulgate regulations implementing the designation if the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7931e26f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the designation will fulfill the purposes and policies of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7931e270-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the area is of special national significance due to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7931e271-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its conservation, recreational, ecological, historical, scientific, cultural, archaeological, educational, or esthetic qualities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7931e272-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the communities of living marine resources it harbors; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7931e273-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its resource or human-use values;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7931e274-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing State and Federal authorities are inadequate or should be supplemented to ensure coordinated and comprehensive conservation and management of the area, including resource protection, scientific research, and public education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7931e275-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designation of the area as a national marine sanctuary will facilitate the objectives stated in paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7931e276-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the area is of a size and nature that will permit comprehensive and coordinated conservation and management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7931e277-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors and consultations required in making determinations and findings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7931e278-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of determining if an area of the marine environment meets the standards set forth in subsection (a), the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7931e279-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the area’s natural resource and ecological qualities, including its contribution to biological productivity, maintenance of ecosystem structure, maintenance of ecologically or commercially important or threatened species or species assemblages, maintenance of critical habitat of endangered species, and the biogeographic representation of the site;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7931e27a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the area’s historical, cultural, archaeological, or paleontological significance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7931e27b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the present and potential uses of the area that depend on maintenance of the area’s resources, including commercial and recreational fishing, subsistence uses, other commercial and recreational activities, and research and education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7931e27c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the present and potential activities that may adversely affect the factors identified in subparagraphs (A), (B), and (C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7931e27d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the existing State and Federal regulatory and management authorities applicable to the area and the adequacy of those authorities to fulfill the purposes and policies of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7931e27e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manageability of the area, including such factors as its size, its ability to be identified as a discrete ecological unit with definable boundaries, its accessibility, and its suitability for monitoring and enforcement activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7931e27f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public benefits to be derived from sanctuary status, with emphasis on the benefits of long-term protection of nationally significant resources, vital habitats, and resources which generate tourism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7931e280-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the negative impacts produced by management restrictions on income-generating activities such as living and nonliving resources development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7931e281-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the socioeconomic effects of sanctuary designation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7931e282-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the area’s scientific value and value for monitoring the resources and natural processes that occur there;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7931e283-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility, where appropriate, of employing innovative management approaches to protect sanctuary resources or to manage compatible uses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7931e284-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of the area as an addition to the System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7931e285-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making determinations and findings, the Secretary shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7931e286-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Resources of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7931e287-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretaries of State, Defense, Transportation, and the Interior, the Administrator, and the heads of other interested Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7931e288-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the responsible officials or relevant agency heads of the appropriate State and local government entities, including coastal zone management agencies, that will or are likely to be affected by the establishment of the area as a national marine sanctuary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7931e289-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate officials of any Regional Fishery Management Council established by section 302 of the Magnuson-Stevens Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1852"},"text":"16 U.S.C. 1852","children":[],"tail":") that may be affected by the proposed designation; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7931e28a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1433/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other interested persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7931e28b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tIII/s303"},"text":"Pub. L. 92–532, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-23"},"text":"Oct. 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1062"},"text":"86 Stat. 1062","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/498/tI/s102"},"text":"Pub. L. 98–498, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2297"},"text":"98 Stat. 2297","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tII/s2103"},"text":"Pub. L. 102–587, title II, § 2103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5041"},"text":"106 Stat. 5041","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/513"},"text":"Pub. L. 106–513","children":[],"tail":", §§ 5, 19(a)(1), (b)(3), "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2383"},"text":"114 Stat. 2383","children":[],"tail":", 2392, 2393; "},{"tag":"ref","attrib":{"href":"/us/pl/106/555/tII/s205/a"},"text":"Pub. L. 106–555, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2769"},"text":"114 Stat. 2769","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7931e28c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7931e28d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7931e28e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/555"},"text":"Pub. L. 106–555","children":[],"tail":", in introductory provisions, substituted “the Secretary determines that—” for “the Secretary—”, added pars. (1) to (5), and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) determines that—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the designation will fulfill the purposes and policies of this chapter;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the area is of special national significance due to—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) its conservation, recreational, ecological, historical, scientific, cultural, archeological, educational, or esthetic qualities;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the communities of living marine resources it harbors; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) its resource or human-use values;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) existing State and Federal authorities are inadequate or should be supplemented to ensure coordinated and comprehensive conservation and management of the area, including resource protection, scientific research, and public education;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) designation of the area as a national marine sanctuary will facilitate the objectives in subparagraph (C); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) the area is of a size and nature that will permit comprehensive and coordinated conservation and management; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) finds that—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the area is of special national significance due to its resource or human-use values;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) existing State and Federal authorities are inadequate or should be supplemented to ensure coordinated and comprehensive conservation and management of the area, including resource protection, scientific research, and public education;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) designation of the area as a national marine sanctuary will facilitate the objectives in subparagraph (B); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) the area is of a size and nature that will permit comprehensive and coordinated conservation and management.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s5/a"},"text":"Pub. L. 106–513, § 5(a)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “determines that the designation will fulfill the purposes and policies of this chapter; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(J) to (L). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s5/b/1"},"text":"Pub. L. 106–513, § 5(b)(1)","children":[],"tail":", added subpars. (J) to (L)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s19/a/1"},"text":"Pub. L. 106–513, § 19(a)(1)","children":[],"tail":", substituted “Resources” for “Merchant Marine and Fisheries”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s19/b/3"},"text":"Pub. L. 106–513, § 19(b)(3)","children":[],"tail":", substituted “Magnuson-Stevens Act” for “Magnuson Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s5/b/2"},"text":"Pub. L. 106–513, § 5(b)(2)","children":[],"tail":", struck out heading and text of par. (3). Prior to amendment, text read as follows: “In making determinations and findings, the Secretary shall draft, as part of the environmental impact statement referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1434/a/2"},"text":"section 1434(a)(2) of this title","children":[],"tail":", a resource assessment report documenting present and potential uses of the area, including commercial and recreational fishing, research and education, minerals and energy development, subsistence uses, and other commercial, governmental, or recreational uses. The Secretary, in consultation with the Secretary of the Interior, shall draft a resource assessment section for the report regarding any commercial, governmental, or recreational resource uses in the area under consideration that are subject to the primary jurisdiction of the Department of the Interior. The Secretary, in consultation with the Secretary of Defense, the Secretary of Energy, and the Administrator, shall draft a resource assessment section for the report, including information on any past, present, or proposed future disposal or discharge of materials in the vicinity of the proposed sanctuary. Public disclosure by the Secretary of such information shall be consistent with national security regulations.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2103/a"},"text":"Pub. L. 102–587, § 2103(a)","children":[],"tail":", inserted “or should be supplemented” after “inadequate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2103/b/1"},"text":"Pub. L. 102–587, § 2103(b)(1)","children":[],"tail":", inserted “maintenance of critical habitat of endangered species,” after “assemblages,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2103/b/2"},"text":"Pub. L. 102–587, § 2103(b)(2)","children":[],"tail":", substituted “1434(a)(2)” for “1434(a)(1)”, inserted “, governmental,” after “other commercial” and after “any commercial”, and inserted at end: “The Secretary, in consultation with the Secretary of Defense, the Secretary of Energy, and the Administrator, shall draft a resource assessment section for the report, including information on any past, present, or proposed future disposal or discharge of materials in the vicinity of the proposed sanctuary. Public disclosure by the Secretary of such information shall be consistent with national security regulations.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/498"},"text":"Pub. L. 98–498","children":[],"tail":" amended section generally, substituting provisions relating to sanctuary designation standards for provisions relating to penalties. See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1437/b"},"text":"section 1437(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7931e28f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7931e290-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7931e291-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/555/tII/s205/c"},"text":"Pub. L. 106–555, title II, § 205(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2770"},"text":"114 Stat. 2770","children":[],"tail":", provided that: "},{"tag":"quotedContent","attri