{"tag":"section","attrib":{"id":"id7a0d4eb1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6501"},"text":null,"children":[{"tag":"num","attrib":{"value":"6501"},"text":"§ 6501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0d4eb2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce wildfire risk to communities, municipal water supplies, and other at-risk Federal land through a collaborative process of planning, prioritizing, and implementing hazardous fuel reduction projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4eb3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize grant programs to improve the commercial value of forest biomass (that otherwise contributes to the risk of catastrophic fire or insect or disease infestation) for producing electric energy, useful heat, transportation fuel, and petroleum-based product substitutes, and for other commercial purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4eb4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance efforts to protect watersheds and address threats to forest and rangeland health, including catastrophic wildfire, across the landscape;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4eb5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote systematic gathering of information to address the impact of insect and disease infestations and other damaging agents on forest and rangeland health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4eb6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6501/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the capacity to detect insect and disease infestations at an early stage, particularly with respect to hardwood forests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4eb7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6501/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to protect, restore, and enhance forest ecosystem components—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0d4eb8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6501/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the recovery of threatened and endangered species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0d4eb9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6501/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve biological diversity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0d4eba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6501/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance productivity and carbon sequestration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0d4ebb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/s2"},"text":"Pub. L. 108–148, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1888"},"text":"117 Stat. 1888","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0d4ebc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0d4ebd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a0d4ebe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148"},"text":"Pub. L. 108–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1887"},"text":"117 Stat. 1887","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a0d4ebf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a0d4ec0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/s1/a"},"text":"Pub. L. 108–148, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1887"},"text":"117 Stat. 1887","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/148/s1/a"},"text":"“This Act [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2103b"},"text":"section 2103b of this title","children":[],"tail":" and amending sections 6601, 8606, and 8609 of Title 7, Agriculture] may be cited as the ‘Healthy Forests Restoration Act of 2003’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a0d4ec1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wildfire Hazard Severity Mapping for Communities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/tII/s210"},"text":"Pub. L. 115–141, div. O, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1067"},"text":"132 Stat. 1067","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/141/dO/tII/s210"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Map Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after the date of the enactment of this section [","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":"], the Secretary of Agriculture, acting through the Chief of the Forest Service, shall—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop and publish a geospatial map appropriate for community-level use that depicts wildfire hazard severity to inform at-risk communities that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjacent to National Forest System lands; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affected by wildland fire, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" disseminate the information under paragraph (1) in an appropriate, web-based format for use by such communities to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve understanding of their risk profile;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clarify thinking on the nature and effect of wildfire risks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop plans to manage and mitigate those risks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes of Map","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the map required under subsection (a) are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To inform evaluations of wildfire risk.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To prioritize fuels management needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To depict the relative potential for wildfire that could be difficult for suppression resources to contain and that could cause ignitions to structures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Secretary of Agriculture and Chief of the Forest Service shall consult with—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Federal Emergency Management Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant colleges, universities, and institutions of higher education with relevant expertise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other entities, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"At-risk Community Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘at-risk community’ has the meaning given the term in section 101 of the Healthy Forests Restoration Act of 2003 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6511"},"text":"16 U.S.C. 6511","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7a0d4ec2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"id7a0d4ec3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Executive Order No. 14072","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 14072, ","children":[{"tag":"date","attrib":{"date":"2022-04-22"},"text":"Apr. 22, 2022","children":[],"tail":", 87 F.R. 24851, which related to restoring and conserving the nation’s forests, stopping international deforestation, and nature-based solutions to tackle climate change and enhance resilience, was revoked by Ex. Ord. No. 14154, § 4(a)(x), "},{"tag":"date","attrib":{"date":"2025-01-20"},"text":"Jan. 20, 2025","children":[],"tail":", 90 F.R. 8355."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
