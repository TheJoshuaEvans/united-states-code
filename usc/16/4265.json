{"tag":"section","attrib":{"id":"id79ebe448-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4265"},"text":null,"children":[{"tag":"num","attrib":{"value":"4265"},"text":"§ 4265.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance and use of donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may accept and use donations to provide assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4264"},"text":"section 4264 of this title","children":[],"tail":". Amounts received by the Secretary in the form of donations shall be transferred to the Secretary of the Treasury for deposit into the Fund."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79ebe449-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/96/s6"},"text":"Pub. L. 105–96, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-19"},"text":"Nov. 19, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2153"},"text":"111 Stat. 2153","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/141/s5/a/2"},"text":"Pub. L. 107–141, § 5(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-02-12"},"text":"Feb. 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/14"},"text":"116 Stat. 14","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79ebe44a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79ebe44b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79ebe44c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/141"},"text":"Pub. L. 107–141","children":[],"tail":" substituted “Acceptance and use of donations” for “Asian Elephant Conservation Fund” as section catchline, struck out subsecs. (a) to (c), which related to establishment, deposits into, and use of the Asian Elephant Conservation Fund, redesignated subsec. (d) as entire section and struck out subsec. heading."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
