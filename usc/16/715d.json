{"tag":"section","attrib":{"id":"id78817ee2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715d"},"text":null,"children":[{"tag":"num","attrib":{"value":"715d"},"text":"§ 715d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase or rental of approved areas or interests therein; gifts and devises; United States lands","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78817ee3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase or rent such areas or interests therein as have been approved for purchase or rental by the Commission at the price or prices fixed by the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78817ee4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, by gift or devise, any area or interests therein;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"which he determines to be suitable for use as an inviolate sanctuary, or for any other management purpose, for migratory birds. The Secretary may pay, when deemed necessary by him and from moneys authorized to be appropriated for the purposes of this subchapter (A) the purchase or rental price of any such area or interest therein, and (B) the expenses incident to the location, examination, survey, and acquisition of title (including options) of any such area or interest therein. No lands acquired, held, or used by the United States for military purposes shall be subject to any provisions of this subchapter.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78817ee5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-02-18/ch257/s5"},"text":"Feb. 18, 1929, ch. 257, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1223"},"text":"45 Stat. 1223","children":[],"tail":"; 1939 Reorg. Plan No. II, § 4(f), eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2731, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1433"},"text":"53 Stat. 1433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/616/s5/a"},"text":"Pub. L. 95–616, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-08"},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3113"},"text":"92 Stat. 3113","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78817ee6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78817ee7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78817ee8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/616"},"text":"Pub. L. 95–616","children":[],"tail":" incorporated existing provisions in pars. (1) and (2) and cls. (A) and (B), made provisions applicable to interests in approved areas, and inserted authority for purchase or acquisition for other management purposes."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id78817ee9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id78817eea-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of functions of Secretary of Agriculture to Secretary of the Interior by Reorg. Plan No. II of 1939, see Transfer of Functions note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s715a"},"text":"section 715a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
