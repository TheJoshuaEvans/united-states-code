{"tag":"section","attrib":{"id":"id780a5333-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"460yyy–1"},"text":"§ 460yyy–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the Fort Stanton-Snowy River Cave National Conservation Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id780a5334-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Fort Stanton-Snowy River Cave National Conservation Area in Lincoln County, New Mexico, to protect, conserve, and enhance the unique and nationally important historic, cultural, scientific, archaeological, natural, and educational subterranean cave resources of the Fort Stanton-Snowy River cave system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780a5335-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Conservation Area shall include the area within the boundaries depicted on the map entitled “Fort Stanton-Snowy River Cave National Conservation Area” and dated ","children":[{"tag":"date","attrib":{"date":"2008-12-15"},"text":"December 15, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780a5336-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map and legal description","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780a5337-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", the Secretary shall submit to Congress a map and legal description of the Conservation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780a5338-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description of the Conservation Area shall have the same force and effect as if included in this subchapter, except that the Secretary may correct any minor errors in the map and legal description.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780a5339-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460yyy–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description of the Conservation Area shall be available for public inspection in the appropriate offices of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id780a533a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tII/s2202"},"text":"Pub. L. 111–11, title II, § 2202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1099"},"text":"123 Stat. 1099","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
