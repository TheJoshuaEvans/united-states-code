{"tag":"section","attrib":{"id":"id77c051a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460i"},"text":null,"children":[{"tag":"num","attrib":{"value":"460i"},"text":"§ 460i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of powers; regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Army may delegate any authority conferred upon him by this subchapter to any officer or employee of the Department of the Army. Any such officer or employee shall exercise the authority so delegated under rules and regulations approved by the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77c051a5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-06/ch987/s5"},"text":"Aug. 6, 1956, ch. 987, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1066"},"text":"70 Stat. 1066","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
