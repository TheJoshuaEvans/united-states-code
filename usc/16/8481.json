{"tag":"section","attrib":{"id":"id7a3aa086-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8481"},"text":null,"children":[{"tag":"num","attrib":{"value":"8481"},"text":"§ 8481.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accessible recreation inventory","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3aa087-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8481/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary concerned shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa088-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8481/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" carry out a comprehensive assessment of outdoor recreation facilities on Federal recreational lands and waters under the jurisdiction of the respective Secretary concerned to determine the accessibility of such outdoor recreation facilities, consistent with the Architectural Barriers Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4151"},"text":"42 U.S.C. 4151","children":[],"tail":" et seq.) and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"section 794 of title 29","children":[],"tail":", including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa089-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8481/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" camp shelters, camping facilities, and camping units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa08a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8481/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" boat launch ramps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa08b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8481/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hunting, fishing, shooting, or archery ranges or locations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa08c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8481/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outdoor constructed features;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa08d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8481/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" picnic facilities and picnic units; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa08e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8481/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other outdoor recreation facilities, as determined by the Secretary concerned; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa08f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8481/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make information about such opportunities available (including through the use of prominently displayed links) on public websites of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa090-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8481/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the Federal land management agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa091-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8481/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each relevant unit and subunit of the Federal land management agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa092-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8481/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of current assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the comprehensive assessment required under subsection (a)(1), to the extent practicable, the Secretary concerned may rely on assessments completed or data gathered prior to ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa093-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8481/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 7 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary concerned shall identify opportunities to create, update, or replace signage and other publicly available information, including web page information, related to accessibility and consistent with the Architectural Barriers Act of 1968 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4151"},"text":"42 U.S.C. 4151","children":[],"tail":" et seq.) and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"section 794 of title 29","children":[],"tail":" at outdoor recreation facilities covered by the assessment required under subsection (a)(1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3aa094-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tII/s211"},"text":"Pub. L. 118–234, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2881"},"text":"138 Stat. 2881","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3aa095-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3aa096-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a3aa097-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Architectural Barriers Act of 1968, referred to in subsecs. (a)(1) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/480"},"text":"Pub. L. 90–480","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-12"},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/718"},"text":"82 Stat. 718","children":[],"tail":", which is classified generally to chapter 51 (§ 4151 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4151"},"text":"section 4151 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"Section 794 of title 29","children":[],"tail":", referred to in subsecs. (a)(1) and (c), was in the original a reference to section 504 of the Rehabilitation Act, and was translated as meaning section 504 of the Rehabilitation Act of 1973, "},{"tag":"ref","attrib":{"href":"/us/pl/93/112"},"text":"Pub. L. 93–112","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
