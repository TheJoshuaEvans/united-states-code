{"tag":"section","attrib":{"id":"id78d74056-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s943b"},"text":null,"children":[{"tag":"num","attrib":{"value":"943b"},"text":"§ 943b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78d74057-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s943b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of the Interior, acting through the Director of the United States Fish and Wildlife Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d74058-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s943b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Great Lakes fish and wildlife” means fauna, fish, and invertebrates dependent on Great Lakes resources, and located within the Great Lakes Basin.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78d74059-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tII/s204"},"text":"Pub. L. 102–440, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2233"},"text":"106 Stat. 2233","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
