{"tag":"section","attrib":{"id":"id77fbfb71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–45"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–45"},"text":"§ 460lll–45.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of personal property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fbfb72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–45/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfb73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–45/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the date of transfer pursuant to section 460","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–41 of this title, the Tennessee Valley Authority shall provide the Secretary with an inventory of all property and facilities at the Recreation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–45/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability for transfer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77fbfb75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–45/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All Tennessee Valley Authority property associated with the administration of the Recreation Area, including any property purchased with Federal funds appropriated for the management of the Tennessee Valley Authority land, shall be available for transfer to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fbfb76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–45/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Property under subparagraph (A) includes buildings, office furniture and supplies, computers, office equipment, buildings, vehicles, tools, equipment, maintenance supplies, boats, engines, and publications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–45/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of the authorized representative of the Tennessee Valley Authority, the Secretary may exclude movable property from transfer based on a showing by the Tennessee Valley Authority that the property is vital to the mission of the Tennessee Valley Authority and cannot be replaced in a cost-effective manner, if the Secretary determines that the property is not needed for management of the Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–45/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to such procedures as may be prescribed in the memorandum of agreement entered into under section 460","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–43 of this title, the Secretary shall identify and designate, in writing, all Tennessee Valley Authority property to be transferred to the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–45/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitation of transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Tennessee Valley Authority shall, to the maximum extent practicable, use current personnel to facilitate the transfer of necessary property and facilities to the Secretary, including replacement of signs and insignia, repainting of vehicles, printing of public information, and training of new personnel. Funding for these costs shall be derived from funding described in section 460","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–49 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–45/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surplus property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfb7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–45/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any personal property, including structures and facilities, that the Secretary determines cannot be efficiently managed and maintained either by the Forest Service or by lease or permit to other persons may be declared excess by the Secretary and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77fbfb7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–45/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sold by the Secretary on such terms and conditions as the Secretary may prescribe to achieve the maximum benefit to the Federal Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77fbfb7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–45/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disposed of under chapters 1 to 11 of title 40 and division C (except sections 3302, 3307(e), 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–45/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All net proceeds from the disposal of any property shall be deposited into the Fund established by section 460","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–31 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fbfb7f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s545"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 545]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–319.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77fbfb80-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77fbfb81-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77fbfb82-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (d)(1)(B), “chapters 1 to 11 of title 40 and division C (except sections 3302, 3307(e), 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41” substituted for “the Federal Property and Administrative Services Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s471"},"text":"40 U.S.C. 471","children":[],"tail":" et seq.)” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", which Act enacted Title 40, Public Buildings, Property, and Works, and "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
