{"tag":"section","attrib":{"id":"id7864ceda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h"},"text":null,"children":[{"tag":"num","attrib":{"value":"667h"},"text":"§ 667h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chronic Wasting Disease Task Force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7864cedb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7864cedc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cervid","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cervid” means any species within the family Cervidae.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7864cedd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chronic wasting disease","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “chronic wasting disease” means the animal disease afflicting deer, elk, and moose populations that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7864cede-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a transmissible disease of the nervous system resulting in distinctive lesions in the brain; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cedf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" belongs to the group of diseases known as transmissible spongiform encephalopathies, which group includes scrapie, bovine spongiform encephalopathy, and Creutzfeldt-Jakob disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7864cee0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretaries” means the Secretary of Agriculture, acting through the Administrator of the Animal and Plant Health Inspection Service, and the Secretary of the Interior, acting through the Director of the United States Geological Survey and the Director of the United States Fish and Wildlife Service, acting jointly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7864cee1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7864cee2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries shall establish within the United States Fish and Wildlife Service a task force, to be known as the “Chronic Wasting Disease Task Force” (referred to in this subsection as the “Task Force”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7864cee3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7864cee4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with foreign governments to share research, coordinate efforts, and discuss best management practices to reduce, minimize, prevent, or eliminate chronic wasting disease in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cee5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop recommendations, including recommendations based on findings of the study conducted under subsection (c), and a set of best practices regarding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7864cee6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interstate coordination of practices to prevent the new introduction of chronic wasting disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864cee7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prioritization and coordination of the future study of chronic wasting disease, based on evolving research needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864cee8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways to leverage the collective resources of Federal, State, and local agencies, Indian Tribes, and foreign governments, and resources from private, nongovernmental entities, to address chronic wasting disease in the United States and along the borders of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864cee9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other area where containment or management efforts relating to chronic wasting disease may differ across jurisdictions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864ceea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, from the recommendations developed under subparagraph (B), an action plan that gives States, the Federal Government, Indian Tribes, and the farmed cervid industry specific recommendations to ensure consistent and coordinated management and focused, prioritized research to stop the spread of and mitigate the impacts of chronic wasting disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7864ceeb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7864ceec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force shall be composed of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7864ceed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative of the United States Fish and Wildlife Service with experience in chronic wasting disease, to be appointed by the Secretary of the Interior (referred to in this subsection as the “Secretary”);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864ceee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative of the United States Geological Survey;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864ceef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 2 representatives of the Department of Agriculture with experience in chronic wasting disease, to be appointed by the Secretary of Agriculture—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7864cef0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/3/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 of whom shall have expertise in cervid health research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7864cef1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/3/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 of whom shall have expertise in wildlife management;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864cef2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of each State in which chronic wasting disease among elk, mule deer, white-tailed deer, or moose has been reported to the appropriate State agency, not more than 2 representatives, to be nominated by the Governor of the State—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7864cef3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/3/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 1 of whom shall be a representative of the State agency with jurisdiction over wildlife management or wildlife disease in the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7864cef4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/3/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a State with a farmed cervid program or economy, not more than 1 of whom shall be a representative of the State agency with jurisdiction over farmed cervid regulation in the State;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864cef5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of each State in which chronic wasting disease among elk, mule deer, white-tailed deer, or moose has not been documented, but that has carried out measures to prevent the introduction of chronic wasting disease among those species, not more than 2 representatives, to be nominated by the Governor of the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864cef6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 2 representatives from an Indian Tribe or Tribal organization chosen in a process determined, in consultation with Indian Tribes, by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864cef7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/3/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 5 nongovernmental members with relevant expertise appointed, after the date on which the members are first appointed under clauses (i) through (vi), by a majority vote of the State representatives appointed under clause (iv).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cef8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph requires a State to participate in the Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7864cef9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Co-Chairs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Co-Chairs of the Task Force shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7864cefa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal representative described in paragraph (3)(A)(i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cefb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 of the Federal representatives described in paragraph (3)(A)(iii); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cefc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 State representative appointed under paragraph (3)(A)(iv), to be selected by a majority vote of those State representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7864cefd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date of initial appointment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7864cefe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Task Force shall be appointed not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"December 23, 2024","children":[],"tail":". The efforts of the Task Force shall not be contingent on the completion of the study required by subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864ceff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On appointment of the members of the Task Force, the Co-Chairs of the Task Force shall notify the Chairs and Ranking Members of the Committees on Environment and Public Works and Agriculture, Nutrition, and Forestry of the Senate and Natural Resources and Agriculture of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7864cf00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any vacancy in the members appointed to the Task Force—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7864cf01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not affect the power or duty of the Task Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cf02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be filled not later than 30 days after the date of the vacancy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7864cf03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force shall convene—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7864cf04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less frequently than twice each year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cf05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at such time and place, and by such means, as the Co-Chairs of the Task Force determine to be appropriate, which may include the use of remote conference technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7864cf06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate action plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7864cf07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date on which the members of the Task Force are appointed, the Task Force shall submit to the Secretaries, and the heads of the State agencies with jurisdiction over wildlife disease and farmed cervid regulation of each State with a representative on the Task Force, the interstate action plan developed by the Task Force under paragraph (2)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cf08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7864cf09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretaries, any other applicable Federal agency, and each applicable State may enter into a cooperative agreement to fund necessary actions under the interstate action plan submitted under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864cf0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Target date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries shall make the best effort of the Secretaries to enter into any cooperative agreement under clause (i) not later than 180 days after the date of submission of the interstate action plan under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cf0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7864cf0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/8/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to clause (ii), for each fiscal year, the Secretaries may provide funds to carry out an interstate action plan through a cooperative agreement under subparagraph (B) in the amount of funds provided by the applicable States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864cf0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/8/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount provided by the United States Fish and Wildlife Service under clause (i) for a fiscal year shall be not greater than $5,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7864cf0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than September 30 of the first full fiscal year after the date on which the first members of the Task Force are appointed, and each September 30 thereafter, the Task Force shall submit to the Secretaries, and the heads of the State agencies with jurisdiction over wildlife disease and farmed cervid regulation of each State with a representatives on the Task Force, a report describing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7864cf0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress on the implementation of actions identified in the interstate action plan submitted under paragraph (8)(A), including the efficacy of funding under the cooperative agreement entered into under paragraph (8)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cf10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" updated resource requirements that are needed to reduce and eliminate chronic wasting disease in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cf11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any relevant updates to the recommended best management practices included in the interstate action plan submitted under paragraph (8)(B) to reduce or eliminate chronic wasting disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cf12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new research findings and emerging research needs relating to chronic wasting disease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cf13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/b/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7864cf14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chronic wasting disease transmission in cervidae resource study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7864cf15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of Academy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “Academy” means the National Academy of Sciences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7864cf16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7864cf17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries shall enter into an arrangement with the Academy under which the Academy shall conduct, and submit to the Secretaries a report describing the findings of, a special resource study to identify the predominant pathways and mechanisms of the transmission of chronic wasting disease in wild, captive, and farmed populations of cervids in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cf18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The arrangement under subparagraph (A) shall provide that the actual expenses incurred by the Academy in conducting the study under subparagraph (A) shall be paid by the Secretaries, subject to the availability of appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7864cf19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of the study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study under paragraph (2) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7864cf1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to wild, captive, and farmed populations of cervids in the United States, identify—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7864cf1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7864cf1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent possible, the pathways and mechanisms for the transmission of chronic wasting disease within live cervid populations and cervid products, which may include pathways and mechanisms for transmission from Canada;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7864cf1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the infection rates for each pathway and mechanism identified under subclause (I); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7864cf1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative frequency of transmission of each pathway and mechanism identified under subclause (I);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864cf1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7864cf20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anthropogenic and environmental factors contributing to new chronic wasting disease emergence events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7864cf21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of geographical areas with increased chronic wasting disease prevalence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7864cf22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the overall geographical patterns of chronic wasting disease distribution;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864cf23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant gaps in current scientific knowledge regarding the transmission pathways and mechanisms identified under clause (i)(I) and potential prevention, detection, and control methods identified under clause (v);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864cf24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for prioritization the scientific research projects that will address the knowledge gaps identified under clause (iii), based on the likelihood that a project will contribute significantly to the prevention or control of chronic wasting disease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864cf25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential prevention, detection, or control measures, practices, or technologies to be used to mitigate the transmission and spread of chronic wasting disease in wild, captive, and farmed populations of cervids in the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cf26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the effectiveness of the potential prevention, detection, or control measures, practices, or technologies identified under subparagraph (A)(v); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cf27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" review and compare science-based best practices, standards, and guidance regarding the prevention, detection, and management of chronic wasting disease in wild, captive, and farmed populations of cervids in the United States that have been developed by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7864cf28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Chronic Wasting Disease Herd Certification Program of the Animal and Plant Health Inspection Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864cf29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Wildlife Research Center of the Animal and Plant Health Inspection Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864cf2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Geological Survey;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864cf2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State wildlife and agricultural agencies, in the case of practices, standards, and guidance that provide practical, science-based recommendations to State and Federal agencies for minimizing or eliminating the risk of transmission of chronic wasting disease in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7864cf2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industry or academia, in the case of any published guidance on practices that provide practical, science-based recommendations to cervid producers for minimizing or eliminating the risk of transmission of chronic wasting disease within or between herds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7864cf2d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The study under paragraph (2) shall be completed not later than 180 days after the date on which funds are first made available for the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7864cf2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data sharing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries shall share with the Academy, as necessary to conduct the study under paragraph (2), subject to the avoidance of a violation of a privacy or confidentiality requirement and the protection of confidential or privileged commercial, financial, or proprietary information, data and access to databases and research information on chronic wasting disease under the jurisdiction of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7864cf2f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Animal and Plant Health Inspection Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cf30-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Geological Survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7864cf31-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date of completion of the study, the Secretaries shall submit to the Committee on Agriculture, Nutrition, and Forestry, the Committee on Energy and Natural Resources, and the Committee on Environment and Public Works of the Senate and the Committee on Agriculture and the Committee on Natural Resources of the House of Representatives a report that describes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7864cf32-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings of the study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7864cf33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any conclusions and recommendations that the Secretaries determine to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7864cf34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7864cf35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the period of fiscal years 2021 through 2030, $5,000,000 to the Secretary of the Interior, acting through the Director of the United States Fish and Wildlife Service, to carry out administrative activities under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7864cf36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2021, $1,200,000 to the Secretary of the Interior, acting through the Director of the United States Geological Survey, to carry out activities to fund research under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7864cf37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667h/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2021, $1,200,000 to the Secretary of Agriculture, acting through the Administrator of the Animal and Plant Health Inspection Service, to carry out activities to fund research under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7864cf38-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188/tI/s104"},"text":"Pub. L. 116–188, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/911"},"text":"134 Stat. 911","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/198/tI/s103"},"text":"Pub. L. 118–198, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2680"},"text":"138 Stat. 2680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7864cf39-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7864cf3a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7864cf3b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s103/1/A"},"text":"Pub. L. 118–198, § 103(1)(A)","children":[],"tail":", struck out “after the completion of the study required by subsection (c)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s103/1/B"},"text":"Pub. L. 118–198, § 103(1)(B)","children":[],"tail":", substituted “90 days after "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"December 23, 2024","children":[],"tail":". The efforts of the Task Force shall not be contingent on the completion of the study required by subsection (c)” for “180 days after the date on which the study is completed under subsection (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s103/2"},"text":"Pub. L. 118–198, § 103(2)","children":[],"tail":", substituted “2030” for “2025”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
