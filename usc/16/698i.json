{"tag":"section","attrib":{"id":"id787a527f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698i"},"text":null,"children":[{"tag":"num","attrib":{"value":"698i"},"text":"§ 698i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of Big Cypress Preserve; applicability of other laws; rules and regulations for use of lands and waters; transportation facilities; consultation and cooperation with Secretary of Transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id787a5280-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The area within the boundaries depicted on the map referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s698f"},"text":"section 698f of this title","children":[],"tail":" shall be known as the Big Cypress National Preserve. Such lands shall be administered by the Secretary as a unit of the National Park System in a manner which will assure their natural and ecological integrity in perpetuity in accordance with the provisions of sections 698f to 698m–4 of this title and with the provisions of the Act of "},{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1–4"},"text":"16 U.S.C. 1–4","children":[],"tail":"),"},{"tag":"ref","attrib":{"idref":"fn002484"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002484"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" as amended and supplemented."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787a5281-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In administering the preserve, the Secretary shall develop and publish in the Federal Register such rules and regulations as he deems necessary and appropriate to limit or control the use of Federal lands and waters with respect to:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id787a5282-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motorized vehicles,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787a5283-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exploration for and extraction of oil, gas, and other minerals,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787a5284-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grazing,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787a5285-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698i/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" draining or constructing of works or structures which alter the natural water courses,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787a5286-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698i/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agriculture,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787a5287-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698i/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hunting, fishing, and trapping,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787a5288-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698i/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new construction of any kind, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787a5289-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698i/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other uses as the Secretary determines must be limited or controlled in order to carry out the purposes of sections 698f to 698m–4 of this title: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the Secretary shall consult and cooperate with the Secretary of Transportation to assure that necessary transportation facilities shall be located within existing or reasonably expanded rights-of-way and constructed within the reserve "},{"tag":"ref","attrib":{"idref":"fn002485"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002485"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “preserve”."}],"tail":" in a manner consistent with the purposes of sections 698f to 698m–4 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id787a528a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/440/s4"},"