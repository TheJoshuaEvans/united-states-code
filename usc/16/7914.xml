<?xml version='1.0' encoding='UTF-8'?>
<section xmlns="http://xml.house.gov/schemas/uslm/1.0" style="-uslm-lc:I80" id="id7a2eba04-6992-11f1-ab3f-8b4c043f8cd5" identifier="/us/usc/t16/s7914"><num value="7914">§ 7914.</num><heading> Shooting ranges</heading><subsection style="-uslm-lc:I19" class="indent2 firstIndent-2" id="id7a2eba05-6992-11f1-ab3f-8b4c043f8cd5" identifier="/us/usc/t16/s7914/a"><num value="a" class="bold">(a)</num><heading class="bold"> In general</heading><content><p style="-uslm-lc:I11" class="indent0">Except as provided in subsection (b), the Secretary concerned may, in accordance with this section and other applicable law, lease or permit the use of Federal land for a shooting range.</p>
</content>
</subsection>
<subsection style="-uslm-lc:I19" class="indent2 firstIndent-2" id="id7a2eba06-6992-11f1-ab3f-8b4c043f8cd5" identifier="/us/usc/t16/s7914/b"><num value="b" class="bold">(b)</num><heading class="bold"> Exception</heading><chapeau style="-uslm-lc:I11" class="indent0">The Secretary concerned shall not lease or permit the use of Federal land for a shooting range within—</chapeau><paragraph style="-uslm-lc:I12" class="indent1" id="id7a2eba07-6992-11f1-ab3f-8b4c043f8cd5" identifier="/us/usc/t16/s7914/b/1"><num value="1">(1)</num><content> a component of the National Landscape Conservation System;</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="id7a2eba08-6992-11f1-ab3f-8b4c043f8cd5" identifier="/us/usc/t16/s7914/b/2"><num value="2">(2)</num><content> a component of the National Wilderness Preservation System;</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="id7a2eba09-6992-11f1-ab3f-8b4c043f8cd5" identifier="/us/usc/t16/s7914/b/3"><num value="3">(3)</num><chapeau> any area that is—</chapeau><subparagraph style="-uslm-lc:I13" class="indent2" id="id7a2eba0a-6992-11f1-ab3f-8b4c043f8cd5" identifier="/us/usc/t16/s7914/b/3/A"><num value="A">(A)</num><content> designated as a wilderness study area;</content>
</subparagraph>
<subparagraph style="-uslm-lc:I13" class="indent2" id="id7a2eba0b-6992-11f1-ab3f-8b4c043f8cd5" identifier="/us/usc/t16/s7914/b/3/B"><num value="B">(B)</num><chapeau> administratively classified as—</chapeau><clause style="-uslm-lc:I14" class="indent3" id="id7a2eba0c-6992-11f1-ab3f-8b4c043f8cd5" identifier="/us/usc/t16/s7914/b/3/B/i"><num value="i">(i)</num><content> wilderness-eligible; or</content>
</clause>
<clause style="-uslm-lc:I14" class="indent3" id="id7a2eba0d-6992-11f1-ab3f-8b4c043f8cd5" identifier="/us/usc/t16/s7914/b/3/B/ii"><num value="ii">(ii)</num><content> wilderness-suitable; or</content>
</clause>
</subparagraph>
<subparagraph style="-uslm-lc:I13" class="indent2" id="id7a2eba0e-6992-11f1-ab3f-8b4c043f8cd5" identifier="/us/usc/t16/s7914/b/3/C"><num value="C">(C)</num><content> a primitive or semiprimitive area;</content>
</subparagraph>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="id7a2eba0f-6992-11f1-ab3f-8b4c043f8cd5" identifier="/us/usc/t16/s7914/b/4"><num value="4">(4)</num><content> a national monument, national volcanic monument, or national scenic area; or</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="id7a2eba10-6992-11f1-ab3f-8b4c043f8cd5" identifier="/us/usc/t16/s7914/b/5"><num value="5">(5)</num><content> a component of the National Wild and Scenic Rivers System (including areas designated for study for potential addition to the National Wild and Scenic Rivers System).</content>
</paragraph>
</subsection>
<sourceCredit id="id7a2eba11-6992-11f1-ab3f-8b4c043f8cd5">(<ref href="/us/pl/116/9/tIV/s4104">Pub. L. 116–9, title IV, § 4104</ref>, <date date="2019-03-12">Mar. 12, 2019</date>, <ref href="/us/stat/133/759">133 Stat. 759</ref>.)</sourceCredit>
</section>
