{"tag":"section","attrib":{"id":"id78b84616-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831g"},"text":null,"children":[{"tag":"num","attrib":{"value":"831g"},"text":"§ 831g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal office of Corporation; books; directors’ oath","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78b84617-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall maintain its principal office in the immediate vicinity of Muscle Shoals, Alabama. The Corporation shall be held to be an inhabitant and resident of the northern judicial district of Alabama within the meaning of the laws of the United States relating to the venue of civil suits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b84618-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Account books","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall at all times maintain complete and accurate books of accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b84619-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oath of office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Board, before entering upon the duties of his office, shall subscribe to an oath (or affirmation) to support the Constitution of the United States and to faithfully and impartially perform the duties imposed upon him by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78b8461a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-18/ch32/s8"},"text":"May 18, 1933, ch. 32, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/63"},"text":"48 Stat. 63","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dC/tVI/s603/a/2"},"text":"Pub. L. 108–447, div. C, title VI, § 603(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2966"},"text":"118 Stat. 2966","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78b8461b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78b8461c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78b8461d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":" substituted “Board” for “board”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78b8461e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78b8461f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":" effective on the later of the date on which at least three persons nominated under "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/s604/a"},"text":"section 604(a) of Pub. L. 108–447","children":[],"tail":" take office or "},{"tag":"date","attrib":{"date":"2005-05-18"},"text":"May 18, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/s604/b"},"text":"section 604(b) of Pub. L. 108–447","children":[],"tail":", set out in an Appointments; Effective Date; Transition note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s831a"},"text":"section 831a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
