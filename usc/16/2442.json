{"tag":"section","attrib":{"id":"id799ade78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2442"},"text":null,"children":[{"tag":"num","attrib":{"value":"2442"},"text":"§ 2442.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to existing treaties and statutes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799ade79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2442/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter ","children":[{"tag":"ref","attrib":{"idref":"fn002728"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002728"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Codification note below."}],"tail":" shall be construed as contravening or superseding (1) the provisions of any international treaty, convention, or agreement, if such treaty, convention or agreement is in force with respect to the United States on "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", or (2) the provisions of any statute which implements any such treaty, convention, or agreement. Nothing in this chapter shall be construed as contravening or superseding the provisions of any statute enacted before "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", which may otherwise apply to Antarctic marine living resources."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799ade7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2442/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of more restrictive provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prevent the application of provisions of the Convention, conservation measures adopted by the Commission pursuant to article IX of the Convention, or regulations promulgated under this chapter, which are more restrictive than the provisions of, measures adopted under, or regulations promulgated under, the treaties or statutes described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799ade7b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623/tIII/s313"},"text":"Pub. L. 98–623, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3406"},"text":"98 Stat. 3406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799ade7c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799ade7d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id799ade7e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, the first time it appears in subsec. (a), was in the original “this Act” and was translated as reading “this title”, as the probable intent of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
