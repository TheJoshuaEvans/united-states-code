{"tag":"section","attrib":{"id":"id77eb321c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vv–19"},"text":null,"children":[{"tag":"num","attrib":{"value":"460vv–19"},"text":"§ 460vv–19.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acreages","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The acreage specified in this subchapter is approximate and in the event of discrepancies between cited acreage and the lands depicted on reference maps, the maps shall control.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77eb321d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/499/s21"},"text":"Pub. L. 100–499, § 21","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-18"},"text":"Oct. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2500"},"text":"102 Stat. 2500","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
