{"tag":"section","attrib":{"id":"id7741f9f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"407dd"},"text":"§ 407dd.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Directives to Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7741f9f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407dd/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independence National Historical Park and other units","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall interpret the origins, subsequent development, and effects of the United States Constitution on this country at Independence National Historical Park and at such other units of the National Park System as are closely associated with the Constitution. The Secretary shall select not less than 12 units of the National Park System for such interpretation, including Independence National Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7741f9f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407dd/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memorial","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish and maintain at Independence National Historical Park an appropriate memorial to the United States Constitution as a key document in our Nation’s history.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7741f9fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407dd/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public materials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In coordination with the National Constitution Center, the Secretary shall develop and make available to the public interpretive and educational materials related to sites within the National Park System as referred to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7741f9fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407dd/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into cooperative agreements with the owners or administrators of historic sites closely associated with the Constitution, pursuant to which the Secretary may provide technical assistance in the preservation and interpretation of such sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7741f9fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407dd/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall contract with the National Constitution Center and other qualified institutions of higher learning for research and other activities including the distribution of interpretive and educational materials as appropriate in order to carry out the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7741f9fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407dd/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of historic integrity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to alter or waive the requirement that the Secretary maintain the historic integrity of units of the National Park System, including compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s306108"},"text":"section 306108 of title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7741f9fe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/433/s5"},"text":"Pub. L. 100–433, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-16"},"text":"Sept. 16, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1641"},"text":"102 Stat. 1641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7741f9ff-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7741fa00-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7741fa01-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (f), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s306108"},"text":"section 306108 of title 54","children":[],"tail":"” substituted for “section 106 of the Historic Preservation Act ("},{"tag":"ref","attrib":{"href":"/us/stat/90/1320"},"text":"90 Stat. 1320","children":[],"tail":") as amended” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/e"},"text":"Pub. L. 113–287, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3272"},"text":"128 Stat. 3272","children":[],"tail":", which Act enacted Title 54, National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
