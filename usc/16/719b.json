{"tag":"section","attrib":{"id":"id78863a96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719b"},"text":null,"children":[{"tag":"num","attrib":{"value":"719b"},"text":"§ 719b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of gifts, devises, and bequests","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may accept and use any gift, devise, or bequest of personal property, or proceeds thereof, for the purpose of funding the activities described in section 719a(c)(1)(A) and (B) of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78863a97-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/340/s4"},"text":"Pub. L. 103–340, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3120"},"text":"108 Stat. 3120","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
