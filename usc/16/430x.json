{"tag":"section","attrib":{"id":"id77957126-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430x"},"text":null,"children":[{"tag":"num","attrib":{"value":"430x"},"text":"§ 430x.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; authorization to expand boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The sum of $100,000 is authorized to be appropriated out of any sums in the Treasury not otherwise appropriated for the purposes herein designated: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That if, after the expenditure of the funds herein authorized, the Secretary of the Interior shall determine that the acquisition of additional lands is necessary in order to perfect the symmetry of the park area or to acquire locations of historic interest adjacent to the park area already acquired upon which fortifications or entrenchments are located which are likely to deteriorate or be destroyed under private ownership, he is authorized to acquire additional lands for such purposes."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77957127-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-06-26/ch315/s5"},"text":"June 26, 1935, ch. 315, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/424"},"text":"49 Stat. 424","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-09/ch614/s1"},"text":"Aug. 9, 1939, ch. 614, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1274"},"text":"53 Stat. 1274","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77957128-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77957129-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7795712a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Herein, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-06-26/ch315"},"text":"act June 26, 1935, ch. 315","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/423"},"text":"49 Stat. 423","children":[],"tail":", which is classified to sections 430t to 430x of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7795712b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1939—Act ","children":[{"tag":"date","attrib":{"date":"1939-08-09"},"text":"Aug. 9, 1939","children":[],"tail":", inserted proviso."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7795712c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7795712d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Additional $55,000 was appropriated by section 2 of act ","children":[{"tag":"date","attrib":{"date":"1939-08-09"},"text":"Aug. 9, 1939","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
