{"tag":"section","attrib":{"id":"id778bd3e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s425e"},"text":null,"children":[{"tag":"num","attrib":{"value":"425e"},"text":"§ 425e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance and distribution of gifts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The commission, acting through the Secretary of the Interior, is authorized to receive gifts and contributions from States, Territories, societies, organizations, and individuals for the said Fredericksburg and Spotsylvania County Battle Fields Memorial: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That all contributions of money received shall be deposited in the Treasury of the United States and credited to a fund to be designated “Fredericksburg and Spotsylvania County Battle Fields Memorial fund”, which fund shall be applied to and expended under the direction of the Secretary of the Interior for carrying out the provisions of sections 425 to 425j of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778bd3e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-02-14/ch127/s6"},"text":"Feb. 14, 1927, ch. 127, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1093"},"text":"44 Stat. 1093","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778bd3e8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id778bd3e9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id778bd3ea-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of administrative functions of park, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s425"},"text":"section 425 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
