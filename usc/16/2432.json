{"tag":"section","attrib":{"id":"id799addf5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432"},"text":null,"children":[{"tag":"num","attrib":{"value":"2432"},"text":"§ 2432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799addf6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antarctic Convergence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Antarctic Convergence” means a line joining the following points along the parallels of latitude and meridians of longitude: 50 degrees south, 0 degrees; 50 degrees south, 30 degrees east; 45 degrees south, 30 degrees east; 45 degrees south, 80 degrees east; 55 degrees south, 80 degrees east; 55 degrees south, 150 degrees east; 60 degrees south, 150 degrees east; 60 degrees south; ","children":[{"tag":"ref","attrib":{"idref":"fn002724"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002724"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be a comma."}],"tail":" 50 degrees west; 50 degrees south, 50 degrees west; and 50 degrees south, 0 degrees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799addf7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antarctic marine living resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Antarctic marine living resources” means the population of finfish, molluscs, crustaceans and all other species of living organisms, including birds, found south of the Antarctic Convergence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799addf8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Commission for the Conservation of Antarctic Marine Living Resources established pursuant to article VII of the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799addf9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Convention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Convention” means the Convention on the Conservation of Antarctic Marine Living Resources, done at Canberra, Australia, ","children":[{"tag":"date","attrib":{"date":"1980-05-07"},"text":"May 7, 1980","children":[],"tail":", and entered into force with respect to the United States on "},{"tag":"date","attrib":{"date":"1982-04-07"},"text":"April 7, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799addfa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harvesting or other associated activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms “harvesting” and “harvesting or other associated activities” mean—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799addfb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the harassing, molesting, harming, pursuing, hunting, shooting, wounding, killing, trapping, or capturing of Antarctic marine living resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799addfc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attempting to engage in any activity set forth in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799addfd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activity which can reasonably be expected to result in any activity described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799addfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any operations at sea in support of, or in preparation for, any activity described in subparagraphs (A) through (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799addff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harvest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “harvest” means to engage in harvesting or other associated activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799ade00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Import","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “import” means to land on, bring into, or introduce into, or attempt to land on, bring into, or introduce into, any place subject to the jurisdiction of the United States, whether or not such landing constitutes an importation within the meaning of the customs laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799ade01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means an individual, partnership, corporation, trust, association, and any other entity subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799ade02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Scientific Committee” means the Scientific Committee for the Conservation of Antarctic Marine Living Resources established pursuant to article XIV of the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799ade03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessel of the United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “vessel of the United States” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799ade04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel documented under chapter 121 of title 46 or a vessel numbered as provided in chapter 123 of that title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799ade05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a vessel owned in whole or in part by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id799ade06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/10/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States or a territory, commonwealth, or possession of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id799ade07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/10/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or political subdivision thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id799ade08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/10/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a citizen or national of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id799ade09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/10/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation created under the laws of the United States or any State, the District of Columbia, or any territory, commonwealth, or possession of the United States;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless the vessel has been granted the nationality of a foreign nation in accordance with Article 5 of the 1958 Convention on the High Seas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799ade0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel that was once documented under the laws of the United States and, in violation of the laws of the United States, was either sold to a person not a citizen of the United States or placed under foreign registry or a foreign flag, whether or not the vessel has been granted the nationality of a foreign nation in accordance with Article 5 of the 1958 Convention on the High Seas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799ade0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2432/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessel subject to the jurisdiction of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “vessel subject to the jurisdiction of the United States” includes a vessel without nationality or a vessel assimilated to a vessel without nationality, in accordance with paragraph (2) of Article 6 of the 1958 Convention on the High Seas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799ade0c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623/tIII/s303"},"text":"Pub. L. 98–623, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3398"},"text":"98 Stat. 3398","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
