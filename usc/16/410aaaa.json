{"tag":"section","attrib":{"id":"id777fec83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaaa"},"text":"§ 410aaaa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fort Sumter and Fort Moultrie National Historical Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id777fec84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777fec85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “map” means the map entitled “Boundary Map, Fort Sumter and Fort Moultrie National Historical Park”, numbered 392/80,088, and dated August 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fec86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Park” means the Fort Sumter and Fort Moultrie National Historical Park established by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fec87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the State of South Carolina.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fec88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sullivan’s island life saving station historic district","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Sullivan’s Island Life Saving Station Historic District” means the Charleston Lighthouse, the boathouse, garage, bunker/sighting station, signal tower, and any associated land and improvements to the land that are located between Sullivan’s Island Life Saving Station and the mean low water mark.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777fec89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Fort Sumter and Fort Moultrie National Historical Park in the State as a single unit of the National Park System to preserve, maintain, and interpret the nationally significant historical values and cultural resources associated with Fort Sumter National Monument, Fort Moultrie National Monument, and the Sullivan’s Island Life Saving Station Historic District.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777fec8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The boundary of the Park shall be as generally depicted on the map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777fec8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777fec8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777fec8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director of the National Park Service, shall administer the Park in accordance with this section and the laws generally applicable to units of the National Park System, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777fec8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 100101(a), chapter 1003, and sections 100751(a), 100752, 100753, and 102101 of title 54; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fec8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 3201 of title 54.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fec90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpretation of historical events","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide for the interpretation of historical events and activities that occurred in the vicinity of Fort Sumter and Fort Moultrie, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777fec91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Battle of Sullivan’s Island on ","children":[{"tag":"date","attrib":{"date":"1776-06-28"},"text":"June 28, 1776","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fec92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Siege of Charleston during 1780;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fec93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Civil War, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777fec94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bombardment of Fort Sumter by Confederate forces on ","children":[{"tag":"date","attrib":{"date":"1861-04-12"},"text":"April 12, 1861","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777fec95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other events of the Civil War that are associated with Fort Sumter and Fort Moultrie;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fec96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the development of the coastal defense system of the United States during the period from the Revolutionary War to World War II, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777fec97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Sullivan’s Island Life Saving Station;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777fec98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lighthouse associated with the Sullivan’s Island Life Saving Station; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777fec99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coastal defense sites constructed during the period of fortification construction from 1898 to 1942, known as the “Endicott Period”; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fec9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lives of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777fec9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the free and enslaved workers who built and maintained Fort Sumter and Fort Moultrie;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777fec9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the soldiers who defended the forts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777fec9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prisoners held at the forts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777fec9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/e/2/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" captive Africans bound for slavery who, after first landing in the United States, were brought to quarantine houses in the vicinity of Fort Moultrie in the 18th century, if the Secretary determines that the quarantine houses and associated historical values are nationally significant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777fec9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaaa/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into cooperative agreements with public and private entities and individuals to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777feca0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2203"},"text":"Pub. L. 116–9, title II, § 2203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/734"},"text":"133 Stat. 734","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777feca1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777feca2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id777feca3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2203"},"text":"section 2203 of Pub. L. 116–9","children":[],"tail":". Subsec. (g) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2203"},"text":"section 2203 of Pub. L. 116–9","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s450ee–1"},"text":"section 450ee–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id777feca4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id777feca5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2"},"text":"section 2 of Pub. L. 116–9","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
