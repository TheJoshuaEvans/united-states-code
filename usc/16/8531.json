{"tag":"section","attrib":{"id":"id7a3d1162-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8531"},"text":null,"children":[{"tag":"num","attrib":{"value":"8531"},"text":"§ 8531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3d1163-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8531/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial use authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commercial use authorization” means a commercial use authorization to provide services to visitors to units of the National Park System under subchapter II of chapter 1019 of title 54.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d1164-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8531/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multijurisdictional trip","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “multijurisdictional trip” means a trip that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3d1165-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8531/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses 2 or more units of Federal recreational lands and waters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3d1166-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8531/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is under the jurisdiction of 2 or more Federal land management agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d1167-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8531/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreation service provider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “recreation service provider” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6801"},"text":"section 6801 of this title","children":[],"tail":" (as amended by section 311)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d1168-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8531/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special recreation permit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “special recreation permit” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6801"},"text":"section 6801 of this title","children":[],"tail":" (as amended by section 311)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d1169-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8531/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visitor-use day","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “visitor-use day” means a visitor-use day, user day, launch, or other metric used by the Secretary concerned for p