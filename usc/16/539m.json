{"tag":"section","attrib":{"id":"id783051d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m"},"text":null,"children":[{"tag":"num","attrib":{"value":"539m"},"text":"§ 539m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id783051d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id783051d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in 1748, the Pueblo of Sandia received a grant from a representative of the King of Spain, which grant was recognized and confirmed by Congress in 1858 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/11/374"},"text":"11 Stat. 374","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783051d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in 1994, the Pueblo filed a civil action against the Secretary of the Interior and the Secretary of Agriculture in the United States District Court for the District of Columbia (Civil No. 1:94CV02624), asserting that Federal surveys of the grant boundaries erroneously excluded certain land within the Cibola National Forest, including a portion of the Sandia Mountain Wilderness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id783051d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of sections 539m to 539m–12 of this title are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id783051da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish the T’uf Shur Bien Preservation Trust Area in the Cibola National Forest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783051db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to confirm the status of national forest land and wilderness land in the Area while resolving issues associated with the civil action referred to in subsection (a)(2) and the opinions of the Solicitor of the Department of the Interior dated ","children":[{"tag":"date","attrib":{"date":"1988-12-09"},"text":"December 9, 1988","children":[],"tail":" (M–36963; 96 I.D. 331) and "},{"tag":"date","attrib":{"date":"2001-01-19"},"text":"January 19, 2001","children":[],"tail":" (M–37002); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783051dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide the Pueblo, the parties to the civil action, and the public with a fair and just settlement of the Pueblo’s claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id783051dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tIV/s402"},"text":"Pub. L. 108–7, div. F, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/279"},"text":"117 Stat. 279","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id783051de-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id783051df-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id783051e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 539m to 539m–12 of this title, referred to in subsec. (b), was in the original “this title”, meaning title IV of div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/279"},"text":"117 Stat. 279","children":[],"tail":", which is classified generally to sections 539m to 539m–12 of this title. For complete classification of title IV to the Code, see Short Title note set out below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7832c1e1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7832c1e2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tIV/s415"},"text":"Pub. L. 108–7, div. F, title IV, § 415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/294"},"text":"117 Stat. 294","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/7/dF/tIV/s415"},"text":"“The provisions of this title [see Short Title note below] shall take effect immediately on enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7832c1e3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/119/s1"},"text":"Pub. L. 113–119, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-09"},"text":"June 9, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1185"},"text":"128 Stat. 1185","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/119/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–11"},"text":"section 539m–11 of this title","children":[],"tail":"] may be cited as the ‘Sandia Pueblo Settlement Technical Amendment Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7832c1e4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tIV/s401"},"text":"Pub. L. 108–7, div. F, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/279"},"text":"117 Stat. 279","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/7/dF/tIV/s401"},"text":"“This title [enacting this section and sections 539m–1 to 539m–12 of this title, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1746"},"text":"section 1746 of Title 43","children":[],"tail":", Public Lands, and enacting provisions set out as a note above] may be cited as the ‘T’uf Shur Bien Preservation Trust Area Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
