{"tag":"section","attrib":{"id":"id78ecc339-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1158"},"text":null,"children":[{"tag":"num","attrib":{"value":"1158"},"text":"§ 1158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance or rejection by Secretaries of State and Commerce of Commission recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State, with the concurrence of the Secretary, is authorized to accept or reject, on behalf of the United States, recommendations made by the Commission pursuant to article V of the Convention.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78ecc33a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/702/tI/s108"},"text":"Pub. L. 89–702, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1093"},"text":"80 Stat. 1093","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/129/s2"},"text":"Pub. L. 98–129, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-10-14"},"text":"Oct. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/838"},"text":"97 Stat. 838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78ecc33b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78ecc33c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78ecc33d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/129"},"text":"Pub. L. 98–129","children":[],"tail":" amended section generally, substituting provisions empowering the Secretaries of State and Commerce to accept or reject recommendations made by the Commission, which were previously contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1157"},"text":"section 1157 of this title","children":[],"tail":", for provisions authorizing Federal agency consultation with and technical assistance to the Secretary of Commerce or the Commission. See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1159"},"text":"section 1159 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
