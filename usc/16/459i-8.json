{"tag":"section","attrib":{"id":"id77b925e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459i–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"459i–8"},"text":"§ 459i–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to President","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Within three years from ","children":[{"tag":"date","attrib":{"date":"1972-10-23"},"text":"October 23, 1972","children":[],"tail":", the Secretary of the Interior shall report to the President, in accordance with section 1132(c) and (d) of this title, his recommendations as to the suitability or nonsuitability of any area within the national seashore for preservation as wilderness, and any designation of any such area as a wilderness shall be accomplished in accordance with said section 1132(c) and (d) of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77b925e5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/536/s9"},"text":"Pub. L. 92–536, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-23"},"text":"Oct. 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1068"},"text":"86 Stat. 1068","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
