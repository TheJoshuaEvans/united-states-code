{"tag":"section","attrib":{"id":"id7a01684f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5722"},"text":null,"children":[{"tag":"num","attrib":{"value":"5722"},"text":"§ 5722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a016850-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor of Alaska may establish and appoint an advisory committee of not less than eight, but not more than 12, individuals who are knowledgeable and experienced with regard to the salmon fisheries on the Yukon River. At least two of the advisory committee members shall be Alaska Natives. Members of the advisory committee may attend all meetings of the Panel, and shall be given the opportunity to examine and be heard on any matter under consideration by the Panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016851-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of such advisory committee shall receive no compensation for their services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016852-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5722/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term length","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of such advisory committee shall serve 2-year terms. Any individual appointed to fill a vacancy occurring before the expiration of any term shall be appointed for the remainder of that term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016853-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5722/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of such advisory committee shall be eligible for reappointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a016854-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/450/tII/s203"},"text":"Pub. L. 106–450, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1943"},"text":"114 Stat. 1943","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
