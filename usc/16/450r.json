{"tag":"section","attrib":{"id":"id779ee775-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450r"},"text":null,"children":[{"tag":"num","attrib":{"value":"450r"},"text":"§ 450r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ackia Battleground National Monument; establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized in his discretion to acquire, by purchase or by condemnation and/or accept by donation in behalf of the United States, such lands, easements, and buildings not to exceed fifty acres, and when title satisfactory to the Secretary of the Interior shall have been vested in the United States such area or areas shall be, upon proclamation of the President, established, dedicated, and set apart as a public monument for the benefit and enjoyment of the people and shall be known as the “Ackia Battleground National Monument”: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That such area shall include the site of the Battle of Ackia."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id779ee776-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-27/ch755/s2"},"text":"Aug. 27, 1935, ch. 755, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/897"},"text":"49 Stat. 897","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id779ee777-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id779ee778-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id779ee779-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inclusion in Natchez Trace Parkway","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Ackia Battleground National Monument included in the Natchez Trace Parkway, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460–1"},"text":"section 460–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id779ee77a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id779ee77b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Boundaries of Monument","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Boundaries established by Presidential Proc. No. 2307, ","children":[{"tag":"date","attrib":{"date":"1938-10-25"},"text":"Oct. 25, 1938","children":[],"tail":", 3 F.R. 2579, "},{"tag":"ref","attrib":{"href":"/us/stat/53/2494"},"text":"53 Stat. 2494","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
