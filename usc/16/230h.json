{"tag":"section","attrib":{"id":"id771bd437-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230h"},"text":null,"children":[{"tag":"num","attrib":{"value":"230h"},"text":"§ 230h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change in name of Chalmette National Historical Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The area described in the Act of ","children":[{"tag":"date","attrib":{"date":"1962-10-09"},"text":"October 9, 1962","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/76/755"},"text":"76 Stat. 755","children":[],"tail":"), as the “Chalmette National Historical Park” is hereby redesignated as the Chalmette Unit of the Jean Lafitte National Historical Park and Preserve. Any references to the Chalmette National Historical Park shall be deemed to be references to said Chalmette Unit."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id771bd438-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/tIX/s909"},"text":"Pub. L. 95–625, title IX, § 909","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3538"},"text":"92 Stat. 3538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7105/f/2/B"},"text":"Pub. L. 111–11, title VII, § 7105(f)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1193"},"text":"123 Stat. 1193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id771bd439-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id771bd43a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","att