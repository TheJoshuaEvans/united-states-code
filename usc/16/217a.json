{"tag":"section","attrib":{"id":"id7714a851-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s217a"},"text":null,"children":[{"tag":"num","attrib":{"value":"217a"},"text":"§ 217a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change in name of Abraham Lincoln National Historical Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Abraham Lincoln National Historical Park at Hodgenville, Kentucky, shall on and after ","children":[{"tag":"date","attrib":{"date":"1959-09-08"},"text":"September 8, 1959","children":[],"tail":", be known as Abraham Lincoln Birthplace National Historic Site, and any law, regulation, document, or record of the United States in which such historical park is designated or referred to under the name of Abraham Lincoln National Historic Park shall be held to refer to such historical park under and by the name of Abraham Lincoln Birthplace National Historic Site."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7714a852-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/231"},"text":"Pub. L. 86–231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-08"},"text":"Sept. 8, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/466"},"text":"73 Stat. 466","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7714a853-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7714a854-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7714a855-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Abraham Lincoln Birthplace National Historic Site was renamed Abraham Lincoln Birthplace National Historical Park by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7114/a"},"text":"Pub. L. 111–11, title VII, § 7114(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1202"},"text":"123 Stat. 1202","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
