{"tag":"section","attrib":{"id":"id776cda26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbb–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410bbb–3"},"text":"§ 410bbb–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id776cda27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbb–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire lands and interests therein within the sites designated pursuant to section 410bbb–1(b)(1) and (3) of this title by donation or purchase with donated or appropriated funds or long term lease: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That sites designated pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410bbb–1/b/3"},"text":"section 410bbb–1(b)(3) of this title","children":[],"tail":" shall only be acquired with the consent of the owner thereof."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776cda28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbb–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local properties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Lands and interests in lands which are owned by the State of Louisiana, or any political subdivision thereof, may be acquired only by donation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id776cda29-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tXII/s1205"},"text":"Pub. L. 103–433, title XII, § 1205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4522"},"text":"108 Stat. 4522","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
