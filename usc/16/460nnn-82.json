{"tag":"section","attrib":{"id":"id7800b67d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–82"},"text":null,"children":[{"tag":"num","attrib":{"value":"460nnn–82"},"text":"§ 460nnn–82.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of State lands and mineral interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7800b67e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–82/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall acquire, for approximately equal value and as agreed to by the Secretary and the State of Oregon, lands and interests in lands owned by the State within the boundaries of the mineral withdrawal area designated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn–81"},"text":"section 460nnn–81 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b67f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–82/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition methods","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall acquire such State lands and interests in lands in exchange for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b680-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–82/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal lands or Federal mineral interests that are outside the boundaries of the mineral withdrawal area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b681-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–82/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a monetary payment to the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b682-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–82/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a combination of a conveyance under paragraph (1) and a monetary payment under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7800b683-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399/tIV/s402"},"text":"Pub. L. 106–399, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1669"},"text":"114 Stat. 1669","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
