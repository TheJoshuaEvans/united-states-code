{"tag":"section","attrib":{"id":"id788fd68a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s756"},"text":null,"children":[{"tag":"num","attrib":{"value":"756"},"text":"§ 756.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations, surveys, and experiments; construction and installation of conservation devices, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce is further authorized and directed (1) to conduct such investigations, and such engineering and biological surveys and experiments, as may be necessary to direct and facilitate conservation of the fishery resources of the Columbia River and its tributaries; (2) to construct and install devices in the Columbia River Basin for the improvement of feeding and spawning conditions for fish, for the protection of migratory fish from irrigation projects, and for facilitating free migration of fish over obstructions; and (3) to perform all other activities necessary for the conservation of fish in the Columbia River Basin in accordance with law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788fd68b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-05-11/ch193/s2"},"text":"May 11, 1938, ch. 193, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/345"},"text":"52 Stat. 345","children":[],"tail":"; 1939 Reorg. Plan No. II, § 4(e), eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2731, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1433"},"text":"53 Stat. 1433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-08/ch883/s1"},"text":"Aug. 8, 1946, ch. 883, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/932"},"text":"60 Stat. 932","children":[],"tail":"; 1970 Reorg. Plan No. 4, eff. "},{"tag":"date","attrib":{"date":"1970-10-03"},"text":"Oct. 3, 1970","children":[],"tail":", 35 F.R. 15627, "},{"tag":"ref","attrib":{"href":"/us/stat/84/2090"},"text":"84 Stat. 2090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788fd68c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788fd68d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id788fd68e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1946—Act ","children":[{"tag":"date","attrib":{"date":"1946-08-08"},"text":"Aug. 8, 1946","children":[],"tail":", struck out requirement to maintain conservation devices, etc."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id788fd68f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id788fd690-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of functions to Secretary of Commerce from Secretary of the Interior and prior transfers, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s755"},"text":"section 755 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
