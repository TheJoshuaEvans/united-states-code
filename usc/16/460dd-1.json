{"tag":"section","attrib":{"id":"id77da8f93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dd–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"460dd–1"},"text":"§ 460dd–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77da8f94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dd–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary; donation or exchange of State lands; concurrence of tribal council respecting trust lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within the boundaries of the recreation area, the Secretary may acquire lands and interests in lands by donation, purchase, or exchange. Any lands owned by the States of Utah or Arizona, or any State, political subdivisions thereof, may be acquired only by donation or exchange. No lands held in trust for any Indian tribe may be acquired except with the concurrence of the tribal council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77da8f95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dd–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Navajo Indian Tribe and Tribal Council reserved mineral and land use rights unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to affect the mineral rights reserved to the Navajo Indian Tribe under ","children":[{"tag":"ref","attrib":{"href":"/us/act/1958-09-02/s2"},"text":"section 2 of the Act of September 2, 1958","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/72/1686"},"text":"72 Stat. 1686","children":[],"tail":"), or the rights reserved to the Navajo Indian Tribal Council in said section 2 with respect to the use of the lands there described under the heading “"},{"tag":"inline","attrib":{},"text":"Parcel B","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77da8f96-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/593/s2"},"text":"Pub. L. 92–593, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1311"},"text":"86 Stat. 1311","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77da8f97-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77da8f98-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77da8f99-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1958-09-02"},"text":"September 2, 1958","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/72/1686"},"text":"72 Stat. 1686","children":[],"tail":"), referred to in subsec. (b), provided for exchange of lands between United States and Navajo Tribe and for other purposes, and was not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
