{"tag":"section","attrib":{"id":"id770b0ace-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160b"},"text":null,"children":[{"tag":"num","attrib":{"value":"160b"},"text":"§ 160b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id770b0acf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id770b0ad0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire lands or interests therein within the boundaries of the park by donation, purchase with donated or appropriated funds, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id770b0ad1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain portions of tracts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id770b0ad2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which only a portion of a tract of land is within the boundaries of the park, the Secretary may acquire all or any portion of the land outside of such boundaries in order to minimize the payment of severance costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id770b0ad3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id770b0ad4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160b/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any land acquired pursuant to subparagraph (A) outside of the park boundaries may be exchanged by the Secretary for non-Federal lands within the park boundaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id770b0ad5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160b/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portions not exchanged","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any portion of land acquired outside the park boundaries and not utilized for exchange shall be reported to the General Services Administration for disposal under chapters 1 to 11 of title 40 and division C (except sections 3302, 3307(e), 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id770b0ad6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of Federal property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Federal property located within the boundaries of the park may be transferred without consideration to the administrative jurisdiction of the Secretary for the purposes of the park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id770b0ad7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160b/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative jurisdiction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective beginning on ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", there is transferred to the National Park Service administrative jurisdiction over—"}],"tail":null},{"tag":"clause","attrib":{"id":"id770b0ad8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160b/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any land managed by the Bureau of Land Management within the boundaries of the park, as depicted on the map described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s160a–1/a"},"text":"section 160a–1(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id770b0ad9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160b/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional public land identified by the Bureau of Land Management as appropriate for transfer within the boundaries of the park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id770b0ada-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160b/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land owned by State","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id770b0adb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160b/a/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations and exchanges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any land located within or adjacent to the boundaries of the park that is owned by the State of Minnesota (or a political subdivision of the State) may be acquired by the Secretary only through donation or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id770b0adc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160b/a/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On completion of an acquisition from the State under clause (i), the Secretary shall revise the boundaries of the park to reflect the acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id770b0add-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offers by individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In exercising the authority to acquire property under this section, the Secretary shall give immediate and careful consideration to any offer made by any individual owning property within the park area to sell such property to the Secretary. In considering such offer, the Secretary shall take into consideration any hardship to the owner which might result from any undue delay in acquiring his property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id770b0ade-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/661/s201"},"text":"Pub. L. 91–661, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1970"},"text":"84 Stat. 1970","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2107/b"},"text":"Pub. L. 116–9, title II, § 2107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/727"},"text":"133 Stat. 727","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id770b0adf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id770b0ae0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id770b0ae1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “chapters 1 to 11 of title 40 and division C (except sections 3302, 3307(e), 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41” substituted for “the Federal Property and Administrative Services Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/63/377"},"text":"63 Stat. 377","children":[],"tail":"), as amended” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", which Act enacted Title 40, Public Buildings, Property, and Works, and "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id770b0ae2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2107/b/1"},"text":"Pub. L. 116–9, § 2107(b)(1)","children":[],"tail":", inserted section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2107/b/1"},"text":"Pub. L. 116–9, § 2107(b)(1)","children":[],"tail":", (2), inserted subsec. heading and in six sentences of existing provisions: designated first sentence as par. (1) and inserted heading; designated second to fifth sentences collectively as par. (2) and individually as subpars. (A), (B)(i), (B)(ii), and (C) of par. (2), respectively, and inserted par., subpar., and cl. headings; and struck out sixth sentence which read as follows: “Lands within the boundaries of the park owned by the State of Minnesota, or any political subdivision thereof, may be acquired only by donation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2107/b/2/A"},"text":"Pub. L. 116–9, § 2107(b)(2)(A)","children":[],"tail":", substituted “In any case in which only a portion of a tract of land is within the boundaries of the park” for “When any tract of land is only partly within such boundaries”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2107/b/2/B"},"text":"Pub. L. 116–9, § 2107(b)(2)(B)","children":[],"tail":", substituted “Any land acquired pursuant to subparagraph (A)” for “Land so acquired”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2107/b/2/E"},"text":"Pub. L. 116–9, § 2107(b)(2)(E)","children":[],"tail":", added subpars. (D) and (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2107/b/3"},"text":"Pub. L. 116–9, § 2107(b)(3)","children":[],"tail":", inserted heading and substituted “the authority” for “his authority”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
