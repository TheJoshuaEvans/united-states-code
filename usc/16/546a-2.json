{"tag":"section","attrib":{"id":"id78411a3b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546a–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"546a–2"},"text":"§ 546a–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish and game","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in sections 546 to 546a–5 of this title shall be construed as affecting the jurisdiction or responsibilities of the State of Michigan with respect to fish and wildlife in the scenic area.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78411a3c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/431/s5"},"text":"Pub. L. 106–431, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-06"},"text":"Nov. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1907"},"text":"114 Stat. 1907","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
