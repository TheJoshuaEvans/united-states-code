{"tag":"section","attrib":{"id":"id777b31f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ttt"},"text":"§ 410ttt.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harriet Tubman National Historical Park, Auburn, New York","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id777b31f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b31f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historical park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “historical park” means the Harriet Tubman National Historical Park established by subsection (b)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Home","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Home” means The Harriet Tubman Home, Inc., located in Auburn, New York.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “map” means the map entitled “Harriet Tubman National Historical Park”, numbered T18/80,000, and dated March 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b31fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the State of New York.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777b31fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harriet Tubman National Historical Park","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b31fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b31fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), there is established the Harriet Tubman National Historical Park in Auburn, New York, as a unit of the National Park System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The historical park shall not be established until the date on which the Secretary determines that a sufficient quantity of land, or interests in land, has been acquired to constitute a manageable park unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b31ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date on which the Secretary makes a determination under subparagraph (B), the Secretary shall publish in the Federal Register notice of the establishment of the historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b3200-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map shall be on file and available for public inspection in appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b3201-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The historical park shall include the Harriet Tubman Home, the Tubman Home for the Aged, the Thompson Memorial AME Zion Church and Rectory, and associated land, as identified in the area entitled “National Historical Park Proposed Boundary” on the map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b3202-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the historical park is to preserve and interpret for the benefit of present and future generations the historical, cultural, and natural resources associated with the life of Harriet Tubman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b3203-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b3204-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire land and interests in land within the areas depicted on the map by purchase from a willing seller, donation, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b3205-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No condemnation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No land or interest in land within the areas depicted on the map may be acquired by condemnation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777b3206-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b3207-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall administer the historical park in accordance with this section and the laws generally applicable to units of the National Park System, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b3208-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Park System Organic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":" et seq.); "},{"tag":"ref","attrib":{"idref":"fn002187"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002187"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b3209-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s461"},"text":"16 U.S.C. 461","children":[],"tail":" et seq.)."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b320a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpretive tours","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide interpretive tours to sites and resources located outside the boundary of the historical park in Auburn, New York, relating to the life of Harriet Tubman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b320b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b320c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enter into an agreement with the owner of any land within the historical park to mark, interpret, or restore nationally significant historic or cultural resources relating to the life of Harriet Tubman, if the agreement provides that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777b320d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary shall have the right of access to any public portions of the land covered by the agreement to allow for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id777b320e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access at reasonable times by historical park visitors to the land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id777b320f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interpretation of the land for the public; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b3210-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no changes or alterations shall be made to the land except by mutual agreement of the Secretary and the owner of the land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b3211-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into an agreement with the State, political subdivisions of the State, institutions of higher education, the Home and other nonprofit organizations, and individuals to conduct research relating to the life of Harriet Tubman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b3212-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing requirement","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777b3213-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the total cost of any activity carried out under this paragraph shall not exceed 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b3214-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share may be in the form of in-kind contributions or goods or services fairly valued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b3215-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney general","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777b3216-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to the Attorney General for review any agreement under this paragraph involving religious property or property owned by a religious institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777b3217-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/c/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No agreement subject to review under this subparagraph shall take effect until the date on which the Attorney General issues a finding that the proposed agreement does not violate the Establishment Clause of the first amendment to the Constitution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777b3218-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General management plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777b3219-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after the date on which funds are made available to carry out this section, the Secretary shall prepare a general management plan for the historical park in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777b321a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall coordinate the preparation and implementation of the management plan with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777b321b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Harriet Tubman Underground Railroad National Historical Park established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410sss"},"text":"section 410sss of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777b321c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ttt/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Underground Railroad Network to Freedom.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777b321d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXX/s3036"},"text":"Pub. L. 113–291, div. B, title XXX, § 3036","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3780"},"text":"128 Stat. 3780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/289/tVI/s601/d"},"text":"Pub. L. 114–289, title VI, § 601(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1491"},"text":"130 Stat. 1491","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777b321e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777b321f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id777b3220-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Park System Organic Act (","children":[{"tag":"ref","att