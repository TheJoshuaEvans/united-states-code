 3272","children":[],"tail":", which Act enacted Title 54, National Park Service and Related Programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3036"},"text":"section 3036 of Pub. L. 113–291","children":[],"tail":". Subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3036"},"text":"section 3036 of Pub. L. 113–291","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/s101/b/12"},"text":"section 101(b)(12) of Pub. L. 104–303","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3667"},"text":"110 Stat. 3667","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id777b3222-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/289"},"text":"Pub. L. 114–289","children":[],"tail":", which directed technical amendment to reference in subsec. (d)(4)(B) of original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410sss"},"text":"section 410sss of this title","children":[],"tail":", was executed to subsec. (d)(2)(A) of this section, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
