{"tag":"section","attrib":{"id":"id7759c7b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kk–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"410kk–2"},"text":"§ 410kk–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to carry out the provisions of this subchapter, but not more than $4,100,000 for development and not more than $1,400,000 for the acquisition of lands and interests therein for the Lyndon B. Johnson National Historical Park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7759c7b6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/134/s3"},"text":"Pub. L. 91–134, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-02"},"text":"Dec. 2, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/274"},"text":"83 Stat. 274","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/87/tIV/s403"},"text":"Pub. L. 96–87, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-12"},"text":"Oct. 12, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/667"},"text":"93 Stat. 667","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/607/tVI/s601/2"},"text":"Pub. L. 96–607, title VI, § 601(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3540"},"text":"94 Stat. 3540","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7759c7b7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7759c7b8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7759c7b9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/607"},"text":"Pub. L. 96–607","children":[],"tail":" substituted “such sums as may be necessary to carry out the provisions of sections 410kk to 410kk–2 of this title, but not more than $4,100,000 for development and not more than $1,400,000 for the acquisition of lands and interests therein for” for “not more than $680,000 to provide for the development of” and “National Historical Park” for “National Historic Site”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/87"},"text":"Pub. L. 96–87","children":[],"tail":" increased appropriation authorization from $180,000 to $680,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
