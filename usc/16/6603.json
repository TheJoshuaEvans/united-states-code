{"tag":"section","attrib":{"id":"id7a193519-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603"},"text":null,"children":[{"tag":"num","attrib":{"value":"6603"},"text":"§ 6603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a19351a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of funds and in consultation with other Federal officials, the Secretary shall use amounts in the Fund to provide financial assistance for projects for the conservation of marine turtles, freshwater turtles, or tortoises for which project proposals are approved by the Secretary in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a19351b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project proposals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a19351c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible applicants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A proposal for a project for the conservation of marine turtles, freshwater turtles, or tortoises may be submitted to the Secretary by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a19351d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any wildlife management authority of a foreign country or territory of the United States that has within its boundaries marine turtle, freshwater turtle, or tortoise habitat, if the activities of the authority directly or indirectly affect marine turtle, freshwater turtle, or tortoise conservation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a19351e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person or group with the demonstrated expertise required for the conservation of marine turtles, freshwater turtles, or tortoises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a19351f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project proposal shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a193520-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the purposes of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a193521-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the individual with overall responsibility for the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a193522-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the qualifications of the individuals that will conduct the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a193523-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a193524-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods for project implementation and outcome assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a193525-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staff and community management for the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a193526-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the logistics of the project;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a193527-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the funds and time required to complete the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a193528-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence of support for the project by appropriate governmental entities of the countries in which the project will be conducted, if the Secretary determines that such support is required for the success of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a193529-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding the source and amount of matching funding available for the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a19352a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information that the Secretary considers to be necessary for evaluating the eligibility of the project for funding under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a19352b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project review and approval","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a19352c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a19352d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 30 days after receiving a project proposal, provide a copy of the proposal to other Federal officials, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a19352e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review each project proposal in a timely manner to determine whether the proposal meets the criteria specified in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a19352f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation; approval or disapproval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after receiving a project proposal, and subject to the availability of funds, the Secretary, after consulting with other Federal officials, as appropriate, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a193530-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult on the proposal with the government of each country and territory of the United States in which the project is to be conducted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a193531-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after taking into consideration any comments resulting from the consultation, approve or disapprove the project proposal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a193532-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide written notification of the approval or disapproval to the person that submitted the project proposal, other Federal officials, and each country and territory of the United States described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a193533-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may approve a project proposal under this section if the Secretary determines that the project will help to restore, recover, and sustain a viable population of marine turtles, freshwater turtles, or tortoises in the wild by assisting efforts in a foreign country or territory of the United States to implement a marine turtle, freshwater turtle, or tortoise conservation program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a193534-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project sustainability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, in determining whether to approve project proposals under this section, the Secretary shall give preference to conservation projects that are designed to ensure effective, long-term conservation of marine turtles, freshwater turtles, or tortoises and the habitats of marine turtles, freshwater turtles, or tortoises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a193535-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether to approve project proposals under this section, the Secretary shall give preference to projects for which matching funds are available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a193536-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a193537-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each person that receives assistance under this section for a project shall submit to the Secretary periodic reports (at such intervals as the Secretary may require) that include all information that the Secretary, after consultation with other government officials, determines is necessary to evaluate the progress and success of the project for the purposes of ensuring positive results, assessing problems, and fostering improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193538-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to the public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Reports under paragraph (1), and any other documents relating to projects for which financial assistance is provided under this chapter, shall be made available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a193539-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiyear grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a19353a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award to a person who is otherwise eligible for a grant under this section a multiyear grant of up to 5 years to carry out a project that the person demonstrates is an effective, long-term conservation strategy for marine turtles, freshwater turtles, or tortoises and the habitat of marine turtles, freshwater turtles, or tortoises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a19353b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6603/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection precludes the Secretary from awarding a grant on an annual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a19353c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/266/s4"},"text":"Pub. L. 108–266, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-02"},"text":"July 2, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/793"},"text":"118 Stat. 793","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tVII/s7001/c/3/C"},"text":"Pub. L. 116–9, title VII, § 7001(c)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/787"},"text":"133 Stat. 787","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLIII/s5307/a"},"text":"Pub. L. 118–159, div. E, title LIII, § 5307(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2446"},"text":"138 Stat. 2446","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a19353d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a19353e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a19353f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/C/i"},"text":"Pub. L. 116–9, § 7001(c)(3)(C)(i)","children":[],"tail":", struck out “Marine turtle” before “Conservation” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/C/ii"},"text":"Pub. L. 116–9, § 7001(c)(3)(C)(ii)","children":[],"tail":", inserted “, freshwater turtles, or tortoises” after “marine turtles”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/C/iii/I"},"text":"Pub. L. 116–9, § 7001(c)(3)(C)(iii)(I)","children":[],"tail":", inserted “, freshwater turtles, or tortoises” after “marine turtles” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/C/iii/II"},"text":"Pub. L. 116–9, § 7001(c)(3)(C)(iii)(II)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A) which read as follows: “any wildlife management authority of a foreign country that has within its boundaries marine turtle nesting habitat if the activities of the authority directly or indirectly affect marine turtle conservation; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/C/iii/III"},"text":"Pub. L. 116–9, § 7001(c)(3)(C)(iii)(III)","children":[],"tail":", inserted “, freshwater turtles, or tortoises” after “marine turtles”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/C/iv"},"text":"Pub. L. 116–9, § 7001(c)(3)(C)(iv)","children":[],"tail":", inserted “and territory of the United States” after “each country”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/C/v"},"text":"Pub. L. 116–9, § 7001(c)(3)(C)(v)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d). Prior to amendment, text read as follows: “The Secretary may approve a project proposal under this section if the project will help recover and sustain viable populations of marine turtles in the wild by assisting efforts in foreign countries to implement marine turtle conservation programs.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/3/C/vi"},"text":"Pub. L. 116–9, § 7001(c)(3)(C)(vi)","children":[],"tail":", substituted “marine turtles, freshwater turtles, or tortoises and the habitats of marine turtles, freshwater turtles, or tortoises” for “marine turtles and their nesting habitats”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
