{"tag":"section","attrib":{"id":"id774de069-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"410cc–13"},"text":"§ 410cc–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id774de06a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority; maximum amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this subchapter, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id774de06b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–13/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002100"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002100"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. There is no par. (2)."}],"tail":" the total of the amounts authorized to be appropriated for the purpose of carrying out "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410cc–32/b/2"},"text":"section 410cc–32(b)(2) of this title","children":[],"tail":", for the payment of grants and loans under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410cc–33"},"text":"section 410cc–33 of this title","children":[],"tail":", for the acquisition of property under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410cc–34"},"text":"section 410cc–34 of this title","children":[],"tail":", and for carrying out any transportation program and any educational and cultural program described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410cc–32/c"},"text":"section 410cc–32(c) of this title","children":[],"tail":" shall not exceed $33,600,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774de06c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds shall be authorized pursuant to this section prior to ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774de06d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated under subsection (a) of this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774de06e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–13/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate amount of money expended; certifying statement to Congress as limiting availability of appropriated amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id774de06f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–13/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within 60 days after ","children":[{"tag":"date","attrib":{"date":"1978-06-05"},"text":"June 5, 1978","children":[],"tail":", and on each subsequent October 1 and March 1, the Secretary shall submit to the Congress a statement certifying the aggregate amount of money expended by the Commonwealth of Massachusetts, the city of Lowell, and by any nonprofit entity for activities in the city of Lowell consistent with the purpose of this subchapter during the period beginning on "},{"tag":"date","attrib":{"date":"1974-01-01"},"text":"January 1, 1974","children":[],"tail":", and ending on the date such statement is submitted."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id774de070-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–13/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate amount of funds made available by the Secretary to the Commission from funds appropriated under subsection (a)(2) of this section may not exceed the amount certified by the Secretary in the most recent statement submitted to the Congress under paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id774de071-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/290/tI/s103"},"text":"Pub. L. 95–290, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-05"},"text":"June 5, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/292"},"text":"92 Stat. 292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/134/s1/1"},"text":"Pub. L. 100–134, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-10-16"},"text":"Oct. 16, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/810"},"text":"101 Stat. 810","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dG/tI/s122"},"text":"Pub. L. 117–328, div. G, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4789"},"text":"136 Stat. 4789","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id774de072-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id774de073-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id774de074-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" redesignated par. (2) as (1) and struck out former par. (1) which read as follows: “the total of the amounts authorized to be appropriated for the purpose of acquisition and development under the park management plan established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410cc–21/b"},"text":"section 410cc–21(b) of this title","children":[],"tail":" and emergency assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410cc–25/a/1"},"text":"section 410cc–25(a)(1) of this title","children":[],"tail":" shall not exceed $19,800,000; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/134"},"text":"Pub. L. 100–134","children":[],"tail":" substituted “$19,800,000” for “$18,500,000” in par. (1), and “$33,600,000” for “$21,500,000” in par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id774de075-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id774de076-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/134/s2"},"text":"Pub. L. 100–134, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-10-16"},"text":"Oct. 16, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/810"},"text":"101 Stat. 810","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/134/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), the amendments made by section 1 [amending sections 410cc–13 and 410cc–31 of this title] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1987-10-16"},"text":"Oct. 16, 1987","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date of Authorization of Appropriation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by section 1(1) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410cc–13"},"text":"section 410cc–13 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id774de077-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions of law requiring submittal to Congress of any annual, semiannual, or other regular periodic report listed in House Document No. 103–7 (in which a report required under subsec. (d)(1) of this section is listed on page 108), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
