{"tag":"section","attrib":{"id":"id79e72942-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4008"},"text":null,"children":[{"tag":"num","attrib":{"value":"4008"},"text":"§ 4008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Fisheries Promotional Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e72943-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4008/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a Fisheries Promotional Fund. The Fund shall be available, to the extent provided for in appropriation Acts, for the purpose of making payments to carry out the annual marketing and promotion plan and annual budget of the National Council under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e72944-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4008/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be deposited in the Fund—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e72945-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4008/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the moneys transferred to the Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s713c–3/b/2"},"text":"section 713c–3(b)(2) of title 15","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e72946-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4008/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments made voluntarily pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4007"},"text":"section 4007 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e72947-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4008/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receipts from investments made under subsection (c) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e72948-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4008/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits and investments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sums in the Fund that are not currently needed for the purposes of the Fund shall be kept on deposit in appropriate interest-bearing accounts that shall be established by the Secretary of the Treasury, or invested in obligations of, or guaranteed by, the United States. Any revenue accruing from such deposits and investments shall be deposited in the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e72949-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4008/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated from the Fund, for the purposes of carrying out the annual marketing and promotion plan and annual budget of the National Council under this chapter, such sums as are deposited in the Fund under subsection (b) of this section in each fiscal year beginning in fiscal year 1987 through fiscal year 1991.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e7294a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659/tII/s209"},"text":"Pub. L. 99–659, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3720"},"text":"100 Stat. 3720","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/627/tVII/s702"},"text":"Pub. L. 101–627, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4463"},"text":"104 Stat. 4463","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e7294b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e7294c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79e7294d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659/s209"},"text":"section 209 of Pub. L. 99–659","children":[],"tail":". Subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/99/659/s209"},"text":"section 209 of Pub. L. 99–659","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s713c–3"},"text":"section 713c–3 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79e7294e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/627"},"text":"Pub. L. 101–627","children":[],"tail":" substituted “1991” for “1990”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
