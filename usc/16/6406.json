{"tag":"section","attrib":{"id":"id7a08942d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6406"},"text":null,"children":[{"tag":"num","attrib":{"value":"6406"},"text":"§ 6406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Block grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a08942e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6406/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In each fiscal year beginning in fiscal year 2023 and subject to the availability of appropriations, the Administrator shall provide block grants of financial assistance of not less than $500,000 to each covered State to support management and restoration activities and further the implementation of coral reef action plans in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6404"},"text":"section 6404 of this title","children":[],"tail":" by covered States and non-Federal coral reef stewardship partnerships in accordance with this section. The Administrator shall review each covered State’s application for block grant funding to ensure that applications are consistent with applicable action plans and the National Coral Reef Resilience Strategy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a08942f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6406/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the Administrator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator is responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a089430-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6406/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing guidance on the proper documentation of expenditures authorized under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a089431-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6406/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuing annual solicitations to covered States for awards under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a089432-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6406/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the appropriate allocation of additional amounts among covered States in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a089433-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6406/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of covered States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each covered State is responsible for documenting and reporting—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a089434-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6406/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such State’s use of Federal funds received under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a089435-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6406/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such expenditures of non-Federal funds made in furtherance of coral reef management and restoration as the Administrator determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a089436-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6406/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Administrator may seek to enter into a cooperative agreement with a covered State to fund coral reef conservation and restoration activities in waters managed under the jurisdiction of such covered State that are consistent with the National Coral Reef Resilience Strategy and any applicable action plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6404"},"text":"section 6404 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0add27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6406/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" All Islands Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may enter into a cooperative agreement with the All Islands Committee of the Task Force to provide support for its activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0add28-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s207"},"text":"Pub. L. 106–562, title II, § 207","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/a"},"text":"Pub. L. 117–263, div. J, title C, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3938"},"text":"136 Stat. 3938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0add29-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0add2a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a0add2b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b)(1) and (c)(1), was in the original “this Act” which was translated as reading “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562"},"text":"Pub. L. 106–562","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a0add2c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6406, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s207"},"text":"Pub. L. 106–562, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2804"},"text":"114 Stat. 2804","children":[],"tail":", related to national program to conserve coral reefs and coral reef ecosystems, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/a"},"text":"Pub. L. 117–263, div. J, title C, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3931"},"text":"136 Stat. 3931","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
