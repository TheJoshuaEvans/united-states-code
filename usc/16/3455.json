{"tag":"section","attrib":{"id":"id79b9d7e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3455"},"text":null,"children":[{"tag":"num","attrib":{"value":"3455"},"text":"§ 3455.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility; terms and conditions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b9d7e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3455/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Technical assistance and financial assistance may be provided by the Secretary under this subchapter to any council to assist in carrying out a project specified in an area plan approved by the Secretary only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b9d7e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3455/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the council agrees in writing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b9d7e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3455/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b9d7e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3455/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to finance or arrange for financing of any portion of the cost of carrying out the project for which financial assistance is not provided by the Secretary under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3455/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project is included in an area plan and is approved by the council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3455/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that assistance is necessary to carry out the area plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3455/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project provided for in the area plan is consistent with any comprehensive plan for the area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3455/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of the land or an interest in the land acquired or to be acquired under the plan by any State, local unit of government, Indian tribe, or local nonprofit organization is borne by the State, local unit of government, Indian tribe, or local nonprofit organization, respectively; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3455/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State, local unit of government, Indian tribe, or local nonprofit organization participating in the area plan agrees to maintain and operate the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b9d7ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3455/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b9d7ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3455/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (2) and (3), a loan made under this subchapter shall be made on such terms and conditions as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3455/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan for a project made under this subchapter shall have a term of not more than 30 years after the date of completion of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d7f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3455/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan made under this subchapter shall bear interest at the average rate of interest paid by the United States on obligations of a comparable term, as determined by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b9d7f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3455/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Technical assistance and financial assistance under this subchapter may not be made available to a council to carry out an area plan unless the area plan has been submitted to and approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b9d7f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3455/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may withdraw technical assistance and financial assistance with respect to any area plan if the Secretary determines that the assistance is no longer necessary or that sufficient progress has not been made toward developing or implementing the elements of the area plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b9d7f4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXV/s1532"},"text":"Pub. L. 97–98, title XV, § 1532","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tII/s2504"},"text":"Pub. L. 107–171, title II, § 2504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/272"},"text":"116 Stat. 272","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b9d7f5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79b9d7f6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79b9d7f7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3455, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXV/s1532"},"text":"Pub. L. 97–98, title XV, § 1532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1339"},"text":"95 Stat. 1339","children":[],"tail":", related to authority of the Secretary to carry out provisions of this subchapter, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
