{"tag":"section","attrib":{"id":"id777feca7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb"},"text":null,"children":[{"tag":"num","attrib":{"value":"410bbbb"},"text":"§ 410bbbb.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reconstruction Era National Historical Park and Reconstruction Era National Historic Network","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id777feca8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777feca9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historical park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “historical park” means the Reconstruction Era National Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fecaa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Map” means the maps entitled “Reconstruction Era National Monument Old Beaufort Firehouse”, numbered 550/135,755, and dated January 2017; “Reconstruction Era National Monument Darrah Hall and Brick Baptist Church”, numbered 550/135,756, and dated January 2017; and “Reconstruction Era National Monument Camp Saxton”, numbered 550/135,757, and dated January 2017, collectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fecab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Network","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Network” means the Reconstruction Era National Historic Network established pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777fecac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reconstruction Era National Historical Park","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777fecad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redesignation of Reconstruction Era National Monument","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777fecae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Reconstruction Era National Monument is redesignated as the Reconstruction Era National Historical Park, as generally depicted on the Map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fecaf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds available for the purposes of the Reconstruction Era National Monument shall be available for the purposes of the historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fecb0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any references in a law, regulation, document, record, map, or other paper of the United States to the Reconstruction Era National Monument shall be considered to be a reference to the historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fecb1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary expansion","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777fecb2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beaufort National Historic Landmark District","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (D), the Secretary is authorized to acquire land or interests in land within the Beaufort National Historic Landmark District that has historic connection to the Reconstruction Era. Upon finalizing an agreement to acquire land, the Secretary shall expand the boundary of the historical park to encompass the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fecb3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" St. Helena Island","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (D), the Secretary is authorized to acquire the following and shall expand the boundary of the historical park to include acquisitions under this authority:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777fecb4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Land and interests in land adjacent to the existing boundary on St. Helena Island, South Carolina, as reflected on the Map.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777fecb5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Land or interests in land on St. Helena Island, South Carolina, that has a historic connection to the Reconstruction Era.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fecb6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Camp Saxton","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (D), the Secretary is authorized to accept administrative jurisdiction of Federal land or interests in Federal land adjacent to the existing boundary at Camp Saxton, as reflected on the Map. Upon finalizing an agreement to accept administrative jurisdiction of Federal land or interests in Federal land, the Secretary shall expand the boundary of the historical park to encompass that Federal land or interests in Federal land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fecb7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may only acquire land under this section by donation, exchange, or purchase with donated funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fecb8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777fecb9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer the historical park in accordance with this section and with the laws generally applicable to units of the National Park System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fecba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the management plan for the Reconstruction Era National Monument—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777fecbb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not been completed on or before ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall incorporate all provisions of this section into the planning process and complete a management plan for the historical park within 3 years; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777fecbc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been completed on or before ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall update the plan incorporating the provisions of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777fecbd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reconstruction Era National Historic Network","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777fecbe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777fecbf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, within the National Park Service, a program to be known as the “Reconstruction Era National Historic Network”;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fecc0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", solicit proposals from sites interested in being a part of the Network; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fecc1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer the Network through the historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fecc2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Network, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777fecc3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review studies and reports to complement and not duplicate studies of the historical importance of Reconstruction Era that may be underway or completed, such as the National Park Service Reconstruction Handbook and the National Park Service Theme Study on Reconstruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fecc4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce and disseminate appropriate educational and promotional materials relating to the Reconstruction Era and the sites in the Network, such as handbooks, maps, interpretive guides, or electronic information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fecc5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into appropriate cooperative agreements and memoranda of understanding to provide technical assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fecc6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777fecc7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create and adopt an official, uniform symbol or device for the Network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777fecc8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue regulations for the use of the symbol or device adopted under clause (i); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777fecc9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research relating to Reconstruction and the Reconstruction Era.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fecca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Network shall encompass the following elements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777feccb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All units and programs of the National Park Service that are determined by the Secretary to relate to the Reconstruction Era.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777feccc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Other Federal, State, local, and privately owned properties that the Secretary determines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777feccd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relate to the Reconstruction Era; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777fecce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are included in, or determined by the Secretary to be eligible for inclusion in, the National Register of Historic Places.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777feccf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other governmental and nongovernmental sites, facilities, and programs of an educational, research, or interpretive nature that are directly related to the Reconstruction Era.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777fecd0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410bbbb/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements and memoranda of understanding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To achieve the purposes of this section and to ensure effective coordination of the Federal and non-Federal elements of the Network and units and programs of the National Park Service, the Secretary may enter into cooperative agreements and memoranda of understanding with, and provide technical assistance to, the heads of other Federal agencies, States, units of local government, regional governmental bodies, and private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777fecd1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2204"},"text":"Pub. L. 116–9, title II, § 2204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/735"},"text":"133 Stat. 735","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777fecd2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id777fecd3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id777fecd4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2"},"text":"section 2 of Pub. L. 116–9","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
