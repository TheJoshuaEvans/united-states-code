{"tag":"section","attrib":{"id":"idbcfe9734-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"§ 13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement of professional services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall have authority to contract with educational and other research organizations for the preparation of monographs and other reports and materials of a similar nature.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcfe9735-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/207/s5"},"text":"Pub. L. 85–207, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-28"},"text":"Aug. 28, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/481"},"text":"71 Stat. 481","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
