{"tag":"section","attrib":{"id":"idbd080d52-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s163"},"text":null,"children":[{"tag":"num","attrib":{"value":"163"},"text":"§ 163.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This subchapter does not revoke or impair the authority of any other Federal agency with respect to the collection or release of information.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd080d53-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1158"},"text":"Aug. 31, 1954, ch. 1158","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1021"},"text":"68 Stat. 1021","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd080d54-76cd-11f0-842a-a3c49cc8bf0c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd080d55-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 13, U.S.C., 1952 ed., § 251 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-07/ch910/s1"},"text":"Sept. 7, 1950, ch. 910, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/784"},"text":"64 Stat. 784","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was derived from part of subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s251"},"text":"section 251 of title 13","children":[],"tail":", U.S.C., 1952 ed. Subsection (a) of such section 251 is also incorporated in this subchapter, and the remainder of such subsection (b) thereof is incorporated in subchapter I of chapter 1 of this title. See Distribution Table."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
