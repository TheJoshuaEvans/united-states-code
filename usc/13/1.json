{"tag":"section","attrib":{"id":"idbcf9b5d4-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"§ 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this title, unless the context requires another meaning or unless it is otherwise provided—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf9b5d5-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Bureau” means the Bureau of the Census;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf9b5d6-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf9b5d7-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s1/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “respondent” includes a corporation, company, association, firm, partnership, proprietorship, society, joint stock company, individual, or other organization or entity which reported information, or on behalf of which information was reported, in response to a questionnaire, inquiry, or other request of the Bureau.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf9b5d8-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1158"},"text":"Aug. 31, 1954, ch. 1158","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1012"},"text":"68 Stat. 1012","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/521/s1"},"text":"Pub. L. 94–521, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2459"},"text":"90 Stat. 2459","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf9b5d9-76cd-11f0-842a-a3c49cc8bf0c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbcf9b5da-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section is new, and was inserted to eliminate the necessity for referring, throughout this title, to the Bureau of the Census, and the Secretary of Commerce, by their full designations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf9b5db-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf9b5dc-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/521"},"text":"Pub. L. 94–521","children":[],"tail":" designated existing provisions as pars. (1) and (2), and added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf9b5dd-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf9b5de-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/521/s17"},"text":"Pub. L. 94–521, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2466"},"text":"90 Stat. 2466","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/521/s17"},"text":"“The amendments made by this Act [enacting sections 181 to 184 and 196 of this title, amending this section and sections 3 to 6, 8, 23, 141, 191, 195, 214, 221, 224, 225, and 241 of this title, and enacting provisions set out as notes under this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1976-10-01"},"text":"October 1, 1976","children":[],"tail":", or on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":"], whichever date is later”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbcf9b5df-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/72/s1"},"text":"Pub. L. 114–72, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-10-22"},"text":"Oct. 22, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/566"},"text":"129 Stat. 566","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/72/s1"},"text":"“This Act [amending provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s91"},"text":"section 91 of this title","children":[],"tail":"] may be cited as the ‘Quarterly Financial Report Reauthorization Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbcf9b5e0-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dB/tXII/s1251"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. B, title XII, subtitle E, § 1251]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–505, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/113/dB/s1000/a/7/dB/tXII/s1251"},"text":"“This subtitle [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s301"},"text":"section 301 of this title","children":[],"tail":" and enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t13/s301"},"text":"section 301 of this title","children":[],"tail":"] may be cited as the ‘Proliferation Prevention Enhancement Act of 1999’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbcf9b5e1-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/430/s1"},"text":"Pub. L. 103–430, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4393"},"text":"108 Stat. 4393","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/430/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s16"},"text":"section 16 of this title","children":[],"tail":", amending sections 9 and 214 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s412"},"text":"section 412 of Title 39","children":[],"tail":", Postal Service, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t13/s16"},"text":"section 16 of this title","children":[],"tail":"] may be cited as the ‘Census Address List Improvement Act of 1994’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"idbcfc25e2-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/521/s16"},"text":"Pub. L. 94–521, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2466"},"text":"90 Stat. 2466","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/521/s16"},"text":"“If a provision enacted by this Act [see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/521/s17"},"text":"section 17 of Pub. L. 94–521","children":[],"tail":" set out above] is held invalid, all valid provisions that are severable from the invalid provision remain in effect. If a provision of this Act ["},{"tag":"ref","attrib":{"href":"/us/pl/94/521"},"text":"Pub. L. 94–521","children":[],"tail":"] is held invalid in one or more of its applications, the provision remains in effect in all valid applications that are severable from the invalid application or applications.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
