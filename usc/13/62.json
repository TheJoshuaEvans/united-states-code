{"tag":"section","attrib":{"id":"idbd0352cd-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s62"},"text":null,"children":[{"tag":"num","attrib":{"value":"62"},"text":"§ 62.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional statistics","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This subchapter does not restrict or limit the Secretary in the collection and publication, under the general authority of the Secretary, of such statistics on fats and oils or products thereof not specifically required in this subchapter, as he deems to be in the public interest.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd0352ce-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1158"},"text":"Aug. 31, 1954, ch. 1158","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1018"},"text":"68 Stat. 1018","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0352cf-76cd-11f0-842a-a3c49cc8bf0c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd0352d0-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 13, U.S.C., 1952 ed., § 85 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-07/ch274/s5"},"text":"Aug. 7, 1916, ch. 274, § 5","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-25/ch331"},"text":"July 25, 1947, ch. 331","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/457"},"text":"61 Stat. 457","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"References to the Secretary (of Commerce) were substituted for reference to the Director of the Census and for reference to the Bureau (of the Census), to conform with 1950 Reorganization Plan No. 5, §§ 1, 2, effective ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1263"},"text":"64 Stat. 1263","children":[],"tail":". See Revision Note to "},{"tag":"ref","attrib":{"href":"/us/usc/t13/s4"},"text":"section 4 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
