{"tag":"section","attrib":{"id":"idbd0352b6-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s45"},"text":null,"children":[{"tag":"num","attrib":{"value":"45"},"text":"§ 45.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simultaneous publication of cotton reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The reports of cotton ginned to the dates as of which the Department of Agriculture is also required to issue cotton crop reports shall be issued simultaneously with the cotton crop reports of that department, the two reports to be issued from the same place at 3 o’clock postmeridian on or before the 12th day of the month to which the respective reports relate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd0352b7-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1158"},"text":"Aug. 31, 1954, ch. 1158","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1017"},"text":"68 Stat. 1017","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/331/s3"},"text":"Pub. L. 92–331, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-30"},"text":"June 30, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/400"},"text":"86 Stat. 400","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0352b8-76cd-11f0-842a-a3c49cc8bf0c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd0352b9-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 13, U.S.C., 1952 ed., § 76 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-04-02/ch80/s6"},"text":"Apr. 2, 1924, ch. 80, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/32"},"text":"43 Stat. 32","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1929-06-18/ch28/s21"},"text":"June 18, 1929, ch. 28, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/26"},"text":"46 Stat. 26","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-28/ch256/s2"},"text":"June 28, 1949, ch. 256, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/278"},"text":"63 Stat. 278","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd0352ba-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd0352bb-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/331"},"text":"Pub. L. 92–331","children":[],"tail":" substituted provisions requiring the two reports to be issued from the same place at 3 o’clock postmeridian on or before the 12th day of the month to which the respective reports relate for provisions requiring the two reports to be issued from the same place at 11 o’clock antemeridian on the 8th day following that on which the respective reports relate, and struck out provisions setting forth the date of release in the event the original release date falls on a Sunday, legal holiday, or other nonworkday in the Department of Commerce at Washington."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
