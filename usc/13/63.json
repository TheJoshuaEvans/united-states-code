{"tag":"section","attrib":{"id":"idbd0352d1-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s63"},"text":null,"children":[{"tag":"num","attrib":{"value":"63"},"text":"§ 63.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duplicate collection of statistics prohibited; access to available statistics","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Statistics required under Federal law, as of the effective date of this title, to be collected by any other Federal department or agency in a manner comparable both as to form and period of time to the collection of statistics provided for by this subchapter shall not be collected by the Secretary under the authority of this subchapter. Immediately upon his request, the Secretary shall have access to any such statistics and shall include them in the publication required by this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd0352d2-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1158"},"text":"Aug. 31, 1954, ch. 1158","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1018"},"text":"68 Stat. 1018","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0352d3-76cd-11f0-842a-a3c49cc8bf0c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd0352d4-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 13, U.S.C., 1952 ed., § 86 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-07/ch274/s6"},"text":"Aug. 7, 1916, ch. 274, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-25/ch331"},"text":"July 25, 1947, ch. 331","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/457"},"text":"61 Stat. 457","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"References to the Secretary (of Commerce) were substituted for references to the Director of the Census to conform with 1950 Reorganization Plan No. 5, §§ 1, 2, effective ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1263"},"text":"64 Stat. 1263","children":[],"tail":". See Revision Note to "},{"tag":"ref","attrib":{"href":"/us/usc/t13/s4"},"text":"section 4 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “, as of the effective date of this title,” were inserted in the first sentence for the purpose of clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd0352d5-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd0352d6-76cd-11f0-842a-a3c49cc8bf0c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this title, referred to in text, is ","children":[{"tag":"date","attrib":{"date":"1955-01-01"},"text":"Jan. 1, 1955","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
