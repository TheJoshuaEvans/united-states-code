{"tag":"section","attrib":{"id":"idbd0352bd-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s61"},"text":null,"children":[{"tag":"num","attrib":{"value":"61"},"text":"§ 61.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection and publication","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0352be-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s61/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall collect, collate, and publish monthly statistics concerning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0352bf-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s61/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the quantities of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0352c0-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s61/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cotton seed, soybeans, peanuts, flaxseed, corn germs, copra, sesame seed, babassu nuts and kernels, and other oilseeds, nuts, and kernels received, crushed, and on hand at oil mills;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0352c1-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s61/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crude and refined oils, cakes, and meals, and other primary products, by type or kind, of the seeds, nuts, and kernels referred to in clause (A) of this paragraph, manufactured, shipped out, and on hand at oil mills and processing establishments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0352c2-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s61/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crude and refined vegetable oils, by type or kind, used by class of product and held by manufacturers of vegetable short­ening, margarine, soap, and other principal products using large quantities of vegetable oils;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0352c3-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s61/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crude and refined vegetable oils, by type or kind, held in warehouses and in transit to consuming establishments; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0352c4-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s61/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the quantities, by types or kinds, of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0352c5-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s61/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" animal fats and oils and greases produced;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0352c6-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s61/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" animal fats and oils and greases shipped and held by producers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0352c7-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s61/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" animal fats and oils and greases, fish and marine mammal oils used by class of product and held by manufacturers of short­ening, margarine, soap, and other principal products which require the use of large quantities of animal fats and oils and greases, fish and marine mammal oils;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0352c8-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s61/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" animal fats and oils and greases, fish and marine mammal oils held in warehouses, cold storage, and in transit to consuming establishments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0352c9-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s61/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall not be required to collect, more frequently than he deems necessary to provide reliable statistical reports, information from any person who produces, holds, or consumes fats and oils in inconsequential quantities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd0352ca-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1158"},"text":"Aug. 31, 1954, ch. 1158","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1017"},"text":"68 Stat. 1017","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0352cb-76cd-11f0-842a-a3c49cc8bf0c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd0352cc-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 13, U.S.C., 1952 ed., § 81 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-07/ch274/s1"},"text":"Aug. 7, 1916, ch. 274, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/436"},"text":"39 Stat. 436","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-25/ch331"},"text":"July 25, 1947, ch. 331","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/457"},"text":"61 Stat. 457","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"References to the Secretary (of Commerce) were substituted for references to the Director of the Census, to conform with 1950 Reorganization Plan No. 5, §§ 1, 2, effective ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1263"},"text":"64 Stat. 1263","children":[],"tail":". See Revision Note to "},{"tag":"ref","attrib":{"href":"/us/usc/t13/s4"},"text":"section 4 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology and arrangement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
