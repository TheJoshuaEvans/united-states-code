{"tag":"section","attrib":{"id":"idbd05c321-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s132"},"text":null,"children":[{"tag":"num","attrib":{"value":"132"},"text":"§ 132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlling law; effect on other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To the extent that the provisions of this subchapter or subchapter IV of this chapter conflict with any other provision of this title or other law, pertaining to the Secretary of the Department of Commerce, the provisions of this title shall control; but nothing in this title shall be deemed to revoke or impair the authority of any other Federal agency with respect to the collection or release of information.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd05c322-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1158"},"text":"Aug. 31, 1954, ch. 1158","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1019"},"text":"68 Stat. 1019","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd05c323-76cd-11f0-842a-a3c49cc8bf0c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd05c324-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 13, U.S.C., 1952 ed., § 123 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-19/ch502/s3"},"text":"June 19, 1948, ch. 502, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/479"},"text":"62 Stat. 479","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was derived from all of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s123"},"text":"section 123 of title 13","children":[],"tail":", U.S.C., 1952 ed., except the first sentence. That sentence is incorporated with other provisions in chapter 1 of this title. See Distribution Table."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The reference “Secretary or Department of Commerce” was substituted for reference to the Bureau of the Census to conform with 1950 Reorganization Plan No. 5, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1263"},"text":"64 Stat. 1263","children":[],"tail":". See Revision Note to "},{"tag":"ref","attrib":{"href":"/us/usc/t13/s4"},"text":"section 4 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
