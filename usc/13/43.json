{"tag":"section","attrib":{"id":"idbd0352ac-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s43"},"text":null,"children":[{"tag":"num","attrib":{"value":"43"},"text":"§ 43.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and reports of cotton ginners","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every cotton ginner shall keep a record of the county or parish in which each bale of cotton ginned by him is grown and report at the completion of the ginning season, but not later than the March canvass, of each year a segregation of the total number of bales ginned by counties or parishes in which grown.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd0352ad-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1158"},"text":"Aug. 31, 1954, ch. 1158","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1016"},"text":"68 Stat. 1016","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/143"},"text":"Pub. L. 92–143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-10-15"},"text":"Oct. 15, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/393"},"text":"85 Stat. 393","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0352ae-76cd-11f0-842a-a3c49cc8bf0c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd0352af-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 13, U.S.C., 1952 ed., § 74 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-04-02/ch80/s4"},"text":"Apr. 2, 1924, ch. 80, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/32"},"text":"43 Stat. 32","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1929-06-18/ch28/s21"},"text":"June 18, 1929, ch. 28, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/26"},"text":"46 Stat. 26","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-14/ch358"},"text":"June 14, 1938, ch. 358","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/678"},"text":"52 Stat. 678","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was derived from second paragraph of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s74"},"text":"section 74 of title 13","children":[],"tail":", U.S.C., 1952 ed. For remainder of such section 74, see Distribution Table."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd0352b0-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd0352b1-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1971—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/143"},"text":"Pub. L. 92–143","children":[],"tail":" inserted “completion of the ginning season, but not later than the”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
