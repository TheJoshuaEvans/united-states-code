{"tag":"section","attrib":{"id":"idbcfe9732-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"§ 12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mechanical and electronic development","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to have conducted mechanical and electronic development work as he determines is needed to further the functions and duties of carrying out the purposes of this title and may enter into such developmental contracts as he may determine to be in the best interest of the Government.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcfe9733-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/207/s5"},"text":"Pub. L. 85–207, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-28"},"text":"Aug. 28, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/481"},"text":"71 Stat. 481","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
