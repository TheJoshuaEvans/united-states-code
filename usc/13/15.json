{"tag":"section","attrib":{"id":"idbcfe973b-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"§ 15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leases for 1980 decennial census","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The 15 percent limitation contained in section 322 ","children":[{"tag":"ref","attrib":{"idref":"fn002010"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002010"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Act of "},{"tag":"date","attrib":{"date":"1932-06-30"},"text":"June 30, 1932","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/47/412"},"text":"47 Stat. 412","children":[],"tail":") shall not apply to leases entered into by the Secretary for the purpose of carrying out the 1980 decennial census, but no lease may be entered into for such purpose at a rental in excess of 105 percent of the appraised fair annual rental of the leased premises, or a proportionate part of the appraised fair annual rental in the case of a lease for less than a year."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcfe973c-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/52/s1/a"},"text":"Pub. L. 96–52, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-13"},"text":"Aug. 13, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/358"},"text":"93 Stat. 358","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/178/s4/c"},"text":"Pub. L. 108–178, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-15"},"text":"Dec. 15, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/