{"tag":"section","attrib":{"id":"idbd00e15f-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"§ 22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications of permanent personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All permanent officers and employees of the Bureau shall be citizens of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd00e160-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1158"},"text":"Aug. 31, 1954, ch. 1158","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1014"},"text":"68 Stat. 1014","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/769/s1"},"text":"Pub. L. 86–769, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/911"},"text":"74 Stat. 911","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd00e161-76cd-11f0-842a-a3c49cc8bf0c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd00e162-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 13, U.S.C., 1952 ed., §§ 5, 6 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-03-06/ch139"},"text":"Mar. 6, 1902, ch. 139","children":[],"tail":", §§ 5, 10, "},{"tag":"ref","attrib":{"href":"/us/stat/32/51"},"text":"32 Stat. 51","children":[],"tail":", 53; "},{"tag":"ref","attrib":{"href":"/us/act/1929-06-18/ch28/s21"},"text":"June 18, 1929, ch. 28, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/26"},"text":"46 Stat. 26","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s5"},"text":"section 5 of title 13","children":[],"tail":", U.S.C., 1952 ed., with section 6 of such title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A reference to “officers” was inserted for completeness, and the word “permanent” was inserted before “officers and employees” for the purpose of clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provision in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s5"},"text":"section 5 of title 13","children":[],"tail":", U.S.C., 1952 ed., excepting unskilled laborers from the requirements for citizenship, was omitted as superseded and covered by the Classification Act of 1949 (5 U.S.C., 1952 ed., ch. 21)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provision that appointments and compensation shall be subject to the Classification Act of 1949 is new but is in accordance with existing law. See chapter 21 of title 5, U.S.C., 1952 ed., Executive Departments and Government Officers and Employees.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provision in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s5"},"text":"section 5 of title 13","children":[],"tail":", U.S.C., 1952 ed., giving preference in appointments to war veterans and their widows, was omitted as superseded and covered by the Veterans’ Preference Act of 1944 (chapter 17 of Title 5, U.S.C., 1952 ed., Executive Departments and Government Officers and Employees)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd00e163-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd00e164-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/769"},"text":"Pub. L. 86–769","children":[],"tail":" struck out references to appointment and compensation under the Civil Service laws and the Classification Act of 1949."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd00e165-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd00e166-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Program for Employment of Spanish-Origin Personnel in Bureau; Report to Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/311/s6"},"text":"Pub. L. 94–311, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-16"},"text":"June 16, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/689"},"text":"90 Stat. 689","children":[],"tail":", required Department of Commerce to implement an affirmative action program within Bureau of the Census for employment of personnel of Spanish origin or descent and to submit a report to Congress within one year of "},{"tag":"date","attrib":{"date":"1976-06-16"},"text":"June 16, 1976","children":[],"tail":", on progress of such program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
