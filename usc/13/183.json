{"tag":"section","attrib":{"id":"idbd080d65-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s183"},"text":null,"children":[{"tag":"num","attrib":{"value":"183"},"text":"§ 183.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of most recent population data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd080d66-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s183/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), for the purpose of administering any law of the United States in which population or other population characteristics are used to determine the amount of benefit received by State, county, or local units of general purpose government, the Secretary shall transmit to the President for use by the appropriate departments and agencies of the executive branch the data most recently produced and published under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd080d67-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s183/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not apply with respect to any law of the United States which, for purposes of determining the amount of benefit received by State, county, or local units of general purpose government, provides that only population or population characteristics data obtained in the most recent decennial census may be used in such determination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd080d68-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/521/s8/a"},"text":"Pub. L. 94–521, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2463"},"text":"90 Stat. 2463","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd080d69-76cd-11f0-842a-a3c49cc8bf0c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd080d6a-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd080d6b-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/521/s17"},"text":"section 17 of Pub. L. 94–521","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t13/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
