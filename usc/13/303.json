{"tag":"section","attrib":{"id":"idbd0f3905-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s303"},"text":null,"children":[{"tag":"num","attrib":{"value":"303"},"text":"§ 303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of Treasury functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To assist the Secretary to carry out the provisions of this chapter, the Secretary of the Treasury shall collect information in the form and manner prescribed by the regulations issued pursuant to this chapter from persons engaged in foreign commerce or trade and from the owners or operators of carriers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd0f3906-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/826/s2"},"text":"Pub. L. 87–826, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-15"},"text":"Oct. 15, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/951"},"text":"76 Stat. 951","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dB/tXIV/s1404/d"},"text":"Pub. L. 107–228, div. B, title XIV, § 1404(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1454"},"text":"116 Stat. 1454","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0f3907-76cd-11f0-842a-a3c49cc8bf0c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd0f3908-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd0f3909-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":" struck out “, other than by mail,” after “foreign commerce or trade”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
