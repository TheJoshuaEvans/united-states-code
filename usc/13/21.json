{"tag":"section","attrib":{"id":"idbd00e14c-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"§ 21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of the Census; duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd00e14d-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s21/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd00e14e-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s21/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Bureau shall be headed by a Director of the Census, appointed by the President, by and with the advice and consent of the Senate, without regard to political affiliation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd00e14f-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s21/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Such appointment shall be made from individuals who have a demonstrated ability in managing large organizations and experience in the collection, analysis, and use of statistical data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd00e150-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s21/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term of Office.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd00e151-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s21/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of office of the Director shall be 5 years, and shall begin on ","children":[{"tag":"date","attrib":{"date":"2012-01-01"},"text":"January 1, 2012","children":[],"tail":", and every fifth year thereafter. An individual may not serve more than 2 full terms as Director."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd00e152-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s21/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any individual appointed to fill a vacancy in such position, occurring before the expiration of the term for which such individual’s predecessor was appointed, shall be appointed for the remainder of that term. The Director may serve after the end of the Director’s term until reappointed or until a successor has been appointed, but in no event longer than 1 year after the end of such term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd00e153-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s21/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Removal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual serving as Director may be removed from office by the President. The President shall communicate in writing the reasons for any such removal to both Houses of Congress not later than 60 days before the removal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd00e154-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s21/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personnel actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided under paragraph (3), nothing in this subsection shall prohibit a personnel action otherwise authorized by law with respect to the Director of the Census, other than removal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd00e155-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s21/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall perform such duties as may be imposed upon the Director by law, regulations, or orders of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd00e156-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1158"},"text":"Aug. 31, 1954, ch. 1158","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1014"},"text":"68 Stat. 1014","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s3/a"},"text":"Pub. L. 112–166, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1291"},"text":"126 Stat. 1291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd00e157-76cd-11f0-842a-a3c49cc8bf0c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd00e158-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 13, U.S.C., 1952 ed., § 2 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-03-06/ch139/s3"},"text":"Mar. 6, 1902, ch. 139, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/51"},"text":"32 Stat. 51","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1929-06-18/ch28/s21"},"text":"June 18, 1929, ch. 28, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/26"},"text":"46 Stat. 26","children":[],"tail":"). The provision of "},{"tag":"ref","attrib":{"href":"/us/usc/t13/s2"},"text":"section 2 of title 13","children":[],"tail":", U.S.C., 1952 ed., which imposed upon the Director the duty to superintend and direct the taking of censuses of the United States was omitted in view of 1950 Reorganization Plan No. 5, effective "},{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1263"},"text":"64 Stat. 1263","children":[],"tail":", which transferred all functions of all officers, employees, bureaus, and agencies of the Department of Commerce to the Secretary of Commerce, and this title, as revised, vests such duty in the Secretary. However, under "},{"tag":"ref","attrib":{"href":"/us/usc/t13/s4"},"text":"section 4 of this title","children":[],"tail":", he may delegate his functions hereunder."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Bureau” was substituted for “permanent Census Office”. See Revision Note to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"At the end of this section, references to regulations, and to orders of the Secretary, were added after “law” in view of the changes effected by 1950 Reorganization Plan No. 5, referred to above.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd00e159-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd00e15a-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “The Bureau shall be headed by a Director of the Census, appointed by the President, by and with the advice and consent of the Senate. The Director shall perform such duties as may be imposed upon him by law, regulations, or orders of the Secretary.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd00e15b-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd00e15c-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166/s6/b"},"text":"Pub. L. 112–166, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1295"},"text":"126 Stat. 1295","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/166/s6/b"},"text":"“The provisions of sections 3 and 4 [amending this section and enacting provisions set out as notes under this section] (including any amendments made by those sections) shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd00e15d-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transition Rules","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166/s3/b"},"text":"Pub. L. 112–166, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1291"},"text":"126 Stat. 1291","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/166/s3/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of initial director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The initial Director of the Bureau of the Census shall be appointed in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s21/a"},"text":"section 21(a) of title 13","children":[],"tail":", United States Code, as amended by subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interim role of current director of the census after date of enactment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, as of ","children":[{"tag":"date","attrib":{"date":"2012-01-01"},"text":"January 1, 2012","children":[],"tail":", the initial Director of the Bureau of the Census has not taken office, the officer serving on "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":", as Director of the Census (or Acting Director of the Census, if applicable) in the Department of Commerce—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall serve as the Director of the Bureau of the Census; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall assume the powers and duties of such Director for one term beginning ","children":[{"tag":"date","attrib":{"date":"2012-01-01"},"text":"January 1, 2012","children":[],"tail":", as described in section 21(b) of such title, as so amended.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd00e15e-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Technical and Conforming Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166/s3/c"},"text":"Pub. L. 112–166, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1291"},"text":"126 Stat. 1291","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/166/s3/c"},"text":"“Not later than ","children":[{"tag":"date","attrib":{"date":"2012-01-01"},"text":"January 1, 2012","children":[],"tail":", [sic] the Secretary of Commerce, in consultation with the Director of the Census, shall submit to each House of the Congress draft legislation containing any technical and conforming amendments to title 13, United States Code, and any other provisions which may be necessary to carry out the purposes of this section [amending this section and enacting provisions set out as notes under this section].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
