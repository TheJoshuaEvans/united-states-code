{"tag":"section","attrib":{"id":"idbd080d49-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s161"},"text":null,"children":[{"tag":"num","attrib":{"value":"161"},"text":"§ 161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quinquennial censuses; inclusion of certain data","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall take, compile, and publish for the year 1957 and for every fifth year thereafter a census of governments. Each such census shall include, but shall not be limited to, data on taxes and tax valuations, governmental receipts, expenditures, indebtedness, and employees of States, counties, cities, and other governmental units.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd080d4a-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1158"},"text":"Aug. 31, 1954, ch. 1158","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1021"},"text":"68 Stat. 1021","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/207/s12"},"text":"Pub. L. 85–207, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-28"},"text":"Aug. 28, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/483"},"text":"71 Stat. 483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd080d4b-76cd-11f0-842a-a3c49cc8bf0c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd080d4c-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 13, U.S.C., 1952 ed., § 251 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-07/ch910/s1"},"text":"Sept. 7, 1950, ch. 910, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/784"},"text":"64 Stat. 784","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was derived from subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s251"},"text":"section 251 of title 13","children":[],"tail":", U.S.C., 1952 ed. For remainder of such section 251, see Distribution Table."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the year 1957 was substituted for reference to the year 1952, since the latter reference is now obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd080d4d-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd080d4e-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1957—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/207"},"text":"Pub. L. 85–207","children":[],"tail":" struck out “in the United States and in such of its Territories and possessions as may be determined by the Secretary” in last sentence. Geographical provisions now covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t13/s191"},"text":"section 191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
