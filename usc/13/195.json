{"tag":"section","attrib":{"id":"idbd0a7e82-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s195"},"text":null,"children":[{"tag":"num","attrib":{"value":"195"},"text":"§ 195.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of sampling","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except for the determination of population for purposes of apportionment of Representatives in Congress among the several States, the Secretary shall, if he considers it feasible, authorize the use of the statistical method known as “sampling” in carrying out the provisions of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd0a7e83-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/207/s14"},"text":"Pub. L. 85–207, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-28"},"text":"Aug. 28, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/484"},"text":"71 Stat. 484","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/521/s10"},"text":"Pub. L. 94–521, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2464"},"text":"90 Stat. 2464","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0a7e84-76cd-11f0-842a-a3c49cc8bf0c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd0a7e85-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd0a7e86-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"