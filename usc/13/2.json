{"tag":"section","attrib":{"id":"idbcfc25e3-76cd-11f0-842a-a3c49cc8bf0c","identifier":"/us/usc/t13/s2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"§ 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau of the Census","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Bureau is continued as an agency within, and under the jurisdiction of, the Department of Commerce.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcfc25e4-76cd-11f0-842a-a3c49cc8bf0c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1158"},"text":"Aug. 31, 1954, ch. 1158","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1012"},"text":"68 Stat. 1012","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcfc25e5-76cd-11f0-842a-a3c49cc8bf0c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbcfc25e6-76cd-11f0-842a-a3c49cc8bf0c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 13, U.S.C., 1952 ed., § 1 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-03-06/ch139/s1"},"text":"Mar. 6, 1902, ch. 139, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/51"},"text":"32 Stat. 51","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1903-02-14/ch552/s4"},"text":"Feb. 14, 1903, ch. 552, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/826"},"text":"32 Stat. 826","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141/s1"},"text":"Mar. 4, 1913, ch. 141, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/736"},"text":"37 Stat. 736","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1929-06-18/ch28/s21"},"text":"June 18, 1929, ch. 28, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/26"},"text":"46 Stat. 26","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s1"},"text":"Section 1 of title 13","children":[],"tail":", U.S.C., 1952 ed., provided that the “Census Office” temporarily established in the Department of the Interior in accordance with the act of "},{"tag":"date","attrib":{"date":"1899-03-03"},"text":"Mar. 3, 1899","children":[],"tail":" (ch. 419, "},{"tag":"ref","attrib":{"href":"/us/stat/30/1014"},"text":"30 Stat. 1014","children":[],"tail":") “is made” a permanent office in the Department of Commerce. Such wording is no longer necessary, and the provisions, as revised in this section, merely continue the Bureau (of the Census) as an agency within, and under the jurisdiction of, the Department of Commerce."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
