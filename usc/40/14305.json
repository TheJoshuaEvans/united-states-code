{"tag":"section","attrib":{"id":"id80dc118a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14305"},"text":null,"children":[{"tag":"num","attrib":{"value":"14305"},"text":"§ 14305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liaison between Federal Government and Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80dc118b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"President","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall provide effective and continuing liaison between the Federal Government and the Appalachian Regional Commission and a coordinated review within the Government of the plans and recommendations submitted by the Commission pursuant to sections 14303 and 14304 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc118c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interagency Coordinating Council on Appalachia","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out subsection (a), the President shall establish the Interagency Coordinating Council on Appalachia, to be composed of the Federal Cochairman and representatives of federal agencies that carry out economic development programs in the Appalachian region. The Federal Cochairman is the Chairperson of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80dc118d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"}