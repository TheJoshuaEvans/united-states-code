{"tag":"section","attrib":{"id":"id80dc112c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102"},"text":null,"children":[{"tag":"num","attrib":{"value":"14102"},"text":"§ 14102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80dc112d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subtitle—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80dc112e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appalachian region","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Appalachian region” means that area of the eastern United States consisting of the following counties (including any political subdivision located within the area):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80dc112f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In Alabama, the counties of Bibb, Blount, Calhoun, Chambers, Cherokee, Chilton, Clay, Cleburne, Colbert, Coosa, Cullman, De Kalb, Elmore, Etowah, Fayette, Franklin, Hale, Jackson, Jefferson, Lamar, Lauderdale, Lawrence, Limestone, Macon, Madison, Marion, Marshall, Morgan, Pickens, Randolph, St. Clair, Shelby, Talladega, Tallapoosa, Tuscaloosa, Walker, and Winston.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc1130-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In Georgia, the counties of Banks, Barrow, Bartow, Carroll, Catoosa, Chattooga, Cherokee, Dade, Dawson, Douglas, Elbert, Fannin, Floyd, Forsyth, Franklin, Gilmer, Gordon, Gwinnett, Habersham, Hall, Haralson, Hart, Heard, Jackson, Lumpkin, Madison, Murray, Paulding, Pickens, Polk, Rabun, Stephens, Towns, Union, Walker, White, and Whitfield.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc1131-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In Kentucky, the counties of Adair, Bath, Bell, Boyd, Breathitt, Carter, Casey, Clark, Clay, Clinton, Cumberland, Edmonson, Elliott, Estill, Fleming, Floyd, Garrard, Green, Greenup, Harlan, Hart, Jackson, Johnson, Knott, Knox, Laurel, Lawrence, Lee, Leslie, Letcher, Lewis, Lincoln, McCreary, Madison, Magoffin, Martin, Menifee, Metcalfe, Monroe, Montgomery, Morgan, Nicholas, Owsley, Perry, Pike, Powell, Pulaski, Robertson, Rockcastle, Rowan, Russell, Wayne, Whitley, and Wolfe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc1132-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In Maryland, the counties of Allegany, Garrett, and Washington.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc1133-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In Mississippi, the counties of Alcorn, Benton, Calhoun, Chickasaw, Choctaw, Clay, Itawamba, Kemper, Lee, Lowndes, Marshall, Monroe, Montgomery, Noxubee, Oktibbeha, Panola, Pontotoc, Prentiss, Tippah, Tishomingo, Union, Webster, Winston, and Yalobusha.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc1134-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In New York, the counties of Allegany, Broome, Cattaraugus, Chautauqua, Chemung, Chenango, Cortland, Delaware, Otsego, Schoharie, Schuyler, Steuben, Tioga, and Tompkins.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc1135-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In North Carolina, the counties of Alexander, Alleghany, Ashe, Avery, Buncombe, Burke, Caldwell, Catawba, Cherokee, Clay, Cleveland, Davie, Forsyth, Graham, Haywood, Henderson, Jackson, McDowell, Macon, Madison, Mitchell, Polk, Rutherford, Stokes, Surry, Swain, Transylvania, Watauga, Wilkes, Yadkin, and Yancey.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc1136-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In Ohio, the counties of Adams, Ashtabula, Athens, Belmont, Brown, Carroll, Clermont, Columbiana, Coshocton, Gallia, Guernsey, Harrison, Highland, Hocking, Holmes, Jackson, Jefferson, Lawrence, Mahoning, Meigs, Monroe, Morgan, Muskingum, Noble, Perry, Pike, Ross, Scioto, Trumbull, Tuscarawas, Vinton, and Washington.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc1137-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In Pennsylvania, the counties of Allegheny, Armstrong, Beaver, Bedford, Blair, Bradford, Butler, Cambria, Cameron, Carbon, Centre, Clarion, Clearfield, Clinton, Columbia, Crawford, Elk, Erie, Fayette, Forest, Fulton, Greene, Huntingdon, Indiana, Jefferson, Juniata, Lackawanna, Lawrence, Luzerne, Lycoming, McKean, Mercer, Mifflin, Monroe, Montour, Northumberland, Perry, Pike, Potter, Schuylkill, Snyder, Somerset, Sullivan, Susquehanna, Tioga, Union, Venango, Warren, Washington, Wayne, Westmoreland, and Wyoming.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc1138-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In South Carolina, the counties of Anderson, Cherokee, Greenville, Oconee, Pickens, Spartanburg, and Union.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc1139-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In Tennessee, the counties of Anderson, Bledsoe, Blount, Bradley, Campbell, Cannon, Carter, Claiborne, Clay, Cocke, Coffee, Cumberland, De Kalb, Fentress, Franklin, Grainger, Greene, Grundy, Hamblen, Hamilton, Hancock, Hawkins, Jackson, Jefferson, Johnson, Knox, Lawrence, Lewis, Loudon, McMinn, Macon, Marion, Meigs, Monroe, Morgan, Overton, Pickett, Polk, Putnam, Rhea, Roane, Scott, Sequatchie, Sevier, Smith, Sullivan, Unicoi, Union, Van Buren, Warren, Washington, and White.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc113a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In Virginia, the counties of Alleghany, Bath, Bland, Botetourt, Buchanan, Carroll, Craig, Dickenson, Floyd, Giles, Grayson, Henry, Highland, Lee, Montgomery, Patrick, Pulaski, Rockbridge, Russell, Scott, Smyth, Tazewell, Washington, Wise, and Wythe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc113b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All the counties of West Virginia, of which the counties of Brooke, Hancock, Marshall, and Ohio shall be considered to be located in the North Central subregion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc113c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Local development district","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “local development district” means any of the following entities for which the Governor of the State in which the entity is located, or the appropriate state officer, certifies to the Appalachian Regional Commission that the entity has a charter or authority that includes the economic development of counties or parts of counties or other political subdivisions within the region:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80dc113d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit incorporated body organized or chartered under the law of the State in which it is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc113e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit agency or instrumentality of a state or local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc113f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit agency or instrumentality created through an interstate compact.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc1140-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit association or combination of bodies, agencies, and instrumentalities described in this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc1141-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Change in Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may not propose or consider a recommendation for any change in the definition of the Appalachian region as set forth in this section without a prior resolution by the Committee on Environment and Public Works of the Senate or the Committee on Transportation and Infrastructure of the House of Representatives that directs a study of the change.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80dc1142-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1254"},"text":"116 Stat. 1254","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/371/s7"},"text":"Pub. L. 110–371, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4042"},"text":"122 Stat. 4042","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11506/a"},"text":"Pub. L. 117–58, div. A, title I, § 11506(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/584"},"text":"135 Stat. 584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80dc1143-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80dc1144-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80dc1145-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14102(a)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:403 (less last 2 pars.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/4/tIV/s403"},"text":"Pub. L. 89–4, title IV, § 403","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Mar. 9, 1965","children":[],"tail":", "},{"tag":"htm