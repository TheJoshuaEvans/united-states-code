 it is one of the following” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the text of 40 App.:403 (last par.) is omitted as obsolete.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80dc1146-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80dc1147-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s11506/a/1"},"text":"Pub. L. 117–58, § 11506(a)(1)","children":[],"tail":", inserted “Catawba,” after “Caldwell,” and “Cleveland,” after “Clay,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s11506/a/2"},"text":"Pub. L. 117–58, § 11506(a)(2)","children":[],"tail":", substituted “Spartanburg, and Union” for “and Spartanburg”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(M). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s11506/a/3"},"text":"Pub. L. 117–58, § 11506(a)(3)","children":[],"tail":", inserted “, of which the counties of Brooke, Hancock, Marshall, and Ohio shall be considered to be located in the North Central subregion” after “West Virginia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/371/s7/a"},"text":"Pub. L. 110–371, § 7(a)","children":[],"tail":", inserted “Metcalfe,” after “Menifee,”, “Nicholas,” after “Morgan,”, and “Robertson,” after “Pulaski,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(H). ","children":[{"tag":"ref