{"tag":"section","attrib":{"id":"id80aa04f3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s606"},"text":null,"children":[{"tag":"num","attrib":{"value":"606"},"text":"§ 606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations related to operation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80aa04f4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s606/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Office of Personnel Management shall prescribe regulations to govern executive agencies in authorizing civilian personnel to operate Federal Government-owned motor vehicles for official purposes within the States of the United States, the District of Columbia, Puerto Rico, and the territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa04f5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s606/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements of the Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations shall prescribe standards of physical fitness for authorized operators. The regulations may require operators and prospective operators to obtain state and local licenses or permits that are required to operate similar vehicles for other than official purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa04f6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s606/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency Orders","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each executive agency shall issue orders and directives necessary for compliance with the regulations. The orders and directives shall provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa04f7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s606/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically testing the physical fitness of operators and prospective operators; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa04f8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s606/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspension and revocation of authority to operate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80aa04f9-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1123"},"text":"116 Stat. 1123","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80aa04fa-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80aa04fb-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80aa04fc-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"606","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:491(j).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title II, § 211(j), as added "},{"tag":"html:a","attrib":{"href":"/us/act/1950-09-05/ch849/s5/c"},"text":"Sept. 5, 1950, ch. 849, § 5(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/583"},"text":"64 Stat. 583","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1954-09-01/ch1211/s2"},"text":"Sept. 1, 1954, ch. 1211, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/1128"},"text":"68 Stat. 1128","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/86/624/s27/b"},"text":"Pub. L. 86–624, § 27(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/418"},"text":"74 Stat. 418","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Director of the Office of Personnel Management” are substituted for “United States Civil Service Commission” in section 211(j) of the Federal Property and Administrative Services Act of 1949 because of section 102 of Reorganization Plan No. 2 of 1978 (eff. ","children":[{"tag":"date","attrib":{"date":"1979-01-01"},"text":"Jan. 1, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3783"},"text":"92 Stat. 3783","children":[],"tail":"). The words “territories and” are added for consistency in the revised title and with other titles of the United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
