{"tag":"section","attrib":{"id":"id80e5ae8a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15309"},"text":null,"children":[{"tag":"num","attrib":{"value":"15309"},"text":"§ 15309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e5ae8b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the last day of each fiscal year, each Commission shall submit to the President and Congress a report on the activities carried out by the Commission under this subtitle in the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5ae8c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5ae8d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15309/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the criteria used by the Commission to designate counties under section 15702 and a list of the counties designated in each category;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae8e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15309/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the progress of the Commission in meeting the goals identified in the Commission’s economic and infrastructure development plan under section 15303 and State economic and infrastructure development plans under section 15502; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae8f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15309/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any policy recommendations approved by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e5ae90-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14217/a/2"},"text":"Pub. L. 110–234, title XIV, § 14217(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1474"},"text":"122 Stat. 1474","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14217(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2236, § 15308; renumbered § 15309 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII"},"text":"Pub. L. 118–272, div. B, title II","children":[],"tail":", §§ 2242(e), 2243(a)(1), "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3203"},"text":"138 Stat. 3203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e5ae91-3a70-11f1