{"tag":"section","attrib":{"id":"id80bacd9a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3314"},"text":null,"children":[{"tag":"num","attrib":{"value":"3314"},"text":"§ 3314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Baby changing facilities in restrooms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80bacd9b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Requirement for the Construction, Alteration, and Acquisition of Public Buildings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b) and subject to any reasonable accommodations that may be made for individuals in accordance with the Americans with Disabilities Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"42 U.S.C. 12101","children":[],"tail":" et seq.) restrooms in a public building shall be equipped with baby changing facilities that the Administrator determines are physically safe, sanitary, and appropriate."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bacd9c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirement under subsection (a) shall not apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bacd9d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3314/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a restroom in a public building that is not available or accessible for public use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacd9e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3314/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a restroom in a public building that contains clear and conspicuous signage indicating where a restroom with a baby changing table is located on the same floor of such public building;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacd9f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3314/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if new construction would be required to install a baby changing facility in the public building and the cost of such construction is unfeasible; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacda0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3314/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a building not subject to an alteration as set forth in section 3307.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bacda1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bacda2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3314/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Baby changing facility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “baby changing facility” means a table or other device suitable for changing the diaper of a child age 3 or under.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacda3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3314/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pubic ","children":[],"tail":null},{"tag":"ref","attrib":{"idref":"fn002020"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002020"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “"},{"tag":"inline","attrib":{},"text":"Public","children":[],"tail":"”."}],"tail":null},{"tag":"inline","attrib":{},"text":" building","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “public building” means a public building as defined in section 3301 and controlled by the Public Building Service of the General Services Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80bacda4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/235/s2/a/2"},"text":"Pub. L. 114–235, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"Oct. 7, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/964"},"text":"130 Stat. 964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80bacda5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80bacda6-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80bacda7-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Americans with Disabilities Act, referred to in subsec. (a), probably means the Americans with Disabilities Act of 1990, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336"},"text":"Pub. L. 101–336","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/327"},"text":"104 Stat. 327","children":[],"tail":", which is classified principally to chapter 126 (§ 12101 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"section 12101 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id80bacda8-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3314 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3315"},"text":"section 3315 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80bacda9-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80bacdaa-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/235/s2/c"},"text":"Pub. L. 114–235, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"Oct. 7, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/965"},"text":"130 Stat. 965","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/235/s2/c"},"text":"“The requirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3314/a"},"text":"section 3314(a) of title 40","children":[],"tail":", United States Code, shall apply in the case of a public building constructed, altered, or acquired by the Administrator of General Services on or after the date that is 1 year after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"Oct. 7, 2016","children":[],"tail":"], beginning on that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
