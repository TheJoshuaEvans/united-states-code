{"tag":"section","attrib":{"id":"id80ecda6e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18304"},"text":null,"children":[{"tag":"num","attrib":{"value":"18304"},"text":"§ 18304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for enforcement of awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80ecda6f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modifications and Finality of Award","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 10 days after the parties receive an arbitration award to which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s18303"},"text":"section 18303 of this title","children":[],"tail":" applies, the interstate compact agency and the employees, through their representative, may agree in writing on any modifications to the award. After the end of that 10-day period, the award, and any modifications, become binding on the interstate compact agency, the employees in the bargaining unit, and the employees’ representative."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ecda70-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each party to an award that becomes binding under subsection (a) shall take all actions necessary to implement the award.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ecda71-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judicial Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 60 days after an award becomes binding under subsection (a), the interstate compact agency or the exclusive representative of the employees concerned may bring a civil action in a court that has jurisdiction over the interstate compact agency for review of the award. The court shall review the award on the record, and shall vacate the award or any part of the award, after notice and a hearing, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ecda72-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the award is in violation of applicable law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda73-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the arbitrator exceeded the arbitrator’s powers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda74-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18304/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decision by the arbitrator is arbitrary or capricious;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda75-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18304/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the arbitrator conducted the hearing contrary to the provisions of this chapter or other laws or rules that apply to the arbitration so as to substantially prejudice the rights of a party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda76-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18304/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there was partiality or misconduct by the arbitrator prejudicing the rights of a party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda77-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18304/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the award was procured by corruption, fraud, or bias on the part of the arbitrator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda78-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18304/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the arbitrator did not comply with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s18303"},"text":"section 18303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ecda79-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1294"},"text":"116 Stat. 1294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ecda7a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ecda7b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ecda7c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"18304","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1304.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/104/50/tIV/s405"},"text":"Pub. L. 104–50, title IV, § 405","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 15, 1995","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/109/465"},"text":"109 Stat. 465","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
