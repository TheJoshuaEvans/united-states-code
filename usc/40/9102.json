{"tag":"section","attrib":{"id":"id80d02b09-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s9102"},"text":null,"children":[{"tag":"num","attrib":{"value":"9102"},"text":"§ 9102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80d02b0a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s9102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission of Fine Arts shall advise on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80d02b0b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s9102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of statues, fountains, and monuments in the public squares, streets, and parks in the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02b0c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s9102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the selection of models for statues, fountains, and monuments erected under the authority of the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02b0d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s9102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the selection of artists to carry out clause (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02b0e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s9102/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" questions of art generally when required to do so by the President or a committee of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d02b0f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s9102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duty To Request Advice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The officers required to decide the questions described in subsection (a)(1)–(3) shall request the Commission to provide the advice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d02b10-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s9102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to the Capitol Building and the Library of Congress buildings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80d02b11-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1232"},"text":"116 Stat. 1232","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80d02b12-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndR