{"tag":"section","attrib":{"id":"id80c44340-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6504"},"text":null,"children":[{"tag":"num","attrib":{"value":"6504"},"text":"§ 6504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease of building","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c44341-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lease Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under an agreement with the person selected to construct the Thurgood Marshall Federal Judiciary Building, the Architect of the Capitol shall lease the Building to carry out the objectives of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c44342-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Requirements of Lease Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agreement includes at a minimum the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c44343-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limit on length of lease","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Architect will lease the Building and other improvements for not more than 30 years from the effective date of the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44344-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rental rate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The rental rate per square foot of occupiable space for all space in the Building and other improvements will be in the best interest of the Federal Government and will carry out the objectives of this chapter. The aggregate rental rate for all space in the Building and other improvements shall produce an amount at least equal to the amount necessary to amortize the cost of development of squares 721 and 722 in the District of Columbia over the life of the lease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44345-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6504/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to make space available and sublease space","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Architect may make space available and sublease space in the Building and other improvements in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6506"},"text":"section 6506 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44346-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6504/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other terms and conditions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The agreement contains terms and conditions the Architect prescribes to carry out the objectives of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c44347-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obligation of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Obligation of amounts for lease payments under this section may only be made—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c44348-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on an annual basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44349-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the account described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6507"},"text":"section 6507 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c4434a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1189"},"text":"116 Stat. 1189","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c4434b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{