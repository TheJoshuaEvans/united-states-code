{"tag":"section","attrib":{"id":"id80ecda2e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18103"},"text":null,"children":[{"tag":"num","attrib":{"value":"18103"},"text":"§ 18103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80ecda2f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support for Research","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services, in consultation with the Federal Communications Commission, shall seek to promote research by federal agencies, state agencies, and private entities to reduce the cost and improve the capabilities of telecommunications devices and systems that provide accessibility to hearing-impaired and speech-impaired individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ecda30-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning To Assimilate Technological Developments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In planning future alterations to and modifications of the federal telecommunications system, the Administrator shall take into account—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ecda31-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modifications that the Administrator determines are necessary to achieve the objectives of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s18102/a"},"text":"section 18102(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda32-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technological improvements in telecommunications devices and systems that provide accessibility to hearing-impaired and speech-impaired individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ecda33-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1291"},"text":"116 Stat. 1291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ecda34-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ecda35-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ecda36-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and R