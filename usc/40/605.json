b. L. 109–313","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/313/s6"},"text":"section 6 of Pub. L. 109–313","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
