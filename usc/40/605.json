{"tag":"section","attrib":{"id":"id80aa04e5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s605"},"text":null,"children":[{"tag":"num","attrib":{"value":"605"},"text":"§ 605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80aa04e6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Acquisition Services Fund To Cover Costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Acquisition Services Fund provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s321"},"text":"section 321 of this title","children":[],"tail":" is available for use by or under the direction and control of the Administrator of General Services to pay the costs of carrying out "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s602"},"text":"section 602 of this title","children":[],"tail":", including the cost of purchasing or renting motor vehicles and related equipment and supplies."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa04e7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Setting Prices To Recover Costs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa04e8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s605/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall set prices for furnishing motor vehicles and related services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s602"},"text":"section 602 of this title","children":[],"tail":". Prices shall be set to recover, so far as practicable, all costs of carrying out "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s602"},"text":"section 602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa04e9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s605/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Increment for replacement cost","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the Administrator’s discretion, prices may include an increment for the estimated replacement cost of motor vehicles and related equipment and supplies. Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s321/f"},"text":"section 321(f) of this title","children":[],"tail":", the increment may be retained as a part of the capital of the Acquisition Services Fund but is available only to replace motor vehicles and related equipment and supplies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa04ea-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s605/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accounting Method","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purchase price of motor vehicles and related equipment, and any increment for estimated replacement cost, shall be recovered only through charges for the cost of amortization. Costs shall be determined, and financial reports prepared, in accordance with the accrual accounting method.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80aa04eb-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1123"},"text":"116 Stat. 1123","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/313/s3/h/6"},"text":"Pub. L. 109–313, § 3(h)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1736"},"text":"120 Stat. 1736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80aa04ec-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80aa04ed-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80aa04ee-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[