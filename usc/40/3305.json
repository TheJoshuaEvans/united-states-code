{"tag":"section","attrib":{"id":"id80b85cd8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3305"},"text":null,"children":[{"tag":"num","attrib":{"value":"3305"},"text":"§ 3305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction and alteration of buildings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80b85cd9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b85cda-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Replacement of existing buildings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the Administrator of General Services considers it to be in the best interest of the Federal Government to construct a new public building to take the place of an existing public building, the Administrator may demolish the existing building and use the site on which it is located for the site of the proposed public building. If the Administrator believes that it is more advantageous to construct the public building on a different site in the same city, the Administrator may exchange the building and site, or the site, for another site, or may sell the building and site in accordance with subtitle I of this title and division C (except sections 3302, 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b85cdb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sale or exchange of sites","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the Administrator decides that a site acquired for the construction of a public building is not suitable for that purpose, the Administrator may exchange the site for another site, or may sell it in accordance with subtitle I of this title and division C (except sections 3302, 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b85cdc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3305/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Committee approval required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection does not permit the Administrator to use any land as a site for a public building if the project has not been approved in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3307"},"text":"section 3307 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b85cdd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alteration of Buildings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b85cde-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to alter buildings and acquire land","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80b85cdf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3305/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alter any public building; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b85ce0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3305/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire in accordance with section 3304(b)–(d) of this title land necessary to carry out the alteration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b85ce1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Committee approval not required.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80b85ce2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3305/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Threshold amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Approval under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3307"},"text":"section 3307 of this title","children":[],"tail":" is not required for any alteration and acquisition authorized by this subsection for which the estimated maximum cost does not exceed $1,500,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b85ce3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3305/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dollar amount adjustment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator annually may adjust the dollar amount referred to in subparagraph (A) to reflect a percentage increase or decrease in construction costs during the prior calendar year, as determined by the composite index of construction costs of the Department of Commerce. Any adjustment shall be expeditiously reported to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b85ce4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction or Alteration by Contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may carry out any construction or alteration authorized by this chapter by contract if the Administrator considers it to be most advantageous to the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b85ce5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1159"},"text":"116 Stat. 1159","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5"},"text":"Pub. L. 111–350, § 5","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(16), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3852"},"text":"124 Stat. 3852","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b85ce6-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b85ce7-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80b85ce8-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. 