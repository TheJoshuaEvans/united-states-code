{"tag":"section","attrib":{"id":"id80b85cb5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3303"},"text":null,"children":[{"tag":"num","attrib":{"value":"3303"},"text":"§ 3303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing investigation and survey of public buildings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80b85cb6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conducted by Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of General Services shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b85cb7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a continuing investigation and survey of the public buildings needs of the Federal Government so that the Administrator may carry out the duties of the Administrator under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b85cb8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress prospectuses of proposed projects in accordance with section 3307(a) and (b) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b85cb9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation with Federal Agencies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b85cba-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties of administrator","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the duties of the Administrator under this chapter, the Administrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80b85cbb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3303/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall cooperate with all federal agencies in order to keep informed of their needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b85cbc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3303/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall advise each federal agency of the program with respect to the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b85cbd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3303/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may request the cooperation and assistance of each federal agency in carrying out duties under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b85cbe-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duty of federal agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each federal agency shall cooperate with, advise, and assist the Administrator in carrying out the duties of the Administrator under this chapter as determined necessary by the Administrator to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b85cbf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Request for Identification of Existing Buildings of Historical, Architectural, or Cultural Significance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"When the Administrator undertakes a survey of the public buildings needs of the Government within a geographical area, the Administrator shall request that, within 60 days, the Advisory Council on Historic Preservation established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s304101"},"text":"section 304101 of title 54","children":[],"tail":" identify any existing buildings in the geographical area that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b85cc0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are of historical, architectural, or cultural significance (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3306/a"},"text":"section 3306(a) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b85cc1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether or not in need of repair, alteration, or addition, would be suitable for acquisition to meet the public buildings needs of the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b85cc2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standard for Construction and Acquisition of Public Buildings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the duties of the Administrator under this chapter, the Administrator shall provide for the construction and acquisition of public buildings equitably throughout the United States with due regard to the comparative urgency of the need for each particular building. In developing plans for new buildings, the Administrator shall give due consideration to excellence of architecture and design.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b85cc3-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1158"},"text":"116 Stat. 1158","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s5/j/5"},"text":"Pub. L. 113–287, § 5(j)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3269"},"text":"128 Stat. 3269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attr