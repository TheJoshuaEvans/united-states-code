{"tag":"section","attrib":{"id":"id80a7ba49-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590"},"text":null,"children":[{"tag":"num","attrib":{"value":"590"},"text":"§ 590.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80a7ba4a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance, Assistance, and Oversight","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Through the General Services Administration’s licensing agreements, the Administrator of General Services shall provide guidance, assistance, and oversight to federal agencies for the development of child care centers to provide economical and effective child care for federal workers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a7ba4b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allotment of Space in Federal Buildings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a7ba4c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the following definitions apply:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a7ba4d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Child care provider","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “child care provider” means an individual or entity that provides or proposes to provide child care services for federal employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a7ba4e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allotment officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “allotment officer” means an officer or agency of the Federal Government charged with the allotment of space in federal buildings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba4f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allotment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A child care provider may be allotted space in a federal building by an allotment officer if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a7ba50-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the child care provider applies to the allotment officer in the community or district in which child care services are to be provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a7ba51-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the space is available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a7ba52-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the allotment officer determines that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80a7ba53-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the space will be used to provide child care services to children of whom at least 50 percent have one parent or guardian employed by the Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80a7ba54-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the child care provider will give priority to federal employees for available child care services in the space.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a7ba55-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment for Space and Services.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a7ba56-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this subsection, the term “services” includes the providing of lighting, heating, cooling, electricity, office furniture, office machines and equipment, classroom furnishings and equipment, kitchen appliances, playground equipment, telephone service (including installation of lines and equipment and other expenses associated with telephone services), and security systems (including installation and other expenses associated with security systems), including replacement equipment, as needed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba57-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No charge","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Space allotted under subsection (b) may be provided without charge for rent or services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba58-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement for costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For space allotted under subsection (b), if there is an agreement for the payment of costs associated with providing space or services, neither title 31, nor any other law, prohibits or restricts payment by reimbursement to the miscellaneous receipts or other appropriate account of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a7ba59-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Other Costs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an agency has a child care facility in its space, or is a sponsoring agency for a child care facility in other federal or leased space, the agency or the Administration may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a7ba5a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay accreditation fees, including renewal fees, for the child care facility to be accredited by a nationally recognized early-childhood professional organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba5b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay travel and per diem expenses for representatives of the child care facility to attend the annual Administration child care conference; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba5c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into a consortium with one or more private entities under which the private entities assist in defraying costs associated with the salaries and benefits for personnel providing services at the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a7ba5d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement for Employee Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1345"},"text":"section 1345 of title 31","children":[],"tail":", an agency, department, or instrumentality of the Government that provides or proposes to provide child care services for federal employees may reimburse a federal employee or any individual employed to provide child care services for travel, transportation, and subsistence expenses incurred for training classes, conferences, or other meetings in connection with providing the services. A per diem allowance made under this subsection may not exceed the rate specified in regulations prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5707"},"text":"section 5707 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a7ba5e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal History Background Checks.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a7ba5f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “executive facility” means a facility owned or leased by an office or entity within the executive branch of the Government. The term includes a facility owned or leased by the General Services Administration on behalf of an office or entity within the judicial branch of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba60-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All workers in a child care center located in an executive facility shall undergo a criminal history background check as defined in section 231 of the Crime Control Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13041"},"text":"42 U.S.C. 13041","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn002011"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002011"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba61-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication to legislative branch facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection does not apply to a facility owned by or leased on behalf of an office or entity within the legislative branch of the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a7ba62-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriated Amounts for Affordable Child Care.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a7ba63-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this subsection, the term “Executive agency” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":", but does not include the Government Accountability Office."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba64-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In accordance with regulations the Office of Personnel Management prescribes, an Executive agency that provides or proposes to provide child care services for federal employees may use appropriated amounts that are otherwise available for salaries and expenses to provide child care in a federal or leased facility, or through contract, for civilian employees of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba65-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affordability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts used pursuant to paragraph (2) shall be applied to improve the affordability of child care for lower income federal employees using or seeking to use the child care services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba66-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3324"},"text":"section 3324 of title 31","children":[],"tail":", amounts may be paid in advance to licensed or regulated child care providers for services to be rendered during an agreed period."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba67-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No amounts made available by law may be used to implement this subsection without advance notice to the Committees on Appropriations of the House of Representatives and the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba68-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to house of representatives","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall apply with respect to the House of Representatives in the same manner as it applies to an Executive agency, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a7ba69-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/g/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority granted to the Office of Personnel Management shall be exercised with respect to the House of Representatives by the Speaker of the House of Representatives in accordance with regulations promulgated by the Committee on House Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a7ba6a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/g/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts may be made available to implement this subsection with respect to the House of Representatives without advance notice to the Committee on Appropriations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba6b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/g/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to senate","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall apply with respect to the Senate in the same manner as it applies to an Executive agency, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a7ba6c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/g/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority granted to the Office of Personnel Management shall be exercised with respect to the Senate, by the Majority and Minority Leaders of the Senate, in accordance with regulations promulgated by the Committee on Rules and Administration of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a7ba6d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s590/g/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts may be made available to implement this subsection with respect to the Senate without advance notice to the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80a7ba6e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1116"},"text":"116 Stat. 1116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dI/tI/s117/a"},"text":"Pub. L. 117–328, div. I, title I, § 117(a)","children":[],"t