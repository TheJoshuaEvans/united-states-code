{"tag":"section","attrib":{"id":"id80bacdfa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3501"},"text":null,"children":[{"tag":"num","attrib":{"value":"3501"},"text":"§ 3501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bacdfb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “public agency” means a State or a public agency or political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacdfc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public works","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “public works” includes any public works other than housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacdfd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” means a State of the United States, the District of Columbia, Puerto Rico, Guam, the Virgin Islands, the Northern Mariana Islands, the Federated States of Micronesia, the Marshall Islands, Palau, and any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80bacdfe-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1167"},"text":"116 Stat. 1167","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80bacdff-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80bace00-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80bace01-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3501","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:460.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-08-02/ch649"},"text":"Aug. 2, 1954, ch. 649","children":[],"tail":", title VII, § 703, "},{"tag":"html:a","attrib":{"href":"/us/stat/68/641"},"text":"68 Stat. 641","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/90/19/s10/d"},"text":"Pub. L. 90–19, § 10(d)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/81/22"},"text":"81 Stat. 22","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/93/383/tIV/s401/c"},"text":"Pub. L. 93–383, title IV, § 401(c)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/691"},"text":"88 Stat. 691","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the text of 40:460(2) is omitted as unnecessary because the complete name of the Secretary of Housing and Urban Development is used the first time the term appears in a section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the words “or ‘public agencies’ ” are omitted as unnecessary because of 1:1.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (3), the words “Guam, the Virgin Islands” are added to clarify that the provisions of the source law apply to those jurisdictions. The words “the Northern Mariana Islands, the Federated States of Micronesia, the Marshall Islands, Palau” are substituted for “the Trust Territory of the Pacific Islands” because of the termination of the Trust Territory of the Pacific Islands. See 48:1681 note prec.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
