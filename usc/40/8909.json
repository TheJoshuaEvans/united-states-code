{"tag":"section","attrib":{"id":"id80d02af4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8909"},"text":null,"children":[{"tag":"num","attrib":{"value":"8909"},"text":"§ 8909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80d02af5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8909/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance of Documentation of Design and Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Complete documentation of design and construction of each commemorative work located in the District of Columbia and its environs shall be provided to the Secretary of the Interior or Administrator of General Services, as appropriate, and shall be permanently maintained in the manner provided by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d02af6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8909/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibility for Maintenance of Completed Work","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On completion of any commemorative work in the District of Columbia and its environs, the Secretary or Administrator, as appropriate, shall assume responsibility for maintaining the work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d02af7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8909/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations or Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary and Administrator shall prescribe appropriate regulations or standards to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80d02af8-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1231"},"text":"116 Stat. 1231","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80d02af9-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80d02afa-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80d02afb-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[