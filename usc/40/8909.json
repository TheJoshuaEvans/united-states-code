t":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8909(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1010(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/99/652/s10/d"},"text":"Pub. L. 99–652, § 10(d)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3654"},"text":"100 Stat. 3654","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/321/s2/g"},"text":"Pub. L. 103–321, § 2(g)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/1795"},"text":"108 Stat. 1795","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80d02afc-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80d02afd-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Waiver of Special Use Permit Application Fee for Veterans’ Special Events","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tVI/s642"},"text":"Pub. L. 117–328, div. DD, title VI, § 642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5612"},"text":"136 Stat. 5612","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dDD/tVI/s642"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Member of a gold star family","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘member of a Gold Star Family’ means any individual that meets the eligibility requirements of section 3.2 of Department of Defense Instruction 1348.36 (or a successor instruction).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special events","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘special events’ has the meaning given the term in section 7.96(g)(1) of title 36, Code of Federal Regulations (or a successor regulation).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"The district of columbia and its environs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘the District of Columbia and its environs’ has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s8902/a"},"text":"section 8902(a) of title 40","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Veteran","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘veteran’ has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of title 38","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Veterans’ special event","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘veterans’ special event’ means a special event at which the majority of attendees are veterans or members of Gold Star Families.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"War memorial","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘war memorial’ means any memorial or monument that has been erected or dedicated to commemorate a military unit, military group, war, conflict, victory, or peace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The application fee for any application for a special use permit, the sole purpose of which is to hold a veterans’ special event at a war memorial on land administered by the National Park Service in the District of Columbia and its environs, shall be waived.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Existing Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (b), an applicant for a special use permit described in that subsection shall be subject to any other law (including regulations) or policy applicable to the application, issuance, or execution of the special use permit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall apply to any special use permit application submitted after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
