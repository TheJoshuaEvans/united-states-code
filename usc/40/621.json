{"tag":"section","attrib":{"id":"id80aa0521-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s621"},"text":null,"children":[{"tag":"num","attrib":{"value":"621"},"text":"§ 621.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa0522-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s621/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Administrator” means the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0523-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s621/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Council","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Council” means the Federal Real Property Council established by section 623(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0524-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s621/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Director” means the Director of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0525-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s621/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal agency","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80aa0526-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s621/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an executive department or independent establishment in the executive branch of the Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa0527-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s621/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a wholly owned Government corporation (other than the United States Postal Service).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0528-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s621/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Field office","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “field office” means any office of a Federal agency that is not the headquarters office location for the Federal agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0529-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s621/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Postal property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “postal property” means any property owned or leased by the United States Postal Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa052a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s621/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public-private partnership","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “public-private partnership” means any partnership or working relationship between a Federal agency and a corporation, individual, or nonprofit organization for the purpose of financing, constructing, operating, managing, or maintaining one or more Federal real property assets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa052b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s621/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Underutilized property","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “underutilized property” means a portion or the entirety of any real property, including any improvements, that is used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80aa052c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s621/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" irregularly or intermittently by the accountable Federal agency for program purposes of the Federal agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa052d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s621/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for program purposes that can be satisfied only with a portion of the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80aa052e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/318/s3/a"},"text":"Pub. L. 114–318, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1608"},"text":"130 Stat. 1608","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80aa052f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80aa0530-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80aa0531-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/318/s2"},"text":"Pub. L. 114–318, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1608"},"text":"130 Stat. 1608","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/318/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The purpose of this Act [see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/318/s1"},"text":"section 1 of Pub. L. 114–318","children":[],"tail":", set out as a Short Title of 2016 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s101"},"text":"section 101 of this title","children":[],"tail":"] is to increase the efficiency and effectiveness of the Federal Government in managing property of the Federal Government by—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring the United States Postal Service to take appropriate measures to better manage and account for property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for increased collocation with Postal Service facilities and guidance on Postal Service leasing practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a Federal Real Property Council to develop guidance on and ensure the implementation of strategies for better managing Federal property.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
