{"tag":"section","attrib":{"id":"id80cb6f72-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8502"},"text":null,"children":[{"tag":"num","attrib":{"value":"8502"},"text":"§ 8502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Capital Service Director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80cb6f73-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is in the Executive Office of the President the National Capital Service Director who shall be appointed by the President. The Director shall receive compensation at the maximum rate established for level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80cb6f74-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director may appoint and fix the rate of compensation of necessary personnel, subject to chapters 33 and 51 and subchapter III of chapter 53 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80cb6f75-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80cb6f76-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"President","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President, through the Director and using District of Columbia governmental services to the extent practicable, shall ensure that there is provided in the area described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s8501/a"},"text":"section 8501(a) of this title","children":[],"tail":" adequate fire protection and sanitation services."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cb6f77-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except with respect to that part of the National Capital Service Area comprising the United States Capitol Buildings and Grounds as defined and described in sections 5101 and 5102 of this title, the Supreme Court Building and grounds as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6101"},"text":"section 6101 of this title","children":[],"tail":", and the Library of Congress buildings and grounds as defined in "},{"tag":"ref","attrib":{"href":"/us/act/1950-08-04/s11"},"text":"section 11 of the Act of August 4, 1950","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t2/s167j"},"text":"2 U.S.C. 167j","children":[],"tail":"), the Director shall ensure that there is provided in the remainder of the area described in "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s8501/a"},"text":"section 8501(a) of this title","children":[],"tail":" adequate police protection and maintenance of streets and highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80cb6f78-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1215"},"text":"116 Stat. 1215","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s6/25"},"text":"Pub. L. 109–284, § 6(25)","children":[],"tail":", (26), "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1213"},"text":"120 Stat. 1213","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80cb6f79-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80cb6f7a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80cb6f7b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8502(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:136(b) (1st sentence), (c) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/93/198/tVII/s739/b"},"text":"Pub. L. 93–198, title VII, § 739(b)","children":[],"tail":", (c), "},{"tag":"html:span","attrib":{},"text":"Dec. 24, 1973","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/87/825"},"text":"87 Stat. 825","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8502(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:136(c) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8502(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:136(b) (2d, last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “from time to time” and “of section 5314 [sic] of title 5” are omitted as unnecessary. [The words “of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"” were not omitted.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the reference to chapter 33 of title 5 is substituted for “the provisions of title 5 governing appointments in the competitive service” for clarity and for consistency in the revised title and with other titles of the United States Code. The words “subchapter III” are substituted for “subchapter 3” to correct an error in the source provision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80cb6f7c-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80cb6f7d-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284/s6/25"},"text":"Pub. L. 109–284, § 6(25)","children":[],"tail":", substituted “5315” for “5314”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284/s6/26"},"text":"Pub. L. 109–284, § 6(26)","children":[],"tail":", inserted “of this title” after “sections 5101 and 5102”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
