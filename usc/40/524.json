{"tag":"section","attrib":{"id":"id809962f7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524"},"text":null,"children":[{"tag":"num","attrib":{"value":"524"},"text":"§ 524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of executive agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id809962f8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each executive agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id809962f9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain adequate inventory controls and accountability systems for property under its control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809962fa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuously survey property under its control to identify excess property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809962fb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promptly report excess property to the Administrator of General Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809962fc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform the care and handling of excess property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809962fd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer or dispose of excess property as promptly as possible in accordance with authority delegated and regulations prescribed by the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809962fe-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop current and future workforce projections so as to have the capacity to assess the needs of the Federal workforce regarding the use of real property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809962ff-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish goals and policies that will lead the executive agency to reduce excess property and underutilized property in the inventory of the executive agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80996300-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Federal Real Property Council an annual report on all excess property that is real property and underutilized property in the inventory of the executive agency, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80996301-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether underutilized property can be better utilized, including through collocation with other executive agencies or consolidation with other facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80996302-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the executive agency believes that retention of the underutilized property serves the needs of the executive agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80996303-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt workplace practices, configurations, and management techniques that can achieve increased levels of productivity and decrease the need for real property assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80996304-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess leased space to identify space that is not fully used or occupied;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80996305-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on an annual basis and subject to the guidance of the Federal Real Property Council—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80996306-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an inventory of real property under control of the executive agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80996307-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make an assessment of each property, which shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80996308-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/11/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the age and condition of the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80996309-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/11/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the size of the property in square footage and acreage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8099630a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/11/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographical location of the property, including an address and description;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8099630b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/11/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the property is being utilized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8099630c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/11/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual annual operating costs associated with the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8099630d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/11/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost of capital expenditures incurred by the Federal Government associated with the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8099630e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/11/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sustainability metrics associated with the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8099630f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/11/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Federal employees and contractor employees and functions housed at the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80996310-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/11/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the mission of the executive agency is dependent on the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80996311-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/11/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated amount of capital expenditures projected to maintain and operate the property during the 5-year period beginning on the date of enactment of this paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80996312-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/11/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional information required by the Administrator of General Services to carry out section 623;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80996313-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the Federal Real Property Council and the Administrator of General Services the information described in paragraph (11)(B) to be used for the establishment and maintenance of the database described in section 21 of the Federal Assets Sale and Transfer Act of 2016; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80996314-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with guidance from the Administrator of General Services—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80996315-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on an annual basis, conduct an inventory and assessment of capitalized personal property to identify excess capitalized personal property under its control, including evaluating—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80996316-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/13/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the age and condition of the personal property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80996317-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/13/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the executive agency utilizes the personal property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80996318-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/13/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the mission of the executive agency is dependent on the personal property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80996319-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/13/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other aspect of the personal property that the Administrator determines is useful or necessary for the executive agency to evaluate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8099631a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on a regular basis, conduct an inventory and assessment of accountable personal property under its control, including evaluating—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8099631b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/13/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the age and condition of the personal property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8099631c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/13/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the executive agency utilizes the personal property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8099631d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/13/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the mission of the executive agency is dependent on the personal property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8099631e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/a/13/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other aspect of the personal property that the Administrator determines is useful or necessary for the executive agency to evaluate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8099631f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required as Far as Practicable","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each executive agency, as far as practicable, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80996320-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reassign property to another activity within the agency when the property is no longer required for the purposes of the appropriation used to make the purchase;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80996321-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer excess property under its control to other federal agencies and to organizations specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s321/c/2"},"text":"section 321(c)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80996322-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain excess property from other federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80996323-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s524/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Executive Agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purpose of paragraphs (6) through (12) of subsection (a), the term “executive agency” shall have the meaning given the term “Federal agency” in section 621.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80996324-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1084"},"text":"116 Stat. 1084","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/318/s6"},"text":"Pub. L. 114–318, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1615"},"text":"130 Stat. 1615","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/419/s2/a"},"text":"Pub. L. 115–419, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-03"},"text":"Jan. 3, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5442"},"text":"132 Stat. 5442","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80996325-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80996326-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80996327-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"524(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:483(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[]