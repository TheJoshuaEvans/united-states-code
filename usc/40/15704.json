{"tag":"section","attrib":{"id":"id80e81f3e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15704"},"text":null,"children":[{"tag":"num","attrib":{"value":"15704"},"text":"§ 15704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspector General; records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e81f3f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of Inspector General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There shall be an Inspector General for the Commissions appointed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s403/a"},"text":"section 403(a) of title 5","children":[],"tail":". All of the Commissions shall be subject to a single Inspector General."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81f40-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records of a Commission.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81f41-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Commission shall maintain accurate and complete records of all its transactions and activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f42-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All records of a Commission shall be available for audit and examination by the Inspector General (including authorized representatives of the Inspector General).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81f43-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records of Recipients of Commission Assistance.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81f44-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15704/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A recipient of funds from a Commission under this subtitle shall maintain accurate and complete records of transactions and activities financed with the funds and report to the Commission on the transactions and activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f45-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All records required under paragraph (1) shall be available for audit by the Commission and the Inspector General (including authorized representatives of the Commission and the Inspector General).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81f46-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Audit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Inspector General shall audit the activities, transactions, and records of each Commission on an annual basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e81f47-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14217/a/2"},"text":"Pub. L. 110–234, title XIV, § 14217(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1480"},"text":"122 Stat. 1480","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14217(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2242; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/70"},"text":"Pub. L. 117–286, § 4(b)(70)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4350"},"text":"136 Stat. 4350","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e81f48-3a70-11f1-b817-