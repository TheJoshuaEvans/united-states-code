{"tag":"section","attrib":{"id":"id80e0f338-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502"},"text":null,"children":[{"tag":"num","attrib":{"value":"14502"},"text":"§ 14502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration health projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e0f339-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To demonstrate the value of adequate health facilities and services to the economic development of the Appalachian region, the Secretary of Health and Human Services may make grants for the planning, construction, equipment, and operation of multi-county demonstration health, nutrition, and child care projects, including hospitals, regional health diagnostic and treatment centers, and other facilities and services necessary for the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f33a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f33b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to provide amounts and make grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide amounts to the Appalachian Regional Commission for the support of its Health Advisory Committee and may make grants for expenses of planning necessary for the development and operation of demonstration health projects for the region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f33c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on available amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of a grant under this section for planning shall not be more than 75 percent of expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f33d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources of assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The federal contribution may be provided entirely from amounts authorized under this section or in combination with amounts provided under other federal or federal grant programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f33e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of law limiting the federal share in those other programs, amounts appropriated to carry out this section may be used to increase the federal share to the maximum percentage cost of a grant authorized by this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f33f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction and Equipment Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f340-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional uses for construction grants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under this section for construction may also be used for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e0f341-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the acquisition of privately owned facilities—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80e0f342-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not operated for profit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e0f343-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" previously operated for profit if the Commission finds that health services would not otherwise be provided in the area served by the facility if the acquisition is not made; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e0f344-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initial equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f345-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards for making grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Grants under this section for construction shall be made in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14523"},"text":"section 14523 of this title","children":[],"tail":" and shall not be incompatible with the applicable provisions of title VI of the Public Health Service Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s291"},"text":"42 U.S.C. 291","children":[],"tail":" et seq.), the Developmental Disabilities Assistance and Bill of Rights Act of 2000 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15001"},"text":"42 U.S.C. 15001","children":[],"tail":" et seq.), and other laws authorizing grants for the construction of health-related facilities, without regard to any provisions in those laws relating to appropriation authorization ceilings or to allotments among the States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f346-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on available amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grant for the construction or equipment of any component of a demonstration health project shall not be more than 80 percent of the cost.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f347-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources of assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The federal contribution may be provided entirely from amounts authorized under this section or in combination with amounts provided under other federal grant programs for the construction or equipment of health-related facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f348-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of law limiting the federal share in those other programs, amounts authorized under this section may be used to increase federal grants for component facilities of a demonstration health project to a maximum of 80 percent of the cost of the facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f349-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f34a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards for making grants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant for the operation of a demonstration health project shall not be made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e0f34b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless the facility is publicly owned, or owned by a public or private nonprofit organization, and is not operated for profit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e0f34c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after five years following the commencement of the initial grant for operation of the project, except that child development demonstrations assisted under this section during fiscal year 1979 may be approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14322"},"text":"section 14322 of this title","children":[],"tail":" for continued support beyond that period, on request of the State, if the Commission finds that no federal, state, or local amounts are available to continue the project; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e0f34d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless the Secretary of Health and Human Services is satisfied that the operation of the project will be conducted under efficient management practices designed to obviate operating deficits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f34e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on available amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under this section for the operation (including initial operating amounts and operating deficits, which include the cost of attracting, training, and retaining qualified personnel) of a demonstration health project, whether or not constructed with amounts authorized to be appropriated by this section, may be made for up to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e0f34f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the cost of that operation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e0f350-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which a distressed county designation is in effect under section 14526, 80 percent of the cost of that operation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e0f351-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out for a county for which an at-risk county designation is in effect under section 14526, 70 percent of the cost of that operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f352-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources of assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The federal contribution may be provided entirely from amounts appropriated to carry out this section or in combination with amounts provided under other federal grant programs for the operation of health related facilities and the provision of health and child development services, including parts A and B of title IV and title XX of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq., 620 et seq., 1397 et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f353-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of law limiting the federal share in those other programs, amounts appropriated to carry out this section may be used to increase federal grants for operating components of a demonstration health project to the maximum percentage cost of a grant authorized by this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f354-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State deemed to meet requirement of providing assistance or services on statewide basis","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s301"},"text":"42 U.S.C. 301","children":[],"tail":" et seq.) requiring assistance or services on a statewide basis, a State providing assistance or services under a federal grant program described in paragraph (2) in any area of the region approved by the Commission is deemed to be meeting that requirement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f355-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Sources and Use of Grants in Computing Allotments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f356-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made only out of amounts specifically appropriated for the purpose of carrying out this subtitle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f357-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be taken into account in computing allotments among the States under any other law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f358-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Commission Contribution.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f359-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraphs (2) and (3), the Commission may contribute not more than 50 percent of any project cost eligible for financial assistance under this section from amounts appropriated to carry out this subtitle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f35a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distressed counties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The maximum Commission contribution for a project to be carried out in a county for which a distressed county designation is in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14526"},"text":"section 14526 of this title","children":[],"tail":" may be increased to the lesser of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e0f35b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e0f35c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum federal contribution percentage authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f35d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"At-risk counties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The maximum Commission contribution for a project to be carried out in a county for which an at-risk county designation is in effect under section 14526 may be increased to the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e0f35e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 70 percent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e0f35f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum Federal contribution percentage authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f360-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14502/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Emphasis on Occupational Diseases From Coal Mining","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To provide for the further development of the Appalachian region’s human resources, grants under this section shall give special emphasis to programs and research for the early detection, diagnosis, and treatment of occupational diseases arising from coal mining, such as black lung.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e0f361-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1266"},"text":"116 Stat. 1266","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/371/s2/b"},"text":"Pub. L. 110–371, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4038"},"text":"122 Stat. 4038","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e0f362-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80e0f363-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80e0f364-3a70-11f1-b817-c08bf6d1fe2