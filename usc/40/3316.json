{"tag":"section","attrib":{"id":"id80bacdb9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3316"},"text":null,"children":[{"tag":"num","attrib":{"value":"3316"},"text":"§ 3316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80bacdba-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Request by Either House of Congress or Any Committee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within a reasonable time after a request of either House of Congress or any committee of Congress, the Administrator of General Services shall submit a report showing the location, space, cost, and status of each public building the construction, alteration, or acquisition of which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bacdbb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3316/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is to be under authority of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacdbc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3316/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was uncompleted as of the date of the request, or as of another date the request may designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bacdbd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3316/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Request of Committee on Public Works and Environment or Committee on Transportation and Infrastructure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator and the United States Postal Service shall make building project surveys requested by resolution by the Committee on Environment and Public Works of the Senate or the Committee on Transportation and Infrastructure of the House of Representatives, and within a reasonable time shall make a report on the survey to Congress. The report shall contain all other information required to be included in a prospectus of the proposed public building project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3307/b"},"text":"section 3307(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80bacdbe-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1166"},"text":"116 Stat. 1166","children":[],"tail":", § 3314; renumbered § 3315, "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIII/s323/c/1/A"},"text":"Pub. L. 110–140, title III, § 323(c)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1590"},"text":"121 Stat. 1590","children":[],"tail":"; renumbered § 3316, "},{"tag":"ref","attrib":{"href":"/us/pl/114/235/s2/a/1"},"text":"Pub. L. 114–235, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"Oct. 7, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/964"},"text":"130 Stat. 964","children":[],"tail":".)"}],"