":{},"text":"2024—Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/182"},"text":"Pub. L. 118–182","children":[],"tail":" added subsecs. (g) and (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8"},"text":"Pub. L. 111–8","children":[],"tail":" substituted “Federal Citizen Services” for “Consumer Information Center” and struck out “consumer” after “Federal Government”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8"},"text":"Pub. L. 111–8","children":[],"tail":" substituted “Federal Citizen Services” for “Consumer Information Center”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8094a855-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8094a856-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/182"},"text":"Pub. L. 118–182","children":[],"tail":" effective on the commencement of the first fiscal year after "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/182/s2/c"},"text":"section 2(c) of Pub. L. 118–182","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
