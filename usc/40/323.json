{"tag":"section","attrib":{"id":"id8094a839-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323"},"text":null,"children":[{"tag":"num","attrib":{"value":"323"},"text":"§ 323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer Information Center Fund ","children":[{"tag":"ref","attrib":{"idref":"fn002004"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002004"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Federal Citizen Services Fund”."}],"tail":null}],"tail":null},{"tag":"subsection","attrib":{"id":"id8094a83a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is in the Treasury a Federal Citizen Services Fund, General Services Administration, for the purpose of disseminating Federal Government information to the public and for other related purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8094a83b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Money shall be deposited into the Fund from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8094a83c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriations from the Treasury for Federal Citizen Services activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8094a83d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" user fees from the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8094a83e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimbursements from other federal agencies for costs of distributing publications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8094a83f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other income incident to Center ","children":[{"tag":"ref","attrib":{"idref":"fn002005"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002005"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. See 2009 Amendment notes below."}],"tail":" activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8094a840-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expenditures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Money deposited into the Fund is available for expenditure for Center ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" activities in amounts specified in appropriation laws. The Fund shall assume all liabilities, obligations, and commitments of the Center "},{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" account."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8094a841-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unobligated Balances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any unobligated balances at the end of a fiscal year remain in the Fund and are available for authorization in appropriation laws for subsequent fiscal years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8094a842-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gift Account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Center ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" may accept and deposit to this account gifts for purposes of defraying the costs of printing, publishing, and distributing consumer information and educational materials and undertaking other consumer information activities. In addition to amounts appropriated or otherwise made available, the Center "},{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" may expend the gifts for these purposes and any balance remains available for expenditure."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8094a843-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator may enter into agreements with federal agencies to provide services through the Fund on a fully reimbursable basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8094a844-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002006"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002006"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See Delayed Effective Date of Amendment note below."}],"tail":" "},{"tag":"inline","attrib":{},"text":"Requirement for Annual Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than September 30 of each year, the Administrator shall submit to the Committee on Oversight and Accountability of the House of Representatives and the Committee on Homeland Security and Governmental Affairs of the Senate a report that includes, at a minimum, a list of each program funded by expenditures during the previous fiscal year, or that have been funded by expenditures in the previous 5-year period, including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8094a845-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An explanation of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8094a846-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information about how the program is funded, including the amount of expenditures the program received in the previous fiscal year and total amount.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8094a847-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of reimbursements associated with or anticipated to be associated with the program from another source of funds or another agency, if applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8094a848-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of projects or initiatives associated with the program, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8094a849-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/g/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information about when the projects or initiatives were initiated and completed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8094a84a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/g/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding information, to the extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8094a84b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any additional information, data, or analysis used to determine the information estimated within the report, if applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8094a84c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":" "},{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8094a84d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Administrator” means the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8094a84e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s323/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expenditure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “expenditure” means any obligation of funds from the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8094a84f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1077"},"text":"116 Stat. 1077","children":[],"ta