{"tag":"section","attrib":{"id":"id80a08ef3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s556"},"text":null,"children":[{"tag":"num","attrib":{"value":"556"},"text":"§ 556.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of dredge vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80a08ef4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s556/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services, pursuant to sections 521 through 527, 529, and 549 of this title, may dispose of a United States Army Corps of Engineers vessel used for dredging, together with related equipment owned by the Federal Government and under the control of the Chief of Engineers, if the Secretary of the Army declares the vessel to be in excess of federal needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08ef5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s556/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recipients and Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Disposal under this section is accomplished—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a08ef6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s556/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" through sale or lease to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a08ef7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s556/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign government as part of a Corps of Engineers technical assistance program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a08ef8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s556/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a federal or state maritime academy for training purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a08ef9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s556/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a non-federal public body for scientific, educational, or cultural purposes; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08efa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s556/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through sale solely for scrap to foreign or domestic interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08efb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s556/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Dredging Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel described in subsection (a) shall not be disposed of under any law for the purpose of engaging in dredging activities within the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08efc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s556/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposit of Amounts Collected","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts collected from the sale or lease of a vessel or equipment under this section shall be deposited into the revolving fund authorized by section 101 (9th par.) of the Civil Functions Appropriation ","children":[{"tag":"ref","attrib":{"idref":"fn002009"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002009"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Appropriations”."}],"tail":" Act, 1954 ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s576"},"text":"33 U.S.C. 576","children":[],"tail":"), to be available, as provided in appropriation laws, for the operation and maintenance of vessels under the control of the Corps of Engineers."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80a08efd-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1102"},"text":"116 Stat. 1102","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80a08efe-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80a08eff-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80a08f00-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"556","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:483d.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/99/662/tIX/s945"},"text":"Pub. L. 99–662, title IX, § 945","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/4200"},"text":"100 Stat. 4200","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “U.S. Army Corps of Engineers” are substituted for “Corps of Engineers” for clarity. The words “Secretary of the Army” are substituted for “Secretary” because of section 2 of the Water Resources Development Act of 1986 (33:2201).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “U.S. Army Corps of Engineers” are substituted for “Corps of Engineers” for clarity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
