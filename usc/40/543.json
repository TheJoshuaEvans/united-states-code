{"tag":"section","attrib":{"id":"id809bd38d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s543"},"text":null,"children":[{"tag":"num","attrib":{"value":"543"},"text":"§ 543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of disposition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An executive agency designated or authorized by the Administrator of General Services to dispose of surplus property may do so by sale, exchange, lease, permit, or transfer, for cash, credit, or other property, with or without warranty, on terms and conditions that the Administrator considers proper. The agency may execute documents to transfer title or other interest in the property and may take other action it considers necessary or proper to dispose of the property under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id809bd38e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1086"},"text":"116 Stat. 1086","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id809bd38f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id809bd390-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id809bd391-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"t