{"tag":"section","attrib":{"id":"id80d02aa1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905"},"text":null,"children":[{"tag":"num","attrib":{"value":"8905"},"text":"§ 8905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Site and design approval","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80d02aa2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation on, and Submission of, Proposals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A sponsor authorized by law to establish a commemorative work in the District of Columbia and its environs may request a permit for construction of the commemorative work only after the following requirements are met:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80d02aa3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The sponsor must consult with the National Capital Memorial Advisory Commission regarding the selection of alternative sites and design concepts for the commemorative work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02aa4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submittal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Following consultation in accordance with clause (1), the Secretary of the Interior or the Administrator of General Services, as appropriate, must submit, on behalf of the sponsor, site and design proposals to the Commission of Fine Arts and the National Capital Planning Commission for their approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d02aa5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Decision Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In considering site and design proposals, the Commission of Fine Arts, National Capital Planning Commission, and the Secretary or Administrator (as appropriate) shall be guided by, but not limited by, the following criteria:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80d02aa6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Surroundings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the maximum extent possible, a commemorative work shall be located in surroundings that are relevant to the subject of the work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02aa7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Location","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A commemorative work shall be located so that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80d02aa8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it does not interfere with, or encroach on, an existing commemorative work; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80d02aa9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, it protects open space, existing public use, and cultural and natural resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02aaa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Material","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A commemorative work shall be constructed of durable material suitable to the outdoor environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02aab-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Landscape features","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Landscape features of commemorative works shall be compatible with the climate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02aac-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Museums","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No commemorative work primarily designed as a museum may be located on lands under the jurisdiction of the Secretary in Area I or in East Potomac Park as depicted on the map referenced in section 8902(2).","children":[{"tag":"ref","attrib":{"idref":"fn002031"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002031"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “8902(a)(2).”"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02aad-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Site-specific guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Capital Planning Commission and the Commission of Fine Arts may develop such criteria or guidelines specific to each site that are mutually agreed upon to ensure that the design of the commemorative work carries out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d02aae-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Donor Contributions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80d02aaf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acknowledgment of donor contribution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this subsection, the Secretary of the Interior or Administrator of General Services, as applicable, may permit a sponsor to acknowledge donor contributions at the commemorative work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02ab0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An acknowledgment under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80d02ab1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be displayed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80d02ab2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inside an ancillary structure associated with the commemorative work; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80d02ab3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of a manmade landscape feature at the commemorative work; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80d02ab4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conform to applicable National Park Service or General Services Administration guidelines for donor recognition, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02ab5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An acknowledgment under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80d02ab6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be limited to an appropriate statement or credit recognizing the contribution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80d02ab7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be displayed in a form in accordance with National Park Service and General Services Administration guidelines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80d02ab8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be displayed for a period of up to 10 years, with the display period to be commensurate with the level of the contribution, as determined in accordance with the plan and guidelines described in subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80d02ab9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be freestanding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80d02aba-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not be affixed to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80d02abb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/c/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any landscape feature at the commemorative work; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80d02abc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/c/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any object in a museum collection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02abd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The sponsor shall bear all expenses related to the display of donor acknowledgments under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02abe-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8905/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection shall apply to any commemorative work dedicated after ","children":[{"tag":"date","attrib":{"date":"2010-01-01"},"text":"January 1, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80d02abf-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1229"},"text":"116 Stat. 1229","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/126/tII"},"text":"Pub. L. 108–126, title II","children":[],"tail":", §§ 203(e), 204, "},{"tag":"date","attrib":{"date":"2003-11-17"},"text":"Nov. 17, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1351"},"text":"117 Stat. 1351","children":[],"tail":", 1352; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXX/s3054/c"},"text":"Pub. L. 113–291, div. B, title XXX, § 3054(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3807"},"text":"128 Stat. 3807","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80d02ac0-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80d02ac1-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80d02ac2-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8905(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1007(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/99/652/s7"},"text":"Pub. L. 99–652, § 7","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3652"},"text":"100 Stat. 3652","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/321/s2/d"},"text":"Pub. L. 103–321, § 2(d)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/1794"},"text":"108 Stat. 1794","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8905(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1007(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80d02ac3-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80d02ac4-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3054/c/1"},"text":"Pub. L. 113–291, § 3054(c)(1)","children":[],"tail":", struck out par. (7). Text read as follows: “Donor contributions to commemorative works shall not be acknowledged in any manner as part of the commemorative work or its site.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3054/c/2"},"text":"Pub. L. 113–291, § 3054(c)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126/s203/e/1/A"},"text":"Pub. L. 108–126, § 203(e)(1)(A)","children":[],"tail":", substituted “sponsor” for “person” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126/s203/e/1/B"},"text":"Pub. L. 108–126, § 203(e)(1)(B)","children":[],"tail":", inserted “Advisory” before “Commission” and substituted “design concepts” for “designs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126/s203/e/2/A"},"text":"Pub. L. 108–126, § 203(e)(2)(A)","children":[],"tail":", substituted “and the Secretary or Administrator (as appropriate)” for “Secretary, and Administrator” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126/s203/e/2/B"},"text":"Pub. L. 108–126, § 203(e)(2)(B)","children":[],"tail":", substituted “open space, existing public use, and cultural and natural resources.” for “open space and existing public use.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126/s204"},"text":"Pub. L. 108–126, § 204","children":[],"tail":", added pars. (5) to (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80d02ac5-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id80d02ac6-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126"},"text":"Pub. L. 108–126","children":[],"tail":" not applicable to a commemorative work for which a site was approved in accordance with this chapter prior to "},{"tag":"date","attrib":{"date":"2003-11-17"},"text":"Nov. 17, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/126/s205"},"text":"section 205 of Pub. L. 108–126","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s8901"},"text":"section 8901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
