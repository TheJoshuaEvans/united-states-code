{"tag":"section","attrib":{"id":"id80de821c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501"},"text":null,"children":[{"tag":"num","attrib":{"value":"14501"},"text":"§ 14501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appalachian development highway system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80de821d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To provide a highway system which, in conjunction with the Interstate System and other Federal-aid highways in the Appalachian region, will open up an area with a developmental potential where commerce and communication have been inhibited by lack of adequate access, the Secretary of Transportation may assist in the construction of an Appalachian development highway system and local access roads serving the Appalachian region. Construction on the development highway system shall not be more than three thousand and ninety miles. There shall not be more than 1,400 miles of local access roads that serve specific recreational, residential, educational, commercial, industrial, or similar facilities or facilitate a school consolidation program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80de821e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commission Designations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80de821f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"What is to be designated","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Appalachian Regional Commission shall transmit to the Secretary its designations of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80de8220-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the general corridor location and termini of the development highways;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80de8221-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local access roads to be constructed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80de8222-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" priorities for the construction of segments of the development highways; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80de8223-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other criteria for the program authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80de8224-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State transportation department recommendation required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before a state member participates in or votes on designations, the member must obtain the recommendations of the state transportation department of the State which the member represents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80de8225-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Addition to Federal-aid Primary System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When completed, each development highway not already on the Federal-aid primary system shall be added to the system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80de8226-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Specific Materials and Products.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80de8227-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indigenous materials and products","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the construction of highways and roads authorized under this section, a State may give special preference to the use of materials and products indigenous to the Appalachian region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80de8228-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coal derivatives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For research and development in the use of coal and coal products in highway construction and maintenance, the Secretary may require each participating State, to the maximum extent possible, to use coal derivatives in the construction of not more than 10 percent of the roads authorized under this subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80de8229-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Federal assistance to any construction project under this section shall not be more than 80 percent of the cost of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80de822a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction Without Federal Amounts.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80de822b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When a participating State constructs a segment of a development highway without the aid of federal amounts and the construction is in accordance with all procedures and requirements applicable to the construction of segments of Appalachian development highways with those amounts, except for procedures and requirements that limit a State to the construction of projects for which federal amounts have previously been appropriated, the Secretary, on application by the State and with the approval of the Commission, may pay to the State the federal share, which shall not be more than 80 percent of the cost of the construction of the segment, from any amounts appropriated and allocated to the State to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80de822c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No commitment or obligation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection does not commit or obligate the Federal Government to provide amounts for segments of development highways constructed under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80de822d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Title","children":[],"tail":" 23.—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80de822e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sections 106","children":[],"tail":"(a) "},{"tag":"inline","attrib":{},"text":"and 118","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 106(a) and 118 of title 23 apply to the development highway system and the local access roads.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80de822f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14501/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction and maintenance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"States are required to maintain each development highway and local access road as provided for Federal-aid highways in title 23. All other provisions of title 23 that are applicable to the construction and maintenance of Federal-aid primary and secondary highways and which the Secretary decides are not inconsistent with this subtitle shall apply to the system and roads, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80de8230-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1265"},"text":"116 Stat. 1265","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/199/dF/tI/s123/a"},"text":"Pub. L. 108–199, div. F, title I, § 123(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/296"},"text":"118 Stat. 296","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80de8231-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80de8232-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80de8233-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Larg