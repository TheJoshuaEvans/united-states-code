{"tag":"section","attrib":{"id":"id80e33ce9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14508"},"text":null,"children":[{"tag":"num","attrib":{"value":"14508"},"text":"§ 14508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic and energy development initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e33cea-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Projects To Be Assisted","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Appalachian Regional Commission may provide technical assistance, make grants, enter into contracts, or otherwise provide amounts to persons or entities in the Appalachian region for projects and activities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33ceb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14508/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote energy efficiency in the Appalachian region to enhance the economic competitiveness of the Appalachian region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33cec-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14508/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the use of renewable energy resources, particularly biomass, in the Appalachian region to produce alternative transportation fuels, electricity, and heat; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33ced-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14508/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the development of regional, conventional energy resources to produce electricity and heat through advanced technologies that achieve a substantial reduction in emissions, including greenhouse gases, over the current baseline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33cee-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Available Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the cost of any activity eligible for a grant under this section, not more than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33cef-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14508/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent may be provided from amounts appropriated to carry out this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33cf0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14508/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which a distressed county designation is in effect under section 14526, 80 percent may be provided from amounts appropriated to carry out this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33cf1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14508/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which an at-risk county designation is in effect under section 14526, 70 percent may be provided from amounts appropriated to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33cf2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14508/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (b), grants provided under this section may be provided from amounts made available to carry out this section in combination with amounts made available under other Federal programs or from any other source.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33cf3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14508/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of law limiting the Federal share under any other Federal program, amounts made available to carry out this section may be used to increase that Federal share, as the Commission decides is appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e33cf4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/371/s3/a"},"text":"Pub. L. 110–371, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4040"},"text":"122 Stat. 4040","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
