{"tag":"section","attrib":{"id":"id80b5ec35-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3171"},"text":null,"children":[{"tag":"num","attrib":{"value":"3171"},"text":"§ 3171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority when appropriation is for less than full amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Unless specifically directed otherwise, the Administrator of General Services may make a contract within the full limit of the cost fixed by Congress for the acquisition of land for sites, or for the enlargement of sites, for public buildings, or for the erection, remodeling, extension, alteration, and repairs of public buildings, even though an appropriation is made for only part of the amount necessary to carry out legislation authorizing that purpose.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id80b5ec36-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1154"},"text":"116 Stat. 1154","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b5ec37-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b5ec38-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80b5ec39-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead",