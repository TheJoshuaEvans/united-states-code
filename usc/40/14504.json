{"tag":"section","attrib":{"id":"id80e0f38d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14504"},"text":null,"children":[{"tag":"num","attrib":{"value":"14504"},"text":"§ 14504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Telecommunications and technology initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e0f38e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Projects To Be Assisted","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Appalachian Regional Commission may provide technical assistance, make grants, enter into contracts, or otherwise provide amounts to persons or entities in the region for projects—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f38f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase affordable access to advanced telecommunications, entrepreneurship, and management technologies or applications in the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f390-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide education and training in the use of telecommunications and technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f391-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14504/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop programs to increase the readiness of industry groups and businesses in the region to engage in electronic commerce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f392-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14504/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support entrepreneurial opportunities for businesses in the information technology sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f393-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Available Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the cost of any activity eligible for a grant under this section, not more than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f394-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent may be provided from amounts appropriated to carry out this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f395-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which a distressed county designation is in effect under section 14526, 80 percent may be provided from amounts appropriated to carry out this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f396-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14504/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which an at-risk county designation is in effect under section 14526, 70 percent may be provided from amounts appropriated to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f397-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Assistance under this section may be provided entirely from amounts made available to carry out this section, in combination with amounts made available under other federal programs, or from any other source.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f398-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14504/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of law limiting the federal share under any other federal program, amounts made available to carry out this section may be used to increase that federal share, as the Commission decides is appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e0f399-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217"