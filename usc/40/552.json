{"tag":"section","attrib":{"id":"id80a08eb9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s552"},"text":null,"children":[{"tag":"num","attrib":{"value":"552"},"text":"§ 552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abandoned or unclaimed property on Government premises","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80a08eba-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s552/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Take Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services may take possession of abandoned or unclaimed property on premises owned or leased by the Federal Government and determine when title to the property vests in the Government. The Administrator may use, transfer, or otherwise dispose of the property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08ebb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s552/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claim Filed by Former Owner","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a former owner files a proper claim within three years from the date that title to the property vests in the Government, the former owner shall be paid an amount—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a08ebc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s552/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equal to the proceeds realized from the disposition of the property less costs incident to care and handling as determined by the Administrator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08ebd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s552/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the property has been used or transferred, equal to the fair value of the property as of the time title vested in the Government less costs incident to care and handling as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80a08ebe-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1099"},"text":"116 Stat. 1099","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s6/3"},"text":"Pub. L. 109–284, § 6(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1212"},"text":"120 Stat. 1212","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80a08ebf-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80a08ec0-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80a08ec1-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead"