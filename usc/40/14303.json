{"tag":"section","attrib":{"id":"id80dc116c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14303"},"text":null,"children":[{"tag":"num","attrib":{"value":"14303"},"text":"§ 14303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80dc116d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the purposes of this subtitle, the Appalachian Regional Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80dc116e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, on a continuing basis, comprehensive and coordinated plans and programs and establish priorities under those plans and programs, giving due consideration to other federal, state, and local planning in the Appalachian region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc116f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct and sponsor investigations, research, and studies, including an inventory and analysis of the resources of the region, and, in cooperation with federal, state, and local agencies, sponsor demonstration projects designed to foster regional productivity and growth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc1170-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14303/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and study, in cooperation with the agency involved, federal, state, and local public and private programs and, where appropriate, recommend modifications or additions which will increase their effectiveness in the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc1171-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14303/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formulate and recommend, where appropriate, interstate compacts and other forms of interstate cooperation and work with state and local agencies in developing appropriate model legislation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc1172-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14303/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the formation of, and support, local development districts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc1173-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14303/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage private investment in industrial, commercial, and recreational projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc1174-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14303/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a focal point and coordinating unit for Appalachian programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc1175-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14303/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a forum for consideration of problems of the region and proposed solutions and establish and utilize, as appropriate, citizens and special advisory councils and public conferences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc1176-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14303/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the use of eco-industrial development technologies and approaches;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc1177-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14303/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to coordinate the economic development activities of, and the use of economic development resources by, federal agencies in the region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc1178-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14303/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support broadband access in the Appalachian region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc1179-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Identify Needs and Goals of Subregional Areas","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out its functions under this section, the Commission shall identify the characteristics of, and may distinguish between the needs and goals of, appropriate subregional areas, including central, northern, and southern Appalachia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80dc117a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1258"},"text":"116 Stat. 1258","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11506/b"},"text":"Pub. L. 117–58, div. A, title I, § 11506(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/584"},"text":"135 Stat. 584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80dc117b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80dc117c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80dc117d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"htm