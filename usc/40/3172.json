{"tag":"section","attrib":{"id":"id80b5ec3a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3172"},"text":null,"children":[{"tag":"num","attrib":{"value":"3172"},"text":"§ 3172.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of state workers’ compensation laws to buildings, works, and property of the Federal Government","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80b5ec3b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3172/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Extension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The state authority charged with enforcing and requiring compliance with the state workers’ compensation laws and with the orders, decisions, and awards of the authority may apply the laws to all land and premises in the State which the Federal Government owns or holds by deed or act of cession, and to all projects, buildings, constructions, improvements, and property in the State and belonging to the Government, in the same way and to the same extent as if the premises were under the exclusive jurisdiction of the State in which the land, premises, projects, buildings, constructions, improvements, or property are located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b5ec3c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3172/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Relinquishing Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Government under this section does not relinquish its jurisdiction for any other purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b5ec3d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3172/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not modify or amend subchapter I of chapter 81 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b5ec3e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1154"},"text":"116 Stat. 1154","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b5ec3f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b5ec40-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80b5ec41-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3172(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:290 (1st par., last par. words before 1st proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-25/ch822"},"text":"June 25, 1936, ch. 822","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/1938"},"text":"49 Stat. 1938","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3172(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:290 (last par. 1st proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3172(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:290 (last par. last proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “by purchase or otherwise” and 40:290(last par. words before 1st proviso) are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is substituted for 40:290(last par. 1st proviso) to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “subchapter I of chapter 81 of title 5” are substituted for “the United States Employees’ Compensation Act as amended from time to time (Act of ","children":[{"tag":"date","attrib":{"date":"1916-09-07"},"text":"September 7, 1916","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/742"},"text":"39 Stat. 742","children":[],"tail":", U.S.C., title 5 and supplement, sec. 751 et seq.)” because of "},{"tag":"ref","attrib":{"href":"/us/act/1966-09-06/s7/b"},"text":"section 7(b) of the Act of September 6, 1966","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Public Law 89–554","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":"), the first section of which enacted Title 5, United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":nul