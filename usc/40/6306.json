,"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6306(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:193t (words after 5th comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5375"},"text":"section 5375 of title 5","children":[],"tail":"” are substituted for “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5365"},"text":"section 5365 of title 5","children":[],"tail":"” because of section 801(a)(3)(A)(ii) of the Civil Service Reform Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Public Law 95–454","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1221"},"text":"92 Stat. 1221","children":[],"tail":"), which redesignated sections 5361 through 5365 of title 5 as sections 5371 through 5375 of title 5. The words “or their designees” are substituted for “or their authorized representatives” for consistency in the revised chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “within which the specified buildings and grounds are located” are substituted for “within which the aforementioned buildings are located” for clarity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
