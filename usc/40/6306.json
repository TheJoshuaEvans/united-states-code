{"tag":"section","attrib":{"id":"id80c442f8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6306"},"text":null,"children":[{"tag":"num","attrib":{"value":"6306"},"text":"§ 6306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policing of buildings and grounds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c442f9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Employees as Special Police","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5375"},"text":"section 5375 of title 5","children":[],"tail":", the Secretary of the Smithsonian Institution, the Trustees of the National Gallery of Art, and the Trustees of the John F. Kennedy Center for the Performing Arts (or their designees) may designate employees of their respective agencies as special police, without additional compensation, for duty in connection with the policing of their respective specified buildings and grounds."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c442fa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Powers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The employees designated as special police under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c442fb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, within the specified buildings and grounds, enforce, and make arrests for violations of, sections 6302 and 6303 of this title, any regulation prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6304"},"text":"section 6304 of this title","children":[],"tail":", federal or state law, or any regulation prescribed under federal or state law; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c442fc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enforce concurrently with the United States Park Police the laws and regulations applicable to the National Capital Parks, and may make arrests for violations of sections 6302 and 6303 of this title, within the several areas located within the exterior boundaries of the face of the curb lines of the squares within which the specified buildings and grounds are located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c442fd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Uniforms and Other Equipment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The employees designated as special police under subsection (a) may be provided, without charge, with uniforms and other equipment as may be necessary for the proper performance of their duties, including badges, revolvers, and ammunition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c442fe-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date",