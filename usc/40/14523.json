{"tag":"section","attrib":{"id":"id80e33d3a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14523"},"text":null,"children":[{"tag":"num","attrib":{"value":"14523"},"text":"§ 14523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program implementation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e33d3b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14523/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A program or project authorized under this chapter shall not be implemented until—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33d3c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14523/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the responsible federal official has decided that applications and plans relating to the program or project are not incompatible with the provisions and objectives of federal laws that the official administers that are not inconsistent with this subtitle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d3d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14523/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Appalachian Regional Commission has approved the program or project and has determined that it—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e33d3e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14523/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the applicable criteria under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14524"},"text":"section 14524 of this title","children":[],"tail":" and the requirements of the development planning process under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s14525"},"text":"section 14525 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e33d3f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14523/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will contribute to the development of the Appalachian region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d40-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14523/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Decision Is Controlling","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A decision under subsection (a)(2) is controlling and shall be accepted by the federal agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e33d41-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1274"},"text":"116 Stat. 1274","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e33d42-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80e33d43-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"