{"tag":"section","attrib":{"id":"id80e5aec9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15503"},"text":null,"children":[{"tag":"num","attrib":{"value":"15503"},"text":"§ 15503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of applications for assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e5aeca-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluation by State Member","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An application to a Commission for a grant or any other assistance for a project under this subtitle shall be made through, and evaluated for approval by, the State member of the Commission representing the applicant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5aecb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application to a Commission for a grant or other assistance for a project under this subtitle shall be eligible for assistance only on certification by the State member of the Commission representing the applicant that the application for the project—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5aecc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes ways in which the project complies with any applicable State economic and infrastructure development plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aecd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets applicable criteria under section 15504;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aece-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequately ensures that the project will be properly administered, operated, and maintained; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aecf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15503/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise meets the requirements for assistance under this subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5aed0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Votes for Decisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On certification by a State member of a Commission of an application for a grant or other assistance for a specific project under this section, an affirmative vote of the Commission under section 15302 shall be required for approval of the application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e5aed1-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"re