attrib":{"href":"/us/act/1941-04-29/ch81/s2"},"text":"Apr. 29, 1941, ch. 81, § 2","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/91/469/s39"},"text":"Pub. L. 91–469, § 39","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 21, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1036"},"text":"84 Stat. 1036","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/12"},"text":"Pub. L. 97–31, § 12(12)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/154"},"text":"95 Stat. 154","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Secretary of Transportation” are substituted for “Secretary of Commerce” because of 49:108. The words “the manufacturing, producing, furnishing, construction, alteration, repair, processing, or assembling of” and “of any kind or nature” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “of any kind or nature” are omitted as unnecessary. The words “sections 1535 and 1536 of title 31” are substituted for “the Act of ","children":[{"tag":"date","attrib":{"date":"1932-06-30"},"text":"June 30, 1932","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/47/382"},"text":"47 Stat. 382","children":[],"tail":", 417–418), as amended ["},{"tag":"ref","attrib":{"href":"/us/usc/t31/s686"},"text":"31 U.S.C. 686","children":[],"tail":", 686b]” because of "},{"tag":"ref","attrib":{"href":"/us/act/1982-09-13/s4/b"},"text":"section 4(b) of the Act of September 13, 1982","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Public Law 97–258","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":"), the first section of which enacted Title 31, United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80b3a1d7-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80b3a1d8-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"An Act to define the functions and duties of the Coast and Geodetic Survey, and for other purposes, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-08-06/ch504"},"text":"act Aug. 6, 1947, ch. 504","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/787"},"text":"61 Stat. 787","children":[],"tail":", popularly known as the Coast and Geodetic Survey Act, which is classified generally to subchapter II (§ 883a et seq.) of chapter 17 of Title 33, Navigation and Navigable Waters. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80b3a1d9-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s3502/b/2"},"text":"Pub. L. 115–91, § 3502(b)(2)","children":[],"tail":", substituted “31 or” for “31,” and struck out “or the Merchant Ship Sales Act of 1946 (50 App. U.S.C. 1735 et seq.),” after “title 46,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":" substituted “subtitle V of title 46” for “the Merchant Marine Act, 1936 (46 App. U.S.C. 1101 et seq.)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80b3a1da-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id80b3a1db-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
