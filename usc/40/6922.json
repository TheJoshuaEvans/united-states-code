{"tag":"section","attrib":{"id":"id80c8fe7b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6922"},"text":null,"children":[{"tag":"num","attrib":{"value":"6922"},"text":"§ 6922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c8fe7c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6922/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Visitor Facilities Advisory Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c8fe7d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6922/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct continuing investigations and studies of sites and plans to provide additional facilities and services for visitors and students coming to the Nation’s Capital; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c8fe7e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6922/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary of the Interior and the Administrator of General Services on the planning, construction, acquisition, and operation of those visitor facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c8fe7f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6922/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text