{"tag":"section","attrib":{"id":"id80a08f44-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572"},"text":null,"children":[{"tag":"num","attrib":{"value":"572"},"text":"§ 572.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80a08f45-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a08f46-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separate fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), proceeds of the disposition of surplus real and related personal property by the Administrator of General Services shall be set aside in a separate fund in the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f47-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of expenses from the fund.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a08f48-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the fund described in paragraph (1), the Administrator may obligate an amount to pay the following direct expenses incurred for the use of excess property and the disposal of surplus property under this subtitle:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80a08f49-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fees of appraisers, auctioneers, and realty brokers, in accordance with the scale customarily paid in similar commercial transactions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80a08f4a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs of environmental and historic preservation services, highest and best use of property studies, utilization of property studies, deed compliance inspection, and the expenses incurred in a relocation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80a08f4b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advertising and surveying.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a08f4c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id80a08f4d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Percentage limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In each fiscal year, no more than 12 percent of the proceeds of all dispositions of surplus real and related personal property may be paid to meet direct expenses incurred in connection with the dispositions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80a08f4e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of maximum amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Office of Management and Budget each quarter shall determine the maximum amount that may be obligated under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a08f4f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Direct payment or reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An amount obligated under this paragraph may be used to pay an expense directly or to reimburse a fund or appropriation that initially paid the expense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f50-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer to miscellaneous receipts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At least once each year, excess amounts beyond current operating needs shall be transferred from the fund described in paragraph (1) to miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f51-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A report of receipts, disbursements, and transfers to miscellaneous receipts under this subsection shall be made annually, in connection with the budget estimate, to the Director and to Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08f52-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Real Property Under Control of a Military Department.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a08f53-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the following definitions apply:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a08f54-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military installation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “military installation” has the meaning given that term in section 2687(e)(1) ","children":[{"tag":"ref","attrib":{"idref":"fn002010"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002010"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 10."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a08f55-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Base closure law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “base closure law” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/17"},"text":"section 101(a)(17) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f56-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a08f57-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection applies to real property, including any improvement on the property, that is under the control of a military department and that the Secretary of the department determines is excess to the department’s needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a08f58-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection does not apply to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80a08f59-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damaged or deteriorated military family housing facilities conveyed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2854a"},"text":"section 2854a of title 10","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80a08f5a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property at a military installation designated for closure or realignment pursuant to a base closure law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f5b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer between military departments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall provide that property described in paragraph (2) is available for transfer, without reimbursement, to other military departments within the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a2d84c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative disposition by administrator of general services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If property is not transferred pursuant to paragraph (3), the Secretary of the military department with the property under its control shall request the Administrator to transfer or dispose of the property in accordance with this subtitle or other applicable law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a2d84d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proceeds.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a2d84e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposit in special account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For a transfer or disposition of property pursuant to paragraph (4), the Administrator shall deposit any proceeds (less expenses of the transfer or disposition as provided in subsection (a)) in a special account in the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a2d84f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of amount deposited","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent provided in an appropriation law, an amount deposited in a special account under subparagraph (A) is available for facility maintenance and repair or environmental restoration as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80a2d850-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of property located at a military installation that is closed, the amount is available for facility maintenance and repair or environmental restoration by the military department that had jurisdiction over the property before the closure of the military installation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80a2d851-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of property located at any other military installation—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id80a2d852-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/5/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the amount is available for facility maintenance and repair or environmental restoration at the military installation where the property was located before it was disposed of or transferred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id80a2d853-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/5/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the amount is available for facility maintenance and repair and for environmental restoration by the military department that had jurisdiction over the property before it was disposed of or transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a2d854-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s572/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As part of the annual request for authorizations of appropriations to the Committees on Armed Services of the Senate and the House of Representatives, the Secretary of Defense shall include an accounting of each transfer and disposal made in accordance with this subsection during the fiscal year preceding the fiscal year in which the request is made. The accounting shall include a detailed explanation of each transfer and disposal and of the use of the proceeds received from it by the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80a2d855-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–2