{"tag":"section","attrib":{"id":"id80d9c80b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11702"},"text":null,"children":[{"tag":"num","attrib":{"value":"11702"},"text":"§ 11702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Index of certain information in information systems included in directory established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s4101"},"text":"section 4101 of title 44","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If in designing an information technology system pursuant to this subtitle, the head of an executive agency determines that a purpose of the system is to disseminate information to the public, then the head of that executive agency shall reasonably ensure that an index of information disseminated by the system is included in the directory created pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s4101"},"text":"section 4101 of title 44","children":[],"tail":". This section does not authorize the dissemination of information to the public unless otherwise authorized."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id80d9c80c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1252"},"text":"116 Stat. 1252","children":[],"tail":", § 11703; renumbered § 11702, "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tVIII/s825/c/2"},"text":"Pub. L. 107–314, div. A, title VIII, § 825(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2616"},"text":"116 Stat. 2616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","at