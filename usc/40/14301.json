{"tag":"section","attrib":{"id":"id80dc114f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14301"},"text":null,"children":[{"tag":"num","attrib":{"value":"14301"},"text":"§ 14301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment, membership, and employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80dc1150-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is an Appalachian Regional Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc1151-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80dc1152-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal and state members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission is composed of the Federal Cochairman, appointed by the President by and with the advice and consent of the Senate, and the Governor of each participating State in the Appalachian region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc1153-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternate members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each state member may have a single alternate, appointed by the Governor from among the members of the Governor’s cabinet or the Governor’s personal staff. The President,,","children":[{"tag":"ref","attrib":{"idref":"fn002034"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002034"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" shall appoint an alternate for the Federal Cochairman. An alternate shall vote in the event of the absence, death, disability, removal, or resignation of the member for whom the individual is an alternate. A state alternate shall not be counted toward the establishment of a quorum of the Commission when a quorum of the state members is required."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc1154-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14301/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cochairmen","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Cochairman is one of the two Cochairmen of the Commission. The state members shall elect a Cochairman of the Commission from among themselves for a term of not less than one year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc1155-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Cochairman shall be compensated by the Federal Government at level III of the Executive Schedule as set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":". The Federal Cochairman’s alternate shall be compensated by the Government at level V of the Executive Schedule as set out in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":". Each state member and alternate shall be compensated by the State which they represent at the rate established by law of that State."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc1156-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14301/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80dc1157-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14301/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Powers and responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Commission powers and responsibilities specified in section 14302(c) and (d) of this title, and the vote of any Commission member, may not be delegated to an individual who is not a Commission member or who is not entitled to vote in Commission meetings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc1158-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14301/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternate federal cochairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The alternate to the Federal Cochairman shall perform the functions and duties the Federal Cochairman delegates when not actively serving as the alternate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc1159-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14301/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission has an executive director. The executive director is responsible for carrying out the administrative functions of the Commission, for directing the Commission staff, and for other duties the Commission may assign.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc115a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14301/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Status of Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members, alternates, officers, and employees of the Commission are not federal employees for any purpose, except the Federal Cochairman, the alternate to the Federal Cochairman, the staff of the Federal Cochairman, and federal employees detailed to the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14306/a/3"},"text":"section 14306(a)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80dc115b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1256"},"text":"116 Stat. 1256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s2/n"},"text":"Pub. L. 112–166, § 2(n)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1287"},"text":"126 Stat. 1287","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80dc115c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80dc115d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80dc115e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"