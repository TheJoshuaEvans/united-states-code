{"tag":"section","attrib":{"id":"id80e81f6b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15733"},"text":null,"children":[{"tag":"num","attrib":{"value":"15733"},"text":"§ 15733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Northern Border Regional Commission","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The region of the Northern Border Regional Commission shall include the following counties:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81f6c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15733/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maine","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The counties of Androscoggin, Aroostook, Franklin, Hancock, Kennebec, Knox, Lincoln, Oxford, Penobscot, Piscataquis, Somerset, Waldo, and Washington in the State of Maine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f6d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15733/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"New hampshire","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The counties of Belknap, Carroll, Cheshire, Coos, Grafton, Merrimack, and Sullivan in the State of New Hampshire.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f6e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15733/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"New york","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib"