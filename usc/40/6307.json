{"tag":"section","attrib":{"id":"id80c44302-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6307"},"text":null,"children":[{"tag":"num","attrib":{"value":"6307"},"text":"§ 6307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c44303-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c44304-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6307/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person violating section 6302 or 6303 of this title, or a regulation prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6304"},"text":"section 6304 of this title","children":[],"tail":", shall be fined under title 18, imprisoned for not more than 60 days, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44305-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6307/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Prosecution for an offense under this subsection shall be in the Superior Court of the District of Columbia, by information by the United States Attorney or an Assistant United States Attorney.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c44306-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses Involving Property Damage Over","children":[],"tail":" $100.—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c44307-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6307/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If in the commission of a violation described in subsection (a), property is damaged in an amount exceeding $100, the period of imprisonment for the offense may be not more than five years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44308-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6307/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Venue and procedure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Prosecution of an offense under this subsection shall be in the United States District Court for the District of Columbia by indictment. Prosecution may be on information by the United States Attorney or an Assistant United States Attorney if the defendant, after being advised of the nature of the charge and of rights of the defendant, waives in open court prosecution by indictment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c44309-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1187"},"text":"116 Stat. 1187","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c4430a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c4430b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c4430c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6307","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:193s.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1951-10-24/ch559/s6"},"text":"Oct. 24, 1951, ch. 559, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/65/635"},"text":"65 Stat. 635","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “fined under title 18” are substituted for “fined not more than $100” for consistency with chapter 227 of title 18.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “Superior Court of the District of Columbia” are substituted for “Municipal Court for the District of Columbia” [subsequently changed to “District of Columbia Court of General Sessions” because of sections 1 and 7 of the Act of ","children":[{"tag":"date","attrib":{"date":"1963-07-08"},"text":"July 8, 1963","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/88/60"},"text":"Public Law 88–60","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/77"},"text":"77 Stat. 77","children":[],"tail":", 78)] because of section 155(a) of the District of Columbia Court Reorganization Act of 1970 ("},{"tag":"ref","attrib":{"href":"/us/pl/91/358"},"text":"Public Law 91–358","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/570"},"text":"85 Stat. 570","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “the amount of the fine for the offense may be not more than $5,000” are omitted for consistency with chapter 227 of title 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
