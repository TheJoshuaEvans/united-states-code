{"tag":"section","attrib":{"id":"id80ac7601-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s904"},"text":null,"children":[{"tag":"num","attrib":{"value":"904"},"text":"§ 904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80ac7602-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Local Government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before offering real property situated in an urban area for sale, the Administrator of General Services shall give reasonable notice to the unit of general local government exercising zoning and land use jurisdiction in order to provide an opportunity for zoning so that the property is used in accordance with local comprehensive planning described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ac7603-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Prospective Purchasers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the greatest extent practicable, the Administrator shall furnish to all prospective purchasers of real property situated in an urban area complete information concerning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ac7604-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current zoning regulations, prospective zoning requirements, and objectives for property if it is unzoned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ac7605-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80ac7606-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s904/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current availability of streets, sidewalks, sewers, water, street lights, and other service facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80ac7607-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s904/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prospective availability of those service facilities if the property is included in local comprehensive planning described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ac7608-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Local Comprehensive Planning","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Local comprehensive planning referred to in subsections (a) and (b) includes any of the following activities, to the extent the activity is directly related to the needs of a unit of general local government:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ac7609-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s904/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As a guide for government policy and action, preparing general plans related to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80ac760a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s904/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pattern and intensity of land use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80ac760b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s904/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of public facilities (including transportation facilities) and other government services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80ac760c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s904/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective development and use of human and natural resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ac760d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s904/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Preparing long-range physical and fiscal plans for government action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ac760e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s904/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programming capital improvements and other major expenditures, based on a determination of relative urgency, together with definitive financial planning for expenditures in the earlier years of a program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ac760f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s904/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinating related plans and activities of state and local governments and agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ac7610-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s904/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Preparing regulatory and administrative measures to support activities described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ac7611-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1128"},"text":"116 Stat. 1128","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ac7612-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ac7613-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ac7614-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"904(a), (b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:532.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title VIII, §§ 803, 806(c), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/90/577/tV/s501"},"text":"Pub. L. 90–577, title V, § 501","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 16, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/82/1105"},"text":"82 Stat. 1105","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"904(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:535(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Whenever the Administrator contemplates the disposal for or on behalf of any Federal agency of” and “such land” are omitted as unnecessary. The words “the head of the governing body of” are omitted for consistency in the chapter. The words “exercising zoning and land-use jurisdiction” are substituted for “having jurisdiction over zoning and land-use regulation in the geographical area within which the land or lands are located” to eliminate unnecessary words and for consistency in the chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the word “Preparing” is added for clarity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
