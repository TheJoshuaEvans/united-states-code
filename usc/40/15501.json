{"tag":"section","attrib":{"id":"id80e5ae9c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501"},"text":null,"children":[{"tag":"num","attrib":{"value":"15501"},"text":"§ 15501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic and infrastructure development grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e5ae9d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Commission may make grants to States and local governments, Indian tribes, and public and nonprofit organizations for projects, approved in accordance with section 15503—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5ae9e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop the transportation infrastructure of its region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae9f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop the basic public infrastructure of its region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aea0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop the telecommunications infrastructure of its region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aea1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist its region in obtaining job skills training, skills development and employment-related education, entrepreneurship, technology, and business development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aea2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide assistance to severely economically distressed and underdeveloped areas of its region that lack financial resources for improving basic health care and other public services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aea3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote resource conservation, tourism, recreation, and preservation of open space in a manner consistent with economic development goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aea4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the development of renewable and alternative energy sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aea5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to grow the capacity for successful community economic development in its region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aea6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to otherwise achieve the purposes of this subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5aea7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Commission shall allocate at least 40 percent of any grant amounts provided by the Commission in a fiscal year for projects described in paragraph (1), (2), (3), or (7) of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5aea8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources of Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Grant amounts may be provided entirely from appropriations to carry out this subtitle, in combination with amounts available under other Federal grant programs, or from any other source.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5aea9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Commission Contributions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5aeaa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraphs (2) and (3), the Commission may contribute not more than 50 percent of a project or activity cost eligible for financial assistance under this section from amounts appropriated to carry out this subtitle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aeab-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distressed counties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum Commission contribution for a project or activity to be carried out in a county for which a distressed county designation is in effect under section 15702 may be increased to 80 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aeac-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for regional projects","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Commission may increase to 60 percent under paragraph (1) and 90 percent under paragraph (2) the maximum Commission contribution for a project or activity if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e5aead-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project or activity involves 3 or more counties or more than one State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e5aeae-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission determines in accordance with section 15302(a) that the project or activity will bring significant interstate or multicounty benefits to a region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5aeaf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance of Effort","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds may be provided by a Commission for a program or project in a State under this section only if the Commission determines that the level of Federal or State financial assistance provided under a law other than this subtitle, for the same type of program or project in the same area of the State within region, will not be reduced as a result of funds made available by this subtitle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5aeb0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15501/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Relocation Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Financial assistance authorized by this section may not be used to assist a person or entity in relocating from one area to another, except that financial assistance may be used as otherwise authorized by this subtitle to attract businesses to the region from outside the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e5aeb1-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14217/a/2"},"text":"Pub. L. 110–234, title XIV, § 14217(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1474"},"text":"122 Stat. 1474","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14217(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2236; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6304/b"},"text":"Pub. L. 115–334, title VI, § 6304(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4749"},"text":"132 Stat. 4749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e5aeb2-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80e5aeb3-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id80e5aeb4-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80e5aeb5-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(8), (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6304/b/1"},"text":"Pub. L. 115–334, § 6304(b)(1)","children":[],"tail":", added par. (8) and redesignated former par. (8) as (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6304/b/2"},"text":"Pub. L. 115–334, § 6304(b)(2)","children":[],"tail":", substituted “paragraph (1), (2), (3), or (7)” for “paragraphs (1) through (3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6304/b/3"},"text":"Pub. L. 115–334, § 6304(b)(3)","children":[],"tail":", substituted “, except that financial assistance may be used as otherwise authorized by this subtitle to attract businesses to the region from outside the United States.” for period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80e5aeb6-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id80e5aeb7-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s14217/d"},"text":"section 14217(d) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s15101"},"text":"section 15101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80e5aeb8-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Waiver of Requirements Relating to Non-Federal Cost-Share Grants and Cooperative Agreements for the Northern Border Regional Commission","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dD/tV/s505/b"},"text":"Pub. L. 116–260, div. D, title V, § 505(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1379"},"text":"134 Stat. 1379","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dD/tV/s505/b"},"text":"“Requirements relating to non-Federal cost-share grants and cooperative agreements for the Northern Border Regional Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s15501/d"},"text":"section 15501(d) of title 40","children":[],"tail":", United States Code, are waived for grants awarded in fiscal year 2020 and in subsequent years in response to economic distress directly related to the impacts of the Coronavirus Disease (COVID–19).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80e5aeb9-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"State Capacity Building Grant Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6304/c"},"text":"Pub. L. 115–334, title VI, § 6304(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4750"},"text":"132 Stat. 4750","children":[],"tail":", which authorized the Commission to establish a State capacity building grant program to provide grants to Commission States, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2248/b"},"text":"Pub. L. 118–272, div. B, title II, § 2248(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3209"},"text":"138 Stat. 3209","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
