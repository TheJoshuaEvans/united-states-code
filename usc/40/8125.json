{"tag":"section","attrib":{"id":"id80c8fef0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8125"},"text":null,"children":[{"tag":"num","attrib":{"value":"8125"},"text":"§ 8125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public spaces resulting from filling of canals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the National Park Service has jurisdiction over all public spaces resulting from the filling of canals in the original city of Washington that were not under the jurisdiction of the Chief of Engineers of the United States Army as of ","children":[{"tag":"date","attrib":{"date":"1914-08-01"},"text":"August 1, 1914","children":[],"tail":", except spaces included in the navy yard or in actual use as roadways and sidewalks and spaces assigned by law to the District of Columbia for use as a property yard and the location of a sewage pumping station. The spaces shall be laid out as reservations as a part of the park system of the District of Columbia."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id80c8fef1-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1207"},"text":"116 Stat. 1207","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c8fef2-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c8fef3-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c8fef4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8125","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:82.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1914-08-01/ch223/s1"},"text":"Aug. 1, 1914, ch. 223, § 1","children":[],"tail":" (last par. on p. 633), "},{"tag":"html:a","attrib":{"href":"/us/stat/38/633"},"text":"38 Stat. 633","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions from the Chief of Engineers to the Director of the National Park Service, see the revision note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s8102"},"text":"section 8102 of this title","children":[],"tail":". However, the words “Chief of Engineers of the United States Army” in the source provision are retained for historical purposes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
