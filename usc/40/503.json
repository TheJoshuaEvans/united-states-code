fice of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s401"},"text":"41 U.S.C. 401","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5"},"text":"Pub. L. 111–350, § 5","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(8)(B), substituted “"},{"tag":"inline","attrib":{},"text":"Section 6101(","children":[],"tail":"b"},{"tag":"inline","attrib":{},"text":") to (","children":[],"tail":"d"},{"tag":"inline","attrib":{},"text":") of title 41","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"Section 3709 of revised statutes","children":[],"tail":"” in heading and “Section 6101(b) to (d) of title 41” for “Section 3709 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"41 U.S.C. 5","children":[],"tail":")” in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
