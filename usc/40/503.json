{"tag":"section","attrib":{"id":"id8096f19b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s503"},"text":null,"children":[{"tag":"num","attrib":{"value":"503"},"text":"§ 503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange or sale of similar items","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8096f19c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Executive Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In acquiring personal property, an executive agency may exchange or sell similar items and may apply the exchange allowance or proceeds of sale in whole or in part payment for the property acquired.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8096f19d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicable Regulation and Law.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8096f19e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations prescribed by administrator of general services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A transaction under subsection (a) must be carried out in accordance with regulations the Administrator of General Services prescribes, subject to regulations prescribed by the Administrator for Federal Procurement Policy under division B (except sections 1704 and 2303) of subtitle I of title 41.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8096f19f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In writing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A transaction under subsection (a) must be evidenced in writing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8096f1a0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Section 6101(","children":[],"tail":"b"},{"tag":"inline","attrib":{},"text":") to (","children":[],"tail":"d"},{"tag":"inline","attrib":{},"text":") of title 41","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 6101(b) to (d) of title 41 applies to a sale of property under subsection (a), except that fixed price sales may be conducted in the same manner and subject to the same conditions as are applicable to the sale of property under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s545/d"},"text":"section 545(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8096f1a1-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1081"},"text":"116 Stat. 1081","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5"},"text":"Pub. L. 111–350, § 5","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(8), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3851"},"text":"124 Stat. 3851","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8096f1a2-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id8096f1a3-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id8096f1a4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"child