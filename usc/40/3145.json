{"tag":"section","attrib":{"id":"id80b5ebfc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3145"},"text":null,"children":[{"tag":"num","attrib":{"value":"3145"},"text":"§ 3145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations governing contractors and subcontractors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80b5ebfd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3145/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Labor shall prescribe reasonable regulations for contractors and subcontractors engaged in constructing, carrying out, completing, or repairing public buildings, public works, or buildings or works that at least partly are financed by a loan or grant from the Federal Government. The regulations shall include a provision that each contractor and subcontractor each week must furnish a statement on the wages paid each employee during the prior week.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b5ebfe-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3145/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1001"},"text":"Section 1001 of title 18","children":[],"tail":" applies to the statements."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b5ebff-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail"