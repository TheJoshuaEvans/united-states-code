{"tag":"section","attrib":{"id":"id80a7baac-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s593"},"text":null,"children":[{"tag":"num","attrib":{"value":"593"},"text":"§ 593.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection for veterans preference employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80a7baad-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s593/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a7baae-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s593/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “covered services” means any guard, elevator operator, messenger, or custodial services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7baaf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s593/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sheltered workshop","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “sheltered workshop” means a sheltered workshop employing the severely handicapped under chapter 85 of title 41.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a7bab0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s593/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (c), amounts made available to the General Services Administration pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s592"},"text":"section 592 of this title","children":[],"tail":" may not be obligated or expended to procure covered services by contract if an employee who was a permanent veterans preference employee of the Administration on "},{"tag":"date","attrib":{"date":"1995-11-19"},"text":"November 19, 1995","children":[],"tail":", would be terminated as a result."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a7bab1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s593/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts made available to the Administration pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s592"},"text":"section 592 of this title","children":[],"tail":" may be obligated and expended to procure covered services by contract with a sheltered workshop or, if sheltered workshops decline to contract for the provision of covered services, by competitive contract for a period of no longer than 5 years. When a competitive contract expires, or is terminated for any reason, the Administration shall again offer to procure the covered services by contract with a sheltered workshop before procuring the covered services by competitive contract."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80a7bab2-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1120"},"text":"116 Stat. 1120","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s6/6"},"text":"Pub. L. 109–284, § 6(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1212"},"text":"120 Stat. 1212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5"},"text":"Pub. L. 111–350, § 5","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(11), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3852"},"text":"124 Stat. 3852","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80a7bab3-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80a7bab4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80a7bab5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"