{"tag":"section","attrib":{"id":"id80e5aed7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15504"},"text":null,"children":[{"tag":"num","attrib":{"value":"15504"},"text":"§ 15504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program development criteria","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In considering programs and projects to be provided assistance by a Commission under this subtitle, and in establishing a priority ranking of the requests for assistance provided to the Commission, the Commission shall follow procedures that ensure, to the maximum extent practicable, consideration of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5aed8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15504/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relationship of the project or class of projects to overall regional development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aed9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15504/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the per capita income and poverty and unemployment and outmigration rates in an area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aeda-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15504/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial resources available to the applicants for assistance seeking to carry out the project, with emphasis on ensuring that projects are adequately financed to maximize the probability of successful economic development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aedb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15504/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importance of the project or class of projects in relation to the other projects or classes of projects that may be in competition for the same funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aedc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15504/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prospects that the project for which assistance is sought will improve, on a continuing rather than a temporary basis, the opportunities for employment, the average level of income, or the economic development of the area to be served by the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aedd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15504/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the project design provides for detailed outcome measurements by which grant expenditures and the results of the expenditures may be evaluated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e5aede-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14217/a/2"},"text":"Pub. L. 110–234, title XIV, § 14217(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1476"},"text":"122 Stat. 1476","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14217(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2238.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e5aedf-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80e5aee0-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id80e5aee1-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80e5aee2-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id80e5aee3-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s14217/d"},"text":"section 14217(d) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s15101"},"text":"section 15101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
