{"tag":"section","attrib":{"id":"id80ea6957-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17501"},"text":null,"children":[{"tag":"num","attrib":{"value":"17501"},"text":"§ 17501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ea6958-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive agency","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “executive agency”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80ea6959-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17501/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means an executive agency (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":") that operates at least 300 motor vehicles; but"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80ea695a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17501/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include the Tennessee Valley Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ea695b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Motor vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “motor vehicle” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80ea695c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17501/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vehicle self-propelled or drawn by mechanical power; but not","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80ea695d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17501/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vehicle designed or used for military field training, combat, or tactical purposes, or any other special purpose vehicle exempted from the requirements of this chapter by the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ea695e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1283"},"text":"116 Stat. 1283","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ea695f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ea6960-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ea6961-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"17501","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:913.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/99/272/tXV/s15313"},"text":"Pub. L. 99–272, title XV, § 15313","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/338"},"text":"100 Stat. 338","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the text of 40:913(2)–(4) is omitted as unnecessary because the complete names of the Director of the Office of Management and Budget, the Administrator of General Services, and the Comptroller General of the United States are used the first time the terms appear in a section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Before clause (1), the words “this chapter” were in the original “this title”, meaning title XV (§§ 15101 to 15313) of the Consolidated Omnibus Budget Reconciliation Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Public Law 99–272","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/330"},"text":"100 Stat. 330","children":[],"tail":"). In clause (2)(B), the words “this chapter” are substituted for “this part” as the probable intent of Congress because title XV of the Act does not contain part designations and the intention was probably to refer to title XV, which is restated as this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
