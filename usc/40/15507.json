{"tag":"section","attrib":{"id":"id80e81f06-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15507"},"text":null,"children":[{"tag":"num","attrib":{"value":"15507"},"text":"§ 15507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of non-Federal share for certain Federal grant programs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Amounts made available to carry out this subtitle shall be available for the payment of the non-Federal share for any project carried out under another Federal grant program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81f07-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15507/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which a Commission is not the sole or primary funding source; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f08-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15507/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is consistent with the authorities of the applicable Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e81f09-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2244/a"},"text":"Pub. L. 118–272, div. B, title II, § 2244(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3204"},"text":"138 Stat. 3204","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
