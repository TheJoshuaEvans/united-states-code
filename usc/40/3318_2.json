{"tag":"section","attrib":{"id":"id80bacde3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318"},"text":null,"children":[{"tag":"num","attrib":{"value":"3318"},"text":"§ 3318.","children":[{"tag":"ref","attrib":{"idref":"fn002022"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002022"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" Another section 3318 is set out preceding this section."}],"tail":null}],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of Federal building project information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80bacde4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of enactment of this section, and, at a minimum, on a quarterly basis thereafter, the Administrator shall make publicly available on a subpage of the website of the General Services Administration all prospectuses submitted pursuant to sections 3307 and 3316, and associated information subject to the following requirements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bacde5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator shall maintain such information in an easily accessible and readable, organized, downloadable, and searchable format.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacde6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator shall ensure the information is current and prospectuses and associated information updated on a regular basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacde7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The information required under this section shall be inclusive for a period of not less than 10 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacde8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The information shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80bacde9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the last date on which the relevant webpage was updated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bacdea-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approval dates of respective authorizing resolutions by each committee of jurisdiction, if applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bacdeb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" copies of respective committee of jurisdiction resolutions authorizing such prospectuses, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bacdec-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cross-references to any resubmitted or amended prospectuses and associated resolutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bacded-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bacdee-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bacdef-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prospectus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “prospectus” means prospectuses, building surveys, and factsheets submitted to the committees of jurisdiction pursuant to sections 3307 and 3316.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacdf0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Committees of jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “committees of jurisdiction” means the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacdf1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Associated information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “associated information” means resolutions approved by the committees of jurisdiction and other information as required pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80bacdf2-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/333/s2/a"},"text":"Pub. L. 116–333, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-13"},"text":"Jan. 13, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5113"},"text":"134 Stat. 5113","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80bacdf3-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80bacdf4-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80bacdf5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/333"},"text":"Pub. L. 116–333","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-01-13"},"text":"Jan. 13, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
