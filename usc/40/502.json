{"tag":"section","attrib":{"id":"id8094a87d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502"},"text":null,"children":[{"tag":"num","attrib":{"value":"502"},"text":"§ 502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services for other entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8094a87e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Agencies, Mixed-Ownership Government Corporations, and the District of Columbia","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On request, the Administrator of General Services shall provide, to the extent practicable, any of the services specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s501"},"text":"section 501 of this title","children":[],"tail":" to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8094a87f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a federal agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8094a880-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mixed-ownership Government corporation (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9101"},"text":"section 9101 of title 31","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8094a881-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8094a882-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified Nonprofit Agencies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8094a883-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On request, the Administrator may provide, to the extent practicable, any of the services specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s501"},"text":"section 501 of this title","children":[],"tail":" to an agency that is—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8094a884-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8094a885-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified nonprofit agency for the blind (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s8501/7"},"text":"section 8501(7) of title 41","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8094a886-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified nonprofit agency for other severely disabled (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s8501/6"},"text":"section 8501(6) of title 41","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8094a887-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing a commodity or service to the Federal Government under chapter 85 of title 41.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8094a888-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A nonprofit agency receiving services under this subsection shall use the services directly in making or providing to the Government a commodity or service that has been determined by the Committee for Purchase From People Who Are Blind or Severely Disabled under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s8503"},"text":"section 8503 of title 41","children":[],"tail":" to be suitable for procurement by the Government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8094a889-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Certain Supply Schedules.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8094a88a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may provide for the use by State or local governments of Federal supply schedules of the General Services Administration for the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8094a88b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Automated data processing equipment (including firmware), software, supplies, support equipment, and services (as contained in Federal supply classification code group 70).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8096f17c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Alarm and signal systems, facility management systems, firefighting and rescue equipment, law enforcement and security equipment, marine craft and related equipment, special purpose clothing, and related services (as contained in Federal supply classification code group 84 or any amended or subsequent version of that Federal supply classification group).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8096f17d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voluntary use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any case of the use by a State or local government of a Federal supply schedule pursuant to paragraph (1), participation by a firm that sells to the Federal Government through the supply schedule shall be voluntary with respect to a sale to the State or local government through such supply schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8096f17e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8096f17f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State or local government” includes any State, local, regional, or tribal government, or any instrumentality thereof (including any local educational agency or institution of higher education).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8096f180-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “tribal government” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8096f181-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the governing body of any Indian tribe, band, nation, or other organized group or community located in the continental United States (excluding the State of Alaska) that is recognized as eligible for the special programs and services provided by the United States to Indians because of their status as Indians, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8096f182-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Alaska Native regional or village corporation established pursuant to the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8096f183-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “local educational agency” has the meaning given that term in section 7013 of the Elementary and Secondary Education Act of 1965.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8096f184-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “institution of higher education” has the meaning given that term in section 101(a) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"20 U.S.C. 1001(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8096f185-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Supply Schedules for Certain Goods and Services.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8096f186-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may provide for the use by State or local governments of Federal supply schedules of the General Services Administration for goods or services that are to be used to facilitate recovery from a major disaster declared by the President under the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.), to facilitate disaster preparedness or response, or to facilitate recovery from terrorism or nuclear, biological, chemical, or radiological attack."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8096f187-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination by secretary of homeland security","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Homeland Security shall determine which goods and services qualify as goods and services described in paragraph (1) before the Administrator provides for the use of the Federal supply schedule relating to such goods and services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8096f188-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voluntary use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of the use by a State or local government of a Federal supply schedule pursuant to paragraph (1), participation by a firm that sells to the Federal Government through the supply schedule shall be voluntary with respect to a sale to the State or local government through such supply schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8096f189-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The definitions in subsection (c)(3) shall apply for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8096f18a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Supply Schedules by the Red Cross and Other Qualified Organizations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8096f18b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may provide for the use by the American National Red Cross and other qualified organizations of Federal supply schedules. Purchases under this authority by the American National Red Cross shall be used in furtherance of the purposes of the American National Red Cross set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s300102"},"text":"section 300102 of title 36","children":[],"tail":", United States Code. Purchases under this authority by other qualified organizations shall be used in furtherance of purposes determined to be appropriate to facilitate emergency preparedness and disaster relief and set forth in guidance by the Administrator of General Services, in consultation with the Administrator of the Federal Emergency Management Agency."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8096f18c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority under this subsection may not be used to purchase supplies for resale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8096f18d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “qualified organization” means a relief or disaster assistance organization as described in section 309 of the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5152"},"text":"42 U.S.C. 5152","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8096f18e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s502/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duty of Users Regarding Use of Supply Schedules","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All users of Federal supply schedules, including non-Federal users, shall use the schedules in accordance with the ordering guidance provided by the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8096f18f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1080"},"text":"116 Stat. 1080","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/tII/s211/a"},"text":"Pub. L. 107–347, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2939"},"text":"116 Stat. 2939","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVIII/s833/a"},"text":"Pub. L. 109–364, div. A, title VIII, § 833(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2332"},"text":"120 Stat. 2332","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/248/s2"},"text":"Pub. L. 110–248, § 2","children":[],"tail":", "},{