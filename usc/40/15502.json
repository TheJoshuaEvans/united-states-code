{"tag":"section","attrib":{"id":"id80e5aeba-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15502"},"text":null,"children":[{"tag":"num","attrib":{"value":"15502"},"text":"§ 15502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive economic and infrastructure development plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e5aebb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Plans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In accordance with policies established by a Commission, each State member of the Commission shall submit a comprehensive economic and infrastructure development plan for the area of the region represented by the State member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5aebc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content of Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State economic and infrastructure development plan shall reflect the goals, objectives, and priorities identified in any applicable economic and infrastructure development plan developed by a Commission under section 15303.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5aebd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation With Interested Local Parties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the development planning process (including the selection of programs and projects for assistance), a State shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5aebe-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with local development districts, local units of government, and local colleges and universities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aebf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration the goals, objectives, priorities, and recommendations of the entities described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5aec0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Participation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5aec1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15502/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Commission and applicable State and local development districts shall encourage and assist, to the maximum extent practicable, public participation in the development, revision, and implementation of all plans and programs under this subtitle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aec2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15502/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Commission shall develop guidelines for providing public participation, including public hearings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e5aec3-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14217/a/2"},"text":"Pub. L. 110–234, title XIV, § 14217(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1476"},"text":"122 Stat. 1476","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14217(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2238.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e5aec4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80e5aec5-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id80e5aec6-3a70-11f1-b817-c08bf6d1fe2c"},"text":nu