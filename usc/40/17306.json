{"tag":"section","attrib":{"id":"id80ea6937-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17306"},"text":null,"children":[{"tag":"num","attrib":{"value":"17306"},"text":"§ 17306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements of indemnity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80ea6938-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “Federal Government” includes wholly owned Government corporations, and officers and employees of the Government or its executive departments, independent establishments, and agencies while acting in their official capacity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ea6939-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Make Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury may make and deliver, on behalf of the Federal Government, a binding agreement of indemnity the Secretary considers necessary and proper to enable the Government to obtain the replacement of any instrument or document—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ea693a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received by the Government or an agent of the Government in the agent’s official capacity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ea693b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which, after having been received, is lost, destroyed, or so mutilated as to impair its value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ea693c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When Federal Government Not Obligated","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Government is not obligated under an agreement of indemnity if the obligee named in the agreement makes a payment or delivery not required by law on the original of the instrument or document covered by the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ea693d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Fund for the Payment of Government Losses in Shipment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The fund described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s17303"},"text":"section 17303 of this title","children":[],"tail":" is available to pay any obligation arising out of an agreement the Secretary makes under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ea693e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"hr