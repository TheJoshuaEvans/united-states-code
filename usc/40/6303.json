{"tag":"section","attrib":{"id":"id80c1f9ea-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6303"},"text":null,"children":[{"tag":"num","attrib":{"value":"6303"},"text":"§ 6303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c1f9eb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Displays and Solicitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is unlawful for anyone other than an authorized employee or concessionaire to carry out any of the following activities within the specified buildings and grounds:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c1f9ec-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Offer or expose any article for sale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c1f9ed-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Display any sign, placard, or other form of advertisement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c1f9ee-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6303/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Solicit alms, subscriptions, or contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c1f9ef-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Touching of, or Injuries to, Property","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is unlawful for anyone—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c1f9f0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other than an authorized employee, to touch or handle objects of art or scientific or historical objects on exhibition within the specified buildings or grounds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c1f9f1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to step or climb on, remove, or in any way injure any object of art, exhibit (including an exhibit animal), equipment, seat, wall, fountain, or other erection or architectural feature, or any tree, shrub, plant, or turf, within the specified buildings or grounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c1f9f2-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1185"},"text":"116 Stat. 1185","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c1f9f3-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"hi