{"tag":"section","attrib":{"id":"id80d7561f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11314"},"text":null,"children":[{"tag":"num","attrib":{"value":"11314"},"text":"§ 11314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to acquire and manage information technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80d75620-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority of the head of an executive agency to acquire information technology includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80d75621-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11314/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquiring information technology as authorized by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d75622-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11314/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making a contract that provides for multiagency acquisitions of information technology in accordance with guidance issued by the Director of the Office of Management and Budget; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d75623-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11314/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Director finds that it would be advantageous for the Federal Government to do so, making a multiagency contract for procurement of commercial products of information technology that requires each executive agency covered by the contract, when procuring those products, to procure the products under that contract or to justify an alternative procurement of the products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d75624-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FTS 2000 ","children":[{"tag":"inline","attrib":{},"text":"Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services shall continue to manage the FTS 2000 program, and to coordinate the follow-on to that program, for and with the advice of the heads of executive agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80d75625-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1241"},"text":"116 Stat. 1241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/g/7/B"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(g)(7)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1874"},"text":"132 Stat. 1874","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80d75626-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80d75627-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[