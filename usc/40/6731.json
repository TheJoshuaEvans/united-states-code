{"tag":"section","attrib":{"id":"id80c6b4f7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6731"},"text":null,"children":[{"tag":"num","attrib":{"value":"6731"},"text":"§ 6731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c6b4f8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6731/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal triangle development area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Federal Triangle development area” means the area bounded as follows:","children":[{"tag":"p","attrib":{"role":"listItem"},"text":"Beginning at a point on the southwest corner of the intersection of Fourteenth Street and Pennsylvania Avenue (formerly E Street), Northwest;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"thence south along the western side of Fourteenth Street to the northwest corner of the intersection of Fourteenth Street and Constitution Avenue, Northwest;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"thence east along the northern side of Constitution Avenue to the northeast corner of the intersection of Twelfth Street and Constitution Avenue, Northwest;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"thence north along the eastern side of Twelfth Street and Constitution Avenue, Northwest;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"thence north along the eastern side of Twelfth Street to the southeast corner of the intersection of Twelfth Street and Pennsylvania Avenue, Northwest;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"thence west along the southern side of Pennsylvania Avenue to the point of beginning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c6b4f9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6731/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal triangle property","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal Triangle property” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80c6b4fa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6731/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property owned by the Federal Government in the District of Columbia, known as the “Great Plaza” site, which consists of squares 256, 257, 258, parts of squares 259 and 260, and adjacent closed rights-of-way as shown on plate IV of the King Plats of 1803 located in the Office of the Surveyor of the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c6b4fb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6731/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6733/a"},"text":"section 6733(a) of this title","children":[],"tail":", any property the Pennsylvania Avenue Development Corporation acquired under section 3(b) of the Federal Triangle Development Act ("},{"tag":"ref","attrib":{"href":"/us/pl/100/113"},"text":"Public Law 100–113","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/736"},"text":"101 Stat. 736","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c6b4fc-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1198"},"text":"116 Stat. 1198","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c6b4fd-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c6b4fe-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c6b4ff-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6731","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1109.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/100/113/s10"},"text":"Pub. L. 100–113, § 10","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 21, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/747"},"text":"101 Stat. 747","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the text of 40:1109(1)–(3) is omitted as unnecessary because the complete names of the Administrator of General Services, International Cultural and Trade Center Commission, and Pennsylvania Avenue Development Corporation are used the first time the terms appear in a section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1), the words “being the southwest corner of the intersection of Fourteenth Street and Pennsylvania Avenue (formerly E Street), Northwest” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80c6b500-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80c6b501-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3(b) of the Federal Triangle Development Act, referred to in par. (2)(B), was classified to section 1102(b) of former Title 40, Public Buildings, Property, and Works, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s6/b"},"text":"Pub. L. 107–217, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1304"},"text":"116 Stat. 1304","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80c6b502-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80c6b503-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Designation of Daniel Patrick Moynihan Place","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/567/tIII/s310"},"text":"Pub. L. 106–567, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2841"},"text":"114 Stat. 2841","children":[],"tail":", designated as “Daniel Patrick Moynihan Place” a parcel of land located in Woodrow Wilson Plaza in the northwest quadrant of Washington, District of Columbia, directed the Administrator of General Services to erect appropriate gateways or other markers to denote that place, and provided that any reference in a law, map, regulation, document, paper, or other record of the United States to that parcel of land was to be deemed to be a reference to Daniel Patrick Moynihan Place."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80c6b504-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Designation of Woodrow Wilson Plaza","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/284"},"text":"Pub. L. 103–284","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-01"},"text":"Aug. 1, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1448"},"text":"108 Stat. 1448","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/284"},"text":"“That the plaza to be constructed on the Federal Triangle property in Washington, DC as part of the development of such site pursuant to the Federal Triangle Development Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/113"},"text":"Public Law 100–113","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s6731"},"text":"40 U.S.C. 6731","children":[],"tail":" et seq.] shall be known and designated as the ‘Woodrow Wilson Plaza’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80c6b505-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":" Designation of Andrew W. Mellon Auditorium","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/113/s9"},"text":"Pub. L. 100–113, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-21"},"text":"Aug. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/746"},"text":"101 Stat. 746","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/113/s9"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Departmental Auditorium, located on the Federal Triangle between the Custom Service building and Interstate Commerce Commission building on Constitution Avenue, shall on and after ","children":[{"tag":"date","attrib":{"date":"1987-08-21"},"text":"August 21, 1987","children":[],"tail":", be known and designated as the ‘Andrew W. Mellon Auditorium’."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any reference in any law, regulation, document, record, map or other paper of the United States to the auditorium referred to in subsection (a) of this section is deemed to be a reference to the ‘Andrew W. Mellon Auditorium’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
