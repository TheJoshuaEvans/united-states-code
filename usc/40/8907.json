{"tag":"section","attrib":{"id":"id80d02add-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8907"},"text":null,"children":[{"tag":"num","attrib":{"value":"8907"},"text":"§ 8907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary site designation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80d02ade-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criterion for Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary of the Interior, in consultation with the National Capital Memorial Commission, determines that a site where commemorative works may be displayed on a temporary basis is necessary to aid in the preservation of the limited amount of open space available to residents of, and visitors to, the Nation’s Capital, a site may be designated on land the Secretary administers in the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d02adf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A designation may be made under subsection (a) only if, at least 120 days before the designation, the Secretary, in consultation with the Commission, prepares and submits to Congress a plan for the site. The plan shall include specifications for the location, construction, and administration of the site and criteria for displaying commemorative works at the site.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d02ae0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8907/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Risk and Agreement To Indemnify","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A commemorative work displayed at the site shall be installed, maintained, and removed at the sole expense and risk of the person authorized to display the work. The person shall agree to indemnify the United States for any liability arising from the display of the commemorative work under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80d02ae1-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1231"},"text":"116 Stat. 1231","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80d02ae2-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80d02ae3-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80d02ae4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8907(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1009(a) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/99/652/s9"},"text":"Pub. L. 99–652, § 9","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3653"},"text":"100 Stat. 3653","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/321/s2/f"},"text":"Pub. L. 103–321, § 2(f)","children":[],"tail":", "},{"tag":"html: