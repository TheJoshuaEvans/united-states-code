{"tag":"section","attrib":{"id":"id80e5ae31-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304"},"text":null,"children":[{"tag":"num","attrib":{"value":"15304"},"text":"§ 15304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative powers and expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e5ae32-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Powers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out its duties under this subtitle, a Commission may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5ae33-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold such hearings, sit and act at such times and places, take such testimony, receive such evidence, and print or otherwise reproduce and distribute a description of the proceedings and reports on actions by the Commission as the Commission considers appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae34-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize, through the Federal or State Cochairperson or any other member of the Commission designated by the Commission, the administration of oaths if the Commission determines that testimony should be taken or evidence received under oath;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae35-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request from any Federal, State, or local agency such information as may be available to or procurable by the agency that may be of use to the Commission in carrying out the duties of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae36-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt, amend, and repeal bylaws and rules governing the conduct of business and the performance of duties by the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae37-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request the head of any Federal agency, State agency, or local government to detail to the Commission such personnel as the Commission requires to carry out its duties, each such detail to be without loss of seniority, pay, or other employee status, which may be done without a requirement for the Commission to reimburse the agency or local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae38-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for coverage of Commission employees in a suitable retirement and employee benefit system by making arrangements or entering into contracts with any participating State government or otherwise providing retirement and other employee coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae39-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept, use, and dispose of gifts or donations or services or real, personal, tangible, or intangible property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae3a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect fees for services provided and retain and expend such fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae3b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into and perform such contracts, cooperative agreements, or other transactions as are necessary to carry out Commission duties, including any contracts or cooperative agreements with a department, agency, or instrumentality of the United States, a State (including a political subdivision, agency, or instrumentality of the State), or a person, firm, association, or corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae3c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain a central office at such location in its region as the Commission may select.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5ae3d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Agency Cooperation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Federal agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5ae3e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with a Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae3f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, to the extent practicable, on request of the Federal Cochairperson, appropriate assistance in carrying out this subtitle, in accordance with applicable Federal laws (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5ae40-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Expenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5ae41-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), the administrative expenses of a Commission shall be paid—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e5ae42-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Federal Government, in an amount equal to 50 percent of the administrative expenses of the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e5ae43-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the States participating in the Commission, in an amount equal to 50 percent of the administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae44-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expenses of the federal cochairperson","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All expenses of the Federal Cochairperson, including expenses of the alternate and staff of the Federal Cochairperson, shall be paid by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae45-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State share.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e5ae46-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subparagraph (B), the share of administrative expenses of a Commission to be paid by each State of the Commission shall be determined by a majority vote of the State members of the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e5ae47-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No federal participation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Cochairperson shall not participate or vote in any decision under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e5ae48-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delinquent states","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"During any period in which a State is more than 1 year delinquent in payment of the State’s share of administrative expenses of the Commission under this subsection—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80e5ae49-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no assistance under this subtitle shall be provided to the State (including assistance to a political subdivision or a resident of the State) for any project not approved as of the date of the commencement of the delinquency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e5ae4a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no member of the Commission from the State shall participate or vote in any action by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae4b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15304/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State’s share of administrative expenses of a Commission under this subsection shall not be taken into consideration when determining the amount of assistance provided to the State under this subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e5ae4c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14217/a/2"},"text":"Pub. L. 110–234, title XIV, § 14217(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1471"},"text":"122 Stat. 1471","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14217(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2233; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6304/a"},"text":"Pub. L. 115–334, title VI, § 6304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4749"},"text":"132 Stat. 4749","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2242/c"},"text":"Pub. L. 118–272, div. B, title II, § 2242(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3203"},"text":"138 Stat. 3203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e5ae4d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80e5ae4e-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id80e5ae4f-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80e5ae50-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2242/c/1"},"text":"Pub. L. 118–272, § 2242(c)(1)","children":[],"tail":", inserted “, which may be done without a requirement for the Commission to reimburse the agency or local government” after “status”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8), (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2242/c/2"},"text":"Pub. L. 118–272, § 2242(c)(2)","children":[],"tail":", (3), added par. (8) and redesignated former par. (8) as (9). Former par. (9) redesignated (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2242/c/2"},"text":"Pub. L. 118–272, § 2242(c)(2)","children":[],"tail":", (4), redesignated par. (9) as (10) and struck out “maintain a government relations office in the District of Columbia and” before “establish and maintain a central office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “majority” for “unanimous”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80e5ae51-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id80e5ae52-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s14217/d"},"text":"section 14217(d) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s15101"},"text":"section 15101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
