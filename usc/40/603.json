{"tag":"section","attrib":{"id":"id80aa04c5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s603"},"text":null,"children":[{"tag":"num","attrib":{"value":"603"},"text":"§ 603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process for establishing motor vehicle pools and transportation systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80aa04c6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination Requirement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa04c7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s603/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services may carry out section 602 only if the Administrator determines, after consultation with the agencies concerned and with due regard to their program activities, that doing so is advantageous to the Federal Government in terms of economy, efficiency, or service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa04c8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s603/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements of the determination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A determination under this section must be in writing. For each motor vehicle pool or system, the determination must set forth an analytical justification that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80aa04c9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s603/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed comparison of estimated costs for present and proposed modes of operation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa04ca-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s603/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a showing that savings can be realized by the establishment, maintenance, and operation of a motor vehicle pool or system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa04cb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations Related to Establishment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa04cc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s603/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall prescribe regulations establishing procedures to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s602"},"text":"section 602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa04cd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s603/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements of the regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations shall provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80aa04ce-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s603/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate notice to an executive agency of any determination that affects the agency or its functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa04cf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s603/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" independent review and decision as directed by the President of any determination disputed by an agency, with the possibility that the decision may include a partial or complete exemption of the agency from the determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa04d0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s603/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforcement of determinations that become effective under the regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa04d1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s603/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of the regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A determination under subsection (a) is binding on an agency only as provided in regulations issued under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80aa04d2-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1122"},"text":"116 Stat. 1122","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80aa04d3-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80aa04d4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80aa04d5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"603(a)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:491(b) (related to determination).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title II, § 211(b) (related to determination), (c), (e), as added "},{"tag":"html:a","attrib":{"href":"/us/act/1950-09-05/ch849/s5/c"},"text":"Sept. 5, 1950, ch. 849, § 5(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/583"},"text":"64 Stat. 583","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1954-09-01/ch1211/s2"},"text":"Sept. 1, 1954, ch. 1211, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/1126"},"text":"68 Stat. 1126","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"603(a)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:491(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"603(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:491(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “within ninety days after the effective date of this section” are omitted as obsolete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
