{"tag":"section","attrib":{"id":"id80bacdab-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3315"},"text":null,"children":[{"tag":"num","attrib":{"value":"3315"},"text":"§ 3315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80bacdac-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3315/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When Allowed","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The carrying out of the duties and powers of the Administrator of General Services under this chapter, in accordance with standards the Administrator prescribes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bacdad-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3315/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, except for the authority contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3305/b"},"text":"section 3305(b) of this title","children":[],"tail":", be delegated on request to the appropriate executive agency when the estimated cost of the project does not exceed $100,000; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacdae-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3315/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be delegated to the appropriate executive agency when the Administrator determines that delegation will promote efficiency and economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bacdaf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3315/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Exemption From Other Provisions of Chapter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Delegation under subsection (a) does not exempt the person to whom the delegation is made, or the carrying out of the delegated duty or power, from any other provision of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80bacdb0-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1166"},"text":"116 Stat. 1166","children":[],"tail":", § 3313; "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s17/g/3"},"text":"Pub. L. 109–304, § 17(g)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1709"},"text":"120 Stat. 1709","children":[],"tail":"; renumbered § 3314, "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIII/s323/c/1/A"},"text":"Pub. L. 110–140, title III, § 323(c)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1590"},"text":"121 Stat. 1590","children":[],"tail":"; renumbered § 3315, "},{"tag":"ref","attrib":{"href":"/us/pl/114/235/s2/a/1"},"text":"Pub. L. 114–235, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"Oct. 7, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/964"},"text":"130 Stat. 964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","