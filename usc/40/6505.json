{"tag":"section","attrib":{"id":"id80c4434e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6505"},"text":null,"children":[{"tag":"num","attrib":{"value":"6505"},"text":"§ 6505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structural and mechanical care and security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c4434f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Structural and Mechanical Care","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Architect of the Capitol, under the direction of the Commission for the Judiciary Office Building—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c44350-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is responsible for the structural and mechanical care and maintenance of the Thurgood Marshall Federal Judiciary Building and improvements, including the care and maintenance of the grounds of the Building, in the same manner and to the same extent as for the structural and mechanical care and maintenance of the Supreme Court Building under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6111"},"text":"section 6111 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44351-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall perform all other duties and work required for the operation and domestic care of the Building and improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c44352-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c44353-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capitol police","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States Capitol Police—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80c44354-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6505/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are responsible for all exterior security of the Building and other improvements constructed under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c44355-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6505/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may police the Building and other improvements, including the interior and exterior, and may make arrests within the interior and exterior of the Building and other improvements for any violation of federal or state law or the laws of the District of Columbia, or any regulation prescribed under any of those laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44356-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Marshal of the supreme court","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This chapter does not interfere with the obligation of the Marshal of the Supreme Court to protect justices, officers, employees, or other personnel of the Supreme Court who may occupy the Building and other improvements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44357-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6505/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Architect shall transfer from the account described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6507"},"text":"section 6507 of this title","children":[],"tail":" amounts necessary to reimburse the United States Capitol Police for expenses incurred in providing exterior security under this subsection. The Capitol Police may accept amounts the Architect transfers under this paragraph. Those amounts shall be credited to the appropriation account charged by the Capitol Police in carrying out security duties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c44358-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1190"},"text":"116 Stat. 1190","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"i