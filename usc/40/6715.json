{"tag":"section","attrib":{"id":"id80c6b4e3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6715"},"text":null,"children":[{"tag":"num","attrib":{"value":"6715"},"text":"§ 6715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with District of Columbia","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c6b4e4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6715/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Local Needs, Initiative, and Participation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the purposes of this subchapter and the Pennsylvania Avenue Development Corporation Act of 1972 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/578"},"text":"Public Law 92–578","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1266"},"text":"86 Stat. 1266","children":[],"tail":"), the Administrator of General Services shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c6b4e5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6715/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult and cooperate with District of Columbia officials and community leaders at the earliest practicable time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c6b4e6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6715/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give primary consideration to local needs and desires and to local and regional goals and policies as expressed in urban renewal, community renewal, and comprehensive land use plans and regional plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c6b4e7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6715/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster local initiative and participation in connection with the planning and development of projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c6b4e8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6715/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance With Local Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent the Administrator constructs, rehabilitates, alters, or improves any project under this subchapter, the Administrator shall comply with all District of Columbia laws, ordinances, codes, and regulations. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s8722/d"},"text":"Section 8722(d) of this title","children":[],"tail":" applies to all construction, rehabilitation, alteration, and improvement of all buildings by the Administrator under this subchapter. Construction, rehabilitation, alteration, and improvement of any project by non-Federal Government sources is subject to the District of Columbia Official Code and zoning regulations."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c6b4e9-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1198"},"text":"116 Stat. 1198","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"us