"attrib":{},"text":"40:13n(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-08-18/ch479/s9/c"},"text":"Aug. 18, 1949, ch. 479, § 9(c)","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/97/390/s1/c/2"},"text":"Pub. L. 97–390, § 1(c)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 29, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1958"},"text":"96 Stat. 1958","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/99/218"},"text":"Pub. L. 99–218","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 26, 1985","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/99/1729"},"text":"99 Stat. 1729","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/99/492/s1"},"text":"Pub. L. 99–492, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 16, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/1240"},"text":"100 Stat. 1240","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/101/462"},"text":"Pub. L. 101–462","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 25, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/1079"},"text":"104 Stat. 1079","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/193"},"text":"Pub. L. 103–193","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/107/2293"},"text":"107 Stat. 2293","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/280/s1"},"text":"Pub. L. 104–280, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/3359"},"text":"110 Stat. 3359","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/106/518/tIII/s313"},"text":"Pub. L. 106–518, title III, § 313","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/114/2421"},"text":"114 Stat. 2421","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “any State” are substituted for “any part of the United States” to eliminate unnecessary words and for consistency with section 6101 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “federal or state law and any regulation under federal or state law” are substituted for “a law of the United States or any State and any regulation under such law” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “The Marshal of the Supreme Court shall report annually to the Congress on March 1 regarding the administrative cost of carrying out his duties under such subsection” are omitted pursuant to section 3003 of the Federal Reports Elimination and Sunset Act of 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"31 U.S.C. 1113","children":[],"tail":" note). See, also, page 13 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80c1f995-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80c1f996-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added subpar. (C) and struck out former subpar. (C) which read as follows: “any member of the immediate family of the Chief Justice, any Associate Justice, or any officer of the Supreme Court if the Marshal determines such protection is necessary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/148"},"text":"Pub. L. 117–148","children":[],"tail":" added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/75/s2/1/A"},"text":"Pub. L. 116–75, § 2(1)(A)","children":[],"tail":", substituted “any location” for “any State” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/75/s2/1/B"},"text":"Pub. L. 116–75, § 2(1)(B)","children":[],"tail":", substituted “Federal or State law” for “federal or state law” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/75/s2/2"},"text":"Pub. L. 116–75, § 2(2)","children":[],"tail":", substituted “Authorization To Carry Firearms—” for “Additional Requirements Related to Subsection (a)(2).—” in heading, struck out par. (1) designation and heading before “Duties under”, substituted “any location” for “any State”, and struck out par. (2) which provided that the authority provided under subsec. (a)(2) would expire on "},{"tag":"date","attrib":{"date":"2019-12-29"},"text":"Dec. 29, 2019","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/62"},"text":"Pub. L. 113–62","children":[],"tail":" substituted “2019” for “2013”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/402"},"text":"Pub. L. 110–402","children":[],"tail":" substituted “2013” for “2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/356"},"text":"Pub. L. 108–356","children":[],"tail":" substituted “2008” for “2004”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
