{"tag":"section","attrib":{"id":"id80c1f985-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6121"},"text":null,"children":[{"tag":"num","attrib":{"value":"6121"},"text":"§ 6121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c1f986-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Marshal of the Supreme Court and Supreme Court Police","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with regulations prescribed by the Marshal of the Supreme Court and approved by the Chief Justice of the United States, the Marshal and the Supreme Court Police shall have authority—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c1f987-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6121/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to police the Supreme Court Building and grounds and adjacent streets to protect individuals and property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c1f988-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6121/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in any location, to protect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80c1f989-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6121/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief Justice, any Associate Justice of the Supreme Court, and any official guest of the Supreme Court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c1f98a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6121/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any officer or employee of the Supreme Court while that officer or employee is performing official duties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c1f98b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6121/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the Marshal determines such protection is necessary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80c1f98c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6121/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any retired or former Chief Justice or Associate Justice of the Supreme Court; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80c1f98d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6121/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any member of the immediate family of the Chief Justice, any Associate Justice, any retired or former Chief Justice or Associate Justice, or any officer of the Supreme Court.","children":[{"tag":"ref","attrib":{"idref":"fn002027"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002027"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c1f98e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6121/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while performing duties necessary to carry out paragraph (1) or (2), to make arrests for any violation of Federal or State law and any regulation under Federal or State law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c1f98f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6121/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry firearms as may be required while performing duties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6102"},"text":"section 6102 of this title","children":[],"tail":", this subchapter, and subchapter IV."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c1f990-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization To Carry Firearms","children":[],"tail":"—"}],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002028"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002028"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The dash probably should be preceded by a period."}],"tail":" Duties under subsection (a)(2)(A) with respect to an official guest of the Supreme Court in any location (other than the District of Columbia, Maryland, and Virginia) shall be authorized in writing by the Chief Justice or an Associate Justice, if those duties require the carrying of firearms under subsection (a)(4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c1f991-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1182"},"text":"116 Stat. 1182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/356/s1"},"text":"Pub. L. 108–356, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-21"},"text":"Oct. 21, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1416"},"text":"118 Stat. 1416","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/402/s1/a"},"text":"Pub. L. 110–402, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4254"},"text":"122 Stat. 4254","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/62/s1"},"text":"Pub. L. 113–62, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-20"},"text":"Dec. 20, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/666"},"text":"127 Stat. 666","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/75/s2"},"text":"Pub. L. 116–75, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-11-27"},"text":"Nov. 27, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1160"},"text":"133 Stat. 1160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/148/s2"},"text":"Pub. L. 117–148, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1288"},"text":"136 Stat. 1288","children":[],"tail":"; "},{"tag":"ref","