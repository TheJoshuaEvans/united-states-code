{"tag":"section","attrib":{"id":"id80c1f9c7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6137"},"text":null,"children":[{"tag":"num","attrib":{"value":"6137"},"text":"§ 6137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c1f9c8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6137/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual who violates this subchapter, or a regulation prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6102"},"text":"section 6102 of this title","children":[],"tail":", shall be fined under title 18, imprisoned not more than 60 days, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c1f9c9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6137/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Venue and Procedure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Prosecution for a violation described in subsection (a) shall be in the United States District Court for the District of Columbia or in the Superior Court of the District of Columbia, on information by the United States Attorney or an Assistant United States Attorney.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c1f9ca-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6137/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses Involving Property Damage Over","children":[],"tail":" $100.—"}],"tail":null},{"tag":"content","attrib":{},"text":"If during the commission of a violation described in subsection (a), public property is damaged in an amount exceeding $100, the period of imprisonment for the offense may be not more than five years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c1f9cb-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1183"},"text":"116 Stat. 1183","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/356/s2"},"text":"Pub. L. 108–356, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-21"},"text":"Oct. 21, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1416"},"text":"118 Stat. 1416","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c1f9cc-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c1f9cd-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c1f9ce-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6137","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:13m.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-08-18/ch479/s8"},"text":"Aug. 18, 1949, ch. 479, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/617"},"text":"63 Stat. 617","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “fined under title 18” are substituted for “fined not more than $100” for consistency with chapter 227 of title 18.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Superior Court of the District of Columbia” are substituted for “Municipal Court for the District of Columbia” [subsequently changed to “District of Columbia Court of General Sessions” because of sections 1 and 7 of the Act of ","children":[{"tag":"date","attrib":{"date":"1963-07-08"},"text":"July 8, 1963","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/88/60"},"text":"Public Law 88–60","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/77"},"text":"77 Stat. 77","children":[],"tail":", 78)] because of section 155(a) of the District of Columbia Court Reorganization Act of 1970 ("},{"tag":"ref","attrib":{"href":"/us/pl/91/358"},"text":"Public Law 91–358","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/570"},"text":"85 Stat. 570","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80c1f9cf-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80c1f9d0-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/356"},"text":"Pub. L. 108–356","children":[],"tail":" added subsec. (b) and struck out heading and text of former subsec. (b). Text read as follows: “Prosecution for a violation described in subsection (a) shall be in the Superior Court of the District of Columbia, on information by the United States Attorney or an Assistant United States Attorney.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
