{"tag":"section","attrib":{"id":"id80996372-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s530"},"text":null,"children":[{"tag":"num","attrib":{"value":"530"},"text":"§ 530.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internal guidance on excess personal property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id809bd373-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s530/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of enactment of this section, each executive agency shall submit to the Administrator of General Services and make publicly available on the website of the executive agency the internal guidance of the executive agency on considering using excess personal property to meet the needs of the executive agency, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id809bd374-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s530/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement to consider excess personal property before buying new;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd375-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s530/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when it is practicable to check for and obtain excess personal property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd376-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s530/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how to evaluate the suitability of excess personal property for use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd377-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s530/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defined roles and responsibilities relevant to considering the use of excess personal property, including the designation of an employee as responsible for searching through available excess personal property for items that meet the needs of the executive agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id809bd378-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s530/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each executive agency shall submit to the Administrator of General Services and update on the website of the executive agency any changes to the internal guidance submitted and made available under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id809bd379-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/99/s2/a/2"},"text":"Pub. L. 118–99, § 2(a)(2)","children":[],"tail":", (e)(2), "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1578"},"text":"138 Stat. 1578","children":[],"tail":", 1579.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id809bd37a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id809bd37b-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/99/s2/e/2"},"text":"Pub. L. 118–99, § 2(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1579"},"text":"138 Stat. 1579","children":[],"tail":", provided that, effective on the date that is 5 years after "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", this section is repealed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id809bd37c-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id809bd37d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/99"},"text":"Pub. L. 118–99","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id809bd37e-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id809bd37f-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of Repeal","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/99/s2/e"},"text":"Pub. L. 118–99, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1579"},"text":"138 Stat. 1579","children":[],"tail":", provided that the repeal of this section by section 2(e)(2) is effective on the date that is 5 years after "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
