{"tag":"section","attrib":{"id":"id80c1f95a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6111"},"text":null,"children":[{"tag":"num","attrib":{"value":"6111"},"text":"§ 6111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supreme Court Building","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c1f95b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c1f95c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Structural and mechanical care","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Architect of the Capitol shall have charge of the structural and mechanical care of the Supreme Court Building, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80c1f95d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6111/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the care and maintenance of the grounds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c1f95e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6111/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supplying of all mechanical furnishings and mechanical equipment for the Building.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c1f95f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation and maintenance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Architect shall direct the operation and maintenance of the mechanical equipment and repair of the building.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c1f960-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6111/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Architect may enter into all necessary contracts to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c1f961-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts appropriated under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c1f962-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subsection (a) and sections 6112 and 6113 of this title are available for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80c1f963-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6111/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses of heating and air-conditioning refrigeration supplied by the Capitol Power Plant, advancements for which shall be made and deposited in the Treasury to the credit of appropriations provided for the Capitol Power Plant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c1f964-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6111/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of electrical energy; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c1f965-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the heading “Supreme Court of the United States” and “care of the building and grounds” are available for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80c1f966-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6111/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvements, maintenance, repairs, equipment, supplies, materials, and appurtenances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c1f967-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6111/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special clothing for workers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c1f968-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6111/b/2/C"},"text":null,"chi