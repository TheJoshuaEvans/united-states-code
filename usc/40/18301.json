{"tag":"section","attrib":{"id":"id80ecda3e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18301"},"text":null,"children":[{"tag":"num","attrib":{"value":"18301"},"text":"§ 18301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80ecda3f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ecda40-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affordable public transportation is essential to the economic vitality of the national capital area and is an essential component of regional efforts to improve air quality to meet environmental requirements and to improve the health of both residents of and visitors to the national capital area as well as to preserve the beauty and dignity of the Nation’s capital;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda41-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of mass transit by both residents of and visitors to the national capital area is substantially affected by the prices charged for mass transit services, prices that are substantially affected by labor costs, since more than two-thirds of operating costs are attributable to labor costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda42-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18301/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" labor costs incurred in providing mass transit in the national capital area have increased at an alarming rate and wages and benefits of operators and mechanics currently are among the highest in the Nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda43-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18301/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" higher operating costs incurred for public transit in the national capital area cannot be offset by increasing costs to patrons, since this often discourages ridership and thus undermines the public interest in promoting the use of public transit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda44-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18301/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" spiraling labor costs cannot be offset by the governmental entities that are responsible for subsidy payments for public transit services since local governments generally, and the District of Columbia government in particular, are operating under severe fiscal constraints;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda45-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18301/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imposition of mandatory standards applicable to arbitrators resolving arbitration disputes involving interstate compact agencies operating in the national capital area will ensure that wage increases are justified and do not exceed the ability of transit patrons and taxpayers to fund the increase; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda46-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18301/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" federal legislation is necessary under section 8 of Article I of the United States Constitution to balance the need to moderate and lower labor costs while maintaining industrial peace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ecda47-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of this chapter is to adopt standards governing arbitration that must be applied by arbitrators resolving disputes involving interstate compact agencies operating in the national capital area in order to lower operating costs for public transportation in the Washington metropolitan area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ecda48-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1291"},"text":"116 Stat. 1291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ecda49-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ecda4a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ecda4b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"18301","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1301.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/104/50/tIV/s402"},"text":"Pub. L. 104–50, title IV, § 402","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 15, 1995","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/109/463"},"text":"109 Stat. 463","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(7), the reference is to section 8 of article I of the United States Constitution to correct an error in the source provision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
