{"tag":"section","attrib":{"id":"id809236bd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s303"},"text":null,"children":[{"tag":"num","attrib":{"value":"303"},"text":"§ 303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Acquisition Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id809236be-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the General Services Administration a Federal Acquisition Service. The Administrator of General Services shall appoint a Commissioner of the Federal Acquisition Service, who shall be the head of the Federal Acquisition Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id809236bf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the direction and control of the Administrator of General Services, the Commissioner of the Federal Acquisition Service shall be responsible for carrying out functions related to the uses for which the Acquisition Services Fund is authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s321"},"text":"section 321 of this title","children":[],"tail":", including any functions that were carried out by the entities known as the Federal Supply Service and the Federal Technology Service and such other related functions as the Administrator considers appropriate."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id809236c0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regional Executives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may appoint Regional Executives in the Federal Acquisition Service, to carry out such functions within the Federal Acquisition Service as the Administrator considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id809236c1-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1072"},"text":"116 Stat. 1072","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/313/s2/a/1"},"text":"Pub. L. 109–313, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1734"},"text":"120 Stat. 1734","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id809236c2-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id809236c3-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id809236c4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},