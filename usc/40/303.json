 380","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1950-09-05/ch849/s6/a"},"text":"Sept. 5, 1950, ch. 849, § 6(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/583"},"text":"64 Stat. 583","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"303(a)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:752(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"303(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:753.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title I, § 103, "},{"tag":"html:a","attrib":{"href":"/us/stat/63/380"},"text":"63 Stat. 380","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the text of 40:752(a) (2d, last sentences) is omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(2) is substituted for 40:752(c) to eliminate obsolete language.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the text of 40:753(a) (related to Public Roads) is omitted because the Bureau of Public Roads was transferred to the Department of Commerce under section 1 of Reorganization Plan No. 7 of 1949 (eff. ","children":[{"tag":"date","attrib":{"date":"1949-08-20"},"text":"Aug. 20, 1949","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/1070"},"text":"63 Stat. 1070","children":[],"tail":"), and subsequently transferred to the Department of Transportation under the Department of Transportation Act ("},{"tag":"ref","attrib":{"href":"/us/pl/89/670"},"text":"Public Law 89–670","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/931"},"text":"80 Stat. 931","children":[],"tail":"). The text of 40:753(a) (last sentence related to Federal Works Agency transfers) and (b) is omitted as executed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id809236c5-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id809236c6-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/313"},"text":"Pub. L. 109–313","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Bureau of Federal Supply.—","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Transfer of functions","children":[],"tail":".—Subject to paragraph (2), the functions of the Administrator of General Services include functions related to the Bureau of Federal Supply in the Department of the Treasury that, immediately before "},{"tag":"date","attrib":{"date":"1949-07-01"},"text":"July 1, 1949","children":[],"tail":", were functions of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the Bureau;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the Director of the Bureau;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) the personnel of the Bureau; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) the Secretary of the Treasury.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Functions not transferred","children":[],"tail":".—The functions of the Administrator of General Services do not include functions retained in the Department of the Treasury under section 102(c) of the Federal Property and Administrative Services Act of 1949 (ch. 288, "},{"tag":"ref","attrib":{"href":"/us/stat/63/380"},"text":"63 Stat. 380","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Federal Works Agency and Commissioner of Public Buildings","children":[],"tail":".—The functions of the Administrator of General Services include functions related to the Federal Works Agency and functions related to the Commissioner of Public Buildings that, immediately before "},{"tag":"date","attrib":{"date":"1949-07-01"},"text":"July 1, 1949","children":[],"tail":", were functions of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the Federal Works Agency;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the Federal Works Administrator; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) the Commissioner of Public Buildings.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id809236c7-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id809236c8-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/313/s2/c"},"text":"Pub. L. 109–313, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1735"},"text":"120 Stat. 1735","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/313/s2/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Any reference in any other Federal law, Executive order, rule, regulation, reorganization plan, or delegation of authority, or in any document—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Federal Supply Service is deemed to refer to the Federal Acquisition Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the GSA Federal Technology Service is deemed to refer to the Federal Acquisition Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Commissioner of the Federal Supply Service is deemed to refer to the Commissioner of the Federal Acquisition Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Commissioner of the GSA Federal Technology Service is deemed to refer to the Commissioner of the Federal Acquisition Service.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id809236c9-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/313"},"text":"Pub. L. 109–313","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/313/s6"},"text":"section 6 of Pub. L. 109–313","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id809236ca-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id809236cb-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Emergency Preparedness Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For assignment of certain emergency preparedness functions to the Administrator of General Services, see Parts 1, 2, and 18 of Ex. Ord. No. 12656, ","children":[{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", 53 F.R. 47491, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5195"},"text":"section 5195 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
