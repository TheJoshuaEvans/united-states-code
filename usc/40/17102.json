{"tag":"section","attrib":{"id":"id80ea68f2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17102"},"text":null,"children":[{"tag":"num","attrib":{"value":"17102"},"text":"§ 17102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on acquisition or purchase of motor vehicles by Federal Government","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Federal Government shall not purchase a motor vehicle for use by the Government unless that motor vehicle is equipped with reasonable passenger safety devices that the Administrator of General Services requires. Those devices shall conform with standards the Administrator prescribes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s17103"},"text":"section 17103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id80ea68f3-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1279"},"text":"116 Stat. 1279","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ea68f4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ea68f5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ea68f6-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":