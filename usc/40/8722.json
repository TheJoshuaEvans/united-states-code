text":"87 Stat. 782","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8722(b)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:71d(a) (1st sentence words before proviso, 2d–last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8722(b)(2)(A)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:71d(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8722(b)(2)(B)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:71d(a) (1st sentence proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8722(c)(1), (2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:71d(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8722(c)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:71c(e) (last par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1924-06-06/ch270/s4/e"},"text":"June 6, 1924, ch. 270, § 4(e)","children":[],"tail":" (last par.), as added "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-19/ch949/s1"},"text":"July 19, 1952, ch. 949, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/787"},"text":"66 Stat. 787","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8722(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"(uncodified).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1938-06-20/ch534/s16"},"text":"June 20, 1938, ch. 534, § 16","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/52/802"},"text":"52 Stat. 802","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8722(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:71d(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “including the acquisition of land” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “received and” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), reference to the National Capital Regional Planning Council is omitted as obsolete because the Council was abolished by section 1 of Reorganization Plan No. 5 of 1966 (eff. ","children":[{"tag":"date","attrib":{"date":"1966-09-08"},"text":"Sept. 8, 1966","children":[],"tail":", 40:71b note)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the word “work” is substituted for “act in conjunction and cooperation” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the word “Commission” [meaning the National Capital Planning Commission] is substituted for “National Capital Park and Planning Commission” because of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-06-06/s9"},"text":"section 9 of the Act of June 6, 1924","children":[],"tail":" (ch. 270), as added by "},{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/s1"},"text":"section 1 of the Act of July 19, 1952","children":[],"tail":" (ch. 949, "},{"tag":"ref","attrib":{"href":"/us/stat/66/790"},"text":"66 Stat. 790","children":[],"tail":"). See section 8711(f) of the revised title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “the boundaries of” and “and from time to time redefined” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80cddffa-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80cddffb-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1938-06-20"},"text":"June 20, 1938","children":[],"tail":", referred to in subsec. (d), is "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-20/ch534"},"text":"act June 20, 1938, ch. 534","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/797"},"text":"52 Stat. 797","children":[],"tail":". While the Act was not classified to the Code, section 16 of the Act was repealed and reenacted as subsec. (d) of this section by "},{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", §§ 1, 6, "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":", 1304. See Historical and Revision Notes above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80cddffc-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284"},"text":"Pub. L. 109–284","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/stat/52/797"},"text":"52 Stat. 797","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/stat/52/802"},"text":"52 Stat. 802","children":[],"tail":"” and “are subject” for “is subject”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
