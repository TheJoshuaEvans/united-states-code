{"tag":"section","attrib":{"id":"id80ac7637-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1104"},"text":null,"children":[{"tag":"num","attrib":{"value":"1104"},"text":"§ 1104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiation of contract","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80ac7638-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The agency head shall negotiate a contract for architectural and engineering services at compensation which the agency head determines is fair and reasonable to the Federal Government. In determining fair and reasonable compensation, the agency head shall consider the scope, complexity, professional nature, and estimated value of the services to be rendered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ac7639-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Order of Negotiation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The agency head shall attempt to negotiate a contract, as provided in subsection (a), with the most highly qualified firm selected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s1103"},"text":"section 1103 of this title","children":[],"tail":". If the agency head is unable to negotiate a satisfactory contract with the firm, the agency head shall formally terminate negotiations and then undertake negotiations with the next most qualified of the selected firms, continuing the process until an agreement is reached. If the agency head is unable to negotiate a satisfactory contract with any of the selected firms, the agency head shall select additional firms in order of their competence and qualification and continue negotiations in accordance with this section until an agreement is reached."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ac763a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1130"},"text":"116 Stat. 1130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ac763b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ac763c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ac763d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1104","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:544.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title IX, § 904, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/92/582"},"text":"Pub. L. 92–582","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/1279"},"text":"86 Stat. 1279","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
