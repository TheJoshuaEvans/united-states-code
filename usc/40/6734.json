{"tag":"section","attrib":{"id":"id80c6b514-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734"},"text":null,"children":[{"tag":"num","attrib":{"value":"6734"},"text":"§ 6734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ronald Reagan Building and International Trade Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c6b515-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The building constructed on the Federal Triangle property shall be known and designated as the Ronald Reagan Building and International Trade Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c6b516-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Title","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The person selected to develop the Federal Triangle property may own the Building for not more than 35 years from the date construction of the Building began. The title to the Building shall be in the Administrator of General Services from the date title to the Federal Triangle property reverts to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c6b517-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c6b518-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Size of building","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Building (including parking facilities) may not exceed 3,100,000 gross square feet in size.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c6b519-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Height of building","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The height of the Building shall be compatible with the height of surrounding Federal Government buildings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c6b51a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Design","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Building shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80c6b51b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be designed in harmony with historical and Government buildings in the vicinity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c6b51c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect the symbolic importance and historic character of Pennsylvania Avenue and the Nation’s Capital; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c6b51d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the dignity and stability of the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c6b51e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Building shall meet all standards applicable to construction of a federal building.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c6b51f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accounting System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall maintain an accounting system for operation and maintenance of the Building which will allow accurate projections of the dates and cost of major repairs, improvements, reconstructions, and replacements of the Building and other capital expenditures on the Building. The Administrator shall act as necessary to ensure that amounts are available to cover the projected cost and expenditures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c6b520-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lease of Building.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c6b521-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lease agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under an agreement with the person selected to construct the Ronald Reagan Building and International Trade Center, the Administrator shall lease the Building for federal office space and the international cultural and trade center space.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c6b522-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum requirements of lease agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agreement includes at a minimum the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80c6b523-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limit on length of lease","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator will lease the Building for the period of time that the person selected to construct the Building owns the Building.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c6b524-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rental rate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The rental rate per square foot of occupiable space for all space in the Building will be in the best interest of the Government and will carry out the objectives of this subchapter and the Federal Triangle Development Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/113"},"text":"Public Law 100–113","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/735"},"text":"101 Stat. 735","children":[],"tail":"). The aggregate rental rate for all space in the Building shall produce an amount at least equal to the amount necessary to amortize the cost of development of the Federal Triangle property over the life of the lease."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c6b525-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obligation of amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Obligation of amounts from the Federal Building Fund shall only be made on an annual basis to meet lease payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c6b526-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6734/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization to obligate amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts may be obligated as described in paragraph (2)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c6b527-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1199"},"text":"116 Stat. 1199","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c6b528-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c6b529-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c6b52a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6734(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1101 note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Pub. L 104–68, § 1, ","children":[{"tag":"html:span","attrib":{},"text":"Dec. 22, 1995","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/109/766"},"text":"109 Stat. 766","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6734(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1102(a)(2) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/100/113"},"text":"Pub. L. 100–113","children":[],"tail":", §§ 3(a)(2) (last sentence), 4(b), 5(b)(2)(B), (d), 6, "},{"tag":"html:span","attrib":{},"text":"Aug. 21, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/736"},"text":"101 Stat. 736","children":[],"tail":", 737, 739, 740."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1104(b)(2)(B).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6734(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1103(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6734(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1104(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6734(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1105(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6734(f)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1105(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6734(f)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1105(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6734(f)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1105(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Ownership of such property and building will be by the United States” in 40:1104(b)(2)(B) are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the text of 40:1104(d) (last sentence) is omitted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (f)(1) is substituted for 40:1105(a) to eliminate obsolete words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(2), the text of 40:1105(b)(4) is omitted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (f)(3) is substituted for 40:1105(d) to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80c6b52b-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80c6b52c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Triangle Development Act, referred to in subsec. (f)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/113"},"text":"Pub. L. 100–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-21"},"text":"Aug. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/735"},"text":"101 Stat. 735","children":[],"tail":", which was classified to chapter 22 (§ 1101 et seq.) of former Title 40, Public Buildings, Property, and Works, prior to repeal, omission, and reenactment as this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", §§ 1, 6(b), "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":", 1304. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80c6b52d-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80c6b52e-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reference to Ronald Reagan Building and International Trade Center","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/68/s2"},"text":"Pub. L. 104–68, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-22"},"text":"Dec. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/766"},"text":"109 Stat. 766","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/68/s2"},"text":"“Any reference in a law, map, regulation, document, paper, or other record of the United States to the building referred to in section 1 [now ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6734/a"},"text":"40 U.S.C. 6734(a)","children":[],"tail":"] shall be deemed to be a reference to the ‘Ronald Reagan Building and International Trade Center’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
