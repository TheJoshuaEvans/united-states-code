{"tag":"section","attrib":{"id":"id80aa05cc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s704"},"text":null,"children":[{"tag":"num","attrib":{"value":"704"},"text":"§ 704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other methods of disposal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80aa05cd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Foreign excess property not disposed of under section 702 or 703 of this title may be disposed of as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ac75ce-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Methods of Disposal.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ac75cf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sale, exchange, lease, or transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an executive agency may dispose of foreign excess property by sale, exchange, lease, or transfer, for cash, credit or other property, with or without warranty, under terms and conditions the head of the executive agency considers proper.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ac75d0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exchange for foreign currency or credit","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the head of an executive agency determines that it is in the interest of the United States, foreign excess property may be exchanged for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80ac75d1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s704/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign currencies or credits; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80ac75d2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s704/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantial benefits or the discharge of claims resulting from the compromise or settlement of claims in accordance with law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ac75d3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s704/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Abandonment, destruction, or donation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an executive agency may authorize the abandonment, destruction, or donation of foreign excess property if the property has no commercial value or if estimated costs of care and handling exceed the estimated proceeds from sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ac75d4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advertising","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an executive agency may dispose of foreign excess property without advertising if the head of the executive agency finds that disposal without advertising is the most practicable and advantageous means for the Federal Government to dispose of the property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ac75d5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Title","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an executive agency may execute documents to transfer title or other interests in, and take other action necessary or proper to dispose of, foreign excess property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ac75d6-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1126"},"text":"116 Stat. 1126","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ac75d7-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ac75d8-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ac75d9-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"704","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:512(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title IV, § 402(a), "},{"tag":"html:a","attrib":{"href":"/us/stat/63/398"},"text":"63 Stat. 398","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/91/426/s2/a"},"text":"Pub. L. 91–426, § 2(a)","children":[],"tail":"–(c), "},{"tag":"html:span","attrib":{},"text":"Sept. 26, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/883"},"text":"84 Stat. 883","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/99/627/s3/a"},"text":"Pub. L. 99–627, § 3(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 7, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3509"},"text":"100 Stat. 3509","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
