{"tag":"section","attrib":{"id":"id80b3a16a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114"},"text":null,"children":[{"tag":"num","attrib":{"value":"3114"},"text":"§ 3114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of taking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80b3a16b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing and Content","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any proceeding in any court of the United States outside of the District of Columbia brought by and in the name of the United States and under the authority of the Federal Government to acquire land, or an easement or right of way in land, for the public use, the petitioner may file, with the petition or at any time before judgment, a declaration of taking signed by the authority empowered by law to acquire the land described in the petition, declaring that the land is taken for the use of the Government. The declaration of taking shall contain or have annexed to it—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b3a16c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the authority under which, and the public use for which, the land is taken;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b3a16d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the land taken that is sufficient to identify the land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b3a16e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the estate or interest in the land taken for public use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b3a16f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan showing the land taken; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b3a170-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the amount of money estimated by the acquiring authority to be just compensation for the land taken.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b3a171-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vesting of Title","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On filing the declaration of taking and depositing in the court, to the use of the persons entitled to the compensation, the amount of the estimated compensation stated in the declaration—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b3a172-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title to the estate or interest specified in the declaration vests in the Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b3a173-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the land is condemned and taken for the use of the Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b3a174-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to just compensation for the land vests in the persons entitled to the compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b3a175-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b3a176-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination and award","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Compensation shall be determined and awarded in the proceeding and established by judgment. The judgment shall include interest, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3116"},"text":"section 3116 of this title","children":[],"tail":", on the amount finally awarded as the value of the property as of the date of taking and shall be awarded from that date to the date of payment. Interest shall not be allowed on as much of the compensation as has been paid into the court. Amounts paid into the court shall not be charged with commissions or poundage."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b3a177-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Order to pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On application of the parties in interest, the court may order that any part of the money deposited in the court be paid immediately for or on account of the compensation to be awarded in the proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b3a178-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deficiency judgment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the compensation finally awarded is more than the amount of money received by any person entitled to compensation, the court shall enter judgment against the Government for the amount of the deficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b3a179-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Court","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the filing of a declaration of taking, the court—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b3a17a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may fix the time within which, and the terms on which, the parties in possession shall be required to surrender possession to the petitioner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b3a17b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make just and equitable orders in respect of encumbrances, liens, rents, taxes, assessments, insurance, and other charges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b3a17c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3114/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vesting Not Prevented or Delayed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An appeal or a bond or undertaking given in a proceeding does not prevent or delay the vesting of title to land in the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b3a17d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1145"},"text":"116 Stat. 1145","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b3a17e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b3a17f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80b3a180-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3114(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:258a (1st par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1931-02-26/ch307/s1"},"text":"Feb. 26, 1931, ch. 307, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/46/1421"},"text":"46 Stat. 1421","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/99/656/s1/1"},"text":"Pub. L. 99–656, § 1(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3668"},"text":"100 Stat. 3668","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3114(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:258a (2d par. 1st sentence words before 1st semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3114(c)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:258a (2d par. 1st sentence words after 1st semicolon, last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3114(c)(2), (3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:258a (3d par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3114(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:258a (last par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3114(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:258b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1931-02-26/ch307/s2"},"text":"Feb. 26, 1931, ch. 307, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/46/1422"},"text":"46 Stat. 1422","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “which has been or may be” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “said lands in fee simple absolute, or such less” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “deemed to be” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
