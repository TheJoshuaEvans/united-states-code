{"tag":"section","attrib":{"id":"id80bf88d4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104"},"text":null,"children":[{"tag":"num","attrib":{"value":"5104"},"text":"§ 5104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80bf88d5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bf88d6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Act of physical violence","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “act of physical violence” means any act involving—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80bf88d7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assault or other infliction or threat of infliction of death or bodily harm on an individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bf88d8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damage to, or destruction of, real or personal property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bf88d9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dangerous weapon","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “dangerous weapon” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80bf88da-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all articles enumerated in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1932-07-08/s14/a"},"text":"section 14(a) of the Act of July 8, 1932","children":[],"tail":" (ch. 465, "},{"tag":"ref","attrib":{"href":"/us/stat/47/654"},"text":"47 Stat. 654","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bf88db-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a device designed to expel or hurl a projectile capable of causing injury to individuals or property, a dagger, a dirk, a stiletto, and a knife having a blade over three inches in length.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bf88dc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Explosives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “explosives” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s841/d"},"text":"section 841(d) of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bf88dd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Firearm","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “firearm” has the meaning given that term in section 921(3) ","children":[{"tag":"ref","attrib":{"idref":"fn002026"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002026"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “921(a)(3)”."}],"tail":" of title 18."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bf88de-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obstruction of Roads","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person may not occupy the roads in the United States Capitol Grounds in a manner that obstructs or hinders their proper use, or use the roads in the area of the Grounds, south of Constitution Avenue and B Street and north of Independence Avenue and B Street, to convey goods or merchandise, except to or from the United States Capitol on Federal Government service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bf88df-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sale of Articles, Display of Signs, and Solicitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may not carry out any of the following activities in the Grounds:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bf88e0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer or expose any article for sale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bf88e1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" display a sign, placard, or other form of advertisement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bf88e2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit fares, alms, subscriptions, or contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bf88e3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Injuries to Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person may not step or climb on, remove, or in any way injure any statue, seat, wall, fountain, or other erection or architectural feature, or any tree, shrub, plant, or turf, in the Grounds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bf88e4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capitol Grounds and Buildings Security.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bf88e5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Firearms, dangerous weapons, explosives, or incendiary devices","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual or group of individuals—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80bf88e6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as authorized by regulations prescribed by the Capitol Police Board—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80bf88e7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not carry on or have readily accessible to any individual on the Grounds or in any of the Capitol Buildings a firearm, a dangerous weapon, explosives, or an incendiary device;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80bf88e8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not discharge a firearm or explosives, use a dangerous weapon, or ignite an incendiary device, on the Grounds or in any of the Capitol Buildings; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80bf88e9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not transport on the Grounds or in any of the Capitol Buildings explosives or an incendiary device; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bf88ea-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not knowingly, with force and violence, enter or remain on the floor of either House of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bf88eb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Violent entry and disorderly conduct","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual or group of individuals may not willfully and knowingly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80bf88ec-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter or remain on the floor of either House of Congress or in any cloakroom or lobby adjacent to that floor, in the Rayburn Room of the House of Representatives, or in the Marble Room of the Senate, unless authorized to do so pursuant to rules adopted, or an authorization given, by that House;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bf88ed-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter or remain in the gallery of either House of Congress in violation of rules governing admission to the gallery adopted by that House or pursuant to an authorization given by that House;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bf88ee-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with the intent to disrupt the orderly conduct of official business, enter or remain in a room in any of the Capitol Buildings set aside or designated for the use of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80bf88ef-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" either House of Congress or a Member, committee, officer, or employee of Congress, or either House of Congress; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80bf88f0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Library of Congress;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bf88f1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utter loud, threatening, or abusive language, or engage in disorderly or disruptive conduct, at any place in the Grounds or in any of the Capitol Buildings with the intent to impede, disrupt, or disturb the orderly conduct of a session of Congress or either House of Congress, or the orderly conduct in that building of a hearing before, or any deliberations of, a committee of Congress or either House of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bf88f2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obstruct, or impede passage through or within, the Grounds or any of the Capitol Buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bf88f3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in an act of physical violence in the Grounds or any of the Capitol Buildings; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bf88f4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parade, demonstrate, or picket in any of the Capitol Buildings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bf88f5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption of government officials","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection does not prohibit any act performed in the lawful discharge of official duties by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80bf88f6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Member of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bf88f7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of a Member of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bf88f8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer or employee of Congress or a committee of Congress; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bf88f9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer or employee of either House of Congress or a committee of that House.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bf88fa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Parades, Assemblages, and Display of Flags","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5106"},"text":"section 5106 of this title","children":[],"tail":", a person may not—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bf88fb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parade, stand, or move in processions or assemblages in the Grounds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bf88fc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5104/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" display in the Grounds a flag, banner, or device designed or adapted to bring into public notice a party, organization, or movement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80bf88fd-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1176"},"text":"116 Stat. 1176","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s1004/d/2/A/iii"},"text":"Pub. L. 110–161, div. H, title I, § 1004(d)(2)(A)(iii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2234"},"text":"121 Stat. 2234","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/178/s4/b/1/C"},"text":"Pub. L. 110–178, § 4(b)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-07"},"text":"Jan. 7, 2008","children":[],"tail":", "},{"tag":