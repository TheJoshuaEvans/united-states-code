":[],"tail":") because of "},{"tag":"ref","attrib":{"href":"/us/act/1995-06-03/s1/a/9"},"text":"section 1(a)(9) of the Act of June 3, 1995","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/104/14"},"text":"Public Law 104–14","children":[],"tail":", 2:21 note prec.). The word “purchase” is omitted as being included in “acquire”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “if any” and “as the case may be” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “at any time thereafter” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(2)(A), the word “first” is omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80b85d2f-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80b85d30-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 11(b) of the Federal Assets Sale and Transfer Act of 2016, referred to in subsec. (b)(8), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/287/s11/b"},"text":"section 11(b) of Pub. L. 114–287","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s1303"},"text":"section 1303 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (i)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this subsection, referred to subsec. (j)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272"},"text":"Pub. L. 118–272","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80b85d31-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2304/c/1"},"text":"Pub. L. 118–272, § 2304(c)(1)","children":[],"tail":", inserted “(referred to in this section as the ‘Administrator’)” after “Administrator of General Services” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9) to (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2304/c/2"},"text":"Pub. L. 118–272, § 2304(c)(2)","children":[],"tail":"–(4), added pars. (9) to (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2304/a"},"text":"Pub. L. 118–272, § 2304(a)","children":[],"tail":", inserted at end “The Administrator shall notify, in writing, the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate of any increase of more than 5 percent of an estimated maximum cost or of any increase or decrease in the scope or size of a project of 5 or more percent. Such notification shall include an explanation regarding any such increase or decrease. The scope or size of a project shall not increase or decrease by more than 10 percent unless an amended prospectus is submitted and approved pursuant to this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2304/f"},"text":"Pub. L. 118–272, § 2304(f)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2310"},"text":"Pub. L. 118–272, § 2310","children":[],"tail":", added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/287"},"text":"Pub. L. 114–287","children":[],"tail":" added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s323/a"},"text":"Pub. L. 110–140, § 323(a)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s323/b"},"text":"Pub. L. 110–140, § 323(b)","children":[],"tail":", added subsec. (f) and redesignated former subsecs. (f) and (g) as (g) and (h), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80b85d32-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id80b85d33-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":