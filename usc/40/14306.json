{"tag":"section","attrib":{"id":"id80dc1191-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306"},"text":null,"children":[{"tag":"num","attrib":{"value":"14306"},"text":"§ 14306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative powers and expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80dc1192-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Powers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out its duties under this subtitle, the Appalachian Regional Commission may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80dc1193-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt, amend, and repeal bylaws and regulations governing the conduct of its business and the performance of its functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc1194-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint and fix the compensation of an executive director and other personnel as necessary to enable the Commission to carry out its functions, except that the compensation shall not exceed the maximum rate of basic pay for the Senior Executive Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of title 5","children":[],"tail":", including any applicable locality-based comparability payment that may be authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5304/h/2/C"},"text":"section 5304(h)(2)(C) of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc1195-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request the head of any federal department or agency to detail to temporary duty with the Commission personnel within the administrative jurisdiction of the head of the department or agency that the Commission may need for carrying out its functions, each detail to be without loss of seniority, pay, or other employee status;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc1196-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrange for the services of personnel from any state or local government, subdivision or agency of a state or local government, or intergovernmental agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc1197-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80dc1198-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make arrangements, including contracts, with any participating state government for inclusion in a suitable retirement and employee benefit system of Commission personnel who may not be eligible for, or continue in, another governmental retirement or employee benefit system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc1199-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise provide for coverage of its personnel;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc119a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept, use, and dispose of gifts or donations of services or any property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc119b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enter into and perform contracts, leases (including the lease of office space for any term), cooperative agreements, or other transactions, necessary in carrying out its functions, on terms as it may consider appropriate, with any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80dc119c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" department, agency, or instrumentality of the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc119d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State or political subdivision, agency, or instrumentality of a State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc119e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" person;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc119f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a temporary office in the District of Columbia and establish a permanent office at a central and appropriate location it may select and field offices at other places it may consider appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc11a0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take other actions and incur other expenses as may be necessary or appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc11a1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorizations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80dc11a2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detail employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of a federal department or agency may detail personnel under subsection (a)(3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc11a3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enter into and perform transactions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A department, agency, or instrumentality of the Government, to the extent not otherwise prohibited by law, may enter into and perform a contract, lease, cooperative agreement, or other transaction under subsection (a)(7).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc11a4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retirement and Other Employee Benefit Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Office of Personnel Management may contract with the Commission for continued coverage of Commission employees, if the employees are federal employees when they begin Commission employment, in the retirement program and other employee benefit programs of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc11a5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Administrative expenses of the Commission shall be paid equally by the Government and the States in the Appalachian region, except that the expenses of the Federal Cochairman, the alternate to the Federal Cochairman, and the staff of the Federal Cochairman shall be paid only by the Government. The Commission shall determine the amount to be paid by each State. The Federal Cochairman shall not participate or vote in that determination. Assistance authorized by this subtitle shall not be furnished to any State or to any political subdivision or any resident of any State, and a state member of the Commission shall not participate or vote in any decision by the Commission, while the State is delinquent in payment of its share of administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80dc11a6-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1259"},"text":"116 Stat. 1259","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80dc11a7-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80dc11a8-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80dc11a9-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14306(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:106(1), (2) (1st sentence), (3) (less words in parentheses), (4), (5) (1st sentence), (6), (7) (less words in last parentheses), (8), (9).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/4/tI/s106/1"},"text":"Pub. L. 89–4, title I, § 106(1)","children":[],"tail":", (2) (1st sentence), (3)–(9), "},{"tag":"html:span","attrib":{},"text":"Mar. 9, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/8"},"text":"79 Stat. 8","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/90/103/tI/s104"},"text":"Pub. L. 90–103, title I, § 104","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 11, 1967","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/81/257"},"text":"81 Stat. 257","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/92/65/tII/s203"},"text":"Pub. L. 92–65, title II, § 203","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 5, 1971","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/85/168"},"text":"85 Stat. 168","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/94/188/tI/s107"},"text":"Pub. L. 94–188, title I, § 107","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/89/1080"},"text":"89 Stat. 1080","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/506/s3/2"},"text":"Pub. L. 96–506, § 3(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 8, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/2746"},"text":"94 Stat. 2746","children":[],"tail":"; Pub. L 105–393, title II, §§ 205, 206, "},{"tag":"html:span","attrib":{},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/3619"},"text":"112 Stat. 3619","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/107/149/s13/b"},"text":"Pub. L. 107–149, § 13(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Mar. 12, 2002","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/116/71"},"text":"116 Stat. 71","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14306(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:106(3) (words in parentheses), (7) (words in last parentheses).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14306(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:106(5) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14306(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:105.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/4/tI/s105"},"text":"Pub. L. 89–4, title I, § 105","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Mar. 9, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/8"},"text":"79 Stat. 8","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/90/103/tI/s103"},"text":"Pub. L. 90–103, title I, § 103","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 11, 1967","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/81/257"},"text":"81 Stat. 257","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/91/123/tI/s102"},"text":"Pub. L. 91–123, title I, § 102","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 25, 1969","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/83/214"},"text":"83 Stat. 214","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/92/65/tII/s202"},"text":"Pub. L. 92–65, title II, § 202","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 5, 1971","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/85/168"},"text":"85 Stat. 168","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/94/188/tI/s106"},"text":"Pub. L. 94–188, title I, § 106","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/89/1080"},"text":"89 Stat. 1080","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/506/s3/1"},"text":"Pub. L. 96–506, § 3(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 8, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/2746"},"text":"94 Stat. 2746","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/35/tXVIII/s1822/a/1"},"text":"Pub. L. 97–35, title XVIII, § 1822(a)(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/767"},"text":"95 Stat. 767","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/393/tII/s204"},"text":"Pub. L. 105–393, title II, § 204","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/3619"},"text":"112 Stat. 3619","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(6), the words “any property” are substituted for “property, real, personal, or mixed, tangible or intangible” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(7), before subclause (A), the words “notwithstanding any other provision of law” are omitted as unnecessary. In subclause (C), the words “firm, association, or corporation” are omitted as being included in the definition of “person” in 1:1.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “Director of the Office of Personnel Management” are substituted for “Civil Service Commission” in section 106(5) of the Appalachian Regional Development Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/4"},"text":"Public Law 89–4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/8"},"text":"79 Stat. 8","children":[],"tail":") because of section 102 of Reorganization Plan No. 2 of 1978 (eff. "},{"tag":"date","attrib":{"date":"1979-01-01"},"text":"Jan. 1, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3783"},"text":"92 Stat. 3783","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the word “amount” is substituted for “share” for clarity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
