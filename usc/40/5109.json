{"tag":"section","attrib":{"id":"id80c1f926-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5109"},"text":null,"children":[{"tag":"num","attrib":{"value":"5109"},"text":"§ 5109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c1f927-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Firearms, Dangerous Weapons, Explosives, or Incendiary Device Offenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual or group violating ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5104/e/1"},"text":"section 5104(e)(1) of this title","children":[],"tail":", or attempting to commit a violation, shall be fined under title 18, imprisoned for not more than five years, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c1f928-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Offenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person violating section 5103 or 5104(b), (c), (d), (e)(2), or (f) of this title, or attempting to commit a violation, shall be fined under title 18, imprisoned for not more than six months, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c1f929-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c1f92a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5109/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An action for a violation of this chapter or section 9, 9A, 9B, 9C or 14 of the Act of ","children":[{"tag":"date","attrib":{"date":"1946-07-31"},"text":"July 31, 1946","children":[],"tail":" (ch. 707, "},{"tag":"ref","attrib":{"href":"/us/stat/60/719"},"text":"60 Stat. 719","children":[],"tail":", 720), including an attempt or a conspiracy to commit a violation, shall be brought by the Attorney General in the name of the United States. This chapter and sections 9, 9A, 9B, 9C and 14 do not supersede any provision of federal law or the laws of the District of Columbia. Where the conduct violating this chapter or section 9, 9A, 9B, 9C or 14 also violates federal law or the laws of the District of Columbia, both violations may be joined in a single action."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c1f92b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5109/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Venue","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An action under this section for a violation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80c1f92c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5109/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5104/e/1"},"text":"section 5104(e)(1) of this title","children":[],"tail":" or for conduct that constitutes a felony under federal law or the laws of the District of Columbia shall be brought in the United States District Court for the District of Columbia; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c1f92d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5109/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other section referred to in subsection (a) may be brought in the Superior Court of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c1f92e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s5109/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The penalty which may be imposed on a person convicted in an action under this subsection is the highest penalty authorized by any of the laws the defendant is convicted of violating.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c1f92f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1178"},"text":"116 Stat. 1178","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c1f930-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c1f931-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c1f932-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5109","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:193h.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-07-31/ch707/s8"},"text":"July 31, 1946, ch. 707, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/719"},"text":"60 Stat. 719","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/87/571"},"text":"Pub. L. 87–571","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1962","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/76/307"},"text":"76 Stat. 307","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/90/108/s1/c"},"text":"Pub. L. 90–108, § 1(c)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 20, 1967","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/81/277"},"text":"81 Stat. 277","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “fined under title 18” are substituted for “a felony punishable by a fine not exceeding $5,000” for consistency with chapter 227 of title 18.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “fined under title 18” are substituted for “a misdemeanor punishable by a fine not exceeding $500” for consistency with chapter 227 of title 18.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “An action . . . shall be brought” are substituted for [“]shall be prosecuted” for consistency with other titles of the United States Code. The words “the Attorney General” are substituted for “the United States attorney or his assistants” because of 28:509.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2)(B), the words “Superior Court of the District of Columbia” are substituted for “Municipal Court for the District of Columbia” [subsequently changed to “District of Columbia Court of General Sessions” because of sections 1 and 7 of the Act of ","children":[{"tag":"date","attrib":{"date":"1963-07-08"},"text":"July 8, 1963","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/88/60"},"text":"Public Law 88–60","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/77"},"text":"77 Stat. 77","children":[],"tail":", 78)] because of section 155(a) of the District of Columbia Court Reorganization Act of 1970 ("},{"tag":"ref","attrib":{"href":"/us/pl/91/358"},"text":"Public Law 91–358","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/570"},"text":"85 Stat. 570","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the words “of a violation of said sections and of the general laws of the United States or the laws of the District of Columbia” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80c1f933-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80c1f934-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 9, 9A, 9B, 9C, and 14 of the Act of ","children":[{"tag":"date","attrib":{"date":"1946-07-31"},"text":"July 31, 1946","children":[],"tail":", referred to in subsec. (c)(1), are classified to sections 1961, 1966, 1967, 1922, and 1969, respectively, of Title 2, The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
