{"tag":"section","attrib":{"id":"id80cde045-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8734"},"text":null,"children":[{"tag":"num","attrib":{"value":"8734"},"text":"§ 8734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of land by Mayor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80cde046-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8734/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Sell","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With the approval of the National Capital Planning Commission, the Mayor of the District of Columbia, for the best interests of the District of Columbia, may sell to the highest bidder at public or private sale real estate in the District of Columbia owned in fee simple by the District of Columbia for municipal use that the Council of the District of Columbia and the Commission find to be no longer required for public purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80cde047-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8734/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Paying Expenses and Depositing Proceeds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Mayor—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80cde048-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8734/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may pay the reasonable and necessary expenses of the sale of each parcel of land sold; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cde049-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8734/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall deposit the net proceeds of each sale in the Treasury to the credit of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80cde04a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1226"},"text":"116 Stat. 1226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80cde04b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80cde04c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80cde04d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"t