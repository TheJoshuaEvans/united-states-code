{"tag":"section","attrib":{"id":"id80b3a181-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3115"},"text":null,"children":[{"tag":"num","attrib":{"value":"3115"},"text":"§ 3115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Irrevocable commitment of Federal Government to pay ultimate award when fixed","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80b3a182-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Irrevocable Commitment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3114"},"text":"section 3114 of this title","children":[],"tail":" irrevocably committing the Federal Government to the payment of the ultimate award shall not be taken unless the head of the executive department or agency or bureau of the Government empowered to acquire the land believes that the ultimate award probably will be within any limits Congress prescribes on the price to be paid."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b3a183-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Purposes of Expenditures After Irrevocable Commitment Made","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the Government has taken or may take title to real property during a condemnation proceeding and in advance of final judgment in the proceeding and has become irrevocably committed to pay the amount ultimately to be awarded as compensation, and the Attorney General believes that title to the property has been vested in the Government or that all persons having an interest in the property have been made parties to the proceeding and will be bound by the final judgment, the Government may expend amounts appropriated for that purpose to demolish existing structures on the property and to erect public buildings or public works on the property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b3a184-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1146"},"text":"116 Stat. 1146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b3a185-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b3a186-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80b3a187-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3115(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:258c.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1931-02-26/ch307/s3"},"text":"Feb. 26, 1931, ch. 307, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/46/1422"},"text":"46 Stat. 1422","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3115(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:258e.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1931-02-26/ch307/s5"},"text":"Feb. 26, 1931, ch. 307, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/46/1422"},"text":"46 Stat. 1422","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/91/393/s4"},"text":"Pub. L. 91–393, § 4","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 1, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/835"},"text":"84 Stat. 835","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “possession of” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
