{"tag":"section","attrib":{"id":"id80e81f8f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15751"},"text":null,"children":[{"tag":"num","attrib":{"value":"15751"},"text":"§ 15751.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e81f90-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15751/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to each Commission to carry out this subtitle $40,000,000 for each of fiscal years 2025 through 2029.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81f91-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15751/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Expenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81f92-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15751/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), not more than 10 percent of the funds made available to a Commission in a fiscal year under this section may be used for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f93-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15751/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limited funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a case in which less than $10,000,000 is made available to a Commission for a fiscal year under this section, paragraph (1) shall not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e81f94-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14217/a/2"},"text":"Pub. L. 110–234, title XIV, § 14217(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1482"},"text":"122 Stat. 1482","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14217(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2244; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVI/s6207"},"text":"Pub. L. 113–79, title VI, § 6207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/861"},"text":"128 Stat. 861","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6304/e"},"text":"Pub. L. 115–334, title VI, § 6304(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4752"},"text":"132 Stat. 4752","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2241"},"text":"Pub. L. 1