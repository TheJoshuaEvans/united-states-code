{"tag":"section","attrib":{"id":"id80ea699e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17509"},"text":null,"children":[{"tag":"num","attrib":{"value":"17509"},"text":"§ 17509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80ea699f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority in Reducing Headquarters Use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The heads of executive agencies shall give first priority to meeting the goals established by the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s17507/a"},"text":"section 17507(a) of this title","children":[],"tail":" by reducing the costs of administrative motor vehicles used at the headquarters and regional headquarters of executive agencies, rather than by reducing the costs of motor vehicles used by line agency personnel working in agency field operations or activities."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ea69a0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations, Standards, and Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall require the Administrator of General Services, in cooperation with the Director of the Office of Management and Budget, to prescribe appropriate regulations, standards, and definitions to ensure that executive agencies meet the goals established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s17507/a"},"text":"section 17507(a) of this title","children":[],"tail":" in the manner prescribed by subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ea69a1-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1285"},"text":"116 Stat. 1285","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ea69a2-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ea69a3-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ea69a4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"