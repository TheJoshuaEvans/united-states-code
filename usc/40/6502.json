itted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the text of 40:1202(d) (2d sentence) is omitted as obsolete.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80c4432e-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80c4432f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Building Height Act of 1910, referred to in subsec. (c)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1910-06-01/ch263"},"text":"act June 1, 1910, ch. 263","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/452"},"text":"36 Stat. 452","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80c44330-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80c44331-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reference to the Thurgood Marshall Federal Judiciary Building","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/4/s2"},"text":"Pub. L. 103–4, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-08"},"text":"Feb. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/30"},"text":"107 Stat. 30","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/4/s2"},"text":"“Any reference in any law, map, regulation, document, paper, or other record of the United States to the Federal Judiciary Building referred to in section 1 [now ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6502/a"},"text":"40 U.S.C. 6502(a)","children":[],"tail":"] shall be deemed to be a reference to the ‘Thurgood Marshall Federal Judiciary Building’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
