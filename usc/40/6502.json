{"tag":"section","attrib":{"id":"id80c44317-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502"},"text":null,"children":[{"tag":"num","attrib":{"value":"6502"},"text":"§ 6502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Thurgood Marshall Federal Judiciary Building","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c44318-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is a Federal Judiciary Building in Washington, D.C., known and designated as the “Thurgood Marshall Federal Judiciary Building”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c44319-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Title.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c4431a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Squares 721 and 722","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Title to squares 721 and 722 remains in the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c4431b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Building","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Title to the Building and other improvements constructed or otherwise made immediately reverts to the Government at the expiration of not more than 30 years from the effective date of the lease agreement referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6504"},"text":"section 6504 of this title","children":[],"tail":" without payment of any compensation by the Government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c4431c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c4431d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Size of building","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Building (excluding parking facilities) may not exceed 520,000 gross square feet in size above the level of Columbia Plaza in the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c4431e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Height of building","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The height of the Building and other improvements shall be compatible with the height of surrounding Government and historic buildings and conform to the provisions of the Act of ","children":[{"tag":"date","attrib":{"date":"1910-06-01"},"text":"June 1, 1910","children":[],"tail":" (ch. 263, "},{"tag":"ref","attrib":{"href":"/us/stat/36/452"},"text":"36 Stat. 452","children":[],"tail":") (known as the Building Height Act of 1910)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c4431f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Design","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Building and other improvements shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80c44320-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be designed in harmony with historical and Government buildings in the vicinity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c44321-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect the symbolic importance and historic character of the United States Capitol and other buildings on the United States Capitol Grounds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c44322-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the dignity and stability of the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c44323-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval of Chief Justice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All final decisions regarding architectural design of the Building are subject to the approval of the Chief Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c44324-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chilled Water and Steam From Capitol Power Plant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Building is connected with the Capitol Power Plant, the Architect of the Capitol shall furnish chilled water and steam from the Plant to the Building on a reimbursable basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c44325-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Building and other improvements constructed under this chapter shall meet all standards applicable to construction of a federal building.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c44326-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accounting System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Architect shall maintain an accounting system for operation and maintenance of the Building and other improvements which will allow accurate projections of the dates and cost of major repairs, improvements, reconstructions, and replacements of the Building and improvements and other capital expenditures on the Building and improvements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c44327-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplicability of Certain Laws.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c44328-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Building codes, permits, or inspection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Building is not subject to any law of the District of Columbia relating to building codes, permits, or inspection, including any such law enacted by Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44329-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6502/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Taxes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Building and other improvements constructed under this chapter are not subject to any law of the District of Columbia relating to real estate and personal property taxes, special assessments, or other taxes, including any such law enacted by Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c4432a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1188"},"text":"116 Stat. 1188","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c4432b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c4432c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c4432d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6502(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1201 note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/103/4/s1"},"text":"Pub. L. 103–4, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Feb. 8, 1993","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/107/30"},"text":"107 Stat. 30","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6502(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1202(b)(2)(B), (C).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[