{"tag":"section","attrib":{"id":"id8096f1af-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s505"},"text":null,"children":[{"tag":"num","attrib":{"value":"505"},"text":"§ 505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange or transfer of medical supplies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8096f1b0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Excess Property Determination.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8096f1b1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Medical materials or supplies an executive agency holds for national emergency purposes are considered excess property for purposes of subchapter II when the head of the agency determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8096f1b2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s505/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remaining storage or shelf life is too short to justify continued retention for national emergency purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8096f1b3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s505/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer or other disposal is in the national interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8096f1b4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the greatest extent practicable, the head of the agency shall make the determination in sufficient time to allow for the transfer or other disposal and use of medical materials or supplies before their shelf life expires and they are rendered unfit for human use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8096f1b5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer or Exchange.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8096f1b6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In accordance with regulations the Administrator of General Services prescribes, medical materials or supplies considered excess property may be transferred to another federal agency or exchanged with another federal agency for other medical materials or supplies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8096f1b7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of proceeds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any proceeds derived from a transfer under this section may be credited to the current applicable appropriation or fund of the transferor agency and shall be available only to purchase medical materials or supplies to be held for national emergency purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8096f1b8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s505/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disposal as surplus property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the materials or supplies are not transferred to or exchanged with another federal agency, they shall be disposed of as surplus property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8096f1b9-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1081"},"text":"116 Stat. 1081","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8096f1ba-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id8096f1bb-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id8096f1bc-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"505","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:481(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title II, § 201(e), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/91/426/s1"},"text":"Pub. L. 91–426, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 26, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/883"},"text":"84 Stat. 883","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “holding such medical materials or supplies” and “provided for in the first sentence of this subsection” are omitted as unnecessary because of the reorganization of the revised section. The words “in sufficient time to allow for” are substituted for “at such times as to insure . . . in sufficient time” for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
