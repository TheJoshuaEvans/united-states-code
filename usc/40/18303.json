{"tag":"section","attrib":{"id":"id80ecda56-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303"},"text":null,"children":[{"tag":"num","attrib":{"value":"18303"},"text":"§ 18303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for arbitrators","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80ecda57-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “public welfare” includes, with respect to arbitration under an interstate compact—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ecda58-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial ability of the individual jurisdictions participating in the compact to pay for the costs of providing public transit services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda59-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average per capita tax burden, during the term of the collective bargaining agreement to which the arbitration relates, of the residents of the Washington metropolitan area, and the effect of an arbitration award rendered under that arbitration on the respective income or property tax rates of the jurisdictions that provide subsidy payments to the interstate compact agency established under the compact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ecda5a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors in Making Arbitration Award","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An arbitrator rendering an arbitration award involving the employees of an interstate compact agency operating in the national capital area may not make a finding or a decision for inclusion in a collective bargaining agreement governing conditions of employment without considering the following factors:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ecda5b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The existing terms and conditions of employment of the employees in the bargaining unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda5c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All available financial resources of the interstate compact agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda5d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The annual increase or decrease in consumer prices for goods and services as reflected in the most recent consumer price index for the Washington metropolitan area, published by the Bureau of Labor Statistics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda5e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The wages, benefits, and terms and conditions of the employment of other employees who perform, in other jurisdictions in the Washington standard metropolitan statistical area, services similar to those in the bargaining unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda5f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The special nature of the work performed by the employees in the bargaining unit, including any hazards or the relative ease of employment, physical requirements, educational qualifications, job training and skills, shift assignments, and the demands placed upon the employees as compared to other employees of the interstate compact agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda60-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The interests and welfare of the employees in the bargaining unit, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80ecda61-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the overall compensation presently received by the employees, having regard not only for wage rates but also for wages for time not worked, including vacations, holidays, and other excused absences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80ecda62-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all benefits received by the employees, including previous bonuses, insurance, and pensions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80ecda63-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continuity and stability of employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda64-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The public welfare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ecda65-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ability To Finance Salaries and Benefits Provided in Award","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An arbitrator rendering an arbitration award involving the employees of an interstate compact agency operating in the national capital area may not, with respect to a collective bargaining agreement governing conditions of employment, provide for salaries and other benefits that exceed the ability of the interstate compact agency, or of any governmental jurisdiction that provides subsidy payments or budgetary assistance to the interstate compact agency, to obtain the necessary financial resources to pay for wage and benefit increases for employees of the interstate compact agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ecda66-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Final Award.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ecda67-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written award","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In resolving a dispute submitted to arbitration involving the employees of an interstate compact agency operating in the national capital area, the arbitrator shall issue a written award that demonstrates that all the factors set forth in subsections (b) and (c) have been considered and applied.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda68-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prerequisites","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An award may grant an increase in pay rates or benefits (including insurance and pension benefits), or reduce hours of work, only if the arbitrator concludes that any costs to the agency do not adversely affect the public welfare.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda69-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s18303/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Substantial evidence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The arbitrator’s conclusion regarding the public welfare must be supported by substantial evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ecda6a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1292"},"text":"116 Stat. 1292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ecda6b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ecda6c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ecda6d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"18303(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1302(6).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/104/50/tIV"},"text":"Pub. L. 104–50, title IV","children":[],"tail":", §§ 403(3), (6), 404, "},{"tag":"html:span","attrib":{},"text":"Nov. 15, 1995","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/109/464"},"text":"109 Stat. 464","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"18303(b)–(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1302(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1303.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of 40:1302(3) and 1303(b) is combined because 40:1303(b) is the only place the definition of “funding ability” is used in the revised chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
