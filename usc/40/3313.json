{"tag":"section","attrib":{"id":"id80bacd78-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313"},"text":null,"children":[{"tag":"num","attrib":{"value":"3313"},"text":"§ 3313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement of life-cycle cost effective and energy efficient lighting systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80bacd79-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bacd7a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Administrator” means the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacd7b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lighting system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “lighting system” means the elements required to maintain a desired light level, including lamps, light fixtures, fixture distribution, sensors and control technologies, interior design elements, and daylighting sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bacd7c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procurement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bacd7d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80bacd7e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure the most life-cycle cost effective and energy efficient lighting systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bacd7f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that procurements after the date of enactment of the BRIGHT Act of lighting systems or the individual components of lighting systems maximize life-cycle cost effectiveness and energy efficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacd80-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each public building constructed, altered, acquired, or leased by the Administrator shall be equipped, to the maximum extent practicable as determined by the Administrator, with the most life-cycle cost effective and energy efficient lighting systems for each application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bacd81-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance of Public Buildings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each individual component of a lighting system, including a lamp or fixture, that is replaced by the Administrator in the normal course of maintenance of public buildings shall be replaced, to the maximum extent practicable, with the most life-cycle cost effective and energy efficient lighting system possible for the application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bacd82-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bacd83-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracting options","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this section, the Administrator shall consider appropriate contracting options for the procurement of the most life-cycle cost effective and energy efficient lighting systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacd84-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procurement and use","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making a determination under this section concerning the practicability of procuring and installing the most life-cycle cost effective and energy efficient lighting system, the Administrator shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80bacd85-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compatibility of the lighting system with existing equipment, including consideration of a cost effective retrofit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bacd86-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether procurement and use of the lighting system could result in interference with productivity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bacd87-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aesthetics relating to the use of the lighting system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bacd88-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as the Administrator determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bacd89-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Life-Cycle Cost Effective","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall use the procedures and methods established under section 544(a) of the National Energy Conservation Policy Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8254/a"},"text":"42 U.S.C. 8254(a)","children":[],"tail":") in determining whether a lighting system is life-cycle cost effective."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bacd8a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Energy Star","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A lighting system shall be treated as being energy efficient for purposes of this section if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bacd8b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lighting system or the individual components of the lighting system are certified under the Energy Star program established by section 324A of the Energy Policy and Conservation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6294a"},"text":"42 U.S.C. 6294a","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacd8c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of all light-emitting diode (LED) luminaires, lamps, and systems whose efficacy (lumens per watt) and Color Rendering Index (CRI) meet the Department of Energy requirements for minimum luminaire efficacy and CRI for the Energy Star certification, as verified by an independent third-party testing laboratory that the Administrator and the Secretary of Energy determine conducts its tests according to the procedures and recommendations of the Illuminating Engineering Society of North America, even if the luminaires, lamps, and systems have not received such certification; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacd8d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator and the Secretary of Energy have otherwise determined that the lighting system is energy efficient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bacd8e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Energy Efficient Lighting Designations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Environmental Protection Agency and the Secretary of Energy shall give priority to establishing Energy Star performance criteria or Federal Energy Management Program designations for additional lighting product categories that are appropriate for procurement and use in public buildings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bacd8f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall develop guidelines for the procurement and use of energy efficient lighting technologies that contain mercury in child care centers in public buildings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bacd90-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3313/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Buy American Act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Acquisitions carried out pursuant to this section shall be subject to the requirements of the Buy American Act ","children":[{"tag":"ref","attrib":{"idref":"fn002019"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002019"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s10c"},"text":"41 U.S.C. 10c","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80bacd91-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIII/s323/c/1/B"},"text":"Pub. L. 110–140, title III, § 323(c)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1590"},"text":"121 Stat. 1590","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/202/s3/a"},"text":"Pub. L. 117–202, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-10-17"},"text":"Oct. 17, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2224"},"text":"136 Stat. 2224","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80bacd92-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80bacd93-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80bacd94-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the BRIGHT Act, referred to in subsec. (b)(1)(B), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/202"},"text":"Pub. L. 117–202","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-10-17"},"text":"Oct. 17, 2022","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Buy American Act, referred to in subsec. (i), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-03-03/ch212"},"text":"act Mar. 3, 1933, ch. 212","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/1520"},"text":"47 Stat. 1520","children":[],"tail":", which was classified generally to sections 10a, 10b, and 10c of former Title 41, Public Contracts, and was substantially repealed and restated in chapter 83 (§ 8301 et seq.) of Title 41, Public Contracts, by "},{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":", §§ 3, 7(b), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3677"},"text":"124 Stat. 3677","children":[],"tail":", 3855. For complete classification of this Act to the Code, see Short Title of 1933 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s101"},"text":"section 101 of Title 41","children":[],"tail":" and Tables. For disposition of sections of former Title 41, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s101"},"text":"section 101 of Title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id80bacd95-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3313 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3315"},"text":"section 3315 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80bacd96-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/202/s3/a/3"},"text":"Pub. L. 117–202, § 3(a)(3)","children":[],"tail":", substituted “Procurement of life-cycle cost effective and energy efficient lighting systems” for “Use of energy efficient lighting fixtures and bulbs” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/202/s3/a/3"},"text":"Pub. L. 117–202, § 3(a)(3)","children":[],"tail":", added subsecs. (a) to (c) and struck out former subsecs. (a) to (c) which related to use of energy efficient lighting fixtures and bulbs in new and existing public buildings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/202/s3/a/3"},"text":"Pub. L. 117–202, § 3(a)(3)","children":[],"tail":", added subsecs. (d) and (e). Former subsecs. (d) and (e) redesignated (f) and (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/202/s3/a/2"},"text":"Pub. L. 117–202, § 3(a)(2)","children":[],"tail":", (4)(A), redesignated subsec. (d) as (f) and substituted “lighting system” for “lighting fixture or bulb” in introductory provisions. Former subsec. (f) redesignated (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/202/s3/a/4/B"},"text":"Pub. L. 117–202, § 3(a)(4)(B)","children":[],"tail":", substituted “the lighting system or the individual components of the lighting system are” for “the fixture or bulb is”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/202/s3/a/4/C"},"text":"Pub. L. 117–202, § 3(a)(4)(C)","children":[],"tail":", substituted “lighting system” for “fixture or bulb”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/202/s3/a/2"},"text":"Pub. L. 117–202, § 3(a)(2)","children":[],"tail":", (5), redesignated subsec. (e) as (g) and inserted “procurement and” before “use in public buildings”. Former subsec. (g) redesignated (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/202/s3/a/2"},"text":"Pub. L. 117–202, § 3(a)(2)","children":[],"tail":", (6), redesignated subsec. (f) as (h) and inserted “procurement and” before “use of energy efficient”. Former subsec. (h) struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/202/s3/a/1"},"text":"Pub. L. 117–202, § 3(a)(1)","children":[],"tail":", struck out subsec. (h). Text read as follows: “The requirements of subsections (a) and (b) shall take effect 1 year after the date of enactment of this subsection.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/202/s3/a/2"},"text":"Pub. L. 117–202, § 3(a)(2)","children":[],"tail":", redesignated subsec. (g) as (i)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80bacd97-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id80bacd98-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80bacd99-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/202/s2"},"text":"Pub. L. 117–202, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-10-17"},"text":"Oct. 17, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2224"},"text":"136 Stat. 2224","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/202/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-10-17"},"text":"Oct. 17, 2022","children":[],"tail":"], the Administrator of General Services shall—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue guidance to Federal agencies for the procurement and use of the most life-cycle cost effective and energy efficient lighting systems (as determined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3313"},"text":"section 3313 of title 40","children":[],"tail":", United States Code) to increase the efficiency, effectiveness, and economy of the Federal Government; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish on the internet or otherwise make available to State, local, and Tribal entities information on ways to improve efficiency, effectiveness, and economy by procuring and using the most life-cycle cost effective and energy efficient lighting systems (as determined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3313"},"text":"section 3313 of title 40","children":[],"tail":", United States Code).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
