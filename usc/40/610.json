{"tag":"section","attrib":{"id":"id80aa0512-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s610"},"text":null,"children":[{"tag":"num","attrib":{"value":"610"},"text":"§ 610.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discontinuance of motor vehicle pool or system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80aa0513-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s610/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services shall discontinue a motor vehicle pool or system if there are no actual savings realized (based on accounting as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s605"},"text":"section 605 of this title","children":[],"tail":") during a reasonable period of not longer than two successive fiscal years."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa0514-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s610/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Return of Comparable Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a motor vehicle pool or system is discontinued, the Administrator shall return to each agency involved motor vehicles and related equipment and supplies similar in kind and reasonably comparable in value to any motor vehicles and related equipment and supplies which were previously taken over by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80aa0515-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"h