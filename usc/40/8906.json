{"tag":"section","attrib":{"id":"id80d02ac7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8906"},"text":null,"children":[{"tag":"num","attrib":{"value":"8906"},"text":"§ 8906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for issuance of construction permit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80d02ac8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Issuing Permit","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before issuing a permit for the construction of a commemorative work in the District of Columbia and its environs, the Secretary of the Interior or Administrator of General Services, as appropriate, shall determine that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80d02ac9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8906/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the site and design have been approved by the Secretary or Administrator, the National Capital Planning Commission and the Commission of Fine Arts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02aca-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8906/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowledgeable individuals qualified in the field of preservation and maintenance have been consulted to determine structural soundness and durability of the commemorative work and to ensure that the commemorative work meets high professional standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02acb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8906/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sponsor authorized to construct the commemorative work has submitted contract documents for construction of the commemorative work to the Secretary or Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02acc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8906/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sponsor authorized to construct the commemorative work has available sufficient amounts to complete construction of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d02acd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Donation for Perpetual Maintenance and Preservation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80d02ace-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8906/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the criteria described above in subsection (a), no construction permit shall be issued unless the sponsor authorized to construct the commemorative work has donated an amount equal to 10 percent of the total estimated cost of construction to offset the costs of perpetual maintenance and preservation of the commemorative work. All such amounts shall be available for those purposes pursuant to the provisions of this subsection. The provisions of this subsection shall not apply in instances when the commemorative work is constructed by a Department or agency of the Federal Government and less than 50 percent of the funding for such work is provided by private sources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02acf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8906/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, money on deposit in the Treasury on the date of enactment of the Commemorative Works Clarification and Revision Act of 2003 provided by a sponsor for maintenance pursuant to this subsection shall be credited to a separate account in the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02ad0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8906/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Money provided by a sponsor pursuant to the provisions of this subsection after the date of enactment of the Commemorative Works Clarification and Revision Act of 2003 shall be credited to a separate account with the National Park Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02ad1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8906/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon request of the Secretary or Administrator (as appropriate), the Secretary of the Treasury or the National Park Foundation shall make all or a portion of such moneys available to the Secretary or the Administrator (as appropriate) for the maintenance of a commemorative work. Under no circumstances may the Secretary or Administrator request funds from a separate account exceeding the total money in the account established under paragraph (2) or (3). The Secretary and the Administrator shall maintain an inventory of funds available for such purposes. Funds provided under this paragraph shall be available without further appropriation and shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d02ad2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspension for Misrepresentation in Fundraising","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Interior or Administrator may suspend any activity under this chapter that relates to the establishment of a commemorative work if the Secretary or Administrator determines that fundraising efforts relating to the work have misrepresented an affiliation with the work or the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d02ad3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8906/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The person authorized to construct a commemorative work under this chapter must submit to the Secretary of the Interior or Administrator an annual report of operations, including financial statements audited by an independent certified public accountant. The person shall pay for the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80d02ad4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1230"},"text":"116 Stat. 1230","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/126/tII/s203/f"},"text":"Pub. L. 108–126, title II, § 203(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-17"},"text":"Nov. 17, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1351"},"text":"117 Stat. 1351","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80d02ad5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80d02ad6-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80d02ad7-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8906(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1008(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/99/652/s8"},"text":"Pub. L. 99–652, § 8","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3652"},"text":"100 Stat. 3652","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/321/s2/e"},"text":"Pub. L. 103–321, § 2(e)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/1794"},"text":"108 Stat. 1794","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8906(b)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1008(b) (words before proviso), cl. (1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8906(b)(2), (3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1008(b)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8906(b)(4)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1008(b) (proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8906(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1008(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8906(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1008(c)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “Notwithstanding any other provision of law” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “Congress authorizes and directs that” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80d02ad8-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80d02ad9-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Commemorative Works Clarification and Revision Act of 2003, referred to in subsec. (b)(2), (3), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126"},"text":"Pub. L. 108–126","children":[],"tail":", which was approved on "},{"tag":"date","attrib":{"date":"2003-11-17"},"text":"Nov. 17, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80d02ada-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126/s203/f/1"},"text":"Pub. L. 108–126, § 203(f)(1)","children":[],"tail":", substituted “sponsor” for “person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126/s203/f/2"},"text":"Pub. L. 108–126, § 203(f)(2)","children":[],"tail":", added subsec. (b) and struck out heading and text of former subsec. (b). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—In addition to the criteria described in subsection (a), a construction permit may not be issued unless the person authorized to construct the commemorative work has donated an amount equal to 10 percent of the total estimated cost of construction to offset the costs of perpetual maintenance and preservation of the commemorative work. The amounts shall be credited to a separate account in the Treasury."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—The Secretary of the Treasury shall make any part of the donated amount available to the Secretary of the Interior or Administrator for maintenance at the request of the Secretary of the Interior or Administrator. The Secretary of the Interior or Administrator shall not request more from the separate account than the total amount deposited by persons establishing commemorative works in areas the Secretary of the Interior or Administrator administers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) ","children":[{"tag":"inline","attrib":{},"text":"Inventory of available amounts","children":[],"tail":".—The Secretary of the Interior and Administrator shall maintain an inventory of amounts available under this subsection. The amounts are not subject to annual appropriations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) ","children":[{"tag":"inline","attrib":{},"text":"Nonapplicability","children":[],"tail":".—This subsection does not apply when a department or agency of the Federal Government constructs the work and less than 50 percent of the funding for the work is provided by private sources.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80d02adb-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id80d02adc-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126"},"text":"Pub. L. 108–126","children":[],"tail":" not applicable to a commemorative work for which a site was approved in accordance with this chapter prior to "},{"tag":"date","attrib":{"date":"2003-11-17"},"text":"Nov. 17, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/126/s205"},"text":"section 205 of Pub. L. 108–126","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s8901"},"text":"section 8901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
