{"tag":"section","attrib":{"id":"id80c8ff1c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8144"},"text":null,"children":[{"tag":"num","attrib":{"value":"8144"},"text":"§ 8144.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery of fuel for use during ensuing fiscal year","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"During April, May, and June of each year, the Administrator of General Services may deliver to all branches of the Federal Government and the government of the District of Columbia as much fuel for their use during the following fiscal year as may be practicable to store at the points of consumption. The branches of the Federal Government and the government of the District of Columbia shall pay for the fuel from their applicable appropriations for that fiscal year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id80c8ff1d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1209"},"text":"116 Stat. 1209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c8ff1e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c8ff1f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c8ff20-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8144","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:113.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1920-06-05/ch235"},"text":"June 5, 1920, ch. 235","children":[],"tail":" (2d complete par. on p. 913), "},{"tag":"html:a","attrib":{"href":"/us/stat/41/913"},"text":"41 Stat. 913","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “the months of” are omitted as unnecessary. The words “Administrator of General Services” are substituted for “Secretary of the Interior” [subsequently changed to [“]Secretary of the Treasury” because of Executive Order No. 4239 (eff. ","children":[{"tag":"date","attrib":{"date":"1925-07-01"},"text":"July 1, 1925","children":[],"tail":") and section 1 of Executive Order No. 6166 (eff. "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":")] because of sections 109(a) and 201(a)(2) of the Federal Property and Administrative Services Act of 1949 (ch. 288, "},{"tag":"ref","attrib":{"href":"/us/stat/63/382"},"text":"63 Stat. 382","children":[],"tail":", 384), restated as sections 321(b)(1) and 501(d) of the revised title. The word “Government” is substituted for “service” for clarity and for consistency in the revised title and with other titles of the United States Code. The word “municipal” is omitted as unnecessary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
