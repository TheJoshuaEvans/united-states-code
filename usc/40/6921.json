{"tag":"section","attrib":{"id":"id80c6b576-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6921"},"text":null,"children":[{"tag":"num","attrib":{"value":"6921"},"text":"§ 6921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment, composition, and meetings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c6b577-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6921/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is a National Visitor Facilities Advisory Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c6b578-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6921/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c6b579-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6921/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission is composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80c6b57a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6921/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c6b57b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6921/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of General Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c6b57c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6921/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Smithsonian Institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c6b57d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6921/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the National Capital Planning Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c6b57e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6921/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Commission of Fine Arts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c6b57f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6921/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six Members of the Senate, three from each party, to be appointed by the President of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c6b580-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6921/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six Members of the House of Representatives, three from each party, to be appointed by the Speaker of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c6b581-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6921/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three individuals appointed by the President, at least two of whom shall not be officers of the Federal Government, and one member of whom shall be a representative of the District of Columbia government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c6b582-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6921/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Interior serves as the Chairman of the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c6b583-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6921/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service of non-federal members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Non-federal members serve at the pleasure of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c6b584-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6921/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},