{"tag":"section","attrib":{"id":"id80b5ebef-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3144"},"text":null,"children":[{"tag":"num","attrib":{"value":"3144"},"text":"§ 3144.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to pay wages and list contractors violating contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80b5ebf0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3144/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Wages.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b5ebf1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3144/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Labor shall pay directly to laborers and mechanics from any accrued payments withheld under the terms of a contract any wages found to be due laborers and mechanics under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b5ebf2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3144/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Right of action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the accrued payments withheld under the terms of the contract are insufficient to reimburse all the laborers and mechanics who have not been paid the wages required under this subchapter, the laborers and mechanics have the same right to bring a civil action and intervene against the contractor and the contractor’s sureties as is conferred by law on persons furnishing labor or materials. In those proceedings it is not a defense that the laborers and mechanics accepted or agreed to accept less than the required rate of wages or voluntarily made refunds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b5ebf3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3144/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"List of Contractors Violating Contracts.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b5ebf4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3144/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General shall distribute to all departments of the Federal Government a list of the names of persons whom the Comptroller General has found to have disregarded their obligations to employees and subcontractors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b5ebf5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3144/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction on awarding contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No contract shall be awarded to persons appearing on the list or to any firm, corporation, partnership, or association in which the persons have an interest until three years have elapsed from the date of publication of the list.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b5ebf6-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1152"},"text":"116 Stat. 1152","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/50/s2/a"},"text":"Pub. L. 113–50, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-11-21"},"text":"Nov. 21, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/578"},"text":"127 Stat. 578","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b5ebf7-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b5ebf8-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80b5ebf9-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3144(a)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:276a–2(a) (1st sentence words before semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1931-03-03/ch411/s3"},"text":"Mar. 3, 1931, ch. 411, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/46/1494"},"text":"46 Stat. 1494","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1935-08-30/ch825"},"text":"Aug. 30, 1935, ch. 825","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/1012"},"text":"49 Stat. 1012","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3144(a)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:276a–2(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3144(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:276a–2(a) (1st sentence words after semicolon, last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “or firms” are omitted as being included in “persons”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80b5ebfa-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80b5ebfb-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/50/s2/a/1"},"text":"Pub. L. 113–50, § 2(a)(1)","children":[],"tail":", struck out “of Comptroller General” after “Authority” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/50/s2/a/2"},"text":"Pub. L. 113–50, § 2(a)(2)","children":[],"tail":", substituted “Secretary of Labor” for “Comptroller General”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
