trib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"525(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:483(d) (words before par. (1)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title II, § 202(d), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/94/519/s3"},"text":"Pub. L. 94–519, § 3","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/2454"},"text":"90 Stat. 2454","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/98/tXIV/s1443"},"text":"Pub. L. 97–98, title XIV, § 1443","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/1321"},"text":"95 Stat. 1321","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"525(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:483(d)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"525(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:483(d)(2)(E).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"525(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:483(d)(2)(A)–(D).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before cl. (A), the words “institution or” are omitted as unnecessary. In clause (A), the words “termination provision” are substituted for “termination made” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “The grantee shall account for and dispose of” are substituted for “and shall be accounted for and disposed of” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (c) and (d), the text of 40:483(d)(2) (last sentence) is omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “Trust Territory of the Pacific Islands” are omitted and the words “the Federated States of Micronesia, the Marshall Islands, Palau” are added because of the termination of the Trust Territory of the Pacific Islands. See 48:1681 note prec.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(1), the words “to the extent” are substituted for “where and to the extent” to eliminate unnecessary words. The words “to be furnished under such Act” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(4), the words “Indian Financing Act of 1974” are substituted for “Indian Financing Act” in section 202(d)(2)(D) of the Federal Property and Administrative Services Act of 1949 to execute the probable intent of Congress. The word “tribe” is substituted for “Indian tribes” for consistency with 25:1452(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80996346-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80996347-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Smith-Lever Act, referred to in subsec. (c)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-05-08/ch79"},"text":"act May 8, 1914, ch. 79","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/372"},"text":"38 Stat. 372","children":[],"tail":", which is classified generally to subchapter IV (§ 341 et seq.) of chapter 13 of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s341"},"text":"section 341 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Hatch Act of 1887, referred to in subsec. (c)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-03-02/ch314"},"text":"act Mar. 2, 1887, ch. 314","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/440"},"text":"24 Stat. 440","children":[],"tail":", which is classified generally to sections 361a to 361i of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s361a"},"text":"section 361a of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1962-10-10"},"text":"October 10, 1962","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s582a"},"text":"16 U.S.C. 582a","children":[],"tail":" et seq.), referred to in subsec. (c)(2)(C), is "},{"tag":"ref","attrib":{"href":"/us/pl/87/788"},"text":"Pub. L. 87–788","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-10"},"text":"Oct. 10, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/806"},"text":"76 Stat. 806","children":[],"tail":", popularly known as the “McIntire-Stennis Act of 1962” and also as the “McIntire-Stennis Cooperative Forestry Act”, which is classified generally to subchapter III (§ 582a et seq.) of chapter 3 of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s582a"},"text":"section 582a of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
