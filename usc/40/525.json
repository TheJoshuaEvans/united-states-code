{"tag":"section","attrib":{"id":"id8099632d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525"},"text":null,"children":[{"tag":"num","attrib":{"value":"525"},"text":"§ 525.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess personal property for federal agency grantees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8099632e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A federal agency is prohibited from obtaining excess personal property for the purpose of furnishing the property to a grantee of the agency, except as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8099632f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Public Agencies and Tax-exempt Nonprofit Organizations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80996330-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations the Administrator of General Services may prescribe, a federal agency may obtain excess personal property for the purpose of furnishing it to a public agency or an organization that is nonprofit and exempt from taxation under section 501 of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501"},"text":"26 U.S.C. 501","children":[],"tail":"), if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80996331-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency or organization is conducting a federally sponsored project pursuant to a grant made for a specific purpose with a specific termination provision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80996332-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property is to be furnished for use in connection with the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80996333-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80996334-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sponsoring federal agency pays an amount equal to 25 percent of the original acquisition cost (except for costs of care and handling) of the excess property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80996335-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount is deposited in the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80996336-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Title","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Title to excess property obtained under this subsection vests in the grantee. The grantee shall account for and dispose of the property in accordance with procedures governing accountability for personal property acquired under grant agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80996337-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Certain Property Furnished by Secretary of Agriculture.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80996338-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “State” means a State of the United States, Puerto Rico, Guam, American Samoa, the Northern Mariana Islands, the Federated States of Micronesia, the Marshall Islands, Palau, the Virgin Islands, and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80996339-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations and restrictions the Administrator may prescribe, subsection (a) does not apply to property furnished by the Secretary of Agriculture to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8099633a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a state ","children":[{"tag":"ref","attrib":{"idref":"fn002007"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002007"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" or county extension service engaged in cooperative agricultural extension work under the Smith-Lever Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s341"},"text":"7 U.S.C. 341","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8099633b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a state ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" experiment station engaged in cooperative agricultural research work under the Hatch Act of 1887 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s361a"},"text":"7 U.S.C. 361a","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8099633c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution engaged in cooperative agricultural research or extension work under section 1433, 1434, 1444, or 1445 of the National Agricultural Research, Extension, and Teaching Policy Act of 1977 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3195"},"text":"7 U.S.C. 3195","children":[],"tail":", 3196, 3221, or 3222), or the Act of "},{"tag":"date","attrib":{"date":"1962-10-10"},"text":"October 10, 1962","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s582a"},"text":"16 U.S.C. 582a","children":[],"tail":" et seq.), if the Federal Government retains title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8099633d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations and restrictions the Administrator may prescribe, subsection (a) does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8099633e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property furnished under section 608 of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2358"},"text":"22 U.S.C. 2358","children":[],"tail":"), to the extent that the Administrator determines that the property is not needed for donation under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s549"},"text":"section 549 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8099633f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific equipment furnished under section 11(e) of the National Science Foundation Act of 1950 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1870/e"},"text":"42 U.S.C. 1870(e)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80996340-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property furnished under section 203 of the Department of Agriculture Organic Act of 1944 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s580a"},"text":"16 U.S.C. 580a","children":[],"tail":"), in connection with the Cooperative Forest Fire Control Program, if the Government retains title; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80996341-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s525/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property furnished in connection with a grant to a tribe, as defined in section 3(c) of the Indian Financing Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1452/c"},"text":"25 U.S.C. 1452(c)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80996342-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1084"},"text":"116 Stat. 1084","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id"