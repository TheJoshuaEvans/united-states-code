{"tag":"section","attrib":{"id":"id80aa04d6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s604"},"text":null,"children":[{"tag":"num","attrib":{"value":"604"},"text":"§ 604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of assets taken over to establish motor vehicle pools and transportation systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80aa04d7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa04d8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s604/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"When the Administrator of General Services takes over motor vehicles or related equipment or supplies under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s602"},"text":"section 602 of this title","children":[],"tail":", reimbursement is required if the property is taken over from—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80aa04d9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s604/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Government corporation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa04da-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s604/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency, if the agency acquired the property through unreimbursed expenditures made from a revolving or trust fund authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa04db-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s604/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall reimburse a Government corporation, or a fund through which an agency acquired property, by an amount equal to the fair market value of the property. If the Administrator subsequently returns property of a similar kind under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s610"},"text":"section 610 of this title","children":[],"tail":", the Government corporation or the fund shall reimburse the Administrator by an amount equal to the fair market value of the property returned."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa04dc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Addition to Acquisition Services Fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Administrator takes over motor vehicles or related equipment or supplies under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s602"},"text":"section 602 of this title","children":[],"tail":" but reimbursement is not required under subsection (a), the value of the property taken over, as determined by the Administrator, may be added to the capital of the Acquisition Services Fund. If the Administrator subsequently returns property of a similar kind under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s610"},"text":"section 610 of this title","children":[],"tail":", the value of the property may be deducted from the Fund."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80aa04dd-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1122"},"text":"116 Stat. 1122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/313/s3/h/5"},"text":"Pub. L. 109–313, § 3(h)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1736"},"text":"120 Stat. 1736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80aa04de-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80aa04df-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80aa04e0-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n