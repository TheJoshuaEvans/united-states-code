{"tag":"section","attrib":{"id":"id80c1f99c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6123"},"text":null,"children":[{"tag":"num","attrib":{"value":"6123"},"text":"§ 6123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Metropolitan Police of the District of Columbia","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Metropolitan Police of the District of Columbia may make arrests within the Supreme Court Building and grounds for a violation of federal or state law or any regulation under federal or state law. This section does not authorize the Metropolitan Police to enter the Supreme Court Building to make an arrest in response to a complaint, serve a warrant, or patrol the Supreme Court Building or grounds, unless the Metropolitan Police have been requested to do so by, or have received the consent of, the Marshal of the Supreme Court or an assistant to the Marshal.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id80c1f99d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1182"},"text":"116 Stat. 1182","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c1f99e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c1f99f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c1f9a0-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6123","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:13n(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-08-18/ch479/s9/b"},"text":"Aug. 18, 1949, ch. 479, § 9(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/617"},"text":"63 Stat. 617","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/390/s1/c/1"},"text":"Pub. L. 97–390, § 1(c)(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 29, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1957"},"text":"96 Stat. 1957","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “violation of federal or state law or any regulation under federal or state law” are substituted for “violations of any such laws or regulations”, and the words “unless the Metropolitan Police have been requested to do so by, or have received the consent of, the Marshal of the Supreme Court of the United States or an assistant to the Marshal” are substituted for “except with the consent or on the request of the Marshal of the Supreme Court or his assistants”, for clarity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
