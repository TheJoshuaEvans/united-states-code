{"tag":"section","attrib":{"id":"id80b3a152-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3111"},"text":null,"children":[{"tag":"num","attrib":{"value":"3111"},"text":"§ 3111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of sufficiency of title prior to acquisition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80b3a153-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval of Attorney General Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Public money may not be expended to purchase land or any interest in land unless the Attorney General gives prior written approval of the sufficiency of the title to the land for the purpose for which the Federal Government is acquiring the property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b3a154-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b3a155-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General may delegate the responsibility under this section to other departments and agencies of the Government, subject to general supervision by the Attorney General and in accordance with regulations the Attorney General prescribes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b3a156-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Request for opinion of attorney general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A department or agency of the Government that has been delegated the responsibility to approve land titles under this section may request the Attorney General to render an opinion as to the validity of the title to any real property or interest in the property, or may request the advice or assistance of the Attorney General in connection with determinations as to the sufficiency of titles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b3a157-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Expenses for Procuring Certificates of Title","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except where otherwise authorized by law or provided by contract, the expenses of procuring certificates of titles or other evidences of title as the Attorney General may require may be paid out of the appropriations for the acquisition of land or out of the appropriations made for the contingencies of the acquiring department or agency of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b3a158-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3111/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not affect any provision of law in effect on ","children":[{"tag":"date","attrib":{"date":"1970-09-01"},"text":"September 1, 1970","children":[],"tail":", that is applicable to the acquisition of land or interests in land by the Tennessee Valley Authority."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b3a159-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1144"},"text":"116 Stat. 1144","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b3a15a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b3a15b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80b3a15c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children