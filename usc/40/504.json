{"tag":"section","attrib":{"id":"id8096f1a7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s504"},"text":null,"children":[{"tag":"num","attrib":{"value":"504"},"text":"§ 504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency cooperation for inspection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8096f1a8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Receiving Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An executive agency may use the services, work, materials, and equipment of another executive agency, with the consent of the other executive agency, to inspect personal property incident to procuring the property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8096f1a9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Providing Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1301/a"},"text":"section 1301(a) of title 31","children":[],"tail":" or any other law, an executive agency may provide services, work, materials, and equipment for purposes of this section without reimbursement or transfer of amounts."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8096f1aa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"tex