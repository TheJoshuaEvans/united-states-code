{"tag":"section","attrib":{"id":"id80c8ff31-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8164"},"text":null,"children":[{"tag":"num","attrib":{"value":"8164"},"text":"§ 8164.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" E. Barrett Prettyman United States Courthouse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c8ff32-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8164/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation, Maintenance, and Repair","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The operation, maintenance, and repair of the E. Barrett Prettyman United States Courthouse, used by the United States Court of Appeals for the District of Columbia and the United States District Court for the District of Columbia, is under the control of the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c8ff33-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8164/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation of Space","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The allocation of space in the Courthouse is vested in the chief judge of the United States Court of Appeals for the District of Columbia and the chief judge of the United States District Court for the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c8ff34-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1209"},"text":"116 Stat. 1209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c8ff35-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c8ff36-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c8ff37-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8164(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:129a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-05-14/ch290"},"text":"May 14, 1948, ch. 290","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/62/235"},"text":"62 Stat. 235","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:130 (words before last comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:130a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8164(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:130 (words after last comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “United States District Court for the District of Columbia” are substituted for “District Court of the United States for the District of Columbia” because of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/s32/b"},"text":"section 32(b) of the Act of June 25, 1948","children":[],"tail":" (ch. 646, "},{"tag":"ref","attrib":{"href":"/us/stat/62/991"},"text":"62 Stat. 991","children":[],"tail":"), as amended by "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/s127"},"text":"section 127 of the Act of May 24, 1949","children":[],"tail":" (ch. 139, "},{"tag":"ref","attrib":{"href":"/us/stat/63/107"},"text":"63 Stat. 107","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “the E. Barrett Prettyman United States Courthouse” are substituted for “the completed building” because of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1996-07-01/s2"},"text":"section 2 of the Act of July 1, 1996","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/104/151"},"text":"Public Law 104–151","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1383"},"text":"110 Stat. 1383","children":[],"tail":"). The words “Administrator of General Services” are substituted for “Public Buildings Administration, in the Federal Works Agency” because of 103(a) of the Federal Property and Administrative Services Act of 1949 (ch. 288, "},{"tag":"ref","attrib":{"href":"/us/stat/63/380"},"text":"63 Stat. 380","children":[],"tail":"), which is restated as section 303(c) [303(b)] of the revised title. The text of 40:129a (words before last proviso) is omitted as obsolete. The text of 40:129a (last proviso) is omitted because of section 173(a)(1) of the District of Columbia Court Reform and Criminal Procedure Act of 1970 ("},{"tag":"ref","attrib":{"href":"/us/pl/91/358"},"text":"Public Law 91–358","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/591"},"text":"84 Stat. 591","children":[],"tail":"). The text of 40:130a is omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “chief judge” are substituted for “chief justice” in both places because of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/s32/a"},"text":"section 32(a) of the Act of June 25, 1948","children":[],"tail":" (ch. 646, "},{"tag":"ref","attrib":{"href":"/us/stat/62/991"},"text":"62 Stat. 991","children":[],"tail":"), as amended by "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/s127"},"text":"section 127 of the Act of May 24, 1949","children":[],"tail":" (ch. 139, "},{"tag":"ref","attrib":{"href":"/us/stat/63/107"},"text":"63 Stat. 107","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80c8ff38-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80c8ff39-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"William B. Bryant Annex Designation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/101"},"text":"Pub. L. 109–101","children":[],"tail":", §§ 3, 4, "},{"tag":"date","attrib":{"date":"2005-11-11"},"text":"Nov. 11, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2171"},"text":"119 Stat. 2171","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/101"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“SEC. 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DESIGNATION OF WILLIAM B. BRYANT ANNEX.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The annex, located on the 200 block of 3rd Street Northwest in the District of Columbia, to the E. Barrett Prettyman Federal Building and United States Courthouse located at Constitution Avenue Northwest in the District of Columbia shall be known and designated as the ‘William B. Bryant Annex’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“SEC. 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" REFERENCES.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Any reference in a law, map, regulation, document, paper, or other record of the United States to the annex referred to in section 3 shall be deemed to be a reference to the ‘William B. Bryant Annex’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80c8ff3a-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"E. Barrett Prettyman United States Courthouse Designation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/151"},"text":"Pub. L. 104–151","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-01"},"text":"July 1, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1383"},"text":"110 Stat. 1383","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/151"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DESIGNATION OF COURTHOUSE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The United States courthouse located at 3rd Street and Constitution Avenue, Northwest, in Washington, District of Columbia, shall be designated and known as the ‘E. Barrett Prettyman United States Courthouse’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" REFERENCES.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Any reference in a law, map, regulation, document, paper, or other record of the United States to the United States courthouse referred to in section 1 shall be deemed to be a reference to the ‘E. Barrett Prettyman United States Courthouse’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
