{"tag":"section","attrib":{"id":"id80e33d45-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14524"},"text":null,"children":[{"tag":"num","attrib":{"value":"14524"},"text":"§ 14524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program development criteria","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e33d46-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14524/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors To Be Considered","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In considering programs and projects to be given assistance under this subtitle, and in establishing a priority ranking of the requests for assistance presented to the Appalachian Regional Commission, the Commission shall follow procedures that will ensure consideration of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33d47-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14524/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relationship of the project or class of projects to overall regional development, including its location in a severely and persistently distressed county or area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d48-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14524/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population and area to be served by the project or class of projects, including the per capita market income and the unemployment rates in the area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d49-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14524/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative financial resources available to the State or political subdivisions or instrumentalities of the State that seek to undertake the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d4a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14524/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importance of the project or class of projects in relation to other projects or classes of projects that may be in competition for the same amounts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d4b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14524/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prospects that the project for which assistance is sought will improve, on a continuing rather than a temporary basis, the opportunities for employment, the average level of income, or the economic and social development of the area served by the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d4c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14524/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the project design provides for detailed outcome measurements by which grant expenditures may be evaluated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d4d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14524/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Financial assistance made available under this subtitle shall not be used to assist establishments relocating from one area to another.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d4e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14524/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination Required Before Amounts May Be Provided","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts may be provided for programs and projects in a State under this subtitle only if the Commission determines that the level of federal and state financial assistance under other laws for the same type of programs or projects in that part of the State within the Appalachian region will not be diminished in order to substitute amounts authorized by this subtitle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d4f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14524/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Amount of Assistance to Distressed Counties and Areas","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each fiscal year, not less than 50 percent of the amount of grant expenditures the Commission approves shall support activities or projects that benefit severely and persistently distressed counties and areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e33d50-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1275"},"text":"116 Stat. 1275","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e33d51-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80e33d52-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80e33d53-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":nul