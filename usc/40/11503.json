{"tag":"section","attrib":{"id":"id80d9c7d1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11503"},"text":null,"children":[{"tag":"num","attrib":{"value":"11503"},"text":"§ 11503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80d9c7d2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the completion of the pilot program under this chapter, the Administrator for Federal Procurement Policy shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80d9c7d3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Director of the Office of Management and Budget a report on the results and findings under the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d9c7d4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a copy of the report to Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d9c7d5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"t