{"tag":"section","attrib":{"id":"id80ea68fe-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17301"},"text":null,"children":[{"tag":"num","attrib":{"value":"17301"},"text":"§ 17301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ea68ff-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Replacement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “replacement” means payment, reimbursement, replacement, or duplication or the expenses incident to payment, reimbursement, replacement, or duplication.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ea6900-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Shipment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “shipment”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80ea6901-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17301/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means the transportation, or the effecting of transportation, of valuables, without limitation as to the means or facilities used or by which the transportation is effected or the person to whom it is made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80ea6902-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17301/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes shipments made to any executive department, independent establishment, agency, wholly owned or mixed-ownership Government corporation, officer, or employee of the Federal Government, or any person acting on behalf of, or at the direction of, the executive department, independent establishment, agency, wholly or partly owned Government corporation, officer, or employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ea6903-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Valuables.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80ea6904-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17301/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “valuables” means any articles or things or representatives of value—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80ea6905-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17301/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the Government, its executive departments, independent establishments, and agencies, including wholly owned Government corporations, and officers and employees of the Government or its executive departments, independent establishments, and agencies while acting in their official capacity, have any interest, or in connection with which they have any obligation or responsibility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80ea6906-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17301/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which the Secretary of the Treasury declares to be valuables within the meaning of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80ea6907-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17301/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for declaring articles or things valuable","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall not declare articles or things that are lost, destroyed, or damaged in the course of shipment to be valuables unless the Secretary determines that replacement of the articles or things in accordance with the procedure established in this chapter would be in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ea6908-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Wholly owned government corporation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “wholly owned Government corporation”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80ea6909-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17301/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any corporation, regardless of the law under which it is incorporated, the capital of which is entirely owned by the Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80ea690a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17301/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the authorized officers, employees, and agents of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ea690b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1280"},"text":"116 Stat. 1280","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ea690c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ea690d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ea690e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"17301(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:729(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1937-07-08/ch444/s7"},"text":"July 8, 1937, ch. 444, § 7","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/50/480"},"text":"50 Stat. 480","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1939-08-10/ch665"},"text":"Aug. 10, 1939, ch. 665","children":[],"tail":", §3, "},{"tag":"html:a","attrib":{"href":"/us/stat/53/1359"},"text":"53 Stat. 1359","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"17301(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:729(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"17301(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:729(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"17301(4)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:729(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this chapter, the words “wholly owned Government corporation” are substituted for “wholly owned corporation” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (3)(A)(i), the words “direct or indirect” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (4)(A), the words “or laws” are omitted because of 1:1. The words “directly or indirectly” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (4)(B), the word “duly” is omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
