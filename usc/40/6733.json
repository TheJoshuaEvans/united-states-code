{"tag":"section","attrib":{"id":"id80c6b50b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6733"},"text":null,"children":[{"tag":"num","attrib":{"value":"6733"},"text":"§ 6733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Triangle property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c6b50c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6733/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Title","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Title to the Federal Triangle property reverts to the Administrator of General Services not later than the date on which ownership of the Ronald Reagan Building and International Trade Center vests in the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c6b50d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6733/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplicability of Certain Laws.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c6b50e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6733/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Building permits and inspection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of development of the Federal Triangle property, the person selected to develop the property is not subject to any state or local law relating to building permits and inspection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c6b50f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6733/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Taxes and assessments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The property and improvements to the property are not subject to real and personal property taxation or to special assessments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c6b510-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1199"},"text":"116 Stat. 1199","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c6b511-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c6b512-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c6b513-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","a