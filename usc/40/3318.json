{"tag":"section","attrib":{"id":"id80bacdd0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318"},"text":null,"children":[{"tag":"num","attrib":{"value":"3318"},"text":"§ 3318.","children":[{"tag":"ref","attrib":{"idref":"fn002021"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002021"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" Another section 3318 is set out after this section."}],"tail":null}],"tail":null},{"tag":"heading","attrib":{},"text":" Lactation room in public buildings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80bacdd1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bacdd2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “appropriate authority” means the head of a Federal agency, the Architect of the Capitol, or other official authority responsible for the operation of a public building.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacdd3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered public building","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “covered public building” means a public building (as defined in section 3301) that is open to the public and contains a public restroom, and includes a building listed in section 6301 or 5101.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacdd4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lactation room","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “lactation room” means a hygienic place, other than a bathroom, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80bacdd5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is shielded from view;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bacdd6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is free from intrusion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bacdd7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains a chair, a working surface, and, if the public building is otherwise supplied with electricity, an electrical outlet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bacdd8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lactation Room Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (c), the appropriate authority of a covered public building shall ensure that the building contains a lactation room that is made available for use by members of the public to express breast milk.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bacdd9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A covered public building may be excluded from the requirement in subsection (b) at the discretion of the appropriate authority if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bacdda-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the public building—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80bacddb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not contain a lactation room for employees who work in the building; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bacddc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not have a room that could be repurposed as a lactation room or a space that could be made private using portable materials, at a reasonable cost; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bacddd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new construction would be required to create a lactation room in the public building and the cost of such construction is unfeasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bacdde-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3318/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Unauthorized Entry","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to authorize an individual to enter a public building or portion thereof that the individual is not otherwise authorized to enter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80bacddf-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/30/s2/a"},"text":"Pub. L. 116–30, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-25"},"text":"July 25, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1032"},"text":"133 Stat. 1032","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80bacde0-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80bacde1-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id80bacde2-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/30/s2/c"},"text":"Pub. L. 116–30, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-25"},"text":"July 25, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1033"},"text":"133 Stat. 1033","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/30/s2/c"},"text":"“The amendments made by this section [enacting this section] shall take effect 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-07-25"},"text":"July 25, 2019","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
