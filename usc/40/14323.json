{"tag":"section","attrib":{"id":"id80de820f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14323"},"text":null,"children":[{"tag":"num","attrib":{"value":"14323"},"text":"§ 14323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80de8210-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a project described in subsection (b), the Appalachian Regional Commission shall provide to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate notice of the award of a grant or other financial assistance not less than 3 full business days before awarding the grant or other financial assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80de8211-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Projects Described","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A project referred to in subsection (a) is a project that the Appalachian Regional Commission has selected to receive a grant or other financial assistance under this subtitle in an amount not less than $50,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80de8212-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11506/c/1"},"text":"Pub. L. 117–58, div. A, title I, § 11506(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/584"},"text":"135 Stat. 584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80de8213-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80de8214-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id80de8215-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as an Effective Date of 2021 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
