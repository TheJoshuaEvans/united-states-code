{"tag":"section","attrib":{"id":"id80e33d1e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14511"},"text":null,"children":[{"tag":"num","attrib":{"value":"14511"},"text":"§ 14511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appalachian regional energy hub initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e33d1f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Appalachian Regional Commission may provide technical assistance to, make grants to, enter into contracts with, or otherwise provide amounts to individuals or entities in the Appalachian region for projects and activities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33d20-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14511/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct research and analysis regarding the economic impact of an ethane storage hub in the Appalachian region that supports a more-effective energy market performance due to the scale of the project, such as a project with the capacity to store and distribute more than 100,000 barrels per day of hydrocarbon feedstock with a minimum gross heating value of 1,700 Btu per standard cubic foot;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d21-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14511/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the potential to significantly contribute to the economic resilience of the area in which the project is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d22-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14511/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that will help establish a regional energy hub in the Appalachian region for natural gas and natural gas liquids, including hydrogen produced from the steam methane reforming of natural gas feedstocks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d23-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Available Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the cost of any project or activity eligible for a grant under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33d24-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14511/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in paragraphs (2) and (3), not more than 50 percent may be provided from amounts made available to carry out this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d25-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14511/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project or activity to be carried out in a county for which a distressed county designation is in effect under section 14526, not more than 80 percent may be provided from amounts made available to carry out this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d26-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14511/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project or activity to be carried out in a county for which an at-risk county designation is in effect under section 14526, not more than 70 percent may be provided from amounts made available to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d27-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), a grant provided under this section may be provided from amounts made available to carry out this section, in combination with amounts made available—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33d28-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14511/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under any other Federal program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d29-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14511/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from any other source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d2a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14511/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of law limiting the Federal share under any other Federal program, amounts made available to carry out this section may be used to increase that Federal share, as the Appalachian Regional Commission determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e33d2b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11506/e/1"},"text":"Pub. L. 117–58, div. A, title I, § 11506(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/585"},"text":"135 Stat. 585","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e33d2c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80e33d2d-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id80e33d2e-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as an Effective Date of 2021 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
