{"tag":"section","attrib":{"id":"id80ea6972-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17504"},"text":null,"children":[{"tag":"num","attrib":{"value":"17504"},"text":"§ 17504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency statements with respect to motor vehicle use","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80ea6973-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Statement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each executive agency shall include with the appropriation request the agency submits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1108"},"text":"section 1108 of title 31","children":[],"tail":" for each fiscal year, a statement—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ea6974-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" specifying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80ea6975-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17504/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total motor vehicle acquisition, maintenance, leasing, operation, and disposal costs (including obligations and outlays) the agency incurred in the most recently completed fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80ea6976-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17504/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of those costs for the fiscal year in which the request is submitted and for the succeeding fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ea6977-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" justifying why the existing and any new motor vehicle acquisition, maintenance, leasing, operation, and disposal requirements of the agency cannot be met through the Interagency Fleet Management System the Administrator of General Services operates, a qualified private fleet management firm, or any other method which is less costly to the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ea6978-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance With Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each executive agency shall comply with the requirements prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s17503/b"},"text":"section 17503(b) of this title","children":[],"tail":" in preparing each statement required under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ea6979-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1284"},"text":"116 Stat. 1284","children":[