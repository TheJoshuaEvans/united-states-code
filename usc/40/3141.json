{"tag":"section","attrib":{"id":"id80b3a1dd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3141"},"text":null,"children":[{"tag":"num","attrib":{"value":"3141"},"text":"§ 3141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b3a1de-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3141/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Federal Government” has the same meaning that the term “United States” had in the Act of ","children":[{"tag":"date","attrib":{"date":"1931-03-03"},"text":"March 3, 1931","children":[],"tail":" (ch. 411, "},{"tag":"ref","attrib":{"href":"/us/stat/46/1494"},"text":"46 Stat. 1494","children":[],"tail":") (known as the Davis-Bacon Act)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b3a1df-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3141/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Wages, scale of wages, wage rates, minimum wages, and prevailing wages","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms “wages”, “scale of wages”, “wage rates”, “minimum wages”, and “prevailing wages” include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80b3a1e0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3141/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basic hourly rate of pay; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b3a1e1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3141/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for medical or hospital care, pensions on retirement or death, compensation for injuries or illness resulting from occupational activity, or insurance to provide any of the forgoing, for unemployment benefits, life insurance, disability and sickness insurance, or accident insurance, for vacation and holiday pay, for defraying the costs of apprenticeship or other similar programs, or for other bona fide fringe benefits, but only where the contractor or subcontractor is not required by other federal, state, or local law to provide any of those benefits, the amount of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80b5ebd2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3141/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of contribution irrevocably made by a contractor or subcontractor to a trustee or to a third person under a fund, plan, or program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5ebd3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3141/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of costs to the contractor or subcontractor that may be reasonably anticipated in providing benefits to laborers and mechanics pursuant to an enforceable commitment to carry out a financially responsible plan or program which was communicated in writing to the laborers and mechanics affected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b5ebd4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1150"},"text":"116 Stat. 1150","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s6/11"},"text":"Pub. L. 109–284, § 6(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1213"},"text":"120 Stat. 1213","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b5ebd5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b5ebd6-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80b5ebd7-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attr