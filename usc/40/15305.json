{"tag":"section","attrib":{"id":"id80e5ae53-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15305"},"text":null,"children":[{"tag":"num","attrib":{"value":"15305"},"text":"§ 15305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e5ae54-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial Meeting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Commission shall hold an initial meeting not later than 180 days after the date of the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5ae55-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Meeting","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Commission shall conduct at least 1 meeting each year with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5ae56-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Cochairperson; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae57-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least a majority of the State members or alternate State members (including designees) present in-person or via electronic means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5ae58-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Commission shall conduct additional meetings at such times as it determines and may conduct such meetings by electronic means.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e5ae59-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14217/a/2"},"text":"Pub. L. 110–234, title XIV, § 14217(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1473"},"text":"122 Stat. 1473","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14217(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2235; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2242/d"},"text":"Pub. L. 118–272, div. B, title II, § 2242(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3203"},"text":"138 Stat. 3203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e5ae5a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"e