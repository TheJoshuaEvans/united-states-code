{"tag":"section","attrib":{"id":"id80a7ba87-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592"},"text":null,"children":[{"tag":"num","attrib":{"value":"592"},"text":"§ 592.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Buildings Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80a7ba88-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is in the Treasury a fund known as the Federal Buildings Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a7ba89-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposits.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a7ba8a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following revenues and collections shall be deposited into the Fund:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a7ba8b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" User charges under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s586/b"},"text":"section 586(b) of this title","children":[],"tail":", payable in advance or otherwise."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a7ba8c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Proceeds from the lease of federal building sites or additions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s581/d"},"text":"section 581(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a7ba8d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Receipts from carriers and others for loss of, or damage to, property belonging to the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba8e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursements for special services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subchapter does not preclude the Administrator of General Services from providing special services, not included in the standard level user charge, on a reimbursable basis. The reimbursements may be credited to the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba8f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of surplus amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To prevent the accumulation of excessive surpluses in the Fund, in any fiscal year an amount specified in an appropriation law may be transferred out of the Fund and deposited as miscellaneous receipts in the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a7ba90-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Uses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a7ba91-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Deposits in the Fund are available for real property management and related activities in the amounts specified in annual appropriation laws without regard to fiscal year limitations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba92-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Salaries and expenses related to construction projects or planning programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Deposits in the Fund that are available pursuant to annual appropriation laws may be transferred and consolidated on the books of the Treasury into a special account in accordance with, and for the purposes specified in, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3176"},"text":"section 3176 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba93-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment of general services administration borrowing from federal financing bank","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator, in accordance with rules and procedures that the Office of Management and Budget and the Secretary of the Treasury establish, may transfer from the Fund an amount necessary to repay the principal amount of a General Services Administration borrowing from the Federal Financing Bank, if the borrowing is a legal obligation of the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba94-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Buildings deemed federally owned","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of amounts authorized to be expended from the Fund, the following are deemed to be federally owned buildings:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a7ba95-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A building constructed pursuant to the purchase contract authority of section 5 of the Public Buildings Amendments of 1972 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/313"},"text":"Public Law 92–313","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/219"},"text":"86 Stat. 219","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a7ba96-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A building occupied pursuant to an installment purchase contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a7ba97-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A building under the control of a department or agency, if alterations of the building are required in connection with moving the department or agency from a former building that is, or will be, under the control of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a7ba98-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Energy Management Programs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a7ba99-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Receiving cash incentives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may receive amounts from rebates or other cash incentives related to energy savings and shall deposit the amounts in the Fund for use as provided in paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba9a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Receiving goods or services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may accept, from a utility, goods or services that enhance the energy efficiency of federal facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba9b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assignment of energy rebates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the administration of real property that the Administrator leases and for which the Administrator pays utility costs, the Administrator may assign all or a portion of energy rebates to the lessor to underwrite the costs incurred in undertaking energy efficiency improvements in the real property if the payback period for the improvement is at least 2 years less than the remainder of the term of the lease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba9c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obligating amounts for energy management improvement programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to amounts appropriated for energy management improvement programs and without regard to subsection (c)(1), the Administrator may obligate for those programs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a7ba9d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts received and deposited in the Fund under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a7ba9e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" goods and services received under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a7ba9f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts the Administrator determines are not needed for other authorized projects and that are otherwise available to implement energy efficiency programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a7baa0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recycling Programs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a7baa1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Receiving amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may receive amounts from the sale of recycled materials and shall deposit the amounts in the Fund for use as provided in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7baa2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obligating amounts for recycling programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to amounts appropriated for such purposes and without regard to subsection (c)(1), the Administrator may obligate amounts received and deposited in the Fund under paragraph (1) for programs which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a7baa3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote further source reduction and recycling programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a7baa4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage employees to participate in recycling programs by providing financing for child care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a7baa5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s592/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Authority Related to Energy Management and Recycling Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Fund may receive, in the form of rebates, cash incentives or otherwise, any revenues, collections, or other income related to energy savings or recycling efforts. Amounts received under this subsection remain in the Fund until expended and remain available for federal energy management improvement programs, recycling programs, or employee programs that are authorized by law or that the Administrator considers appropriate. The Administration may use amounts received under this subsection, in addition to amounts received as New Obligational Authority, in activities of the Fund as necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80a7baa6-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1118"},"text":"116 Stat. 1118","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80a7baa7-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80a7baa8-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80a7baa9-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"