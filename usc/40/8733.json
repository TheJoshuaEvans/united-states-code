{"tag":"section","attrib":{"id":"id80cde03d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8733"},"text":null,"children":[{"tag":"num","attrib":{"value":"8733"},"text":"§ 8733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease of land acquired for park, parkway, or playground purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior may lease, for not more than five years, land or an existing building or structure on land acquired for park, parkway, or playground purposes, and may renew the lease for an additional five years. A lease or renewal under this section is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80cde03e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8733/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the approval of the National Capital Planning Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cde03f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8733/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the need for the immediate use of the land, building, or structure in other ways by the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cde040-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8733/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on terms the Administrator decides.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80cde041-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1225"},"text":"116 Stat. 1225","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80cde042-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80cde043-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80cde044-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8733","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:72b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1928-12-22/ch48/s2"},"text":"Dec. 22, 1928, ch. 48, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/45/1070"},"text":"45 Stat. 1070","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “Administrator of General Services” are substituted for “Director of Public Buildings and Public Parks of the National Capital” [subsequently changed to “Director of the National Park Service” because of section 2 of Executive Order No. 6166 (eff. ","children":[{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":") and the Act of "},{"tag":"date","attrib":{"date":"1934-03-02"},"text":"March 2, 1934","children":[],"tail":" (ch. 38, "},{"tag":"ref","attrib":{"href":"/us/stat/48/389"},"text":"48 Stat. 389","children":[],"tail":"), and “Public Buildings Administrator” because of sections 301 and 303 of Reorganization Plan No. I of 1939 (eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1426"},"text":"53 Stat. 1426","children":[],"tail":", 1427)] because of section 103(a) of the Federal Property and Administrative Services Act of 1949 (ch. 288, "},{"tag":"ref","attrib":{"href":"/us/stat/63/380"},"text":"63 Stat. 380","children":[],"tail":"), which is restated as section 303(c) [303(b)] of the revised title. The words “National Capital Planning Commission” are substituted for “National Capital Park and Planning Commission” because of "},{"tag":"ref","attrib":{"href":"/us/act/1924-06-06/s9"},"text":"section 9 of the Act of June 6, 1924","children":[],"tail":" (ch. 270), as added by "},{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/s1"},"text":"section 1 of the Act of July 19, 1952","children":[],"tail":" (ch. 949, "},{"tag":"ref","attrib":{"href":"/us/stat/66/790"},"text":"66 Stat. 790","children":[],"tail":"). See section 8711(f) of the revised title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
