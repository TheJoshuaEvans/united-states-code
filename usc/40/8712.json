{"tag":"section","attrib":{"id":"id80cb6fbf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8712"},"text":null,"children":[{"tag":"num","attrib":{"value":"8712"},"text":"§ 8712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mayor of the District of Columbia","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80cb6fc0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Mayor of the District of Columbia is the central planning agency for the government of the District of Columbia in the National Capital and is responsible for coordinating the planning activities of the District government and for preparing and implementing the District elements of the comprehensive plan for the National Capital, which may include land use elements, urban renewal and redevelopment elements, a multiyear program of public works for the District, and physical, social, economic, transportation, and population elements. The Mayor’s planning responsibility shall not extend to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80cb6fc1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8712/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" federal or international projects and developments in the District, as determined by the National Capital Planning Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cb6fc2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8712/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Capitol Buildings and Grounds as defined and described in sections 5101 and 5102 of this title, any extension of, or additions to, those Buildings and Grounds, and buildings and grounds under the care of the Architect of the Capitol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80cb6fc3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation and Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the responsibilities under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s8721"},"text":"section 8721 of this title","children":[],"tail":", the Mayor shall establish procedures for citizen participation in the planning process and for appropriate meaningful consultation with any state or local government or planning agency in the National Capital region affected by any aspect of a comprehensive plan, including amendments, affecting or relating to the District."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80cb6fc4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1218"},"text":"116 Stat. 1218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s6/28"},"text":"Pub. L. 109–284, § 6(28)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1213"},"text":"120 Stat. 1213","children":[],"tail":".)"}],"tail":"\