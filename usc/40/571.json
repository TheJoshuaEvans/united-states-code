{"tag":"section","attrib":{"id":"id80a08f34-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s571"},"text":null,"children":[{"tag":"num","attrib":{"value":"571"},"text":"§ 571.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rules for deposit and use of proceeds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80a08f35-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s571/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposit in Treasury as Miscellaneous Receipts.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a08f36-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s571/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this subchapter, proceeds described in paragraph (2) shall be deposited in the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f37-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s571/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proceeds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The proceeds referred to in paragraph (1) are proceeds under this chapter from a—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a08f38-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s571/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer of excess property to a federal agency for agency use; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a08f39-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s571/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sale, lease, or other disposition of surplus property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08f3a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s571/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Expenses of Sale Before Deposit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to regulations under this subtitle, the expenses of the sale of old material, condemned stores, supplies, or other public property may be paid from the proceeds of sale so that only the net proceeds are deposited in the Treasury. This subsection applies whether proceeds are deposited as miscellaneous receipts or to the credit of an appropriation as authorized by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80a08f3b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1104"},"text":"116 Stat. 1104","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/287/s20/a"},"text":"Pub. L. 114–287, § 20(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1477"},"text":"130 Stat. 1477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/318/s7/c/1"},"text":"Pub. L. 114–318, § 7(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1616"},"text":"130 Stat. 1616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80a08f3c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id80a08f3d-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/287/s20"},"text":"Pub. L. 114–287, § 20","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1477"},"text":"130 Stat. 1477","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tIII/s2301/k"},"text":"Pub. L. 118–272, div. B, title III, § 2301(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3217"},"text":"138 Stat. 3217","children":[],"tail":", which Act is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s1303"},"text":"section 1303 of this title","children":[],"tail":", provided that, effective on the date on which the Public Buildings Reform Board transmits the second report under "},{"tag":"ref","attrib":{"href":"/us/pl/114/287/s12/h/2/B"},"text":"section 12(h)(2)(B) of Pub. L. 114–287","children":[],"tail":" and applicable to proceeds from transactions contained in that report and conducted after the date on which the Board terminates under "},{"tag":"ref","attrib":{"href":"/us/pl/114/287/s10"},"text":"section 10 of Pub. L. 114–287","children":[],"tail":", this section is amended by striking subsections (a) and (b) and inserting the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"(a) ","children":[],"tail":null},{"tag":"inline","attrib":{},"text":null,"children":[],"tail":null},{"tag":"i","attrib":{},"text":"Proceeds From Transfer or Sale of Real Property.—","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"(1) ","children":[],"tail":null},{"tag":"inline","attrib":{},"text":null,"children":[],"tail":null},{"tag":"i","attrib":{},"text":"Deposit of net proceeds","children":[],"tail":null},{"tag":"i","attrib":{},"text":".—Net proceeds described in subsection (c) shall be deposited into the appropriate real property account of the agency that had custody and accountability for the real property at the time the real property is determined to be excess.","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"(2) ","children":[],"tail":null},{"tag":"inline","attrib":{},"text":null,"children":[],"tail":null},{"tag":"i","attrib":{},"text":"Expenditure of net proceeds","children":[],"tail":null},{"tag":"i","attrib":{},"text":".—The net proceeds deposited pursuant to paragraph (1) may only be expended, as authorized in annual appropriations Acts, for activities described in sections 543 and 545, including paying costs incurred by the General Services Administration for any disposal-related activity authorized by this chapter.","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"(3) ","children":[],"tail":null},{"tag":"inline","attrib":{},"text":null,"children":[],"tail":null},{"tag":"i","attrib":{},"text":"Deficit reduction","children":[],"tail":null},{"tag":"i","attrib":{},"text":".—Any net proceeds described in subsection (c) from the sale, lease, or other disposition of surplus real property that are not expended under paragraph (2) shall be used for deficit reduction. Any net proceeds not obligated within 3 years after the date of deposit and not expended within 5 years after such date shall be deposited as miscellaneous receipts in the Treasury.","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"(b) ","children":[],"tail":null},{"tag":"inline","attrib":{},"text":null,"children":[],"tail":null},{"tag":"i","attrib":{},"text":"Effect on Other Sections","children":[],"tail":null},{"tag":"i","attrib":{},"text":".—Nothing in this section is intended to affect section 572(b), 573, or 574.","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"(c) ","children":[],"tail":null},{"tag":"inline","attrib":{},"text":null,"children":[],"tail":null},{"tag":"i","attrib":{},"text":"Net Proceeds","children":[],"tail":null},{"tag":"i","attrib":{},"text":".—The net proceeds described in this subsection are proceeds under this chapter, less expenses of the transfer or disposition as provided in section 572(a), from a—","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"(1) transfer of excess real property to a Federal agency for agency use; or","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"(2) sale, lease, or other disposition of surplus real property.","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/318/s7/c"},"text":"Pub. L. 114–318, § 7(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1616"},"text":"130 Stat. 1616","children":[],"tail":", provided that, effective as if enacted as part of "},{"tag":"ref","attrib":{"href":"/us/pl/114/287"},"text":"Pub. L. 114–287","children":[],"tail":", this section is amended by adding at the end the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"(d) ","children":[],"tail":null},{"tag":"inline","attrib":{},"text":null,"children":[],"tail":null},{"tag":"i","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"i","attrib":{},"text":".—Nothing in this section modifies, alters, or repeals any other provision of Federal law directing the use of retained proceeds relating to the sale of property of an agency.","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"See 2016 Amendment notes below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80a08f3e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80a08f3f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"571(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:485(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title II, § 204(a), "},{"tag":"html:a","attrib":{"href":"/us/stat/63/388"},"text":"63 Stat. 388","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/101/510/dB/tXXVIII/s2805/1"},"text":"Pub. L. 101–510, div. B, title XXVIII, § 2805(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/1786"},"text":"104 Stat. 1786","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"571(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:485a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1896-06-08/ch373"},"text":"June 8, 1896, ch. 373","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/29/268"},"text":"29 Stat. 268","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1951-10-31/ch654/s2/20"},"text":"Oct. 31, 1951, ch. 654, § 2(20)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/65/707"},"text":"65 Stat. 707","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/316/tI/s120/a"},"text":"Pub. L. 104–316, title I, § 120(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/3836"},"text":"110 Stat. 3836","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “whether proceeds are deposited as miscellaneous receipts or to the credit of an appropriation as authorized by law” are substituted for “either as miscellaneous receipts on account of ‘proceeds of Government property’ or to the credit of the appropriations to which such proceeds are by law authorized to be made . . . either as miscellaneous receipts or to the credit of such appropriations, as the case may be” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80a08f40-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80a08f41-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/287"},"text":"Pub. L. 114–287","children":[],"tail":" added subsecs. (a) to (c) and struck out former subsecs. (a) and (b) which related to deposit in the Treasury as miscellaneous receipts of net proceeds from transfer or other disposition of surplus property and payment of expenses of sale before deposit."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/318"},"text":"Pub. L. 114–318","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80a08f42-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id80a08f43-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/318/s7/c/2"},"text":"Pub. L. 114–318, § 7(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1617"},"text":"130 Stat. 1617","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/318/s7/c/2"},"text":"“The amendments made by this subsection [amending this section] shall take effect as if enacted as part of the applicable Act [","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/287"},"text":"Pub. L. 114–287","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/318/s7/e"},"text":"Pub. L. 114–318, § 7(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1617"},"text":"130 Stat. 1617","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/318/s7/e"},"text":"“Except as provided in subsection (c)(2) [set out above], this section [amending this section and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s1303"},"text":"section 1303 of this title","children":[],"tail":"] and the amendments made by this section shall take effect immediately after the enactment of the applicable Act ["},{"tag":"ref","attrib":{"href":"/us/pl/114/287"},"text":"Pub. L. 114–287","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/287"},"text":"Pub. L. 114–287","children":[],"tail":" effective on the date on which the Public Buildings Reform Board transmits the second report under "},{"tag":"ref","attrib":{"href":"/us/pl/114/287/s12/h/2/B"},"text":"section 12(h)(2)(B) of Pub. L. 114–287","children":[],"tail":" and applicable to proceeds from transactions contained in that report and conducted after the date on which the Board terminates under "},{"tag":"ref","attrib":{"href":"/us/pl/114/287/s10"},"text":"section 10 of Pub. L. 114–287","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/287/s20/b"},"text":"section 20(b) of Pub. L. 114–287","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s1303"},"text":"section 1303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
