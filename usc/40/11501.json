{"tag":"section","attrib":{"id":"id80d9c7b5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11501"},"text":null,"children":[{"tag":"num","attrib":{"value":"11501"},"text":"§ 11501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to conduct pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80d9c7b6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80d9c7b7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In consultation with the Administrator for the Office of Information and Regulatory Affairs, the Administrator for Federal Procurement Policy may conduct a pilot program pursuant to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11521"},"text":"section 11521 of this title","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002033"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002033"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" to test alternative approaches for the acquisition of information technology by executive agencies."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d9c7b8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiagency, multi-activity conduct of each program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this chapter, the pilot program conducted under this chapter shall be carried out in not more than two procuring activities in each of the executive agencies that are designated by the Administrator for Federal Procurement Policy in accordance with this chapter to carry out the pilot program. With the approval of the Administrator for Federal Procurement Policy, the head of each designated executive agency shall select the procuring activities of the executive agency that are to participate in the test and shall designate a procurement testing official who shall be responsible for the conduct and evaluation of the pilot program within the executive agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d9c7b9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The total amount obligated for contracts entered into under the pilot program conducted under this chapter may not exceed $375,000,000. The Administrator for Federal Procurement Policy shall monitor those contracts and ensure that contracts are not entered into in violation of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d9c7ba-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of Programs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80d9c7bb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11501/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), the pilot program may be carried out under this chapter for the period, not in excess of five years, the Administrator for Federal Procurement Policy determines is sufficient to establish reliable results.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d9c7bc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11501/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuing validity of contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contract entered into under the pilot program before the expiration of that program remains in effect according to the terms of the contract after the expiration of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80d9c7bd-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1245"},"text":"116 Stat. 1245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tVIII/s825/b/2/A"},"text":"Pub. L. 107–314, div. A, title VIII, § 825(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"t