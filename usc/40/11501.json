hildren":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s210/h/2/A/ii"},"text":"Pub. L. 107–347, § 210(h)(2)(A)(ii)","children":[],"tail":", amended par. (1) identically, substituting “conduct a pilot program pursuant to the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s11521"},"text":"section 11521 of this title","children":[],"tail":"” for “conduct pilot programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s825/b/2/A/iii"},"text":"Pub. L. 107–314, § 825(b)(2)(A)(iii)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s210/h/2/A/iii"},"text":"Pub. L. 107–347, § 210(h)(2)(A)(iii)","children":[],"tail":", amended par. (2) identically, substituting “the pilot program conducted” for “each pilot program conducted”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347/s210/h/2/A/iv"},"text":"Pub. L. 107–347, § 210(h)(2)(A)(iv)","children":[],"tail":", which directed amendment of subsec. (b) by substituting the heading “"},{"tag":"inline","attrib":{},"text":"Limitation on Amount","children":[],"tail":"” and text “The total amount obligated for contracts entered into under the pilot program conducted under this chapter may not exceed $375,000,000.” for the heading “"},{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":"” and all that followed through “$750,000,000.”, was executed by making the substitution for “"},{"tag":"inline","attrib":{},"text":"Limitation on Amount","children":[],"tail":"” in the heading and “The total amount obligated for contracts entered into under the pilot program conducted under this chapter may not exceed $750,000,000.” in text to reflect the probable intent of Congress and the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/s825/b/2/A/iv/I"},"text":"Pub. L. 107–314, § 825(b)(2)(A)(iv)(I)","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s825/b/2/A/iv/II"},"text":"Pub. L. 107–314, § 825(b)(2)(A)(iv)(II)","children":[],"tail":", substituted “subsection.” for “paragraph.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s825/b/2/A/iv/I"},"text":"Pub. L. 107–314, § 825(b)(2)(A)(iv)(I)","children":[],"tail":", substituted “"},{"tag":"inline","attrib":{},"text":"Limitation on Amount","children":[],"tail":".—The total amount obligated for contracts entered into under the pilot program conducted” for “"},{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Number","children":[],"tail":".—Not more than two pilot programs may be conducted under this chapter, including one pilot program each pursuant to the requirements of sections 11521 and 11522 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—The total amount obligated for contracts entered into under the pilot programs conducted”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s825/b/2/A/v"},"text":"Pub. L. 107–314, § 825(b)(2)(A)(v)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s210/h/2/A/v"},"text":"Pub. L. 107–347, § 210(h)(2)(A)(v)","children":[],"tail":", amended par. (1) identically, substituting “the pilot” for “a pilot”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80d9c7c4-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id80d9c7c5-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347"},"text":"Pub. L. 107–347","children":[],"tail":" effective 120 days after "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s402/a"},"text":"section 402(a) of Pub. L. 107–347","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3601"},"text":"section 3601 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
