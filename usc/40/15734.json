{"tag":"section","attrib":{"id":"id80e81f77-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15734"},"text":null,"children":[{"tag":"num","attrib":{"value":"15734"},"text":"§ 15734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes Authority","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The region of the Great Lakes Authority shall consist of the counties which contain, in part or in whole, the areas in the watershed of the Great Lakes and the Great Lakes System (as such terms are defined in section 118(a)(3) of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1268/a/3"},"text":"33 U.S.C. 1268(a)(3)","children":[],"tail":")), in each of the following States:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81f78-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15734/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Illinois.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f79-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15734/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indiana.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f7a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15734/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Michigan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f7b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15734/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Minnesota.","children":[],"tail":"\n"}],"tail":"\n"},{"tag