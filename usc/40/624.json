{"tag":"section","attrib":{"id":"id80aa058f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s624"},"text":null,"children":[{"tag":"num","attrib":{"value":"624"},"text":"§ 624.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information on certain leasing authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80aa0590-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s624/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), not later than December 31 of each year following the date of enactment of this subchapter, a Federal agency with independent leasing authority shall submit to the Council a list of all leases, including operating leases, in effect on the date of enactment of this subchapter that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa0591-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s624/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which each lease was executed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0592-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s624/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which each lease will expire;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0593-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s624/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the size of the space;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0594-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s624/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0595-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s624/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tenant agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0596-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s624/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total annual rental payment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0597-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s624/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the net present value of the total estimated legal obligations of the Federal Government over the life of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa0598-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s624/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa0599-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s624/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Postal Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa059a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s624/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other property the Director excludes from subsection (a) for reasons of national security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80aa059b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/318/s3/a"},"text":"Pub. L. 114–318, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1612"},"text":"130 Stat. 1612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80aa059c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80aa059d-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80aa059e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this subchapter, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/318"},"text":"Pub. L. 114–318","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
