{"tag":"section","attrib":{"id":"id80ecda10-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17904"},"text":null,"children":[{"tag":"num","attrib":{"value":"17904"},"text":"§ 17904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation powers and limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80ecda11-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accommodation of Needs for Electric Energy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This chapter does not require or authorize a federal agency to construct a new electric generating facility or related facility, to modify an existing facility, or to employ reserve or standby equipment to accommodate the needs of a non-federal person for electric energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ecda12-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Revenue From Sales","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Revenue received by a federal agency pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s17902"},"text":"section 17902 of this title","children":[],"tail":" from the sale of electric energy generated from a facility of that agency is available to the agency without fiscal year limitation to purchase fuel and for operation, maintenance, and other costs associated with that facility."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ecda13-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exercise of Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority under this chapter shall be exercised for those periods and pursuant to terms and conditions that the head of the federal agency concerned decides are necessary consistent with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ecda14-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17904/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda15-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17904/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responsibilities of the head of the federal agency under other law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ecda16-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Negotiation and Execution of Contracts and Other Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contract or other agreement executed under this chapter shall be negotiated and executed by the head of the federal agency selling or purchasing electric energy under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ecda17-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1290"},"text":"116 Stat. 1290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ecda18-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ecda19-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ecda1a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"17904","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:795c.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/96/571/s5"},"text":"Pub. L. 96–571, § 5","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/3342"},"text":"94 Stat. 3342","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “federal agency” are substituted for “department, agency, or instrumentality of the United States Government” because of the definition of “federal agency” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s17901"},"text":"section 17901 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “notwithstanding any other provision of law” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
