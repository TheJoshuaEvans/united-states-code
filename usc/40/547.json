{"tag":"section","attrib":{"id":"id809bd3ca-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s547"},"text":null,"children":[{"tag":"num","attrib":{"value":"547"},"text":"§ 547.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural commodities, foods, and cotton or woolen goods","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id809bd3cb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s547/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services shall consult with the Secretary of Agriculture to formulate policies for the disposal of surplus agricultural commodities, surplus foods processed from agricultural commodities, and surplus cotton or woolen goods. The policies shall be formulated to prevent surplus agricultural commodities, or surplus foods processed from agricultural commodities, from being dumped on the market in a disorderly manner and disrupting the market prices for agricultural commodities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id809bd3cc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s547/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfers to Department of Agriculture.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id809bd3cd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s547/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall transfer without charge to the Department of Agriculture any surplus agricultural commodities, foods, and cotton or woolen goods for disposal, when the Secretary determines that a transfer is necessary for the Secretary to carry out responsibilities for price support or stabilization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd3ce-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s547/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposit of receipts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Receipts resulting from disposal by the Department under this subsection shall be deposited pursuant to any authority available to the Secretary. When applicable, however, net proceeds from the sale of surplus property transferred under this subsection shall be credited pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s572/a"},"text":"section 572(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd3cf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s547/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation of sales","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Surplus farm commodities transferred under this subsection may not be sold, other than for export, in quantities exceeding, or at prices less than, the applicable quantities and prices for sales of those commodities by the Commodity Credit Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id809bd3d0-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1089"},"text":"116 Stat. 1089","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id809bd3d1-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id809bd3d2-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id809bd3d3-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},