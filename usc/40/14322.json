{"tag":"section","attrib":{"id":"id80de8203-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14322"},"text":null,"children":[{"tag":"num","attrib":{"value":"14322"},"text":"§ 14322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of development plans, strategy statements, and projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80de8204-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Review and Approval Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Appalachian Regional Commission annually shall review and approve, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14302"},"text":"section 14302 of this title","children":[],"tail":", state and regional development plans and strategy statements, and any multistate subregional plans which may be developed."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80de8205-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application Process","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application for a grant or for other assistance for a specific project under this subtitle shall be made through the state member of the Commission representing the applicant. The state member shall evaluate the application for approval. To be approved, the state member must certify, and the Federal Cochairman must determine, that the application—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80de8206-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14322/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implements the Commission-approved state development plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80de8207-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14322/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is included in the Commission-approved strategy statement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80de8208-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14322/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequately ensures that the project will be properly administered, operated, and maintained; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80de8209-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14322/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise meets the requirements for assistance under this subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80de820a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14322/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affirmative Vote Requirement Deemed Met","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After the appropriate state development plan and strategy statement are approved, certification by a state member, when joined by an affirmative vote of the Federal Cochairman, is deemed to satisfy the requirements for affirmative votes for decisions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14302/a"},"text":"section 14302(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80de820b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1264"},"text":"116 Stat. 1264","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80de820c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80de820d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80de820e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"ta