{"tag":"section","attrib":{"id":"id80c4437a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6507"},"text":null,"children":[{"tag":"num","attrib":{"value":"6507"},"text":"§ 6507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Account in Treasury","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c4437b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Contents of Separate Account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is a separate account in the Treasury. The account includes all amounts deposited in the account under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6506/f"},"text":"section 6506(f) of this title","children":[],"tail":" and amounts appropriated to the account. However, the appropriated amounts may not be more than $2,000,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c4437c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts in the account are available to the Architect of the Capitol—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c4437d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6507/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for paying expenses for structural, mechanical, and domestic care, maintenance, operation, and utilities of the Thurgood Marshall Federal Judiciary Building and other improvements constructed under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c4437e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6507/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for reimbursing the United States Capitol Police for expenses incurred in providing exterior security for the Building and other improvements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c4437f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6507/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for making lease payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6504"},"text":"section 6504 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44380-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6507/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for necessary personnel (including consultants).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c44381-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1192"},"text":"116 Stat. 1192","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c44382-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c44383-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:t