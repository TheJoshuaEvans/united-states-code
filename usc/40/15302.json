{"tag":"section","attrib":{"id":"id80e5ae0f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15302"},"text":null,"children":[{"tag":"num","attrib":{"value":"15302"},"text":"§ 15302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e5ae10-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Approval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in section 15304(c)(3), decisions by the Commission shall require the affirmative vote of the Federal Cochairperson and a majority of the State members or alternate State members, including designees (exclusive of members representing States delinquent under section 15304(c)(3)(C)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5ae11-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In matters coming before the Commission, the Federal Cochairperson shall, to the extent practicable, consult with the Federal departments and agencies having an interest in the subject matter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5ae12-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quorums.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5ae13-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), a Commission shall determine what constitutes a quorum for meetings of the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae14-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any quorum for meetings of a Commission shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e5ae15-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15302/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Cochairperson or the alternate Federal Cochairperson; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e5ae16-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15302/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a majority of State members or alternate State members, including designees (exclusive of members representing States delinquent under section 15304(c)(3)(C)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5ae17-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Projects and Grant Proposals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The approval of project and grant proposals shall be a responsibility of each Commission and shall be carried out in accordance with section 15503.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e5ae18-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14217/a/2"},"text":"Pub. L. 110–234, title XIV, § 14217(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1470"},"text":"122 Stat. 1470","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14217(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2232; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2242/b"},"text":"Pub. L. 118–272, div. B, title II, § 2242(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3202"},"text":"138 Stat. 3202","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e5ae19-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80e5ae1a-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id80e5ae1b-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80e5ae1c-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2242/b/1"},"text":"Pub. L. 118–272, § 2242(b)(1)","children":[],"tail":", inserted “or alternate State members, including designees” after “State members”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2242/b/2"},"text":"Pub. L. 118–272, § 2242(b)(2)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c). Prior to amendment, text read as follows: “A Commission shall determine what constitutes a quorum for Commission meetings; except that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) any quorum shall include the Federal Cochairperson or the alternate Federal Cochairperson; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) a State alternate member shall not be counted toward the establishment of a quorum.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80e5ae1d-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id80e5ae1e-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s14217/d"},"text":"section 14217(d) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s15101"},"text":"section 15101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
