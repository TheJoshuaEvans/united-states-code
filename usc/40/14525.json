{"tag":"section","attrib":{"id":"id80e33d54-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14525"},"text":null,"children":[{"tag":"num","attrib":{"value":"14525"},"text":"§ 14525.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State development planning process","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e33d55-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14525/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Development Plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to policies the Appalachian Regional Commission establishes, each state member shall submit a development plan for the area of the State within the Appalachian region. The plan shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33d56-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14525/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be submitted according to a schedule the Commission prescribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d57-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14525/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect the goals, objectives, and priorities identified in the regional development plan and in any subregional development plan that may be approved for the subregion of which the State is a part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d58-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14525/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe the state organization and continuous process for Appalachian development planning, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e33d59-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14525/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedures established by the State for the participation of local development districts in the process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e33d5a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14525/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the process is related to overall statewide planning and budgeting processes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e33d5b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14525/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method of coordinating planning and projects in the region under this subtitle, the Public Works and Economic Development Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"42 U.S.C. 3121","children":[],"tail":" et seq.), and other federal, state, and local programs;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d5c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14525/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the goals, objectives, and priorities of the State for the region, as established by the Governor, and identify the needs on which the goals, objectives, and priorities are based; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d5d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14525/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the development strategies for achieving the goals, objectives, and priorities, including funding sources, and recommendations for specific projects to receive assistance under this subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d5e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14525/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Areawide Action Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall encourage the preparation and execution of areawide action programs that specify interrelated projects and schedules of actions, the necessary agency funding, and other commitments to implement the programs. The programs shall make appropriate use of existing plans affecting the area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d5f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14525/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Local Development Districts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Local development districts certified by the State as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14102/a/2"},"text":"section 14102(a)(2) of this title","children":[],"tail":" provide the linkage between state and substate planning and development. The districts shall assist the States in the coordination of areawide programs and projects and may prepare and adopt areawide plans or action programs. In carrying out the development planning process, including the selection of programs and projects for assistance, States shall consult with local development districts, local units of government, and citizen groups and shall consider the goals, objectives, priorities, and recommendations of those bodies."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d60-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14525/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, federal departments, agencies, and instrumentalities undertaking or providing financial assistance for programs or projects in the region shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33d61-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14525/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into account the policies, goals, and objectives the Commission and its member States establish pursuant to this subtitle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d62-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14525/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognize Appalachian state development strategies approved by the Commission as satisfying requirements for overall economic development planning under the programs or projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d63-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14525/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept the boundaries and organization of any local development district certified under this subtitle that the Governor may designate as the areawide agency required under any of those programs undertaken or assisted by those federal departments, agencies, and instrumentalities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e33d64-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1275"},"text":"116 Stat. 1275","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e33d65-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80e33d66-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80e33d67-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14525(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:225(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/4/tII/s225"},"text":"Pub. L. 89–4, title II, § 225","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/94/188/tI/s118"},"text":"Pub. L. 94–188, title I, § 118","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/89/1084"},"text":"89 Stat. 1084","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/107/149/s13/h"},"text":"Pub. L. 107–149, § 13(h)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Mar. 12, 2002","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/116/72"},"text":"116 Stat. 72","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14525(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:225(b)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14525(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:225(b)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14525(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:225(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80e33d68-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80e33d69-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Public Works and Economic Development Act of 1965, referred to in subsec. (a)(3)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136"},"text":"Pub. L. 89–136","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/552"},"text":"79 Stat. 552","children":[],"tail":", which is classified principally to chapter 38 (§ 3121 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
