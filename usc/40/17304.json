{"tag":"section","attrib":{"id":"id80ea6924-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17304"},"text":null,"children":[{"tag":"num","attrib":{"value":"17304"},"text":"§ 17304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claim for replacement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80ea6925-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presentation of Claim","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When valuables that have been shipped in accordance with regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s17302"},"text":"section 17302 of this title","children":[],"tail":" are lost, destroyed, or damaged, a claim in writing for replacement shall be made on the Secretary of the Treasury."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ea6926-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Decision of the Secretary of the Treasury.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ea6927-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Replacement made from fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary is satisfied that the loss, destruction, or damage has occurred and that shipment was made substantially in accordance with the regulations, the Secretary shall have replacement be made out of the fund described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s17303"},"text":"section 17303 of this title","children":[],"tail":" through an officer the Secretary designates."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ea6928-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Replacement made by credit","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"When the Secretary decides that any part of the replacement can be made, without actual or ultimate injury to the Federal Government, by a credit in the accounts of the executive department, independent establishment, agency, officer, employee, or other accountable person making the claim, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80ea6929-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17304/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify the decision to the Comptroller General who, on receiving the certification, shall make the credit in the settlement of accounts in the Government Accountability Office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80ea692a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17304/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the fund only to the extent that the replacement cannot be made by the credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ea692b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Decision of Secretary Not Reviewable","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The decision of the Secretary that a loss, destruction, or damage has occurred or that a shipment was made substantially in accordance with regulations is final and conclusive and is not subject to review by any other officer of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ea692c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1281"},"text":"116 Stat. 1281","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ea692d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ea692e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ea692f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"17304(a), (b)(1)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:723 (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1937-07-08/ch444/s3"},"text":"July 8, 1937, ch. 444, § 3","children":[],"tail":" (1st sentence, 2d sentence words before 2d proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/50/479"},"text":"50 Stat. 479","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"17304(b)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:723 (2d sentence 1st proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"17304(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:723 (2d sentence words before 1st proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “Notwithstanding any provision of law to the contrary” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80ea6930-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80ea6931-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
