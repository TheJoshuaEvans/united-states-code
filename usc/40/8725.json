{"tag":"section","attrib":{"id":"id80cde014-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8725"},"text":null,"children":[{"tag":"num","attrib":{"value":"8725"},"text":"§ 8725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations on platting and subdividing land","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80cde015-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"By Council of the District of Columbia","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council of the District of Columbia shall submit any proposed change in, or addition to, the regulations or general orders regulating the platting and subdividing of lands and grounds in the District of Columbia to the National Capital Planning Commission for report and recommendation before the Council adopts the change or addition. The Council shall advise the Commission when it does not agree with the recommendations of the Commission and shall give the reasons why it disagrees. The Commission then shall submit a final report within 30 days. After considering the final report, the Council may act in accordance with its legal responsibilities and authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80cde016-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"By Planning Commission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall submit to the Council any proposed change in, or amendment to, the general orders that the Commission considers appropriate. The Council shall treat the amendments proposed in the same manner as other proposed amendments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80cde017-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1224"},"text":"116 Stat. 1224","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80cde018-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80cde019-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80cde01a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8725","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:71g(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1924-06-06/ch270/s8/d"},"text":"June 6, 1924, ch. 270, § 8(d)","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-19/ch949/s1"},"text":"July 19, 1952, ch. 949, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/790"},"text":"66 Stat. 790","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “to the Council” are added for clarity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
