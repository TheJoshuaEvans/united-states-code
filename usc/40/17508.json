{"tag":"section","attrib":{"id":"id80ea6997-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17508"},"text":null,"children":[{"tag":"num","attrib":{"value":"17508"},"text":"§ 17508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80ea6998-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrator of General Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services shall comply with and be subject to this chapter with regard to all motor vehicles that are used within the General Services Administration for official purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ea6999-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Managers of Other Motor Pools","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This chapter with respect to motor vehicles from the Interagency Fleet Management System shall be complied with by the executive agencies to which such motor vehicles are assigned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ea699a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1285"},"text":"116 Stat. 1285","children":[],"tail":".)"}],"tail":"\n"},{"t