{"tag":"section","attrib":{"id":"id80a08f1a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559"},"text":null,"children":[{"tag":"num","attrib":{"value":"559"},"text":"§ 559.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advice of Attorney General with respect to antitrust law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80a08f1b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “antitrust law” includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a08f1c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Sherman Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1"},"text":"15 U.S.C. 1","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f1d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Clayton Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"15 U.S.C. 12","children":[],"tail":" et seq., "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s52"},"text":"29 U.S.C. 52","children":[],"tail":", 53);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f1e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Trade Commission Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f1f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 73 and 74 of the Wilson Tariff Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8"},"text":"15 U.S.C. 8","children":[],"tail":", 9)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08f20-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advice Required.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a08f21-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An executive agency shall not dispose of property to a private interest until the agency has received the advice of the Attorney General on whether the disposal to a private interest would tend to create or maintain a situation inconsistent with antitrust law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f22-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply to disposal of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a08f23-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" real property, if the estimated fair market value is less than $3,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a08f24-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal property (other than a patent, process, technique, or invention), if the estimated fair market value is less than $3,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08f25-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Attorney General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a08f26-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An executive agency that contemplates disposing of property to a private interest shall promptly transmit notice of the proposed disposal, including probable terms and conditions, to the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f27-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Copy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except for the General Services Administration, an executive agency that transmits notice under paragraph (1) shall simultaneously transmit a copy of the notice to the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08f28-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advice From Attorney General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within a reasonable time, not later than 60 days, after receipt of notice under subsection (c), the Attorney General shall advise the Administrator and any interested executive agency whether, so far as the Attorney General can determine, the proposed disposition would tend to create or maintain a situation inconsistent with antitrust law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08f29-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Request for Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On request from the Attorney General, the head of an executive agency shall furnish information the agency possesses that the Attorney General determines is appropriate or necessary to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a08f2a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give advice required by this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f2b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether any other disposition or proposed disposition of surplus property violates antitrust law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08f2c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s559/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Effect on Antitrust Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subtitle does not impair, amend, or modify antitrust law or limit or prevent application of antitrust law to a person acquiring property under this subtitle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80a08f2d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1103"},"text":"116 Stat. 1103","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80a08f2e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80a08f2f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80a08f30-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"559","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:488.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title II, § 207, "},{"tag":"html:a","attrib":{"href":"/us/stat/63/391"},"text":"63 Stat. 391","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/85/680"},"text":"Pub. L. 85–680","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 19, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/631"},"text":"72 Stat. 631","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/100/612/s7"},"text":"Pub. L. 100–612, § 7","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 5, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/3182"},"text":"102 Stat. 3182","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “the head of an executive agency” are substituted for “the Administrator or any other executive agency”, the words “or cause to be furnished” are omitted, and the words “information the agency possesses” are substituted for “such information as the Administrator or such other executive agency may possess”, to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80a08f31-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80a08f32-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Sherman Act, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-07-02/ch647"},"text":"act July 2, 1890, ch. 647","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/209"},"text":"26 Stat. 209","children":[],"tail":", which is classified to sections 1 to 7 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1"},"text":"section 1 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Clayton Act, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-10-15/ch323"},"text":"act Oct. 15, 1914, ch. 323","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/730"},"text":"38 Stat. 730","children":[],"tail":", which is classified generally to sections 12, 13, 14 to 19, 21, 22 to 27 of Title 15, Commerce and Trade, and sections 52 and 53 of Title 29, Labor. For further details and complete classification of this Act to the Code, see note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"section 12 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Trade Commission Act, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311"},"text":"act Sept. 26, 1914, ch. 311","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/717"},"text":"38 Stat. 717","children":[],"tail":", which is classified generally to subchapter I (§ 41 et seq.) of chapter 2 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s58"},"text":"section 58 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
