{"tag":"section","attrib":{"id":"id80e81f33-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15703"},"text":null,"children":[{"tag":"num","attrib":{"value":"15703"},"text":"§ 15703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counties eligible for assistance in more than one region","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e81f34-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A political subdivision of a State may not receive assistance under this subtitle in a fiscal year from more than one Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81f35-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection of Commission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A political subdivision included in the region of more than one Commission shall select the Commission with which it will participate by notifying, in writing, the Federal Cochairperson and the appropriate State member of that Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81f36-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Changes in Selections","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The selection of a Commission by a political subdivision shall apply in the fiscal year in which the selection is made, and shall apply in each subsequent fiscal year unless the political subdivision, at least 90 days before the first day of the fiscal year, notifies the Cochairpersons of another Commission in writing that the political subdivision will participate in that Commission and also transmits a copy of such notification to the Cochairpersons of the Commission in which the political subdivision is currently participating.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81f37-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion of Appalachian Regional Commission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “Commission” includes the Appalachian Regional Commission established under chapter 143.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e81f38-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14217/a/2"},"text":"Pub. L. 110–234, title XIV, § 14217(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1480"},"text":"122 Stat. 1480","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14217(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2242.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","