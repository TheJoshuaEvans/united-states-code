{"tag":"section","attrib":{"id":"id80a54a02-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587"},"text":null,"children":[{"tag":"num","attrib":{"value":"587"},"text":"§ 587.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Telecommuting and other alternative workplace arrangements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80a54a03-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “telecommuting centers” means flexiplace work telecommuting centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a54a04-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Telecommuting Centers Established by Administrator of General Services.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a54a05-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services may acquire space for, establish, and equip telecommuting centers for use in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a54a06-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A telecommuting center may be used by employees of federal agencies, state and local governments, and the private sector. The Administrator shall give federal employees priority in using a telecommuting center. The Administrator may make a telecommuting center available for use by others to the extent it is not fully utilized by federal employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a54a07-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"User fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall charge a user fee for the use of a telecommuting center. The amount of the user fee shall approximate commercial charges for comparable space and services. However, the user fee may not be less than necessary to pay the cost of establishing and operating the telecommuting center, including the reasonable cost of renovation and replacement of furniture, fixtures, and equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a54a08-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposit and use of fees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a54a09-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposit user fees into the Federal Buildings Fund and use the fees to pay costs incurred in establishing and operating the telecommuting center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a54a0a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept and retain income received by the General Services Administration, from federal agencies and non-federal sources, to defray costs directly associated with the functions of telecommuting centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a54a0b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development of Alternative Workplace Arrangements by Executive Agencies and Others.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a54a0c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “alternative workplace arrangements” includes telecommuting, hoteling, virtual offices, and other distributive work arrangements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a54a0d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration by executive agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In considering whether to acquire space, quarters, buildings, or other facilities for use by employees, the head of an executive agency shall consider whether needs can be met using alternative workplace arrangements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a54a0e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance from administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may provide guidance, assistance, and oversight to any person regarding the establishment and operation of alternative workplace arrangements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a54a0f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amounts Available for Flexiplace Work Telecommuting Programs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a54a10-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “flexiplace work telecommuting program” means a program under which employees of a department or agency set out in paragraph (2) are permitted to perform all or a portion of their duties at a telecommuting center established under this section or other federal law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a54a11-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum funding","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each of the following departments and agencies, in each fiscal year at least $50,000 of amounts made available for salaries and expenses is available only for carrying out a flexiplace work telecommuting program:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a54a12-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a54a13-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a54a14-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a54a15-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a54a16-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a54a17-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a54a18-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a54a19-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a54a1a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s587/d/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a54a1b-3a70-11f1-b817-c08bf6d1fe2c","identif