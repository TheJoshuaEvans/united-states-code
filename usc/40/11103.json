{"tag":"section","attrib":{"id":"id80d29b95-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11103"},"text":null,"children":[{"tag":"num","attrib":{"value":"11103"},"text":"§ 11103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to national security systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80d29b96-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80d29b97-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National security system","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “national security system” means a telecommunications or information system operated by the Federal Government, the function, operation, or use of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80d29b98-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11103/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves intelligence activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80d29b99-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11103/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves cryptologic activities related to national security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80d29b9a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11103/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves command and control of military forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80d29b9b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11103/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves equipment that is an integral part of a weapon or weapons system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80d29b9c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11103/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (2), is critical to the direct fulfillment of military or intelligence missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d29b9d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1)(E) does not include a system to be used for routine administrative and business applications (including payroll, finance, logistics, and personnel management applications).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d29b9e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (c), chapter 113 of this title does not apply to national security systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d29b9f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80d29ba0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 11313, 11315, and 11316 of this title apply to national security systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d29ba1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capital planning and investment control","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The heads of executive agencies shall apply sections 11302 and 11312 of this title to national security systems to the extent practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d29ba2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11103/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of performance-based and results-based management to national security systems.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80d29ba3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11103/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subparagraph (B), the heads of executive agencies shall apply ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11303"},"text":"section 11303 of this title","children":[],"tail":" to national security systems to the extent practicable."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80d29ba4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s11103/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"National security systems are subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11303/b/5"},"text":"section 11303(b)(5) of this title","children":[],"tail":", except for subparagraph (B)(iv)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80d29ba5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1236"},"text":"116 Stat. 1236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","att