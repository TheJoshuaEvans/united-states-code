{"tag":"section","attrib":{"id":"id80e5ae61-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306"},"text":null,"children":[{"tag":"num","attrib":{"value":"15306"},"text":"§ 15306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal financial interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e5ae62-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conflicts of Interest.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5ae63-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No role allowed","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as permitted by paragraph (2), an individual who is a State member or alternate, or an officer or employee of a Commission, shall not participate personally and substantially as a member, alternate, officer, or employee of the Commission, through decision, approval, disapproval, recommendation, request for a ruling, or other determination, contract, claim, controversy, or other matter in which, to the individual’s knowledge, any of the following has a financial interest:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e5ae64-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e5ae65-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individual’s spouse, minor child, or partner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e5ae66-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An organization (except a State or political subdivision of a State) in which the individual is serving as an officer, director, trustee, partner, or employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e5ae67-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person or organization with whom the individual is negotiating or has any arrangement concerning prospective employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae68-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply if the individual, in advance of the proceeding, application, request for a ruling or other determination, contract, claim controversy, or other particular matter presenting a potential conflict of interest—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e5ae69-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advises the Commission of the nature and circumstances of the matter presenting the conflict of interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e5ae6a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes full disclosure of the financial interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e5ae6b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives a written decision of the Commission that the interest is not so substantial as to be considered likely to affect the integrity of the services that the Commission may expect from the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae6c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Violation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual violating this subsection shall be fined under title 18, imprisoned for not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5ae6d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Member or Alternate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State member or alternate member may not receive any salary, or any contribution to, or supplementation of, salary, for services on a Commission from a source other than the State of the member or alternate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5ae6e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detailed Employees.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5ae6f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No person detailed to serve a Commission shall receive any salary, or any contribution to, or supplementation of, salary, for services provided to the Commission from any source other than the State, local, or intergovernmental department or agency from which the person was detailed to the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae70-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Violation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person that violates this subsection shall be fined under title 18, imprisoned not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5ae71-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Cochairman, Alternate to Federal Cochairman, and Federal Officers and Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Cochairman, the alternate to the Federal Cochairman, and any Federal officer or employee detailed to duty with the Commission are not subject to this section but remain subject to sections 202 through 209 of title 18.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5ae72-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15306/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rescission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Commission may declare void any contract, loan, or grant of or by the Commission in relation to which the Commission determines that there has been a violation of any provision under subsection (a)(1), (b), or (c), or any of the provisions of sections 202 through 209 of title 18.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e5ae73-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14217/a/2"},"text":"Pub. L. 110–234, title XIV, § 14217(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1473"},"text":"122 Stat. 1473","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14217(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2235.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e5ae74-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80e5ae75-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id80e5ae76-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80e5ae77-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id80e5ae78-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s14217/d"},"text":"section 14217(d) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s15101"},"text":"section 15101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
