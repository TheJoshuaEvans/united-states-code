{"tag":"section","attrib":{"id":"id80e33cf5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509"},"text":null,"children":[{"tag":"num","attrib":{"value":"14509"},"text":"§ 14509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-speed broadband deployment initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e33cf6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Appalachian Regional Commission may provide technical assistance, make grants, enter into contracts, or otherwise provide amounts to individuals or entities in the Appalachian region for projects and activities to increase affordable access to broadband networks throughout the Appalachian region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33cf7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Projects and Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project or activity eligible to be carried out under this section is a project or activity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33cf8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct research, analysis, and training to increase broadband adoption efforts in the Appalachian region; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33cf9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the construction and deployment of broadband service-related infrastructure in the Appalachian region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33cfa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Available Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the cost of any activity eligible for a grant under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33cfb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 50 percent may be provided from amounts appropriated to carry out this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33cfc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notwithstanding paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e33cfd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which a distressed county designation is in effect under section 14526, not more than 80 percent may be provided from amounts appropriated to carry out this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e33cfe-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which an at-risk designation is in effect under section 14526, not more than 70 percent may be provided from amounts appropriated to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33cff-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (c), a grant provided under this section may be provided from amounts made available to carry out this section in combination with amounts made available—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33d00-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under any other Federal program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d01-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from any other source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d02-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of law limiting the Federal share under any other Federal program, amounts made available to carry out this section may be used to increase that Federal share, as the Appalachian Regional Commission determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d03-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Request for Data","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before making a grant for a project or activity described in subsection (b)(2), the Appalachian Regional Commission shall request from the Federal Communications Commission, the National Telecommunications and Information Administration, the Economic Development Administration, and the Department of Agriculture data on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33d04-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level and extent of broadband service that exists in the area proposed to be served by the broadband service-related infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d05-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level and extent of broadband service that will be deployed in the area proposed to be served by the broadband service-related infrastructure pursuant to another Federal program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d06-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14509/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each fiscal year, not less than 65 percent of the amounts made available to carry out this section shall be used for grants for projects and activities described in subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e33d07-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tI/s1436/a/1"},"text":"Pub. L. 114–94, div. A, title I, § 1436(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1430"},"text":"129 Stat. 1430","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11506/d"},"text":"Pub. L. 117–58, div. A, title I, § 11506(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/584"},"text":"135 Stat. 584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e33d08-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80e33d09-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80e33d0a-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s11506/d/1"},"text":"Pub. L. 117–58, § 11506(d)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which related to the Appalachian Regional Commission providing technical assistance, making grants, entering into contracts, or otherwise providing amounts to individuals or entities in the Appalachian region for projects and activities and specifying particular objectives in pars. (1) to (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s11506/d/3"},"text":"Pub. L. 117–58, § 11506(d)(3)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s11506/d/2"},"text":"Pub. L. 117–58, § 11506(d)(2)","children":[],"tail":", redesignated subsec. (b) as (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s11506/d/2"},"text":"Pub. L. 117–58, § 11506(d)(2)","children":[],"tail":", (4), redesignated subsec. (c) as (d) and substituted “subsection (c)” for “subsection (b)” in introductory provisions. Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s11506/d/2"},"text":"Pub. L. 117–58, § 11506(d)(2)","children":[],"tail":", redesignated subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s11506/d/5"},"text":"Pub. L. 117–58, § 11506(d)(5)","children":[],"tail":", added subsecs. (f) and (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80e33d0b-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id80e33d0c-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id80e33d0d-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tI/s1436/d"},"text":"Pub. L. 114–94, div. A, title I, § 1436(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1432"},"text":"129 Stat. 1432","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dA/tI/s1436/d"},"text":"“This section [enacting this section and amending sections 14703 and 14704 of this title] and the amendments made by this section take effect on ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"October 1, 2015","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
