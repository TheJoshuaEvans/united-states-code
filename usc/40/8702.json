{"tag":"section","attrib":{"id":"id80cb6f96-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8702"},"text":null,"children":[{"tag":"num","attrib":{"value":"8702"},"text":"§ 8702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80cb6f97-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Environs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “environs” means the territory surrounding the District of Columbia included in the National Capital region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cb6f98-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National capital","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “National Capital” means the District of Columbia and territory the Federal Government owns in the environs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cb6f99-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National capital region","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “National Capital region” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80cb6f9a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8702/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80cb6f9b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8702/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Montgomery and Prince Georges Counties in Maryland;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80cb6f9c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8702/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Arlington, Fairfax, Loudoun, and Prince William Counties in Virginia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80cb6f9d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8702/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all cities in Maryland or Virginia in the geographic area bounded by the outer boundaries of the combined area of the counties listed in subparagraphs (B) and (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cb6f9e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “planning agency” means any city, county, bi-county, part-county, or regional planning agency authorized under state and local laws to 