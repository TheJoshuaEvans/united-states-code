{"tag":"section","attrib":{"id":"id80e5aef5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15506"},"text":null,"children":[{"tag":"num","attrib":{"value":"15506"},"text":"§ 15506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplements to Federal grant programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e5aef6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Finding","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that certain States and local communities of the region, including local development districts, may be unable to take maximum advantage of Federal grant programs for which the States and communities are eligible because—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5aef7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" they lack the economic resources to provide the required matching share; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aef8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are insufficient funds available under the applicable Federal law with respect to a project to be carried out in the region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5aef9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Grant Program Funding","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Commission, with the approval of the Federal Cochairperson, may use amounts made available to carry out this subtitle—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81efa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any part of the basic Federal contribution to projects or activities under the Federal grant programs authorized by Federal laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81efb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the Federal contribution to projects and activities under the programs above the fixed maximum part of the cost of the projects or activities otherwise authorized by the applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81efc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For a program, project, or activity for which any part of the basic Federal contribution to the project or activity under a Federal grant program is proposed to be made under subsection (b), the Federal contribution shall not be made until the responsible Federal official administering the Federal law authorizing the Federal contribution certifies that the program, project, or activity meets the applicable requirements of the Federal law and could be approved for Federal contribution under that law if amounts were available under the law for the program, project, or activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81efd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15506/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations in Other Laws Inapplicable","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts provided pursuant to this subtitle are available without regard to any limitations on areas eligible for assistance or authorizations for appropriation in any other law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81efe-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15506/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of a project or activity receiving assistance under this section shall not exceed 80 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81eff-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15506/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Commission Contribution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 15501(d), relating to limitations on Commission contributions, shall apply to a program, project, or activity receiving assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e81f00-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14217/a/2"},"text":"Pub. L. 110–234, title XIV, § 14217(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1477"},"text":"122 Stat. 1477","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14217(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2239.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e81f01-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80e81f02-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id80e81f03-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80e81f04-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id80e81f05-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s14217/d"},"text":"section 14217(d) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s15101"},"text":"section 15101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
