{"tag":"section","attrib":{"id":"id809bd397-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545"},"text":null,"children":[{"tag":"num","attrib":{"value":"545"},"text":"§ 545.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure for disposal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id809bd398-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Advertising for Bids.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id809bd399-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id809bd39a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), the Administrator of General Services may make or authorize a disposal or a contract for disposal of surplus property only after public advertising for bids, under regulations the Administrator prescribes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id809bd39b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection does not apply to disposal or a contract for disposal of surplus property—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id809bd39c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under subsection (b) or (d); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id809bd39d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by abandonment, destruction, or donation or through a contract broker.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd39e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time, method, and terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The time, method, and terms and conditions of advertisement must permit full and free competition consistent with the value and nature of the property involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd39f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public disclosure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Bids must be publicly disclosed at the time and place stated in the advertisement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd3a0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Awards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An award shall be made with reasonable promptness by notice to the responsible bidder whose bid, conforming to the invitation for bids, is most advantageous to the Federal Government, price and other factors considered. However, all bids may be rejected if it is in the public interest to do so.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id809bd3a1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Negotiated Disposal","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations the Administrator prescribes, disposals and contracts for disposal may be negotiated without regard to subsection (a), but subject to obtaining competition that is feasible under the circumstances, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id809bd3a2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" necessary in the public interest—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id809bd3a3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the period of a national emergency declared by the President or Congress, with respect to a particular lot of personal property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id809bd3a4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period not exceeding three months, with respect to a specifically described category of personal property as determined by the Administrator;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd3a5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public health, safety, or national security will be promoted by a particular disposal of personal property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd3a6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public exigency will not allow delay incident to advertising certain personal property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd3a7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and quantity of personal property involved are such that disposal under subsection (a) would impact an industry to an extent that would adversely affect the national economy, and the estimated fair market value of the property and other satisfactory terms of disposal can be obtained by negotiation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd3a8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated fair market value of the property involved does not exceed $15,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd3a9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after advertising under subsection (a), the bid prices for the property, or part of the property, are not reasonable or have not been independently arrived at in open competition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd3aa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to real property, the character or condition of the property or unusual circumstances make it impractical to advertise publicly for competitive bids and the fair market value of the property and other satisfactory terms of disposal can be obtained by negotiation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd3ab-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disposal will be to a State, territory, or possession of the United States, or to a political subdivision of, or a tax-supported agency in, a State, territory, or possession, and the estimated fair market value of the property and other satisfactory terms of disposal are obtained by negotiation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd3ac-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id809bd3ad-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disposal Through Contract Brokers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Disposals and contracts for disposal of surplus real and related personal property through contract realty brokers employed by the Administrator shall be made in the manner followed in similar commercial transactions under regulations the Administrator prescribes. The regulations must require that brokers give wide public notice of the availability of the property for disposal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id809bd3ae-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Negotiated Sale at Fixed Price.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id809bd3af-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may make a negotiated sale of personal property at a fixed price, either directly or through the use of a disposal contractor, without regard to subsection (a). However, the sale must be publicized to an extent consistent with the value and nature of the property involved and the price established must reflect the estimated fair market value of the property. Sales under this subsection are limited to categories of personal property for which the Administrator determines that disposal under this subsection best serves the interests of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd3b0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"First offer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations and restrictions the Administrator prescribes, an opportunity to purchase property at a fixed price under this subsection may be offered first to an entity specified in subsection (b)(8) that has expressed an interest in the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id809bd3b1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Explanatory Statements for Negotiated Disposals.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id809bd3b2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id809bd3b3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), an explanatory statement of the circumstances shall be prepared for each disposal by negotiation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id809bd3b4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal property that has an estimated fair market value in excess of $15,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id809bd3b5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" real property that has an estimated fair market value in excess of $100,000, except that real property disposed of by lease or exchange is subject only to clauses (iii)–(v) of this subparagraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id809bd3b6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" real property disposed of by lease for a term of not more than 5 years, if the estimated fair annual rent is more than $100,000 for any year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id809bd3b7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/e/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" real property disposed of by lease for a term of more than 5 years, if the total estimated rent over the term of the lease is more than $100,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id809bd3b8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/e/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" real property or real and related personal property disposed of by exchange, regardless of value, or any property for which any part of the consideration is real property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id809bd3b9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An explanatory statement is not required for a disposal of personal property under subsection (d), or for a disposal of real or personal property authorized by any other law to be made without advertising.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd3ba-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transmittal to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The explanatory statement shall be transmitted to the appropriate committees of Congress in advance of the disposal, and a copy of the statement shall be preserved in the files of the executive agency making the disposal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd3bb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Listing in report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A report of the Administrator under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s126"},"text":"section 126 of this title","children":[],"tail":" must include a listing and description of any negotiated disposals of surplus property having an estimated fair market value of more than $15,000, in the case of real property, or $5,000, in the case of any other property, other than disposals for which an explanatory statement has been transmitted under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id809bd3bc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s545/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Other Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 6101(b)–(d) of title 41 does not apply to a disposal or contract for disposal made under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id809bd3bd-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/10