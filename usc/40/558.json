{"tag":"section","attrib":{"id":"id80a08f06-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s558"},"text":null,"children":[{"tag":"num","attrib":{"value":"558"},"text":"§ 558.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donation of forfeited vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80a08f07-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s558/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel that is forfeited to the Federal Government may be donated, in accordance with procedures under this subtitle, to an eligible institution described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08f08-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s558/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Institution","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible institution referred to in subsection (a) is an educational institution with a commercial fishing vessel safety program or other vessel safety, education and training program. The institution must certify to the federal officer making the donation that the program includes, at a minimum, all of the following courses in vessel safety:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a08f09-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s558/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vessel stability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f0a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s558/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Firefighting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f0b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s558/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Shipboard first aid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f0c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s558/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Marine safety and survival.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f0d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s558/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Seamanship rules of the road.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08f0e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s558/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The donation of a vessel under this section shall be made on terms and conditions considered appropriate by the federal officer making the donation. All of the following terms and conditions are required:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a08f0f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s558/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No warranty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The institution must accept the vessel as is, where it is, and without warranty of any kind and without any representation as to its condition or suitability for use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f10-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s558/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The institution is responsible for maintaining the vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f11-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s558/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Instruction only","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The vessel may be used only for instructing students in a vessel safety education and training program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f12-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s558/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Documentation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the vessel is eligible to be documented, it must be documented by the institution as a vessel of the United States under chapter 121 of title 46. The requirements of paragraph (5) must be noted on the permanent record of the vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f13-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s558/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disposal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The institution must obtain prior approval from the Administrator of General Services before disposing of the vessel and any proceeds from disposal shall be payable to the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08f14-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s558/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspection or regulation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The vessel shall be inspected or regulated in the same manner as a nautical school vessel under chapter 33 of title 46.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08f15-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s558/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Government Liability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Government is not liable in an action arising out of the transfer or use of a vessel transferred under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80a08f16-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1103"},"text":"116 Stat. 1103","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80a08f17-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80a08f18-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80a08f19-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"558","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:484d.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/99/640/s13/a"},"text":"Pub. L. 99–640, § 13(a)","children":[],"tail":"–(c), "},{"tag":"html:span","attrib":{},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3551"},"text":"100 Stat. 3551","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “all of” are inserted for clarity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
