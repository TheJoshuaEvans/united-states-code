{"tag":"section","attrib":{"id":"id80dc11c2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14309"},"text":null,"children":[{"tag":"num","attrib":{"value":"14309"},"text":"§ 14309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal financial interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80dc11c3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conflict of Interest.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80dc11c4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14309/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No role allowed","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as permitted by paragraph (2), an individual who is a state member or alternate, or an officer or employee of the Appalachian Regional Commission, shall not participate personally and substantially as a member, alternate, officer, or employee in any way in any particular matter in which, to the individual’s knowledge, any of the following has a financial interest:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80dc11c5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14309/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc11c6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14309/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual’s spouse, minor child, or partner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc11c7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14309/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization (except a State or political subdivision of a State) in which the individual is serving as an officer, director, trustee, partner, or employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc11c8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14309/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any person or organization with whom the individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80dc11c9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14309/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving as an officer, director, trustee, partner, or employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80dc11ca-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14309/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is negotiating or has any arrangement concerning prospective employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc11cb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14309/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) does not apply if the individual first advises the Commission of the nature and circumstances of the particular matter and makes full disclosure of the financial interest and receives in advance a written decision of the Commission that the interest is not so substantial as to be considered likely to affect the integrity of the services which the Commission may expect from the individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc11cc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14309/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual violating this subsection shall be fined under title 18, imprisoned for not more than two years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc11cd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Sources of Salary Disallowed.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80dc11ce-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14309/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State member or alternate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A state member or alternate may not receive any salary, or any contribution to, or supplementation of, salary, for services on the Commission from a source other than the State of the member or alternate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc11cf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14309/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individuals detailed to commission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual detailed to serve the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14306/a/4"},"text":"section 14306(a)(4) of this title","children":[],"tail":" may not receive any salary, or any contribution to, or supplementation of, salary, for services on the Commission from a source other than the state, local, or intergovernmental department or agency from which the individual was detailed or from the Commission."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc11d0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14309/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual violating this subsection shall be fined under title 18, imprisoned for not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc11d1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14309/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Cochairman, Alternate to Federal Cochairman, and Federal Officers and Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Cochairman, the alternate to the Federal Cochairman, and any federal officer or employee detailed to duty with the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14306/a/3"},"text":"section 14306(a)(3) of this title","children":[],"tail":" are not subject to this section but remain subject to sections 202–209 of title 18."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc11d2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14309/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rescission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may declare void and rescind any contract, loan, or grant of or by the Commission in relation to which it finds that there has been a violation of subsection (a)(1) or (b) of this section or any of the provisions of sections 202–209 of title 18.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80dc11d3-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1261"},"text":"116 Stat. 1261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80dc11d4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80dc11d5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80dc11d6-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14309(a)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:108(a) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/4/tI/s108"},"text":"Pub. L. 89–4, title I, § 108","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Mar. 9, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/9"},"text":"79 Stat. 9","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14309(a)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:108(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14309(a)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:108(a) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14309(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:108(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14309(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:108(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14309(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:108(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “proceeding, application, request for a ruling or other determination, contract, claim, controversy, or other” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before clause (A), the words “in any way” are substituted for “through decision, approval, disapproval, recommendation, the rendering of advice, investigation, or otherwise” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “fined under title 18” are substituted for “fined not more than $10,000” for consistency with chapter 227 of title 18.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the words “fined under title 18” are substituted for “fined not more than $5,000” for consistency with chapter 227 of title 18.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “Notwithstanding any other subsection of this section” are omitted as unnecessary. The words “this section” are substituted for “any such subsection” to correct an apparent error in the source provision.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “in its discretion” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
