{"tag":"section","attrib":{"id":"id80a549e0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s585"},"text":null,"children":[{"tag":"num","attrib":{"value":"585"},"text":"§ 585.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80a549e1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s585/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a549e2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s585/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services may enter into a lease agreement with a person, copartnership, corporation, or other public or private entity for the accommodation of a federal agency in a building (or improvement) which is in existence or being erected by the lessor to accommodate the federal agency. The Administrator may assign and reassign the leased space to a federal agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a549e3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s585/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A lease agreement under this subsection shall be on terms the Administrator considers to be in the interest of the Federal Government and necessary for the accommodation of the federal agency. However, the lease agreement may not bind the Government for more than 20 years and the obligation of amounts for a lease under this subsection is limited to the current fiscal year for which payments are due without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1341/a/1/B"},"text":"section 1341(a)(1)(B) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a549e4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s585/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sublease.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a549e5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s585/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection applies to rent received if the Administrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a549e6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s585/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that an unexpired portion of a lease of space to the Government is surplus property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a549e7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s585/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disposes of the property by sublease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a549e8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s585/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of rent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s571/a"},"text":"section 571(a) of this title","children":[],"tail":", the Administrator may deposit rent received into the Federal Buildings Fund. The Administrator may defray from the fund any costs necessary to provide services to the Government’s lessee and to pay the rent (not otherwise provided for) on the lease of the space to the Government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a549e9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s585/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amounts for Rent Available for Lease of Buildings on Government Land","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts made available to the General Services Administration for the payment of rent may be used to lease space, for a period of not more than 30 years, in buildings erected on land owned by the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a549ea-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s585/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any bargain-price option to purchase at less than fair market value contained in any lease agreement entered into on or after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", pursuant to this section may be exercised only to the extent specifically provided for in subsequent appropriation Acts or other Acts of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80a549eb-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1112"},"text":"116 Stat. 1112","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/257/s1"},"text":"Pub. L. 117–257, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-21"},"text":"Dec. 21, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2371"},"text":"136 Stat. 2371","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80a549ec-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80a549ed-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80a549ee-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"585(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:490(h)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title II, § 210(h)(1), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/85/493/s1"},"text":"Pub. L. 85–493, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 2, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/294"},"text":"72 Stat. 294","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/86/249/s12/e"},"text":"Pub. L. 86–249, § 12(e)","children":[],"tail":", formerly § 12(d), "},{"tag":"html:span","attrib":{},"text":"Sept. 9, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/73/482"},"text":"73 Stat. 482","children":[],"tail":"; redesignated § 12(e), "},{"tag":"html:a","attrib":{"href":"/us/pl/94/541/tI/s103/3"},"text":"Pub. L. 94–541, title I, § 103(3)","children":[],"tail":" (related to § 12(e)), "},{"tag":"html:span","attrib":{},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/2506"},"text":"90 Stat. 2506","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:490e.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/101/136/tIV/s22"},"text":"Pub. L. 101–136, title IV, § 22","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 3, 1989","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/103/807"},"text":"103 Stat. 807","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"585(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:490(h)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title II, § 210(h)(2), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/85/493/s1"},"text":"Pub. L. 85–493, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 2, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/294"},"text":"72 Stat. 294","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"585(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:490d.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/101/136/tIV/s5"},"text":"Pub. L. 101–136, title IV, § 5","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 3, 1989","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/103/802"},"text":"103 Stat. 802","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “Federal Buildings Fund” are substituted for “buildings management fund” because the fund established under 40:490(f)(1) is the Federal Buildings Fund and unexpended balances in the Buildings Management Fund were merged into the Federal Buildings Fund under 40:490(f)(3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80a549ef-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80a549f0-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/257"},"text":"Pub. L. 117–257","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80a549f1-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80a549f2-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Secure Federal Leases from Espionage And Suspicious Entanglements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/276"},"text":"Pub. L. 116–276","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3362"},"text":"134 Stat. 3362","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/276"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE; FINDINGS.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Short Title","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This Act may be cited as the ‘Secure Federal Leases from Espionage And Suspicious Entanglements Act’ or the ‘Secure Federal LEASEs Act’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government Accountability Office has reported that the Federal Government often leases high-security space from private sector landlords;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the General Services Administration collects highest-level and immediate ownership information through the System for Award Management, but it is not currently required to collect beneficial ownership information and lacks an adequate system for doing so;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the General Services Administration and Federal agencies with leasing authority may not know if foreign owners have a stake in the buildings leased by the agencies, either through foreign-incorporated legal entities or through ownership in United States-incorporated legal entities, even when the leased space is used for classified operations or to store sensitive data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" according to a report of the Government Accountability Office, dated January 2017, that examined the risks of foreign ownership of Government-leased real estate, ‘leasing space in foreign-owned buildings could present security risks such as espionage and unauthorized cyber and physical access’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DEFINITIONS.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“In this Act:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Beneficial owner.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), the term ‘beneficial owner’ means, with respect to a covered entity, each natural person who, directly or indirectly, through any contract, arrangement, understanding, relationship, or otherwise—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercises control over the covered entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a substantial interest in or receives substantial economic benefits from the assets of the covered entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘beneficial owner’ does not include, with respect to a covered entity—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a minor child;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person acting as a nominee, intermediary, custodian, or agent on behalf of another person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person acting solely as an employee of the covered entity and whose control over or economic benefits from the covered entity derives solely from the employment status of the person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"“(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person whose only interest in the covered entity is through a right of inheritance, unless the person also meets the requirements of subparagraph (A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"“(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a creditor of the covered entity, unless the creditor also meets the requirements of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Anti-abuse rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The exceptions under subparagraph (B) shall not apply if used for the purpose of evading, circumventing, or abusing the requirements of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Control","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘control’ means, with respect to a covered entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having the authority or ability to determine how a covered entity is utilized; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having some decision-making power for the use of a covered entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered entity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘covered entity’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person, corporation, company, business association, partnership, society, trust, or any other nongovernmental entity, organization, or group; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any governmental entity or instrumentality of a government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Executive agency’ has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Federal agency’ means any Executive agency or any establishment in the legislative or judicial branch of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal lessee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘Federal lessee’—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means the Administrator of General Services, the Architect of the Capitol, or the head of any Federal agency, other than the Department of Defense, that has independent statutory leasing authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include the head of an element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal tenant","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘Federal tenant’—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a Federal agency that is occupying or will occupy a high-security leased space for which a lease agreement has been secured on behalf of the Federal agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include an element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign entity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘foreign entity’ means a covered entity that is headquartered or incorporated in a country that is not the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign person","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘foreign person’ means an individual who is not a United States person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"“(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"High-security leased space","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘high-security leased space’ means a space leased by a Federal lessee that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be occupied by Federal employees for nonmilitary activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a facility security level of III, IV, or V, as determined by the Federal tenant in consultation with the Interagency Security Committee, the Department of Homeland Security, and the General Services Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"“(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Highest-level owner","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘highest-level owner’ means the entity that owns or controls an immediate owner of the offeror of a lease, or that owns or controls 1 or more entities that control an immediate owner of the offeror.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"“(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Immediate owner","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘immediate owner’ means an entity, other than the offeror of a lease, that has direct control of the offeror, including ownership or interlocking management, identity of interests among family members, shared facilities and equipment, and the common use of employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"“(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intelligence community","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘intelligence community’ has the meaning given the term in section 3 of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"50 U.S.C. 3003","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"“(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Substantial economic benefits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘substantial economic benefits’ means, with respect to a natural person described in paragraph (1)(A)(ii), having an entitlement to the funds or assets of a covered entity that, as a practical matter, enables the person, directly or indirectly, to control, manage, or direct the covered entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"“(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United states person","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘United States person’ means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a citizen of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an alien lawfully admitted for permanent residence in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"“(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Widely held","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘widely held’ means a fund that has not less than 100 natural persons as direct or indirect investors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“SEC. 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DISCLOSURE OF OWNERSHIP OF HIGH-SECURITY SPACE LEASED FOR FEDERAL AGENCIES.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Disclosures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before entering into a lease agreement with a covered entity or approving a novation agreement with a covered entity involving a change of ownership under a lease that will be used for high-security leased space, a Federal lessee shall require the covered entity to identify and disclose whether the immediate or highest-level owner of the leased space, including an entity involved in the financing thereof, is a foreign person or a foreign entity, including the country associated with the ownership entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a disclosure is made under subsection (a), the Federal lessee shall notify the Federal tenant of the building or other improvement that will be used for high-security space in writing, and consult with the Federal tenant, regarding security concerns and necessary mitigation measures, if any, prior to award of the lease or approval of the novation agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Federal lessee shall require a covered entity to provide the information described in subsection (a) when first submitting a proposal in response to a solicitation for offers issued by the Federal lessee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Federal lessee shall require a covered entity to submit an update of the information described in subsection (a) annually, beginning on the date that is 1 year after the date on which the Federal tenant began occupancy, with information including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the list of immediate or highest-level owners of the covered entity during the preceding 1-year period of Federal occupancy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required to be provided relating to each such immediate or highest-level owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“SEC. 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" IMMEDIATE, HIGHEST-LEVEL, AND BENEFICIAL OWNERS.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The General Services Administration, in coordination with the Office of Management and Budget, shall develop a Government-wide plan for agencies (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551"},"text":"section 551 of title 5","children":[],"tail":", United States Code) for identifying all immediate, highest-level, or beneficial owners of high-security leased spaces before entering into a lease agreement with a covered entity for the accommodation of a Federal tenant in a high-security leased space."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan described in subsection (a) shall include a process for collecting and utilizing the following information on each immediate, highest-level, or beneficial owner of a high-security leased space:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Name.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Current residential or business street address.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An identifying number or document that verifies identity as a United States person, foreign person, or foreign entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosures and notifications.—","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan described in subsection (a) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the disclosure of any immediate, highest-level, or beneficial owner that is a foreign person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that, if the Federal lessee is assigning the building or other improvement that will be used for high-security space to a Federal tenant, the Federal tenant shall be notified of the disclosure described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exclude collecting ownership information on widely held pooled-investment vehicles, mutual funds, trusts, or other pooled-investment vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report and Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The General Services Administration shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":"], submit the plan described in subsection (a) to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 2 years after the date of enactment of this Act, implement the plan described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after the implementation of the plan described in subsection (a), and each year thereafter for 9 years, submit a report to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives on the status of the implementation of the plan, including the number of disclosures made under subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“SEC. 5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OTHER SECURITY AGREEMENTS FOR LEASED SPACE.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“A lease agreement between a Federal lessee and a covered entity for the accommodation of a Federal agency in a building or other improvement that will be used for high-security leased space shall include language that provides that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the covered entity and any member of the property management company who may be responsible for oversight or maintenance of the high-security leased space shall not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain access to the high-security leased space; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have access to the high-security leased space without prior approval from the Federal tenant;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to the high-security leased space or any property or information located within that space will only be granted by the Federal tenant if the Federal tenant determines that the access is clearly consistent with the mission and responsibilities of the Federal tenant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal lessee shall have written procedures in place, signed by the Federal lessee and the covered entity, governing access to the high-security leased space in case of emergencies that may damage the leased property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“SEC. 6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AGENCY NOTIFICATIONS.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Not later than 60 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":"], the Administrator of General Services, in consultation with the Office of Management and Budget, shall provide notification to relevant Executive branch agencies with independent leasing authorities of the requirements of this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“SEC. 7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" APPLICABILITY.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Except where otherwise provided, this Act shall apply with respect to any lease or novation agreement entered into on or after the date that is 6 months after the date of enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80a549f3-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Lease of Building Space by Wholly Owned Government Corporations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch358/tIII/s306"},"text":"Act July 30, 1947, ch. 358, title III, § 306","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/584"},"text":"61 Stat. 584","children":[],"tail":", provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1947-07-30/ch358/tIII/s306"},"text":"“Wholly owned Government corporations requiring space in office buildings at the seat of government shall occupy only such space as may be allotted in accordance with the provisions of such Act of ","children":[{"tag":"date","attrib":{"date":"1919-03-01"},"text":"March 1, 1919","children":[],"tail":", as amended [ch. 86, § 10, "},{"tag":"ref","attrib":{"href":"/us/stat/40/1269"},"text":"40 Stat. 1269","children":[],"tail":"] ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s1"},"text":"40 U.S.C. 1","children":[],"tail":"), and shall pay such rental thereon as may be determined by the Federal Works Administrator [Administrator of General Services], such rental to include all cost of maintenance, upkeep, and repair.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
