{"tag":"section","attrib":{"id":"id8088c12a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s112"},"text":null,"children":[{"tag":"num","attrib":{"value":"112"},"text":"§ 112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain policies, procedures, and directives in effect on ","children":[{"tag":"date","attrib":{"date":"1949-07-01"},"text":"July 1, 1949","children":[],"tail":null}],"tail":null},{"tag":"subsection","attrib":{"id":"id8088c12b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A policy, procedure, or directive described in subsection (b) remains in effect until superseded or amended under this subtitle or other appropriate authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8088c12c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A policy, procedure, or directive referred to in subsection (a) is one that was in effect on ","children":[{"tag":"date","attrib":{"date":"1949-07-01"},"text":"July 1, 1949","children":[],"tail":", and that was prescribed by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8088c12d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Bureau of Federal Supply or the Secretary of the Treasury and that related to a function transferred to or vested in the Administrator of General Services on ","children":[{"tag":"date","attrib":{"date":"1949-06-30"},"text":"June 30, 1949","children":[],"tail":", by the Federal Property and Administrative Services Act of 1949; "},{"tag":"ref","attrib":{"idref":"fn002000"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002000"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8088c12e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer of the Federal Government under authority of the Surplus Property Act of 1944 (ch. 479, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/58/765"},"text":"58 Stat. 765","children":[],"tail":") or other authority related to surplus property or foreign excess property;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8088c12f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s112/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Works Administrator or the head of a constituent agency of the Federal Works Agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8088c130-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s112/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Archivist of the United States or another officer or body whose functions were transferred on ","children":[{"tag":"date","attrib":{"date":"1949-06-30"},"text":"June 30, 1949","children":[],"tail":", by title I "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the Federal Property and Administrative Services Act of 1949."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8088c131-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1065"},"text":"116 Stat. 1065","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8088c132-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id8088c133-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id8088c134-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":