{"tag":"section","attrib":{"id":"id80b5ec83-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301"},"text":null,"children":[{"tag":"num","attrib":{"value":"3301"},"text":"§ 3301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and nonapplication","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80b5ec84-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b5ec85-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alter","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “alter” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80b5ec86-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preliminary planning, engineering, architectural, legal, fiscal, and economic investigations and studies, surveys, designs, plans, working drawings, specifications, procedures, and other similar actions necessary for the alteration of a public building; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b5ec87-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repairing, remodeling, improving, or extending, or other changes in, a public building.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b5ec88-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construct","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “construct” includes preliminary planning, engineering, architectural, legal, fiscal, and economic investigations and studies, surveys, designs, plans, working drawings, specifications, procedures, and other similar actions necessary for the construction of a public building.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b5ec89-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive agency","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “executive agency” means an executive department or independent establishment in the executive branch of the Federal Government, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80b5ec8a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any wholly owned Government corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b5ec8b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Central-Bank for Cooperatives and the regional banks for cooperatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b5ec8c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" federal land banks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b5ec8d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" federal intermediate credit banks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b5ec8e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Deposit Insurance Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b5ec8f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government National Mortgage Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b5ec90-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “federal agency” means an executive agency or an establishment in the legislative or judicial branch of the Government (except the Senate, the House of Representatives, and the Architect of the Capitol and any activities under the direction of the Architect).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b5ec91-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public building","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “public building”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80b5ec92-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a building, whether for single or multitenant occupancy, and its grounds, approaches, and appurtenances, which is generally suitable for use as office or storage space or both by one or more federal agencies or mixed-ownership Government corporations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b5ec93-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80b5ec94-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" federal office buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5ec95-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" post offices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5ec96-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" customhouses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5ec97-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" courthouses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5ec98-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appraisers stores;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5ec99-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" border inspection facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5ec9a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" warehouses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5ec9b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" record centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5ec9c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relocation facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5ec9d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" telecommuting centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5ec9e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" similar federal facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5ec9f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/B/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other buildings or construction projects the inclusion of which the President considers to be justified in the public interest; but","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b5eca0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include a building or construction project described in subparagraphs (A) and (B)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80b5eca1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is on the public domain (including that reserved for national forests and other purposes);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5eca2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is on property of the Government in foreign countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5eca3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is on Indian and native Eskimo property held in trust by the Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5eca4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is on land used in connection with federal programs for agricultural, recreational, and conservation purposes, including research in connection with the programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5eca5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is on or used in connection with river, harbor, flood control, reclamation or power projects, for chemical manufacturing or development projects, or for nuclear production, research, or development projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5eca6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is on or used in connection with housing and residential projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5eca7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is on military installations (including any fort, camp, post, naval training station, airfield, proving ground, military supply depot, military school, or any similar facility of the Department of Defense);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5eca8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is on installations of the Department of Veterans Affairs used for hospital or domiciliary purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b5eca9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/5/C/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exclusion of which the President considers to be justified in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b5ecaa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United states","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “United States” includes the States of the United States, the District of Columbia, Puerto Rico, and the territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b5ecab-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This chapter does not apply to the construction of any public building to which section 241(g) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1231/g"},"text":"8 U.S.C. 1231(g)","children":[],"tail":") or "},{"tag":"ref","attrib":{"href":"/us/act/1930-06-26/s1"},"text":"section 1 of the Act of June 26, 1930","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t19/s68"},"text":"19 U.S.C. 68","children":[],"tail":") applies."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b5ecac-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1156"},"text":"116 Stat. 1156","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b5ecad-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b5ecae-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80b5ecaf-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:co