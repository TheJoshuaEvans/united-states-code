{"tag":"section","attrib":{"id":"id809962de-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s522"},"text":null,"children":[{"tag":"num","attrib":{"value":"522"},"text":"§ 522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for transfer of excess property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id809962df-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s522/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsections (b) and (c), the Administrator of General Services, with the approval of the Director of the Office of Management and Budget, shall prescribe the amount of reimbursement required for a transfer of excess property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id809962e0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s522/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement at Fair Value","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of reimbursement required for a transfer of excess property is the fair value of the property, as determined by the Administrator, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id809962e1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s522/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" net proceeds are requested under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s574/a"},"text":"section 574(a) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809962e2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s522/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either the transferor or the transferee agency (or the organizational unit affected) is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id809962e3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s522/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to chapter 91 of title 31; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id809962e4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s522/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s321/c/2"},"text":"section 321(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id809962e5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s522/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution Through General Services Administration Supply Centers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Excess property determined by the Administrator to be suitable for distribution through the supply centers of the General Services Administration shall be retransferred at prices set by the Administrator with due regard to prices established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s321/d"},"text":"section 321(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id809962e6-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1083"},"text":"116 Stat. 1083","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s6/1"},"text":"Pub. L. 109–284, § 6(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1212"},"text":"120 Stat. 1212","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id809962e7-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id809962e8-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id809962e9-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"522","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:483(a)(1) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title II, § 202(a)(1) (last sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/63/384"},"text":"63 Stat. 384","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-12/ch703/s1/f"},"text":"July 12, 1952, ch. 703, § 1(f)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/593"},"text":"66 Stat. 593","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Director of the Office of Management and Budget” are substituted for “Director of the Bureau of the Budget” in section 202(a)(1) (last sentence) of the Federal Property and Administrative Services Act of 1949 because the office of Director of the Bureau of the Budget was redesignated the Director of the Office of Management and Budget by section 102(b) of Reorganization Plan No. 2 of 1970 (eff. ","children":[{"tag":"date","attrib":{"date":"1970-07-01"},"text":"July 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2085"},"text":"84 Stat. 2085","children":[],"tail":"). Section 102 of Reorganization Plan No. 2 of 1970, was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1982-09-13/s5/b"},"text":"section 5(b) of the Act of September 13, 1982","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Public Law 97–258","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1085"},"text":"96 Stat. 1085","children":[],"tail":"), the first section of which enacted Title 31, United States Code, but the successor provision, 31:502, continued the designation as Director of the Office of Management and Budget."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the reference to “section 204(b)” in section 202(a)(1) (last sentence) of the Federal Property and Administrative Services Act of 1949 is translated as a reference to section 204(c) of the Act because subsection (b) was redesignated as (c) by the Act of ","children":[{"tag":"date","attrib":{"date":"1954-08-31"},"text":"August 31, 1954","children":[],"tail":" (ch.1178, "},{"tag":"ref","attrib":{"href":"/us/stat/68/1051"},"text":"68 Stat. 1051","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2)(A), the words “chapter 91 of title 31” are substituted for “the Government Corporation Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/stat/59/597"},"text":"59 Stat. 597","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s841"},"text":"31 U.S.C. 841","children":[],"tail":")” in section 202(a)(1) (last sentence) of the Federal Property and Administrative Services Act of 1949 because of "},{"tag":"ref","attrib":{"href":"/us/act/1982-09-13/s4/b"},"text":"section 4(b) of the Act of September 13, 1982","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Public Law 97–258","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":"), the first section of which enacted Title 31, United States Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “at” is substituted for “as” (in the phrase “as [sic] prices set by the Administrator”) to reflect the probable intent of Congress. See Senate Report No. 2075, dated ","children":[{"tag":"date","attrib":{"date":"1952-07-02"},"text":"July 2, 1952","children":[],"tail":" (United States Code Congressional and Administrative News, 82nd Congress, 2d Session, 1952, Volume 2, p. 2123)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id809962ea-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id809962eb-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284/s6/1"},"text":"Pub. L. 109–284, § 6(1)","children":[],"tail":", struck out “of this section” after “subsections (b) and (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284/s6/2"},"text":"Pub. L. 109–284, § 6(2)","children":[],"tail":", substituted “at” for “At” in heading."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
