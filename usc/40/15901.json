{"tag":"section","attrib":{"id":"id80e81f9d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901"},"text":null,"children":[{"tag":"num","attrib":{"value":"15901"},"text":"§ 15901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State capacity building grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e81f9e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81f9f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commission state","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Commission State” means a State that contains 1 or more eligible counties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fa0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible county","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “eligible county” means a county described in subchapter II of chapter 157.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fa1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “program” means a State capacity building grant program established by a Commission under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81fa2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Commission shall establish a State capacity building grant program to provide grants to Commission States in the area served by the Commission for the purposes described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81fa3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of a program are to support the efforts of the Commission—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81fa4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to better support business retention and expansion in eligible counties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fa5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create programs to encourage job creation and workforce development in eligible counties, including projects and activities, in coordination with other relevant Federal agencies, to strengthen the water sector workforce and facilitate the sharing of best practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fa6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to partner with universities in distressed counties (as designated under section 15702(a)(1))—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e81fa7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen the capacity in eligible counties to train new professionals in fields for which there is a shortage of workers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e81fa8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase local capacity in eligible counties for project management, project execution, and financial management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e81fa9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to leverage funding sources for eligible counties;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81faa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prepare economic and infrastructure plans for eligible counties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fab-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand access to high-speed broadband in eligible counties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fac-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical assistance that results in Commission investments in transportation, water, wastewater, and other critical infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fad-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote workforce development in eligible counties to support resilient infrastructure projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fae-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop initiatives to increase the effectiveness of local development districts in eligible counties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81faf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement new or innovative economic development practices that will better position eligible counties to compete in the global economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81fb0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81fb1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds from a grant under a program may be used to support a project, program, or related expense of the Commission State in an eligible county.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fb2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds from a grant under a program shall not be used for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e81fb3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of furniture, fixtures, or equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e81fb4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the compensation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80e81fb5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State member of the Commission (as described in section 15301(b)(1)(B)); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e81fb6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State alternate member of the Commission (as described in section 15301(b)(2)(B)); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e81fb7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of supplanting existing State programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81fb8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Work Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81fb9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each fiscal year, before providing a grant under a program, each Commission State shall provide to the Commission an annual work plan that includes the proposed use of the grant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fba-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No grant under a program shall be provided to a Commission State unless the Commission has approved the annual work plan of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81fbb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Grant.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81fbc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a grant provided to a Commission State under a program for a fiscal year shall be based on the proportion that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e81fbd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount paid by the Commission State (including any amounts paid on behalf of the Commission State by a nonprofit organization) for administrative expenses for the applicable fiscal year (as determined under section 15304(c)); bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e81fbe-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount paid by all Commission States served by the Commission (including any amounts paid on behalf of a Commission State by a nonprofit organization) for administrative expenses for that fiscal year (as determined under that section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fbf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be eligible to receive a grant under a program for a fiscal year, a Commission State (or a nonprofit organization on behalf of the Commission State) shall pay the amount of administrative expenses of the Commission State for the applicable fiscal year (as determined under section 15304(c)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fc0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each fiscal year, a grant provided under a program shall be approved and made available as part of the approval of the annual budget of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81fc1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds from a grant under a program shall be available only during the fiscal year for which the grant is provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81fc2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each fiscal year, each Commission State shall submit to the relevant Commission and make publicly available a report that describes the use of the grant funds and the impact of the program in the Commission State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81fc3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15901/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuation of Program Authority for Northern Border Regional Commission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to the Northern Border Regional Commission, the program shall be a continuation of the program under section 6304(c) of the Agriculture Improvement Act of 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s15501"},"text":"40 U.S.C. 15501","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Public Law 115–334","children":[],"tail":") (as in effect on the day before the date of enactment of this section)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e81fc4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2248/a"},"text":"Pub. L. 118–272, div. B, title II, § 2248(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3205"},"text":"138 Stat. 3205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e81fc5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80e81fc6-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80e81fc7-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (i), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272"},"text":"Pub. L. 118–272","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
