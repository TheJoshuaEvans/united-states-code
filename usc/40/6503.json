{"tag":"section","attrib":{"id":"id80c44332-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6503"},"text":null,"children":[{"tag":"num","attrib":{"value":"6503"},"text":"§ 6503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission for the Judiciary Office Building","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c44333-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is a Commission for the Judiciary Office Building, composed of the following 13 members or their designees:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c44334-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two individuals appointed by the Chief Justice from among justices of the Supreme Court and other judges of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44335-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The members of the House Office Building Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44336-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6503/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The majority leader and minority leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44337-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6503/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman and the ranking minority member of the Senate Committee on Rules and Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44338-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6503/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman and the ranking minority member of the Senate Committee on Environment and Public Works.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44339-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6503/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman and ranking minority member of the Committee on Transportation and Infrastructure of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c4433a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quorum","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Seven members of the Commission is a quorum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c4433b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission is responsible for the supervision of the design, construction, operation, maintenance, structural, mechanical, and domestic care, and security of the Thurgood Marshall Federal Judiciary Building. The Commission shall prescribe regulations to govern the actions of the Architect of the Capitol under this chapter and to govern the use and occupancy of all space in the Building.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c4433c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1189"},"text":"116 Stat. 1189","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c4433d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c4433e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c4433f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{}