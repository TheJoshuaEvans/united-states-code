{"tag":"section","attrib":{"id":"id80aa0545-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623"},"text":null,"children":[{"tag":"num","attrib":{"value":"623"},"text":"§ 623.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of a Federal Real Property Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80aa0546-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established a Federal Real Property Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa0547-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the Council shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa0548-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop guidance and ensure implementation of an efficient and effective real property management strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0549-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify opportunities for the Federal Government to better manage property and assets of the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa054a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the costs of managing property of the Federal Government, including operations, maintenance, and security associated with Federal property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa054b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa054c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be composed exclusively of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80aa054d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the senior real property officers of each Federal agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa054e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Deputy Director for Management of the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa054f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Controller of the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa0550-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa0551-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other full-time or permanent part-time Federal officials or employees, as the Chairperson determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0552-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairperson","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Deputy Director for Management of the Office of Management and Budget shall serve as Chairperson of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0553-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive director.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80aa0554-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chairperson shall designate an Executive Director to assist in carrying out the duties of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa0555-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Executive Director shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80aa0556-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed from among individuals who have substantial experience in the areas of commercial real estate and development, real property management, and Federal operations and management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80aa0557-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold no outside employment that may conflict with duties inherent to the position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa0558-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa0559-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall meet subject to the call of the Chairperson.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa055a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall meet not fewer than 4 times each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa055b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council, in consultation with the Director and the Administrator, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa055c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 1 year after the date of enactment of this subchapter, establish a real property management plan template, to be updated annually, which shall include performance measures, specific milestones, measurable savings, strategies, and Government-wide goals based on the goals established under section 524(a)(7) to reduce surplus property or to achieve better utilization of underutilized property, and evaluation criteria to determine the effectiveness of real property management that are designed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80aa055d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable Congress and heads of Federal agencies to track progress in the achievement of property management objectives on a Government-wide basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa055e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the management of real property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa055f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow for comparison of the performance of Federal agencies against industry and other public sector agencies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0560-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop utilization rates consistent throughout each category of space, considering the diverse nature of the Federal portfolio and consistent with nongovernmental space use rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0561-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a strategy to reduce the reliance of Federal agencies on leased space for long-term needs if ownership would be less costly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0562-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guidance on eliminating inefficiencies in the Federal leasing process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0563-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compile a list of field offices that are suitable for collocation with other property assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0564-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research best practices regarding the use of public-private partnerships to manage properties and develop guidelines for the use of those partnerships in the management of Federal property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0565-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 1 year after the date of enactment of this subchapter and annually during the 4-year period beginning on the date that is 1 year after the date of enactment of this subchapter and ending on the date that is 5 years after the date of enactment of this subchapter, the Council shall submit to the Director a report that contains—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80aa0566-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/e/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the remaining excess property that is real property, surplus property that is real property, and underutilized property of each Federal agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa0567-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/e/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress of the Council toward developing guidance for Federal agencies to ensure that the assessment required under section 524(a)(11)(B) is carried out in a uniform manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa0568-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/e/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress of Federal agencies toward achieving the goals established under section 524(a)(7);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa0569-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/e/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if necessary, recommendations for legislation or statutory reforms that would further the goals of the Council, including streamlining the disposal of excess or underutilized real property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa056a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/e/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of entities that are consulted under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa056b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the duties described in subsection (e), the Council shall also consult with representatives of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa056c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, and tribal authorities, as appropriate, and other affected communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa056d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" appropriate private sector entities and nongovernmental organizations that have expertise in areas of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80aa056e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial real estate and development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa056f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" government management and operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa0570-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" space planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa0571-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community development, including transportation and planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa0572-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" historic preservation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa0573-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/f/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing housing to the homeless population.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa0574-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Council Resources","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director and the Administrator shall provide staffing, and administrative support for the Council, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa0575-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall provide, on an annual basis, the real property management plan template required under subsection (e)(1) and the reports required under subsection (e)(7) to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa0576-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0577-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Environment and Public Works of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0578-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Oversight and Government Reform of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0579-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Transportation and Infrastructure of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa057a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Comptroller General of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa057b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, surplus property shall not include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa057c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any military installation (as defined in section 2910 of the Defense Base Closure and Realignment Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2687"},"text":"10 U.S.C. 2687","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Public Law 101–510","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa057d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property that is excepted from the definition of the term “property” under section 102;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa057e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian and native Eskimo property held in trust by the Federal Government as described in section 3301(a)(5)(C)(iii);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa057f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" real property operated and maintained by the Tennessee Valley Authority pursuant to the Tennessee Valley Authority Act of 1933 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s831"},"text":"16 U.S.C. 831","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0580-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s623/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any real property the Director excludes for reasons of national security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0581-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s62