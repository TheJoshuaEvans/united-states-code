{"tag":"section","attrib":{"id":"id80aa0507-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s609"},"text":null,"children":[{"tag":"num","attrib":{"value":"609"},"text":"§ 609.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of vehicles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80aa0508-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s609/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Administrator of General Services, every motor vehicle acquired and used for official purposes within the United States, or the territories or possessions of the United States, by any federal agency or by the District of Columbia shall be conspicuously identified by showing, on the vehicle—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa0509-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s609/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80aa050a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s609/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the full name of the department, establishment, corporation, or agency that uses the vehicle and the service for which the vehicle is used; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa050b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s609/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a title that readily identifies the department, establishment, corporation, or agency that uses the vehicle and that is descriptive of the service for which the vehicle is used; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa050c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s609/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the legend “For official use only”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa050d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s609/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations prescribed pursuant to this section may provide for exemptions when conspicuous identification would interfere with the purpose for which a vehicle is acquired and used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80aa050e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1124"},"text":"116 Stat. 1124","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80aa050f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80aa0510-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80aa0511-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","a