{"tag":"section","attrib":{"id":"id80a2d865-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574"},"text":null,"children":[{"tag":"num","attrib":{"value":"574"},"text":"§ 574.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rules regarding proceeds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80a2d866-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credit to Reimbursable Fund or Appropriation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a2d867-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection applies to property acquired with amounts—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a2d868-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not appropriated from the general fund of the Treasury; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a2d869-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriated from the general fund of the Treasury but by law reimbursable from assessment, tax, or other revenue or receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a2d86a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The net proceeds of a disposition or transfer of property described in paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a2d86b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credited to the applicable reimbursable fund or appropriation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a2d86c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid to the federal agency that determined the property to be excess.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a2d86d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Calculation of net proceeds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this subsection, the net proceeds of a disposition or transfer of property are the proceeds less all expenses incurred for the disposition or transfer, including care and handling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a2d86e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative credit to miscellaneous receipts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the agency that determined the property to be excess decides that it is uneconomical or impractical to ascertain the amount of net proceeds, the proceeds shall be credited to miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a2d86f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Account for Refunds or Payments for Breach.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a2d870-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A federal agency that disposes of surplus property under this chapter may deposit, in a special account in the Treasury, amounts of the proceeds of the dispositions that the agency decides are necessary to permit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a2d871-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate refunds to purchasers for dispositions that are rescinded or that do not become final; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a2d872-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments for breach of warranty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a2d873-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withdrawals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A federal agency that deposits proceeds in a special account under paragraph (1) may withdraw amounts to be refunded or paid from the account without regard to the origin of the amounts withdrawn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a2d874-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credit to Cost of Contractor’s Work","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a contract made by an executive agency, or a subcontract under that contract, authorizes the proceeds of a sale of property in the custody of a contractor or subcontractor to be credited to the price or cost of work covered by the contract or subcontract, then the proceeds of the sale shall be credited in accordance with the contract or subcontract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a2d875-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of Property Instead of Cash","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An executive agency entitled to receive cash under a contract for the lease, sale, or other disposition of surplus property may accept property instead of cash if the President determines that the property is strategic or critical material. The property is valued at the prevailing market price when the cash payment becomes due.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a2d876-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management of Credit, Leases, and Permits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a disposition of surplus property under this chapter, if credit has been extended, or if the disposition has been by lease or permit, the Administrator of General Services, in a manner and on terms the Administrator determines are in the best interest of the Federal Government—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a2d877-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall administer and manage the credit, lease, or permit, and any security for the credit, lease, or permit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a2d878-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s574/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enforce, adjust, and settle any right of the Government with respect to the credit, lease, or permit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80a2d879-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1107"},"text":"116 Stat. 1107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80a2d87a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80a2d87b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80a2d87c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"574(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:485(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title II, § 204(c)–(g), formerly § 204(b)–(f), "},{"tag":"html:a","attrib":{"href":"/us/stat/63/389"},"text":"63 Stat. 389","children":[],"tail":"; redesignated § 204(c)–(g), "},{"tag":"html:a","attrib":{"href":"/us/act/1954-08-31/ch1178/s1/a"},"text":"Aug. 31, 1954, ch. 1178, § 1(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/1051"},"text":"68 Stat. 1051","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/41/s3/d"},"text":"Pub. L. 96–41, § 3(d)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 30, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/325"},"text":"93 Stat. 325","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"574(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:485(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"574(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:485(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"574(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:485(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"574(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:485(g).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “in the Treasury” are substituted for “with the Treasurer of the United States” because of section 1 of Reorganization Plan No. 26 of 1950 (eff. ","children":[{"tag":"date","attrib":{"date":"1950-07-31"},"text":"July 31, 1950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1280"},"text":"64 Stat. 1280","children":[],"tail":"), restated as 31:321."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “or by War Assets Administration (or its predecessor agencies) under the Surplus Property Act of 1944” are omitted because the War Assets Administration was abolished and its functions were transferred to the General Services Administration by section 105 of the Federal Property and Administrative Services Act of 1949 (ch. 288, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/63/381"},"text":"63 Stat. 381","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id80a2d87d-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id80a2d87e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under subsec. (f) of section 485 of former Title 40, Public Buildings, Property, and Works (which was repealed and reenacted as subsec. (d) of this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", §§ 1, 6(b), "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":", 1304), delegated to Secretary of Defense, see section 3 of Ex. Ord. No. 12626, "},{"tag":"date","attrib":{"date":"1988-02-25"},"text":"Feb. 25, 1988","children":[],"tail":", 53 F.R. 6114, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98"},"text":"section 98 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
