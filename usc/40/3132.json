{"tag":"section","attrib":{"id":"id80b3a1b0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3132"},"text":null,"children":[{"tag":"num","attrib":{"value":"3132"},"text":"§ 3132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternatives to payment bonds provided by Federal Acquisition Regulation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80b3a1b1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Acquisition Regulation shall provide alternatives to payment bonds as payment protections for suppliers of labor and materials under contracts referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3131/a"},"text":"section 3131(a) of this title","children":[],"tail":" that are more than $25,000 and not more than $100,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b3a1b2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities of Contracting Officer","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The contracting officer for a contract shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b3a1b3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3132/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select, from among the payment protections provided for in the Federal Acquisition Regulation pursuant to subsection (a), one or more payment protections which the offeror awarded the contract is to submit to the Federal Government for the protection of suppliers of labor and materials for the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b3a1b4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3132/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify in the solicitation of offers for the contract the payment protections selected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b3a1b5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1148"},"text":"116 Stat. 1148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b3a1b6-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b3a1b7-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80b3a1b8-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":nu