{"tag":"section","attrib":{"id":"id80ea6962-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17502"},"text":null,"children":[{"tag":"num","attrib":{"value":"17502"},"text":"§ 17502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring system","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The head of each executive agency shall designate one office, officer, or employee of the agency—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ea6963-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17502/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish and operate a central monitoring system for the motor vehicle operations of the agency, related activities, and related reporting requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ea6964-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17502/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide oversight of those operations, activities, and requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ea6965-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1283"},"text":"116 Stat. 1283","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ea6966-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ea6967-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ea6968-3a70-11f