{"tag":"section","attrib":{"id":"id80ea6969-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17503"},"text":null,"children":[{"tag":"num","attrib":{"value":"17503"},"text":"§ 17503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80ea696a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost Identification and Analysis","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each executive agency shall develop a system to identify, collect, and analyze data with respect to all costs (including obligations and outlays) the agency incurs in the operation, maintenance, acquisition, and disposition of motor vehicles, including vehicles owned or leased by the Federal Government and privately owned vehicles used for official purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ea696b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Data Systems.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ea696c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In cooperation with the Comptroller General of the United States and the Director of the Office of Management and Budget, the Administrator of General Services shall prescribe requirements governing the establishment and operation by executive agencies of the systems required by subsection (a), including requirements with respect to data on the costs and uses of motor vehicles and with respect to the uniform collection and submission of the data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ea696d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conformity with principles and standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Requirements prescribed under this section shall conform to accounting principles and standards issued by the Comptroller General. Each executive agency shall comply with those requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ea696e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1284"},"text":"116 Stat. 1284","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ea696f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ea6970-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ea6971-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"17503","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:902.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/99/272/tXV/s15302"},"text":"Pub. L. 99–272, title XV, § 15302","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/335"},"text":"100 Stat. 335","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “including vehicles owned or leased by the Federal Government and privately owned vehicles” are substituted for “Government-owned vehicles, leased vehicles, and privately owned vehicles” for clarity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
