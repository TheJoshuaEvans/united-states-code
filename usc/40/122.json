{"tag":"section","attrib":{"id":"id808fc573-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s122"},"text":null,"children":[{"tag":"num","attrib":{"value":"122"},"text":"§ 122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on sex discrimination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id808fc574-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to a program or activity carried on or receiving federal assistance under this subtitle, an individual may not be excluded from participation, denied benefits, or otherwise discriminated against based on sex.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id808fc575-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall be enforced through agency provisions and rules similar to those already established with respect to racial and other discrimination under title VI of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d"},"text":"42 U.S.C. 2000d","children":[],"tail":" et seq.). However, this remedy is not exclusive and does not prejudice or remove any other legal remedies available to an individual alleging discrimination."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id808fc576-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1070"},"text":"116 Stat. 1070","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id808fc577-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id808fc578-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id808fc579-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"ht