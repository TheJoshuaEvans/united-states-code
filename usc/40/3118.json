{"tag":"section","attrib":{"id":"id80b3a196-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3118"},"text":null,"children":[{"tag":"num","attrib":{"value":"3118"},"text":"§ 3118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of taking as addition to existing rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The right to take possession and title in advance of final judgment in condemnation proceedings as provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3114"},"text":"section 3114 of this title","children":[],"tail":" is in addition to any right, power, or authority conferred by the laws of the United States or of a State, territory, or possession of the United States under which the proceeding may be conducted, and does not abrogate, limit, or modify that right, power, or authority."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id80b3a197-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1147"},"text":"116 Stat. 1147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b3a198-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b3a199-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80b3a19a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag