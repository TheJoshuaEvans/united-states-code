{"tag":"section","attrib":{"id":"id80e81f17-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702"},"text":null,"children":[{"tag":"num","attrib":{"value":"15702"},"text":"§ 15702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distressed counties and areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e81f18-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date of the enactment of this section, and annually thereafter, each Commission shall make the following designations:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81f19-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distressed counties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall designate as distressed counties those counties in its region that are the most severely and persistently economically distressed and underdeveloped and have high rates of poverty, unemployment, or outmigration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f1a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transitional counties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall designate as transitional counties those counties in its region that are economically distressed and underdeveloped or have recently suffered high rates of poverty, unemployment, or outmigration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f1b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attainment counties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall designate as attainment counties, those counties in its region that are not designated as distressed or transitional counties under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f1c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Isolated areas of distress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall designate as isolated areas of distress, areas located in counties designated as attainment counties under paragraph (3) that have high rates of poverty, unemployment, or outmigration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81f1d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Commission shall allocate at least 50 percent of the appropriations made available to the Commission to carry out this subtitle for programs and projects designed to serve the needs of distressed counties and isolated areas of distress in the region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81f1e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attainment Counties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81f1f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), funds may not be provided under this subtitle for a project located in a county designated as an attainment county under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f20-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e81f21-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative expenses of local development districts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The funding prohibition under paragraph (1) shall not apply to grants to fund the administrative expenses of local development districts under section 15505.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e81f22-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multicounty and other projects","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Commission may waive the application of the funding prohibition under paragraph (1) with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80e81f23-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multicounty project that includes participation by an attainment county; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e81f24-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other type of project, if a Commission determines that the project could bring significant benefits to areas of the region outside an attainment county.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f25-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (2) shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e81f26-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a county described in paragraph (2) or (3) of section 15735; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e81f27-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Southern New England Regional Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f28-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Isolated areas of distress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a designation of an isolated area of distress to be effective, the designation shall be supported—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e81f29-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the most recent Federal data available; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e81f2a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15702/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if no recent Federal data are available, by the most recent data available through the government of the State in which the isolated area of distress is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e81f2b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14217/a/2"},"text":"Pub. L. 110–234, title XIV, § 14217(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1479"},"text":"122 Stat. 1479","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14217(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2241; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII"},"text":"Pub. L. 118–272, div. B, title II","children":[],"tail":", §§ 2249(c), 2250(c), "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3209"},"text":"138 Stat. 3209","children":[],"tail":", 3210.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e81f2c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80e81f2d-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80e81f2e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id80e81f2f-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80e81f30-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2250/c"},"text":"Pub. L. 118–272, § 2250(c)","children":[],"tail":", inserted dash after “to” in introductory provisions and subpar. (A) designation before “a county”, substituted “; or” for period at end, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2249/c/2"},"text":"Pub. L. 118–272, § 2249(c)(2)","children":[],"tail":", added par. (3). Former par. (3) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2249/c/1"},"text":"Pub. L. 118–272, § 2249(c)(1)","children":[],"tail":", redesignated par. (3) as (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80e81f31-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id80e81f32-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s14217/d"},"text":"section 14217(d) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s15101"},"text":"section 15101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
