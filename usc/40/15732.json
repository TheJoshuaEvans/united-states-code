{"tag":"section","attrib":{"id":"id80e81f5f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15732"},"text":null,"children":[{"tag":"num","attrib":{"value":"15732"},"text":"§ 15732.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Southwest Border Regional Commission","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The region of the Southwest Border Regional Commission shall consist of the following political subdivisions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81f60-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15732/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Arizona","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The counties of Cochise, Gila, Graham, Greenlee, La Paz, Maricopa, Pima, Pinal, Santa Cruz, and Yuma in the State of Arizona.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f61-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15732/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"California","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The counties of Imperial, Los Angeles, Orange, Riverside, San Bernardino, San Diego, and Ventura in the State of California.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f62-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15732/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"New mexico","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The counties of Bernalillo, Catron, Chaves, Cibola, Curry, De Baca, Dona Ana, Eddy, Grant, Guadalupe, Hidalgo, Lea, Lincoln, Luna, Otero, Roosevelt, Sierra, Socorro, Torrance, and Valencia in the State of New Mexico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81f63-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15732/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Texas","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The counties of Atascosa, Bandera, Bee, Bexar, Brewster, Brooks, Cameron, Coke, Concho, Crane, Crockett, Culberson, Dimmit, Duval, Ector, Edwards, El Paso, Frio, Gillespie, Glasscock, Guadalupe, Hidalgo, Hudspeth, Irion, Jeff Davis, Jim Hogg, Jim Wells, Karnes, Kendall, Kenedy, Kerr, Kimble, Kinney, Kleberg, La Salle, Live Oak, Loving, Mason, Maverick, McMullen, Medina, Menard, Midland, Nueces, Pecos, Presidio, Reagan, Real, Reeves, San Patricio, Shleicher, Sutton, Starr, Sterling, Terrell, Tom Green, Upton, Uvalde, Val Verde, Ward, Webb, Willacy, Wilson, Winkler, Zapata, and Zavala in the State of Texas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e81f64-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14217/a/2"},"text":"Pub. L. 110–234, title XIV, § 14217(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1481"},"text":"122 Stat. 1481","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14217(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib