dren":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/50/480"},"text":"50 Stat. 480","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “On and after the effective date of the regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s721"},"text":"section 721 of this title","children":[],"tail":"” are omitted as obsolete. The words “the circumstances are such that” are omitted as unnecessary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
