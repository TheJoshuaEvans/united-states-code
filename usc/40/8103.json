"children":[{"tag":"html:span","attrib":{},"text":"8103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:101.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1892-07-29/ch320/s15"},"text":"July 29, 1892, ch. 320, § 15","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/27/325"},"text":"27 Stat. 325","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/90/108/s2"},"text":"Pub. L. 90–108, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 20, 1967","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/81/277"},"text":"81 Stat. 277","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “enclosure” is substituted for “inclosure” to use the more understood term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
