{"tag":"section","attrib":{"id":"id80c8fea3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8103"},"text":null,"children":[{"tag":"num","attrib":{"value":"8103"},"text":"§ 8103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of District of Columbia laws to public buildings and grounds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c8fea4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Laws and regulations of the District of Columbia for the protection of public or private property and the preservation of peace and order are extended to all public buildings and public grounds belonging to the Federal Government in the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c8fea5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person shall be fined under title 18, imprisoned for not more than six months, or both if the person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c8fea6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is guilty of disorderly and unlawful conduct in or about those public buildings or public grounds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c8fea7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully injures the buildings or shrubs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c8fea8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pull downs, impairs, or otherwise injures any fence, wall, or other enclosure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c8fea9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8103/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" injures any sink, culvert, pipe, hydrant, cistern, lamp, or bridge; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c8feaa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8103/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" removes any stone, gravel, sand, or other property of the Government, or any other part of the public grounds or lots belonging to the Government in the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c8feab-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1205"},"text":"116 Stat. 1205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c8feac-3a70-11f