ext":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80d75602-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Procurement of Automatic Data Processing Equipment for Tax Systems Modernization Program; Delegation of Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/52/tV/s526"},"text":"Pub. L. 104–52, title V, § 526","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-19"},"text":"Nov. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/495"},"text":"109 Stat. 495","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/52/tV/s526"},"text":"“Notwithstanding any other provision of law, the Administrator of General Services shall delegate the authority to procure automatic data processing equipment for the Tax Systems Modernization Program to the Secretary of the Treasury: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the Director of the Office of Management and Budget shall have the authority to revoke such delegation upon the written recommendation of the Administrator that the Secretary’s actions under such delegation are inconsistent with the goals of economic and efficient procurement and utilization of automatic data processing equipment: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That for all other purposes, a procurement conducted under such delegation shall be treated as if made under a delegation by the Administrator pursuant to [former] "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s759"},"text":"40 U.S.C. 759","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
