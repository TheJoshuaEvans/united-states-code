{"tag":"section","attrib":{"id":"id80e33d6a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526"},"text":null,"children":[{"tag":"num","attrib":{"value":"14526"},"text":"§ 14526.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distressed, at-risk, and economically strong counties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e33d6b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33d6c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Appalachian Regional Commission, in accordance with criteria the Commission may establish, each year shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e33d6d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate as “distressed counties” those counties in the Appalachian region that are the most severely and persistently distressed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e33d6e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate as “at-risk counties” those counties in the Appalachian region that are most at risk of becoming economically distressed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e33d6f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" designate two categories of economically strong counties, consisting of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80e33d70-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “competitive counties”, which shall be those counties in the region that are approaching economic parity with the rest of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e33d71-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “attainment counties”, which shall be those counties in the region that have attained or exceeded economic parity with the rest of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d72-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual review of designations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e33d73-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an annual review of each designation of a county under paragraph (1) to determine if the county still meets the criteria for the designation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e33d74-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renew the designation for another one-year period only if the county still meets the criteria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d75-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distressed Counties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In program and project development and implementation and in the allocation of appropriations made available to carry out this subtitle, the Commission shall give special consideration to the needs of counties for which a distressed county designation is in effect under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d76-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Economically Strong Counties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33d77-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Competitive counties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraphs (3) and (4), assistance under this subtitle for a project that is carried out in a county for which a competitive county designation is in effect under this section shall not be more than 30 percent of the project cost.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d78-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attainment counties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraphs (3) and (4), amounts may not be provided under this subtitle for a project that is carried out in a county for which an attainment county designation is in effect under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d79-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraphs (1) and (2) do not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e33d7a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project on the Appalachian development highway system authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14501"},"text":"section 14501 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e33d7b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local development district administrative project assisted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14321/a/1/A"},"text":"section 14321(a)(1)(A) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e33d7c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a multicounty project that is carried out in at least two counties designated under this section if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80e33d7d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one of the participating counties is designated as a distressed county under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e33d7e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project will be of substantial direct benefit to at least one distressed county.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d7f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e33d80-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may waive the requirements of paragraphs (1) and (2) for a project when the recipient of assistance for the project shows the existence of any of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80e33d81-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a significant pocket of distress in the part of the county in which the project is carried out.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e33d82-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a significant potential benefit from the project in at least one area of the region outside the designated county.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e33d83-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14526/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives an annual report describing each waiver granted under subparagraph (A) during the period covered by the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e33d84-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1277"},"text":"116 Stat. 1277","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/371/s4/a"},"text":"Pub. L. 110–371, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4041"},"text":"122 Stat. 4041","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e33d85-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80e33d86-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80e33d87-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14526","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:226.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/4/tII/s226"},"text":"Pub. L. 89–4, title II, § 226","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/105/393/tII/s219"},"text":"Pub. L. 105–393, title II, § 219","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/3623"},"text":"112 Stat. 3623","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before clause (A), the words “Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1988-11-13"},"text":"November 13, 1988","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80e33d88-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80e33d89-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/371/s4/a/1"},"text":"Pub. L. 110–371, § 4(a)(1)","children":[],"tail":", inserted “, at-risk,” after “Distressed” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/371/s4/a/2"},"text":"Pub. L. 110–371, § 4(a)(2)","children":[],"tail":", added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
