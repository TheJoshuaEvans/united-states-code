{"tag":"section","attrib":{"id":"id80b130bf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1310"},"text":null,"children":[{"tag":"num","attrib":{"value":"1310"},"text":"§ 1310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of war supplies, land, and buildings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80b130c0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President, through the head of any executive department and on terms the head of the department considers expedient, may sell to a person, another department of the Federal Government, or the government of a foreign country engaged in war against a country with which the United States is at war—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b130c1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1310/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" war supplies, material, and equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b130c2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1310/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by-products of the war supplies, material, and equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b130c3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1310/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any building, plant, or factory, including the land on which the plant or factory may be situated, acquired since ","children":[{"tag":"date","attrib":{"date":"1917-04-06"},"text":"April 6, 1917","children":[],"tail":", for the production of war supplies, materials, and equipment that, during the emergency existing on "},{"tag":"date","attrib":{"date":"1918-07-09"},"text":"July 9, 1918","children":[],"tail":", may have been purchased, acquired, or manufactured by the Government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b130c4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Sale of Guns and Ammunition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sales of guns and ammunition authorized under any law shall be limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b130c5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1310/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other departments of the Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b130c6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1310/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" governments of foreign countries engaged in war against a country with which the United States is at war; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b130c7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1310/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the National Rifle Association and of other recognized associations organized in the United States for the encouragement of small-arms target practice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b130c8-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1137"},"text":"116 Stat. 1137","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b130c9-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b130ca-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80b130cb-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1310","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:314.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1918-07-09/ch143"},"text":"July 9, 1918, ch. 143","children":[],"tail":" (last par. on p. 850), "},{"tag":"html:a","attrib":{"href":"/us/stat/40/850"},"text":"40 Stat. 850","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1919-02-25/ch39/s3"},"text":"Feb. 25, 1919, ch. 39, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/40/1173"},"text":"40 Stat. 1173","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1928-05-29/ch901/s1/8"},"text":"May 29, 1928, ch. 901, § 1(8)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/45/986"},"text":"45 Stat. 986","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1946-08-07/ch770"},"text":"Aug. 7, 1946, ch. 770","children":[],"tail":", (55), "},{"tag":"html:a","attrib":{"href":"/us/stat/60/870"},"text":"60 Stat. 870","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “government of a foreign country” are substituted for “foreign State or Government”, and the words “against a country” are substituted for “against any Government”, for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “partnership, association” are omitted because of the definition of person in 1:1.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “in this section or . . . other” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
