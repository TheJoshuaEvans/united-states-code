{"tag":"section","attrib":{"id":"id80b130e7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314"},"text":null,"children":[{"tag":"num","attrib":{"value":"1314"},"text":"§ 1314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Easements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80b130e8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b130e9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “executive agency” means an executive department or independent establishment in the executive branch of the Federal Government, including a wholly owned Government corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b130ea-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Real property of the government","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “real property of the Government” excludes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80b130eb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" public land (including minerals, vegetative, and other resources) in the United States, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80b130ec-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land reserved or dedicated for national forest purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b130ed-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land the Secretary of the Interior administers or supervises in accordance with section 100101(a), chapter 1003, and sections 100751(a), 100752, 100753, and 102101 of title 54;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b130ee-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian-owned trust and restricted land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b130ef-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land the Government acquires primarily for fish and wildlife conservation purposes and the Secretary administers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b130f0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land withdrawn from the public domain primarily under the jurisdiction of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b130f1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land acquired for national forest purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b130f2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” means a State of the United States, the District of Columbia, Puerto Rico, and the territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b130f3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant of Easement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When a State, a political subdivision or agency of a State, or a person applies for the grant of an easement in, over, or on real property of the Government, the executive agency having control of the real property may grant to the applicant, on behalf of the Government, an easement that the head of the agency decides will not be adverse to the interests of the Government, subject to reservations, exceptions, limitations, benefits, burdens, terms, or conditions that the head of the agency considers necessary to protect the interests of the Government. The grant may be made without consideration, or with monetary or other consideration, including an interest in real property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b130f4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relinquishment of Legislative Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In connection with the grant of an easement, the executive agency concerned may relinquish to the State in which the real property is located legislative jurisdiction that the executive agency considers necessary or desirable. Relinquishment of legislative jurisdiction may be accomplished by filing with the chief executive officer of the State a notice of relinquishment to take effect upon acceptance or by proceeding in the manner that the laws applicable to the State may provide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b130f5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Easement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b130f6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When termination occurs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The instrument granting the easement may provide for termination of any part of the easement if there has been—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80b130f7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a failure to comply with a term or condition of the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b130f8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonuse of the easement for a consecutive 2-year period for the purpose for which granted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b130f9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an abandonment of the easement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b130fa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a termination provision is included, it shall require that written notice of the termination be given to the grantee, or its successors or assigns.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b130fb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The termination is effective as of the date of the notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b130fc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Easement Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority conferred by this section is in addition to, and shall not affect or be subject to, any other law under which an executive agency may grant easements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b130fd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1314/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Issuance of Rights of Way","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Rights of way over, under, and through public lands and lands in the National Forest System may not be granted under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b130fe-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1139"},"text":"116 Stat. 1139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s5/j/4"},"text":"Pub. L. 113–287, § 5(j)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3269"},"text":"128 Stat. 3269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b130ff-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b13100-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80b13101-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":