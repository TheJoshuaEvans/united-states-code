n":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1314(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:319a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1314(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:319b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1314(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:319 note, 319a note, 319b note, 319c note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/94/579/tVII/s706/a"},"text":"Pub. L. 94–579, title VII, § 706(a)","children":[],"tail":" (related to the Act of "},{"tag":"html:span","attrib":{},"text":"Oct. 23, 1962","children":[],"tail":" (Pub. L. 87—852, "},{"tag":"html:a","attrib":{"href":"/us/stat/76/1129"},"text":"76 Stat. 1129","children":[],"tail":")), "},{"tag":"html:span","attrib":{},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/2793"},"text":"90 Stat. 2793","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the text of 40:319c(c) is omitted because of 1:1. In clause (3), the words “territories and” are added for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “for a right-of-way or other purpose” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “affected” and “concerned” before “a notice” are omitted as unnecessary. The words “chief executive officer” are substituted for “Governor” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80b13102-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80b13103-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":" substituted “section 100101(a), chapter 1003, and sections 100751(a), 100752, 100753, and 102101 of title 54” for “the Act of "},{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":", 2, 3, 4) (known as the National Park Service Organic Act)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
