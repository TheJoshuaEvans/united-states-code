{"tag":"section","attrib":{"id":"id80dc1163-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14302"},"text":null,"children":[{"tag":"num","attrib":{"value":"14302"},"text":"§ 14302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80dc1164-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Approval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14306/d"},"text":"section 14306(d) of this title","children":[],"tail":", decisions by the Appalachian Regional Commission require the affirmative vote of the Federal Cochairman and of a majority of the state members, exclusive of members representing States delinquent under section 14306(d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc1165-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In matters coming before the Commission, the Federal Cochairman, to the extent practicable, shall consult with the federal departments and agencies having an interest in the subject matter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc1166-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Decisions Requiring Quorum of State Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A decision involving Commission policy, approval of state, regional or subregional development plans or strategy statements, modification or revision of the Appalachian Regional Commission Code, allocation of amounts among the States, or designation of a distressed county or an economically strong county shall not be made without a quorum of state members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc1167-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project and Grant Proposals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The approval of project and grant proposals is a responsibility of the Commission and shall be carried out in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14322"},"text":"section 14322 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80dc1168-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1257"},"text":"116 Stat. 1257","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80dc1169-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80dc116a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80dc116b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n",