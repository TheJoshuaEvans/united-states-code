{"tag":"section","attrib":{"id":"id80dc11dd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321"},"text":null,"children":[{"tag":"num","attrib":{"value":"14321"},"text":"§ 14321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and other assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80dc11de-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization To Make Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80dc11df-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Appalachian Regional Commission may make grants—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80dc11e0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for administrative expenses, including the development of areawide plans or action programs and technical assistance activities, of local development districts, but—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80dc11e1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the amount of the grant shall not exceed—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id80dc11e2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of administrative expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id80dc11e3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the discretion of the Commission, if the grant is to a local development district that has a charter or authority that includes the economic development of a county or a part of a county for which a distressed county designation is in effect under section 14526, 75 percent of administrative expenses; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id80dc11e4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/1/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the discretion of the Commission, if the grant is to a local development district that has a charter or authority that includes the economic development of a county or a part of a county for which an at-risk county designation is in effect under section 14526, 70 percent of administrative expenses;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80dc11e5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants for administrative expenses shall not be made for a state agency certified as a local development district for a period of more than three years beginning on the date the initial grant is made for the development district; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80dc11e6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local development district contributions for administrative expenses may be in cash or in kind, fairly evaluated, including space, equipment, and services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc11e7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for assistance to States for a period of not more than two years to strengthen the state development planning process for the Appalachian region and the coordination of state planning under this subtitle, the Public Works and Economic Development Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"42 U.S.C. 3121","children":[],"tail":" et seq.), and other federal and state programs; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc11e8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for investigation, research, studies, evaluations, and assessments of needs, potentials, or attainments of the people of the region, technical assistance, training programs, demonstrations, and the construction of necessary facilities incident to those activities, which will further the purposes of this subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc11e9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on available amounts.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80dc11ea-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), of the cost of any activity eligible for financial assistance under this section, not more than—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80dc11eb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent may be provided from amounts appropriated to carry out this subtitle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80dc11ec-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which a distressed county designation is in effect under section 14526, 80 percent may be provided from amounts appropriated to carry out this subtitle; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80dc11ed-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which an at-risk county designation is in effect under section 14526, 70 percent may be provided from amounts appropriated to carry out this subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc11ee-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discretionary grants.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id80dc11ef-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants to which percentage limitation doesn’t apply","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Discretionary grants made by the Commission to implement significant regional initiatives, to take advantage of special development opportunities, or to respond to emergency economic distress in the region may be made without regard to the percentage limitations specified in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80de81f0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on aggregate amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each fiscal year, the aggregate amount of discretionary grants referred to in clause (i) shall not be more than 10 percent of the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14703"},"text":"section 14703 of this title","children":[],"tail":" for the fiscal year, except that a discretionary grant to respond to economic distress directly related to the impacts of the Coronavirus Disease 2019 (COVID–19) shall not be included in such aggregate amount."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80de81f1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources of grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Grant amounts may be provided entirely from appropriations to carry out this section, in combination with amounts available under other federal or federal grant programs, or from any other source.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80de81f2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any law limiting the federal share in any other federal or federal grant program, amounts appropriated to carry out this section may be used to increase that federal share, as the Commission decides is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80de81f3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance for Demonstrations of Enterprise Development.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80de81f4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may provide assistance under this section for demonstrations of enterprise development, including site acquisition or development where necessary for the feasibility of the project, in connection with the development of the region’s energy resources and the development and stimulation of indigenous arts and crafts of the region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80de81f5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation by federal agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the purposes of this subtitle and in implementing this section, the Secretary of Energy, the Environmental Protection Agency, and other federal agencies shall cooperate with the Commission and shall provide assistance that the Federal Cochairman may request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80de81f6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Available amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any fiscal year, not more than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80de81f7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000,000 shall be obligated for energy resource related demonstrations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80de81f8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,500,000 shall be obligated for indigenous arts and crafts demonstrations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80de81f9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80de81fa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission, as required by the President, shall maintain accurate and complete records of transactions and activities financed with federal amounts and report to the President on the transactions and activities. The records of the Commission with respect to grants are available for audit by the President and the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80de81fb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14321/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recipients of federal assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Recipients of federal assistance under this section, as required by the Commission, shall maintain accurate and complete records of transactions and activities financed with federal amounts and report to the Commission on the transactions and activities. The records are be ","children":[{"tag":"ref","attrib":{"idref":"fn002035"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002035"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “to”."}],"tail":" available for audit by the President, the Comptroller General, and the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80de81fc-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1262"},"text":"116 Stat. 1262","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/371/s2/a"},"text":"Pub. L. 110–371, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4037"},"text":"122 Stat. 4037","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dB/tIV/s14004"},"text":"Pub. L. 116–136, div. B, title IV, § 14004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/526"},"text":"134 Stat. 526","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80de81fd-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80de81fe-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80de81ff-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n"