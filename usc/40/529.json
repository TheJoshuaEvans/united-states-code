{"tag":"section","attrib":{"id":"id8099635b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s529"},"text":null,"children":[{"tag":"num","attrib":{"value":"529"},"text":"§ 529.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual executive agency reports on excess personal property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8099635c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s529/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the calendar quarter following the close of each fiscal year, each executive agency shall submit to the Administrator of General Services and the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Oversight and Accountability of the House of Representatives a report on personal property—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8099635d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s529/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" obtained as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8099635e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s529/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" excess property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8099635f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s529/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal property determined to be no longer required for the purpose of the appropriation used to make the purchase; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80996360-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s529/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnished within the United States to a recipient other than a federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80996361-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s529/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report must set out the categories of equipment and show—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80996362-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s529/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition cost of the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80996363-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s529/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient of the property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80996364-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s529/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other information the Administrator may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80996365-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s529/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compilation of Data","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days following the close of a fiscal year, the Administrator shall compile the data in the reports submitted under subsection (a) and submit to the Committee on Homeland Security ","children":[{"tag":"ref","attrib":{"idref":"fn002008"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002008"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “and” probably should appear."}],"tail":" Governmental Affairs of the Senate and the Committee on Oversight and Accountability of the House of Representatives and publish on a centralized online website a publicly available report, which shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80996366-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s529/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the complete data provided in each report in a user-friendly format;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80996367-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s529/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the findings of each report, including the aggregate dollar amount of personal property determined to be no longer required for the purpose of the appropriation used to make the purchase; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80996368-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s529/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other recommendations from the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80996369-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1086"},"text":"116 Stat. 1086","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/99/s2/a/1"},"text":"Pub. L. 118–99, § 2(a)(1)","children":[],"tail":", (e)(1), "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1578"},"text":"138 Stat. 1578","children":[],"tail":", 1579.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8099636a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id8099636b-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/99/s2/e/1"},"text":"Pub. L. 118–99, § 2(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1579"},"text":"138 Stat. 1579","children":[],"tail":", provided that, effective on the date that is 5 years after "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", this section is amended:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) in subsection (a), in the matter preceding paragraph (1), by striking “and the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Oversight and Accountability of the House of Representatives”; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) by striking subsection (c).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See 2024 Amendment notes below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id8099636c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id8099636d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"529","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:483(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title II, § 202(e), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/94/519/s3"},"text":"Pub. L. 94–519, § 3","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/2454"},"text":"90 Stat. 2454","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “in any manner whatsoever” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “set out the categories of equipment” are substituted for “showing . . . categories of equipment” to clarify the required form and content of the report. The words “The Administrator shall submit a report to the Senate (or to the Secretary of the Senate if the Senate is not in session) and to the House of Representatives (or to the Clerk of the House if the House is not in session) summarizing and analyzing the reports of the executive agencies” are omitted pursuant to section 3003 of the Federal Reports Elimination and Sunset Act of 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"31 U.S.C. 1113","children":[],"tail":" note). See, also, page 173 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8099636e-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8099636f-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/99/s2/e/1/A"},"text":"Pub. L. 118–99, § 2(e)(1)(A)","children":[],"tail":", struck out “and the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Oversight and Accountability of the House of Representatives” after “Administrator of General Services” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/99/s2/a/1/A"},"text":"Pub. L. 118–99, § 2(a)(1)(A)","children":[],"tail":", inserted “and the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Oversight and Accountability of the House of Representatives” after “Administrator of General Services” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/99/s2/e/1/B"},"text":"Pub. L. 118–99, § 2(e)(1)(B)","children":[],"tail":", struck out subsec. (c) which related to compilation of data in the reports submitted under subsection (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/99/s2/a/1/B"},"text":"Pub. L. 118–99, § 2(a)(1)(B)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80996370-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id80996371-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/99/s2/e"},"text":"Pub. L. 118–99, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1579"},"text":"138 Stat. 1579","children":[],"tail":", provided that the amendment made by section 2(e)(1) is effective on the date that is 5 years after "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
