ail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8711(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:74.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1924-06-06/ch270/s13"},"text":"June 6, 1924, ch. 270, § 13","children":[],"tail":", formerly § 4, "},{"tag":"html:a","attrib":{"href":"/us/stat/43/464"},"text":"43 Stat. 464","children":[],"tail":"; renumbered § 13, "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-19/ch949/s2"},"text":"July 19, 1952, ch. 949, § 2","children":[],"tail":" (1st sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/791"},"text":"66 Stat. 791","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/94/273/s21"},"text":"Pub. L. 94–273, § 21","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/379"},"text":"90 Stat. 379","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8711(h)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:71a note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/105/83"},"text":"Pub. L. 105–83","children":[],"tail":", (last proviso in par. under heading “National Capital Planning Commission”), "},{"tag":"html:span","attrib":{},"text":"Nov. 14, 1997","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/111/1589"},"text":"111 Stat. 1589","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this chapter, the word “Mayor” is substituted for “Commissioners” [meaning the Board of Commissioners of the District of Columbia] [subsequently changed to “Commissioner” [meaning the Commissioner of the District of Columbia] because of section 401 of Reorganization Plan No. 3 of 1967 (eff. ","children":[{"tag":"date","attrib":{"date":"1967-11-03"},"text":"Nov. 3, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/951"},"text":"81 Stat. 951","children":[],"tail":")] because of section 421 of the District of Columbia Home Rule Act ("},{"tag":"ref","attrib":{"href":"/us/pl/93/198"},"text":"Public Law 93–198","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/789"},"text":"87 Stat. 789","children":[],"tail":"). The words “Council of the District of Columbia” are substituted for “Board of Commissioners of the District of Columbia” [subsequently changed to “District of Columbia Council” because of section 402(21), (28), (32), and (199) of Reorganization Plan No. 3 of 1967 (eff. "},{"tag":"date","attrib":{"date":"1967-11-03"},"text":"Nov. 3, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/952"},"text":"81 Stat. 952","children":[],"tail":", 953, 963)] because of sections 401 and 404(a) of the Act ("},{"tag":"ref","attrib":{"href":"/us/stat/87/785"},"text":"87 Stat. 785","children":[],"tail":", 787)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1)(A), the words “the Chairman of the Committee on Governmental Affairs of the Senate, and the Chairman of the Committee on Government Reform of the House of Representatives” are substituted for “and the chairman of the Committees of the District of Columbia of the Senate and the House of Representatives” in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-06-24/s2/b/1"},"text":"section 2(b)(1) of the Act of June 24, 1924","children":[],"tail":" (ch. 270), because of Rule XXV of the Standing Rules of the Senate, as amended by Senate Resolution 4 (popularly cited as the “Committee System Reorganization Amendments of 1977”), approved "},{"tag":"date","attrib":{"date":"1977-02-04"},"text":"February 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/act/1995-06-03/s1/b/1"},"text":"section 1(b)(1) of the Act of June 3, 1995","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/104/14"},"text":"Public Law 104–14","children":[],"tail":", 2:21 note prec.), and Rule X(1)(h) of House Resolution No. 5 (105th Congress, "},{"tag":"date","attrib":{"date":"1999-01-06"},"text":"January 6, 1999","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “bona fide” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the words “except that of the members first appointed, the President shall designate one to serve two years and one to serve four years” and “The members first appointed under this section shall assume their office on ","children":[{"tag":"date","attrib":{"date":"1975-01-02"},"text":"January 2, 1975","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(4), the words “are entitled to $100 a day when performing duties” are substituted for “shall each receive compensation at the rate of $100 for each day such member is engaged in the actual performance of duties” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “chapters 33 and 51, and subchapter III of chapter 53” are substituted for “the civil service and classification laws” because of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1966-09-06/s7/b"},"text":"section 7(b) of the Act of September 6, 1966","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Public Law 89–554","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":"), the first section of which enacted Title 5, United States Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), before clause (1), the words “As hereinafter more specifically described in sections 71c to 71g of this title” are omitted as unnecessary. The text of 40:71a(e)(3) is omitted as obsolete because the National Capital Regional Planning Council was abolished by section 1 of Reorganization Plan No. 5 of 1966 (eff. ","children":[{"tag":"date","attrib":{"date":"1966-09-08"},"text":"Sept. 8, 1966","children":[],"tail":", 40:71b note). In clause (2), the words “in such capacity” are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (f) is substituted for 40:71h to eliminate obsolete language.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g), the words “Said Commission shall report to Congress annually on the first Monday of March the lands acquired during the preceding fiscal year, the method of acquisition, and the cost of each tract” are omitted pursuant to section 3003 of the Federal Reports Elimination and Sunset Act of 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"31 U.S.C. 1113","children":[],"tail":" note). See, also, page 180 of House Document No. 103–7. The words “Office of Management and Budget” are substituted for “Bureau of the Budget” in "},{"tag":"ref","attrib":{"href":"/us/act/1924-06-06/s13"},"text":"section 13 of the Act of June 6, 1924","children":[],"tail":", because the Bureau of the Budget was redesignated the Office of Management and Budget by section 102 of Reorganization Plan No. 2 of 1970 (eff. "},{"tag":"date","attrib":{"date":"1970-07-01"},"text":"July 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2085"},"text":"84 Stat. 2085","children":[],"tail":"). Section 102 of Reorganization Plan No. 2 of 1970 was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1982-09-13/s5/b"},"text":"section 5(b) of the Act of September 13, 1982","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Public Law 97–258","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1085"},"text":"96 Stat. 1085","children":[],"tail":"), the first section of which enacted Title 31, United States Code, but the successor provision, 31:501, continued the designation as Office of Management and Budget."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (h), the words “beginning in fiscal year 1998 and thereafter” are omitted as obsolete.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80cb6fb9-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80cb6fba-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1893-03-02"},"text":"March 2, 1893","children":[],"tail":", referred to in subsec. (f), is "},{"tag":"ref","attrib":{"href":"/us/act/1893-03-02/ch197"},"text":"act Mar. 2, 1893, ch. 197","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/532"},"text":"27 Stat. 532","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1924-06-06"},"text":"June 6, 1924","children":[],"tail":", referred to in subsec. (f), is "},{"tag":"ref","attrib":{"href":"/us/act/1924-06-06/ch270"},"text":"act June 6, 1924, ch. 270","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/463"},"text":"43 Stat. 463","children":[],"tail":", which enacted sections 71 to 71i, 72, 73, and 74 of former Title 40, Public Buildings, Property, and Works. Sections 71, 71a, 71c, 71d, 71f to 71i, 72, 73, and 74 of former Title 40 were repealed and reenacted as sections 8701, 8702, 8711, 8721 to 8724, 8731, and 8737 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", §§ 1, 6(b), "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":", 1304. Section 71b of former Title 40 was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":". Section 71e of former Title 40 was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/93/198/tII/s203/e"},"text":"Pub. L. 93–198, title II, § 203(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-24"},"text":"Dec. 24, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/782"},"text":"87 Stat. 782","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80cb6fbb-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":", which directed substitution of “section 6101(b) to (d) of title 41” for “section 3709 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"41 U.S.C. 5","children":[],"tail":")”, was executed by making the substitution for “section 3709 of the Revised Statues ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"41 U.S.C. 5","children":[],"tail":")” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284"},"text":"Pub. L. 109–284","children":[],"tail":" inserted “of this title” after “sections 5101 and 5102”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80cb6fbc-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id80cb6fbd-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Government Reform of House of Representatives changed to Committee on Oversight and Government Reform of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":". Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Governmental Affairs of Senate changed to Committee on Homeland Security and Governmental Affairs of Senate, effective ","children":[{"tag":"date","attrib":{"date":"2005-01-04"},"text":"Jan. 4, 2005","children":[],"tail":", by Senate Resolution No. 445, One Hundred Eighth Congress, "},{"tag":"date","attrib":{"date":"2004-10-09"},"text":"Oct. 9, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80cb6fbe-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Compensation of Appointed Commission Members","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/108/tII"},"text":"Pub. L. 108–108, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-10"},"text":"Nov. 10, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1301"},"text":"117 Stat. 1301","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/108/tII"},"text":"“That for fiscal year 2004 and thereafter, all appointed members of the Commission will be compensated at a rate not to exceed the daily equivalent of the annual rate of pay for positions at level IV of the Executive Schedule for each day such member is engaged in the actual performance of duties.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tII"},"text":"Pub. L. 108–7, div. F, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/269"},"text":"117 Stat. 269","childr