{"tag":"section","attrib":{"id":"id80cb6fa4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8711"},"text":null,"children":[{"tag":"num","attrib":{"value":"8711"},"text":"§ 8711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Capital Planning Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80cb6fa5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8711/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Capital Planning Commission is the central federal planning agency for the Federal Government in the National Capital, created to preserve the important historical and natural features of the National Capital, except for the United States Capitol Buildings and Grounds (as defined and described in sections 5101 and 5102 of this title), any extension of, or additions to, those Buildings and Grounds, and buildings and grounds under the care of the Architect of the Capitol.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80cb6fa6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8711/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80cb6fa7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8711/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Capital Planning Commission is composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80cb6fa8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8711/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ex officio, the Secretary of the Interior, the Secretary of Defense, the Administrator of General Services, the Mayor of the District of Columbia, the Chairman of the Council of the District of Columbia, the chairman of the Committee on Governmental Affairs of the Senate, and the chairman of the Committee on Government Reform of the House of Representatives, or an alternate any of those individuals designates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80cb6fa9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8711/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" five citizens with experience in city or regional planning, three of whom shall be appointed by the President and two of whom shall be appointed by the Mayor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cb6faa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8711/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Residency requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The citizen members appointed by the Mayor shall be residents of the District of Columbia. Of the three appointed by the President, at least one shall be a resident of Virginia and at least one shall be a resident of Maryland.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cb6fab-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8711/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual appointed by the President serves for six years. An individual appointed by the Mayor serves for four years. An individual appointed to fill a vacancy shall be appointed only for the unexpired term of the individual being replaced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cb6fac-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8711/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pay and expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Citizen members are entitled to $100 a day when performing duties vested in the Commission and to reimbursement for necessary expenses incurred in performing those duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80cb6fad-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8711/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairman and Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall designate the Chairman of the National Capital Planning Commission. The Commission may elect from among its members other officers as it considers desirable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80cb6fae-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8711/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Capital Planning Commission may employ a Director, an executive officer, and other technical and administrative personnel as it considers necessary. Without regard to section 6101(b) to (d) of title 41 and section 3109, chapters 33 and 51, and subchapter III of chapter 53, of title 5, the Commission may employ, by contract or otherwise, the temporary or intermittent (not more than one year) services of city planners, architects, engineers, appraisers, and other experts or organizations of experts, as may be necessary to carry out its functions. The Commission shall fix the rate of compensation so as not to exceed the rate usual for similar services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80cb6faf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8711/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Principal Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The principal duties of the National Capital Planning Commission include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80cb6fb0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8711/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparing, adopting, and amending a comprehensive plan for the federal activities in the National Capital and making related recommendations to the appropriate developmental agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cb6fb1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8711/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving as the central planning agency for the Government within the National Capital region and reviewing the development programs of the developmental agencies to advise as to consistency with the comprehensive plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80cb6fb2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8711/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Other Functions, Powers, and Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Capital Planning Commission shall carry out all other functions, powers, and duties of the National Capital Park and Planning Commission, including those formerly vested in the Highway Commission established by the Act of ","children":[{"tag":"date","attrib":{"date":"1893-03-02"},"text":"March 2, 1893","children":[],"tail":" (ch. 197, "},{"tag":"ref","attrib":{"href":"/us/stat/27/532"},"text":"27 Stat. 532","children":[],"tail":"), and those formerly vested in the National Capital Park Commission by the Act of "},{"tag":"date","attrib":{"date":"1924-06-06"},"text":"June 6, 1924","children":[],"tail":" (ch. 270, "},{"tag":"ref","attrib":{"href":"/us/stat/43/463"},"text":"43 Stat. 463","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80cb6fb3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8711/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Estimate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Capital Planning Commission shall submit to the Office of Management and Budget before December 16 of each year its estimate of the total amount to be appropriated for expenditure under this chapter (except sections 8732–8736) during the next fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80cb6fb4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8711/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Capital Planning Commission may charge fees to cover the full cost of Geographic Information System products and services the Commission supplies. The fees shall be credited to the applicable appropriation account as an offsetting collection and remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80cb6fb5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1217"},"text":"116 Stat. 1217","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s6/27"},"text":"Pub. L. 109–284, § 6(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1213"},"text":"120 Stat. 1213","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5"},"text":"Pub. L. 111–350, § 5","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(23), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3852"},"text":"124 Stat. 3852","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80cb6fb6-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80cb6fb7-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80cb6fb8-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":