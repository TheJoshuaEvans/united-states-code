{"tag":"section","attrib":{"id":"id80c1f9be-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6136"},"text":null,"children":[{"tag":"num","attrib":{"value":"6136"},"text":"§ 6136.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of prohibitions against use of Supreme Court grounds","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To allow the observance of authorized ceremonies in the Supreme Court Building and grounds, the Marshal of the Supreme Court may suspend for those occasions any of the prohibitions contained in this subchapter as may be necessary for the occasion if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c1f9bf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6136/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responsible officers have been appointed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c1f9c0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6136/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Marshal determines that adequate arrangements have been made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80c1f9c1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6136/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain suitable order and decorum in the proceedings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c1f9c2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6136/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect the Supreme Court Building and grounds and individuals and property in the Building and grounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c1f9c3-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1183"},"text":"116 Stat. 1183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c1f9c4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c1f9c5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c1f9c6-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","att