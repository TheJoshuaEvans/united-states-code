{"tag":"section","attrib":{"id":"id80e5ae80-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15308"},"text":null,"children":[{"tag":"num","attrib":{"value":"15308"},"text":"§ 15308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds among Federal agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e5ae81-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (c), for purposes of this subtitle, each Commission may transfer funds to and accept transfers of funds from other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5ae82-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Funds to Other Federal Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds made available to a Commission may be transferred to other Federal agencies if the funds are used consistently with the purposes for which the funds were specifically authorized and appropriated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5ae83-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15308/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Funds From Other Federal Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds may be transferred to any Commission under this section if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5ae84-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15308/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statutory authority for the funds provided by the Federal agency does not expressly prohibit use of funds for authorities being carried out by a Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae85-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15308/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal agency that provides the funds determines that the activities for which the funds are to be used are otherwise eligible for funding under such a statutory authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e5ae86-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2243/a/2"},"text":"Pub. L. 118–272, div. B, title II, § 2243(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3203"},"text":"138 Stat. 3203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e5ae87-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80e5ae88-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id80e5ae89-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 15308 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s15309"},"text":"section 15309 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
