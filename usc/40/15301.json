{"tag":"section","attrib":{"id":"id80e5ade8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301"},"text":null,"children":[{"tag":"num","attrib":{"value":"15301"},"text":"§ 15301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment, membership, and employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e5ade9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are established the following regional Commissions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5adea-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Southeast Crescent Regional Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5adeb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Southwest Border Regional Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5adec-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Northern Border Regional Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5aded-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Great Lakes Authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5adee-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Mid-Atlantic Regional Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5adef-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Southern New England Regional Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5adf0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5adf1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal and state members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Commission shall be composed of the following members:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e5adf2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Federal Cochairperson, to be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e5adf3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Governor of each participating State in the region of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5adf4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternate members.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e5adf5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternate federal cochairperson","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall appoint an alternate Federal Cochairperson for each Commission. The alternate Federal Cochairperson, when not actively serving as an alternate for the Federal Cochairperson, shall perform such functions and duties as are delegated by the Federal Cochairperson.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e5adf6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State alternates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The State member of a participating State may have a single alternate, who shall be appointed by the Governor of the State from among the members of the Governor’s cabinet or personal staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e5adf7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voting.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id80e5adf8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An alternate member shall vote in the case of the absence, death, disability, removal, or resignation of the Federal or State member for which the alternate member is an alternate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e5adf9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State alternates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the alternate State member is unable to vote in accordance with clause (i), the alternate State member may delegate voting authority to a designee, subject to the condition that the executive director shall be notified, in writing, of the designation not less than 1 week before the applicable vote is to take place.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5adfa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cochairpersons","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Commission shall be headed by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e5adfb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Cochairperson, who shall serve as a liaison between the Federal Government and the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e5adfc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State Cochairperson, who shall be a Governor of a participating State in the region and shall be elected by the State members for a term of not less than 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5adfd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consecutive terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State member may not be elected to serve as State Cochairperson for more than 2 consecutive terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5adfe-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5adff-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal cochairpersons","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Federal Cochairperson shall be compensated by the Federal Government at level III of the Executive Schedule as set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae00-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternate federal cochairpersons","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Federal Cochairperson’s alternate shall be compensated by the Federal Government at level V of the Executive Schedule as set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae01-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State members and alternates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each State member and alternate shall be compensated by the State that they represent at the rate established by the laws of that State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5ae02-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive Director and Staff.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e5ae03-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Commission shall appoint and fix the compensation of an executive director and such other personnel as are necessary to enable the Commission to carry out its duties. Compensation under this paragraph may not exceed the maximum rate of basic pay established for the Senior Executive Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of title 5","children":[],"tail":", including any applicable locality-based comparability payment that may be authorized under section 5304(h)(2)(C) of that title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e5ae04-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The executive director shall be responsible for carrying out the administrative duties of the Commission, directing the Commission staff, and such other duties as the Commission may assign.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5ae05-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Federal Employee Status","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No member, alternate, officer, or employee of a Commission (other than the Federal Cochairperson, the alternate Federal Cochairperson, staff of the Federal Cochairperson, and any Federal employee detailed to the Commission) shall be considered to be a Federal employee for any purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e5ae06-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15301/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Succession","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the time limitations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3346"},"text":"section 3346 of title 5","children":[],"tail":", the Federal Cochairperson may designate an employee of the Commission to perform the functions and duties of the office of the Federal Cochairperson temporarily in an acting capacity if both the Federal Cochairperson and the alternate Federal Cochairperson die, resign, or otherwise are unable to perform the functions and duties of their offices."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e5ae07-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14217/a/2"},"text":"Pub. L. 110–234, title XIV, § 14217(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1469"},"text":"122 Stat. 1469","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14217(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2231; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6304/f"},"text":"Pub. L. 115–334, title VI, § 6304(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4752"},"text":"132 Stat. 4752","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dO/tIV/s401/a/1"},"text":"Pub. L. 117–328, div. O, title IV, § 401(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5228"},"text":"136 Stat. 5228","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII"},"text":"Pub. L. 118–272, div. B, title II","children":[],"tail":", §§ 2242(a), 2249(a), 2250(a), "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3202"},"text":"138 Stat. 3202","children":[],"tail":", 3209.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e5ae08-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80e5ae09-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id80e5ae0a-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80e5ae0b-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2249/a"},"text":"Pub. L. 118–272, § 2249(a)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2250/a"},"text":"Pub. L. 118–272, § 2250(a)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2242/a/1"},"text":"Pub. L. 118–272, § 2242(a)(1)","children":[],"tail":", designated existing provisions as cl. (i), inserted heading, and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2242/a/2"},"text":"Pub. L. 118–272, § 2242(a)(2)","children":[],"tail":", substituted “an employee” for “a Federal employee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80e5ae0c-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id80e5ae0d-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s14217/d"},"text":"section 14217(d) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s15101"},"text":"section 15101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80e5ae0e-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Establishment of the Northwest Regional Commission","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/74/dB/tIV"},"text":"Pub. L. 119–74, div. B, title IV","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-01-23"},"text":"Jan. 23, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/90"},"text":"140 Stat. 90","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/74/dB/tIV"},"text":"“For expenses necessary to establish a Northwest Regional Commission located in Washington, Oregon, Idaho, and Montana, $1,000,000, to remain available until expended: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That amounts provided to the Northwest Regional Commission shall be used to carry out activities authorized for other regional Commissions by subtitle V of title 40, United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
