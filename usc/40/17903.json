{"tag":"section","attrib":{"id":"id80ecda09-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17903"},"text":null,"children":[{"tag":"num","attrib":{"value":"17903"},"text":"§ 17903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of electric power","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of economy, efficiency, and conserving oil and natural gas, the head of a federal agency, when practicable and consistent with other laws and requirements applicable to that agency, shall endeavor to purchase electric energy from a non-federal person for consumption in Alaska by a facility of that agency when (taking into account the remaining useful life of any facility available to that agency to generate electric energy for that agency and the cost of maintaining the facility on a standby basis) the purchase will result in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ecda0a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17903/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a savings to other consumers of electric energy sold by that non-federal person without increasing the cost incurred by any federal agency for electric energy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ecda0b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17903/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cost savings to the federal agency purchasing the electric energy without increasing costs to other consumers of electric energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ecda0c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1289"},"text":"116 Stat. 1289","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ecda0d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ecda0e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ecda0f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"17903","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:795b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/96/571/s4"},"text":"Pub. L. 96–571, § 4","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/3342"},"text":"94 Stat. 3342","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, before clause (1), the words “electric energy” are substituted for “electric power” for consistency in the revised section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
