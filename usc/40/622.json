{"tag":"section","attrib":{"id":"id80aa0532-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s622"},"text":null,"children":[{"tag":"num","attrib":{"value":"622"},"text":"§ 622.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collocation among United States Postal Service properties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80aa0533-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s622/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Identification of Postal Property","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each year, the Postmaster General shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa0534-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s622/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify a list of postal properties with space available for use by Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa0535-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s622/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than September 30, submit the list to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80aa0536-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s622/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa0537-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s622/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Oversight and Government Reform of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa0538-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s622/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voluntary Identification of Postal Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each year, the Postmaster General may submit the list under subsection (a) to the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa0539-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s622/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of List of Postal Properties to Federal Agencies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa053a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s622/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the completion of a list under subsection (a), the Council shall provide the list to each Federal agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa053b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s622/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review by federal agencies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the receipt of the list submitted under paragraph (1), each Federal agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80aa053c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s622/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the list;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa053d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s622/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review properties under the control of the Federal agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa053e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s622/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend collocations if appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa053f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s622/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms of Collocation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On approval of the recommendations under subsection (c) by the Postmaster General and the applicable agency head, the Federal agency or appropriate landholding entity may work with the Postmaster General to establish appropriate terms of a lease for each postal property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa0540-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s622/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section exceeds, modifies, or supplants any other Federal law relating to any competitive bidding process governing the leasing of postal property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80aa0541-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/318/s3/a"},"text":"Pub. L. 114–318, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1609"},"text":"130 Stat. 1609","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80aa0542-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80aa0543-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id80aa0544-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
