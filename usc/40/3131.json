ildren":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 17, 1999","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/113/231"},"text":"113 Stat. 231","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:270d.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1935-08-24/ch642/s4"},"text":"Aug. 24, 1935, ch. 642, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/794"},"text":"49 Stat. 794","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3131(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:270a(a) (words before cl. (1) related to furnishing bond), (1), (2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:270d–1.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1935-08-24/ch642/s5"},"text":"Aug. 24, 1935, ch. 642, § 5","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/103/355/tIV/s4104/b/1/A"},"text":"Pub. L. 103–355, title IV, § 4104(b)(1)(A)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/3341"},"text":"108 Stat. 3341","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3131(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:270a(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1935-08-24/ch642/s1/d"},"text":"Aug. 24, 1935, ch. 642, § 1(d)","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/89/719/tI/s105/b"},"text":"Pub. L. 89–719, title I, § 105(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/1139"},"text":"80 Stat. 1139","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3131(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:270a(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3131(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:270a(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the text of 40:270d is omitted because of 1:1.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (c), the words “or sureties” are omitted because of 1:1.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80b3a1ad-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsec. (c)(2), is classified to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80b3a1ae-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80b3a1af-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284"},"text":"Pub. L. 109–284","children":[],"tail":" substituted “To” for “to” in heading."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
