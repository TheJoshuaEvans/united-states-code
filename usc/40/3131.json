{"tag":"section","attrib":{"id":"id80b3a19c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3131"},"text":null,"children":[{"tag":"num","attrib":{"value":"3131"},"text":"§ 3131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bonds of contractors of public buildings or works","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80b3a19d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subchapter, the term “contractor” means a person awarded a contract described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b3a19e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Type of Bonds Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before any contract of more than $100,000 is awarded for the construction, alteration, or repair of any public building or public work of the Federal Government, a person must furnish to the Government the following bonds, which become binding when the contract is awarded:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b3a19f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3131/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance bond","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A performance bond with a surety satisfactory to the officer awarding the contract, and in an amount the officer considers adequate, for the protection of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b3a1a0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3131/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment bond","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A payment bond with a surety satisfactory to the officer for the protection of all persons supplying labor and material in carrying out the work provided for in the contract for the use of each person. The amount of the payment bond shall equal the total amount payable by the terms of the contract unless the officer awarding the contract determines, in a writing supported by specific findings, that a payment bond in that amount is impractical, in which case the contracting officer shall set the amount of the payment bond. The amount of the payment bond shall not be less than the amount of the performance bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b3a1a1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3131/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coverage for Taxes in Performance Bond.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b3a1a2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3131/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Every performance bond required under this section specifically shall provide coverage for taxes the Government imposes which are collected, deducted, or withheld from wages the contractor pays in carrying out the contract with respect to which the bond is furnished.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b3a1a3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3131/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Government shall give the surety on the bond written notice, with respect to any unpaid taxes attributable to any period, within 90 days after the date when the contractor files a return for the period, except that notice must be given no later than 180 days from the date when a return for the period was required to be filed under the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"26 U.S.C. 1","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b3a1a4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3131/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil action","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Government may not bring a civil action on the bond for the taxes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80b3a1a5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3131/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless notice is given as provided in this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b3a1a6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3131/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than one year after the day on which notice is given.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b3a1a7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3131/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of Bonds for Contracts Performed in Foreign Countries","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contracting officer may waive the requirement of a performance bond and payment bond for work under a contract that is to be performed in a foreign country if the officer finds that it is impracticable for the contractor to furnish the bonds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b3a1a8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3131/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Require Additional Bonds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not limit the authority of a contracting officer to require a performance bond or other security in addition to those, or in cases other than the cases, specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b3a1a9-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1147"},"text":"116 Stat. 1147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s6/8"},"text":"Pub. L. 109–284, § 6(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1213"},"text":"120 Stat. 1213","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b3a1aa-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b3a1ab-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80b3a1ac-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attr