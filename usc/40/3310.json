{"tag":"section","attrib":{"id":"id80b85d4b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3310"},"text":null,"children":[{"tag":"num","attrib":{"value":"3310"},"text":"§ 3310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for leased buildings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For any building to be constructed for lease to, and for predominant use by, the Federal Government, the Administrator of General Services—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b85d4c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3310/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s585/a/1"},"text":"section 585(a)(1) of this title","children":[],"tail":", shall not make any agreement or undertake any commitment which will result in the construction of the building until the Administrator has established detailed specification requirements for the building;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b85d4d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3310/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may acquire a leasehold interest in the building only by the use of competitive procedures required by sections 3105, 3301, and 3303 to 3305 of title 41;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b85d4e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3310/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include in the solicitation for any lease requiring a prospectus under section 3307 an evaluation factor considering the extent to which the offeror will promote energy efficiency and the use of renewable energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b85d4f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3310/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall inspect every building during construction to establish that the specifications established for the building are complied with;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b85d50-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3310/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on completion of the building, shall evaluate the building to determine the extent of failure to comply with the specifications referred to in clause (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b85d51-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3310/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall ensure that any contract entered into for the building shall contain provisions permitting a reduction of rent during any period when the building is not in compliance with the specifications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b85d52-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1164"},"text":"116 Stat. 1164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIII/s323/d"},"text":"Pub. L. 110–140, title III, § 323(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1591"},"text":"121 Stat. 1591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5"},"text":"Pub. L. 111–350, § 5","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(18), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3852"},"text":"124 Stat. 3852","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b85d53-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b85d54-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80b85d55-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","