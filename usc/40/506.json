{"tag":"section","attrib":{"id":"id8096f1bd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s506"},"text":null,"children":[{"tag":"num","attrib":{"value":"506"},"text":"§ 506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory controls and systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8096f1be-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities of the Administrator of General Services.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8096f1bf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), and after adequate advance notice to affected executive agencies, the Administrator of General Services may undertake the following activities as necessary to carry out functions under this chapter:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8096f1c0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s506/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Surveys and reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Survey and obtain executive agency reports on Federal Government property and property management practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8096f1c1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s506/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inventory levels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Cooperate with executive agencies to establish reasonable inventory levels for property stocked by them, and report any excessive inventory levels to Congress and to the Director of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8096f1c2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s506/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal supply catalog system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Establish and maintain a uniform federal supply catalog system that is appropriate to identify and classify personal property under the control of federal agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8096f1c3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s506/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standard purchase specifications and standard forms and procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Prescribe standard purchase specifications and standard forms and procedures (except forms and procedures that the Comptroller General prescribes by law) subject to regulations the Administrator for Federal Procurement Policy prescribes under division B (except sections 1704 and 2303) of subtitle I of title 41.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8096f1c4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s506/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capitalization thresholds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Establish thresholds for acquisitions of personal property for which executive agencies shall capitalize the personal property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8096f1c5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s506/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accountability thresholds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 121(b), for the management and accountability of personal property, establish thresholds for acquisitions of personal property for which executive agencies shall establish and maintain property records in a centralized system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8096f1c6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special considerations regarding department of defense.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8096f1c7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s506/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services shall carry out activities under paragraph (1) with due regard to the requirements of the Department of Defense, as determined by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8096f1c8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s506/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal supply catalog system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In establishing and maintaining a uniform federal supply catalog system under paragraph (1)(C), the Administrator of General Services and the Secretary shall coordinate to avoid unnecessary duplication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8096f1c9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities of Federal Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each federal agency shall use the uniformed federal supply catalog system, the standard purchase specifications, and the standard forms and procedures established under subsection (a), except as the Administrator of General Services, considering efficiency, economy, or other interests of the Government, may otherwise provide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8096f1ca-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Audit of Property Accounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General shall audit all types of property accounts and transactions. Audits shall be conducted at the time and in the manner the Comptroller General decides and as far as practicable at the place where the property or records of the executive agencies are kept. Audits shall include an evaluation of the effectiveness of internal controls and audits, and a general audit of the discharge of accountability for Government-owned or controlled property, based on generally accepted principles of auditing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8096f1cb-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1082"},"text":"116 Stat. 1082","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5"},"text":"Pub. L. 111–350, § 5","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(9), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3852"},"text":"124 Stat. 3852","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/419/s2/b"},"text":"Pub. L. 115–419, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-03"},"text":"Jan. 3, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5443"},"text":"132 Stat. 5443","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8096f1cc-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id8096f1cd-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id8096f1ce-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"506","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:487.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title II, § 206, "},{"tag":"html:a","attrib":{"href":"/us/stat/63/390"},"text":"63 Stat. 390","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-12/ch703/s1/k"},"text":"July 12, 1952, ch. 703, § 1(k)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/593"},"text":"66 Stat. 593","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/93/400/s15/3"},"text":"Pub. L. 93–400, § 15(3)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 30, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/800"},"text":"88 Stat. 800","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/83/s10/a"},"text":"Pub. L. 96–83, § 10(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 10, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/652"},"text":"93 Stat. 652","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/98/191"},"text":"Pub. L. 98–191","children":[],"tail":", §§ 8(d)(1), 9(a)(2), "},{"tag":"html:span","attrib":{},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/97/1331"},"text":"97 Stat. 1331","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1)(B), the words “from time to time” are omitted as unnecessary. The words “Director of the Office of Management and Budget” are substituted for “Director of the Bureau of the Budget” in section 206(a)(2) of the Federal Property and Administrative Services Act of 1949 because the office of Director of the Bureau of the Budget was redesignated the Director of the Office of Management and Budget by section 102(b) of Reorganization Plan No. 2 of 1970 (eff. ","children":[{"tag":"date","attrib":{"date":"1970-07-01"},"text":"July 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2085"},"text":"84 Stat. 2085","children":[],"tail":"). Section 102 of Reorganization Plan No. 2 of 1970, was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1982-09-13/s5/b"},"text":"section 5(b) of the Act of September 13, 1982","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Public Law 97–258","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1085"},"text":"96 Stat. 1085","children":[],"tail":"), the first section of which enacted Title 31, United States Code, but the successor provision, 31:502, continued the designation as Director of the Office of Management and Budget."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1)(D), the words “Subject to regulations” are substituted for “subject to regulations and regulations” in section 206(a)(4) of the Federal Property and Administrative Services Act of 1949 to correct an error resulting from an inconsistency between section 8(d)(1) and section 9(a)(2) of the Office of Federal Procurement Policy Act Amendments of 1983 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/191"},"text":"Public Law 98–191","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1331"},"text":"97 Stat. 1331","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)(A), the words “Department of Defense” are substituted for “National Military Establishment” in section 206(a) of the Federal Property and Administrative Services Act of 1949 because the Department of Defense is deemed to succeed the National Military Establishment under section 12(a) and (g) of the National Security Act Amendments of 1949 (ch. 412, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/63/591"},"text":"63 Stat. 591","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “Comptroller General” are substituted for “General Accounting Office” because of 31:702 and for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8096f1cf-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8096f1d0-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1)(E), (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/419"},"text":"Pub. L. 115–419","children":[],"tail":" added subpars. (E) and (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":" substituted “division B (except sections 1704 and 2303) of subtitle I of title 41” for “the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s401"},"text":"41 U.S.C. 401","children":[],"tail":" et seq.)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
