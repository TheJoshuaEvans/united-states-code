{"tag":"section","attrib":{"id":"id80aa05a1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701"},"text":null,"children":[{"tag":"num","attrib":{"value":"701"},"text":"§ 701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80aa05a2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policies Prescribed by the President","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President may prescribe policies that the President considers necessary to carry out this chapter. The policies must be consistent with this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa05a3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive Agency Responsibility.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa05a4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an executive agency that has foreign excess property is responsible for the disposal of the property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa05a5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conformance to policies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out functions under this chapter, the head of an executive agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80aa05a6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the policies prescribed by the President under subsection (a) for guidance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa05a7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dispose of foreign excess property in a manner that conforms to the foreign policy of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa05a8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation of authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an executive agency may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80aa05a9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delegate authority conferred by this chapter to an official in the agency or to the head of another executive agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa05aa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize successive redelegation of authority conferred by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa05ab-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employment of personnel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As necessary to carry out this chapter, the head of an executive agency may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80aa05ac-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint and fix the pay of personnel in the United States, subject to chapters 33 and 51 and subchapter III of chapter 53 of title 5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa05ad-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint personnel outside the States of the United States and the District of Columbia, without regard to chapter 33 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aa05ae-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Responsibilities of Secretary of State.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aa05af-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of foreign currencies and credits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State may use foreign currencies and credits acquired by the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s704/b/2"},"text":"section 704(b)(2) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80aa05b0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the Mutual Educational and Cultural Exchange Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2451"},"text":"22 U.S.C. 2451","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa05b1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the Foreign Service Buildings Act, 1926 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s292"},"text":"22 U.S.C. 292","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80aa05b2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay other governmental expenses payable in local currencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aa05b3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s701/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Renewal of certain agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise directed by the President, the Secretary of State shall continue to perform functions under agreements in effect on ","children":[{"tag":"date","attrib":{"date":"1949-07-01"},"text":"July 1, 1949","children":[],"tail":", related to the disposal of foreign excess property. The Secretary of State may amend, modify, and renew the agreements. Foreign currencies or credits the Secretary of State acquires under the agreements shall be administered in accordance with procedures that the Secretary of the Treasury may establish. Foreign currencies or credits reduced to United States currency must be deposited in the Treasury as miscellaneous receipts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80aa05b4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1125"},"text":"116 Stat. 1125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80aa05b5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80aa05b6-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id