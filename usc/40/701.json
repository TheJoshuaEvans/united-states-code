before last comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title IV, § 404, "},{"tag":"html:a","attrib":{"href":"/us/stat/63/398"},"text":"63 Stat. 398","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/86/624/s27/c"},"text":"Pub. L. 86–624, § 27(c)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/418"},"text":"74 Stat. 418","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/470/tI/s101/a"},"text":"Pub. L. 96–470, title I, § 101(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/2237"},"text":"94 Stat. 2237","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"701(b)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:511 (words before proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title IV, § 401, "},{"tag":"html:a","attrib":{"href":"/us/stat/63/397"},"text":"63 Stat. 397","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:514(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"701(b)(2)(A)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:514(a) (words after last comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"701(b)(2)(B)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:511 (proviso cl. (a)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"701(b)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:514(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"701(b)(4)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:514(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"701(c)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:511 (proviso cl. (b) (words before “and the authority to amend”)[)].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"701(c)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:511 (proviso cl. (b) (words beginning “and the authority to amend”), (c), (d)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the text of 40:514(d) is omitted as executed and obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(4), the words “chapters 33 and 51 and subchapter III of chapter 53 of title 5” are substituted for “the civil-service and classification laws”, and the words “chapter 33 of title 5” are substituted for “the civil-service laws”, because of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1966-09-06/s7/b"},"text":"section 7(b) of the Act of September 6, 1966","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Public Law 89–554","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":"), the first section of which enacted Title 5, United States Code. In subclause (A), the words “in the United States” are added for clarity. In subclause (B), provisions related to the heads of executive agencies fixing the compensation of personnel outside the continental limits of the United States that were contained in section 404(c)(2) of the Federal Property and Administrative Services Act of 1949 are omitted as obsolete. Sections 1202 and 1204 of the Classification Act of 1949 (ch. 782, "},{"tag":"ref","attrib":{"href":"/us/stat/63/972"},"text":"63 Stat. 972","children":[],"tail":", 973) repealed the Classification Act of 1923 (ch. 265, "},{"tag":"ref","attrib":{"href":"/us/stat/42/1488"},"text":"42 Stat. 1488","children":[],"tail":") and all other provisions inconsistent with the 1949 Act. The Classification Act of 1949 was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1966-09-06/s8/a"},"text":"section 8(a) of the Act of September 6, 1966","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Public Law 89–554","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/632"},"text":"80 Stat. 632","children":[],"tail":"), the first section of which enacted title 5, United States Code. The Classification Act of 1949 was reenacted as chapter 51 and subchapter III of chapter 53 of title 5. See especially 5:5102 and 5103."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “Mutual Educational and Cultural Exchange Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2451"},"text":"22 U.S.C. 2451","children":[],"tail":" et seq.)” are substituted for “section 32(b)(2) of the Surplus Property Act of 1944, as amended” because of section 111(a)(1) and (c) of the Mutual Educational and Cultural Exchange Act of 1961 ("},{"tag":"ref","attrib":{"href":"/us/pl/87/257"},"text":"Public Law 87–257","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/538"},"text":"75 Stat. 538","children":[],"tail":"). The words “Foreign Service Buildings Act, 1926” are substituted for “Foreign Service Buildings Act of "},{"tag":"date","attrib":{"date":"1926-05-07"},"text":"May 7, 1926","children":[],"tail":", as amended” because of section 8 of the Foreign Service Buildings Act (22:299). The words “(including "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s295b"},"text":"section 295b of title 22","children":[],"tail":")” are omitted as executed and obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “Secretary of State” are substituted for “Department of State” because of 22:2651.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80aa05b8-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80aa05b9-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Mutual Educational and Cultural Exchange Act of 1961, referred to in subsec. (c)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/256"},"text":"Pub. L. 87–256","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-21"},"text":"Sept. 21, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/527"},"text":"75 Stat. 527","children":[],"tail":", which is classified principally to chapter 33 (§ 2451 et seq.) of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2451"},"text":"section 2451 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Foreign Service Buildings Act, 1926, referred to in subsec. (c)(1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-07/ch250"},"text":"act May 7, 1926, ch. 250","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/403"},"text":"44 Stat. 403","children":[],"tail":", as which is classified generally to chapter 8 (§ 292 et seq.) of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s299"},"text":"section 299 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
