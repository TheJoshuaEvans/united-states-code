{"tag":"section","attrib":{"id":"id809bd3d4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s548"},"text":null,"children":[{"tag":"num","attrib":{"value":"548"},"text":"§ 548.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surplus vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id809bd3d5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s548/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), the Maritime Administration shall dispose of surplus vessels of 1,500 gross tons or more which the Administration determines to be merchant vessels or capable of conversion to merchant use. The vessels shall be disposed of in accordance with part F of subtitle V of title 46 and other laws authorizing the sale of such vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id809bd3d6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s548/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Oceanic and Atmospheric Administration Vessels and Equipment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id809bd3d7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s548/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the National Oceanic and Atmospheric Administration may dispose of covered vessels and equipment, which would otherwise be disposed of under subsection (a), through sales or transfers under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd3d8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s548/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of proceeds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the 2-year period beginning of the date of enactment of the National Defense Authorization Act for Fiscal Year 2026, notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s571"},"text":"section 571 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", the Administrator of the National Oceanic and Atmospheric Administration may—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id809bd3d9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s548/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain the proceeds from the sale or transfer of a covered vessel or equipment under paragraph (1) until expended under subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id809bd3da-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s548/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use such proceeds, without fiscal year limitation, for the acquisition of new covered vessels and equipment or the repair and maintenance of existing covered vessels and equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id809bd3db-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s548/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered vessels and equipment defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “covered vessels and equipment” means survey and research vessels and related equipment owned by the Federal Government and under the control of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id809bd3dc-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1090"},"text":"116 Stat. 1090","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s17/g/1"},"text":"Pub. L. 109–304, § 17(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1708"},"text":"120 Stat. 1708","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIV/s8409"},"text":"Pub. L. 119–60, div. H, title LXXXIV, § 8409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1913"},"text":"139 Stat. 1913","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id809bd3dd-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id809bd3de-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"widt