{"tag":"section","attrib":{"id":"id80a08ed8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s554"},"text":null,"children":[{"tag":"num","attrib":{"value":"554"},"text":"§ 554.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property for development or operation of a port facility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80a08ed9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s554/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a08eda-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s554/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Base closure law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “base closure law” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/17"},"text":"section 101(a)(17) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08edb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s554/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” includes the District of Columbia, Puerto Rico, Guam, American Samoa, the Virgin Islands, the Federated States of Micronesia, the Marshall Islands, Palau, and the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08edc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s554/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority for Assignment to the Secretary of Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations that the Administrator of General Services, after consultation with the Secretary of Defense, may prescribe, the Administrator, or the Secretary of Defense in the case of property located at a military installation closed or realigned pursuant to a base closure law, may assign to the Secretary of Transportation for disposal surplus real property, including buildings, fixtures, and equipment situated on the property, that the Secretary of Transportation recommends as needed for the development or operation of a port facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08edd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s554/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority for Conveyance by the Secretary of Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a08ede-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s554/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to disapproval by the Administrator or the Secretary of Defense within 30 days after notice of a proposed conveyance by the Secretary of Transportation, the Secretary of Transportation, for the development or operation of a port facility, may convey property assigned to the Secretary of Transportation under subsection (b) to a State or political subdivision, municipality, or instrumentality of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08edf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s554/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conveyance requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A transfer of property may be made under this section only after the Secretary of Transportation has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a08ee0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s554/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined, after consultation with the Secretary of Labor, that the property to be conveyed is located in an area of serious economic disruption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a08ee1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s554/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received and, after consultation with the Secretary of Commerce, approved an economic development plan submitted by an eligible grantee and based on assured use of the property to be conveyed as part of a necessary economic development program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a08ee2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s554/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmitted to Congress an explanatory statement that contains information substantially similar to the information contained in statements prepared under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s545/e"},"text":"section 545(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08ee3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s554/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Monetary Consideration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A conveyance under this section shall be made without monetary consideration to the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08ee4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s554/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deed of Conveyance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The deed of conveyance of any surplus real and related personal property disposed of under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a08ee5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s554/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that all of the property be used and maintained for the purpose for which it was conveyed in perpetuity, and that if the property ceases to be used or maintained for that purpose, all or any portion of the property shall, in its then existing condition, at the option of the Government, revert to the Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a08ee6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s554/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain additional terms, reservations, restrictions, and conditions that the Secretary of Transportation shall by regulation require to ensure use of the property for the purposes for which it was conveyed and to safeguard the interests of the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a08ee7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s554/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement and Revision of Instruments Transferring Property Under This Section","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall determine and enforce compliance with the terms, conditions, reservations, and restrictions contained in an instrument by which a transfer or conveyance under this section is made. The Secretary shall reform, correct, or amend the instrument if necessary to correct the instrument or to conform the transfer to the requirements of law. The Secretary shall grant a release from any term, condition, reservation or restriction contained in the instrument, and shall convey, quitclaim, or release to the grantee any right or interest reserved to the Government by the instrument, if the Secretary determines that the property no longer serves the purpose for which it was transferred or that a release, conveyance, or quitclaim deed will not prevent accomplishment of that purpose. The release, conveyance, or quitclaim deed may be made subject to terms and conditions that the Secretary considers necessary to protect or advance the interests of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80a08ee8-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1100"},"text":"116 Stat. 1100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1056/a/5/A"},"text":"Pub. L. 109–163, div. A, title X, § 1056(a)(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3439"},"text":"119 Stat. 3439","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s6/4"},"text":"Pub. L. 109–284, § 6(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1212"},"text":"120 Stat. 1212","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80a08ee9-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80a08eea-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80a08eeb-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"554","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:484(q).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title II, § 203(q), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/103/160/dB/tXXIX/s2927/2"},"text":"Pub. L. 103–160, div. B, title XXIX, § 2927(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/107/1933"},"text":"107 Stat. 1933","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Trust Territory of the Pacific Islands” are omitted and the words “the Federated States of Micronesia, the Marshall Islands, Palau” are added because of the termination of the Trust Territory of the Pacific Islands. See 48:1681 note prec.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80a08eec-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80a08eed-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “has the meaning given that term in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/17"},"text":"section 101(a)(17) of title 10","children":[],"tail":".” for “means the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) Title II of the Defense Authorization Amendments and Base Closure and Realignment Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/526"},"text":"Public Law 100–526","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2687"},"text":"10 U.S.C. 2687","children":[],"tail":" note)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) The Defense Base Closure and Realignment Act of 1990 (part A of title XXIX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Public Law 101–510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2687"},"text":"10 U.S.C. 2687","children":[],"tail":" note)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2687"},"text":"Section 2687 of title 10","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284"},"text":"Pub. L. 109–284","children":[],"tail":" substituted “"},{"tag":"inline","attrib":{},"text":"Transportation","children":[],"tail":".—” for “"},{"tag":"inline","attrib":{},"text":"Transportation","children":[],"tail":".” in heading."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
