{"tag":"section","attrib":{"id":"id80b3a188-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3116"},"text":null,"children":[{"tag":"num","attrib":{"value":"3116"},"text":"§ 3116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest as part of just compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80b3a189-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Calculation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The district court shall calculate interest required to be paid under this subchapter as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b3a18a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3116/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of not more than one year","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Where the period for which interest is owed is not more than one year, interest shall be calculated from the date of taking at an annual rate equal to the weekly average one-year constant maturity Treasury yield, as published by the Board of Governors of the Federal Reserve System, for the calendar week preceding the date of taking.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b3a18b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3116/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of more than one year","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Where the period for which interest is owed is more than one year, interest for the first year shall be calculated in accordance with paragraph (1) and interest for each additional year shall be calculated on the amount by which the award of compensation is more than the deposit referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3114"},"text":"section 3114 of this title","children":[],"tail":", plus accrued interest, at an annual rate equal to the weekly average one-year constant maturity Treasury yield, as published by the Board of Governors of the Federal Reserve System, for the calendar week preceding the beginning of each additional year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b3a18c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of Notice of Rates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Administrative Office of the United States Courts shall distribute to all federal courts notice of the rates described in paragraphs (1) and (2) of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b3a18d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1146"},"text":"116 Stat. 1146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b3a18e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b3a18f-3a70-11f1-b81