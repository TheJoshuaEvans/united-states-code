{"tag":"section","attrib":{"id":"id80ac762c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1103"},"text":null,"children":[{"tag":"num","attrib":{"value":"1103"},"text":"§ 1103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection procedure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80ac762d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"These procedures apply to the procurement of architectural and engineering services by an agency head.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ac762e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Statements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The agency head shall encourage firms to submit annually a statement of qualifications and performance data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ac762f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each proposed project, the agency head shall evaluate current statements of qualifications and performance data on file with the agency, together with statements submitted by other firms regarding the proposed project. The agency head shall conduct discussions with at least 3 firms to consider anticipated concepts and compare alternative methods for furnishing services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ac7630-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"From the firms with which discussions have been conducted, the agency head shall select, in order of preference, at least 3 firms that the agency head considers most highly qualified to provide the services required. Selection shall be based on criteria established and published by the agency head.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ac7631-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1130"},"text":"116 Stat. 1130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ac7632-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ac7633-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ac7634-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:543.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title IX, § 903, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/92/582"},"text":"Pub. L. 92–582","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/1279"},"text":"86 Stat. 1279","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “engaged in the lawful practice of their profession” are omitted as unnecessary because of the definition of “firm” in section 1102 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “compare alternative methods for furnishing services” are substituted for “the relative utility of alternative methods of approach for furnishing the required services” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80ac7635-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80ac7636-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Architectural and Engineering Services","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tXIV/s1427/b"},"text":"Pub. L. 108–136, div. A, title XIV, § 1427(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1670"},"text":"117 Stat. 1670","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1702"},"text":"Pub. L. 117–81, div. A, title XVII, § 1702","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(8), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2161"},"text":"135 Stat. 2161","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/stat/135/2161"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Architectural and engineering services (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s1102"},"text":"section 1102 of title 40","children":[],"tail":", United States Code) shall not be offered under multiple-award schedule contracts entered into by the Administrator of General Services or under Governmentwide task and delivery order contracts entered into under sections 3403 and 3405 of title 10, United States Code, or sections 303H and 303I of the Federal Property and Administrative Services Act of 1949 ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s253h"},"text":"41 U.S.C. 253h","children":[],"tail":" and 253i) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s4103"},"text":"41 U.S.C. 4103","children":[],"tail":", 4105(a) to (c)(1), (d) to (i)] unless such services—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are performed under the direct supervision of a professional architect or engineer licensed, registered, or certified in the State, territory (including the Commonwealth of Puerto Rico), possession, or Federal District in which the services are to be performed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are awarded in accordance with the selection procedures set forth in chapter 11 of title 40, United States Code.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
