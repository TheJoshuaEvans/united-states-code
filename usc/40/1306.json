{"tag":"section","attrib":{"id":"id80aee68f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306"},"text":null,"children":[{"tag":"num","attrib":{"value":"1306"},"text":"§ 1306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of abandoned or forfeited personal property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80aee690-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aee691-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “agency” includes any executive department, independent establishment, board, commission, bureau, service, or division of the Federal Government, and any corporation in which the Government owns at least a majority of the stock.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aee692-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “property” means all personal property, including vessels, vehicles, and aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aee693-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voluntarily Abandoned Property","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Property voluntarily abandoned to any agency in a way that vests title to the property in the Government may be retained by the agency and devoted to official use only. If the agency does not desire to retain the property, the head of the agency immediately shall notify the Administrator of General Services to that effect, and the Administrator, within a reasonable time, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aee694-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" order the agency to deliver the property to another agency that requests the property and that the Administrator believes should be given the property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aee695-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" order disposal of the property as otherwise provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80aee696-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forfeited Property.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80aee697-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency retains property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An agency that seizes property that has been forfeited to the Government other than by court decree may retain the property and devote it only to official use instead of disposing of the property as otherwise provided by law if competent authority does not order the property returned to any claimant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80aee698-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency does not desire to retain property","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the agency does not desire to retain the property, the head of the agency immediately shall notify the Administrator to that effect, and the property—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80b13089-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if not ordered by competent authority to be returned to any claimant, or disposed of as otherwise provided by law, shall be delivered by the agency, on order of the Administrator given within a reasonable time, to another agency that requests the property and that the Administrator believes should be given the property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b1308a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on order of the Administrator given within a reasonable time, shall be disposed of as otherwise provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b1308b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Property Subject to Court Proceeding for Forfeiture.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b1308c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a proceeding has begun for the forfeiture of any property by court decree, the agency that seized the property immediately shall notify the Administrator and at the same time may file with the Administrator a request for the property for its official use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b1308d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application for court order to deliver property.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80b1308e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before entry of a decree, the Administrator shall apply to the court to order delivery of the property in accordance with this paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b1308f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delivery to seizing agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the agency that seized the property files a request for the property under paragraph (1), the Administrator shall apply to the court to order delivery of the property to the agency that seized the property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b13090-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delivery to other requesting agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the agency that seized the property does not file a request for the property under paragraph (1) but another agency requests the property, the Administrator shall apply to the court to order delivery of the property to the requesting agency if the Administrator believes that the requesting agency should be given the property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b13091-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delivery to seizing agency for temporary holding","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If application to the court cannot be made under subparagraph (B) or (C) and the Administrator believes the property may later become necessary to any agency for official use, the Administrator shall apply to the court to order delivery of the property to the agency that seized the property, to be retained in its custody. Within a reasonable time, the Administrator shall order the agency to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80b13092-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/d/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deliver the property to another agency that requests the property and that the Administrator believes should be given the property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80b13093-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/d/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dispose of the property as otherwise provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b13094-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forfeiture decreed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If forfeiture is decreed and the property is not ordered by competent authority to be returned to any claimant, the court shall order delivery as provided in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b13095-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When no application made","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court shall dispose of property for which no application is made in accordance with law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b13096-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention or Delivery of Property Deemed Sale","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Retention or delivery of forfeited or abandoned property under this section is deemed to be a sale of the property for the purpose of laws providing for informer’s fees or remission or mitigation of a forfeiture. Property acquired under this section when no longer needed for official use shall be disposed of in the same manner as other surplus property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b13097-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Costs Related to Property.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b13098-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The appropriation available to an agency for the purchase, hire, operation, maintenance, and repair of any property is available for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80b13099-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment of expenses of operation, maintenance, and repair of property of the same kind the agency receives under this section for official use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b1309a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment of a lien recognized and allowed under law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b1309b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment of amounts found to be due a person on the authorized remission or mitigation of a forfeiture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b1309c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimbursement of other agencies as provided in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b1309d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment and reimbursement of certain costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The agency that receives property under this section shall pay the cost of hauling, transporting, towing, and storing the property. If the property is later delivered to another agency for official use under this section, the agency to which the property is delivered shall make reimbursement for all of those costs incurred prior to the date the property is delivered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b1309e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With the approval of the Secretary of the Treasury, the Administrator may require an agency to make a report of all property abandoned to it or seized and the disposal of the property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b1309f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b130a0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With the approval of the Secretary, the Administrator may prescribe regulations necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b130a1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other laws not repealed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not repeal any other laws relating to the disposition of forfeited or abandoned property, except provisions of those laws directly in conflict with this section which were enacted prior to ","children":[{"tag":"date","attrib":{"date":"1935-08-27"},"text":"August 27, 1935","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b130a2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Property not subject to allocation under this section","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following classes of property are not subject to allocation under this section, but shall be disposed of in the manner otherwise provided by law:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80b130a3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" narcotic drugs, as defined in the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"21 U.S.C. 801","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b130a4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" firearms, as defined in section 5845 of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s5845"},"text":"26 U.S.C. 5845","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b130a5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s1306/h/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other classes or kinds of property the disposal of which the Administrator, with the approval of the Secretary, may consider in the public interest, and may by regulation provide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b130a6-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1134"},"text":"116 Stat. 1134","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b130a7-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b130a8-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"i