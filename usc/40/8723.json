717(b) of the Balanced Budget Act of 1997 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Public Law 105–33","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/786"},"text":"111 Stat. 786","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80cde004-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80cde005-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 444 of the District of Columbia Home Rule Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/198/s444"},"text":"section 444 of Pub. L. 93–198","children":[],"tail":", title IV, "},{"tag":"date","attrib":{"date":"1973-12-24"},"text":"Dec. 24, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/800"},"text":"87 Stat. 800","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
