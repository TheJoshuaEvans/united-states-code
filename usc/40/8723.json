{"tag":"section","attrib":{"id":"id80cddffd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8723"},"text":null,"children":[{"tag":"num","attrib":{"value":"8723"},"text":"§ 8723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital improvements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80cddffe-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Six-Year Program of Public Works Projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Capital Planning Commission shall recommend a six-year program of public works projects for the Federal Government which the Commission shall review annually with the agencies concerned. Each federal agency shall submit to the Commission in the first quarter of each fiscal year a copy of its advance program of capital improvements within the National Capital and its environs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80cddfff-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Multiyear Capital Improvement Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"By February 1 of each year, the Mayor of the District of Columbia shall submit to the Commission a copy of the multiyear capital improvements plan for the District of Columbia that the Mayor develops under section 444 of the District of Columbia Home Rule Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/198"},"text":"Public Law 93–198","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/800"},"text":"87 Stat. 800","children":[],"tail":"). The Commission has 30 days in which to comment on the plan but may not change or disapprove of the plan."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80cde000-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1223"},"text":"116 Stat. 1223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80cde001-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80cde002-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80cde003-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null}