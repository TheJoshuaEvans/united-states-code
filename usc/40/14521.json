{"tag":"section","attrib":{"id":"id80e33d30-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14521"},"text":null,"children":[{"tag":"num","attrib":{"value":"14521"},"text":"§ 14521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required level of expenditure","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A State or political subdivision of a State is not eligible to receive benefits under this subtitle unless the aggregate expenditure of state amounts, except expenditures for participation in the Dwight D. Eisenhower System of Interstate and Defense Highways and local and federal amounts, for the benefit of the area within the State located in the Appalachian region is maintained at a level which does not fall below the average level of those expenditures for the State’s last two full fiscal years prior to ","children":[{"tag":"date","attrib":{"date":"1965-03-09"},"text":"March 9, 1965","children":[],"tail":". In computing the level, a State’s past expenditure for participation in the Dwight D. Eisenhower System of Interstate and Defense Highways and expenditures of local and federal amounts shall not be included. The Commission shall recommend to the President a lesser requirement when it finds that a substantial population decrease in that part of a State which lies within the region would not justify a state expenditure equal to the average level of the last two years or when it finds that a State’s average level of expenditure in an individual program has been disproportionate to the present need for that part of the State."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id80e33d31-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1274"},"text":"116 Stat. 1274","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e33d32-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80e33d33-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80e33d34-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14521","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:221.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/4/tII/s221"},"text":"Pub. L. 89–4, title II, § 221","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Mar. 9, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/18"},"text":"79 Stat. 18","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/90/103/tI/s117"},"text":"Pub. L. 90–103, title I, § 117","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 11, 1967","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/81/263"},"text":"81 Stat. 263","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/101/427"},"text":"Pub. L. 101–427","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/927"},"text":"104 Stat. 927","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “or such Federal officer or officers as the President may designate” are omitted because of 3:301.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
