{"tag":"section","attrib":{"id":"id80cb6f81-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8701"},"text":null,"children":[{"tag":"num","attrib":{"value":"8701"},"text":"§ 8701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80cb6f82-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80cb6f83-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of the seat of government in the District of Columbia has brought about the development of a metropolitan region extending well into adjoining territory in Maryland and Virginia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cb6f84-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective comprehensive planning is necessary on a regional basis and of continuing importance to the federal establishment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cb6f85-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8701/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distribution of federal installations throughout the region has been and will continue to be a major influence in determining the extent and character of development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cb6f86-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8701/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is needed a central planning agency for the National Capital region to coordinate certain developmental activities of the many different agencies of the Federal and District of Columbia Governments so that those activities may conform with general objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cb6f87-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8701/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is an increasing mutuality of interest and responsibility between the various levels of government that calls for coordinate and unified policies in planning both federal and local development in the interest of order and economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cb6f88-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8701/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are developmental problems of an interstate character, the planning of which requires collaboration between federal, state, and local governments in the interest of equity and constructive action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cb6f89-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8701/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the instrumentalities and procedures provided in this chapter will aid in providing Congress with information and advice requisite to legislation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80cb6f8a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80cb6f8b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter (except sections 8733–8736) are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80cb6f8c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8701/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to secure comprehensive planning for the physical development of the National Capital and its environs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80cb6f8d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8701/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the participation of the appropriate planning agencies of the environs in the planning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80cb6f8e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8701/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish the agency and procedures requisite to the administration of the functions of the Federal and District Governments related to the planning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cb6f8f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Objective","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The general objective of this chapter (except sections 8733–8736) is to enable appropriate agencies to plan for the development of the federal establishment at the seat of government in a manner—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80cb6f90-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8701/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the nature and function of the National Capital and with due regard for the rights and prerogatives of the adjoining States and local governments to exercise control appropriate to their functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80cb6f91-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8701/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which will, in accordance with present and future needs, best promote public health, safety, morals, order, convenience, prosperity, and the general welfare, as well as efficiency and economy in the process of development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80cb6f92-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1216"},"text":"116 Stat. 1216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80cb6f93-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80cb6f94-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80cb6f95-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8701(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:71(a) (2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1924-06-06/ch270/s1/a"},"text":"June 6, 1924, ch. 270, § 1(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/43/463"},"text":"43 Stat. 463","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1926-04-30/ch198"},"text":"Apr. 30, 1926, ch. 198","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/44/374"},"text":"44 Stat. 374","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1928-05-24/ch726"},"text":"May 24, 1928, ch. 726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/45/726"},"text":"45 Stat. 726","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-19/ch949/s1"},"text":"July 19, 1952, ch. 949, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/781"},"text":"66 Stat. 781","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8701(b)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:71(a) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8701(b)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:71(a) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(7), the words “from time to time” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the text of 40:72a, restated as section 8732 of the revised title, is included in the purposes and objectives of this chapter because by its terms, the authority of the National Capital Planning Commission is enlarged as provided in that section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
