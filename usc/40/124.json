{"tag":"section","attrib":{"id":"id808fc58e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s124"},"text":null,"children":[{"tag":"num","attrib":{"value":"124"},"text":"§ 124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency use of amounts for property management","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Amounts appropriated, allocated, or available to a federal agency for purposes similar to the purposes in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s121"},"text":"section 121 of this title","children":[],"tail":" or subchapter I (except section 506), II, or III of chapter 5 of this title may be used by the agency for the disposition of property under this subtitle, and for the care and handling of property pending the disposition, if the Director of the Office of Management and Budget authorizes the use."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id808fc58f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1071"},"text":"116 Stat. 1071","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id808fc590-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id808fc591-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id808fc592-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"ta