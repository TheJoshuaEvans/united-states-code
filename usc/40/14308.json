{"tag":"section","attrib":{"id":"id80dc11b1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14308"},"text":null,"children":[{"tag":"num","attrib":{"value":"14308"},"text":"§ 14308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80dc11b2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions of Commission","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To obtain information needed to carry out its duties, the Appalachian Regional Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80dc11b3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14308/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold hearings, sit and act at times and places, take testimony, receive evidence, and print or otherwise reproduce and distribute so much of its proceedings and reports on the proceedings as the Commission may deem advisable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc11b4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14308/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrange for the head of any federal, state, or local department or agency to furnish to the Commission information as may be available to or procurable by the department or agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc11b5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14308/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" keep accurate and complete records of its doings and transactions which shall be made available for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80dc11b6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14308/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public inspection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80dc11b7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14308/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" audit and examination by the Comptroller General or an authorized representative of the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc11b8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorizations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80dc11b9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14308/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administer oaths","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Cochairman of the Commission, or any member of the Commission designated by the Commission, may administer oaths when the Commission decides that testimony shall be taken or evidence received under oath.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80dc11ba-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14308/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Furnish information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of any federal, state, or local department or agency, to the extent not otherwise prohibited by law, may carry out subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80dc11bb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14308/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Participation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Public participation in the development, revision, and implementation of all plans and programs under this subtitle by the Commission, any State, or any local development district shall be provided for, encouraged, and assisted. The Commission shall develop and publish regulations specifying minimum guidelines for public participation, including public hearings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80dc11bc-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1260"},"text":"116 Stat. 1260","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s6/31"},"text":"Pub. L. 109–284, § 6(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1213"},"text":"120 Stat. 1213","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80dc11bd-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80dc11be-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80dc11bf-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"te