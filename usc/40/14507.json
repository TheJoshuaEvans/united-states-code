{"tag":"section","attrib":{"id":"id80e0f3d4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507"},"text":null,"children":[{"tag":"num","attrib":{"value":"14507"},"text":"§ 14507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplements to federal grant programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e0f3d5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f3d6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal grant programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “federal grant programs”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e0f3d7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means any federal grant program that provides assistance for the acquisition or development of land, the construction or equipment of facilities, or other community or economic development or economic adjustment activities, including a federal grant program authorized by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80e0f3d8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Consolidated Farm and Rural Development Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"7 U.S.C. 1921","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e0f3d9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 2003 of title 54;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e0f3da-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Watershed Protection and Flood Prevention Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1001"},"text":"16 U.S.C. 1001","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e0f3db-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Carl D. Perkins Career and Technical Education Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2301"},"text":"20 U.S.C. 2301","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e0f3dc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.) (known as the Clean Water Act);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e0f3dd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/a/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title VI of the Public Health Services Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s291"},"text":"42 U.S.C. 291","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e0f3de-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/a/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 201 and 209 of the Public Works and Economic Development Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3141"},"text":"42 U.S.C. 3141","children":[],"tail":", 3149);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e0f3df-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/a/1/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title I of the Housing and Community Development Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5301"},"text":"42 U.S.C. 5301","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e0f3e0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/a/1/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part IV of title III of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s390"},"text":"47 U.S.C. 390","children":[],"tail":" et seq.); but"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e0f3e1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80e0f3e2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program for the construction of the development highway system authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14501"},"text":"section 14501 of this title","children":[],"tail":" or any other program relating to highway or road construction authorized by title 23; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e0f3e3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other program to the extent that financial assistance other than a grant is authorized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3e4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain sewage treatment works deemed constructed with federal grant assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purpose of this section, any sewage treatment works constructed pursuant to title II of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1281"},"text":"33 U.S.C. 1281","children":[],"tail":" et seq.) (known as the Clean Water Act) without federal grant assistance under that title is deemed to be constructed with that assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f3e5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To enable the people, States, and local communities of the Appalachian region, including local development districts, to take maximum advantage of federal grant programs for which they are eligible but for which, because of their economic situation, they cannot supply the required matching share, or for which there are insufficient amounts available under the federal law authorizing the programs to meet pressing needs of the region, the Federal Cochairman may use amounts made available to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f3e6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any part of the basic federal contribution to projects or activities under the federal grant programs authorized by federal laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3e7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the federal contribution to projects and activities under the programs above the fixed maximum part of the cost of the projects or activities otherwise authorized by the applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f3e8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For a program, project, or activity for which any part of the basic federal contribution to the project or activity under a federal grant program is proposed to be made under subsection (b), the contribution shall not be made until the responsible federal official administering the federal law authorizing the contribution certifies that the program, project, or activity meets the applicable requirements of the federal law and could be approved for federal contribution under that law if amounts were available under the law for the program, project, or activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f3e9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations in Other Laws Inapplicable","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts provided pursuant to this subtitle are available without regard to any limitations on areas eligible for assistance or authorizations for appropriation in any other law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f3ea-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of Certain Material","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For a supplemental grant for a project or activity under a federal grant program, the Federal Cochairman shall accept any finding, report, certification, or documentation required to be submitted to the head of the department, agency, or instrumentality of the Federal Government responsible for the administration of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f3eb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The federal portion of the cost of a project or activity shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f3ec-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be increased to more than the percentages the Commission establishes; nor","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3ed-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be more than 80 percent of the cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f3ee-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Commission Contribution.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f3ef-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraphs (2) and (3), the Commission may contribute not more than 50 percent of a project or activity cost eligible for financial assistance under this section from amounts appropriated to carry out this subtitle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3f0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distressed counties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum Commission contribution for a project or activity to be carried out in a county for which a distressed county designation is in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14526"},"text":"section 14526 of this title","children":[],"tail":" may be increased to 80 percent."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3f1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14507/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"At-risk counties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum Commission contribution for a project to be carried out in a county for which an at-risk county designation is in effect under section 14526 may be increased to 70 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e0f3f2-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1272"},"text":"116 Stat. 1272","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/270/s2/j"},"text":"Pub. L. 109–270, § 2(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/748"},"text":"120 Stat. 748","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/371/s2/g"},"text":"Pub. L. 110–371, § 2(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4040"},"text":"122 Stat. 4040","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s5/j/7"},"text":"Pub. L. 113–287, § 5(j)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3269"},"text":"128 Stat. 3269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e0f3f3-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80e0f3f4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80e0f3f5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"