{"tag":"section","attrib":{"id":"id80c8ff10-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8143"},"text":null,"children":[{"tag":"num","attrib":{"value":"8143"},"text":"§ 8143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Heat","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c8ff11-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corcoran Gallery of Art","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of General Services may furnish heat from the central heating plant to the Corcoran Gallery of Art, if the Corcoran Gallery of Art agrees to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c8ff12-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8143/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay for heat furnished at rates the Administrator determines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c8ff13-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8143/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" connect the building with the Federal Government mains in a manner satisfactory to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c8ff14-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board of Governors of the Federal Reserve System","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may furnish steam from the central heating plant for the use of the Board of Governors of the Federal Reserve System on the property which the Board acquired in squares east of 87 and east of 88 in the District of Columbia if the Board agrees to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c8ff15-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8143/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay for the steam furnished at reasonable rates the Administrator determines but that are at least equal to cost; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c8ff16-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8143/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the necessary connections with the Government mains at its own expense and in a manner satisfactory to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c8ff17-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8143/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-Federal Public Buildings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall determine the rates to be paid for steam furnished to the Corcoran Gallery of Art, the Pan American Union Buildings, the American Red Cross Buildings, and other non-federal public buildings authorized to receive steam from the central heating plant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c8ff18-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1208"},"text":"116 Stat. 1208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c8ff19-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c8ff1a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c8ff1b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8143(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:22a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1934-06-19/ch648"},"text":"June 19, 1934, ch. 648","children":[],"tail":" (last par. on p. 1044), "},{"tag":"html:a","attrib":{"href":"/us/stat/48/1044"},"text":"48 Stat. 1044","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8143(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:22b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1935-06-27/ch320"},"text":"June 27, 1935, ch. 320","children":[],"tail":", §§ 1, 2, "},{"tag":"html:a","attrib":{"href":"/us/stat/49/425"},"text":"49 Stat. 425","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8143(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:22c.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Administrator of General Services” are substituted for “Treasury Department”, “Secretary of the Treasury”, and [“]Public Works Branch, Procurement Division, Treasury Department” [subsequently changed to “Federal Works Agency”, [“]Federal Works Administrator”, and “Public Buildings Administration, Federal Works Agency”, respectively, because of sections 301 and 303 of Reorganization Plan No. I of 1939 (eff. ","children":[{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1426"},"text":"53 Stat. 1426","children":[],"tail":", 1427)] because of section 103(a) of the Federal Property and Administrative Services Act of 1949 (ch. 288, "},{"tag":"ref","attrib":{"href":"/us/stat/63/380"},"text":"63 Stat. 380","children":[],"tail":"), which is restated as section 303(c) [303(b)] of the revised title. In clause (1), the words “not less than cost” are omitted because of 40:22c, restated as subsection (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (c), the word “Administrator” is substituted for “Secretary of the Interior, through the National Park Service” and “Secretary of the Interior” [both subsequently changed to “Federal Works Administrator” because of sections 301 and 303 of Reorganization Plan No. I of 1939 (eff. ","children":[{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1426"},"text":"53 Stat. 1426","children":[],"tail":", 1427)] because of section 103(a) of the Federal Property and Administrative Services Act of 1949 (ch. 288, "},{"tag":"ref","attrib":{"href":"/us/stat/63/380"},"text":"63 Stat. 380","children":[],"tail":"), which is restated as section 303(c) [303(b)] of the revised title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “Board of Governors of the Federal Reserve System” are substituted for “Federal Reserve Board” because of section 203(a) of the Banking Act of 1935 (ch. 614, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/49/704"},"text":"49 Stat. 704","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “On and after June 27” are omitted as obsolete. The words “the Pan American Union buildings” are substituted for “the buildings, old and new, of the Pan American Union” for clarity. The words “as are or hereafter may be” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
