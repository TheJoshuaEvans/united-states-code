d for “Postmaster General” because of section 4(a) of the Postal Reorganization Act ("},{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Public Law 91–375","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/773"},"text":"84 Stat. 773","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80c8febf-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80c8fec0-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284"},"text":"Pub. L. 109–284","children":[],"tail":" substituted “post office” for “post-office”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
