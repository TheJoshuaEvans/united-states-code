{"tag":"section","attrib":{"id":"id80e81fc8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902"},"text":null,"children":[{"tag":"num","attrib":{"value":"15902"},"text":"§ 15902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration health projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e81fc9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To demonstrate the value of adequate health facilities and services to the economic development of the region, a Commission may make grants for the planning, construction, equipment, and operation of demonstration health, nutrition, and child care projects to serve distressed areas (referred to in this section as a “demonstration health project”), including hospitals, regional health diagnostic and treatment centers, and other facilities and services necessary for the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81fca-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Entities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity eligible to receive a grant under this section is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81fcb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity described in section 15501(a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fcc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (as defined in section 101(a) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"20 U.S.C. 1001(a)","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fcd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a hospital (as defined in section 1861 of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x"},"text":"42 U.S.C. 1395x","children":[],"tail":")); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fce-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a critical access hospital (as defined in that section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81fcf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81fd0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Commission may make grants for planning expenses necessary for the development and operation of demonstration health projects for the region served by the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fd1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum commission contribution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum Commission contribution for a demonstration health project that receives a grant under paragraph (1) shall be made in accordance with section 15501(d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fd2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources of assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grant under paragraph (1) may be provided entirely from amounts made available to carry out this section or in combination with amounts provided under other Federal grant programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fd3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal share for grants under other federal grant programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of law limiting the Federal share in other Federal grant programs, amounts made available to carry out this subsection may be used to increase the Federal share of another Federal grant up to the maximum contribution described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81fd4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction and Equipment Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81fd5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant under this section for construction or equipment of a demonstration health project may be used for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e81fd6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs of construction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e81fd7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the acquisition of privately owned facilities—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80e81fd8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not operated for profit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e81fd9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" previously operated for profit if the Commission finds that health services would not otherwise be provided in the area served by the facility if the acquisition is not made; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e81fda-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of initial equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fdb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards for making grants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e81fdc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be approved in accordance with section 15503; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e81fdd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be incompatible with the applicable provisions of title VI of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s291"},"text":"42 U.S.C. 291","children":[],"tail":" et seq.), the Developmental Disabilities Assistance and Bill of Rights Act of 2000 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15001"},"text":"42 U.S.C. 15001","children":[],"tail":" et seq.), and other laws authorizing grants for the construction of health-related facilities, without regard to any provisions in those laws relating to appropriation authorization ceilings or to allotments among the States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fde-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum commission contribution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum Commission contribution for a demonstration health project that receives a grant under paragraph (1) shall be made in accordance with section 15501(d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fdf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources of assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grant under paragraph (1) may be provided entirely from amounts made available to carry out this section or in combination with amounts provided under other Federal grant programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fe0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contribution to increased federal share for other federal grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of law limiting the Federal share in another Federal grant program for the construction or equipment of a demonstration health project, amounts made available to carry out this subsection may be used to increase Federal grants for component facilities of a demonstration health project to a maximum of 90 percent of the cost of the facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81fe1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81fe2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant under this section for the operation of a demonstration health project may be used for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e81fe3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of operation of the facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e81fe4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initial operating costs, including the costs of attracting, training, and retaining qualified personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fe5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards for making grants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant for the operation of a demonstration health project shall not be made unless the facility funded by the grant is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e81fe6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publicly owned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e81fe7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by a public or private nonprofit organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e81fe8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private hospital described in section 501(c)(3) of the Internal Revenue Code of 1986 and exempt from taxation under section 501(a) of that Code; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e81fe9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private hospital that provides a certain amount of uncompensated care, as determined by the Commission, and applies for the grant in partnership with a State, local government, or Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fea-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum commission contribution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum Commission contribution for a demonstration health project that receives a grant under paragraph (1) shall be made in accordance with section 15501(d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81feb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources of assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grant under paragraph (1) may be provided entirely from amounts made available to carry out this section or in combination with amounts provided under other Federal grant programs for the operation of health-related facilities or the provision of health and child development services, including parts A and B of title IV and title XX of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq., 621 et seq., 1397 et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fec-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of law limiting the Federal share in the other Federal programs described in paragraph (4), amounts made available to carry out this subsection may be used to increase the Federal share of a grant under those programs up to the maximum contribution described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e81fed-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority Health Programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a Commission elects to make grants under this section, the Commission shall establish specific regional health priorities for such grants that address—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e81fee-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addiction treatment and access to resources helping individuals in recovery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81fef-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" workforce shortages in the healthcare industry; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e81ff0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15902/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to services for screening and diagnosing chronic health issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e81ff1-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2248/a"},"text":"Pub. L. 118–272, div. B, title II, § 2248(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3207"},"text":"138 Stat. 3207","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e81ff2-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80e81ff3-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80e81ff4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Public Health Service Act, referred to in subsec. (d)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":". Title VI of the Act is classified generally to subchapter IV (§ 291 et seq.) of chapter 6A of Title 42. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Developmental Disabilities Assistance and Bill of Rights Act of 2000, referred to in subsec. (d)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402"},"text":"Pub. L. 106–402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1677"},"text":"114 Stat. 1677","children":[],"tail":", which is classified principally to chapter 144 (§ 15001 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15001"},"text":"section 15001 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 501 of the Internal Revenue Code of 1986, referred to in subsec. (e)(2)(C), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501"},"text":"section 501 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (e)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Parts A and B of title IV of the Act are classified ge