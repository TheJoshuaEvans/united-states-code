{"tag":"section","attrib":{"id":"id80a7ba78-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s591"},"text":null,"children":[{"tag":"num","attrib":{"value":"591"},"text":"§ 591.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of electricity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80a7ba79-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s591/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Limitation on Use of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A department, agency, or instrumentality of the Federal Government may not use amounts appropriated or made available by any law to purchase electricity in a manner inconsistent with state law governing the provision of electric utility service, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a7ba7a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s591/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state utility commission rulings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba7b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s591/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electric utility franchises or service territories established under state statute, state regulation, or state-approved territorial agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80a7ba7c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s591/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80a7ba7d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s591/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Energy savings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not preclude the head of a federal agency from entering into a contract under section 801 of the National Energy Conservation Policy Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8287"},"text":"42 U.S.C. 8287","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80a7ba7e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s591/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Energy savings for military installations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not preclude the Secretary of a military department from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80a7ba7f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s591/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entering into a contract under section 2394 ","children":[{"tag":"ref","attrib":{"idref":"fn002012"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002012"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 10; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80a7ba80-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s591/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchasing electricity from any provider if the Secretary finds that the utility having the applicable state-approved franchise (or other service authorization) is unwilling or unable to meet unusual standards of service reliability that are necessary for purposes of national defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80a7ba81-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1118"},"text":"116 Stat. 1118","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80a7ba82-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80a7ba83-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80a7ba84-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"591","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:490 note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/100/202/s101/b/tVIII/s8093"},"text":"Pub. L. 100–202, § 101(b) [title VIII, § 8093]","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1329-79"},"text":"101 Stat. 1329–79","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “section 801 of the National Energy Conservation Policy Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8287"},"text":"42 U.S.C. 8287","children":[],"tail":")” are substituted for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8287"},"text":"42 U.S.C. 8287","children":[],"tail":"” in section 8093 of the Department of Defense Appropriations Act, 1988 as the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80a7ba85-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80a7ba86-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2394"},"text":"Section 2394 of title 10","children":[],"tail":", referred to in subsec. (b)(2)(A), was renumbered section 2922a of such title by "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dB/tXXVIII/s2851/b/2"},"text":"Pub. L. 109–364, div. B, title XXVIII, § 2851(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2494"},"text":"120 Stat. 2494","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
