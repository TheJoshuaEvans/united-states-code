{"tag":"section","attrib":{"id":"id80c6b554-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6906"},"text":null,"children":[{"tag":"num","attrib":{"value":"6906"},"text":"§ 6906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Union Station Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c6b555-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is a special deposit account in the Treasury known as the “Union Station Fund”, which shall be administered as a revolving fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c6b556-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The account shall be credited with receipts of the Secretary of Transportation from activities authorized by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c6b557-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may use income and proceeds received from activities authorized by this subchapter, including operating and leasing income and payments made to the Federal Government under development agreements, to pay expenses the Secretary incurs in carrying out the purposes of this subchapter, including construction, acquisition, leasing, operation, and maintenance expenses and payments made to developers under development agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c6b558-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6906/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The balance in the account is available in amounts specified in annual appropriation laws for making expenditures authorized by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c6b559-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1202"},"text":"116 Stat. 1202","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c6b55a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c6b55b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c6b55c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag