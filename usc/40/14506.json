{"tag":"section","attrib":{"id":"id80e0f3b7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506"},"text":null,"children":[{"tag":"num","attrib":{"value":"14506"},"text":"§ 14506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional skills partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e0f3b8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Entity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible entity” means a consortium that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f3b9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is established to serve one or more industries in a specified geographic area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3ba-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consists of representatives of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e0f3bb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" businesses (or a nonprofit organization that represents businesses);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e0f3bc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" labor organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e0f3bd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local governments; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e0f3be-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f3bf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Projects To Be Assisted","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Appalachian Regional Commission may provide technical assistance, make grants, enter into contracts, or otherwise provide amounts to eligible entities in the region for projects to improve the job skills of workers for a specified industry, including projects for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f3c0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assessment of training and job skill needs for the industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3c1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of curricula and training methods, including, in appropriate cases, electronic learning or technology-based training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3c2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of training providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3c3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of partnerships between the industry and educational institutions, including community colleges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3c4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of apprenticeship programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3c5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of training programs for workers, including dislocated workers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3c6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of training plans for businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f3c7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An eligible entity may use not more than 10 percent of amounts made available to the eligible entity under subsection (b) to pay administrative costs associated with the projects described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f3c8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Available Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the cost of any activity eligible for a grant under this section, not more than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f3c9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent may be provided from amounts appropriated to carry out this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3ca-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which a distressed county designation is in effect under section 14526, 80 percent may be provided from amounts appropriated to carry out this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3cb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which an at-risk county designation is in effect under section 14526, 70 percent may be provided from amounts appropriated to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f3cc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Assistance under this section may be provided entirely from amounts made available to carry out this section, in combination with amounts made available under other federal programs, or from any other source.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f3cd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14506/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of law limiting the federal share under any other federal program, amounts made available to carry out this section may be used to increase that Federal share, as the Commission decides is appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e0f3ce-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1271"},"text":"116 Stat. 1271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/371/s2/f"},"text":"Pub. L. 110–371, § 2(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4039"},"text":"122 Stat. 4039","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e0f3cf-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80e0f3d0-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80e0f3d1-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","childre