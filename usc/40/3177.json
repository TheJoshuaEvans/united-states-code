{"tag":"section","attrib":{"id":"id80b5ec64-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177"},"text":null,"children":[{"tag":"num","attrib":{"value":"3177"},"text":"§ 3177.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of photovoltaic energy in public buildings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80b5ec65-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Photovoltaic Energy Commercialization Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b5ec66-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services may establish a photovoltaic energy commercialization program for the procurement and installation of photovoltaic solar electric systems for electric production in new and existing public buildings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b5ec67-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the program shall be to accomplish the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80b5ec68-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To accelerate the growth of a commercially viable photovoltaic industry to make this energy system available to the general public as an option which can reduce the national consumption of fossil fuel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b5ec69-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To reduce the fossil fuel consumption and costs of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b5ec6a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To attain the goal of installing solar energy systems in 20,000 Federal buildings by 2010, as contained in the Federal Government’s Million Solar Roof Initiative of 1997.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b5ec6b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To stimulate the general use within the Federal Government of life-cycle costing and innovative procurement methods.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b5ec6c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop program performance data to support policy decisions on future incentive programs with respect to energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b5ec6d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition of photovoltaic solar electric systems.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80b5ec6e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The program shall provide for the acquisition of photovoltaic solar electric systems and associated storage capability for use in public buildings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b5ec6f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition levels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The acquisition of photovoltaic electric systems shall be at a level substantial enough to allow use of low-cost production techniques with at least 150 megawatts (peak) cumulative acquired during the 5 years of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b5ec70-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall administer the program and shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80b5ec71-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue such rules and regulations as may be appropriate to monitor and assess the performance and operation of photovoltaic solar electric systems installed pursuant to this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b5ec72-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop innovative procurement strategies for the acquisition of such systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80b5ec73-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit to Congress an annual report on the results of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b5ec74-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Photovoltaic Systems Evaluation Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b5ec75-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date of enactment of this section, the Administrator shall establish a photovoltaic solar energy systems evaluation program to evaluate such photovoltaic solar energy systems as are required in public buildings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b5ec76-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In evaluating photovoltaic solar energy systems under the program, the Administrator shall ensure that such systems reflect the most advanced technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b5ec77-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80b5ec78-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Photovoltaic energy commercialization program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated to carry out subsection (a) $50,000,000 for each of fiscal years 2006 through 2010. Such sums shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80b5ec79-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3177/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Photovoltaic systems evaluation program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated to carry out subsection (b) $10,000,000 for each of fiscal years 2006 through 2010. Such sums shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b5ec7a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s204/a"},"text":"Pub. L. 109–58, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/653"},"text":"119 Stat. 653","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b5ec7b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80b5ec7c-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80b5ec7d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (b)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
