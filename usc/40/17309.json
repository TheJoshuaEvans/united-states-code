{"tag":"section","attrib":{"id":"id80ea694c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17309"},"text":null,"children":[{"tag":"num","attrib":{"value":"17309"},"text":"§ 17309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80ea694d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With the approval of the President, the Secretary of the Treasury may prescribe regulations necessary to carry out the duties and powers vested in the Secretary under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ea694e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Providing Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To carry out subsection (a), the Secretary may require a person making a shipment of valuables or a claim for replacement to make a declaration or to provide other information the Secretary considers necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ea694f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1283"},"text":"116 Stat. 1283","children":[],"tail":".)"}],"tail":"\n"},{"tag"