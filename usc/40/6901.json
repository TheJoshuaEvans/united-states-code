{"tag":"section","attrib":{"id":"id80c6b532-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6901"},"text":null,"children":[{"tag":"num","attrib":{"value":"6901"},"text":"§ 6901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In this subchapter, the term “Union Station complex” means real property, air rights, and improvements the Secretary of the Interior leased under sections 101–110 of the National Visitors Center Facilities Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/264"},"text":"Public Law 90–264","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/43"},"text":"82 Stat. 43","children":[],"tail":") and property acquired and improvements made in accordance with this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id80c6b533-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1201"},"text":"116 Stat. 1201","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c6b534-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c6b535-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c6b536-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"