 § 3(3)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/1668"},"text":"95 Stat. 1668","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80c6b537-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80c6b538-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 101–110 of the National Visitors Center Facilities Act of 1968, referred to in text, are sections 101 to 110 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/264/tI"},"text":"Pub. L. 90–264, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-03-12"},"text":"Mar. 12, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/43-45"},"text":"82 Stat. 43–45","children":[],"tail":", which were classified principally to part A (§ 801 et seq.) of subchapter I of chapter 18 of former Title 40, Public Buildings, Property, and Works, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s6/b"},"text":"Pub. L. 107–217, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1304"},"text":"116 Stat. 1304","children":[],"tail":". Section 104 of the Act was classified as a note under section 804 of former Title 40 prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":". Section 108 of the Act was not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80c6b539-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80c6b53a-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sale of Air Rights","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIX/s9102"},"text":"Pub. L. 105–33, title IX, § 9102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/670"},"text":"111 Stat. 670","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/33/tIX/s9102"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, the Administrator of General Services shall sell, at fair market value and in a manner to be determined by the Administrator, the air rights adjacent to Washington Union Station described in subsection (b), including air rights conveyed to the Administrator under subsection (d). The Administrator shall complete the sale by such date as is necessary to ensure that the proceeds from the sale will be deposited in accordance with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The air rights referred to in subsection (a) total approximately 16.5 acres and are depicted on the plat map of the District of Columbia as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part of lot 172, square 720.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part of lots 172 and 823, square 720.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part of lot 811, square 717.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proceeds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before ","children":[{"tag":"date","attrib":{"date":"2002-09-30"},"text":"September 30, 2002","children":[],"tail":", proceeds from the sale of air rights under subsection (a) shall be deposited in the general fund of the Treasury and credited as miscellaneous receipts."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conveyance of Amtrak Air Rights.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As a condition of future Federal financial assistance, Amtrak shall convey to the Administrator of General Services on or before ","children":[{"tag":"date","attrib":{"date":"1997-12-31"},"text":"December 31, 1997","children":[],"tail":", at no charge, all of the air rights of Amtrak described in subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure to comply","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If Amtrak does not meet the condition established by paragraph (1), Amtrak shall be prohibited from obligating Federal funds after ","children":[{"tag":"date","attrib":{"date":"1998-03-01"},"text":"March 1, 1998","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80c6b53b-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Capitol Grounds; Erection of Flagpoles and Improvement of Traffic","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/320"},"text":"Pub. L. 94–320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-25"},"text":"June 25, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/711"},"text":"90 Stat. 711","children":[],"tail":", authorized the Secretary of the Interior, upon approval and subject to conditions of the Architect of the Capitol, in the portion of the United States Capitol Grounds in close proximity to the sidewalks abutting the circular perimeter of the Union Station Plaza in front of Columbus Plaza and the National Visitor Center, to erect and maintain flagpoles to fly the flags of each of the States of the United States and its territories and possessions, and to enter into an agreement with the appropriate officials of the District of Columbia to permit the District of Columbia to use certain areas of the United States Capitol Grounds to make certain street changes to coordinate and improve the flow of traffic in and around the United States Capitol Grounds, the National Visitor Center (formerly Union Station), and Union Station Plaza."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
