:[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:123.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1932-05-20/ch197/s2"},"text":"May 20, 1932, ch. 197, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/47/162"},"text":"47 Stat. 162","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “National Capital Planning Commission” are substituted for “National Capital Park and Planning Commission” because of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-06-06/s9"},"text":"section 9 of the Act of June 6, 1924","children":[],"tail":" (ch. 270), as added by "},{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/s1"},"text":"section 1 of the Act of July 19, 1952","children":[],"tail":" (ch. 949, "},{"tag":"ref","attrib":{"href":"/us/stat/66/790"},"text":"66 Stat. 790","children":[],"tail":"). See section 8711(f) of the revised title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “but all such laws shall remain in full force and effect” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
