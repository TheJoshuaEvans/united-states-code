{"tag":"section","attrib":{"id":"id80c8fee8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8124"},"text":null,"children":[{"tag":"num","attrib":{"value":"8124"},"text":"§ 8124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of jurisdiction between Federal and District of Columbia authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c8fee9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8124/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Federal and District of Columbia authorities administering properties in the District that are owned by the Federal Government or by the District may transfer jurisdiction over any part of the property among or between themselves for purposes of administration and maintenance under conditions the parties agree on. The National Capital Planning Commission shall recommend the transfer before it is completed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c8feea-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8124/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The District authorities shall report all transfers and agreements to Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c8feeb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8124/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Laws Not Repealed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not repeal any law in effect on ","children":[{"tag":"date","attrib":{"date":"1932-05-20"},"text":"May 20, 1932","children":[],"tail":", which authorized the transfer of jurisdiction of certain land among and between federal and District authorities."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c8feec-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1207"},"text":"116 Stat. 1207","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c8feed-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c8feee-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c8feef-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,