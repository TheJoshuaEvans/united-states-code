"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/99/652/s1"},"text":"Pub. L. 99–652, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3650"},"text":"100 Stat. 3650","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80cde071-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80cde072-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126"},"text":"Pub. L. 108–126","children":[],"tail":" substituted “Columbia and its environs, and to encourage the location of commemorative works within the urban fabric of the District of Columbia;” for “Columbia;”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80cde073-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id80cde074-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126/tII/s205"},"text":"Pub. L. 108–126, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-17"},"text":"Nov. 17, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1353"},"text":"117 Stat. 1353","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/126/tII/s205"},"text":"“Except for the provision in the amendment made by section 202(b) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s8908"},"text":"section 8908 of this title","children":[],"tail":"] prohibiting a visitor center from being located in the Reserve (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s8902"},"text":"section 8902 of title 40","children":[],"tail":", United States Code), nothing in this title [see Short Title of 2003 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s101"},"text":"section 101 of this title","children":[],"tail":"] shall apply to a commemorative work for which a site was approved in accordance with chapter 89 of title 40, United States Code, prior to the date of enactment of this title ["},{"tag":"date","attrib":{"date":"2003-11-17"},"text":"Nov. 17, 2003","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80cde075-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126/tII/s202/a"},"text":"Pub. L. 108–126, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-17"},"text":"Nov. 17, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1349"},"text":"117 Stat. 1349","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/126/tII/s202/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the great cross-axis of the Mall in the District of Columbia, which generally extends from the United States Capitol to the Lincoln Memorial, and from the White House to the Jefferson Memorial, is a substantially completed work of civic art; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve the integrity of the Mall, a reserve area should be designated within the core of the great cross-axis of the Mall where the siting of new commemorative works is prohibited.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
