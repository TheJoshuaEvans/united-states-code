{"tag":"section","attrib":{"id":"id80cde066-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8901"},"text":null,"children":[{"tag":"num","attrib":{"value":"8901"},"text":"§ 8901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80cde067-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve the integrity of the comprehensive design of the L’Enfant and McMillan plans for the Nation’s Capital;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cde068-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure the continued public use and enjoyment of open space in the District of Columbia and its environs, and to encourage the location of commemorative works within the urban fabric of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cde069-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve, protect and maintain the limited amount of open space available to residents of, and visitors to, the Nation’s Capital; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80cde06a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8901/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to ensure that future commemorative works in areas administered by the National Park Service and the Administrator of General Services in the District of Columbia and its environs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80cde06b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8901/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are appropriately designed, constructed, and located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80cde06c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8901/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect a consensus of the lasting national significance of the subjects involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80cde06d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1227"},"text":"116 Stat. 1227","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/126/tII/s203/a"},"text":"Pub. L. 108–126, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-17"},"text":"Nov. 17, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1349"},"text":"117 Stat. 1349","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80cde06e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80cde06f-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80cde070-3a70-11f1-b817-c08bf6d1fe