{"tag":"section","attrib":{"id":"id80bd1730-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3702"},"text":null,"children":[{"tag":"num","attrib":{"value":"3702"},"text":"§ 3702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Work hours","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80bd1731-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standard Workweek","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The wages of every laborer and mechanic employed by any contractor or subcontractor in the performance of work on a contract described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3701"},"text":"section 3701 of this title","children":[],"tail":" shall be computed on the basis of a standard workweek of 40 hours. Work in excess of the standard workweek is permitted subject to this section. For each workweek in which the laborer or mechanic is so employed, wages include compensation, at a rate not less than one and one-half times the basic rate of pay, for all hours worked in excess of 40 hours in the workweek."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bd1732-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contract described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3701"},"text":"section 3701 of this title","children":[],"tail":", and any obligation of the Federal Government, a territory of the United States, or the District of Columbia in connection with that contract, must provide that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bd1733-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contractor or subcontractor contracting for any part of the contract work which may require or involve the employment of laborers or mechanics shall not require or permit any laborer or mechanic, in any workweek in which the laborer or mechanic is employed on that work, to work more than 40 hours in that workweek, except as provided in this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bd1734-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" when a violation of clause (1) occurs, the contractor and any subcontractor responsible for the violation are liable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80bd1735-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3702/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the affected employee for the employee’s unpaid wages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bd1736-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3702/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Government, the District of Columbia, or a territory for liquidated damages as provided in the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bd1737-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liquidated Damages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Liquidated damages under subsection (b)(2)(B) shall be computed for each individual employed as a laborer or mechanic in violation of this chapter and shall be equal to $10 for each calendar day on which the individual was required or permitted to work in excess of the standard workweek without payment of the overtime wages required by this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bd1738-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amounts Withheld To Satisfy Liabilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3703"},"text":"section 3703 of this title","children":[],"tail":", the governmental agency for which the contract work is done or which is providing financial assistance for the work may withhold, or have withheld, from money payable because of work performed by a contractor or subcontractor, amounts administratively determined to be necessary to satisfy the liabilities of the contractor or subcontractor for unpaid wages and liquidated damages as provided in this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80bd1739-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1169"},"text":"116 Stat. 1169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s6/15"},"text":"Pub. L. 109–284, § 6(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1213"},"text":"120 Stat. 1213","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80bd173a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80bd173b-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80bd173c-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","child