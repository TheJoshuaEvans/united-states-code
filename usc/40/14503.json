{"tag":"section","attrib":{"id":"id80e0f36a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503"},"text":null,"children":[{"tag":"num","attrib":{"value":"14503"},"text":"§ 14503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for proposed low- and middle-income housing projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e0f36b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appalachian Housing Fund.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f36c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is an Appalachian Housing Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f36d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Source and use of amounts in fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts allocated to the Secretary of Housing and Urban Development for the purposes of this section shall be deposited in the Fund. The Secretary shall use the Fund as a revolving fund to carry out those purposes. Amounts in the Fund not needed for current operation may be invested in bonds or other obligations the Federal Government guarantees as to principal and interest. General expenses of administration of this section may be charged to the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f36e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To encourage and facilitate the construction or rehabilitation of housing to meet the needs of low- and moderate-income families and individuals, the Secretary may make grants and loans from the Fund, under terms and conditions the Secretary may prescribe. The grants and loans may be made to nonprofit, limited dividend, or cooperative organizations and public bodies and are for planning and obtaining federally insured mortgage financing or other financial assistance for housing construction or rehabilitation projects for low- and moderate-income families and individuals, in any area of the Appalachian region the Appalachian Regional Commission establishes, under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f36f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 221 of the National Housing Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715"},"text":"12 U.S.C. 1715","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f370-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 8 of the United States Housing Act of 1937 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"42 U.S.C. 1437f","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f371-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 515 of the Housing Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1485"},"text":"42 U.S.C. 1485","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f372-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other law of similar purpose administered by the Secretary or any other department, agency, or instrumentality of the Federal Government or a state government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f373-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Providing Amounts to States for Grants and Loans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or the Commission may provide amounts to the States for making grants and loans to nonprofit, limited dividend, or cooperative organizations and public bodies for the purposes for which the Secretary may provide amounts under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f374-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loans.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f375-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on available amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A loan under subsection (b) for the cost of planning and obtaining financing (including the cost of preliminary surveys and analyses of market needs, preliminary site engineering and architectural fees, site options, application and mortgage commitment fees, legal fees, and construction loan fees and discounts) of a project described in that subsection may be made for up to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e0f376-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of that cost;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e0f377-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which a distressed county designation is in effect under section 14526, 80 percent of that cost; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e0f378-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out for a county for which an at-risk county designation is in effect under section 14526, 70 percent of that cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f379-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A loan shall be made without interest, except that a loan made to an organization established for profit shall bear interest at the prevailing market rate authorized for an insured or guaranteed loan for that type of project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f37a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require payment of a loan made under this section, under terms and conditions the Secretary may require, no later than on completion of the project. Except for a loan to an organization established for profit, the Secretary may cancel any part of a loan made under this section on determining that a permanent loan to finance the project cannot be obtained in an amount adequate for repayment of a loan made under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f37b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f37c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant under this section for expenses incidental to planning and obtaining financing for a project under this section that the Secretary considers to be unrecoverable from the proceeds of a permanent loan made to finance the project shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e0f37d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be made to an organization established for profit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e0f37e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as provided in paragraph (2), not exceed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80e0f37f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of those expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e0f380-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which a distressed county designation is in effect under section 14526, 80 percent of those expenses; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e0f381-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which an at-risk county designation is in effect under section 14526, 70 percent of those expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f382-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Site development costs and offsite improvements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make grants and commitments for grants, and may advance amounts under terms and conditions the Secretary may require, to nonprofit, limited dividend, or cooperative organizations and public bodies for reasonable site development costs and necessary offsite improvements, such as sewer and water line extensions, when the grant, commitment, or advance is essential to the economic feasibility of a housing construction or rehabilitation project for low- and moderate-income families and individuals which otherwise meets the requirements for assistance under this section. A grant under this paragraph for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e0f383-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction of housing shall not be more than 10 percent of the cost of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e0f384-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rehabilitation of housing shall not be more than 10 percent of the reasonable value of the rehabilitation housing, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f385-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information, Advice, and Technical Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or the Commission may provide, or contract with public or private organizations to provide, information, advice, and technical assistance with respect to the construction, rehabilitation, and operation by nonprofit organizations of housing for low- or moderate- income families in areas of the region the Commission establishes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f386-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14503/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Certain Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Programs and projects assisted under this section are subject to the provisions cited in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14701"},"text":"section 14701 of this title","children":[],"tail":" to the extent provided in the laws authorizing assistance for low- and moderate-income housing."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e0f387-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1268"},"text":"116 Stat. 1268","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/371/s2/c"},"text":"Pub. L. 110–371, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4038"},"text":"122 Stat. 4038","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e0f388-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80e0f389-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80e0f38a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"14503(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 App.:207(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/4/tII/s207"},"text":"Pub. L. 89–4, title II, § 207","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/90/103/tI/s112"},"text":"Pub. L. 90–103, title I, § 112","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 11, 1967","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/81/261"},"text":"81 Stat. 261","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/90/448/tII/s201/f"},"text":"Pub. L. 90–448, title II, § 201(f)","children":[],"tail":", "},{"tag":"ht