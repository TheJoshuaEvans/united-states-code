proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) is added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before clause (A), the words “except as otherwise provided” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), before clause (A), the words “Except as otherwise expressly provided” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3)(A)(ii), the words “Walsh-Healey Act” are substituted for [“]Walsh-Healey Public Contracts Act” to use the correct short title of the Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80bd172d-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80bd172e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Contract Work Hours and Safety Standards Act, referred to in subsec. (a), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/581"},"text":"Pub. L. 87–581","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-08-13"},"text":"Aug. 13, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/357"},"text":"76 Stat. 357","children":[],"tail":", which was classified generally to subchapter II (§ 327 et seq.) of chapter 5 of former Title 40, Public Buildings, Property, and Works, prior to repeal and reenactment as this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", §§ 1, 6(b), "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1062"},"text":"116 Stat. 1062","children":[],"tail":", 1304. "},{"tag":"ref","attrib":{"href":"/us/pl/87/581/tI/s101"},"text":"Section 101 of title I of Pub. L. 87–581","children":[],"tail":" was classified to section 327 of former Title 40 and was repealed and not reenacted by "},{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80bd172f-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(3)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":" substituted “chapter 65 of title 41” for “the Walsh-Healey Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s35"},"text":"41 U.S.C. 35","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284"},"text":"Pub. L. 109–284","children":[],"tail":" substituted “3702” for “3902” in heading and text and “paragraph (1)(B)(iii)” for “subsection (a)(2)(C)” in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
