{"tag":"section","attrib":{"id":"id80bace24-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701"},"text":null,"children":[{"tag":"num","attrib":{"value":"3701"},"text":"§ 3701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition and application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80bace25-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this chapter, the term “Federal Government” has the same meaning that the term “United States” had in the Contract Work Hours and Safety Standards Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/581"},"text":"Public Law 87–581","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/357"},"text":"76 Stat. 357","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80bace26-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80bace27-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter applies to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80bace28-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contract that may require or involve the employment of laborers or mechanics on a public work of the Federal Government, a territory of the United States, or the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bace29-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any other contract that may require or involve the employment of laborers or mechanics if the contract is one—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80bace2a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which the Government, an agency or instrumentality of the Government, a territory, or the District of Columbia is a party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80bace2b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is made for or on behalf of the Government, an agency or instrumentality, a territory, or the District of Columbia; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80bace2c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is a contract for work financed at least in part by loans or grants from, or loans insured or guaranteed by, the Government or an agency or instrumentality under any federal law providing wage standards for the work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bace2d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Laborers and mechanics","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter applies to all laborers and mechanics employed by a contractor or subcontractor in the performance of any part of the work under the contract—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80bace2e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" including watchmen, guards, and workers performing services in connection with dredging or rock excavation in any river or harbor of the United States, a territory, or the District of Columbia; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bace2f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not including an employee employed as a seaman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80bace30-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80bace31-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"This chapter","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter does not apply to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80bace32-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a contract for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id80bace33-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation by land, air, or water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id80bace34-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transmission of intelligence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id80bace35-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/3/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of supplies or materials or articles ordinarily available in the open market;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80bace36-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any work required to be done in accordance with the provisions of chapter 65 of title 41; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80bace37-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract in an amount that is not greater than $100,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80bace38-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3701/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Section 3702","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3702"},"text":"Section 3702 of this title","children":[],"tail":" does not apply to work where the assistance described in paragraph (1)(B)(iii) from the Government or an agency or instrumentality is only a loan guarantee or insurance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80bace39-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1169"},"text":"116 Stat. 1169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s6/14"},"text":"Pub. L. 109–284, § 6(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1213"},"text":"120 S