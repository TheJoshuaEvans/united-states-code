"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/479"},"text":"73 Stat. 479","children":[],"tail":") because of section 4(a) of the Postal Reorganization Act ("},{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Public Law 91–375","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/773"},"text":"84 Stat. 773","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80b85cd4-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80b85cd5-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":" substituted “division C (except sections 3302, 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41” for “title III of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s251"},"text":"41 U.S.C. 251","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/178"},"text":"Pub. L. 108–178","children":[],"tail":" inserted “, by purchase, condemnation, donation, exchange, or otherwise,” after “The Administrator may acquire”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80b85cd6-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id80b85cd7-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/178"},"text":"Pub. L. 108–178","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/178/s5"},"text":"section 5 of Pub. L. 108–178","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5334"},"text":"section 5334 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
