{"tag":"section","attrib":{"id":"id80e33d0e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14510"},"text":null,"children":[{"tag":"num","attrib":{"value":"14510"},"text":"§ 14510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug abuse mitigation initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e33d0f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14510/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Appalachian Regional Commission may provide technical assistance to, make grants to, enter into contracts with, or otherwise provide amounts to individuals or entities in the Appalachian region for projects and activities to address drug abuse, including opioid abuse, in the region, including projects and activities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33d10-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14510/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the sharing of best practices among States, counties, and other experts in the region with respect to reducing such abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d11-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14510/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to initiate or expand programs designed to eliminate or reduce the harm to the workforce and economic growth of the region that results from such abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d12-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14510/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to attract and retain relevant health care services, businesses, and workers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d13-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14510/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop relevant infrastructure, including broadband infrastructure that supports the use of telemedicine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d14-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14510/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Available Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the cost of any activity eligible for a grant under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33d15-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14510/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 50 percent may be provided from amounts appropriated to carry out this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d16-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14510/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notwithstanding paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e33d17-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14510/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which a distressed county designation is in effect under section 14526, not more than 80 percent may be provided from amounts appropriated to carry out this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e33d18-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14510/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which an at-risk designation is in effect under section 14526, not more than 70 percent may be provided from amounts appropriated to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d19-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14510/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), a grant provided under this section may be provided from amounts made available to carry out this section in combination with amounts made available—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33d1a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14510/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under any other Federal program (subject to the availability of subsequent appropriations); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33d1b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14510/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from any other source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e33d1c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14510/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of law limiting the Federal share under any other Federal program, amounts made available to carry out this section may be used to increase that Federal share, as the Appalachian Regional Commission determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e33d1d-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVIII/s8062/a"},"text":"Pub. L. 115–271, title VIII, § 8062(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4094"},"text":"132 Stat. 4094","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
