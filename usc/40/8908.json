{"tag":"section","attrib":{"id":"id80d02ae5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8908"},"text":null,"children":[{"tag":"num","attrib":{"value":"8908"},"text":"§ 8908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas I and II","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80d02ae6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Map","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Interior or the Administrator of General Services (as appropriate) shall make available, for public inspection at appropriate offices of the National Park Service and the General Services Administration, the map entitled “Commemorative Areas Washington, DC and Environs”, numbered 869/86501 B, and dated ","children":[{"tag":"date","attrib":{"date":"2003-06-24"},"text":"June 24, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d02ae7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specific Conditions Applicable to Area I and Area II.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80d02ae8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8908/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Area i","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After seeking the advice of the National Capital Memorial Advisory Commission, the Secretary or Administrator, as appropriate, may recommend the location of a commemorative work in Area I only if the Secretary or Administrator decides that the subject of the commemorative work is of preeminent historical and lasting significance to the United States. The Secretary or Administrator shall notify the Commission, the Committee on Natural Resources of the House of Representatives, and the Committee on Energy and Natural Resources of the Senate of the recommendation that a commemorative work should be located in Area I. The location of a commemorative work in Area I is deemed to be authorized only if the recommendation is approved by law not later than 150 calendar days after the notification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02ae9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8908/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Area ii","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Commemorative works of subjects of lasting historical significance to the American people may be located in Area II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d02aea-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reserve","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After the date of enactment of the Commemorative Works Clarification and Revision Act of 2003, no commemorative work or visitor center shall be located within the Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80d02aeb-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1231"},"text":"116 Stat. 1231","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/126/tII"},"text":"Pub. L. 108–126, title II","children":[],"tail":", §§ 202(b), 203(g), "},{"tag":"date","attrib":{"date":"2003-11-17"},"text":"Nov. 17, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1349"},"text":"117 Stat. 1349","children":[],"tail":", 1352; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7116/e/3"},"text":"Pub. L. 111–11, title VII, § 7116(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1203"},"text":"123 Stat. 1203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80d02aec-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80d02aed-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80d02aee-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8908(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1005.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/99/652/s5"},"text":"Pub. L. 99–652, § 5","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3651"},"text":"100 Stat. 3651","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8908(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:1006.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/99/652/s6"},"text":"Pub. L. 99–652, § 6","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3651"},"text":"100 Stat. 3651","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/321/s2/c"},"text":"Pub. L. 103–321, § 2(c)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/108/1794"},"text":"108 Stat. 1794","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “the Committee on House Administration of the House of Representatives, and the Committee on Energy and Natural Resources of the Senate” are substituted for “the committees of Congress specified in section 1003(b) [sic] of this title” for clarity. The reference to section 1003(b) should be to section 1003(d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80d02aef-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80d02af0-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Commemorative Works Clarification and Revision Act of 2003, referred to in subsec. (c), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126"},"text":"Pub. L. 108–126","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2003-11-17"},"text":"Nov. 17, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80d02af1-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":" inserted “Advisory” before “Commission” in first sentence and substituted “Natural Resources of the House” for “House Administration of the House” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126/s203/g/2"},"text":"Pub. L. 108–126, § 203(g)(2)","children":[],"tail":", which directed substitution of “entitled ‘Commemorative Areas Washington, DC and Environs’, numbered 869/86501 B, and dated "},{"tag":"date","attrib":{"date":"2003-06-24"},"text":"June 24, 2003","children":[],"tail":"” for “numbered 869/86581, and dated "},{"tag":"date","attrib":{"date":"1986-05-01"},"text":"May 1, 1986","children":[],"tail":"”, was executed by making the substitution for “numbered 869/86501, and dated "},{"tag":"date","attrib":{"date":"1986-05-01"},"text":"May 1, 1986","children":[],"tail":"” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126/s203/g/1"},"text":"Pub. L. 108–126, § 203(g)(1)","children":[],"tail":", substituted “Secretary of the Interior or the Administrator of General Services (as appropriate)” for “Secretary of the Interior and Administrator of General Services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126/s202/b"},"text":"Pub. L. 108–126, § 202(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80d02af2-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id80d02af3-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/126"},"text":"Pub. L. 108–126","children":[],"tail":", except for the provision in the amendment made by section 202(b) prohibiting a visitor center from being located in the Reserve (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s8902"},"text":"section 8902 of this title","children":[],"tail":"), are not applicable to a commemorative work for which a site was approved in accordance with this chapter prior to "},{"tag":"date","attrib":{"date":"2003-11-17"},"text":"Nov. 17, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/126/s205"},"text":"section 205 of Pub. L. 108–126","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s8901"},"text":"section 8901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
