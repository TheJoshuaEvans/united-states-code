{"tag":"section","attrib":{"id":"id80ea69b4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17702"},"text":null,"children":[{"tag":"num","attrib":{"value":"17702"},"text":"§ 17702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of Government-owned long-lines communication facilities in and to Alaska","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80ea69b5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ea69b6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of the secretary of defense.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80ea69b7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17702/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements prior to transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s17703"},"text":"section 17703 of this title","children":[],"tail":" and with the advice, assistance, and, in the case of an agency not under the jurisdiction of the Secretary of Defense, the consent of the agency concerned, and after approval of the President, the Secretary of Defense shall transfer for adequate consideration any or all long-lines communication facilities in or to Alaska under the jurisdiction of the Federal Government to any person qualifying under section 17703."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80ea69b8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17702/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to carry out chapter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may take action and exercise powers as may be necessary or appropriate to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ea69b9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consent of secretary concerned","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An interest in public lands, withdrawn or otherwise appropriated, shall not be transferred under this chapter without the prior consent of the Secretary of the Interior, or, with respect to lands in a national forest, of the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ea69ba-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17702/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures and methods","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall carry out a transfer under this chapter in accordance with the procedures and methods required of the Administrator of General Services by section 545(a) and (b) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ea69bb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Documents of Title or Other Property Interests","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of the agency concerned (or a designee of the head) shall execute documents for the transfer of title or other interest in property, except any mineral rights in the property, and take other action that the Secretary of Defense decides is necessary or proper to transfer the property under this chapter. A copy of a deed, lease, or other instrument executed by or on behalf of the head of the agency concerned purporting to transfer title or another interest in public land shall be provided to the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ea69bc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Solicitation of Offers To Purchase Certain Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In connection with soliciting offers to purchase long-lines facilities of the Alaska Communication System, the Secretary of Defense shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ea69bd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide any prospective purchaser who requests it data on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80ea69be-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17702/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facilities available for purchase;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80ea69bf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17702/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts considered to be the current fair and reasonable value of those facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80ea69c0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17702/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initial rates that will be charged to the purchaser for capacity in facilities retained by the Government and available for commercial use;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ea69c1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide in the request for offers to purchase that offerors must specify the rates the offerors propose to charge for service and the improvements in service the offerors propose to initiate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ea69c2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17702/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an opportunity for prospective purchasers to meet as a group with Department of Defense representatives to ensure that the data and public interest requirements described in clauses (1) and (2) are fully understood; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ea69c3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17702/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek the advice and assistance of the Federal Communications Commission and the Governor of Alaska (or a designee of the Governor) to ensure consideration of all public interest factors associated with the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ea69c4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s17702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Antitrust Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s559"},"text":"section 559 of this title","children":[],"tail":" apply to transfers under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ea69c5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1286"},"text":"116 Stat. 1286","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ea69c6-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ea69c7-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ea69c8-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"17702(a)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:781(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/90/135/tI/s201"},"text":"Pub. L. 90–135, title I, § 201","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 14, 1967","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/81/442"},"text":"81 Stat. 442","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"17702(a)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:781(5).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"17702(a)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:781(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"17702(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:781(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"17702(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:781(6).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"17702(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:781(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this chapter, the words “or his designee” are omitted because of 10:113.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1)(A), the words “and notwithstanding provisions of any other law” are omitted as unnecessary. The words “shall transfer” are substituted for “is authorized to and shall transfer” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(4), the words “the Federal Field Committee for Development Planning in Alaska” are omitted because the Committee has been terminated. See Executive Order No. 11608 (eff. ","children":[{"tag":"date","attrib":{"date":"1971-07-19"},"text":"July 19, 1971","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
