html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"111","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"(no source).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section is added to provide an accurate literal translation of the words “this Act”, meaning the Federal Property and Administrative Services Act of 1949. In the positive law codification of title 40, most of the Federal Property and Administrative Services Act of 1949 is restated as subtitle I of title 40. However, title III of the Act, which is outside the scope of the positive law codification, remains classified to the United States Code as ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s251"},"text":"41 U.S.C. 251","children":[],"tail":" et seq. Where the words “this Act” are restated, substituting the words “this subtitle” does not yield an accurate literal translation because “this subtitle” does not include title III of the Act. This section does not subject any provision of law to title III of the Act if that provision was not subject to title III prior to the positive law codification of title 40."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8088c128-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8088c129-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":" substituted “division C (except sections 3302, 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41” for “Federal Property and Administrative Services Act of 1949” in section catchline and for “title III of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s251"},"text":"41 U.S.C. 251","children":[],"tail":" et seq.)” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
