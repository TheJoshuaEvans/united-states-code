{"tag":"section","attrib":{"id":"id80d02b3d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s9501"},"text":null,"children":[{"tag":"num","attrib":{"value":"9501"},"text":"§ 9501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief of Engineers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80d02b3e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s9501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Superintendence Duties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80d02b3f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s9501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Washington aqueduct and other public works and improvements in the district of columbia","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief of Engineers has the immediate superintendence of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80d02b40-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s9501/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Washington Aqueduct, together with all rights, appurtenances, and fixtures connected with the Aqueduct and belonging to the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80d02b41-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s9501/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other public works and improvements in the District of Columbia in which the Government has an interest and which are not otherwise specially provided for by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02b42-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s9501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obeying regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out paragraph (1), the Chief of Engineers shall obey regulations the President prescribes, through the Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d02b43-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s9501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Increase in Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of Engineers shall not receive additional compensation for the services required under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d29b44-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s9501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Office","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of Engineers shall be furnished an office in one of the public buildings in the District of Columbia, as the Administrator of General Services directs, and shall be supplied by the Federal Government with stationery, instruments, books, and furniture which may be required for the performance of the duties of the Chief of Engineers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80d29b45-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1233"},"text":"116 Stat. 1233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80d29b46-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80d29b47-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80d29b48-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9501(a)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:45.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 1800.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9501(a)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:48.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 1801.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9501(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:46.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 1807.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9501(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:47.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 1808.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “pursuant to law” are omitted as unnecessary. The words “Secretary of the Army” are substituted for “Department of War” [subsequently changed to “Department of the Army” because of section 205(a) of the National Security Act of 1947 (ch. 343, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":")] because of 10:3013(a)(1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “additional” is substituted for “other than his regular pay as an officer of the Corps of Engineers” to eliminate unnecessary words. The words “of him” are omitted as unnecessary. The words “this chapter” are substituted for “title 21 of the Revised Statutes” because the only provisions of title 21 related to the Chief of Engineers that have not been repealed are contained in the revised chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “an office” are substituted for “official apartments” for clarity. The words “District of Columbia” are substituted for “city of Washington” for consistency in the revised title and with other titles of the United States Code. The words “Administrator of General Services” are substituted for “President” [subsequently changed to “Public Buildings Commission” because of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1919-03-01/s10"},"text":"section 10 of the Act of March 1, 1919","children":[],"tail":" (ch. 86, "},{"tag":"ref","attrib":{"href":"/us/stat/40/1269"},"text":"40 Stat. 1269","children":[],"tail":"), “National Park Service” because of section 2 of Executive Order No. 6166 (eff. "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":") and the Act of "},{"tag":"date","attrib":{"date":"1934-03-02"},"text":"March 2, 1934","children":[],"tail":" (ch. 38, "},{"tag":"ref","attrib":{"href":"/us/stat/48/389"},"text":"48 Stat. 389","children":[],"tail":"), and “Public Buildings Administrator in the Federal Works Agency” because of sections 301 and 303 of Reorganization Plan No. I of 1939 (eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1426"},"text":"53 Stat. 1426","children":[],"tail":", 1427)] because of section 103(a) of the Federal Property and Administrative Services Act of 1949 (ch. 288, "},{"tag":"ref","attrib":{"href":"/us/stat/63/380"},"text":"63 Stat. 380","children":[],"tail":"), which is restated as section 303(c) [303(b)] of the revised title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80d29b49-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80d29b4a-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Washington Aqueduct","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8146"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8146","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3729"},"text":"136 Stat. 3729","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tIII/s1350"},"text":"Pub. L. 118–272, div. A, title III, § 1350","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3159"},"text":"138 Stat. 3159","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/272/dA/tIII/s1350"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capital Improvement Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary [of the Army] may carry out capital improvements for the Washington Aqueduct that the Secretary determines necessary for the safe, effective, and efficient operation of the Aqueduct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Borrowing Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraphs (2) through (4) and subsection (c), the Secretary is authorized to borrow from the Treasury of the United States such amounts as are sufficient to cover any obligations that will be incurred by the Secretary in carrying out capital improvements for the Washington Aqueduct under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount borrowed by the Secretary under paragraph (1) may not exceed $40,000,000 in any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts borrowed under paragraph (1) may only be used to carry out capital improvements with respect to which the Secretary has entered into an agreement with each customer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms of borrowing.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (c), the Secretary of the Treasury shall provide amounts borrowed under paragraph (1) under such terms and conditions as the Secretary of Treasury determines to be necessary and in the public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of any loan made under paragraph (1) shall be for a period of not less than 20 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prepayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There shall be no penalty for the prepayment of any amounts borrowed under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracts With Customers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not borrow any amounts under subsection (b) until such time as the Secretary has entered into a contract with each customer under which the customer commits to pay a pro rata share (based on water purchase) of the principal and interest owed to the Secretary of the Treasury under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prepayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any customer may pay, in advance, the pro rata share of the principal and interest owed by the customer, or any portion thereof, without penalty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Risk of default","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A customer that enters into a contract under this subsection shall, as a condition of the contract, commit to pay any additional amount necessary to fully offset the risk of default on the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obligations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each contract entered into under paragraph (1) shall include such terms and conditions as the Secretary of the Treasury may require so that the total value to the Government of all contracts entered into under paragraph (1) is estimated to be equal to the obligations of the Secretary for carrying out capital improvements for the Washington Aqueduct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each contract entered into under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include other conditions consistent with this section that the Secretary and the Secretary of the Treasury determine to be appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the United States priority in regard to income from fees assessed to operate and maintain the Washington Aqueduct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Customer Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term ‘customer’ means—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia Water and Sewer Authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Arlington County, Virginia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Fairfax County Water Authority, Virginia.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
