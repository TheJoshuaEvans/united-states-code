{"tag":"section","attrib":{"id":"id80c1f939-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6101"},"text":null,"children":[{"tag":"num","attrib":{"value":"6101"},"text":"§ 6101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c1f93a-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c1f93b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Official guest of the supreme court","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “official guest of the Supreme Court” means an individual who is a guest of the Supreme Court, as determined by the Chief Justice of the United States or any Associate Justice of the Supreme Court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c1f93c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” means a State of the United States, the District of Columbia, Puerto Rico, the Virgin Islands, Guam, the Northern Mariana Islands, the Federated States of Micronesia, the Marshall Islands, Palau, and any territory or possession of the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c1f93d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6102"},"text":"section 6102 of this title","children":[],"tail":" and subchapters III and IV, the Supreme Court grounds—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c1f93e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" extend to the line of the face of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80c1f93f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6101/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the east curb of First Street Northeast, between Maryland Avenue Northeast and East Capitol Street;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c1f940-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6101/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the south curb of Maryland Avenue Northeast, between First Street Northeast and Second Street Northeast;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c1f941-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6101/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the west curb of Second Street Northeast, between Maryland Avenue Northeast and East Capitol Street; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80c1f942-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6101/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the north curb of East Capitol Street between First Street Northeast and Second Street Northeast; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c1f943-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprise any property under the custody and control of the Supreme Court as part of the Supreme Court grounds, including property acquired as provided by law on behalf of the Federal Government in lots 2, 3, 800, 801, and 802 in square 758 in the District of Columbia as an addition to the grounds of the Supreme Court Building and that parcel transferred under the Supreme Court Grounds Transfer Act of 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c1f944-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1180"},"text":"116 Stat. 1180","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/214/s1/c/2"},"text":"Pub. L. 109–214, § 1(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-04-11"},"text":"Apr. 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/326"},"text":"120 Stat. 326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c1f945-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c1f946-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c1f947-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6101(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:13n(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-08-18/ch479/s9/d"},"text":"Aug. 18, 1949, ch. 479, § 9(d)","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/97/390/s1/c/2"},"text":"Pub. L. 97–390, § 1(c)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 29, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1958"},"text":"96 Stat. 1958","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6101(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:13p.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-08-18/ch479/s11"},"text":"Aug. 18, 1949, ch. 479, § 11","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/617"},"text":"63 Stat. 617","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/390/s1/d"},"text":"Pub. L. 97–390, § 1(d)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 29, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1958"},"text":"96 Stat. 1958","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the definition of “United States” is omitted as unnecessary because, within 40:13f–13p, the words “United States” are used in the geographical sense only in 40:13n(a)(2) and (c) and the restatement of those provisions, in section 6121 of the revised title, substitutes the words “any State” for “any part of the United States”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Before clause (1), the words “In this chapter, the following definitions apply” are substituted for “As used in sections 13f to 13p of this title, the term—” for clarity. The terms are not used in 40:13a–13e, so using them chapter-wide does not expand their scope.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), the words “the Virgin Islands, Guam, the Northern Mariana Islands, the Federal States of Micronesia, the Marshall Islands, Palau, and any territory or possession of the United States” are substituted for “any territory or possession of the United States” to clarify that the provisions of the source law apply to those jurisdictions.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “In addition to the property referred to in the preceding sentence, for the purposes of sections 13f to 13p of this title, the Supreme Court grounds” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80c1f948-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Supreme Court Grounds Transfer Act of 2005, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/214/s1"},"text":"section 1 of Pub. L. 109–214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-04-11"},"text":"Apr. 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/326"},"text":"120 Stat. 326","children":[],"tail":", which is set out as a note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80c1f949-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80c1f94a-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/214"},"text":"Pub. L. 109–214","children":[],"tail":" inserted “and that parcel transferred under the Supreme Court Grounds Transfer Act of 2005” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80c1f94b-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id80c1f94c-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/214"},"text":"Pub. L. 109–214","children":[],"tail":" applicable to fiscal year 2006 and each fiscal year thereafter, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/214/s1/d"},"text":"section 1(d) of Pub. L. 109–214","children":[],"tail":", set out as a note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80c1f94d-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Jurisdiction Over Certain Real Property to the Supreme Court","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/214/s1"},"text":"Pub. L. 109–214, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-04-11"},"text":"Apr. 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/326"},"text":"120 Stat. 326","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/214/s1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Short Title","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section may be cited as the ‘Supreme Court Grounds Transfer Act of 2005’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Jurisdiction.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Jurisdiction over the parcel of Federal real property described under paragraph (2) (over which jurisdiction was transferred to the Architect of the Capitol under section 514(b)(2)(B)(i) of the Omnibus Parks and Public Lands Management Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5102"},"text":"40 U.S.C. 5102","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/104/333"},"text":"Public Law 104–333","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/110/4165"},"text":"110 Stat. 4165","children":[],"tail":")) is transferred to the Supreme Court of the United States, without consideration."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Parcel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The parcel of Federal real property referred to under paragraph (1) is that portion of the triangle of Federal land in Reservation No. 204 in the District of Columbia under the jurisdiction of the Architect of the Capitol, including any contiguous sidewalks, bound by Constitution Avenue, N.E., on the north, the branch of Maryland Avenue, N.E., running in a northeast direction on the west, the major portion of Maryland Avenue, N.E., on the south, and 2nd Street, N.E., on the east, including the contiguous sidewalks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Miscellaneous.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance with other laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Compliance with this section shall be deemed to satisfy the requirements of all laws otherwise applicable to transfers of jurisdiction over parcels of Federal real property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion in supreme court grounds","children":[],"tail":".—"}],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80c1f94e-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"[Amended ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6101/b/2"},"text":"section 6101(b)(2) of this title","children":[],"tail":".]"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United states capitol grounds.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5102"},"text":"Section 5102 of title 40","children":[],"tail":", United States Code, is amended to exclude within the definition of the United States Capitol Grounds the parcel of Federal real property described in subsection (b)(2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction of capitol police","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The United States Capitol Police shall not have jurisdiction over the parcel of Federal real property described in subsection (b)(2) by reason of such parcel formerly being part of the United States Capitol Grounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recording of map of supreme court grounds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Architect of the Capitol shall record with the Office of the Surveyor of the District of Columbia a map showing areas comprising the grounds of the Supreme Court of the United States that reflects—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the legal boundaries described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6101/b/1"},"text":"section 6101(b)(1) of title 40","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any portion of the United States Capitol Grounds as described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s5102"},"text":"section 5102 of title 40","children":[],"tail":", United States Code, which is contiguous to the boundaries or property described under subparagraph (A) of this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This Act shall apply to fiscal year 2006 and each fiscal year thereafter.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id80c1f94f-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"United States Supreme Court Building; Acquisition of Certain Real Property","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/532"},"text":"Pub. L. 96–532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-15"},"text":"Dec. 15, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3130"},"text":"94 Stat. 3130","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/97/390/s3"},"text":"Pub. L. 97–390, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-29"},"text":"Dec. 29, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1958"},"text":"96 Stat. 1958","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/390/s3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“That the Architect of the Capitol is authorized to acquire on behalf of the United States by purchase, condemnation, transfer, or otherwise, as an addition to the grounds of the United States Supreme Court Building, all privately owned real property contained in lots 2, 3, 800, 801, and 802 in square 758 in the District of Columbia, as such lots appear on the records in the office of the Surveyor of the District of Columbia as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1980-12-15"},"text":"Dec. 15, 1980","children":[],"tail":"]."}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“Sec. 2.","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The acquisition of real property under this Act shall be conducted in accordance with the Act entitled ‘Uniform Relocation Assistance and Land Acquisition Policies Act of 1970’, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/646"},"text":"Public Law 91–646","children":[],"tail":", approved "},{"tag":"date","attrib":{"date":"1971-01-02"},"text":"January 2, 1971","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4601"},"text":"42 U.S.C. 4601","children":[],"tail":" et seq.], and any proceeding for condemnation brought in its course shall be conducted in accordance with the Act entitled ‘An Act to provide for the acquisition of land in the District of Columbia for the use of the United States’, approved "},{"tag":"date","attrib":{"date":"1929-03-01"},"text":"March 1, 1929","children":[],"tail":" (16 D.C. Code, secs. 1351–1368)."}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“Sec. 3.","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon acquisition of such real property by the Architect of the Capitol, on behalf of the United States, such property shall become a part of the grounds of the United States Supreme Court Building and shall be subject to all of the provisions of the Act entitled ‘An Act to provide for the custody and maintenance of the United States Supreme Court Building and the equipment and grounds thereof’, approved ","children":[{"tag":"date","attrib":{"date":"1934-05-07"},"text":"May 7, 1934","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s13a–13c"},"text":"40 U.S.C. 13a–13c","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s6111–611"},"text":"40 U.S.C. 6111–611","children":[],"tail":"3], and section 6 of the joint resolution entitled ‘Joint resolution to provide for the use and disposition of the bequest of the late Justice Oliver Wendell Holmes to the United States, and for other purposes’, approved "},{"tag":"date","attrib":{"date":"1940-10-22"},"text":"October 22, 1940","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s13e"},"text":"40 U.S.C. 13e","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s6114"},"text":"40 U.S.C. 6114","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“Sec. 4.","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Architect of the Capitol is authorized to enter into contracts and to make expenditures for grading and paving and such other expenditures, including expenditures for personal and other services, as may be necessary to carry out the purposes of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“Sec. 5.","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby authorized to be appropriated the sum of $645,000 for fiscal year 1981 for the purpose of carrying out the provisions of this Act, said appropriation to remain available until expended.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
