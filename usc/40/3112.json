{"tag":"section","attrib":{"id":"id80b3a15d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3112"},"text":null,"children":[{"tag":"num","attrib":{"value":"3112"},"text":"§ 3112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal jurisdiction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80b3a15e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusive Jurisdiction Not Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is not required that the Federal Government obtain exclusive jurisdiction in the United States over land or an interest in land it acquires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b3a15f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition and Acceptance of Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the head of a department, agency, or independent establishment of the Government, or other authorized officer of the department, agency, or independent establishment, considers it desirable, that individual may accept or secure, from the State in which land or an interest in land that is under the immediate jurisdiction, custody, or control of the individual is situated, consent to, or cession of, any jurisdiction over the land or interest not previously obtained. The individual shall indicate acceptance of jurisdiction on behalf of the Government by filing a notice of acceptance with the Governor of the State or in another manner prescribed by the laws of the State where the land is situated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80b3a160-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s3112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presumption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is conclusively presumed that jurisdiction has not been accepted until the Government accepts jurisdiction over land as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80b3a161-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1144"},"text":"116 Stat. 1144","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80b3a162-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80b3a163-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80b3a164-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3112(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:255 (last par. 1st sentence words before semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 355 (last par.); ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1930-06-28/ch710"},"text":"June 28, 1930, ch. 710","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/46/828"},"text":"46 Stat. 828","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1940-02-01/ch18"},"text":"Feb. 1, 1940, ch. 18","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/54/19"},"text":"54 Stat. 19","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1940-10-09/ch793"},"text":"Oct. 9, 1940, ch. 793","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/54/1083"},"text":"54 Stat. 1083","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3112(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:255 (last par. 1st sentence words after semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3112(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:255 (last par. last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) is substituted for 40:255 (last par. 1st sentence words before semicolon) to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “exclusive or partial” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
