{"tag":"section","attrib":{"id":"id80d02a8b-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8904"},"text":null,"children":[{"tag":"num","attrib":{"value":"8904"},"text":"§ 8904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Capital Memorial Advisory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80d02a8c-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Composition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established the National Capital Memorial Advisory Commission, which shall be composed of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80d02a8d-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Park Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02a8e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Architect of the Capitol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02a8f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8904/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the American Battle Monuments Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02a90-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8904/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Commission of Fine Arts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02a91-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8904/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the National Capital Planning Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02a92-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8904/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Mayor of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02a93-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8904/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commissioner of the Public Buildings Service of the General Services Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80d02a94-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8904/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d02a95-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director is the Chairman of the National Capital Memorial Advisory Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d02a96-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory Role","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Capital Memorial Advisory Commission shall advise the Secretary of the Interior and the Administrator of General Services (as appropriate) on policy and procedures for establishment of, and proposals to establish, commemorative works in the District of Columbia and its environs and on other matters concerning commemorative works in the Nation’s Capital as the Commission considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80d02a97-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s8904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Capital Memorial Advisory Commission shall meet at least twice annually.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80d02a98-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1229"},"text":"116 Stat. 1229","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/126/tII/s203/d"},"text":"Pub. L. 108–126, title II, § 203(d)","children":