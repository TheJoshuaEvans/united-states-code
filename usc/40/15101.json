{"tag":"section","attrib":{"id":"id80e33dc7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101"},"text":null,"children":[{"tag":"num","attrib":{"value":"15101"},"text":"§ 15101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subtitle, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e33dc8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Commission” means a Commission or Authority established under section 15301.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33dc9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Local development district","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “local development district” means an entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80e33dca-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80e33dcb-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is an economic development district that is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id80e33dcc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in existence on the date of the enactment of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id80e33dcd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located in the region; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e33dce-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if an entity described in clause (i) does not exist—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id80e33dcf-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is organized and operated in a manner that ensures broad-based community participation and an effective opportunity for local officials, community leaders, and the public to contribute to the development and implementation of programs in the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id80e33dd0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is governed by a policy board with at least a simple majority of members consisting of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id80e33dd1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/2/A/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elected officials; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id80e33dd2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/2/A/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designees or employees of a general purpose unit of local government that have been appointed to represent the unit of local government; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id80e33dd3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is certified by the Governor or appropriate State officer as having a charter or authority that includes the economic development of counties, portions of counties, or other political subdivisions within the region; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80e33dd4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has not, as certified by the Federal Cochairperson—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id80e33dd5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inappropriately used Federal grant funds from any Federal source; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id80e33dd6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appointed an officer who, during the period in which another entity inappropriately used Federal grant funds from any Federal source, was an officer of the other entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33dd7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal grant program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Federal grant program” means a Federal grant program to provide assistance in carrying out economic and community development activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33dd8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indian tribe","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"25 U.S.C. 450b","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn002039"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002039"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33dd9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonprofit entity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “nonprofit entity” means any organization described in section 501(c) of the Internal Revenue Code of 1986 and exempt from taxation under 501(a) of that Code that has been formed for the purpose of economic development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e33dda-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s15101/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Region","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “region” means the area covered by a Commission as described in subchapter II of chapter 157.","children":[{"tag":"ref","attrib":{"idref":"fn002040"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002040"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably means chapter 4 of this subtitle."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e33ddb-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14217/a/2"},"text":"Pub. L. 110–234, title XIV, § 14217(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1468"},"text":"122 Stat. 1468","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14217(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2230; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dO/tIV/s401/a/2"},"text":"Pub. L. 117–328, div. O, title IV, § 401(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5228"},"text":"136 Stat. 5228","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e33ddc-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80e33ddd-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80e33dde-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this chapter, referred to in par. (2)(A)(i)(I), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"25 U.S.C. 450b","children":[],"tail":"), referred to in par. (4), was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"section 450b of Title 25","children":[],"tail":", Indians, prior to editorial reclassification and renumbering as "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of Title 25","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 501 of the Internal Revenue Code of 1986, referred to in par. (5), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501"},"text":"section 501 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id80e33ddf-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80e33de0-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" inserted “or Authority” after “a Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id80e33de1-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"top