ildren":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3309(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:607(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/86/249/s8/d"},"text":"Pub. L. 86–249, § 8(d)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 9, 1959","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/93/72"},"text":"Pub. L. 93–72","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 10, 1973","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/87/169"},"text":"87 Stat. 169","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Council of the District of Columbia” are substituted for “Board of Commissioners of the District of Columbia” [subsequently changed to “District of Columbia Council” because of section 402(431) of Reorganization Plan No. 3 of 1967 (eff. ","children":[{"tag":"date","attrib":{"date":"1967-08-11"},"text":"Aug. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/951"},"text":"81 Stat. 951","children":[],"tail":")] in section 8(b) of the Public Buildings Act of 1959 ("},{"tag":"ref","attrib":{"href":"/us/pl/86/249"},"text":"Public Law 86–249","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/481"},"text":"73 Stat. 481","children":[],"tail":") because of sections 401 and 404(a) of the District of Columbia Home Rule Act ("},{"tag":"ref","attrib":{"href":"/us/pl/93/198"},"text":"Public Law 93–198","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/785"},"text":"87 Stat. 785","children":[],"tail":", 787)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) is substituted for 40:607(d) to eliminate obsolete words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80b85d49-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id80b85d4a-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1907-03-04"},"text":"March 4, 1907","children":[],"tail":", referred to in subsec. (c)(1), is "},{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2918"},"text":"act Mar. 4, 1907, ch. 2918","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1365"},"text":"34 Stat. 1365","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s2001"},"text":"section 2001 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The District of Columbia Stadium Act of 1957, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/300"},"text":"Pub. L. 85–300","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-09-07"},"text":"Sept. 7, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/619"},"text":"71 Stat. 619","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
