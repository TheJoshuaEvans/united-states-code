{"tag":"section","attrib":{"id":"id80c4438e-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6701"},"text":null,"children":[{"tag":"num","attrib":{"value":"6701"},"text":"§ 6701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of rights and authorities of Pennsylvania Avenue Development Corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80c4438f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of General Services—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c44390-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make and perform transactions with an agency or instrumentality of the Federal Government, a State, the District of Columbia, or any person as necessary to carry out the trade center plan at the Federal Triangle Project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44391-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has all the rights and authorities of the former Pennsylvania Avenue Development Corporation with regard to property transferred from the Corporation to the General Services Administration in fiscal year 1996.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c44392-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Amounts and Income.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80c44393-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities associated with transferred responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may use amounts transferred from the Corporation or income earned on Corporation property for activities associated with carrying out the responsibilities of the Corporation transferred to the Administrator. Any income earned after ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":", shall be deposited to the Federal Buildings Fund to be available for the purposes authorized under this subchapter, notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s592/c/1"},"text":"section 592(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80c44394-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Excess amounts or income","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amounts or income the Administrator considers excess to the amount needed to fulfill the responsibilities of the Corporation transferred to the Administrator shall be applied to any outstanding debt the Corporation incurred when acquiring real estate, except debt associated with the Ronald Reagan Building and International Trade Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80c44395-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s6701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment to District of Columbia","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to real property transferred from the Corporation to the Administrator under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s6702"},"text":"section 6702 of this title","children":[],"tail":", the Administrator shall pay to the District of Columbia government, in the same way as previously paid by the Corporation, an amount equal to the amount of real property tax which would have been payable to the government beginning on the date the Corporation acquired the real property if legal title to the property had been held by a private citizen on that date and during all periods to which that date relates."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80c44396-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1193"},"text":"116 Stat. 1193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80c44397-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80c44398-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80c44399-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6701(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:872 note (words before 1st proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/104/208/dA/tI/s101/f/tIV/s3d–6t"},"text":"Pub. L. 104–208, div. A, title I, § 101(f) [title IV, 3d–6th provisos on p. 3009–335]","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/3009-335"},"text":"110 Stat. 3009–335","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6701(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:872 note (1st, 2d provisos).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:872 note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/105/277/s101/h/tIV/s9th"},"text":"Pub. L. 105–277, § 101(h) [title IV, 9th proviso on p. 2681–502]","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/2681-502"},"text":"112 Stat. 2681–502","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6701(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:872 note (last proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:879(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/92/578/s10/b"},"text":"Pub. L. 92–578, § 10(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/1274"},"text":"86 Stat. 1274","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “in fiscal year 1997 and thereafter” are omitted as obsolete. In clause (1), the words “leases, contracts or other” are omitted as unnecessary. The words “firm, association, or corporation” are omitted because of the definition of “person” in 1:1.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “notwithstanding any other provision of law” are omitted as unnecessary. The words “That the remaining balances and associated assets and laibilites [sic] of the Pennsylvania Avenue Activities account are hereby transferred to the Federal Buildings Fund to be effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":"” are omitted as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “To the extent that the District of Columbia may not suffer undue loss of tax revenue by reason of the provisions of subsection (a) of this section” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
