{"tag":"section","attrib":{"id":"id80ac75da-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s705"},"text":null,"children":[{"tag":"num","attrib":{"value":"705"},"text":"§ 705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Handling of proceeds from disposal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80ac75db-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies to proceeds from the sale, lease, or other disposition of foreign excess property under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ac75dc-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Currencies or Credits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Proceeds in the form of foreign currencies or credits, must be administered in accordance with procedures that the Secretary of the Treasury may establish.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ac75dd-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United States Currency.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ac75de-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s705/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separate fund in treasury","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s572/a"},"text":"Section 572(a) of this title","children":[],"tail":" applies to proceeds of foreign excess property disposed of for United States currency under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ac75df-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s705/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposited in treasury as miscellaneous receipts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (1), proceeds in the form of United States currency, including foreign currencies or credits that are reduced to United States currency, must be deposited in the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80ac75e0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s705/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Account for Refunds or Payments for Breach.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id80ac75e1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s705/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A federal agency that disposes of foreign excess property under this chapter may deposit, in a special account in the Treasury, amounts of the proceeds of the dispositions that the agency decides are necessary to permit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id80ac75e2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s705/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate refunds to purchasers for dispositions that are rescinded or that do not become final; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id80ac75e3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s705/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments for breach of warranty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80ac75e4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s705/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withdrawals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A federal agency that deposits proceeds in a special account under paragraph (1) may withdraw amounts to be refunded or paid from the account without regard to the origin of the amounts withdrawn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80ac75e5-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1127"},"text":"116 Stat. 1127","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80ac75e6-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80ac75e7-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80ac75e8-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"705","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:513.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title IV, § 403, "},{"tag":"html:a","attrib":{"href":"/us/stat/63/398"},"text":"63 Stat. 398","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(1), the words “in the Treasury” are substituted for “with the Treasurer of the United States” because of section 1 of Reorganization Plan No. 26 of 1950 (eff. ","children":[{"tag":"date","attrib":{"date":"1950-07-31"},"text":"July 31, 1950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1280"},"text":"64 Stat. 1280","children":[],"tail":"), restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s321"},"text":"section 321 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
