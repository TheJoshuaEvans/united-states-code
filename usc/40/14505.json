{"tag":"section","attrib":{"id":"id80e0f39f-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505"},"text":null,"children":[{"tag":"num","attrib":{"value":"14505"},"text":"§ 14505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entrepreneurship initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id80e0f3a0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Business Incubator Service","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “business incubator service” means a professional or technical service necessary for the initiation and initial sustainment of the operations of a newly established business, including a service such as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f3a1-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a legal service, including aid in preparing a corporate charter, partnership agreement, or basic contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3a2-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a service in support of the protection of intellectual property through a patent, a trademark, or any other means;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3a3-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a service in support of the acquisition and use of advanced technology, including the use of Internet services and Web-based services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3a4-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consultation on strategic planning, marketing, or advertising.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f3a5-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Projects To Be Assisted","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Appalachian Regional Commission may provide technical assistance, make grants, enter into contracts, or otherwise provide amounts to persons or entities in the region for projects—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f3a6-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the advancement of, and provide, entrepreneurial training and education for youths, students, and businesspersons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3a7-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve access to debt and equity capital by such means as facilitating the establishment of development venture capital funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3a8-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to aid communities in identifying, developing, and implementing development strategies for various sectors of the economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3a9-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop a working network of business incubators; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3aa-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support entities that provide business incubator services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f3ab-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Available Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the cost of any activity eligible for a grant under this section, not more than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id80e0f3ac-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent may be provided from amounts appropriated to carry out this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3ad-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which a distressed county designation is in effect under section 14526, 80 percent may be provided from amounts appropriated to carry out this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id80e0f3ae-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be carried out in a county for which an at-risk county designation is in effect under section 14526, 70 percent may be provided from amounts appropriated to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f3af-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Assistance under this section may be provided entirely from amounts made available to carry out this section, in combination with amounts made available under other federal programs, or from any other source.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id80e0f3b0-3a70-11f1-b817-c08bf6d1fe2c","identifier":"/us/usc/t40/s14505/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of law limiting the federal share under any other federal program, amounts made available to carry out this section may be used to increase that federal share, as the Commission decides is appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id80e0f3b1-3a70-11f1-b817-c08bf6d1fe2c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1271"},"text":"116 Stat. 1271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/371/s2/e"},"text":"Pub. L. 110–371, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4039"},"text":"122 Stat. 4039","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id80e0f3b2-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id80e0f3b3-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id80e0f3b4-3a70-11f1-b817-c08bf6d1fe2c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text"