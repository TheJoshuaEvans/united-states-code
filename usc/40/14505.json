"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id80e0f3b5-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id80e0f3b6-3a70-11f1-b817-c08bf6d1fe2c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/371"},"text":"Pub. L. 110–371","children":[],"tail":" added subsec. (c) and struck out heading and text of former subsec. (c). Text read as follows: “Not more than 50 percent (or 80 percent in the case of a project to be carried out in a county for which a distressed county designation is in effect under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s14526"},"text":"section 14526 of this title","children":[],"tail":") of the cost of any activity eligible for a grant under this section may be provided from amounts appropriated to carry out this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
