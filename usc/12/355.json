":"/us/pl/95/534"},"text":"Pub. L. 95–534","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-27"},"text":"Oct. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2032"},"text":"92 Stat. 2032","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/18"},"text":"Pub. L. 96–18","children":[],"tail":", §§ 1, 3, "},{"tag":"date","attrib":{"date":"1979-06-08"},"text":"June 8, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/35"},"text":"93 Stat. 35","children":[],"tail":", 36; "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tI/s105/b/2"},"text":"Pub. L. 96–221, title I, § 105(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/140"},"text":"94 Stat. 140","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb35c214-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb35c215-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb35c216-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1463"},"text":"Section 1463 of this title","children":[],"tail":", referred to in par. (1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s8/a"},"text":"Pub. L. 89–554, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/648"},"text":"80 Stat. 648","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in par. (1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6"},"text":"act Dec. 23, 1913, ch. 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/251"},"text":"38 Stat. 251","children":[],"tail":", known as the Federal Reserve Act. For complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s226"},"text":"section 226 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb35c217-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsec. (b) of section 14 of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":". For classification to this title of remainder of section 14, see Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s353"},"text":"section 353 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb35c218-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221"},"text":"Pub. L. 96–221","children":[],"tail":" inserted provisions relating to obligations of a foreign government or agency thereof."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/18/s1/a"},"text":"Pub. L. 96–18, § 1(a)","children":[],"tail":", struck out proviso under which Federal Reserve banks had been allowed, until "},{"tag":"date","attrib":{"date":"1979-05-01"},"text":"May 1, 1979","children":[],"tail":", to buy and sell either in the open market or directly from or to the United States bonds, notes, or other obligations which were direct obligations of the United States or which were fully guaranteed by the United States and, after "},{"tag":"date","attrib":{"date":"1979-04-30"},"text":"Apr. 30, 1979","children":[],"tail":", had allowed such obligations to be purchased but only in the open market."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/18/s3/b"},"text":"Pub. L. 96–18, § 3(b)","children":[],"tail":", inserted provision that notwithstanding any other provision of this chapter, any bonds, notes, or other obligations which are direct obligations of the United States or which are fully guaranteed by the United States as to principal and interest may be bought and sold without regard to maturities but only in the open market."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/18"},"text":"Pub. L. 96–18","children":[],"tail":", §§ 1(b), 3(a), temporarily substituted “the United States or any agency of the United States, and to lend, under the direction and regulations of the Federal Open Market Committee, any such obligation to the Secretary of the Treasury” for “any agency of the United States”. See Effective and Termination Dates of 1979 Amendment note set out below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/18"},"text":"Pub. L. 96–18","children":[],"tail":", §§ 1(c), 3(a), temporarily added pars. (3) and (4). See Effective and Termination Dates of 1979 Amendment note set out below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/534"},"text":"Pub. L. 95–534","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1979-0