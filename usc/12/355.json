children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221"},"text":"Pub. L. 96–221","children":[],"tail":" effective on first day of sixth month which begins after "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/s108"},"text":"section 108 of Pub. L. 96–221","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s248"},"text":"section 248 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221/tI/s105/b/2"},"text":"Pub. L. 96–221, title I, § 105(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/140"},"text":"94 Stat. 140","children":[],"tail":", provided that the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/s105/b/2"},"text":"section 105(b)(2) of Pub. L. 96–221","children":[],"tail":" is applicable to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s355/1"},"text":"12 U.S.C. 355(1)","children":[],"tail":" as such section is in effect on the first day of the sixth month which begins after "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"March 31, 1980","children":[],"tail":", and as it will be in effect on "},{"tag":"date","attrib":{"date":"1981-06-01"},"text":"June 1, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb35c21c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/18/s3/a"},"text":"Pub. L. 96–18, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-06-08"},"text":"June 8, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/36"},"text":"93 Stat. 36","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/18/s3/a"},"text":"“Except for the amendments made by subsection (a) of the first section of this Act [amending par. (1) of this section], and except for the amendment made by subsection (b) of this section [amending par. (1) of this section effective upon the expiration of the two-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1979-06-08"},"text":"June 8, 1979","children":[],"tail":"], the amendments made by this Act [enacting "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s359a"},"text":"section 359a of this title","children":[],"tail":" and pars. (3) and (4) of this section and amending par. (2) of this section] shall be effective only during the two-year period which begins on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1979-06-08"},"text":"June 8, 1979","children":[],"tail":"]. Upon the expiration of such period, each provision of law amended by this Act [enacting "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s359a"},"text":"section 359a of this title","children":[],"tail":" and amending this section], except section 14(b)(1) of the Federal Reserve Act [par. (1) of this section], is amended to read as it did immediately prior to the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/18/s3/b"},"text":"Pub. L. 96–18, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-06-08"},"text":"June 8, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/36"},"text":"93 Stat. 36","children":[],"tail":", provided that the amendment made by that section is effective “Upon the expiration of the 2-year period which begins on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1979-06-08"},"text":"June 8, 1979","children":[],"tail":"]”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb35c21d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Expiration of 1942 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of the proviso of this section by act ","children":[{"tag":"date","attrib":{"date":"1942-03-27"},"text":"Mar. 27, 1942","children":[],"tail":", remained in force only until the date fixed by section 645 of the former Appendix to Title 50, War and National Defense, after which provisions in force before the amendment again became effective. Before the 1942 amendment, the proviso of this section read: "},{"tag":"i","attrib":{},"text":"“Provided","children":[],"tail":", That any bonds, notes, or other obligations which are direct obligations of the United States or which are fully guaranteed by the United States as to principal and interest may be bought and sold without regard to maturities but only in the open market.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
