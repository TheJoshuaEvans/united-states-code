{"tag":"section","attrib":{"id":"iddcec737b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279bb–6"},"text":"§ 2279bb–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervisory actions applicable to level III","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcec737c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory supervisory actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec737d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital restoration plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Corporation is classified as within level III, the Corporation shall, within the time period determined by the Director, submit to the Director a capital restoration plan and, after approval, carry out the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec737e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on dividends","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcec737f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Corporation is classified as within level III, the Corporation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcec7380-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not make any payment of dividends that would result in the Corporation being reclassified as within level IV; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcec7381-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make any other payment of dividends only if the Director approves the payment before the payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec7382-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard for approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Corporation is classified as within level III, the Director may approve a payment of dividends by the Corporation only if the Director determines that the payment (i) will enhance the ability of the Corporation to meet the risk-based capital level and the minimum capital level promptly, (ii) will contribute to the long-term safety and soundness of the Corporation, or (iii) is otherwise in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec7383-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reclassification from level III to level IV","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall immediately reclassify the Corporation as within level IV if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcec7384-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation is classified as within level III; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec7385-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcec7386-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation does not submit a capital restoration plan that is approved by the Director; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcec7387-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director determines that the Corporation has failed to make, in good faith, reasonable efforts necessary to comply with such a capital restoration plan and fulfill the schedule for the plan approved by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec7388-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary supervisory actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any other actions taken by the Director (including actions under subsection (a)), the Director may, at any time, take any of the following actions if the Corporation is classified as within level III:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec7389-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on increase in obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Limit any increase in, or order the reduction of, any obligations of the Corporation, including off-balance sheet obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec738a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on growth","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Limit or prohibit the growth of the assets of the Corporation or require contraction of the assets of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec738b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on dividends","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prohibit the Corporation from making any payment of dividends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec738c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of new capital","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Require the Corporation to acquire new capital in any form and in any amount sufficient to provide for the reclassification of the Corporation as within level II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec738d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction of activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Require the Corporation to terminate, reduce, or modify any activity that the Director determines creates excessive risk to the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec738e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservatorship","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appoint a conservator for the Corporation consistent with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec738f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect on ","children":[{"tag":"date","attrib":{"date":"1992-01-01"},"text":"January 1, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcec7390-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVIII/s8"},"text":"Pub. L. 92–181, title VIII, § 8","children":[],"tail":".37, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tV/s503/b/2"},"text":"Pub. L. 102–237, title V, § 503(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1876"},"text":"105 Stat. 1876","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
