{"tag":"section","attrib":{"id":"iddb29dab0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s250"},"text":null,"children":[{"tag":"num","attrib":{"value":"250"},"text":"§ 250.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independence of financial regulatory agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No officer or agency of the United States shall have any authority to require the Securities and Exchange Commission, the Board of Governors of the Federal Reserve System, the Federal Deposit Insurance Corporation, the Comptroller of the Currency, the Director of the Office of Thrift Supervision, the Director of the Federal Housing Finance Agency, or the National Credit Union Administration to submit legislative recommendations, or testimony, or comments on legislation, to any officer or agency of the United States for approval, comments, or review, prior to the submission of such recommendations, testimony, or comments to the Congress if such recommendations, testimony, or comments to the Congress include a statement indicating that the views expressed therein are those of the agency submitting them and do not necessarily represent the views of the President.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb29dab1-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/495/tI/s111"},"text":"Pub. L. 93–495, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1506"},"text":"88 Stat. 1506","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s331/a"},"text":"Pub. L. 103–325, title III, § 331(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2232"},"text":"108 Stat. 2232","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVI/s606/e/2"},"text":"Pub. L. 106–102, title VI, § 606(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1455"},"text":"113 Stat. 1455","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1102/b"},"text":"Pub. L. 110–289, div. A, title I, § 1102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2664"},"text":"122 Stat. 2664","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb29dab2-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb29dab3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb29dab4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Federal Reserve Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb29dab5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289"},"text":"Pub. L. 110–289","children":[],"tail":" substituted “the Director of the Federal Housing Finance Agency” for “the Federal Housing Finance Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Pub. L. 106–102","children":[],"tail":" substituted “Director of the Office of Thrift Supervision, the Federal Housing Finance Board,” for “Federal Home Loan Bank Board,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":" inserted “the Comptroller of the Currency,” after “Federal Deposit Insurance Corporation,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
