{"tag":"section","attrib":{"id":"iddb7d519d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1441a–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1441a–2"},"text":"§ 1441a–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for State housing finance agencies and nonprofit entities to purchase mortgage-related assets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb7d519e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1441a–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of Federal or State law, a State housing finance authority or nonprofit entity may purchase mortgage-related assets from the Resolution Trust Corporation or from financial institutions with respect to which the Federal Deposit Insurance Corporation is acting as a conservator or receiver (including assets associated with any trust business), and any contract for such purchase shall be effective in accordance with its terms without any further approval, assignment, or consent with respect to that contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb7d519f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1441a–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State housing finance authority or nonprofit entity which purchases mortgage-related assets pursuant to subsection (a) shall invest any net income attributable to the ownership of those assets in financing, refinancing, or rehabilitating low- and moderate-income housing within the jurisdiction of the State housing finance authority or within the geographical area served by the nonprofit entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb7d51a0-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXIII/s1302"},"text":"Pub. L. 101–73, title XIII, § 1302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/548"},"text":"103 Stat. 548","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb7d51a1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb7d51a2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb7d51a3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Financial Institutions Reform, Recovery, and Enforcement Act of 1989, and not as part of the Federal Home Loan Bank Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb7d51a4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"iddb7d51a5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1441a–1"},"text":"section 1441a–1 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
