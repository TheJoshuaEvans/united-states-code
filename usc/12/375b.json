{"tag":"section","attrib":{"id":"iddb3ced75-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b"},"text":null,"children":[{"tag":"num","attrib":{"value":"375b"},"text":"§ 375b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extensions of credit to executive officers, directors, and principal shareholders of member banks","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb3ced76-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No member bank may extend credit to any of its executive officers, directors, or principal shareholders, or to any related interest of such a person, except to the extent permitted under paragraphs (2), (3), (4), (5), and (6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3ced77-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferential terms prohibited","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb3ced78-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member bank may extend credit to its executive officers, directors, or principal shareholders, or to any related interest of such a person, only if the extension of credit—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3ced79-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made on substantially the same terms, including interest rates and collateral, as those prevailing at the time for comparable transactions by the bank with persons who are not executive officers, directors, principal shareholders, or employees of the bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3ced7a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not involve more than the normal risk of repayment or present other unfavorable features; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3ced7b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bank follows credit underwriting procedures that are not less stringent than those applicable to comparable transactions by the bank with persons who are not executive officers, directors, principal shareholders, or employees of the bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3ced7c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this paragraph shall prohibit any extension of credit made pursuant to a benefit or compensation program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3ced7d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is widely available to employees of the member bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3ced7e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that does not give preference to any officer, director, or principal shareholder of the member bank, or to any related interest of such person, over other employees of the member bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3ced7f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior approval required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member bank may extend credit to a person described in paragraph (1) in an amount that, when aggregated with the amount of all other outstanding extensions of credit by that bank to each such person and that person’s related interests, would exceed an amount prescribed by regulation of the appropriate Federal banking agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":") only if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb3ced80-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extension of credit has been approved in advance by a majority vote of that bank’s entire board of directors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3ced81-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interested party has abstained from participating, directly or indirectly, in the deliberations or voting on the extension of credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3ced82-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate limit on extensions of credit to any executive officer, director, or principal shareholder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member bank may extend credit to any executive officer, director, or principal shareholder, or to any related interest of such a person, only if the extension of credit is in an amount that, when aggregated with the amount of all outstanding extensions of credit by that bank to that person and that person’s related interests, would not exceed the limits on loans to a single borrower established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s84"},"text":"section 84 of this title","children":[],"tail":". For purposes of this paragraph, "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s84"},"text":"section 84 of this title","children":[],"tail":" shall be deemed to apply to a State member bank as if the State member bank were a national banking association."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3ced83-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate limit on extensions of credit to all executive officers, directors, and principal shareholders","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb3ced84-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member bank may extend credit to any executive officer, director, or principal shareholder, or to any related interest of such a person, if the extension of credit is in an amount that, when aggregated with the amount of all outstanding extensions of credit by that bank to its executive officers, directors, principal shareholders, and those persons’ related interests would not exceed the bank’s unimpaired capital and unimpaired surplus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3ced85-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" More stringent limit authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may, by regulation, prescribe a limit that is more stringent than that contained in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3ced86-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board may make exceptions for certain banks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may, by regulation, make exceptions to subparagraph (A) for member banks with less than $100,000,000 in deposits if the Board determines that the exceptions are important to avoid constricting the availability of credit in small communities or to attract directors to such banks. In no case may the aggregate amount of all outstanding extensions of credit to a bank’s executive officers, directors, principal shareholders, and those persons’ related interests be more than 2 times the bank’s unimpaired capital and unimpaired surplus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3f3777-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overdrafts by executive officers and directors prohibited","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb3f3778-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any executive officer or director has an account at the member bank, the bank may not pay on behalf of that person an amount exceeding the funds on deposit in the account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3f3779-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) does not prohibit a member bank from paying funds in accordance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3f377a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written preauthorized, interest-bearing extension of credit specifying a method of repayment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3f377b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written preauthorized transfer of funds from another account of the executive officer or director at that bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3f377c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on knowingly receiving unauthorized extension of credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No executive officer, director, or principal shareholder shall knowingly receive (or knowingly permit any of that person’s related interests to receive) from a member bank, directly or indirectly, any extension of credit not authorized under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3f377d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive officer, director, or principal shareholder of certain affiliates treated as executive officer, director, or principal shareholder of member bank","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb3f377e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, any executive officer, director, or principal shareholder (as the case may be) of any company of which the member bank is a subsidiary, or of any other subsidiary of that company, shall be deemed to be an executive officer, director, or principal shareholder (as the case may be) of the member bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3f377f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board may, by regulation, make exceptions to subparagraph (A) for any executive officer or director of a subsidiary of a company that controls the member bank if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3f3780-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the executive officer or director does not have authority to participate, and does not participate, in major policymaking functions of the member bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3f3781-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assets of such subsidiary do not exceed 10 percent of the consolidated assets of a company that controls the member bank and such subsidiary (and is not controlled by any other company).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3f3782-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb3f3783-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Company","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3f3784-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), the term “company” means any corporation, partnership, business or other trust, association, joint venture, pool syndicate, sole proprietorship, unincorporated organization, or other business entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3f3785-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “company” does not include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddb3f3786-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insured depository institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddb3f3787-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation the majority of the shares of which are owned by the United States or by any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3f3788-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Control","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person controls a company or bank if that person, directly or indirectly, or acting through or in concert with 1 or more persons—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3f3789-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns, controls, or has the power to vote 25 percent or more of any class of the company’s voting securities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3f378a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" controls in any manner the election of a majority of the company’s directors; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3f378b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the power to exercise a controlling influence over the company’s management or policies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3f378c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person is an “executive officer” of a company or bank if that person participates or has authority to participate (other than as a director) in major policymaking functions of the company or bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3f378d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of credit","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3f378e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member bank extends credit to a person by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddb3f378f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making or renewing any loan, granting a line of credit, or entering into any similar transaction as a result of which the person becomes obligated (directly or indirectly, or by any means whatsoever) to pay money or its equivalent to the bank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddb3f3790-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having credit exposure to the person arising from a derivative transaction (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s84/b"},"text":"section 84(b) of this title","children":[],"tail":"), repurchase agreement, reverse repurchase agreement, securities lending transaction, or securities borrowing transaction between the member bank and the person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3f3791-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may, by regulation, make exceptions to clause (i) for transactions that the Board determines pose minimal risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3f3792-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Member bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “member bank” includes any subsidiary of a member bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3f3793-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal shareholder","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “principal shareholder”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3f3794-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any person that directly or indirectly, or acting through or in concert with one or more persons, owns, controls, or has the power to vote more than 10 percent of any class of voting securities of a member bank or company; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3f3795-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a company of which a member bank is a subsidiary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3f3796-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A “related interest” of a person is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3f3797-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any company controlled by that person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3f3798-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any political or campaign committee that is controlled by that person or the funds or services of which will benefit that person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3f3799-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/9/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsidiary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “subsidiary” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841"},"text":"section 1841 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3f379a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s375b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board’s rulemaking authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Governors of the Federal Reserve System may prescribe such regulations, including definitions of terms, as it determines to be necessary to effectuate the purposes and prevent evasions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb3f379b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s22/h"},"text":"Dec. 23, 1913, ch. 6, § 22(h)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tI/s104"},"text":"Pub. L. 95–630, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3644"},"text":"92 Stat. 3644","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/320/tIV"},"text":"Pub. L. 97–320, title IV","children":[],"tail":", §§ 410(e), 422, "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1520"},"text":"96 Stat. 1520","children":[],"tail":", 1522; "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIII/s306/a"},"text":"Pub. L. 102–242, title III, § 306(a)","children":[],"tail":"–(h), "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2355"},"text":"105 Stat. 2355","children":[],"tail":", 2357–2359; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tIX/s955"},"text":"Pub. L. 102–550, title IX, § 955","children":[],"tail":", title XVI, § 1605(a)(10), "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3895"},"text":"106 Stat. 3895","children":[],"tail":", 4086; "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s334/b"},"text":"Pub. L. 103–325, title III, § 334(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2233"},"text":"108 Stat. 2233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2211"},"text":"Pub. L. 104–208, div. A, title II, § 2211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-410"},"text":"110 Stat. 3009–410","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVI/s614/a"},"text":"Pub. L. 111–203, title VI, § 614(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1614"},"text":"124 Stat. 1614","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb3f379c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb3f379d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddb3f379e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 22(h) of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6"},"text":"act Dec. 23, 1913, ch. 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch653/s3"},"text":"June 19, 1934, ch. 653, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1107"},"text":"48 Stat. 1107","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s596"},"text":"section 596 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645/s21"},"text":"act June 25, 1948, ch. 645, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/862"},"text":"62 Stat. 862","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb3f379f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (9)(D)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “extends credit to a person by—” for “extends credit by making”, inserted “(I) making” before “or renewing”, substituted “which the person” for “which a person” and “the bank; or” for “the bank.”, and added subcl. (II)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2211/a/1"},"text":"Pub. L. 104–208, § 2211(a)(1)","children":[],"tail":", (2), designated existing provisions as subpar. (A), inserted heading, redesignated former subpars. (A) to (C) as cls. (i) to (iii), respectively, and adjusted margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2211/a/3"},"text":"Pub. L. 104–208, § 2211(a)(3)","children":[],"tail":", added subpar. (B). Former subpar. (B) redesignated cl. (ii) of subpar. (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2211/a/1"},"text":"Pub. L. 104–208, § 2211(a)(1)","children":[],"tail":", redesignated subpar. (C) as cl. (iii) of subpar. (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2211/b"},"text":"Pub. L. 104–208, § 2211(b)","children":[],"tail":", amended heading and text of subpar. (B) generally. Prior to amendment, text read as follows: “The Board may, by regulation, make exceptions to subparagraph (A), except as that subparagraph makes applicable paragraph (2), for an executive officer or director of a subsidiary of a company that controls the member bank, if that executive officer or director does not have authority to participate, and does not participate, in major policymaking functions of the member bank.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":" designated existing provisions as subpar. (A), inserted heading, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Par. (6)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1605/a/10"},"text":"Pub. L. 102–550, § 1605(a)(10)","children":[],"tail":", substituted “or” for “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s955/a"},"text":"Pub. L. 102–550, § 955(a)","children":[],"tail":", designated existing provisions as cl. (i), inserted heading, and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s955/b"},"text":"Pub. L. 102–550, § 955(b)","children":[],"tail":", designated portion of existing provisions as cl. (i), realigned margin, substituted “; and” for period at end, and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s306/a"},"text":"Pub. L. 102–242, § 306(a)","children":[],"tail":", amended section generally, substituting provisions relating to extensions of credit to executive officers, directors, and principal shareholders of member banks for provisions relating to prohibitions respecting loans and extensions of credit to executive officers and directors of banks, political or campaign committees, etc."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s306/d/2"},"text":"Pub. L. 102–242, § 306(d)(2)","children":[],"tail":", inserted “(5),” after “(4),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s306/b"},"text":"Pub. L. 102–242, § 306(b)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s306/c"},"text":"Pub. L. 102–242, § 306(c)","children":[],"tail":", inserted “, director,” after “executive officer” in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s306/d/1"},"text":"Pub. L. 102–242, § 306(d)(1)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s306/e"},"text":"Pub. L. 102–242, § 306(e)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s306/f"},"text":"Pub. L. 102–242, § 306(f)","children":[],"tail":", struck out “bank holding” before “company of which the member”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s306/g"},"text":"Pub. L. 102–242, § 306(g)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s306/h"},"text":"Pub. L. 102–242, § 306(h)","children":[],"tail":", struck out last sentence of subpar. (F) which read as follows: “For purposes of paragraph (4), if a member bank has its main banking office in a city, town, or village with a population of less than 30,000, the preceding sentence shall apply with ‘18 percent’ substituted for ‘10 percent’.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320/s422"},"text":"Pub. L. 97–320, § 422","children":[],"tail":", substituted “an amount prescribed in a regulation of the appropriate Federal banking agency” for “$25,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6)(C) to (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320/s410/e"},"text":"Pub. L. 97–320, § 410(e)","children":[],"tail":", redesignated subpars. (D) to (G) as (C) to (F), respectively. Former subpar. (C), relating to definition of term “extension of credit”, was struck out."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb3f37a0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb3f37a1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVI/s614/b"},"text":"Pub. L. 111–203, title VI, § 614(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1614"},"text":"124 Stat. 1614","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/203/tVI/s614/b"},"text":"“The amendments made by this section [amending this section] shall take effect 1 year after the transfer date.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “transfer date” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s614/b"},"text":"section 614(b) of Pub. L. 111–203","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb3f37a2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1605/a/10"},"text":"section 1605(a)(10) of Pub. L. 102–550","children":[],"tail":" effective as if included in the Federal Deposit Insurance Corporation Improvement Act of 1991, "},{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":", as of "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1609"},"text":"section 1609 of Pub. L. 102–550","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s191"},"text":"section 191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb3f37a3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIII/s306"},"text":"Pub. L. 102–242, title III, § 306","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2360"},"text":"105 Stat. 2360","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/stat/105/2360"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by this section [amending this section and sections 1468, 1828, and 1972 of this title] shall become effective upon the earlier of—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which final regulations under subsection (m)(1) [set out below] become effective [","children":[{"tag":"date","attrib":{"date":"1992-05-18"},"text":"May 18, 1992","children":[],"tail":", see 57 F.R. 22417]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 150 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddb3f37a4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXXI/s2101"},"text":"Pub. L. 95–630, title XXI, § 2101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3741"},"text":"92 Stat. 3741","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/630/tXXI/s2101"},"text":"“Except as otherwise provided herein, this Act [see Short Title of 1978 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s226"},"text":"section 226 of this title","children":[],"tail":"] shall take effect upon the expiration of one hundred and twenty days after the date of its enactment ["},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb3f37a5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIII/s306/m"},"text":"Pub. L. 102–242, title III, § 306(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2360"},"text":"105 Stat. 2360","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/242/tIII/s306/m"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board of Governors of the Federal Reserve System shall, not later than 120 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":"], promulgate final regulations to implement the amendments made by this section [amending this section and sections 1468, 1828, and 1972 of this title], other than the amendments made by subsections (i) and (k) [amending sections 1468 and 1828 of this title]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limiting extensions of credit to executive officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Deposit Insurance Corporation and Director of the Office of Thrift Supervision shall each, not later than 120 days after the date of enactment of this Act, promulgate final regulations prescribing the maximum amount that a nonmember insured bank or insured savings association (as the case may be) may lend under section 22(g)(4) of the Federal Reserve Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s375a/4"},"text":"12 U.S.C. 375a(4)","children":[],"tail":"], as made applicable to those institutions by subsections (k) and (i), respectively.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb3f37a6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Existing Transactions Not Affected by 1991 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIII/s306/n"},"text":"Pub. L. 102–242, title III, § 306(n)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2360"},"text":"105 Stat. 2360","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/242/tIII/s306/n"},"text":"“The amendments made by this section [amending this section and sections 1468, 1828, and 1972 of this title] do not affect the validity of any extension of credit or other transaction lawfully entered into on or before the effective date of those amendments [see Effective Date of 1991 Amendment note above].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb3f37a7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reporting of Credit by Executive Officers and Directors","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIII/s306"},"text":"Pub. L. 102–242, title III, § 306","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2360"},"text":"105 Stat. 2360","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/stat/105/2360"},"text":"“An executive officer or director of an insured depository institution, a bank holding company, or a savings and loan holding company, the shares of which are not publicly traded, shall report annually to the board of directors of the institution or holding company the outstanding amount of any credit that was extended to such executive officer or director and that is secured by shares of the institution or holding company.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
