{"tag":"section","attrib":{"id":"iddcde1a06-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"2277a–7"},"text":"§ 2277a–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General corporate powers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"On ","children":[{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":", the Corporation shall become a body corporate and as such shall have the following powers:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcde1a07-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–7/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may adopt and use a corporate seal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a08-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–7/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Succession","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may have succession until dissolved by an Act of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a09-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–7/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may make contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a0a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–7/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal actions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcde1a0b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–7/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may sue and be sued, complain and defend, in any court of law or equity, State or Federal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcde1a0c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–7/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All suits of a civil nature at common law or in equity to which the Corporation shall be a party shall be deemed to arise under the laws of the United States, and the United States district courts shall have original jurisdiction thereof, without regard to the amount in controversy, and the Corporation, in any capacity, without bond or security, may remove any such action, suit, or proceeding from a State court to the United States district court for the district or division embracing the place where the same is pending by following any procedure for removal then in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcde1a0d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–7/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attachment and execution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No attachment or execution may be issued against the Corporation or its property before final judgment in any suit, action, or proceeding in any State, county, municipal, or United States court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcde1a0e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–7/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agent for service of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Directors shall designate an agent on whom service of process may be made in any State or jurisdiction in which any insured System bank is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a0f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–7/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers and employees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcde1a10-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–7/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may appoint by its Board of Directors such officers and employees as are not otherwise provided for in this part, define their duties, fix their compensation, and require bonds of them and fix the penalty thereof, and dismiss at pleasure such officers or employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcde1a11-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–7/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter or any other Act shall be construed to prevent the appointment and compensation, as an officer or employee of the Corporation, of any officer or employee of the United States in any board, commission, independent establishment, or executive department thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a12-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–7/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bylaws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may prescribe, by its Board of Directors, bylaws not inconsistent with law, regulating the manner in which its general business may be conducted, and the privileges granted to it by law may be exercised and enjoyed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a13-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–7/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incidental powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may exercise by its Board of Directors, or duly authorized officers or agents, all powers specifically granted by the provisions of this part, and such incidental powers as shall be necessary to carry out the powers so granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a14-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–7/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may, when necessary, make examinations of, and require information and reports from, System institutions, as provided in this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a15-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–7/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservator or receiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may act as a conservator or receiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcde1a16-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2277a–7/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may prescribe by its Board of Directors such rules and regulations as it considers necessary to carry out this part and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2020/b"},"text":"section 2020(b) of this title","children":[],"tail":" (except to the extent that authority to issue such rules and regulations has been expressly and exclusively granted to any other regulatory agency)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcde1a17-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".58, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIII/s302"},"text":"Pub. L. 100–233, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1614"},"text":"101 Stat. 1614","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIII/s302/i"},"text":"Pub. L. 100–399, title III, § 302(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/994"},"text":"102 Stat. 994","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tV/s502/j"},"text":"Pub. L. 102–237, title V, § 502(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1869"},"text":"105 Stat. 1869","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/552/tII/s202/a"},"text":"Pub. L. 102–552, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4105"},"text":"106 Stat. 4105","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/105/tII/s214/b"},"text":"Pub. L. 104–105, title II, § 214(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/sta