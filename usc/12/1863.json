{"tag":"section","attrib":{"id":"iddcb5ab82-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1863"},"text":null,"children":[{"tag":"num","attrib":{"value":"1863"},"text":"§ 1863.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible bank service company activities for depository institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Without regard to the provisions of sections 1864 and 1865 of this title, an insured depository institution may invest in a bank service company that performs, and a bank service company may perform, the following services only for depository institutions: check and deposit sorting and posting, computation and posting of interest and other credits and charges, preparation and mailing of checks, statements, notices, and similar items, or any other clerical, bookkeeping, accounting, statistical, or similar functions performed for a depository institution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcb5ab83-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/856/s3"},"text":"Pub. L. 87–856, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1132"},"text":"76 Stat. 1132","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/320/tVII/s709"},"text":"Pub. L. 97–320, title VII, § 709","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1541"},"text":"96 Stat. 1541","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2613/d"},"text":"Pub. L. 104–208, div. A, title II, § 2613(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-477"},"text":"110 Stat. 3009–477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tVI/s602/a"},"text":"Pub. L. 109–351, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1978"},"text":"120 Stat. 1978","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcb5ab84-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcb5ab85-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcb5ab86-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351"},"text":"Pub. L. 109–351","children":[],"tail":" substituted “insured depository institution” for “insured bank”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “company” for “corporation” wherever appearing in section catchline and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320"},"text":"Pub. L. 97–320","children":[],"tail":" substituted provisions relating to permissible bank service corporation activities for depository institutions for provisions that a bank service corporation must provide bank services to a bank that applied for them if the applying bank competed with a bank which held stock in the corporation unless comparable services were available elsewhere at competitive cost or furnishing the services would be beyond the practical capacity of the corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
