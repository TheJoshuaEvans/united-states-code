{"tag":"section","attrib":{"id":"iddd6d3bcb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5495"},"text":null,"children":[{"tag":"num","attrib":{"value":"5495"},"text":"§ 5495.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Bureau shall coordinate with the Commission, the Commodity Futures Trading Commission, the Federal Trade Commission, and other Federal agencies and State regulators, as appropriate, to promote consistent regulatory treatment of consumer financial and investment products and services.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd6d3bcc-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1015"},"text":"Pub. L. 111–203, title X, § 1015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1974"},"text":"124 Stat. 1974","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
