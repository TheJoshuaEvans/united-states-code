{"tag":"section","attrib":{"id":"iddd104e64-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3768"},"text":null,"children":[{"tag":"num","attrib":{"value":"3768"},"text":"§ 3768.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deficiency judgment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd104e65-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3768/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd104e66-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3768/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral to Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If after deducting the payments provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3762"},"text":"section 3762 of this title","children":[],"tail":", the price at which the security property is sold at a foreclosure sale is less than the unpaid balance of the debt secured by the security property, resulting in a deficiency, the Secretary may refer the matter to the Attorney General who may commence an action or actions against any or all debtors to recover the deficiency, unless such an action is specifically prohibited by the mortgage."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104e67-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3768/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other recoveries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any action instituted pursuant to this section the United States may recover—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd104e68-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3768/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s3011"},"text":"section 3011 of title 28","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd104e69-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3768/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd104e6a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3768/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any action commenced to recover a deficiency under this section must be brought not later than 6 years after the date of the last sale of the security property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd104e6b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/327/tII"},"text":"Pub. L. 103–327, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-28"},"text":"Sept. 28, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2316"},"text":"108 Stat. 2316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd104e6c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd104e6d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd104e6e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 819 of title VIII of S. 2281, One Hundred Third Congress, as reported ","children":[{"tag":"date","attrib":{"date":"1994-07-13"},"text":"July 13, 1994","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/103/327"},"text":"Pub. L. 103–327","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
