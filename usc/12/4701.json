{"tag":"section","attrib":{"id":"iddd36745e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4701"},"text":null,"children":[{"tag":"num","attrib":{"value":"4701"},"text":"§ 4701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd36745f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd367460-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" many of the Nation’s urban, rural, and Native American communities face critical social and economic problems arising in part from the lack of economic growth, people living in poverty, and the lack of employment and other opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd367461-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the restoration and maintenance of the economies of these communities will require coordinated development strategies, intensive supportive services, and increased access to equity investments and loans for development activities, including investment in businesses, housing, commercial real estate, human development, and other activities that promote the long-term economic and social viability of the community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd367462-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4701/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community development financial institutions have proven their ability to identify and respond to community needs for equity investments, loans, and development services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd367463-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this subchapter is to create a Community Development Financial Institutions Fund to promote economic revitalization and community development through investment in and assistance to community development financial institutions, including enhancing the liquidity of community development financial institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd367464-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s102"},"text":"Pub. L. 103–325, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2163"},"text":"108 Stat. 2163","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd367465-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd367466-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd367467-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (b), was in original “this subtitle”, meaning subtitle A of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2163"},"text":"108 Stat. 2163","children":[],"tail":", which is classified principally to this subchapter. For complete classification of this subtitle to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd367468-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddd367469-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s1/a"},"text":"Pub. L. 103–325, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2160"},"text":"108 Stat. 2160","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/325/s1/a"},"text":"“This Act [see Tables for classification] may be cited as the ‘Riegle Community Development and Regulatory Improvement Act of 1994’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"t