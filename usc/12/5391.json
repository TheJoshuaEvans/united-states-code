{"tag":"section","attrib":{"id":"iddd63c5c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391"},"text":null,"children":[{"tag":"num","attrib":{"value":"5391"},"text":"§ 5391.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspector General reviews","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd63c5c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" to (c) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd63c5c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FDIC Inspector General reviews","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd63c5c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Inspector General of the Corporation shall conduct, supervise, and coordinate audits and investigations of the liquidation of any covered financial company by the Corporation as receiver under this subchapter, including collecting and summarizing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd63c5c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of actions taken by the Corporation as receiver;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd63c5c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any material sales, transfers, mergers, obligations, purchases, and other material transactions entered into by the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd63c5c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the adequacy of the policies and procedures of the Corporation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5383/d"},"text":"section 5383(d) of this title","children":[],"tail":" and orderly liquidation plan under section 5390(n)(14) "},{"tag":"ref","attrib":{"idref":"fn002483"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002483"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd63c5c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the utilization by the Corporation of the private sector in carrying out its functions, including the adequacy of any conflict-of-interest reviews; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd63c5c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the overall performance of the Corporation in liquidating the covered financial company, including administrative costs, timeliness of liquidation process, and impact on the financial system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd63c5c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after the date of appointment of the Corporation as receiver under this subchapter and every 6 months thereafter, the Inspector General of the Corporation shall conduct the audit and investigation described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd63c5ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and testimony","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Corporation shall include in the semiannual reports required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s405/b"},"text":"section 405(b) of title 5","children":[],"tail":", a summary of the findings and evaluations under paragraph (1), and shall appear before the appropriate committees of Congress, if requested, to present each such report."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd63c5cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd63c5cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The expenses of the Inspector General of the Corporation in carrying out this subsection shall be considered administrative expenses of the receivership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd63c5cd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the maximum amount available to the Corporation as receiver under this subchapter is insufficient to enable the Inspector General of the Corporation to carry out the duties under this subsection, the Corporation shall pay such additional amounts from assessments imposed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5390"},"text":"section 5390 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd63c5ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The duties and responsibilities of the Inspector General of the Corporation under this subsection shall terminate 1 year after the date of termination of the receivership under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd63c5cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treasury Inspector General reviews","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd63c5d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Inspector General of the Department of the Treasury shall conduct, supervise, and coordinate audits and investigations of actions taken by the Secretary related to the liquidation of any covered financial company under this subchapter, including collecting and summarizing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd63c5d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of actions taken by the Secretary under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd63c5d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the approval by the Secretary of the policies and procedures of the Corporation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5383"},"text":"section 5383 of this title","children":[],"tail":" and acceptance of the orderly liquidation plan of the Corporation under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5390"},"text":"section 5390 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd63c5d3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the terms and conditions underlying the purchase by the Secretary of obligations of the Corporation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5390"},"text":"section 5390 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd63c5d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after the date of appointment of the Corporation as receiver under this subchapter and every 6 months thereafter, the Inspector General of the Department of the Treasury shall conduct the audit and investigation described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd63c5d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and testimony","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Department of the Treasury shall include in the semiannual reports required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s405/b"},"text":"section 405(b) of title 5","children":[],"tail":", a summary of the findings and assessments under paragraph (1), and shall appear before the appropriate committees of Congress, if requested, to present each such report."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd63c5d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The duties and responsibilities of the Inspector General of the Department of the Treasury under this subsection shall terminate 1 year after the date on which the obligations purchased by the Secretary from the Corporation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5390"},"text":"section 5390 of this title","children":[],"tail":" are fully redeemed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd63c5d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Primary financial regulatory agency Inspector General reviews","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd63c5d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon the appointment of the Corporation as receiver for a covered financial company supervised by a Federal primary financial regulatory agency or the Board of Governors under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5365"},"text":"section 5365 of this title","children":[],"tail":", the Inspector General of the agency or the Board of Governors shall make a written report reviewing the supervision by the agency or the Board of Governors of the covered financial company, which shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd63c5d9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the effectiveness of the agency or the Board of Governors in carrying out its supervisory responsibilities with respect to the covered financial company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd63c5da-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any acts or omissions on the part of agency or Board of Governors officials that contributed to the covered financial company being in default or in danger of default;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd63c5db-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any actions that could have been taken by the agency or the Board of Governors that would have prevented the company from being in default or in danger of default; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd63c5dc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend appropriate administrative or legislative action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd63c5dd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5391/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and testimony","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date of appointment of the Corporation as receiver under this subchapter, the Inspector General of the Federal primary financial regulatory agency or the Board of Governors shall provide the report required by paragraph (1) to such agency or the Board of Governors, and along with such agency or the Board of Governors, as applicable, shall appear before the appropriate committees of Congress, if requested, to present the report required by paragraph (1). Not later than 90 days after the date of receipt of the report required by paragraph (1), such agency or the Board of Governors, as applicable, shall provide a written report to Congress describing any actions taken in response to the recommendations in the report, and if no such actions were taken, describing the reasons why no actions were taken.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd63c5de-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tII/s211"},"text":"Pub. L. 111–203, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1514"},"text":"124 Stat. 1514","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/36"},"text":"Pub. L. 117–286, § 4(b)(36)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4347"},"text":"136 Stat. 4347","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd63c5df-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd63c5e0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd63c5e1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsecs. (d)(1), (2), (4)(B), (5), (e)(1), (2), and (f)(2), was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1442"},"text":"124 Stat. 1442","children":[],"tail":", which is classified principally to this subchapter. For complete classification of title II to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5390/n/14"},"text":"Section 5390(n)(14) of this title","children":[],"tail":", referred to in subsec. (d)(1)(C), probably means section 5390(n)(9), because "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5390/n"},"text":"section 5390(n) of this title","children":[],"tail":" does not contain a par. (14) and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5390/n/9"},"text":"section 5390(n)(9) of this title","children":[],"tail":" relates to orderly liquidation plans."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd63c5e2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s211"},"text":"section 211 of Pub. L. 111–203","children":[],"tail":". Subsecs. (a) to (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s211"},"text":"section 211 of Pub. L. 111–203","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4403"},"text":"section 4403 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1032"},"text":"section 1032 of title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd63c5e3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/36/A"},"text":"Pub. L. 117–286, § 4(b)(36)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s405/b"},"text":"section 405(b) of title 5","children":[],"tail":",” for “section 5(a) of the Inspector General Act of 1978 (5 U.S.C. App.),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/36/B"},"text":"Pub. L. 117–286, § 4(b)(36)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s405/b"},"text":"section 405(b) of title 5","children":[],"tail":",” for “section 5(a) of the Inspector General Act of 1978 (5 U.S.C. App.),”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd63c5e4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd63c5e5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
