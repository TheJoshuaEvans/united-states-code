{"tag":"section","attrib":{"id":"iddd06b1c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3352"},"text":null,"children":[{"tag":"num","attrib":{"value":"3352"},"text":"§ 3352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency exceptions for disaster areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd06b1c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3352/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Federal financial institutions regulatory agency may, by regulation or order, make exceptions to this chapter, and to standards prescribed pursuant to this chapter, for transactions involving institutions for which the agency is the primary Federal regulator with respect to real property located within a disaster area if the agency—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd06b1c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3352/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes the exception not later than 30 months after the date on which the President determines, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"section 5170 of title 42","children":[],"tail":", that a major disaster exists in the area; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b1c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3352/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determines that the exception—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd06b1c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3352/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would facilitate recovery from the major disaster; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06b1c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3352/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with safety and soundness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06b1ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3352/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 3-year limit on exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any exception made under this section shall expire not later than 3 years after the date of the determination referred to in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06b1cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3352/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any Federal financial institutions regulatory agency shall publish in the Federal Register a statement that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd06b1cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3352/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes any exception made under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd06b1cd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3352/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" explains how the exception—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd06b1ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3352/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would facilitate recovery from the major disaster; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd06b1cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3352/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with safety and soundness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd06b1d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3352/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Disaster area” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “disaster area” means an area in which the President, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"section 5170 of title 42","children":[],"tail":", has determined that a major disaster exists."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd06b1d1-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXI/s1123"},"text":"Pub. L. 101–73, title XI, § 1123","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/485/s2"},"text":"Pub. L. 102–485, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2771"},"text":"106 Stat. 2771","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
