{"tag":"section","attrib":{"id":"iddcbf2197-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2072"},"text":null,"children":[{"tag":"num","attrib":{"value":"2072"},"text":"§ 2072.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of directors","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each production credit association shall elect from the voting members of such association, a board of directors of such number, for such terms, with such qualifications, and in such manner as may be required by the bylaws of the association, except that at least one member shall be elected by the other directors, which member shall not be a director, officer, employee, stockholder, or agent of a System institution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcbf2198-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tII/s2"},"text":"Pub. L. 92–181, title II, § 2","children":[],"tail":".1, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1630"},"text":"101 Stat. 1630","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s401/n"},"text":"Pub. L. 100–399, title IV, § 401(n)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/997"},"text":"102 Stat. 997","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tV/s502/c"},"text":"Pub. L. 102–237, title V, § 502(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/10