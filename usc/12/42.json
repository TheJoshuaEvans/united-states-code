{"tag":"section","attrib":{"id":"iddb0d2b97-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s42"},"text":null,"children":[{"tag":"num","attrib":{"value":"42"},"text":"§ 42.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territorial application","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of all Acts of Congress relating to national banks shall apply in the several States, the District of Columbia, the several Territories and possessions of the United States, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb0d2b98-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/230/s14"},"text":"Pub. L. 86–230, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-08"},"text":"Sept. 8, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/458"},"text":"73 Stat. 458","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
