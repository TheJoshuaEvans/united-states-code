{"tag":"section","attrib":{"id":"iddb92ae88-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1465"},"text":null,"children":[{"tag":"num","attrib":{"value":"1465"},"text":"§ 1465.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State law preemption standards for Federal savings associations clarified","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb92ae89-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1465/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any determination by a court or by the Director or any successor officer or agency regarding the relation of State law to a provision of this chapter or any regulation or order prescribed under this chapter shall be made in accordance with the laws and legal standards applicable to national banks regarding the preemption of State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb92ae8a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1465/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principles of conflict preemption applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the authorities granted under sections 1463 and 1464 of this title, this chapter does not occupy the field in any area of State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb92ae8b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1465/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visitorial powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of sections ","children":[{"tag":"ref","attrib":{"idref":"fn002095"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002095"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 25b(i) of this title shall apply to Federal savings associations, and any subsidiary thereof, to the same extent and in the same manner as if such savings associations, or subsidiaries thereof, were national banks or subsidiaries of national banks, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb92ae8c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1465/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The ability of the Comptroller of the Currency to bring an enforcement action under this chapter or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"section 45 of title 15","children":[],"tail":" does not preclude any private party from enforcing rights granted under Federal or State law in the courts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb92ae8d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-13/ch64/s6"},"text":"June 13, 1933, ch. 64, § 6","children":[],"tail":", as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX"},"text":"Pub. L. 111–203, title X","children":[],"tail":", §§ 1046(a), 1047(b), "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/u