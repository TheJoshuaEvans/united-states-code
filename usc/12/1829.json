{"tag":"section","attrib":{"id":"iddc8f84ed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829"},"text":null,"children":[{"tag":"num","attrib":{"value":"1829"},"text":"§ 1829.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for unauthorized participation by convicted individual","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc8f84ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f84ef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except with the prior written consent of the Corporation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f84f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any person who has been convicted of any criminal offense involving dishonesty or a breach of trust or money laundering, or has agreed to enter into a pretrial diversion or similar program in connection with a prosecution for such offense, may not—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc8f84f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" become, or continue as, an institution-affiliated party with respect to any insured depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc8f84f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" own or control, directly or indirectly, any insured depository institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc8f84f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise participate, directly or indirectly, in the conduct of the affairs of any insured depository institution; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f84f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any insured depository institution may not permit any person referred to in subparagraph (A) to engage in any conduct or continue any relationship prohibited under such subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f84f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum 10-year prohibition period for certain offenses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f84f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the offense referred to in paragraph (1)(A) in connection with any person referred to in such paragraph is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc8f84f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an offense under—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddc8f84f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/a/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 215, 656, 657, 1005, 1006, 1007, 1008,","children":[{"tag":"ref","attrib":{"idref":"fn002263"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002263"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" 1014, 1032, 1344, 1517, 1956, or 1957 of title 18; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddc8f84f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/a/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1341 or 1343 of such title which affects any financial institution (as defined in section 20 of such title); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc8f84fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense of conspiring to commit any such offense,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Corporation may not consent to any exception to the application of paragraph (1) to such person during the 10-year period beginning on the date the conviction or the agreement of the person becomes final.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f84fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception by order of sentencing court","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc8f84fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On motion of the Corporation, the court in which the conviction or the agreement of a person referred to in subparagraph (A) has been entered may grant an exception to the application of paragraph (1) to such person if granting the exception is in the interest of justice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc8f84fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period for filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A motion may be filed under clause (i) at any time during the 10-year period described in subparagraph (A) with regard to the person on whose behalf such motion is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f84fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever knowingly violates subsection (a) shall be fined not more than $1,000,000 for each day such prohibition is violated or imprisoned for not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f84ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f8500-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain older offenses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f8501-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to an individual, subsection (a) shall not apply to an offense if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc8f8502-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it has been 7 years or more since the offense occurred; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc8f8503-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual was incarcerated with respect to the offense and it has been 5 years or more since the individual was released from incarceration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f8504-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses committed by individuals 21 or younger","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For individuals who committed an offense when they were 21 years of age or younger, subsection (a) shall not apply to the offense if it has been more than 30 months since the sentencing occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f8505-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This paragraph shall not apply to an offense described under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f8506-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expungement and sealing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to an individual, subsection (a) shall not apply to an offense if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f8507-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is an order of expungement, sealing, or dismissal that has been issued in regard to the conviction in connection with such offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f8508-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is intended by the language in the order itself, or in the legislative provisions under which the order was issued, that the conviction shall be destroyed or sealed from the individual’s State, Tribal, or Federal record, even if exceptions allow the record to be considered for certain character and fitness evaluation purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f8509-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" De minimis exemption","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f850a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to such de minimis offenses as the Corporation determines, by rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f850b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confinement criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In issuing rules under subparagraph (A), the Corporation shall include a requirement that the offense was punishable by a term of three years or less confined in a correctional facility, where such confinement—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc8f850c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is calculated based on the time an individual spent incarcerated as a punishment or a sanction, not as pretrial detention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc8f850d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include probation or parole where an individual was restricted to a particular jurisdiction or was required to report occasionally to an individual or a specific location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f850e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bad check criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In setting the criteria for de minimis offenses under subparagraph (A), if the Corporation establishes criteria with respect to insufficient funds checks, the Corporation shall require that the aggregate total face value of all insufficient funds checks across all convictions or program entries related to insufficient funds checks is $2,000 or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f850f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated lesser offenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to certain lesser offenses (including the use of a fake ID, shoplifting, trespass, fare evasion, driving with an expired license or tag, and such other low-risk offenses as the Corporation may designate) if 1 year or more has passed since the applicable conviction or program entry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f8510-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bank holding companies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f8511-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (a) and (b) shall apply to any company (other than a foreign bank) that is a bank holding company and any organization organized and operated under section 25A of the Federal Reserve Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s611"},"text":"12 U.S.C. 611","children":[],"tail":" et seq.] or operating under section 25 of the Federal Reserve Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s601"},"text":"12 U.S.C. 601","children":[],"tail":" et seq.], as if such bank holding company or organization were an insured depository institution, except that such subsections shall be applied for purposes of this subsection by substituting “Board of Governors of the Federal Reserve System” for “Corporation” each place that term appears in such subsections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f8512-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Governors of the Federal Reserve System may provide exemptions, by regulation or order, from the application of paragraph (1) if the exemption is consistent with the purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f8513-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings and loan holding companies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f8514-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (a) and (b) shall apply to any savings and loan holding company as if such savings and loan holding company were an insured depository institution, except that such subsections shall be applied for purposes of this subsection by substituting “Board of Governors of the Federal Reserve System” for “Corporation” each place that term appears in such subsections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f8515-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Governors of the Federal Reserve System may provide exemptions, by regulation or order, from the application of paragraph (1) if the exemption is consistent with the purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f8516-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f8517-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall accept consent applications from an individual and from an insured depository institution or depository institution holding company on behalf of an individual that are filed separately or contemporaneously with a regional office of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f8518-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sponsored applications filed with regional offices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consent applications filed at a regional office of the Corporation by an insured depository institution or depository institution holding company on behalf of an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f8519-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be reviewed by such office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f851a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be approved or denied by such office, if such authority has been delegated to such office by the Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f851b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may only be denied by such office if the general counsel of the Corporation (or a designee) certifies that the denial is consistent with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f851c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual applications filed with regional offices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consent applications filed at a regional office by an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f851d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be reviewed by such office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f851e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be approved or denied by such office, if such authority has been delegated to such office by the Corporation, except with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc8f851f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cases involving an offense described under subsection (a)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc8f8520-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other high-level security cases as may be designated by the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f8521-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National office review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The national office of the Corporation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f8522-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review any consent application with respect to which a regional office is not authorized to approve or deny the application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f8523-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review any consent application that is denied by a regional office, if the individual requests a review by the national office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f8524-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forms and instructions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f8525-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall make all forms and instructions related to consent applications available to the public, including on the website of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f8526-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The forms and instructions described under subparagraph (A) shall provide a sample cover letter and a comprehensive list of items that may accompany the application, including clear guidance on evidence that may support a finding of rehabilitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f8527-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of criminal history","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f8528-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional office consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In reviewing a consent application, a regional office shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc8f8529-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primarily rely on the criminal history record of the Federal Bureau of Investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc8f852a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such record to the applicant to review for accuracy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f852b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified copies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may not require an applicant to provide certified copies of criminal history records unless the Corporation determines that there is a clear and compelling justification to require additional information to verify the accuracy of the criminal history record of the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f852c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of rehabilitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with title VII of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e"},"text":"42 U.S.C. 2000e","children":[],"tail":" et seq.), the Corporation shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f852d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an individualized assessment when evaluating consent applications that takes into account evidence of rehabilitation, the applicant’s age at the time of the conviction or program entry, the time that has elapsed since conviction or program entry, and the relationship of individual’s ","children":[{"tag":"ref","attrib":{"idref":"fn002264"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002264"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be preceded by “the”."}],"tail":" offense to the responsibilities of the applicable position;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f852e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the individual’s employment history, letters of recommendation, certificates documenting participation in substance abuse programs, successful participating in job preparation and educational programs, and other relevant mitigating evidence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f852f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider any additional information the Corporation determines necessary for safety and soundness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f8530-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of employment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to an approved consent application filed by an insured depository institution or depository institution holding company on behalf of an individual, if the Corporation determines it appropriate, such approved consent application shall allow the individual to work for the same employer (without restrictions on the location) and across positions, except that the prior consent of the Corporation (which may require a new application) shall be required for any proposed significant changes in the individual’s security-related duties or responsibilities, such as promotion to an officer or other positions that the employer determines will require higher security screening credentials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f8531-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/f/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with the NCUA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Corporation shall consult and coordinate with the National Credit Union Administration as needed to promote consistent implementation where appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc8f8532-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc8f8533-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consent application” means an application filed with Corporation ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" by an individual (or by an insured depository institution or depository institution holding company on behalf of an individual) seeking the written consent of the Corporation under subsection (a)(1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f8534-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal offense involving dishonesty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “criminal offense involving dishonesty”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc8f8535-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means an offense under which an individual, directly or indirectly—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc8f8536-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/g/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cheats or defrauds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc8f8537-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/g/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wrongfully takes property belonging to another in violation of a criminal statute;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f8538-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an offense that Federal, State, or local law defines as dishonest, or for which dishonesty is an element of the offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc8f8539-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc8f853a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/g/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a misdemeanor criminal offense committed more than one year before the date on which an individual files a consent application, excluding any period of incarceration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc8f853b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/g/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offense involving the possession of controlled substances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc8f853c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1829/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pretrial diversion or similar program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “pretrial diversion or similar program” means a program characterized by a suspension or eventual dismissal or reversal of charges or criminal prosecution upon agreement by the accused to restitution, drug or alcohol rehabilitation, anger management, or community service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc8f853d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"Sept. 21, 1950, ch. 967, § 2","children":[],"tail":"[19], "},{"tag":"ref","attrib":{"href":"/us/stat/64/893"},"text":"64 Stat. 893","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX/s910/a"},"text":"Pub. L. 101–73, title IX, § 910(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/477"},"text":"103 Stat. 477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2502/a"},"text":"Pub. L. 101–647, title XXV, § 2502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4860"},"text":"104 Stat. 4860","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXV/s1505"},"text":"Pub. L. 102–550, title XV, § 1505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4055"},"text":"106 Stat. 4055","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXII/s320605"},"text":"Pub. L. 103–322, title XXXII, § 320605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2119"},"text":"108 Stat. 2119","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tVII/s710/a"},"text":"Pub. L. 109–351, title VII, § 710(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1990"},"text":"120 Stat. 1990","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s363/8"},"text":"Pub. L. 111–203, title III, § 363(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1554"},"text":"124 Stat. 1554","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVII/s5705/a"},"text":"Pub. L. 117–263, div. E, title LVII, § 5705(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3411"},"text":"136 Stat. 3411","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc8f853e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc8f853f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddc8f8540-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1008"},"text":"Section 1008 of title 18","children":[],"tail":", referred to in subsec. (a)(2)(A)(i)(I), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX/s961/g/1"},"text":"Pub. L. 101–73, title IX, § 961(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/500"},"text":"103 Stat. 500","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 25 and 25A of the Federal Reserve Act, referred to in subsec. (d)(1), are classified to subchapters I (§ 601 et seq.) and II (§ 611 et seq.), respectively, of chapter 6 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1964, referred to in subsec. (f)(7), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Pub. L. 88–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/241"},"text":"78 Stat. 241","children":[],"tail":". Title VII of the Act is classified generally to subchapter VI (§ 2000e et seq.) of chapter 21 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"section 2000a of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc8f8541-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5705/a/1"},"text":"Pub. L. 117–263, § 5705(a)(1)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5705/a/2"},"text":"Pub. L. 117–263, § 5705(a)(2)","children":[],"tail":", added subsecs. (f) and (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Board of Governors of the Federal Reserve System” for “Director of the Office of Thrift Supervision” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351"},"text":"Pub. L. 109–351","children":[],"tail":" added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(2)(A)(i)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “1517, 1956, or 1957” for “or 1956”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" inserted “or money laundering” after “breach of trust”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “Except with the prior written consent of the Corporation—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) any person who has been convicted of any criminal offense involving dishonesty or a breach of trust may not participate, directly or indirectly, in any manner in the conduct of the affairs of an insured depository institution; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) an insured depository institution may not permit such participation.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “Except with the written consent of the Corporation, no person shall serve as a director, officer, or employee of an insured bank who has been convicted, or who is hereafter convicted, of any criminal offense involving dishonesty or a breach of trust. For each willful violation of this prohibition, the bank involved shall be subject to a penalty of not more than $100 for each day this prohibition is violated, which the Corporation may recover for its use.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc8f8542-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc8f8543-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s351"},"text":"section 351 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s906"},"text":"section 906 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddc8f8544-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Provisions Not Repealed, Modified or Affected","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing contained in sections 201 to 205 and 207 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/695"},"text":"Pub. L. 89–695","children":[],"tail":" amending sections 1813 and 1817 to 1820 and repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s77"},"text":"section 77 of this title","children":[],"tail":" to be construed as repealing, modifying, or affecting this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/89/695/s206"},"text":"section 206 of Pub. L. 89–695","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
