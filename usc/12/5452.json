{"tag":"section","attrib":{"id":"iddd688025-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452"},"text":null,"children":[{"tag":"num","attrib":{"value":"5452"},"text":"§ 5452.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Minority and Women Inclusion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd688026-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Minority and Women Inclusion","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd688027-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd688028-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", each agency shall establish an Office of Minority and Women Inclusion that shall be responsible for all matters of the agency relating to diversity in management, employment, and business activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd688029-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall establish an Office of Minority and Women Inclusion not later than 6 months after the designated transfer date established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5582"},"text":"section 5582 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd68802a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each agency that, on the day before ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", assigned the responsibilities described in paragraph (1) (or comparable responsibilities) to another office of the agency shall ensure that such responsibilities are transferred to the Office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd68802b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties with respect to civil rights laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responsibilities described in paragraph (1) do not include enforcement of statutes, regulations, or executive orders pertaining to civil rights, except each Director shall coordinate with the agency administrator, or the designee of the agency administrator, regarding the design and implementation of any remedies resulting from violations of such statutes, regulations, or executive orders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd68802c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd68802d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of each Office shall be appointed by, and shall report to, the agency administrator. The position of Director shall be a career reserved position in the Senior Executive Service, as that position is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132"},"text":"section 3132 of title 5","children":[],"tail":", or an equivalent designation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd68802e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Director shall develop standards for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd68802f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equal employment opportunity and the racial, ethnic, and gender diversity of the workforce and senior management of the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd688030-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased participation of minority-owned and women-owned businesses in the programs and contracts of the agency, including standards for coordinating technical assistance to such businesses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd688031-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the diversity policies and practices of entities regulated by the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd688032-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Director shall advise the agency administrator on the impact of the policies and regulations of the agency on minority-owned and women-owned businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd688033-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (2)(C) may be construed to mandate any requirement on or otherwise affect the lending policies and practices of any regulated entity, or to require any specific action based on the findings of the assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd688034-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion in all levels of business activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd688035-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of each Office shall develop and implement standards and procedures to ensure, to the maximum extent possible, the fair inclusion and utilization of minorities, women, and minority-owned and women-owned businesses in all business and activities of the agency at all levels, including in procurement, insurance, and all types of contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd688036-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The procedures established by each agency for review and evaluation of contract proposals and for hiring service providers shall include, to the extent consistent with applicable law, a component that gives consideration to the diversity of the applicant. Such procedure shall include a written statement, in a form and with such content as the Director shall prescribe, that a contractor shall ensure, to the maximum extent possible, the fair inclusion of women and minorities in the workforce of the contractor and, as applicable, subcontractors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd688037-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd688038-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The standards and procedures developed and implemented under this subsection shall include a procedure for the Director to make a determination whether an agency contractor, and, as applicable, a subcontractor has failed to make a good faith effort to include minorities and women in their workforce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd688039-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of determination","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd68803a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendation to agency administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon a determination described in subparagraph (A), the Director shall make a recommendation to the agency administrator that the contract be terminated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd68803b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by agency administrator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon receipt of a recommendation under clause (i), the agency administrator may—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd68803c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/c/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate the contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd68803d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/c/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a referral to the Office of Federal Contract Compliance Programs of the Department of Labor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd68803e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/c/3/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take other appropriate action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd68803f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to all contracts of an agency for services of any kind, including the services of financial institutions, investment banking firms, mortgage banking firms, asset management firms, brokers, dealers, financial services entities, underwriters, accountants, investment consultants, and providers of legal services. The contracts referred to in this subsection include all contracts for all business and activities of an agency, at all levels, including contracts for the issuance or guarantee of any debt, equity, or security, the sale of assets, the management of the assets of the agency, the making of equity investments by the agency, and the implementation by the agency of programs to address economic recovery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd688040-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Office shall submit to Congress an annual report regarding the actions taken by the agency and the Office pursuant to this section, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd688041-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the total amounts paid by the agency to contractors since the previous report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd688042-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of the amounts described in paragraph (1) that were paid to contractors described in subsection (c)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd688043-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the successes achieved and challenges faced by the agency in operating minority and women outreach programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd688044-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the challenges the agency may face in hiring qualified minority and women employees and contracting with qualified minority-owned and women-owned businesses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd688045-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information, findings, conclusions, and recommendations for legislative or agency action, as the Director determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd688046-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diversity in agency workforce","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each agency shall take affirmative steps to seek diversity in the workforce of the agency at all levels of the agency in a manner consistent with applicable law. Such steps shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd688047-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruiting at historically black colleges and universities, Hispanic-serving institutions, women’s colleges, and colleges that typically serve majority minority populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd688048-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sponsoring and recruiting at job fairs in urban communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd688049-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" placing employment advertisements in newspapers and magazines oriented toward minorities and women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd68804a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partnering with organizations that are focused on developing opportunities for minorities and women to place talented young minorities and women in industry internships, summer employment, and full-time positions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd68804b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where feasible, partnering with inner-city high schools, girls’ high schools, and high schools with majority minority populations to establish or enhance financial literacy programs and provide mentoring; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd68804c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other mass media communications that the Office determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd68804d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd68804e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd68804f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Departmental Offices of the Department of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd688050-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd688051-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Housing Finance Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd688052-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the Federal reserve banks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd688053-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/g/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd688054-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/g/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Credit Union Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd688055-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/g/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Comptroller of the Currency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd688056-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5452/g/1/H"},"text":null,"children":[{"tag":"num","attrib":