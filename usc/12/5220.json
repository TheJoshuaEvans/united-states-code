{"tag":"section","attrib":{"id":"iddd4bcfc0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220"},"text":null,"children":[{"tag":"num","attrib":{"value":"5220"},"text":"§ 5220.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to homeowners","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd4bcfc1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4bcfc2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “Federal property manager” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4bcfc3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Housing Finance Agency, in its capacity as conservator of the Federal National Mortgage Association and the Federal Home Loan Mortgage Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4bcfc4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation, with respect to residential mortgage loans and mortgage-backed securities held by any bridge depository institution pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1821/n"},"text":"section 1821(n) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4bcfc5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board, with respect to any mortgage or mortgage-backed securities or pool of securities held, owned, or controlled by or on behalf of a Federal reserve bank, other than mortgages or securities held, owned, or controlled in connection with open market operations under sections 348a and 353 to 359 of this title,","children":[{"tag":"ref","attrib":{"idref":"fn002449"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002449"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or as collateral for an advance or discount that is not in default;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4bcfc6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “consumer” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of title 15","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4bcfc7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “insured depository institution” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4bcfc8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “servicer” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2605/i/2"},"text":"section 2605(i)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4bcfc9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeowner assistance by agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4bcfca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that the Federal property manager holds, owns, or controls mortgages, mortgage backed ","children":[{"tag":"ref","attrib":{"idref":"fn002450"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002450"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “mortgage-backed”."}],"tail":" securities, and other assets secured by residential real estate, including multifamily housing, the Federal property manager shall implement a plan that seeks to maximize assistance for homeowners and use its authority to encourage the servicers of the underlying mortgages, and considering net present value to the taxpayer, to take advantage of the HOPE for Homeowners Program under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715z–23"},"text":"section 1715z–23 of this title","children":[],"tail":" or other available programs to minimize foreclosures."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4bcfcb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a residential mortgage loan, modifications made under paragraph (1) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4bcfcc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduction in interest rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4bcfcd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduction of loan principal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4bcfce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other similar modifications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4bcfcf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tenant protections","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of mortgages on residential rental properties, modifications made under paragraph (1) shall ensure—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4bcfd0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continuation of any existing Federal, State, and local rental subsidies and protections; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4bcfd1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that modifications take into account the need for operating funds to maintain decent and safe conditions at the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4bcfd2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal property manager shall develop and begin implementation of the plan required by this subsection not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2008-10-03"},"text":"October 3, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4bcfd3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal property manager shall, 60 days after ","children":[{"tag":"date","attrib":{"date":"2008-10-03"},"text":"October 3, 2008","children":[],"tail":", and every 30 days thereafter, report to Congress specific information on the number and types of loan modifications made and the number of actual foreclosures occurring during the reporting period in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4bcfd4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the plan required by this subsection, the Federal property managers shall consult with one another and, to the extent possible, utilize consistent approaches to implement the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4bcfd5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions with respect to servicers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which a Federal property manager is not the owner of a residential mortgage loan, but holds an interest in obligations or pools of obligations secured by residential mortgage loans, the Federal property manager shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd4bcfd6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage implementation by the loan servicers of loan modifications developed under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4bcfd7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in facilitating any such modifications, to the extent possible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd4bcfd8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5220/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this section shall not supersede any other duty or requirement imposed on the Federal property managers under otherwise applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd4bcfd9-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dA/tI/s110"},"text":"Pub. L. 110–343, div. A, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3775"},"text":"122 Stat. 3775","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd4bcfda-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd4bcfdb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd4bcfdc-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 348a and 353 to 359 of this title, referred to in subsec. (a)(1)(C), was in the original a reference to “section 14 of the Federal Reserve Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s353"},"text":"12 U.S.C. 353","children":[],"tail":")”. For classification of section 14 to the Code, see Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s353"},"text":"section 353 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd4bcfdd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd4bcfde-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effect of Foreclosure on Preexisting Tenancy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/22/dA/tVII/s702"},"text":"Pub. L. 111–22, div. A, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1660"},"text":"123 Stat. 1660","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXIV/s1484/1"},"text":"Pub. L. 111–203, title XIV, § 1484(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2204"},"text":"124 Stat. 2204","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/203/tXIV/s1484/1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any foreclosure on a federally-related mortgage loan or on any dwelling or residential real property after the date of enactment of this title [","children":[{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":"], any immediate successor in interest in such property pursuant to the foreclosure shall assume such interest subject to—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision, by such successor in interest of a notice to vacate to any bona fide tenant at least 90 days before the effective date of such notice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the rights of any bona fide tenant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under any bona fide lease entered into before the notice of foreclosure to occupy the premises until the end of the remaining term of the lease, except that a successor in interest may terminate a lease effective on the date of sale of the unit to a purchaser who will occupy the unit as a primary residence, subject to the receipt by the tenant of the 90 day notice under paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without a lease or with a lease terminable at will under State law, subject to the receipt by the tenant of the 90 day notice under subsection (1),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that nothing under this section shall affect the requirements for termination of any Federal- or State-subsidized tenancy or of any State or local law that provides longer time periods or other additional protections for tenants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bona Fide Lease or Tenancy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a lease or tenancy shall be considered bona fide only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mortgagor or the child, spouse, or parent of the mortgagor under the contract is not the tenant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lease or tenancy was the result of an arms-length transaction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lease or tenancy requires the receipt of rent that is not substantially less than fair market rent for the property or the unit’s rent is reduced or subsidized due to a Federal, State, or local subsidy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term ‘federally-related mortgage loan’ has the same meaning as in section 3 of the Real Estate Settlement Procedures Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2602"},"text":"12 U.S.C. 2602","children":[],"tail":"). For purposes of this section, the date of a notice of foreclosure shall be deemed to be the date on which complete title to a property is transferred to a successor entity or person as a result of an order of a court or pursuant to provisions in a mortgage, deed of trust, or security deed.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/22/s704"},"text":"Section 704 of Pub. L. 111–22","children":[],"tail":", as amended, formerly set out as a Termination Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of Title 42","children":[],"tail":", The Public Health and Welfare, which provided that title VII of div. A of "},{"tag":"ref","attrib":{"href":"/us/pl/111/22"},"text":"Pub. L. 111–22","children":[],"tail":", and the amendments made such title, are repealed, and the requirements under such title terminated, effective "},{"tag":"date","attrib":{"date":"2014-12-31"},"text":"Dec. 31, 2014","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/tIII/s304/a"},"text":"Pub. L. 115–174, title III, § 304(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1339"},"text":"132 Stat. 1339","children":[],"tail":", effective 30 days after "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":".]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/22/s702"},"text":"Section 702 of Pub. L. 111–22","children":[],"tail":", provisions of law amended by such section, and any regulations promulgated pursuant to such section, as in effect on "},{"tag":"date","attrib":{"date":"2014-12-30"},"text":"Dec. 30, 2014","children":[],"tail":", restored and revived, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/s304/b"},"text":"section 304(b) of Pub. L. 115–174","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of Title 42","children":[],"tail":", The Public Health and Welfare.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
