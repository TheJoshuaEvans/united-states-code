{"tag":"section","attrib":{"id":"iddd1e7f88-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4246"},"text":null,"children":[{"tag":"num","attrib":{"value":"4246"},"text":"§ 4246.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards of costs and fees to prevailing plaintiff","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When the United States, through private counsel retained under this subchapter, prevails in any civil action, the court, in its discretion, may allow the United States reasonable attorney’s fees and other expenses of litigation as part of the costs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd1e7f89-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2593"},"text":"Pub. L. 101–647, title XXV, § 2593","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4906"},"text":"104 Stat. 4906","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
