{"tag":"section","attrib":{"id":"iddca29798-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831v"},"text":null,"children":[{"tag":"num","attrib":{"value":"1831v"},"text":"§ 1831v.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of State insurance regulator and Securities and Exchange Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca29799-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831v/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the provisions of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca2979a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831v/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1844/c"},"text":"section 1844(c) of this title","children":[],"tail":" that limit the authority of the Board of Governors of the Federal Reserve System to require reports from, to make examinations of, or to impose capital requirements on holding companies and their functionally regulated subsidiaries or that require deference to other regulators;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca2979b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831v/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1844/g"},"text":"section 1844(g) of this title","children":[],"tail":" that limit the authority of the Board to require a functionally regulated subsidiary of a holding company to provide capital or other funds or assets to a depository institution subsidiary of the holding company and to take certain actions including requiring divestiture of the depository institution; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca2979c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831v/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1848a ","children":[{"tag":"ref","attrib":{"idref":"fn002272"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002272"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title that limit whatever authority the Board might otherwise have to take direct or indirect action with respect to holding companies and their functionally regulated subsidiaries;"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall also limit whatever authority that a Federal banking agency might otherwise have under any statute or regulation to require reports, make examinations, impose capital requirements, or take any other direct or indirect action with respect to any functionally regulated affiliate of a depository institution, subject to the same standards and requirements as are applicable to the Board under those provisions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca2979d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831v/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain exemption authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this section shall be construed as preventing the Corporation, if the Corporation finds it necessary to determine the condition of a depository institution for insurance purposes, from examining an affiliate of any depository institution, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1820/b/4"},"text":"section 1820(b)(4) of this title","children":[],"tail":", as may be necessary to disclose fully the relationship between the depository institution and the affiliate, and the effect of such relationship on the depository institution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca2979e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831v/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca2979f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831v/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functionally regulated subsidiary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “functionally regulated subsidiary” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1844/c/5"},"text":"section 1844(c)(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca297a0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831v/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functionally regulated affiliate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “functionally regulated affiliate” means, with respect to any depository institution, any affiliate of such depository institution that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddca297a1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831v/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not a depository institution holding company; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddca297a2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831v/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a company described in any clause of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1844/c/5/B"},"text":"section 1844(c)(5)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca297a3-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"Sept. 21, 1950, ch. 967, § 2","children":[],"tail":"[45], as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tI/s112/b"},"text":"Pub. L. 106–102, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1367"},"text":"113 Stat. 1367","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca297a4-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca297a5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddca297a6-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1848a"},"text":"Section 1848a of this title","children":[],"tail":", referred to in subsec. (a)(3), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVI/s604/c/2"},"text":"Pub. L. 111–203, title VI, § 604(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1601"},"text":"124 Stat. 1601","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddca297a7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddca297a8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 120 days after ","children":[{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/s161"},"text":"section 161 of Pub. L. 106–102","children":[],"tail":", set out as an Effective Date of 1999 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s24"},"text":"section 24 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
