{"tag":"section","attrib":{"id":"iddc3e57e6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1758"},"text":null,"children":[{"tag":"num","attrib":{"value":"1758"},"text":"§ 1758.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bylaws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to simplify the organization of Federal credit unions the Board shall from time to time cause to be prepared a form of organization certificate and a form of bylaws, consistent with this chapter, which shall be used by Federal credit union incorporators, and shall be supplied to them on request. At the time of presenting the organization certificate the incorporators shall also submit proposed bylaws to the Board for its approval.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc3e57e7-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title I, § 108, formerly § 8, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1219"},"text":"48 Stat. 1219","children":[],"tail":"; 1947 Reorg. Plan No. 1, § 401, eff. "},{"tag":"date","attrib":{"date":"1947-07-01"},"text":"July 1, 1947","children":[],"tail":", 12 F.R. 4534, "},{"tag":"ref","attrib":{"href":"/us/stat/61/952"},"text":"61 Stat. 952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-29/ch711"},"text":"June 29, 1948, ch. 711","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/62/1091"},"text":"62 Stat. 1091","children":[],"tail":"; renumbered § 9 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/354/s1"},"text":"Pub. L. 86–354, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-22"},"text":"Sept. 22, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/631"},"text":"73 Stat. 631","children":[],"tail":"; "}