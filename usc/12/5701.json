{"tag":"section","attrib":{"id":"iddd7e03f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701"},"text":null,"children":[{"tag":"num","attrib":{"value":"5701"},"text":"§ 5701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7e03f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e03f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Small Business and Entrepreneurship, the Committee on Agriculture, Nutrition, and Forestry, the Committee on Banking, Housing, and Urban Affairs, the Committee on Finance, the Committee on the Budget, and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e03f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Small Business, the Committee on Agriculture, the Committee on Financial Services, the Committee on Ways and Means, the Committee on the Budget, and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e03f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate Federal banking agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate Federal banking agency”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e03f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/q"},"text":"section 1813(q) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e03f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the National Credit Union Administration Board in the case of any credit union the deposits of which are insured in accordance with the Federal Credit Union Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1751"},"text":"12 U.S.C. 1751","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e03f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrolled loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “enrolled loan” means a loan made by a financial institution lender that is enrolled by a participating State in an approved State capital access program in accordance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e03fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal contribution” means the portion of the contribution made by a participating State to, or for the account of, an approved State program that is made with Federal funds allocated to the State by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5702"},"text":"section 5702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e03fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial institution” means any insured depository institution, insured credit union, or community development financial institution, as those terms are each defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4702"},"text":"section 4702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e03fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participating State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “participating State” means any State that has been approved for participation in the Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5703"},"text":"section 5703 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e03fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the State Small Business Credit Initiative established under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e03fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying loan or swap funding facility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualifying loan or swap funding facility” means a contractual arrangement between a participating State and a private financial entity under which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e03ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participating State delivers funds to the entity as collateral;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e0400-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity provides funding from the arrangement back to the participating State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e0401-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the full amount of resulting funding from the arrangement, less any fees and other costs of the arrangement, is contributed to, or for the account of, an approved State program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e0402-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “reserve fund” means a fund, established by a participating State, dedicated to a particular financial institution lender, for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e0403-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depositing all required premium charges paid by the financial institution lender and by each borrower receiving a loan under an approved State program from that financial institution lender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e0404-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depositing contributions made by the participating State, including State contributions made with Federal contributions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e0405-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covering losses on enrolled loans by disbursing accumulated funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e0406-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e0407-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e0408-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of Northern Mariana Islands, Guam, American Samoa, and the United States Virgin Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e0409-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when designated by a State of the United States, a political subdivision of that State that the Secretary determines has the capacity to participate in the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e040a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the circumstances described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5703/d"},"text":"section 5703(d) of this title","children":[],"tail":", a municipality of a State of the United States to which the Secretary has given a special permission under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5703/d"},"text":"section 5703(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e040b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/10/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Tribal government, or a group of Tribal governments that jointly apply for an allocation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e040c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State capital access program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State capital access program” means a program of a State that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e040d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses public resources to promote private access to credit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e040e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the eligibility criteria in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5704/c"},"text":"section 5704(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e040f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State other credit support program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State other credit support program”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e0410-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a program of a State that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd7e0411-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/12/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses public resources to promote private access to credit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7e0412-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/12/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a State capital access program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7e0413-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/12/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the eligibility criteria in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5705/c"},"text":"section 5705(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e0414-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes, collateral support programs, loan participation programs, State-run venture capital fund programs, and credit guarantee programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e0415-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State program” means a State capital access program or a State other credit support program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e0416-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e0417-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business enterprise owned and controlled by socially and economically disadvantaged individuals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “business enterprise owned and controlled by socially and economically disadvantaged individuals” means a business that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e0418-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if privately owned, 51 percent is owned by one or more socially and economically disadvantaged individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e0419-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if publicly owned, 51 percent of the stock is owned by one or more socially and economically disadvantaged individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e041a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/15/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a mutual institution, a majority of the Board of Directors, account holders, and the community which the institution services is predominantly comprised of socially and economically disadvantaged individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e041b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community development financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community development financial institution” has the meaning given that term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4702"},"text":"section 4702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e041c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minority depository institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “minority depository institution” has the meaning given that term under section 308(b) of the Financial Institutions Reform, Recovery, and Enforcement Act of 1989.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e041d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Socially and economically disadvantaged individual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “socially and economically disadvantaged individual” means an individual who is a socially disadvantaged individual or an economically disadvantaged individual, as such terms are defined, respectively, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637"},"text":"section 637 of title 15","children":[],"tail":" and the regulations thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e041e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5701/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Tribal government” means the recognized governing body of any Indian or Alaska Native tribe, band, nation, pueblo, village, community, component band, or component reservation, individually identified (including parenthetically) in the list published most recently as of ","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":", pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5131"},"text":"section 5131 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd7e041f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240/tIII/s3002"},"text":"Pub. L. 111–240, title III, § 3002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2568"},"text":"124 Stat. 2568","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIII/s3301/e"},"text":"Pub. L. 117–2, title III, § 3301(e)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/71"},"text":"135 Stat. 71","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd7e0420-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd7e0421-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd7e0422-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Credit Union Act, referred to in par. (2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"act June 26, 1934, ch. 750","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1216"},"text":"48 Stat. 1216","children":[],"tail":", which is classified principally to chapter 14 (§ 1751 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1751"},"text":"section 1751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 308(b) of the Financial Institutions Reform, Recovery, and Enforcement Act of 1989, referred to in par. (17), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s308/b"},"text":"section 308(b) of Pub. L. 101–73","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1463"},"text":"section 1463 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd7e0423-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Par. (10)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/e"},"text":"Pub. L. 117–2, § 3301(e)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (15) to (19). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/f"},"text":"Pub. L. 117–2, § 3301(f)","children":[],"tail":", added pars. (15) to (19)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd7e0424-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd7e0425-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIII/s3301/g"},"text":"Pub. L. 117–2, title III, § 3301(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/72"},"text":"135 Stat. 72","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/2/tIII/s3301/g"},"text":"“The amendments made by this section [amending this section and sections 5702 to 5706, 5708, and 5710 of this title and enacting provisions set out as a note below] shall apply with respect to funds appropriated under this section and funds appropriated on and after the date of enactment of this section [","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddd7e0426-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240/tIII/s3001"},"text":"Pub. L. 111–240, title III, § 3001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2568"},"text":"124 Stat. 2568","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/240/tIII/s3001"},"text":"“This title [enacting this chapter] may be cited as the ‘State Small Business Credit Initiative Act of 2010’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd7e0427-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIII/s3301/a/2"},"text":"Pub. L. 117–2, title III, § 3301(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/69"},"text":"135 Stat. 69","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/2/tIII/s3301/a/2"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to amounts otherwise available, there is hereby appropriated to the Secretary of the Treasury for fiscal year 2021, out of any money in the Treasury not otherwise appropriated, $10,000,000,000, to remain available until expended, to provide support to small businesses responding to and recovering from the economic effects of the COVID–19 pandemic, ensure business enterprises owned and controlled by socially and economically disadvantaged individuals have access to credit and investments, provide technical assistance to help small businesses applying for various support programs, and to pay reasonable costs of administering such Initiative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rescission","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to amounts appropriated under subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury shall complete all disbursements and remaining obligations before ","children":[{"tag":"date","attrib":{"date":"2030-09-30"},"text":"September 30, 2030","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts that remain unexpended (whether obligated or unobligated) on ","children":[{"tag":"date","attrib":{"date":"2030-09-30"},"text":"September 30, 2030","children":[],"tail":", shall be rescinded and deposited into the general fund of the Treasury.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
