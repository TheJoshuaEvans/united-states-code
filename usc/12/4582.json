{"tag":"section","attrib":{"id":"iddd2cd739-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4582"},"text":null,"children":[{"tag":"num","attrib":{"value":"4582"},"text":"§ 4582.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2cd73a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4582/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd73b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4582/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue and record","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any hearing under section 4581 or 4585 of this title shall be held on the record and in the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd73c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4582/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any such hearing shall be fixed for a date not earlier than 30 days nor later than 60 days after service of the notice of charges under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4581/b/1"},"text":"section 4581(b)(1) of this title","children":[],"tail":" or determination to impose a penalty under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4585/c/1"},"text":"section 4585(c)(1) of this title","children":[],"tail":", unless an earlier or a later date is set by the hearing officer at the request of the enterprise served."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd73d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4582/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any such hearing shall be conducted in accordance with chapter 5 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd73e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4582/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to appear","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the enterprise served fails to appear at the hearing through a duly authorized representative, such enterprise shall be deemed to have consented to the issuance of the cease-and-desist order or the imposition of the penalty for which the hearing is held.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd73f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4582/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of order","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd740-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4582/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After any such hearing, and within 90 days after the enterprise has been notified that the case has been submitted to the Director for final decision, the Director shall render the decision (which shall include findings of fact upon which the decision is predicated) and shall issue and serve upon the enterprise an order or orders consistent with the provisions of this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd741-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4582/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Judicial review of any such order shall be exclusively as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4583"},"text":"section 4583 of this title","children":[],"tail":". Unless such a petition for review is timely filed as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4583"},"text":"section 4583 of this title","children":[],"tail":", and thereafter until the record in the proceeding has been filed as so provided, the Director may at any time, modify, terminate, or set aside any such order, upon such notice and in such manner as the Director considers proper. Upon such filing of the record, the Director may modify, terminate, or set aside any such order with permission of the court."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2cd742-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1342"},"text":"Pub. L. 102–550, title XIII, § 1342","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3965"},"text":"106 Stat. 3965","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1130/e/3/A"},"text":"Pub. L. 110–289, div. A, title I, § 1130(e)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2711"},"text":"122 Stat. 2711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2cd743-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2cd744-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2cd745-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289"},"text":"Pub. L. 110–289","children":[],"tail":" substituted “Director” for “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
