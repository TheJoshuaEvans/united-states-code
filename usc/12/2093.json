{"tag":"section","attrib":{"id":"iddcc19227-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093"},"text":null,"children":[{"tag":"num","attrib":{"value":"2093"},"text":"§ 2093.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General corporate powers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each Federal land bank association shall be a body corporate and, subject to supervision of the Farm Credit Bank for the district and the regulation of the Farm Credit Administration, shall have the power to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcc19228-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt and use a corporate seal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc19229-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have succession until dissolved under the provisions of this chapter or other Act of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc1922a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc1922b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sue and be sued;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc1922c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, hold, dispose, and otherwise exercise all of the usual incidents of ownership of real estate and personal property necessary or convenient to the business of the association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc1922d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate under the direction of the board of directors of the association in accordance with this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc1922e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide by its board of directors for a manager or other chief executive officer, and provide for such other officers or employees as may be necessary, including joint employees as provided in this chapter, define the duties of such, and require surety bonds or make other provision against losses occasioned by employees, except that no director shall, within one year after the date when such director ceases to be a member of the board, serve as a salaried employee of the association on the board of which such director served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc1922f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prescribe, by its board of directors, its bylaws that shall be consistent with law, and that shall provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcc19230-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the classes of its stock and the manner in which such stock shall be issued, transferred, and retired; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcc19231-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the manner in which it is to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcc19232-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select officers and employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcc19233-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, hold, and transfer property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcc19234-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/8/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct general business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcc19235-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/8/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise and enjoy the privileges granted to it by law;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc19236-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept applications for Farm Credit Bank loans and receive from such bank and disburse to the borrowers the proceeds of such loans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc19237-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subscribe to stock of the Farm Credit Bank of the district;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc19238-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elect by its board of directors a loan committee with power to elect applicants for membership in the association and recommend loans to the Farm Credit Bank, or with the approval of the Farm Credit Bank, delegate the election of applicants for membership and the approval of loans within specified limits to other committees or to authorized employees of the association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc19239-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on agreement with the bank, take such additional actions with respect to applications and loans and perform such functions as are vested by law in the Farm Credit Banks as may be agreed to by the association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc1923a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" endorse and become liable to the bank on loans it makes to association members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc1923b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive such compensation and deduct such sums from loan proceeds with respect to each loan as may be agreed between the association and the bank and make such other charges for services as may be approved by the bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc1923c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to members, borrowers, applicants, and other eligible persons and make available to them, at their option, such financial related services appropriate to their operations as it determines, with Farm Credit Bank approval, are feasible, under regulations of the Farm Credit Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc1923d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" borrow money from the bank and, with the approval of such bank, borrow from and issue association notes or other obligations to any commercial bank or other financial institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc1923e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" buy and sell obligations of or insured by the United States or any agency thereof or of any banks of the Farm Credit System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc1923f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invest association funds in such obligations as may be authorized in regulations of the Farm Credit Administration and approved by the bank and deposit securities and current funds of the association with any member bank of the Federal Reserve System, with the Farm Credit Bank, or with any bank insured by the Federal Deposit Insurance Corporation, and pay fees therefor and receive interest thereon as may be agreed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc19240-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other function delegated to the association by the Farm Credit Bank of the district;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc19241-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise by its board of directors or authorized officers or agents all such incidental powers as may be necessary or expedient in the conduct of its business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc19242-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to the capital of the bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcc19243-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2093/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate as an originator and become certified as a certified facility under subchapter VIII.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcc19244-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tII/s2"},"text":"Pub. L. 92–181, title II, § 2","children":[],"tail":".12, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1635"},"text":"101 Stat. 1635","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s401/u"},"text":"Pub. L. 100–399, title IV, § 401(u)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/998"},"text":"102 Stat. 998","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcc19245-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcc19246-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddcc19247-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2093, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tII/s2"},"text":"Pub. L. 92–181, title II, § 2","children":[],"tail":".12, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/598"},"text":"85 Stat. 598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/592/tII/s208"},"text":"Pub. L. 96–592, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3442"},"text":"94 Stat. 3442","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s205/e/11"},"text":"Pub. L. 99–205, title II, § 205(e)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1704"},"text":"99 Stat. 1704","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVII/s705/d"},"text":"Pub. L. 100–233, title VII, § 705(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1707"},"text":"101 Stat. 1707","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tVI/s604"},"text":"Pub. L. 100–399, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1006"},"text":"102 Stat. 1006","children":[],"tail":", related to general corporate powers, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"Pub. L. 100–233, § 401","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcc19248-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/u/1"},"text":"Pub. L. 100–399, § 401(u)(1)","children":[],"tail":", substituted “provide by its board of directors for” for “elect by its board of directors” and “serve as” for “be elected or designated”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/u/2"},"text":"Pub. L. 100–399, § 401(u)(2)","children":[],"tail":", amended par. (8) generally. Prior to amendment, par. (8) read as follows: “prescribe by its board of directors, association bylaws, not inconsistent with law, providing for the classes of association stock and the manner in which such stock shall be issued, transferred, and retired; the officers and employees of the association elected or provided for, the property of the association that is acquired, held, and transferred, the general business of the association conducted, and the privileges granted to the association by law exercised and enjoyed;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/u/3"},"text":"Pub. L. 100–399, § 401(u)(3)","children":[],"tail":", substituted “agreed to by” for “agreed to or delegated to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (22). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s401/u/4"},"text":"Pub. L. 100–399, § 401(u)(4)","children":[],"tail":"–(6), added par. (22)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcc19249-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcc1924a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective immediately after amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"section 401 of Pub. L. 100–233","children":[],"tail":", which was effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/b"},"text":"section 1001(b) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcc1924b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1622"},"text":"101 Stat. 1622","children":[],"tail":", provided that this section is effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
