{"tag":"section","attrib":{"id":"iddd7e04ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5706"},"text":null,"children":[{"tag":"num","attrib":{"value":"5706"},"text":"§ 5706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd7e04cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly use-of-funds report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7e04d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the beginning of each calendar quarter, beginning after the first full calendar quarter to occur after the date the Secretary approves a State for participation, the participating State shall submit to the Secretary a report on the use of Federal funding by the participating State during the previous calendar quarter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under this subsection shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7e04d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5706/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicate the total amount of Federal funding used by the participating State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7e04d3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5706/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a certification by the participating State that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd7e04d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5706/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information provided in accordance with subparagraph (A) is accurate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7e04d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5706/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds continue to be available and legally committed to contributions by the State to, or for the account of, approved State programs, less any amount that has been contributed by the State to, or for the account of, approved State programs subsequent to the State being approved for participation in the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7e04d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5706/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participating State is implementing its approved State program or programs in accordance with this chapter and regulations issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5709"},"text":"section 5709 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e04d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than March 31 of each year, beginning ","children":[{"tag":"date","attrib":{"date":"2022-03-31"},"text":"March 31, 2022","children":[],"tail":", each participating State shall submit to the Secretary an annual report that shall include the following information:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7e04d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5706/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of borrowers that received new loans originated under the approved State program or programs after the State program was approved as eligible for Federal contributions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04d9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5706/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount of such new loans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04da-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5706/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Breakdowns by industry type, loan size, annual sales, and number of employees of the borrowers that received such new loans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04db-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5706/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The zip code of each borrower that received such a new loan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7e04dc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5706/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other data as the Secretary, in the Secretary’s sole discretion, may require to carry out the purposes of the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e04dd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reports and data filed under subsections (a) and (b) shall be in such form as the Secretary, in the Secretary’s sole discretion, may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7e04de-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5706/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of reporting requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirement to submit reports under subsections (a) and (b) shall terminate for a participating State with the submission of the completed reports due on the first March 31 to occur after 5 complete 12-month periods after the State is approved by the Secretary to be a participating State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd7e04df-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240/tIII/s3007"},"text":"Pub. L. 111–240, title III, § 3007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2579"},"text":"124 Stat. 2579","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIII/s3301/a/1/E"},"text":"Pub. L. 117–2, title III, § 3301(a)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/69"},"text":"135 Stat. 69","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd7e04e0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd7e04e1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd7e04e2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2022-03-31"},"text":"March 31, 2022","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2011-03-31"},"text":"March 31, 2011","children":[],"tail":"” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd7e04e3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd7e04e4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":" applicable with respect to funds appropriated under "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301"},"text":"section 3301 of Pub. L. 117–2","children":[],"tail":" and funds appropriated on and after "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/s3301/g"},"text":"section 3301(g) of Pub. L. 117–2","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5701"},"text":"section 5701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
