{"tag":"section","attrib":{"id":"iddb48d487-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s531"},"text":null,"children":[{"tag":"num","attrib":{"value":"531"},"text":"§ 531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from taxation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Federal reserve banks, including the capital stock and surplus therein and the income derived therefrom shall be exempt from Federal, State, and local taxation, except taxes upon real estate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb48d488-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s7/c"},"text":"Dec. 23, 1913, ch. 6, § 7(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/258"},"text":"38 Stat. 258","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1919-03-03/ch101/s1"},"text":"Mar. 3, 1919, ch. 101, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/1314"},"text":"40 Stat. 1314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tIII/s3002/c/2"},"text":"Pub. L. 103–66, title III, § 3002(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/338"},"text":"107 Stat. 338","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb48d489-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb48d48a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb48d48b-3a6f-11f1