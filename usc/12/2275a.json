{"tag":"section","attrib":{"id":"iddcd23386-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2275a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2275a"},"text":"§ 2275a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition rules relating to amendment of certain FCA approval authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcd23387-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2275a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any approvals granted by the Farm Credit Administration before ","children":[{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":", shall remain in effect on and after such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd23388-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2275a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to issue regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcd23389-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2275a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any approval authority of the Farm Credit Administration that, under the amendments made by section 802 of the Agricultural Credit Act of 1987, became an authority to issue regulations may be exercised only until the earlier of the date the Farm Credit Administration issues final regulations under such authority, or 1 year after ","children":[{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcd2338a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2275a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the close of the 1-year period referred to in paragraph (1), the Farm Credit Administration shall not take any enforcement action against any System institution with respect to any provision so amended, until the Farm Credit Administration issues final regulations under such provision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcd2338b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2275a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not affect the authority of the Farm Credit Administration to exercise any other approval authority either on a case-by-case basis or through regulation, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2252/a/5"},"text":"section 2252(a)(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcd2338c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".45, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVIII/s802/w"},"text":"Pub. L. 100–233, title VIII, § 802(w)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1713"},"text":"101 Stat. 1713","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd2338d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcd2338e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcd2338f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The amendments made by section 802 of the Agricultural Credit Act of 1987, referred to in subsec. (b)(1), are the amendments made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/s802"},"text":"section 802 of Pub. L. 100–233","children":[],"tail":", title VIII, "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1710"},"text":"101 Stat. 1710","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2275a"},"text":"section 2275a of this title","children":[],"tail":" and amended sections 2011 to 2013, 2017, 2031, 2051, 2052, 2071 to 2073, 2077, 2091, 2121, 2122, 2124, 2126, 2130, 2132, 2212, 2213, 2223, and 2252 of this title. For complete classification of section 802 to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
