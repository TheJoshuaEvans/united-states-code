{"tag":"section","attrib":{"id":"iddca4e2a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1833c"},"text":"§ 1833c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller General audit and access to records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca4e2a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit of agencies or other persons performing functions under banking laws","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca4e2a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), all agencies, corporations, organizations, and other persons of any description which perform any function or activity under this Act, or any other Act which is amended by this Act, shall be subject to audit by the Comptroller General of the United States with respect to such function or activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e2aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddca4e2ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any function or activity of the Board of Governors of the Federal Reserve System or the Federal Reserve banks that is described in any paragraph of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s714/b"},"text":"section 714(b) of title 31","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddca4e2ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any function or activity of the Federal National Mortgage Association, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1723a/j"},"text":"section 1723a(j) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4e2ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit of persons providing certain goods or services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All persons and organizations which, by contract, grant, or otherwise, provide goods or services to, or receive financial assistance from, any agency or other person performing functions or activities under this Act shall be subject to audit by the Comptroller General with respect to such provision of goods or services or receipt of financial assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4e2ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions applicable to audits under this section","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca4e2af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nature and scope of audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General shall determine the nature, scope, and terms and conditions of audits conducted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e2b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other provisions of law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Comptroller General under this section shall be in addition to any audit authority available to the Comptroller General under other provisions of this Act or any other law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e2b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of access, examination, and copying","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General, and any duly authorized representative of the Comptroller General, shall have access to, and the right to examine and copy, all records and other recorded information in any form, and to examine any property, within the possession or control of any agency or person which is subject to audit under this section which the Comptroller General deems relevant to an audit conducted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e2b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833c/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of right of access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General’s right of access to information under this section shall be enforceable pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s716"},"text":"section 716 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e2b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1833c/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of confidential records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s716/e"},"text":"section 716(e) of title 31","children":[],"tail":" shall apply to information obtained by the Comptroller General under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca4e2b4-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXII/s1213"},"text":"Pub. L. 101–73, title XII, § 1213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/528"},"text":"103 Stat. 528","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddca4e2b5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddca4e2b6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddca4e2b7-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (a)(1), (b), and (c)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/183"},"text":"103 Stat. 183","children":[],"tail":", known as the Financial Institutions Reform, Recovery, and Enforcement Act of 1989. For complete classification of this Act to the Code, see Short Title of 1989 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"section 1811 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddca4e2b8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Financial Institutions Reform, Recovery, and Enforcement Act of 1989, and not as part of the Federal Deposit Insurance Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
