{"tag":"section","attrib":{"id":"iddd177a05-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4105"},"text":null,"children":[{"tag":"num","attrib":{"value":"4105"},"text":"§ 4105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal cost limits and limitations on plans of action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd177a06-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of relationship to Federal cost limits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd177a07-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each eligible low-income housing project appraised under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4103/a"},"text":"section 4103(a) of this title","children":[],"tail":", the Secretary shall determine whether the aggregate preservation rents for the project determined under paragraph (1) or (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4104/b"},"text":"section 4104(b) of this title","children":[],"tail":" exceed the amount determined by multiplying 120 percent of the fair market rental (established under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f/c"},"text":"section 1437f(c) of title 42","children":[],"tail":") for the market area in which the housing is located by the number of dwelling units in the project (according to appropriate unit sizes)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd177a08-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relevant local markets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the aggregate preservation rents for a project exceeds the amount determined under paragraph (1), the Secretary shall determine whether such aggregate rents exceed the amount determined by multiplying 120 percent of the prevailing rents in the relevant local market area in which the housing is located by the number of units in the project (according to the appropriate unit sizes). A relevant local market area shall be an area geographically smaller than a market area established by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f/c/1"},"text":"section 1437f(c)(1) of title 42","children":[],"tail":" that is identifiable as a distinct rental market area. The Secretary may rely on the appraisal to determine the relevant local market areas and prevailing rents in such local areas and any other information the Secretary determines is appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd177a09-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4105/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter, the aggregate preservation rents shall be considered to exceed the Federal cost limits under this subsection only if the aggregate preservation rents exceed the amount determined under paragraph (1) and the amount determined under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd177a0a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on action pursuant to Federal cost limits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd177a0b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing within Federal cost limits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the aggregate preservation rents for an eligible low-income housing project do not exceed the Federal cost limit, the owner may not prepay the mortgage on the housing or terminate the insurance contract with respect to the housing, except as permitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4114"},"text":"section 4114 of this title","children":[],"tail":". The owner may—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd177a0c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4105/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file a plan of action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4107"},"text":"section 4107 of this title","children":[],"tail":" to receive incentives under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4109"},"text":"section 4109 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd177a0d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4105/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file a second notice of intent under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4106/d"},"text":"section 4106(d) of this title","children":[],"tail":" indicating an intention to transfer the housing under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4110"},"text":"section 4110 of this title","children":[],"tail":" and take actions pursuant to such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd177a0e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing exceeding Federal cost limits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the aggregate preservation rents for an eligible low-income housing project exceed the Federal cost limit, the owner may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd177a0f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4105/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file a plan of action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4107"},"text":"section 4107 of this title","children":[],"tail":" to receive incentives under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4109"},"text":"section 4109 of this title","children":[],"tail":" if the owner agrees to accept incentives under such sections in an amount that shall not exceed the Federal cost limit;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd177a10-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4105/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file a second notice of intent under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4106/d"},"text":"section 4106(d) of this title","children":[],"tail":" indicating an intention to transfer the housing under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4110"},"text":"section 4110 of this title","children":[],"tail":" and take actions pursuant to such section if the owner agrees to transfer the housing at a price that shall not exceed the Federal cost limit; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd177a11-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4105/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file a second notice of intent under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4106/d"},"text":"section 4106(d) of this title","children":[],"tail":" indicating an intention to prepay the mortgage or voluntarily terminate the insurance, subject to the mandatory sale provisions under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4111"},"text":"section 4111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd177a12-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/tII/s215"},"text":"Pub. L. 100–242, title II, § 215","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVI/s601/a"},"text":"Pub. L. 101–625, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4252"},"text":"104 Stat. 4252","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tIII/s317/a/1"},"text":"Pub. L. 102–550, title III, § 317(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3772"},"text":"106 Stat. 3772","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd177a13-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd177a14-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd177a15-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f/c/1"},"text":"section 1437f(c)(1) of title 42","children":[],"tail":" to reflect correction of corresponding provision of original act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
