{"tag":"section","attrib":{"id":"iddb335094-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b"},"text":null,"children":[{"tag":"num","attrib":{"value":"347b"},"text":"§ 347b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advances to individual member banks on time or demand notes; maturities; time notes secured by mortgage loans covering one-to-four family residences","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb335095-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Federal Reserve bank, under rules and regulations prescribed by the Board of Governors of the Federal Reserve System, may make advances to any member bank on its time or demand notes having maturities of not more than four months and which are secured to the satisfaction of such Federal Reserve bank.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Notwithstanding the foregoing, any Federal Reserve bank, under rules and regulations prescribed by the Board of Governors of the Federal Reserve System, may make advances to any member bank on its time notes having such maturities as the Board may prescribe and which are secured by mortgage loans covering a one-to-four family residence. Such advances shall bear interest at a rate equal to the lowest discount rate in effect at such Federal Reserve bank on the date of such note.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb335096-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on advances","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb335097-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on extended periods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), no advances to any undercapitalized depository institution by any Federal Reserve bank under this section may be outstanding for more than 60 days in any 120-day period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb335098-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Viability exception","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb335099-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb33509a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of the appropriate Federal banking agency certifies in advance in writing to the Federal Reserve bank that any depository institution is viable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb33509b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board conducts an examination of any depository institution and the Chairman of the Board certifies in writing to the Federal Reserve bank that the institution is viable,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the limitation contained in paragraph (1) shall not apply during the 60-day period beginning on the date such certification is received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb33509c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extensions of period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The 60-day period may be extended for additional 60-day periods upon receipt by the Federal Reserve bank of additional written certifications under subparagraph (A) with respect to each such additional period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb33509d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to issue a certificate of viability may not be delegated","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the head of any agency to issue a written certification of viability under this paragraph may not be delegated to any other person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb33509e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extended advances subject to paragraph (3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1), an undercapitalized depository institution which does not have a certificate of viability in effect under this paragraph may have advances outstanding for more than 60 days in any 120-day period if the Board elects to treat—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb33509f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such institution as critically undercapitalized under paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3350a0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any such advance as an advance described in subparagraph (A)(i) of paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3350a1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advances to critically undercapitalized depository institutions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb3350a2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for increased loss","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this section, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3350a3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of any critically undercapitalized depository institution—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddb3350a4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any advance under this section to such institution is outstanding without payment having been demanded as of the end of the 5-day period beginning on the date the institution becomes a critically undercapitalized depository institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddb3350a5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any new advance is made to such institution under this section after the end of such period; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3350a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the end of that 5-day period, the Deposit Insurance Fund of the Federal Deposit Insurance Corporation incurs a loss exceeding the loss that the Corporation would have incurred if it had liquidated that institution as of the end of that period,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Board shall, subject to the limitations in subparagraph (B), be liable to the Federal Deposit Insurance Corporation for the excess loss, without regard to the terms of the advance or any collateral pledged to secure the advance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3350a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on excess loss","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The liability of the Board under subparagraph (A) shall not exceed the lesser of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3350a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the loss the Board or any Federal Reserve bank would have incurred on the increases in the amount of advances made after the 5-day period referred to in subparagraph (A) if those increased advances had been unsecured.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3350a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The interest received on the increases in the amount of advances made after the 5-day period referred to in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3350aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Reserve to pay obligation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall pay the Federal Deposit Insurance Corporation the amount of any liability of the Board under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3350ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall report to the Congress on any excess loss liability it incurs under subparagraph (A), as limited by subparagraph (B)(i), and the reasons therefore, not later than 6 months after incurring the liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3350ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No obligation to make advances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal Reserve bank shall have no obligation to make, increase, renew, or extend any advance or discount under this chapter to any depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3350ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb3350ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate Federal banking agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate Federal banking agency” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3350af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critically undercapitalized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “critically undercapitalized” has the same meaning as in section 1831","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3350b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depository institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “depository institution” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3350b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Undercapitalized depository institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “undercapitalized depository institution” means any depository institution which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3350b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/5/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is undercapitalized, as defined in section 1831","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3350b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/5/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a composite CAMEL rating of 5 under the Uniform Financial Institutions Rating System (or an equivalent rating by any such agency under a comparable rating system) as of the most recent examination of such institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3350b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Viable","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A depository institution is “viable” if the Board or the appropriate Federal banking agency determines, giving due regard to the economic conditions and circumstances in the market in which the institution operates, that the institution—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3350b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/5/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not critically undercapitalized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3350b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/5/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not expected to become critically undercapitalized; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3350b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s347b/b/5/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not expected to be placed in conservatorship or receivership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb3350b8-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s10B"},"text":"Dec. 23, 1913, ch. 6, § 10B","children":[],"tail":", formerly § 10(b), as added "},{"tag":"ref","attrib":{"href":"/us/act/1932-02-27/ch58/s2"},"text":"Feb. 27, 1932, ch. 58, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/56"},"text":"47 Stat. 56","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1933-02-03/ch34"},"text":"Feb. 3, 1933, ch. 34","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/794"},"text":"47 Stat. 794","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1933-03-09/ch1"},"text":"Mar. 9, 1933, ch. 1","children":[],"tail":", title IV, § 402, "},{"tag":"ref","attrib":{"href":"/us/stat/48/7"},"text":"48 Stat. 7","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-23/ch614"},"text":"Aug. 23, 1935, ch. 614","children":[],"tail":", title II, § 204, "},{"tag":"ref","attrib":{"href":"/us/stat/49/705"},"text":"49 Stat. 705","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/449/s5"},"text":"Pub. L. 93–449, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-18"},"text":"Oct. 18, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1368"},"text":"88 Stat. 1368","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tI/s106"},"text":"Pub. L. 96–221, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/140"},"text":"94 Stat. 140","children":[],"tail":"; renumbered § 10B and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tI/s142/a/2"},"text":"Pub. L. 102–242, title I, § 142(a)(2)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2279"},"text":"105 Stat. 2279","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2704/d/9"},"text":"Pub. L. 104–208, div. A, title II, § 2704(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-489"},"text":"110 Stat. 3009–489","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tII/s2102/b"},"text":"Pub. L. 109–171, title II, § 2102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/9"},"text":"120 Stat. 9","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/173/s9/c"},"text":"Pub. L. 109–173, § 9(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-15"},"text":"Feb. 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3616"},"text":"119 Stat. 3616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb3350b9-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","to