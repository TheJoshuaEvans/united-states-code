{"tag":"section","attrib":{"id":"iddd425abb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4904"},"text":null,"children":[{"tag":"num","attrib":{"value":"4904"},"text":"§ 4904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification upon cancellation or termination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd425abc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the date of cancellation or termination of a private mortgage insurance requirement in accordance with this chapter, the servicer shall notify the mortgagor in writing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd425abd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the private mortgage insurance has terminated and that the mortgagor no longer has private mortgage insurance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425abe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that no further premiums, payments, or other fees shall be due or payable by the mortgagor in connection with the private mortgage insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd425abf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of grounds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd425ac0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a servicer determines that a mortgage did not meet the requirements for termination or cancellation of private mortgage insurance under subsection (a) or (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902"},"text":"section 4902 of this title","children":[],"tail":", the servicer shall provide written notice to the mortgagor of the grounds relied on to make the determination (including the results of any appraisal used to make the determination)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425ac1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notice required by paragraph (1) shall be provided—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd425ac2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4904/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to cancellation of private mortgage insurance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902/a"},"text":"section 4902(a) of this title","children":[],"tail":", not later than 30 days after the later of—"}],"tail":null},{"tag":"clause","attrib":{"id":"iddd425ac3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4904/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which a request is received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902/a/1"},"text":"section 4902(a)(1) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd425ac4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4904/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the mortgagor satisfies any evidence and certification requirements under section 4902(a)(3) ","children":[{"tag":"ref","attrib":{"idref":"fn002442"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002442"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd425ac5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4904/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to termination of private mortgage insurance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4902/b"},"text":"section 4902(b) of this title","children":[],"tail":", not later than 30 days after the scheduled termination date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd425ac6-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/216/s5"},"text":"Pub. L. 105–216, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/903"},"text":"112 Stat. 903","children":[],"tail":".)"}],"tail":