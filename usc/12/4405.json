{"tag":"section","attrib":{"id":"iddd20efad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4405"},"text":null,"children":[{"tag":"num","attrib":{"value":"4405"},"text":"§ 4405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No stay, injunction, avoidance, moratorium, or similar proceeding or order, whether issued or granted by a court, administrative agency, or otherwise, shall limit or delay application of otherwise enforceable netting contracts in accordance with sections 4403 and 4404 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd20efae-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIV/s405"},"text":"Pub. L. 102–242, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2375"},"text":"105 Stat. 2375","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
