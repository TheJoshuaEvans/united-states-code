","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title IV, § 407(b)], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1211"},"text":"97 Stat. 1211","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/204/tIV/s425/b"},"text":"Pub. L. 104–204, title IV, § 425(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2928"},"text":"110 Stat. 2928","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dB/tI"},"text":"Pub. L. 110–289, div. B, title I","children":[],"tail":", §§ 2117(b), (c), 2120(c), "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2833"},"text":"122 Stat. 2833","children":[],"tail":", 2835.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddbc2715d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddbc2715e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddbc2715f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s2117/b"},"text":"Pub. L. 110–289, § 2117(b)","children":[],"tail":", inserted “(A)” before “a first mortgage”, substituted “(B) a first mortgage on a leasehold on real estate (i)” for “or on a leasehold (1)” and “, or (ii)” for “or (2)”, and inserted “, or (C) a first mortgage given to secure the unpaid purchase price of a fee interest in, or long-term leasehold interest in, real estate consisting of a one-family unit in a multifamily project, including a project in which the dwelling units are attached, or are manufactured housing units, semi-detached, or detached, and an undivided interest in the common areas and facilities which serve the project” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s2120/c"},"text":"Pub. L. 110–289, § 2120(c)","children":[],"tail":", substituted “the Commonwealth of the Northern Mariana Islands” for “the Trust Territory of the Pacific Islands”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s2117/c"},"text":"Pub. L. 110–289, § 2117(c)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204"},"text":"Pub. L. 104–204","children":[],"tail":" added subsecs. (e) and (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181"},"text":"Pub. L. 98–181","children":[],"tail":" inserted “American Samoa,” after “Pacific Islands,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399"},"text":"Pub. L. 96–399","children":[],"tail":" substituted “ten years to run beyond the maturity date of the mortgage” for “fifty years to run from the date the mortgage was executed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/152"},"text":"Pub. L. 91–152","children":[],"tail":" inserted “the Trust Territory of the Pacific Islands” after “Guam”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/19"},"text":"Pub. L. 90–19","children":[],"tail":" substituted “Secretary” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/624"},"text":"Pub. L. 86–624","children":[],"tail":" struck out “Hawaii,” before “Puerto Rico”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/70"},"text":"Pub. L. 86–70","children":[],"tail":" struck out “Alaska,” before “Hawaii”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1952—Subsec. (d). Act ","children":[{"tag":"date","attrib":{"date":"1952-07-14"},"text":"July 14, 1952","children":[],"tail":", inserted “Guam,” after “District of Columbia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-04-20"},"text":"Apr. 20, 1950","children":[],"tail":", substituted “Commissioner” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1941—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1941-03-28"},"text":"Mar. 28, 1941","children":[],"tail":", § 4(a)(1), struck out “district, or Territory”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). Act ","children":[{"tag":"date","attrib":{"date":"1941-03-28"},"text":"Mar. 28, 1941","children":[],"tail":", § 4(a)(2), added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1938—Subsec. (a)(2). Act ","children":[{"tag":"date","attrib":{"date":"1938-02-03"},"text":"Feb. 3, 1938","children":[],"tail":", struck out “upon which there is located a dwelling for not more than four families which is used in whole or in part for residential purposes, irrespective of whether such dwelling has a party wall or is otherwise physically connected with another dwelling” after “executed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). Act ","children":[{"tag":"date","attrib":{"date":"1938-02-03"},"text":"Feb. 3, 1938","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddbc27160-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddbc27161-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Improvement of Financing for Multifamily Housing","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tV"},"text":"Pub. L. 102–550, title V","children":[],"tail":", subtitle C, "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3794"},"text":"106 Stat. 3794","children":[],"tail":", which related to improvement of financing for multifamily housing and was formerly set out as a note under this section, was transferred or omitted as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s541"},"text":"Section 541 of Pub. L. 102–550","children":[],"tail":" was transferred and is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701"},"text":"section 1701 of this title","children":[],"tail":";"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s542"},"text":"Section 542 of Pub. L. 102–550","children":[],"tail":" was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715z–22"},"text":"section 1715z–22 of this title","children":[],"tail":";"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s543"},"text":"Section 543 of Pub. L. 102–550","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s371"},"text":"Pub. L. 111–203, title III, § 371","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1565"},"text":"124 Stat. 1565","children":[],"tail":", was omitted from the Code;"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s544"},"text":"Section 544 of Pub. L. 102–550","children":[],"tail":" was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715z–22a"},"text":"section 1715z–22a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
