{"tag":"section","attrib":{"id":"iddd25ab48-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518"},"text":null,"children":[{"tag":"num","attrib":{"value":"4518"},"text":"§ 4518.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition and withholding of executive compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd25ab49-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall prohibit the regulated entities from providing compensation to any executive officer of the regulated entity that is not reasonable and comparable with compensation for employment in other similar businesses (including other publicly held financial institutions or major financial services companies) involving similar duties and responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25ab4a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making any determination under subsection (a), the Director may take into consideration any factors the Director considers relevant, including any wrongdoing on the part of the executive officer, and such wrongdoing shall include any fraudulent act or omission, breach of trust or fiduciary duty, violation of law, rule, regulation, order, or written agreement, and insider abuse with respect to the regulated entity. The approval of an agreement or contract pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1723a/d/3/B"},"text":"section 1723a(d)(3)(B) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1452/h/2"},"text":"section 1452(h)(2) of this title","children":[],"tail":" shall not preclude the Director from making any subsequent determination under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25ab4b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding of compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (a), the Director may require a regulated entity to withhold any payment, transfer, or disbursement of compensation to an executive officer, or to place such compensation in an escrow account, during the review of the reasonableness and comparability of compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25ab4c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of setting compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (a), the Director may not prescribe or set a specific level or range of compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd25ab4d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to regulate or prohibit certain forms of benefits to affiliated parties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd25ab4e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Golden parachutes and indemnification payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may prohibit or limit, by regulation or order, any golden parachute payment or indemnification payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25ab4f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors to be taken into account","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall prescribe, by regulation, the factors to be considered by the Director in taking any action pursuant to paragraph (1), which may include such factors as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd25ab50-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there is a reasonable basis to believe that the affiliated party has committed any fraudulent act or omission, breach of trust or fiduciary duty, or insider abuse with regard to the regulated entity that has had a material effect on the financial condition of the regulated entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd25ab51-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there is a reasonable basis to believe that the affiliated party is substantially responsible for the insolvency of the regulated entity, the appointment of a conservator or receiver for the regulated entity, or the troubled condition of the regulated entity (as defined in regulations prescribed by the Director);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd25ab52-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there is a reasonable basis to believe that the affiliated party has materially violated any applicable provision of Federal or State law or regulation that has had a material effect on the financial condition of the regulated entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd25ab53-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the affiliated party was in a position of managerial or fiduciary responsibility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd25ab54-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the length of time that the party was affiliated with the regulated entity, and the degree to which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd25ab55-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment reasonably reflects compensation earned over the period of employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25ab56-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compensation involved represents a reasonable payment for services rendered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25ab57-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain payments prohibited","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No regulated entity may prepay the salary or any liability or legal expense of any affiliated party if such payment is made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd25ab58-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in contemplation of the insolvency of such regulated entity, or after the commission of an act of insolvency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd25ab59-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with a view to, or having the result of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd25ab5a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing the proper application of the assets of the regulated entity to creditors; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25ab5b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preferring one creditor over another.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25ab5c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Golden parachute payment defined","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd25ab5d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “golden parachute payment” means any payment (or any agreement to make any payment) in the nature of compensation by any regulated entity for the benefit of any affiliated party pursuant to an obligation of such regulated entity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd25ab5e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is contingent on the termination of such party’s affiliation with the regulated entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25ab5f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is received on or after the date on which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd25ab60-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regulated entity became insolvent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd25ab61-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any conservator or receiver is appointed for such regulated entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd25ab62-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/4/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director determines that the regulated entity is in a troubled condition (as defined in the regulations of the Director).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd25ab63-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain payments in contemplation of an event","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any payment which would be a golden parachute payment but for the fact that such payment was made before the date referred to in subparagraph (A)(ii) shall be treated as a golden parachute payment if the payment was made in contemplation of the occurrence of an event described in any subclause of such subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd25ab64-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain payments not included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “golden parachute payment” shall not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd25ab65-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any payment made pursuant to a retirement plan which is qualified (or is intended to be qualified) under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of title 26","children":[],"tail":", or other nondiscriminatory benefit plan;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25ab66-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any payment made pursuant to a bona fide deferred compensation plan or arrangement which the Director determines, by regulation or order, to be permissible; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25ab67-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any payment made by reason of the death or disability of an affiliated party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25ab68-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the following definitions shall apply:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd25ab69-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indemnification payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (6), the term “indemnification payment” means any payment (or any agreement to make any payment) by any regulated entity for the benefit of any person who is or was an affiliated party, to pay or reimburse such person for any liability or legal expense with regard to any administrative proceeding or civil action instituted by the Agency which results in a final order under which such person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd25ab6a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is assessed a civil money penalty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25ab6b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is removed or prohibited from participating in conduct of the affairs of the regulated entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25ab6c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required to take any affirmative action to correct certain conditions resulting from violations or practices, by order of the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd25ab6d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability or legal expense","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “liability or legal expense” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd25ab6e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any legal or other professional expense incurred in connection with any claim, proceeding, or action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25ab6f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of, and any cost incurred in connection with, any settlement of any claim, proceeding, or action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25ab70-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of, and any cost incurred in connection with, any judgment or penalty imposed with respect to any claim, proceeding, or action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd25ab71-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “payment” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd25ab72-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any direct or indirect transfer of any funds or any asset; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd25ab73-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any segregation of any funds or assets for the purpose of making, or pursuant to an agreement to make, any payment after the date on which such funds or assets are segregated, without regard to whether the obligation to make such payment is contingent on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd25ab74-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/5/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination, after such date, of the liability for the payment of such amount; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd25ab75-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/5/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the liquidation, after such date, of the amount of such payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd25ab76-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4518/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain commercial insurance coverage not treated as covered benefit payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this subsection shall be construed as prohibiting any regulated entity from purchasing any commercial insurance policy or fidelity bond, except that, subject to any requirement described in paragraph (5)(A)(iii), such insurance policy or bond shall not cover any legal or liability expense of the regulated entity which is described in paragraph (5)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd25ab77-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1318"},"text":"Pub. L. 102–550, title XIII, § 1318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3949"},"text":"106 Stat. 3949","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI"},"text":"Pub. L. 110–289, div. A, title I","children":[],"tail":", §§ 1113(a), 1114, "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2678"},"text":"122 Stat. 2678","children":[],"tail":", 2679.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd25ab78-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd25ab79-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd25ab7a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1113/a/1"},"text":"Pub. L. 110–289, § 1113(a)(1)","children":[],"tail":", substituted “and withholding of executive” for “of excessive” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1113/a/2"},"text":"Pub. L. 110–289, § 1113(a)(2)","children":[],"tail":", substituted “regulated entity” for “enterprise” and “regulated entities” for “enterprises”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1113/a/3"},"text":"Pub. L. 110–289, § 1113(a)(3)","children":[],"tail":", (4), added subsecs. (b) and (c) and redesignated former subsec. (b) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1114"},"text":"Pub. L. 110–289, § 1114","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd25ab7b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd25ab7c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Equity in Government Compensation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/93"},"text":"Pub. L. 114–93","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1310"},"text":"129 Stat. 1310","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/93"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Equity in Government Compensation Act of 2015’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DEFINITIONS.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“In this Act:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Director’ means the Director of the Federal Housing Finance Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enterprise","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘enterprise’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal National Mortgage Association and any affiliate thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Home Loan Mortgage Corporation and any affiliate thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“SEC. 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" REASONABLE PAY FOR CHIEF EXECUTIVE OFFICERS.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspension of Current Compensation Package and Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall suspend the compensation packages approved for 2015 for the chief executive officers of each enterprise and, in lieu of such packages, subject to the limitation under subsection (b), establish the compensation and benefits for each such chief executive officer at the same level in effect for such officer as of ","children":[{"tag":"date","attrib":{"date":"2015-01-01"},"text":"January 1, 2015","children":[],"tail":", and such compensation and benefits may not thereafter be increased."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Bonuses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall not be construed to affect the applicability of section 16 of the STOCK Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4518a"},"text":"12 U.S.C. 4518a","children":[],"tail":") to the chief executive officer of each enterprise."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall only apply to a chief executive officer of an enterprise if the enterprise is in conservatorship or receivership pursuant to section 1367 of the Federal Housing Enterprises Financial Safety and Soundness Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4617"},"text":"12 U.S.C. 4617","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“SEC. 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FANNIE AND FREDDIE CHIEF EXECUTIVE OFFICERS NOT FEDERAL EMPLOYEES.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Any chief executive officer affected by any provision under section 3 shall not be considered a Federal employee.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
