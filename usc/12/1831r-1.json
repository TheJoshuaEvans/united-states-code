{"tag":"section","attrib":{"id":"iddc9dddc2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1831r–1"},"text":"§ 1831r–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of branch closure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc9dddc3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to appropriate Federal banking agency","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9dddc4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An insured depository institution which proposes to close any branch shall submit a notice of the proposed closing to the appropriate Federal banking agency not later than the first day of the 90-day period ending on the date proposed for the closing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9dddc5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A notice under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9dddc6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed statement of the reasons for the decision to close the branch; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9dddc7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statistical or other information in support of such reasons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9dddc8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to customers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9dddc9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An insured depository institution which proposes to close a branch shall provide notice of the proposed closing to its customers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9dddca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notice under paragraph (1) shall consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9dddcb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" posting of a notice in a conspicuous manner on the premises of the branch proposed to be closed during not less than the 30-day period ending on the date proposed for that closing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9dddcc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" inclusion of a notice in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc9dddcd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one of any regular account statements mailed to customers of the branch proposed to be closed, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc9dddce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a separate mailing,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"by not later than the beginning of the 90-day period ending on the date proposed for that closing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9dddcf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption of policies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each insured depository institution shall adopt policies for closings of branches of the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9dddd0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Branch closures in interstate banking or branching operations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9dddd1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an interstate bank which proposes to close any branch in a low- or moderate-income area, the notice required under subsection (b)(2) shall contain the mailing address of the appropriate Federal banking agency and a statement that comments on the proposed closing of such branch may be mailed to such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9dddd2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action required by appropriate Federal banking agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, in the case of a branch referred to in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9dddd3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person from the area in which such branch is located—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc9dddd4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits a written request relating to the closing of such branch to the appropriate Federal banking agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc9dddd5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a statement of specific reasons for the request, including a discussion of the adverse effect of such closing on the availability of banking services in the area affected by the closing of the branch; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9dddd6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency concludes that the request is not frivolous,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the agency shall consult with community leaders in the affected area and convene a meeting of representatives of the agency and other interested depository institution regulatory agencies with community leaders in the affected area and such other individuals, organizations, and depository institutions (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s461/b/1/A"},"text":"section 461(b)(1)(A) of this title","children":[],"tail":") as the agency may determine, in the discretion of the agency, to be appropriate, to explore the feasibility of obtaining adequate alternative facilities and services for the affected area, including the establishment of a new branch by another depository institution, the chartering of a new depository institution, or the establishment of a community development credit union, following the closing of the branch."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9dddd7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on closing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No action by the appropriate Federal banking agency under paragraph (2) shall affect the authority of an interstate bank to close a branch (including the timing of such closing) if the requirements of subsections (a) and (b) have been met by such bank with respect to the branch being closed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9dddd8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the following definitions shall apply:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9dddd9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate bank defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “interstate bank” means a bank which maintains branches in more than 1 State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9dddda-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low- or moderate-income area","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “low- or moderate-income area” means a census tract for which the median family income is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc9ddddb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than 80 percent of the median family income for the metropolitan statistical area (as designated by the Director of the Office of Management and Budget) in which the census tract is located; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc9ddddc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a census tract which is not located in a metropolitan statistical area, less than 80 percent of the median family income for the State in which the census tract is located, as determined without taking into account family income in metropolitan statistical areas in such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc9ddddd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc9dddde-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an automated teller machine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9ddddf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the relocation of a branch or consolidation of one or more branches into another branch, if the relocation or consolidation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9ddde0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occurs within the immediate neighborhood; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9ddde1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not substantially affect the nature of the business or customers served; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc9ddde2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a branch that is closed in connection with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc9ddde3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an emergency acquisition under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc9ddde4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1821/n"},"text":"section 1821(n) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc9ddde5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (f) or (k) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1823"},"text":"section 1823 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc9ddde6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831r–1/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any assistance provided by the Corporation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1823/c"},"text":"section 1823(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc9ddde7-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"Sept. 21, 1950, ch. 967, § 2","children":[],"tail":"[42], formerly § 2[39], as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s228"},"text":"Pub. L. 102–242, title II, § 228","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2308"},"text":"105 Stat. 2308","children":[],"tail":"; renumbered § 2[42], "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXVI/s1602/a"},"text":"Pub. L. 102–550, title XVI, § 1602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4078"},"text":"106 Stat. 4078","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/328/tI/s106"},"text":"Pub. L. 103–328, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-29"},"text":"Sept. 29, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2357"},"text":"108 Stat. 2357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2213"},"text":"Pub. L. 104–208, div. A, title II, § 2213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-411"},"text":"110 Stat. 3009–411","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc9ddde8-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc9ddde9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc9dddea-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831p"},"text":"section 1831p of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc9dddeb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/328"},"text":"Pub. L. 103–328","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
