{"tag":"section","attrib":{"id":"iddc3270bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1747j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1747j"},"text":"§ 1747j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxation of real property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to exempt any real property acquired and held by the Secretary under this subchapter from taxation by any State or political subdivision thereof, to the same extent, according to its value, as other real property is taxed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc3270bd-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title VII, § 711, as added "},{"tag":"ref","attrib":{"href":"/us/act/1948-08-10/ch832"},"text":"Aug. 10, 1948, ch. 832","children":[],"tail":", title IV, § 401, "},{"tag":"ref","attrib":{"href":"/us/stat/62/1281"},"text":"62 Stat. 1281","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1950-04-20/ch94"},"text":"Apr. 20, 1950, ch. 94","children":[],"tail":", title I, § 122, "},{"tag":"ref","attrib":{"href":"/us/stat/64/59"},"text":"64 Stat. 59","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/19/s1/a/3"},"text":"Pub. L. 90–19, § 1(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-05-25"},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/17"},"text":"81 Stat. 17","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc3270be-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc3270bf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"