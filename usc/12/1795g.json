{"tag":"section","attrib":{"id":"iddc5b07ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1795g"},"text":"§ 1795g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depositories, custodians, and fiscal agents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Federal Reserve Banks are authorized to act as depositories, custodians and/or fiscal agents for the Central Liquidity Facility in the general performance of its powers conferred by this subchapter. Each Federal Reserve Bank when designated by the Board as fiscal agent for the Central Liquidity Facility, shall be entitled to be reimbursed for all expenses incurred as such fiscal agent.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc5b0800-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title III, formerly subch. III, § 308, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tV/s502/b"},"text":"Pub. L. 95–630, title V, § 502(b)","children":[],"tail":", title XVIII, § 1802, "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3681"},"text":"92 Stat. 3681","children":[],"tail":", 3723; "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tIII/s309/a/4"},"text":"Pub. L. 96–221, title III, § 309(a)(4)","children":[],"tail":", (b)(1), (2), "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/149"},"text":"94 Stat. 149","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc5b0801-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"ed