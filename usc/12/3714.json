{"tag":"section","attrib":{"id":"iddd0ddd51-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3714"},"text":null,"children":[{"tag":"num","attrib":{"value":"3714"},"text":"§ 3714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record of foreclosure and sale","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd0ddd52-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3714/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To establish a sufficient record of foreclosure and sale, the foreclosure commissioner shall include in the recitals of the deed to the purchaser or prepare an affidavit or addendum to the deed stating—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd0ddd53-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3714/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the mortgage was held by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0ddd54-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3714/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the particulars of the foreclosure commissioner’s service of notice of default and foreclosure sale in accordance with sections 3708 and 3710 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0ddd55-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3714/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the foreclosure was conducted in accordance with the provisions of this chapter and with the terms of the notice of default and foreclosure sale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0ddd56-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3714/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a correct statement of the costs of foreclosure, calculated in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3711"},"text":"section 3711 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd0ddd57-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3714/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the successful bidder and the amount of the successful bid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd0ddd58-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3714/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The deed executed by the foreclosure commissioner, the foreclosure commissioner’s affidavit and any other instruments submitted for recordation in relation to the foreclosure of the security property under this chapter shall be accepted for recordation by the registrar of deeds or other appropriate official of the county or counties in which the security property is located upon tendering of payment of the usual recording fees for such instruments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd0ddd59-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s369F"},"text":"Pub. L. 97–35, title III, § 369F","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/430"},"text":"95 Stat. 430","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
