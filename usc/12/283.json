{"tag":"section","attrib":{"id":"iddb2c24fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s283"},"text":null,"children":[{"tag":"num","attrib":{"value":"283"},"text":"§ 283.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public subscription to capital stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No individual, copartnership, or corporation other than a member bank of its district shall be permitted to subscribe for or to hold at any time more than $25,000 par value of stock in any Federal reserve bank. Such stock shall be known as public stock and may be transferred on the books of the Federal reserve bank by the chairman of the board of directors of such bank.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb2c24ff-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s2"},"text":"Dec. 23, 1913, ch. 6, § 2","children":[],"tail":" (par.), "},{"tag":"ref","attrib":{"href":"/us/stat/38/253"},"text":"38 Stat. 253","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb2c2500-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb2c2501-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb2c2502-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of the ninth par. of section 2 of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":". For classification of other pars. of section 2 of this Act, see Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s222"},"text":"section 222 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
