{"tag":"section","attrib":{"id":"iddb1b82e7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s182"},"text":null,"children":[{"tag":"num","attrib":{"value":"182"},"text":"§ 182.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of intent to dissolve","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever a vote is taken to go into liquidation it shall be the duty of the board of directors to cause notice of this fact to be certified, under the seal of the association, by its president or cashier, to the Comptroller of the Currency, and publication thereof to be made for a period of two months in every issue of a newspaper published in the city or town in which the association is located, or if no newspaper is there published, then in the newspaper published nearest thereto, that the association is closing up its affairs, and notifying its creditors to present their claims against the association for payment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb1b82e8-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 5221; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch626"},"text":"Aug. 9, 1955, ch. 626","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/546"},"text":"69 Stat. 546","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb1b82e9-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb1b82ea-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb1b82eb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5221 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-03/ch106/s42"},"text":"act June 3, 1864, ch. 106, § 42","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/112"},"text":"13 Stat. 112","children":[],"tail":", which was the National Bank Act. See "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb1b82ec-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1955—Act ","children":[{"tag":"date","attrib":{"date":"1955-08-09"},"text":"Aug. 9, 1955","children":[],"tail":", struck out provisions relating to publication in a newspaper published in the City of New York, and notification to holders of national bank notes to present them for payment."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddb1b82ed-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb1b82ee-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exception as to Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested by any provision of law in Comptroller of the Currency, referred to in this section, not included in transfer of functions to Secretary of the Treasury, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
