{"tag":"section","attrib":{"id":"iddd04676f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3302"},"text":null,"children":[{"tag":"num","attrib":{"value":"3302"},"text":"§ 3302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd046770-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Federal financial institutions regulatory agencies” means the Office of the Comptroller of the Currency, the Board of Governors of the Federal Reserve System, the Federal Deposit Insurance Corporation, the Office of Thrift Supervision, and the National Credit Union Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd046771-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Council” means the Financial Institutions Examination Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd046772-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “financial institution” means a commercial bank, a savings bank, a trust company, a savings association, a building and loan association, a homestead association, a cooperative bank, or a credit union; ","children":[{"tag":"ref","attrib":{"idref":"fn002338"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002338"},"text":null,"children":[{"tag":"num","attrib":{},"tex