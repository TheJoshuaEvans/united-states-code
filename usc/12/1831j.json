{"tag":"section","attrib":{"id":"iddc96b0ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1831j"},"text":"§ 1831j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depository institution employee protection remedy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc96b0ef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc96b0f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees of depository institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No insured depository institution may discharge or otherwise discriminate against any employee with respect to compensation, terms, conditions, or privileges of employment because the employee (or any person acting pursuant to the request of the employee) provided information to any Federal banking agency or to the Attorney General regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc96b0f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a possible violation of any law or regulation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc96b0f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gross mismanagement, a gross waste of funds, an abuse of authority, or a substantial and specific danger to public health or safety;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"by the depository institution or any director, officer, or employee of the institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc96b0f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees of banking agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No Federal banking agency, Federal home loan bank, Federal reserve bank, or any person who is performing, directly or indirectly, any function or service on behalf of the Corporation may discharge or otherwise discriminate against any employee with respect to compensation, terms, conditions, or privileges of employment because the employee (or any person acting pursuant to the request of the employee) provided information to any such agency or bank or to the Attorney General regarding any possible violation of any law or regulation, gross mismanagement, a gross waste of funds, an abuse of authority, or a substantial and specific danger to public health or safety by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc96b0f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any depository institution or any such bank or agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc96b0f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any director, officer, or employee of any depository institution or any such bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc96b0f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any officer or employee of the agency which employs such employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc96b0f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person, or any officer or employee of the person, who employs such employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc96b0f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any employee or former employee who believes he has been discharged or discriminated against in violation of subsection (a) may file a civil action in the appropriate United States district court before the close of the 2-year period beginning on the date of such discharge or discrimination. The complainant shall also file a copy of the complaint initiating such action with the appropriate Federal banking agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc96b0f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the district court determines that a violation of subsection (a) has occurred, it may order the depository institution, Federal home loan bank, Federal Reserve bank, or Federal banking agency which committed the violation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc96b0fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reinstate the employee to his former position;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc96b0fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay compensatory damages; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc96b0fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take other appropriate actions to remedy any past discrimination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc96b0fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The protections of this section shall not apply to any employee who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc96b0fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deliberately causes or participates in the alleged violation of law or regulation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc96b0ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly or recklessly provides substantially false information to such an agency or the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc96b100-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Federal banking agency” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsections (a) and (c), the term “Federal banking agency” means the Corporation, the Board of Governors of the Federal Reserve System, the Federal Housing Finance Agency and the Comptroller of the Currency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc96b101-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1831j/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burdens of proof","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The legal burdens of proof that prevail under subchapter III of chapter 12 of title 5 shall govern adjudication of protected activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc96b102-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"Sept. 21, 1950, ch. 967, § 2","children":[],"tail":"[33], as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX/s932/a"},"text":"Pub. L. 101–73, title IX, § 932(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/494"},"text":"103 Stat. 494","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s251/a/1"},"text":"Pub. L. 102–242, title II, § 251(a)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2331"},"text":"105 Stat. 2331","children":[],"tail":", 2332; "},{"tag":"ref","attrib":{"href":"/us/pl/103/204/s21/a"},"text":"Pub. L. 103–204, § 21(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2406"},"text":"107 Stat. 2406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tVI/s602/a/61"},"text":"Pub. L. 103–325, title VI, § 602(a)(61)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2291"},"text":"108 Stat. 2291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s363/10"},"text":"Pub. L. 111–203, title III, § 363(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1555"},"text":"124 Stat. 1555","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc96b103-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc96b104-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc96b105-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Federal Housing Finance Agency and the Comptroller of the Currency” for “Federal Housing Finance Board, the Comptroller of the Currency, and the Director of the Office of Thrift Supervision”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s602/c"},"text":"Pub. L. 103–325, § 602(c)","children":[],"tail":", amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/204/s21/a"},"text":"Pub. L. 103–204, § 21(a)","children":[],"tail":". See 1993 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s602/a/61"},"text":"Pub. L. 103–325, § 602(a)(61)","children":[],"tail":", substituted semicolon for comma at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s602/c/1"},"text":"Pub. L. 103–325, § 602(c)(1)","children":[],"tail":"–(3), amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/204/s21/a/1/B"},"text":"Pub. L. 103–204, § 21(a)(1)(B)","children":[],"tail":". See 1993 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/204/s21/a/1/A"},"text":"Pub. L. 103–204, § 21(a)(1)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/s602/c/1"},"text":"Pub. L. 103–325, § 602(c)(1)","children":[],"tail":"–(3), substituted “regarding—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) a possible violation of any law or regulation; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) gross mismanagement, a gross waste of funds, an abuse of authority, or a substantial and specific danger to public health or safety;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"by the depository institution or any director, officer, or employee of the institution.” for “regarding any possible violation of any law or regulation by the depository institution or any director, officer, or employee of the institution.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/204/s21/a/2/A"},"text":"Pub. L. 103–204, § 21(a)(2)(A)","children":[],"tail":", (B), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/s602/c/1"},"text":"Pub. L. 103–325, § 602(c)(1)","children":[],"tail":", (2), (4), in introductory provisions, substituted “Federal reserve bank, or any person who is performing, directly or indirectly, any function or service on behalf of the Corporation” for “or Federal Reserve bank” and “any possible violation of any law or regulation, gross mismanagement, a gross waste of funds, an abuse of authority, or a substantial and specific danger to public health or safety by” for “any possible violation of any law or regulation by”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/204/s21/a/2/C"},"text":"Pub. L. 103–204, § 21(a)(2)(C)","children":[],"tail":"–(E), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/s602/c/1"},"text":"Pub. L. 103–325, § 602(c)(1)","children":[],"tail":", (2), (4), added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/204/s21/a/1/B"},"text":"Pub. L. 103–204, § 21(a)(1)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/s602/c/1"},"text":"Pub. L. 103–325, § 602(c)(1)","children":[],"tail":"–(3), added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s251/a/1"},"text":"Pub. L. 102–242, § 251(a)(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “No federally insured depository institution may discharge or otherwise discriminate against any employee with respect to compensation, terms, conditions, or privileges of employment because the employee (or any person acting pursuant to the request of the employee) provided information to any Federal banking agency or to the Attorney General regarding a possible violation of any law or regulation by the depository institution or any of its officers, directors, or employees.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s251/a/2"},"text":"Pub. L. 102–242, § 251(a)(2)","children":[],"tail":", inserted “, Federal home loan bank, Federal Reserve bank, or Federal banking agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s251/a/3"},"text":"Pub. L. 102–242, § 251(a)(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc96b106-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc96b107-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s351"},"text":"section 351 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s906"},"text":"section 906 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc96b108-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s251/a/4"},"text":"Pub. L. 102–242, title II, § 251(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2332"},"text":"105 Stat. 2332","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/242/tII/s251/a/4"},"text":"“Paragraph (2) of section 33(a) of the Federal Deposit Insurance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831j/a/2"},"text":"12 U.S.C. 1831j(a)(2)","children":[],"tail":"] (as added under the amendment made by paragraph (1)) shall be treated as having taken effect on "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", and for purposes of any cause of action arising under such paragraph (as so effective) before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":"], the 2-year period referred to in section 33(b) of such Act shall be deemed to begin on such date of enactment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
