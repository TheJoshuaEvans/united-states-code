{"tag":"section","attrib":{"id":"iddcec72e5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279aa–13"},"text":"§ 2279aa–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to issue obligations to cover guarantee losses of Corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcec72e6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of obligations to Treasury","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec72e7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–13/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the limitations contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa–10/c"},"text":"section 2279aa–10(c) of this title","children":[],"tail":" and the requirement of paragraph (2), the Corporation may issue obligations to the Secretary of the Treasury the proceeds of which may be used by the Corporation solely for the purpose of fulfilling the obligations of the Corporation under any guarantee provided by the Corporation under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec72e8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–13/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury may purchase obligations of the Corporation under paragraph (1) only if the Corporation certifies to the Secretary that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcec72e9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–13/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa–10/c"},"text":"section 2279aa–10(c) of this title","children":[],"tail":" have been fulfilled; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcec72ea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–13/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proceeds of the sale of such obligations are needed to fulfill the obligations of the Corporation under any guarantee provided by the Corporation under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec72eb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expeditious transaction required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 10 business days after receipt by the Secretary of the Treasury of any certification by the Corporation under subsection (a)(2), the Secretary of the Treasury shall purchase obligations issued by the Corporation in an amount determined by the Corporation to be sufficient to meet the guarantee liabilities of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec72ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on amount of outstanding obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate amount of obligations issued by the Corporation under subsection (a)(1) which may be held by the Secretary of the Treasury at any time (as determined by the Secretary) shall not exceed $1,500,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec72ed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–13/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of obligation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec72ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–13/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each obligation purchased by the Secretary of the Treasury shall bear interest at a rate determined by the Secretary, taking into consideration the average rate on outstanding marketable obligations of the United States as of the last day of the last calendar month ending before the date of the purchase of such obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec72ef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–13/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall require that such obligations be repurchased by the Corporation within a reasonable time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec72f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–13/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with title 31","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec72f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–13/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to use proceeds from sale of Treasury securities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of purchasing obligations of the Corporation, the Secretary of the Treasury may use as a public debt transaction the proceeds from the sale by the Secretary of any securities issued under chapter 31 of title 31, and the purposes for which securities may be issued under such chapter are extended to include such purchases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec72f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–13/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All purchases and sales by the Secretary of the Treasury of obligations issued by the Corporation under this section shall be treated as public debt transactions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec72f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–13/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary of the Treasury $1,500,000,000, without fiscal year limitation, to carry out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcec72f4-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVIII/s8"},"text":"Pub. L. 92–181, title VIII, § 8","children":[],"tail":".13, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVII/s702"},"text":"Pub. L. 100–233, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1704"},"text":"101 Stat. 1704","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/105/tI/s109/b/2"},"text":"Pub. L. 104–105, title I, § 109(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/165"},"text":"110 Stat. 165","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcec72f5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcec72f6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcec72f7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105"},"text":"Pub. L. 104–105","children":[],"tail":" substituted “section” for “sections 2279aa–6(b) and” in pars. (1) and (2)(A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
