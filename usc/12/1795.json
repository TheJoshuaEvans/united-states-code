{"tag":"section","attrib":{"id":"iddc5b0782-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795"},"text":null,"children":[{"tag":"num","attrib":{"value":"1795"},"text":"§ 1795.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Congress finds that the establishment of a National Credit Union Central Liquidity Facility is needed to improve general financial stability by meeting the liquidity needs of credit unions and thereby encourage savings, support consumer and mortgage lending, and provide basic financial resources to all segments of the economy.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc5b0783-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title III, formerly subch. III, § 301, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXVIII/s1802"},"text":"Pub. L. 95–630, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3719"},"text":"92 Stat. 3719","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tIII/s309/b/1"},"text":"Pub. L. 96–221, title III, § 309(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/149"},"text":"94 Stat. 149","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc5b0784-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc5b0785-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":nu