{"tag":"section","attrib":{"id":"iddafc88da-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"§ 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oath of Comptroller","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Comptroller of the Currency shall, within fifteen days from the time of notice of his appointment, take and subscribe the oath of office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddafc88db-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 326; ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/251/s1/d"},"text":"Pub. L. 86–251, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-09"},"text":"Sept. 9, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/488"},"text":"73 Stat. 488","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/310/tII/s223/a"},"text":"Pub. L. 92–310, title II, § 223(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-06"},"text":"June 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/206"},"text":"86 Stat. 206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddafc88dc-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddafc88dd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddafc88de-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 326 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-03/ch106/s1"},"text":"act June 3, 1864, ch. 106, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/99"},"text":"13 Stat. 99","children":[],"tail":", which was the National Bank Act. See "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddafc88df-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/310"},"text":"Pub. L. 92–310","children":[],"tail":" struck out provisions which required the Comptroller to give a bond in the sum of $250,000."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/251"},"text":"Pub. L. 86–251","children":[],"tail":" increased the surety bond requirement from $100,000 to $250,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
