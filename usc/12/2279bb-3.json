{"tag":"section","attrib":{"id":"iddcec734d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279bb–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279bb–3"},"text":"§ 2279bb–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical capital level","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of this part, the critical capital level for the Corporation shall be an amount of core capital equal to 50 percent of the total minimum capital amount determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279bb–2"},"text":"section 2279bb–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcec734e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVIII/s8"},"text":"Pub. L. 92–181, title VIII, § 8","children":[],"tail":".34, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tV/s503/b/2"},"text":"Pub. L. 102–237, title V, § 503(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1874"},"text":"105 Stat. 1874","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/105/tI/s115"},"text":"Pub. L. 104–105, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/167"},"text":"110 Stat. 167","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcec734f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcec7350-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcec7351-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105"},"text":"Pub. L. 104–105","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “For purposes of this part, the critical capital level for the Corporation shall be an amount of core capital equal to the sum of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) 1.25 percent of the aggregate on-balance sheet assets of the Corporation (other than assets referred to in paragraph (3)), as determined in accordance with generally accepted accounting principles;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) 0.25 percent of the unpaid principal balance of outstanding securities guaranteed by the Corporation and backed by pools of qualified loans and substantially equivalent instruments issued or guaranteed by the Corporation, and other off-balance sheet obligations of the Corporation; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) a percentage of any aggregate assets of the Corporation acquired pursuant to the linked portfolio option under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa–6/g"},"text":"section 2279aa–6(g) of this title","children":[],"tail":", which shall be—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) during the 5-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1991-12-13"},"text":"December 13, 1991","children":[],"tail":", one-half of the percentage that is determined under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279bb–2/c/1"},"text":"section 2279bb–2(c)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) after the expiration of such 5-year period, 1.25 percent of any such aggregate assets.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
