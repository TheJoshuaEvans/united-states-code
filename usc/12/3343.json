{"tag":"section","attrib":{"id":"iddd06b148-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3343"},"text":null,"children":[{"tag":"num","attrib":{"value":"3343"},"text":"§ 3343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transactions requiring services of State licensed appraiser","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All federally related transactions not requiring the services of a State certified appraiser shall be performed by either a State certified or licensed appraiser.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd06b149-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXI/s1114"},"text":"Pub. L. 101–73, title XI, § 1114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/514"},"text":"103 Stat. 514","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
