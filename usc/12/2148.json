{"tag":"section","attrib":{"id":"iddcc64c4c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2148"},"text":null,"children":[{"tag":"num","attrib":{"value":"2148"},"text":"§ 2148.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transactions to accomplish merger","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The receipt of assets or assumption of liabilities by the consolidated bank, the exchange of stock, equities, or other ownership interests, and any other transaction carried out in accomplishing the merger of the banks for cooperatives shall not be treated as a taxable event under the laws of the United States or of any State or political subdivision thereof. The preceding sentence shall also apply to the receipt of assets and liabilities by a cooperative to the extent that the net amount of the distribution is immediately reinvested in stock of a consolidated bank (and in such case the basis of such stock shall be appropriately reduced by the amount of gain not recognized by reason of this sentence).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcc64c4d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIII/s3"},"text":"Pub. L. 92–181, title III, § 3","children":[],"tail":".27, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s415/2"},"text":"Pub. L. 100–233, title IV, § 415(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1644"},"text":"101 Stat. 1644","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s407/g"},"text":"Pub. L. 100–399, title IV, § 407(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1001"},"text":"102 Stat. 1001","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcc64c4e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcc64c4f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcc64c50-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" substituted “cooperative” for “taxable institution”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcc64c51-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcc64c52-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective as if enacted immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/a"},"text":"section 1001(a) of Pub. L. 100–399","children":[],"tail":", 