{"tag":"section","attrib":{"id":"iddccb08ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2219e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2219e"},"text":"§ 2219e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for making criminal referrals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddccb08af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2219e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any institution of the Farm Credit System, or any director, officer, employee, or agent of a Farm Credit System institution, that discloses to a Government authority information proffered in good faith that may be relevant to a possible violation of any law or regulation shall not be liable to any person under any law of the United States or any State—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddccb08b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2219e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the disclosure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccb08b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2219e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any failure to notify the person involved in the possible violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccb08b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2219e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No prohibition on disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any institution of the Farm Credit System, or any director, officer, employee, or agent of a Farm Credit System institution, may disclose information to a Government authority that may be relevant to a possible violation of any law or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddccb08b3-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/105/tII/s221"},"text":"Pub. L. 104–105, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/184"},"text":"110 Stat. 184","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddccb08b4-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddccb08b5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddccb08b6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Farm Credit System Reform Act of 1996, and not as part of the Farm Credit Act of 1971 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
