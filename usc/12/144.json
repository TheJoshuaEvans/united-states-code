{"tag":"section","attrib":{"id":"iddb191283-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s144"},"text":null,"children":[{"tag":"num","attrib":{"value":"144"},"text":"§ 144.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain balances counted toward reserves in dependencies and insular possessions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Four-fifths of the reserve of 15 per centum which a national bank located in a dependency or insular possession or any part of the United States outside of the continental United States, and not a member of the Federal Reserve System, is required to keep, may consist of balances due such bank from associations approved by the Comptroller of the Currency and located in any one of the reserve cities as now or hereafter defined by law or designated by the Board of Governors of the Federal Reserve System.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb191284-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 5192; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-01/ch536"},"text":"July 1, 1952, ch. 536","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/314"},"text":"66 Stat. 314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/70/s7"},"text":"Pub. L. 86–70, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-06-25"},"text":"June 25, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/142"},"text":"73 Stat. 142","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/114/s3/b/3"},"text":"Pub. L. 86–114, § 3(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-07-28"},"text":"July 28, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/263"},"text":"73 Stat. 263","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb191285-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb191286-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb191287-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5192 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-03/ch106/s31"},"text":"act June 3, 1864, ch. 106, § 31","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/108"},"text":"13 Stat. 108","children":[],"tail":", which was the National Bank Act. See "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb191288-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/114"},"text":"Pub. L. 86–114","children":[],"tail":" struck out “central reserve or” before “reserve cities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/70"},"text":"Pub. L. 86–70","children":[],"tail":" struck out “in Alaska or” before “in a dependency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1952—Act ","children":[{"tag":"date","attrib":{"date":"1952-07-01"},"text":"July 1, 1952","children":[],"tail":", reduced the required amount of cash on hand from two-fifths to one-fifth of the required reserve of 15 per centum."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id"