{"tag":"section","attrib":{"id":"iddbb68add-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"1701z–10"},"text":"§ 1701z–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model rehabilitation guidelines in inspection and approval of rehabilitated properties; report to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddbb68ade-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddbb68adf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–10/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall develop model rehabilitation guidelines for the voluntary adoption by States and communities to be used in conjunction with existing building codes by State and local officials in the inspection and approval of rehabilitated properties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddbb68ae0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–10/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such guidelines shall be developed in consultation with the National Institute of Building Sciences, appropriate national organizations of agencies and officials of State and local governments, representatives of the building industry, and consumer groups, and other interested parties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddbb68ae1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–10/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall publish such guidelines for public comment not later than one year after ","children":[{"tag":"date","attrib":{"date":"1978-10-31"},"text":"October 31, 1978","children":[],"tail":", and promulgate them no later than eighteen months after such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddbb68ae2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–10/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may furnish technical assistance to State and local governments to facilitate the use and implementation of such guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddbb68ae3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall report to Congress not later than thirty-six months after ","children":[{"tag":"date","attrib":{"date":"1978-10-31"},"text":"October 31, 1978","children":[],"tail":", regarding (1) actions taken by State and local governments to adopt guidelines or their equivalents, and (2) recommendations for further action."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddbb68ae4-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/609/tV/s511"},"text":"Pub. L. 91–609, title V, § 511","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/557/tIX/s903"},"text":"Pub. L. 95–557, title IX, § 903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2125"},"text":"92 Stat. 2125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddbb68ae5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddbb68ae6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddbb68ae7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Housing and Urban Development Act of 1970, and not as part of the National Housing Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
