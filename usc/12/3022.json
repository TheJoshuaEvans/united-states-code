{"tag":"section","attrib":{"id":"iddcfaca33-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3022"},"text":null,"children":[{"tag":"num","attrib":{"value":"3022"},"text":"§ 3022.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of additional appropriations; restrictions on use","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to appropriations specifically authorized in this chapter, there are authorized to be appropriated $2,000,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":", and for each of the two succeeding fiscal years, ending "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":", such sums as may be necessary: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That none of these appropriated sums shall be used to retire any indebtedness of the Bank incurred pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3017"},"text":"section 3017 of this title","children":[],"tail":". Any sums so appropriated shall remain available until expended."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcfaca34-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/351/tI/s112"},"text":"Pub. L. 95–351, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-20"},"text":"Aug. 20, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/510"},"text":"92 Stat. 510","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
