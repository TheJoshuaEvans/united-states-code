{"tag":"section","attrib":{"id":"iddb7625bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1435"},"text":null,"children":[{"tag":"num","attrib":{"value":"1435"},"text":"§ 1435.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligations as lawful investments; liability of United States for debentures, etc., issued by banks","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Obligations of the Federal Home Loan Banks issued with the approval of the Board or the Director under this chapter shall be lawful investments, and may be accepted as security, for all fiduciary, trust, and public funds the investment or deposit of which shall be under the authority or control of the United States or any officer or officers thereof. The Federal reserve banks are authorized to act as depositaries, custodians, and/or fiscal agents for Federal Home Loan Banks in the general performance of their powers under this chapter. All obligations of Federal Home Loan Banks shall plainly state that such obligations are not obligations of the United States and are not guaranteed by the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb7625bc-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1932-07-22/ch522/s15"},"text":"July 22, 1932, ch. 522, § 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/736"},"text":"47 Stat. 736","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tVII/s701/b/1"},"text":"Pub. L. 101–73, title VII, § 701(b)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/412"},"text":"103 Stat. 412","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tII/s1204/7"},"text":"Pub. L. 110–289, div. A, title II, § 1204(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2786"},"text":"122 Stat. 2786","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb7625bd-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb7625be-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb7625bf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289"},"text":"Pub. L. 110–289","children":[],"tail":" inserted “or the Director” after “the Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" substituted “Board” for “board”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
