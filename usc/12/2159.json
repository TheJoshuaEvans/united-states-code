{"tag":"section","attrib":{"id":"iddcc64cd3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2159"},"text":null,"children":[{"tag":"num","attrib":{"value":"2159"},"text":"§ 2159.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase and sale of obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each bank of the System may purchase its own obligations and the obligations of other banks of the System and may provide for the sale of obligations issued by it, consolidated obligations, or Systemwide obligations through a fiscal agent or agents, by negotiation, offer, bid, syndicate sale, and to deliver such obligations by book entry, wire transfer, or such other means as may be appropriate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcc64cd4-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".8, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/612"},"text":"85 Stat. 612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tI/s1034"},"text":"Pub. L. 99–509, title I, § 1034","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1878"},"text":"100 Stat. 1878","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tII/s205/a"},"text":"Pub. L. 100–233, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1607"},"text":"101 Stat. 1607","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5411/18"},"text":"Pub. L. 115–334, title V, § 5411(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4680"},"text":"132 Stat. 4680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcc64cd5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcc64cd6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcc64cd7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" struck out subsec. (a) designation before “Each bank” and struck out subsec. (b) which described conditions under which each bank of the System could reduce the cost of its borrowings and amortize certain capitalizations through "},{"tag":"date","attrib":{"date":"1992-12-31"},"text":"Dec. 31, 1992","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1992-12-31"},"text":"December 31, 1992","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1988-12-31"},"text":"December 31, 1988","children":[],"tail":"” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],