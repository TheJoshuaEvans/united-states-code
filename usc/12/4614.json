{"tag":"section","attrib":{"id":"iddd2f47ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614"},"text":null,"children":[{"tag":"num","attrib":{"value":"4614"},"text":"§ 4614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital classifications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2f47ed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enterprises","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the Director shall classify the enterprises according to the following capital classifications:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f47ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adequately capitalized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An enterprise shall be classified as adequately capitalized if the enterprise—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2f47ef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains an amount of total capital that is equal to or exceeds the risk-based capital level established for the enterprise under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4611"},"text":"section 4611 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f47f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains an amount of core capital that is equal to or exceeds the minimum capital level established for the enterprise under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4612"},"text":"section 4612 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f47f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Undercapitalized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An enterprise shall be classified as undercapitalized if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2f47f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the enterprise—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd2f47f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not maintain an amount of total capital that is equal to or exceeds the risk-based capital level established for the enterprise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd2f47f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains an amount of core capital that is equal to or exceeds the minimum capital level established for the enterprise; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f47f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enterprise is otherwise classified as undercapitalized under subsection (b)(1) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f47f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Significantly undercapitalized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An enterprise shall be classified as significantly undercapitalized if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2f47f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the enterprise—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd2f47f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not maintain an amount of total capital that is equal to or exceeds the risk-based capital level established for the enterprise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd2f47f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not maintain an amount of core capital that is equal to or exceeds the minimum capital level established for the enterprise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd2f47fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains an amount of core capital that is equal to or exceeds the critical capital level established for the enterprise under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4613"},"text":"section 4613 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f47fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enterprise is otherwise classified as significantly undercapitalized under subsection (b)(2) of this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4615/b"},"text":"section 4615(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f47fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critically undercapitalized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An enterprise shall be classified as critically undercapitalized if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2f47fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the enterprise—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd2f47fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not maintain an amount of total capital that is equal to or exceeds the risk-based capital level established for the enterprise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd2f47ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not maintain an amount of core capital that is equal to or exceeds the critical capital level for the enterprise; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f4800-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is otherwise classified as critically undercapitalized under subsection (b)(3) of this section or section 4616(b)(5) ","children":[{"tag":"ref","attrib":{"idref":"fn002422"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002422"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f4801-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Home Loan Banks","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f4802-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the Director shall, by regulation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2f4803-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the capital classifications specified under paragraph (2) for the Federal Home Loan Banks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f4804-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish criteria for each such capital classification based on the amount and types of capital held by a bank and the risk-based, minimum, and critical capital levels for the banks and taking due consideration of the capital classifications established under subsection (a) for the enterprises, with such modifications as the Director determines to be appropriate to reflect the difference in operations between the banks and the enterprises; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f4805-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall classify the Federal Home Loan Banks according to such capital classifications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f4806-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The capital classifications specified under this paragraph are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2f4807-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequately capitalized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f4808-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undercapitalized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f4809-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly undercapitalized; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f480a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" critically undercapitalized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f480b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary classification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f480c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grounds for reclassification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may reclassify a regulated entity under paragraph (2) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2f480d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at any time, the Director determines in writing that the regulated entity is engaging in conduct that could result in a rapid depletion of core or total capital or the value of collateral pledged as security has decreased significantly or that the value of the property subject to mortgages held by the regulated entity (or securitized in the case of an enterprise) has decreased significantly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f480e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after notice and an opportunity for hearing, the Director determines that the regulated entity is in an unsafe or unsound condition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f480f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4631/b"},"text":"section 4631(b) of this title","children":[],"tail":", the Director deems the regulated entity to be engaging in an unsafe or unsound practice."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f4810-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reclassification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any other action authorized under this chapter, including the reclassification of a regulated entity for any reason not specified in this subsection, if the Director takes any action described in paragraph (1), the Director may classify a regulated entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2f4811-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as undercapitalized, if the regulated entity is otherwise classified as adequately capitalized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f4812-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as significantly undercapitalized, if the regulated entity is otherwise classified as undercapitalized; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f4813-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as critically undercapitalized, if the regulated entity is otherwise classified as significantly undercapitalized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f4814-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall determine the capital classification of the regulated entities for purposes of this subchapter on not less than a quarterly basis (and as appropriate under subsection (c)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f4815-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on capital distributions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f4816-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A regulated entity shall make no capital distribution if, after making the distribution, the regulated entity would be undercapitalized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f4817-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1), the Director may permit a regulated entity, to the extent appropriate or applicable, to repurchase, redeem, retire, or otherwise acquire shares or ownership interests if the repurchase, redemption, retirement, or other acquisition—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2f4818-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made in connection with the issuance of additional shares or obligations of the regulated entity in at least an equivalent amount; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f4819-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will reduce the financial obligations of the regulated entity or otherwise improve the financial condition of the entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f481a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4614/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":", and ending upon the effective date of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4615"},"text":"section 4615 of this title","children":[],"tail":" (as provided in section 4615(c) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title), an enterprise shall be classified as adequately capitalized if the enterprise maintains an amount of core capital that is equal to or exceeds the minimum capital level for the enterprise under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4612"},"text":"section 4612 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2f481b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1364"},"text":"Pub. L. 102–550, title XIII, § 1364","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3976"},"text":"106 Stat. 3976","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI"},"text":"Pub. L. 110–289, div. A, title I","children":[],"tail":", §§ 1142(a), 1161(a)(3), "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2730"},"text":"122 Stat. 2730","children":[],"tail":", 2779.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2f481c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2f481d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd2f481e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4616/b/5"},"text":"Section 4616(b)(5) of this title","children":[],"tail":", referred to in subsec. (a)(4)(B), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4616/b/6"},"text":"section 4616(b)(6) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1144/5/D"},"text":"Pub. L. 110–289, div. A, title I, § 1144(5)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2733"},"text":"122 Stat. 2733","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c)(2), was in the original “this title”, meaning title XIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3941"},"text":"106 Stat. 3941","children":[],"tail":", which is classified principally to this chapter. For complete classification of title XIII to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4501"},"text":"section 4501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4615/c"},"text":"Section 4615(c) of this title","children":[],"tail":", referred to in subsec. (f), was repealed and a new section 4615(c) was added by "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1143/6"},"text":"Pub. L. 110–289, div. A, title I, § 1143(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2734"},"text":"122 Stat. 2734","children":[],"tail":". The new section 4615(c) does not relate to effective date."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2f481f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1142/a/1"},"text":"Pub. L. 110–289, § 1142(a)(1)","children":[],"tail":", substituted “Enterprises” for “In general” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1142/a/4"},"text":"Pub. L. 110–289, § 1142(a)(4)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which related to discretionary classification."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1161/a/3"},"text":"Pub. L. 110–289, § 1161(a)(3)","children":[],"tail":", which directed amendment of subsec. (c) by striking out the last sentence, was not executed as the probable intent of Congress. The amendment was probably intended to strike out the last sentence of former subsec. (c), now subsec. (d), as it existed prior to being struck out by "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1142/a/2/C"},"text":"Pub. L. 110–289, § 1142(a)(2)(C)","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1142/a/3"},"text":"Pub. L. 110–289, § 1142(a)(3)","children":[],"tail":", (4), added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1142/a/2/C"},"text":"Pub. L. 110–289, § 1142(a)(2)(C)","children":[],"tail":", struck out last sentence which read as follows: “The first such determination shall be made during the 3-month period beginning on the appointment of the Director.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1142/a/2/A"},"text":"Pub. L. 110–289, § 1142(a)(2)(A)","children":[],"tail":", (B), substituted “regulated entities” for “enterprises” and “subsection (c)” for “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1142/a/3"},"text":"Pub. L. 110–289, § 1142(a)(3)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1142/a/5"},"text":"Pub. L. 110–289, § 1142(a)(5)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1142/a/3"},"text":"Pub. L. 110–289, § 1142(a)(3)","children":[],"tail":", redesignated subsec. (d) as (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd2f4820-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd2f4821-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1142/b"},"text":"Pub. L. 110–289, div. A, title I, § 1142(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2732"},"text":"122 Stat. 2732","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/289/dA/tI/s1142/b"},"text":"“Not later than the expiration of the 180-day period beginning on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":"], the Director of the Federal Housing Finance Agency shall issue regulations to carry out section 1364(b) of the Federal Housing Enterprises Financial Safety and Soundness Act of 1992 ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4614/b"},"text":"12 U.S.C. 4614(b)","children":[],"tail":"] (as added by this section), relating to capital classifications for the Federal Home Loan Banks.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
