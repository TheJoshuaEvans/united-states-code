{"tag":"section","attrib":{"id":"iddd38be68-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4705"},"text":null,"children":[{"tag":"num","attrib":{"value":"4705"},"text":"§ 4705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd38be69-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application for assistance may be filed jointly by a community development financial institution and a community partner to carry out a community partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38be6a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Fund shall require a community partnership application—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd38be6b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4705/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet the minimum requirements established for community development financial institutions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4704/b"},"text":"section 4704(b) of this title","children":[],"tail":", except that the criteria specified in paragraphs (1) and (2)(A) of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4704/b"},"text":"section 4704(b) of this title","children":[],"tail":" shall not apply to the community partner;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be6c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4705/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to describe how each coapplicant will participate in carrying out the community partnership and how the partnership will enhance activities serving the investment area or targeted population; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be6d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4705/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to demonstrate that the community partnership activities are consistent with the strategic plan submitted by the community development financial institution coapplicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38be6e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Fund shall consider a community partnership application based on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd38be6f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4705/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the community development financial institution coapplicant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd38be70-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4705/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meeting the minimum selection criteria described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4704"},"text":"section 4704 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38be71-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4705/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfying the selection criteria of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4706"},"text":"section 4706 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be72-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4705/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the community partner coapplicant will participate in carrying out the partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be73-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4705/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the community partnership will enhance the likelihood of success of the community development financial institution coapplicant’s strategic plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be74-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4705/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which service to the investment area or targeted population will be better performed by a partnership as opposed to the individual community development financial institution coapplicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38be75-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4705/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on distribution of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance provided upon approval of an application under this section shall be distributed only to the community development financial institution coapplicant, and shall not be used to fund any activities carried out directly by the community partner or an affiliate or subsidiary thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38be76-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4705/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other requirements and limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All other requirements and limitations imposed by this subchapter on a community development financial institution assisted under this subchapter shall apply (in the manner that the Fund determines to be appropriate) to assistance provided to carry out community partnerships. The Fund may establish additional guidelines and restrictions on the use of Federal funds to carry out community partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd38be77-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s106"},"text":"Pub. L. 103–325, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2171"},"text":"108 Stat. 2171","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
