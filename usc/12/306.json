{"tag":"section","attrib":{"id":"iddb2e956f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s306"},"text":null,"children":[{"tag":"num","attrib":{"value":"306"},"text":"§ 306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistants to Federal reserve agent","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to the approval of the Board of Governors of the Federal Reserve System, the Federal reserve agent shall appoint one or more assistants. Such assistants, who shall be persons of tested banking experience, shall assist the Federal reserve agent in the performance of his duties and shall also have power to act in his name and stead during his absence or disability. The Board of Governors of the Federal Reserve System shall require such bonds of the assistant Federal reserve agents as it may deem necessary for the protection of the United States. Assistants to the Federal reserve agent shall receive an annual compensation, to be fixed and paid in the same manner as that of the Federal reserve agent.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb2e9570-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s4"},"text":"Dec. 23, 1913, ch. 6, § 4","children":[],"tail":" (par.), as added "},{"tag":"ref","attrib":{"href":"/us/act/1917-06-21/ch32/s2"},"text":"June 21, 1917, ch. 32, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/232"},"text":"40 Stat. 232","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-23/ch614"},"text":"Aug. 23, 1935, ch. 614","children":[],"tail":", title II, § 203(a), "},{"tag":"ref","attrib":{"href":"/us/stat/49/704"},"text":"49 Stat. 704","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb2e9571-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb2e9572-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb2e9573-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of par. 23 of section 4 of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1917-06-21"},"text":"June 21, 1917","children":[],"tail":". For classification to this title of other pars. of section 4, see Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s301"},"text":"section 301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb2e9574-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddb2e9575-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 203(a) of act ","children":[{"tag":"date","attrib":{"date":"1935-08-23"},"text":"Aug. 23, 1935","children":[],"tail":", changed name of Federal Reserve Board to Board of Governors of the Federal Reserve System."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
