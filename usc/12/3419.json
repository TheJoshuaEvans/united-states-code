{"tag":"section","attrib":{"id":"iddd0b6c3e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3419"},"text":null,"children":[{"tag":"num","attrib":{"value":"3419"},"text":"§ 3419.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any individual files a motion or application under this chapter which has the effect of delaying the access of a Government authority to financial records pertaining to such individual, any applicable statute of limitations shall be deemed to be tolled for the period extending from the date such motion or application was filed until the date upon which the motion or application is decided.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd0b6c3f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXI/s1119"},"text":"Pub. L. 95–630, title XI, § 1119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3709"},"text":"92 Stat. 3709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0b6c40-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd0b6c41-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd0b6c42-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of 120 days after ","children":[{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/s2101"},"text":"section 2101 of Pub. L. 95–630","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s375b"},"text":"section 375b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
