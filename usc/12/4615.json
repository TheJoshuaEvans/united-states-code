{"tag":"section","attrib":{"id":"iddd2f4822-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615"},"text":null,"children":[{"tag":"num","attrib":{"value":"4615"},"text":"§ 4615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervisory actions applicable to undercapitalized regulated entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2f4823-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f4824-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required monitoring","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2f4825-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" closely monitor the condition of any undercapitalized regulated entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f4826-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" closely monitor compliance with the capital restoration plan, restrictions, and requirements imposed on an undercapitalized regulated entity under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f4827-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically review the plan, restrictions, and requirements applicable to an undercapitalized regulated entity to determine whether the plan, restrictions, and requirements are achieving the purpose of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f4828-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital restoration plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A regulated entity that is classified as undercapitalized shall, within the time period provided in section 4622(b) and (d) of this title, submit to the Director a capital restoration plan that complies with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4622"},"text":"section 4622 of this title","children":[],"tail":" and carry out the plan after approval."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f4829-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on capital distributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A regulated entity that is classified as undercapitalized may not make any capital distribution that would result in the regulated entity being reclassified as significantly undercapitalized or critically undercapitalized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f482a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction of asset growth","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An undercapitalized regulated entity shall not permit its average total assets during any calendar quarter to exceed its average total assets during the preceding calendar quarter, unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2f482b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director has accepted the capital restoration plan of the regulated entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f482c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any increase in total assets is consistent with the capital restoration plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f482d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ratio of tangible equity to assets of the regulated entity increases during the calendar quarter at a rate sufficient to enable the regulated entity to become adequately capitalized within a reasonable time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f482e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior approval of acquisitions and new activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An undercapitalized regulated entity shall not, directly or indirectly, acquire any interest in any entity or engage in any new activity, unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2f482f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director has accepted the capital restoration plan of the regulated entity, the regulated entity is implementing the plan, and the Director determines that the proposed action is consistent with and will further the achievement of the plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2f4830-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director determines that the proposed action will further the purpose of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f4831-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reclassification from undercapitalized to significantly undercapitalized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall reclassify as significantly undercapitalized a regulated entity that is classified as undercapitalized (and the regulated entity shall be subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4616"},"text":"section 4616 of this title","children":[],"tail":") if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2f4832-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regulated entity does not submit a capital restoration plan that is substantially in compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4622"},"text":"section 4622 of this title","children":[],"tail":" within the applicable period or the Director does not approve the capital restoration plan submitted by the regulated entity; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2f4833-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director determines that the regulated entity has failed to comply with the capital restoration plan and fulfill the schedule for the plan approved by the Director in any material respect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2f4834-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4615/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other discretionary safeguards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may take, with respect to an undercapitalized regulated entity, any of the actions authorized to be taken under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4616"},"text":"section 4616 of this title","children":[],"tail":" with respect to a significantly undercapitalized regulated entity, if the Director determines that such actions are necessary to carry out the purpose of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2f4835-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1365"},"text":"Pub. L. 102–550, title XIII, § 1365","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3978"},"text":"106 Stat. 3978","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1143"},"text":"Pub. L. 110–289, div. A, title I, § 1143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2732"},"text":"122 Stat. 2732","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2f4836-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2f4837-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2f4838-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1143/4/B"},"text":"Pub. L. 110–289, § 1143(4)(B)","children":[],"tail":", added par. (1). Former par. (1) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1143/2"},"text":"Pub. L. 110–289, § 1143(2)","children":[],"tail":", substituted “A regulated entity” for “An enterprise”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1143/4/A"},"text":"Pub. L. 110–289, § 1143(4)(A)","children":[],"tail":", redesignated par. (1) as (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1143/1"},"text":"Pub. L. 110–289, § 1143(1)","children":[],"tail":", (2), substituted “the regulated entity” for “the enterprise” and “A regulated entity” for “An enterprise”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1143/4/A"},"text":"Pub. L. 110–289, § 1143(4)(A)","children":[],"tail":", redesignated par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1143/4/C"},"text":"Pub. L. 110–289, § 1143(4)(C)","children":[],"tail":", added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1143/5/A"},"text":"Pub. L. 110–289, § 1143(5)(A)","children":[],"tail":", (B), substituted “Reclassification” for “Discretionary reclassification” in heading and “shall” for “may” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1143/1"},"text":"Pub. L. 110–289, § 1143(1)","children":[],"tail":", (3), substituted “a regulated entity” for “an enterprise” and “the regulated entity” for “the enterprise” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1143/1"},"text":"Pub. L. 110–289, § 1143(1)","children":[],"tail":", substituted “the regulated entity” for “the enterprise” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1143/5/C"},"text":"Pub. L. 110–289, § 1143(5)(C)","children":[],"tail":", struck out “make, in good faith, reasonable efforts necessary to” before “comply with” and inserted “in any material respect” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1143/1"},"text":"Pub. L. 110–289, § 1143(1)","children":[],"tail":", substituted “the regulated entity” for “the enterprise”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1143/6"},"text":"Pub. L. 110–289, § 1143(6)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c). Prior to amendment, text read as follows: “This section shall take effect upon the expiration of the 1-year period beginning on the date of the effectiveness of the regulations issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4611/e"},"text":"section 4611(e) of this title","children":[],"tail":" establishing the risk-based capital test.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
