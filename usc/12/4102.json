{"tag":"section","attrib":{"id":"iddd1779cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4102"},"text":null,"children":[{"tag":"num","attrib":{"value":"4102"},"text":"§ 4102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of intent","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1779cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing with Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An owner of eligible low-income housing that intends to terminate the low-income affordability restrictions through prepayment or voluntary termination in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4108"},"text":"section 4108 of this title","children":[],"tail":", extend the low-income affordability restrictions of the housing in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4109"},"text":"section 4109 of this title","children":[],"tail":", or transfer the housing to a qualified purchaser in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4110"},"text":"section 4110 of this title","children":[],"tail":", shall file with the Secretary a notice indicating such intent in the form and manner as the Secretary shall prescribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1779cd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing with State or local government, tenants, and mortgagee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The owner, upon filing a notice of intent under this section, shall simultaneously file the notice of intent with the chief executive officer of the appropriate State or local government for the jurisdiction within which the housing is located and with the mortgagee, and shall inform the tenants of the housing of the filing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1779ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility for filing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An owner shall not be eligible to file a notice of intent under this section if the mortgage covering the housing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1779cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" falls into default on or after ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1779d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1779d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4102/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fell into default before, but is current as of, ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1779d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4102/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner does not agree to recompense the appropriate Insurance Fund, in the amount the Secretary determines appropriate, for any losses sustained by the Fund as a result of any work-out or other arrangement agreed to by the Secretary and the owner with respect to the defaulted mortgage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary shall carry out this subsection in a manner consistent with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701z–11"},"text":"section 1701z–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1779d3-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/tII/s212"},"text":"Pub. L. 100–242, title II, § 212","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVI/s601/a"},"text":"Pub. L. 101–625, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4249"},"text":"104 Stat. 4249","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
