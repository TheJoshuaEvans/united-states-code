{"tag":"section","attrib":{"id":"iddd0ddd5a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3715"},"text":null,"children":[{"tag":"num","attrib":{"value":"3715"},"text":"§ 3715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of time","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Periods of time provided for in this chapter shall be calculated in consecutive calendar days including the day or days on which the actions or events occur or are to occur for which the period of time is provided and including the day on which an event occurs or is to occur from which the period is to be calculated.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd0ddd5b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s369G"},"text":"Pub. L. 97–35, title III, § 369G","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/431"},"text":"95 Stat. 431","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
