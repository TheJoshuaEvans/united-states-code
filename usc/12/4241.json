{"tag":"section","attrib":{"id":"iddd1e7f77-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4241"},"text":null,"children":[{"tag":"num","attrib":{"value":"4241"},"text":"§ 4241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to enter into contracts for private counsel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1e7f78-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4241/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may enter into contracts retaining private counsel to furnish legal services, including representation in investigation, negotiation, compromise, settlement, litigation, and execution of judgments in the case of any civil action referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4201"},"text":"section 4201 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4225"},"text":"section 4225 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7f79-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4241/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each contract under subsection (a) shall include the provisions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4244"},"text":"section 4244 of this title","children":[],"tail":" and such other terms and conditions as the Attorney General considers necessary and appropriate to protect the interests of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7f7a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4241/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the contingency fee payable for legal services furnished under a contract described in subsection (a) shall not exceed the contingency fee that counsel engaged in the private practice of law in the jurisdiction wherein the legal services are furnished typically charge clients for furnishing the same or comparable legal services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7f7b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4241/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contingent fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302/b"},"text":"section 3302(b) of title 31","children":[],"tail":", a contract under this section shall provide that a fee that the United States pays private counsel for services is payable from the amount recovered and shall be based on a percentage of the civil penalties or assets recovered."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1e7f7c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2588"},"text":"Pub. L. 101–647, title XXV, § 2588","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4905"},"text":"104 Stat. 4905","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
