{"tag":"section","attrib":{"id":"iddcf39e40-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2606"},"text":null,"children":[{"tag":"num","attrib":{"value":"2606"},"text":"§ 2606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempted transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf39e41-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2606/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter does not apply to credit transactions involving extensions of credit—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf39e42-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2606/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primarily for business, commercial, or agricultural purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf39e43-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2606/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to government or governmental agencies or instrumentalities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf39e44-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2606/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpretation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In prescribing regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2617/a"},"text":"section 2617(a) of this title","children":[],"tail