{"tag":"section","attrib":{"id":"iddd0467fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3334"},"text":null,"children":[{"tag":"num","attrib":{"value":"3334"},"text":"§ 3334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers and staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Chairperson of the Appraisal Subcommittee shall appoint such officers and staff as may be necessary to carry out the functions of this chapter consistent with the appointment and compensation practices of the Council.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd0467ff-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tXI/s1105"},"text":"Pub. L. 101–73, title XI, § 1105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/512"},"text":"103 Stat. 512","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
