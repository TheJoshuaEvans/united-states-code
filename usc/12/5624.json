{"tag":"section","attrib":{"id":"iddd7b93b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5624"},"text":null,"children":[{"tag":"num","attrib":{"value":"5624"},"text":"§ 5624.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-cost alternatives to small dollar loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd7b93b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5624/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish multiyear demonstration programs by means of grants, cooperative agreements, financial agency agreements, and similar contracts or undertakings, with eligible entities to provide low-cost, small loans to consumers that will provide alternatives to more costly small dollar loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7b93b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5624/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7b93b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5624/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Loans under this section shall be made on terms and conditions, and pursuant to lending practices, that are reasonable for consumers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7b93b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5624/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial literacy and education opportunities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7b93b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5624/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity awarded a grant under this section shall promote and take appropriate steps to ensure the provision of financial literacy and education opportunities, such as relevant counseling services, educational courses, or wealth building programs, to each consumer provided with a loan pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7b93b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5624/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to expand access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the grants, agreements, and undertakings established under this section, the Secretary may implement reasonable measures or programs designed to expand access to financial literacy and education opportunities, including relevant counseling services, educational courses, or wealth building programs to be provided to individuals who obtain loans from eligible entities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd7b93b8-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXII/s1205"},"text":"Pub. L. 111–203, title XII, § 1205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2130"},"text":"124 Stat. 2130","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
