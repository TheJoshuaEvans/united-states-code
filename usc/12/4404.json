{"tag":"section","attrib":{"id":"iddd20ef9d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4404"},"text":null,"children":[{"tag":"num","attrib":{"value":"4404"},"text":"§ 4404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clearing organization netting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd20ef9e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of State or Federal law (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1821/e"},"text":"section 1821(e) of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1787/c"},"text":"section 1787(c) of this title","children":[],"tail":", and any order authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78eee/b/2"},"text":"section 78eee(b)(2) of title 15","children":[],"tail":"), the covered contractual payment obligations and the covered contractual payment entitlements of a member of a clearing organization to and from all other members of a clearing organization shall be terminated, liquidated, accelerated, and netted in accordance with and subject to the conditions of any applicable netting contract (except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s561/b/2"},"text":"section 561(b)(2) of title 11","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd20ef9f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of obligation to make payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The only obligation, if any, of a member of a clearing organization to make payment with respect to covered contractual payment obligations arising under a single netting contract to any other member of a clearing organization shall be equal to its net obligation arising under that netting contract, and no such obligation shall exist if there is no net obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd20efa0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on right to receive payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The only right, if any, of a member of a clearing organization to receive payment with respect to a covered contractual payment entitlement arising under a single netting contract from other members of a clearing organization shall be equal to its net entitlement arising under that netting contract, and no such right shall exist if there is no net entitlement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd20efa1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4404/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entitlement of failed members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The net entitlement, if any, of any failed member of a clearing organization shall be paid to the failed member in accordance with, and subject to the conditions of, the applicable netting contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd20efa2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4404/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligations of failed members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The net obligation, if any, of any failed member of a clearing organization shall be determined in accordance with, and subject to the conditions of, the applicable netting contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd20efa3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4404/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on claims for entitlement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A failed member of a clearing organization shall have no recognizable claim against any member of a clearing organization for any amount based on such covered contractual payment entitlements other than its net entitlement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd20efa4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4404/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectiveness notwithstanding status as member","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be given effect notwithstanding that a member is a failed member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd20efa5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4404/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforceability of security agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of any security agreement or arrangement or other credit enhancement related to one or more netting contracts between any 2 members of a clearing organization shall be enforceable in accordance with their terms (except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s561/b/2"},"text":"section 561(b)(2) of title 11","children":[],"tail":"), and shall not be stayed, avoided, or otherwise limited by any State or Federal law (other than "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1821/e"},"text":"section 1821(e) of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1787/c"},"text":"section 1787(c) of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78eee/b/2"},"text":"section 78eee(b)(2) of title 15","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd20efa6-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIV/s404"},"text":"Pub. L. 102–242, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2374"},"text":"105 Stat. 2374","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tIX/s906/c"},"text":"Pub. L. 109–8, title IX, § 906(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/168"},"text":"119 Stat. 168","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/390/s4/b"},"text":"Pub. L. 109–390, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-12"},"text":"Dec. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2695"},"text":"120 Stat. 2695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd20efa7-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd20efa8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd20efa9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/390"},"text":"Pub. L. 109–390","children":[],"tail":" struck out “paragraphs (8)(E), (8)(F), and (10)(B) of” before “section 1821(e)” and “section 1787(c)” and inserted “terminated, liquidated, accelerated, and” after “organization shall be”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/390/s4/b/1"},"text":"Pub. L. 109–390, § 4(b)(1)","children":[],"tail":", struck out “paragraphs (8)(E), (8)(F), and (10)(B) of” before “section 1821(e)” and “section 1787(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s906/c/1"},"text":"Pub. L. 109–8, § 906(c)(1)","children":[],"tail":", added subsec. (a) and struck out heading and text of former subsec. (a). Text read as follows: “Notwithstanding any other provision of law, the covered contractual payment obligations and covered contractual payment entitlements of a member of a clearing organization to and from all other members of a clearing organization shall be netted in accordance with and subject to the conditions of any applicable netting contract.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/s906/c/2"},"text":"Pub. L. 109–8, § 906(c)(2)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd20efaa-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd20efab-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/390"},"text":"Pub. L. 109–390","children":[],"tail":" not applicable to any cases commenced under Title 11, Bankruptcy, or to appointments made under any Federal or State law, before "},{"tag":"date","attrib":{"date":"2006-12-12"},"text":"Dec. 12, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/390/s7"},"text":"section 7 of Pub. L. 109–390","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd20efac-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under Title 11, Bankruptcy, before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
