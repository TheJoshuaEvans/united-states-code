{"tag":"section","attrib":{"id":"iddb24f8be-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s228"},"text":null,"children":[{"tag":"num","attrib":{"value":"228"},"text":"§ 228.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Banking Act of 1935”","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-23/ch614"},"text":"act of August 23, 1935, ch. 614","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/684"},"text":"49 Stat. 684","children":[],"tail":", may be cited as the “Banking Act of 1935.”"}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb24f8bf-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-23/ch614/s1"},"text":"Aug. 23, 1935, ch. 614, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/684"},"text":"49 Stat. 684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb24f8c0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb24f8c1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb24f8c2-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Banking Act of 1935, referred to in text, is classified to sections 2, 24, 33 to 34c, 35, 36, 51, 51a, 51b–1, 52, 59 to 61, 64a, 71a, 78, 84, 85, 170, 181, 192, 221a, 228, 241, 242, 244, 247a, 248, 263, 287, 288, 321, 324, 336, 341, 343, 347b, 352a, 355, 357, 371, 371b, 371c, 375a, 377, 378, 461, 462a–1, 462b, 465, 481, 482, 486, 619, 1702, 1703, 1709, and 1713 of this title; ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy; "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s19"},"text":"section 19 of Title 15","children":[],"tail":", Commerce and Trade. See, also, sections 217, 218, 334, 655, 656, 709, 1005, 1906, 1909, and 2113 of Title 18, Crimes and Criminal Procedure. For complete classification of this Act to the Code see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb24f8c3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"iddb24f8c4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-23/ch614/tIII/s346"},"text":"Act Aug. 23, 1935, ch. 614, title III, § 346","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/723"},"text":"49 Stat. 723","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1935-08-23/ch614/tIII/s346"},"text":"“If any provision of this Act, or the application thereof to any person or circumstances, is held invalid, the remainder of the Act, and the application of such provision to other persons and circumstances, shall not be affected thereby.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
