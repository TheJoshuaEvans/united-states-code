{"tag":"section","attrib":{"id":"iddd3fe9c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4803"},"text":null,"children":[{"tag":"num","attrib":{"value":"4803"},"text":"§ 4803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Streamlining of regulatory requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3fe9c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of regulations; regulatory uniformity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the 2-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1994-09-23"},"text":"September 23, 1994","children":[],"tail":", each Federal banking agency shall, consistent with the principles of safety and soundness, statutory law and policy, and the public interest—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fe9c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct a review of the regulations and written policies of that agency to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3fe9c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4803/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" streamline and modify those regulations and policies in order to improve efficiency, reduce unnecessary costs, and eliminate unwarranted constraints on credit availability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fe9ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4803/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remove inconsistencies and outmoded and duplicative requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fe9cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4803/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to regulations prescribed pursuant to section 1828(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of this title, consider the impact that such standards have on the availability of credit for small business, residential, and agricultural purposes, and on low- and moderate-income communities;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fe9cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the extent to which existing regulations require insured depository institutions and insured credit unions to produce unnecessary internal written policies and eliminate such requirements, where appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fe9cd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4803/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work jointly with the other Federal banking agencies to make uniform all regulations and guidelines implementing common statutory or supervisory policies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fe9ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4803/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a joint report to the Congress at the end of such 2-year period detailing the progress of the agencies in carrying out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fe9cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of disclosures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Governors of the Federal Reserve System, in consultation with the consumer advisory council to such Board, consumers, representatives of consumers, lenders, and other interested persons, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fe9d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4803/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the regulations and written policies of the Board with respect to disclosures pursuant to the Truth in Lending Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"15 U.S.C. 1601","children":[],"tail":" et seq.] with regard to variable-rate mortgages in order to simplify the disclosures, if necessary, and make the disclosures more meaningful and comprehensible to consumers;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fe9d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4803/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement any necessary regulatory changes, consistent with applicable law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fe9d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4803/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 2 years after completion of the review required by paragraph (1), submit a report to the Congress on the results of its actions taken in accordance with this subsection and any recommended legislative actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3fe9d3-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s303"},"text":"Pub. L. 103–325, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2215"},"text":"108 Stat. 2215","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2242"},"text":"Pub. L. 104–208, div. A, title II, § 2242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-418"},"text":"110 Stat. 3009–418","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3fe9d4-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd3fe9d5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd3fe9d6-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Truth in Lending Act, referred to in subsec. (b)(1), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321"},"text":"Pub. L. 90–321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/146"},"text":"82 Stat. 146","children":[],"tail":", which is classified generally to subchapter I (§ 1601 et seq.) of chapter 41 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd3fe9d7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" added par. (2) and redesignated former pars. (2) and (3) as (3) and (4), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd3fe9d8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd3fe9d9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Update on Review of Regulations and Paperwork Reductions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/219/tIV/s402"},"text":"Pub. L. 105–219, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/935"},"text":"112 Stat. 935","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/219/tIV/s402"},"text":"“Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":"], the Federal banking agencies [see "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/z"},"text":"12 U.S.C. 1813(z)","children":[],"tail":"] shall submit a report to the Congress detailing their progress in carrying out section 303(a) of the Riegle Community Development and Regulatory Improvement Act of 1994 ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4803/a"},"text":"12 U.S.C. 4803(a)","children":[],"tail":"], since their submission of the report dated "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"September 23, 1996","children":[],"tail":", as required by section 303(a)(4) of that Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
