{"tag":"section","attrib":{"id":"iddd1e7fd6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4305"},"text":null,"children":[{"tag":"num","attrib":{"value":"4305"},"text":"§ 4305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of schedules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1e7fd7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A schedule required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4303"},"text":"section 4303 of this title","children":[],"tail":" for an appropriate account shall be—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7fd8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made available to any person upon request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fd9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided to any potential customer before an account is opened or a service is rendered; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fda-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4305/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided to the depositor, in the case of any time deposit which has a maturity of more than 30 days ","children":[{"tag":"ref","attrib":{"idref":"fn002392"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002392"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “and”."}],"tail":" is renewable at maturity without notice from the depositor, at least 30 days before the date of maturity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7fdb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution in case of certain initial deposits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7fdc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a depositor is not physically present at an office of a depository institution at the time an initial deposit is accepted with respect to an account established by or for such person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fdd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the schedule required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4303/a"},"text":"section 4303(a) of this title","children":[],"tail":" has not been furnished previously to such depositor,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the depository institution shall mail the schedule to the depositor at the address shown on the records of the depository institution for such account no later than 10 days after the date of the initial deposit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7fde-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of notice of certain changes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7fdf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4305/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any change is made in any term or condition which is required to be disclosed in the schedule required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4303/a"},"text":"section 4303(a) of this title","children":[],"tail":" with respect to any account; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fe0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4305/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the change may reduce the yield or adversely affect any holder of the account,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"all account holders who may be affected by such change shall be notified and provided with a description of the change by mail at least 30 days before the change takes effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7fe1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4305/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution in case of accounts established by more than 1 individual or by a group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an account is established by more than 1 individual or for a person other than an individual, any distribution described in this section with respect to such account meets the requirements of this section if the distribution is made to 1 of the individuals who established the account or 1 individual representative of the person on whose behalf such account was established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7fe2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4305/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to account holders as of effective date of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any account for which the depository institution delivers an account statement on a quarterly or more frequent basis, the depository institution shall include on or with the first regularly scheduled mailing sent after the end of the 6-month period beginning on the date of publication of regulations issued by the Bureau in final form, a statement that the account holder has the right to request an account schedule containing the terms, charges, and interest rates of the account, and that the account holder may wish to request such an account schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1e7fe3-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s266"},"text":"Pub. L. 102–242, title II, § 266","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2337"},"text":"105 Stat. 2337","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXVI/s1604/e/1"},"text":"Pub. L. 102–550, title XVI, § 1604(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4084"},"text":"106 Stat. 4084","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2604/d"},"text":"Pub. L. 104–208, div. A, title II, § 2604(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-471"},"text":"110 Stat. 3009–471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100B/1"},"text":"Pub. L. 111–203, title X, § 1100B(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2109"},"text":"124 Stat. 2109","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1e7fe4-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1e7fe5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd1e7fe6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Bureau” for “Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" inserted “has a maturity of more than 30 days” after “deposit which”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" substituted “on or with the first regularly scheduled mailing sent after the end of the 6-month period beginning on the date of publication” for “on or with any regularly scheduled mailing posted or delivered within 180 days after publication”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd1e7fe7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd1e7fe8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd1e7fe9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" effective as if included in the Federal Deposit Insurance Corporation Improvement Act of 1991, "},{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":", as of "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1609/a"},"text":"section 1609(a) of Pub. L. 102–550","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s191"},"text":"section 191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
