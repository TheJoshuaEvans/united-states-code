{"tag":"section","attrib":{"id":"iddc21cfef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1723i"},"text":"§ 1723i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil money penalties against issuers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc21cff0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc21cff1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever an issuer or custodian approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1721/g"},"text":"section 1721(g) of this title","children":[],"tail":" knowingly and materially violates any provisions of subsection (b), the Secretary of Housing and Urban Development may impose a civil money penalty on the issuer or the custodian in accordance with the provisions of this section. The penalty shall be in addition to any other available civil remedy or any available criminal penalty and may be imposed whether or not the Secretary imposes other administrative sanctions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc21cff2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the penalty, as determined by the Secretary, may not exceed $5,000 for each violation, except that the maximum penalty for all violations by a particular issuer or custodian during any one-year period shall not exceed $1,000,000. Each violation of a provision of subsection (b)(1) shall constitute a separate violation with respect to each pool of mortgages. In the case of a continuing violation, as determined by the Secretary, each day shall constitute a separate violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc243ff3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations for which penalty may be imposed","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc243ff4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The violations by an issuer or a custodian for which the Secretary may impose a civil money penalty under subsection (a) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc243ff5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to make timely payments of principal and interest to holders of securities guaranteed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1721/g"},"text":"section 1721(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc243ff6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to segregate cash flow from pooled mortgages or to deposit either principal and interest funds or escrow funds into special accounts with a depository institution whose accounts are insured by the National Credit Union Administration or by the Federal Deposit Insurance Corporation through the Deposit Insurance Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc243ff7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use of escrow funds for any purpose other than that for which they were received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc243ff8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transfer of servicing for a pool of mortgages to an issuer not approved under this subchapter, unless expressly permitted by statute, regulation, or contract approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc243ff9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to maintain a minimum net worth in accordance with requirements prescribed by the Association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc243ffa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to promptly notify the Association in writing of any changes that materially affect the business status of an issuer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc243ffb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Submission to the Association of false information in connection with any securities guaranteed, or mortgages pooled, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1721/g"},"text":"section 1721(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc243ffc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hiring, or retaining in employment, an officer, director, principal, or employee whose duties involve, directly or indirectly, programs administered by the Association while such person was under suspension or debarment by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc243ffd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Submission to the Association of a false certification either on its own behalf or on behalf of another person or entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc243ffe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to comply with an agreement, certification, or condition of approval set forth on, or applicable to, the application for approval as an issuer of securities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1721/g"},"text":"section 1721(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc243fff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Violation of any provisions of this subchapter or any implementing regulation, handbook, or participant letter issued under authority of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc244000-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before taking action to impose a civil money penalty for a violation under paragraph (1)(G) or paragraph (1)(I), the Secretary shall inform the Attorney General of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc244001-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc244002-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish standards and procedures governing the imposition of civil money penalties under subsection (a). The standards and procedures—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc244003-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for the Secretary to make the determination to impose the penalty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc244004-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for the imposition of a penalty only after an issuer or a custodian has been given notice of, and opportunity for, a hearing on the record; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc244005-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide for review by the Secretary of any determination or order, or interlocutory ruling, arising from a hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc244006-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If no hearing is requested within 15 days of receipt of a notice of opportunity for hearing, the imposition of a penalty shall constitute a final and unappealable determination. If the Secretary reviews the determination or order, the Secretary may affirm, modify, or reverse that determination or order. If the Secretary does not review the determination or order within 90 days of the issuance of the determination or order, the determination or order shall be final.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc244007-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors in determining amount of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the amount of a penalty under subsection (a), consideration shall be given to such factors as the gravity of the offense, any history of prior offenses (including offenses occurring before ","children":[{"tag":"date","attrib":{"date":"1989-12-15"},"text":"December 15, 1989","children":[],"tail":"), ability to pay the penalty, injury to the public, benefits received, deterrence of future violations, and such other factors as the Secretary may determine by regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc244008-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviewability of imposition of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary’s determination or order imposing a penalty under subsection (a) shall not be subject to review, except as provided in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc244009-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review of agency determination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc24400a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After exhausting all administrative remedies established by the Secretary under subsection (c)(1), an issuer or a custodian against which the Secretary has imposed a civil money penalty under subsection (a) may obtain a review of the penalty and such ancillary issues as may be addressed in the notice provided under subsection (c)(1)(A) in the appropriate court of appeals of the United States, by filing in such court, within 20 days after the entry of such order or determination, a written petition praying that the Secretary’s order or determination be modified or be set aside in whole or in part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc24400b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objections not raised in hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A court shall not consider any objection that was not raised in the hearing conducted pursuant to subsection (c)(1) unless a demonstration is made of extraordinary circumstances causing the failure to raise the objection. If any party demonstrates to the satisfaction of the court that additional evidence, which was not presented at such hearing, is material and that there were reasonable grounds for the failure to present such evidence at the hearing, the court shall remand the matter to the Secretary for consideration of such additional evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc24400c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The decisions, findings, and determinations of the Secretary shall be reviewed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s706"},"text":"section 706 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc24400d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order to pay penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the court shall have the power in any such review to order payment of the penalty imposed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc24400e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action to collect penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any issuer or custodian fails to comply with the Secretary’s determination or order imposing a civil money penalty under subsection (a), after the determination or order is no longer subject to review as provided by subsections (c)(1) and (d), the Secretary may request the Attorney General of the United States to bring an action in an appropriate United States district court to obtain a monetary judgment against the issuer or custodian and such other relief as may be available. The monetary judgment may, in the discretion of the court, include any attorneys fees and other expenses incurred by the United States in connection with the action. In an action under this subsection, the validity and appropriateness of the Secretary’s determination or order imposing the penalty shall not be subject to review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc24400f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlement by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may compromise, modify, or remit any civil money penalty which may be, or has been, imposed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc244010-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Knowingly” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “knowingly” means having actual knowledge of or acting with deliberate ignorance of or reckless disregard for the prohibitions under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc244011-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue such regulations as the Secretary deems appropriate to implement this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc244012-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1723i/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall deposit all civil money penalties collected under this section into moneys of the Association pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1722"},"text":"section 1722 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc244013-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"June 27, 1934, ch. 847","children":[],"tail":", title III, § 317, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/235/tI/s110/a"},"text":"Pub. L. 101–235, title I, § 110(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-15"},"text":"Dec. 15, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2011"},"text":"103 Stat. 2011","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2704/d/13/A"},"text":"Pub. L. 104–208, div. A, title II, § 2704(d)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-490"},"text":"110 Stat. 3009–490","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tII/s2102/b"},"text":"Pub. L. 109–171, title II, § 2102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/9"},"text":"120 Stat. 9","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/173/s9/f/1"},"text":"Pub. L. 109–173, § 9(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-15"},"text":"Feb. 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3618"},"text":"119 Stat. 3618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc244014-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc244015-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc244016-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/173"},"text":"Pub. L. 109–173","children":[],"tail":" substituted “Deposit Insurance Fund” for “Bank Insurance Fund for banks or through the Savings Association Insurance Fund for savings associations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171"},"text":"Pub. L. 109–171","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2704/d/13/A"},"text":"Pub. L. 104–208, § 2704(d)(13)(A)","