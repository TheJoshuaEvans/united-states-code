{"tag":"section","attrib":{"id":"iddd556dd6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334"},"text":null,"children":[{"tag":"num","attrib":{"value":"5334"},"text":"§ 5334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd556dd7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556dd8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered agencies” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd556dd9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556dda-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board of Governors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556ddb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Comptroller of the Currency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556ddc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556ddd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556dde-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556ddf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Housing Finance Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556de0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Credit Union Administration Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556de1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other primary financial regulatory agency designated by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556de2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “data asset”, “machine-readable”, “metadata”, and “open license” have the meanings given the terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3502"},"text":"section 3502 of title 44","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556de3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “data standard” means a standard that specifies rules by which data is described and recorded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556de4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556de5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposed rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the heads of the covered agencies shall jointly issue proposed rules for public comment that establish data standards for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd556de6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collections of information reported to each covered agency by financial entities under the jurisdiction of the covered agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556de7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the data collected from covered agencies on behalf of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556de8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the heads of the covered agencies shall jointly promulgate final rules that establish the data standards described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556de9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd556dea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Common identifiers; quality","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The data standards established in the final rules promulgated under subsection (b)(2) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd556deb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include common identifiers for collections of information reported to covered agencies or collected on behalf of the Council, which shall include a common nonproprietary legal entity identifier that is available under an open license for all entities required to report to covered agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556dec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent practicable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd556ded-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" render data fully searchable and machine-readable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd556dee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable high quality data through schemas, with accompanying metadata documented in machine-readable taxonomy or ontology models, which clearly define the semantic meaning of the data, as defined by the underlying regulatory information collection requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd556def-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that a data element or data asset that exists to satisfy an underlying regulatory information collection requirement be consistently identified as such in associated machine-readable metadata;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd556df0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be nonproprietary or made available under an open license;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd556df1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate standards developed and maintained by voluntary consensus standards bodies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd556df2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/c/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use, be consistent with, and implement applicable accounting and reporting principles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd556df3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation; interoperability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing data standards in the final rules promulgated under subsection (b)(2), the heads of the covered agencies shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd556df4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with other Federal departments and agencies and multi-agency initiatives responsible for Federal data standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd556df5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to promote interoperability of financial regulatory data across members of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd556df6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5334/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The data standards established in the final rules promulgated under subsection (b)(2) shall take effect not later than 2 years after the date on which those final rules are promulgated under that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd556df7-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tI/s124"},"text":"Pub. L. 111–203, title I, § 124","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5811/a"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5811(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3422"},"text":"136 Stat. 3422","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd556df8-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd556df9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd556dfa-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rules of Construction Applicable to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5813"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5813","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3424"},"text":"136 Stat. 3424","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLVIII/s5813"},"text":"“Nothing in this subtitle [subtitle A (§§ 5811–5813) of title LVIII of div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", enacting this section, "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5335"},"text":"section 5335 of this title","children":[],"tail":", and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5335"},"text":"section 5335 of this title","children":[],"tail":"], or the amendments made by this subtitle, shall be construed to require the Secretary of the Treasury to collect or make publicly available additional information under the Financial Stability Act of 2010 ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5311"},"text":"12 U.S.C. 5311","children":[],"tail":" et seq.), beyond information that was collected or made publicly available under that Act, as of the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5891"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5891","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3438"},"text":"136 Stat. 3438","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLVIII/s5891"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Effect on Intellectual Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this title [see Short Title of 2022 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"section 78a of Title 15","children":[],"tail":", Commerce and Trade], or the amendments made by this title, may be construed to alter the legal protections, as in effect on the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], of copyrighted material or other intellectual property rights of any non-Federal person."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Effect on Monetary Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this title, or the amendments made by this title, may be construed to apply to activities conducted, or data standards used, in connection with monetary policy proposed or implemented by the Board of Governors of the Federal Reserve System or the Federal Open Market Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preservation of Agency Authority To Tailor Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this title, or the amendments made by this title, may be construed to prohibit the head of a covered agency, as defined in section 124(a) of the Financial Stability Act of 2010 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5334/a"},"text":"12 U.S.C. 5334(a)","children":[],"tail":"], as added by "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5811/a"},"text":"section 5811(a) of this title","children":[],"tail":", from tailoring those standards when those standards are adopted under this title and the amendments made by this title.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5892"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5892","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3438"},"text":"136 Stat. 3438","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLVIII/s5892"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this title [see Short Title of 2022 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"section 78a of Title 15","children":[],"tail":", Commerce and Trade], or the amendments made by this title, shall require the disclosure to the public of—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information that would be exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":", United States Code (commonly known as the ‘Freedom of Information Act’); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information protected under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":", United States Code (commonly known as the ‘Privacy Act of 1974’);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 6103 of the Internal Revenue Code of 1986 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6103"},"text":"26 U.S.C. 6103","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any law administered, or regulation promulgated, by the Financial Crimes Enforcement Network of the Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existing Agency Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this title, or the amendments made by this title, shall be construed to require the Secretary of the Treasury, the Securities and Exchange Commission, the Federal Deposit Insurance Corporation, the Comptroller of the Currency, the Director of the Bureau of Consumer Financial Protection, the Board of Governors of the Federal Reserve System, the National Credit Union Administration Board, the Director of the Federal Housing Finance Agency, or the head of any other primary financial regulatory agency (as defined in section 2 of the Dodd-Frank Wall Street Reform and Consumer Protection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"12 U.S.C. 5301","children":[],"tail":")) designated by the Secretary of the Treasury to amend regulations and procedures, as in effect on the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], regarding the sharing and disclosure of nonpublic information, including confidential supervisory information."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data Privacy and Personally Identifiable Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this title, or the amendments made by this title, shall be construed to require the Secretary of the Treasury, the Securities and Exchange Commission, the Federal Deposit Insurance Corporation, the Comptroller of the Currency, the Director of the Bureau of Consumer Financial Protection, the Board of Governors of the Federal Reserve System, the National Credit Union Administration Board, the Director of the Federal Housing Finance Agency, or the head of any other primary financial regulatory agency (as defined in section 2 of the Dodd-Frank Wall Street Reform and Consumer Protection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"12 U.S.C. 5301","children":[],"tail":")) designated by the Secretary of the Treasury to disclose to the public any information that can be used to distinguish or trace the identity of an individual, either alone or when combined with other personal or identifying information that is linked or linkable to a specific individual.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
