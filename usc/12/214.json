{"tag":"section","attrib":{"id":"iddb203db7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s214"},"text":null,"children":[{"tag":"num","attrib":{"value":"214"},"text":"§ 214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb203db8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s214/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this subchapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s321"},"text":"section 321 of this title","children":[],"tail":" the term “State bank” means any bank, banking association, trust company, savings bank (other than a mutual savings bank), or other banking institution which is engaged in the business of receiving deposits and which is incorporated under the laws of any State, any Territory of the United States, Puerto Rico, or the Virgin Islands, or which is operating under the Code of Law for the District of Columbia."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb203db9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s214/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of merger or consolidation under this subchapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s321"},"text":"section 321 of this title","children":[],"tail":" the term “national banking association” means one or more national banking associations, and the term “State bank” means one or more State banks."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb203dba-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-17/ch729/s1"},"text":"Aug. 17, 1950, ch. 729, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/455"},"text":"64 Stat. 455","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s24"},"text":"Sept. 3, 1954, ch. 1263, § 24","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1234"},"text":"68 Stat. 1234","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tVII/s725/f"},"text":"Pub. L. 109–351, title VII, § 725(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2002"},"text":"120 Stat. 2002","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/356/tI/s123/f"},"text":"Pub. L. 109–356, title I, § 123(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-16"},"text":"Oct. 16, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2029"},"text":"120 Stat. 2029","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb203dbb-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb203dbc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb203dbd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351"},"text":"Pub. L. 109–351","children":[],"tail":" and 109–356 amended subsec. (a) identically, striking out “(except a national banking association)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-09-03"},"text":"Sept. 3, 1954","children":[],"tail":", substituted “this subchapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s321"},"text":"section 321 of this title","children":[],"tail":"” for “sections 214 to 214c, 264(e)(2), (i)(2), (v)(4), and 321 of this title” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb203dbe-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"iddb203dbf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-17/ch729/s9"},"text":"Act Aug. 17, 1950, ch. 729, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/458"},"text":"64 Stat. 458","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1950-08-17/ch729/s9"},"text":"“If any provision of this Act [enacting this subchapter and amending of sections 264 and 321 of this title], or the application thereof to any person or circumstance, is held invalid, the remainder of the Act and the application of such provision to other persons or circumstances shall not be affected thereby.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
