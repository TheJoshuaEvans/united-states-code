{"tag":"section","attrib":{"id":"iddc43399b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1765"},"text":null,"children":[{"tag":"num","attrib":{"value":"1765"},"text":"§ 1765.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minors","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Shares may be issued in the name of a minor or in trust, subject to such conditions as may be prescribed by the bylaws. When shares are issued in trust, the name of the beneficiary shall be disclosed to the Federal credit union.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc43399c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title I, § 119, formerly § 15, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1221"},"text":"48 Stat. 1221","children":[],"tail":"; renumbered § 20, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/354/s1"},"text":"Pub. L. 86–354, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-22"},"text":"Sept. 22, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/634"},"text":"73 Stat. 634","children":[],"tail":"; renumbered title I, § 119, "},{"tag":"ref","attrib":{"href":"/us/pl/91/468/s1/2"},"text":"Pub. L. 91–468, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-19"},"text":"Oct. 19, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/994"},"text":"84 Stat. 994","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc43399d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc43399e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc43399f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/354"},"text":"Pub. L. 86–354","children":[],"tail":" substituted “When shares are issued in trust, the” for “The” in second sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
