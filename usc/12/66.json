{"tag":"section","attrib":{"id":"iddb11e61d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s66"},"text":null,"children":[{"tag":"num","attrib":{"value":"66"},"text":"§ 66.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal liability of representatives of stockholders","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Persons holding stock as executors, administrators, guardians, or trustees, shall not be personally subject to any liabilities as stockholders; but the estates and funds in their hands shall be liable in like manner and to the same extent as the testator, intestate, ward, or person interested in such trust funds would be, if living and competent to act and hold the stock in his own name.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb11e61e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 5152.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb11e61f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb11e620-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb11e621-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5152 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-03/ch106/s63"},"text":"act June 3, 1864, ch. 106, § 63","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/118"},"text":"13 Stat. 118","children":[],"tail":", which was the National Bank Act. See "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
