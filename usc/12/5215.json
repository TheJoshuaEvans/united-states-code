{"tag":"section","attrib":{"id":"iddd49865a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215"},"text":null,"children":[{"tag":"num","attrib":{"value":"5215"},"text":"§ 5215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd49865b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before the expiration of the 60-day period beginning on the date of the first exercise of the authority granted in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5211/a"},"text":"section 5211(a) of this title","children":[],"tail":", or of the first exercise of the authority granted in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5212"},"text":"section 5212 of this title","children":[],"tail":", whichever occurs first, and every 30-day period thereafter, the Secretary shall report to the appropriate committees of Congress, with respect to each such period—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd49865c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an overview of actions taken by the Secretary, including the considerations required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5213"},"text":"section 5213 of this title","children":[],"tail":" and the efforts under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5219"},"text":"section 5219 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd49865d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual obligation and expenditure of the funds provided for administrative expenses by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5228"},"text":"section 5228 of this title","children":[],"tail":" during such period and the expected expenditure of such funds in the subsequent period; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd49865e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a detailed financial statement with respect to the exercise of authority under this chapter, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd49865f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all agreements made or renewed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd498660-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all insurance contracts entered into pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5212"},"text":"section 5212 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd498661-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all transactions occurring during such period, including the types of parties involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd498662-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the assets purchased;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd498663-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all projected costs and liabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd498664-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operating expenses, including compensation for financial agents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd498665-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the valuation or pricing method used for each transaction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd498666-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the vehicles established to exercise such authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd498667-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tranche reports to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd498668-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide to the appropriate committees of Congress, at the times specified in paragraph (2), a written report, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd498669-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of all of the transactions made during the reporting period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd49866a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the pricing mechanism for the transactions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd49866b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a justification of the price paid for and other financial terms associated with the transactions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd49866c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the impact of the exercise of such authority on the financial system, supported, to the extent possible, by specific data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd49866d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of challenges that remain in the financial system, including any benchmarks yet to be achieved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd49866e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of additional actions under the authority provided under this chapter that may be necessary to address such challenges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd49866f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required by this subsection shall be submitted not later than 7 days after the date on which commitments to purchase troubled assets under the authorities provided in this chapter first reach an aggregate of $50,000,000,000 and not later than 7 days after each $50,000,000,000 interval of such commitments is reached thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd498670-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory modernization report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall review the current state of the financial markets and the regulatory system and submit a written report to the appropriate committees of Congress not later than ","children":[{"tag":"date","attrib":{"date":"2009-04-30"},"text":"April 30, 2009","children":[],"tail":", analyzing the current state of the regulatory system and its effectiveness at overseeing the participants in the financial markets, including the over-the-counter swaps market and government-sponsored enterprises, and providing recommendations for improvement, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd498671-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd498672-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether any participants in the financial markets that are currently outside the regulatory system should become subject to the regulatory system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd498673-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancement of the clearing and settlement of over-the-counter swaps; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd498674-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rationale underlying such recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd498675-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any report required under this section shall also be submitted to the Congressional Oversight Panel established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5233"},"text":"section 5233 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd498676-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The reporting requirements under this section shall terminate on the later of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd498677-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that the last troubled asset acquired by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5211"},"text":"section 5211 of this title","children":[],"tail":" has been sold or transferred out of the ownership or control of the Federal Government; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd498678-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5215/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of expiration of the last insurance contract issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5212"},"text":"section 5212 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd498679-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dA/tI/s105"},"text":"Pub. L. 110–343, div. A, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3771"},"text":"122 Stat. 3771","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd49867a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd49867b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd49867c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(3) and (b)(1)(F), (2), was in the original “this Act” and was translated as reading “this division”, meaning div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343"},"text":"Pub. L. 110–343","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3765"},"text":"122 Stat. 3765","children":[],"tail":", known as the Emergency Economic Stabilization Act of 2008, to reflect the probable intent of Congress. For complete classification of division A to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5201"},"text":"section 5201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
