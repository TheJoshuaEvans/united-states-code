{"tag":"section","attrib":{"id":"iddd3fe9ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806"},"text":null,"children":[{"tag":"num","attrib":{"value":"4806"},"text":"§ 4806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory appeals process, ombudsman, and alternative dispute resolution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd3fea00-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1994-09-23"},"text":"September 23, 1994","children":[],"tail":", each appropriate Federal banking agency and the National Credit Union Administration Board shall establish an independent intra-agency appellate process. The process shall be available to review material supervisory determinations made at insured depository institutions or at insured credit unions that the agency supervises."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fea01-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing the independent appellate process under subsection (a), each agency shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fea02-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any appeal of a material supervisory determination by an insured depository institution or insured credit union is heard and decided expeditiously; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fea03-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate safeguards exist for protecting the appellant from retaliation by agency examiners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fea04-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comment period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1994-09-23"},"text":"September 23, 1994","children":[],"tail":", each appropriate Federal banking agency and the National Credit Union Administration Board shall provide public notice and opportunity for comment on proposed guidelines for the establishment of an appellate process under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fea05-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency ombudsman","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fea06-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1994-09-23"},"text":"September 23, 1994","children":[],"tail":", each Federal banking agency and the National Credit Union Administration Board shall appoint an ombudsman."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fea07-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of ombudsman","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The ombudsman appointed in accordance with paragraph (1) for any agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3fea08-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" act as a liaison between the agency and any affected person with respect to any problem such party may have in dealing with the agency resulting from the regulatory activities of the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fea09-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assure that safeguards exist to encourage complainants to come forward and preserve confidentiality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fea0a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative dispute resolution pilot program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fea0b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1994-09-23"},"text":"September 23, 1994","children":[],"tail":", each Federal banking agency and the National Credit Union Administration Board shall develop and implement a pilot program for using alternative means of dispute resolution of issues in controversy (hereafter in this section referred to as the “alternative dispute resolution program”) that is consistent with the requirements of subchapter IV of chapter 5 of title 5 if the parties to the dispute, including the agency, agree to such proceeding."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fea0c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An alternative dispute resolution pilot program developed under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3fea0d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be fair to all interested parties to a dispute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fea0e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resolve disputes expeditiously; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fea0f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be less costly than traditional means of dispute resolution, including litigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fea10-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after the date on which a pilot program is implemented under paragraph (1), the Administrative Conference of the United States shall submit to the Congress a report containing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3fea11-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of that pilot program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fea12-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the pilot programs meet the standards established under paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fea13-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which parties to disputes were offered alternative means of dispute resolution and the frequency with which the parties, including the agencies, accepted or declined to use such means; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fea14-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations of the Conference to improve the alternative dispute resolution procedures of the Federal banking agencies and the National Credit Union Administration Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fea15-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At any time after completion of the evaluation under paragraph (3)(A), any Federal banking agency and the National Credit Union Administration Board may implement an alternative dispute resolution program throughout the agency, taking into account the results of that evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fea16-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with existing agency ADR programs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3fea17-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any Federal banking agency or the National Credit Union Administration maintains an alternative dispute resolution program as of ","children":[{"tag":"date","attrib":{"date":"1994-09-23"},"text":"September 23, 1994","children":[],"tail":", under any other provision of law, the Administrative Conference of the United States shall include such program in the evaluation conducted under paragraph (3)(A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fea18-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple ADR programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this section shall be construed as precluding any Federal banking agency or the National Credit Union Administration Board from establishing more than 1 alternative means of dispute resolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fea19-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd3fea1a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Material supervisory determinations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “material supervisory determinations”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3fea1b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes determinations relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd3fea1c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examination ratings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd3fea1d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of loan loss reserve provisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd3fea1e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/f/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loan classifications on loans that are significant to an institution; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fea1f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a determination by a Federal banking agency or the National Credit Union Administration Board to appoint a conservator or receiver for an insured depository institution or a liquidating agent for an insured credit union, as the case may be, or a decision to take action pursuant to section 1831","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title or "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1790a"},"text":"section 1790a of this title","children":[],"tail":", as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fea20-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent appellate process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “independent appellate process” means a review by an agency official who does not directly or indirectly report to the agency official who made the material supervisory determination under review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fea21-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative means of dispute resolution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “alternative means of dispute resolution” has the meaning given to such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s571"},"text":"section 571 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd3fea22-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issues in controversy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “issues in controversy” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd3fea23-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any final agency decision involving any claim against an insured depository institution or insured credit union for which the agency has been appointed conservator or receiver or for which a liquidating agent has been appointed, as the case may be;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fea24-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any final action taken by an agency in the agency’s capacity as conservator or receiver for an insured depository institution or by the liquidating agent appointed for an insured credit union; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd3fea25-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other issue for which the appropriate Federal banking agency or the National Credit Union Administration Board determines that alternative means of dispute resolution would be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd3fea26-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4806/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall affect the authority of an appropriate Federal banking agency or the National Credit Union Administration Board to take enforcement or supervisory action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd3fea27-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s309"},"text":"Pub. L. 103–325, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2218"},"text":"108 Stat. 2218","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd3fea28-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd3fea29-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd3fea2a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Administrative Conference of United States","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Administrative Conference of United States, see provision of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/52"},"text":"Pub. L. 104–52","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s591"},"text":"section 591 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
