{"tag":"section","attrib":{"id":"iddd1779e8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104"},"text":null,"children":[{"tag":"num","attrib":{"value":"4104"},"text":"§ 4104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual authorized return and preservation rents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1779e9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual authorized return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to an appraisal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4103"},"text":"section 4103 of this title","children":[],"tail":", the Secretary shall determine the annual authorized return on the appraised housing, which shall be equal to 8 percent of the preservation equity (as such term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4119/8"},"text":"section 4119(8) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1779ea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation rents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall also determine the aggregate preservation rents under this subsection for each project appraised under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4103"},"text":"section 4103 of this title","children":[],"tail":". The aggregate preservation rents shall be used solely for the purposes of comparison with Federal cost limits under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4105"},"text":"section 4105 of this title","children":[],"tail":". Actual rents received by an owner (or a qualified purchaser) shall be determined pursuant to section 4109, 4110, or 4111 of this title. The aggregate preservation rents shall be established as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1779eb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of affordability limits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The aggregate preservation rent for purposes of receiving incentives pursuant to extension of the low-income affordability restrictions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4109"},"text":"section 4109 of this title","children":[],"tail":" shall be the gross potential income for the project, determined by the Secretary, that would be required to support the following costs:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1779ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The annual authorized return determined under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1779ed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Debt service on any rehabilitation loan for the housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1779ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Debt service on the federally-assisted mortgage for the housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1779ef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Project operating expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1779f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adequate reserves.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1779f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The aggregate preservation rent for purposes of receiving incentives pursuant to sale under section 4110 or 4111 of this title shall be the gross income for the project determined by the Secretary, that would be required to support the following costs:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1779f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Debt service on the loan for acquisition of the housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1779f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Debt service on any rehabilitation loan for the housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1779f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Debt service on the federally-assisted mortgage for the housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1779f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Project operating expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1779f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adequate reserves.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1779f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Future financing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Neither this section, nor any plan of action or use agreement implementing this section, shall restrict an owner from obtaining a new loan or refinancing an existing loan secured by the project, or from distributing the proceeds of such a loan; except that, in conjunction with such refinancing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1779f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner shall provide for adequate rehabilitation pursuant to a capital needs assessment to ensure long-term sustainability of the property satisfactory to the lender or bond issuance agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1779f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any resulting budget-based rent increase shall include debt service on the new financing, commercially reasonable debt service coverage, and replacement reserves as required by the lender; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1779fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for tenants of dwelling units not covered by a project- or tenant-based rental subsidy, any rent increases resulting from the refinancing transaction may not exceed 10 percent per year, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1779fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any tenant occupying a dwelling unit as of time of the refinancing may not be required to pay for rent and utilities, for the duration of such tenancy, an amount that exceeds the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd1779fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 percent of the tenant’s income; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1779fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount paid by the tenant for rent and utilities immediately before such refinancing; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1779fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4104/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this paragraph shall not apply to any tenant who does not provide the owner with proof of income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Paragraph (3) may not be construed to limit any rent increases resulting from increased operating costs for a project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1779ff-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/tII/s214"},"text":"Pub. L. 100–242, title II, § 214","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVI/s601/a"},"text":"Pub. L. 101–625, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4251"},"text":"104 Stat. 4251","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dG/tLXXVII/s77002"},"text":"Pub. L. 114–94, div. G, title LXXVII, § 77002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1790"},"text":"129 Stat. 1790","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd177a00-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd177a01-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd177a02-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd177a03-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd177a04-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dG/tLXXVII/s77003"},"text":"Pub. L. 114–94, div. G, title LXXVII, § 77003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1791"},"text":"129 Stat. 1791","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dG/tLXXVII/s77003"},"text":"“The Secretary of Housing and Urban Development shall issue any guidance that the Secretary considers necessary to carry out the provisions added by the amendments made by this title [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4112"},"text":"section 4112 of this title","children":[],"tail":"] not later than the expiration of the 120-day period beginning on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
