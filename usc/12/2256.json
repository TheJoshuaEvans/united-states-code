{"tag":"section","attrib":{"id":"iddccfe9ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2256"},"text":null,"children":[{"tag":"num","attrib":{"value":"2256"},"text":"§ 2256.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent to the availability of reports and to examinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any organization other than State banks, trust companies, and savings associations shall, as a condition precedent to securing discount privileges with a bank of the Farm Credit System, file with such bank its written consent to examination by farm credit examiners as may be directed by the Farm Credit Administration; and State banks, trust companies, and savings associations may be required in like manner to file a written consent that reports of their examination by constituted State authorities may be furnished by such authorities upon the request of the Farm Credit Administration.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddccfe9cb-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".21, formerly § 5.22, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/623"},"text":"85 Stat. 623","children":[],"tail":"; renumbered § 5.21, "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s203/b"},"text":"Pub. L. 99–205, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1694"},"text":"99 Stat. 1694","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddccfe9cc-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddccfe9cd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddccfe9ce-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5.21 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181"},"text":"Pub. L. 92–181","children":[],"tail":" was renumbered section 5.20 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2255"},"text":"section 2255 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
