{"tag":"section","attrib":{"id":"iddb5be70a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635a–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"635a–7"},"text":"§ 635a–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent audit of bank portfolio","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb5be70b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635a–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Export-Import Bank of the United States shall conduct an audit or evaluation of the portfolio risk management procedures of the Bank, including a review of the implementation by the Bank of the duties assigned to the Chief Risk Officer under section 635a(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of this title, as amended by section 51005."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb5be70c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635a–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2015-12-04"},"text":"December 4, 2015","children":[],"tail":", and not less frequently than every 3 years thereafter, the Inspector General shall submit to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives a written report containing all findings and determinations made in carrying out subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb5be70d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dE/tLI/s51007"},"text":"Pub. L. 114–94, div. E, title LI, § 51007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1766"},"text":"129 Stat. 1766","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb5be70e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb5be70f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb5be710-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 635a(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of this title, as amended by section 51005, referred to in subsec. (a), is section 635a("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of this title, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s51005"},"text":"section 51005 of Pub. L. 114–94","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb5be711-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Fixing America’s Surface Transportation Act, also known as the FAST Act, and not as part of the Export-Import Bank Act of 1945 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
