{"tag":"section","attrib":{"id":"iddb631334-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"635i–7"},"text":"§ 635i–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation on export financing programs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Bank shall, subject to appropriate memoranda of understanding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb631335-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–7/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide complete and current information on all of its programs and financing practices to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb631336-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–7/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Small Business Administration and other Federal agencies involved in promoting exports and marketing export financing programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb631337-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–7/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local export financing organizations that indicate a desire to participate in export promotion; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb631338-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635i–7/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4721/f/2"},"text":"section 4721(f)(2) of title 15","children":[],"tail":", undertake a program to provide training for personnel designated in such memoranda with respect to such financing programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb631339-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch341/s13"},"text":"July 31, 1945, ch. 341, § 13","children":[],"tail":", formerly § 19, as added and renumbered § 13, "},{"tag":"ref","attrib":{"href":"/us/pl/102/429/tI"},"text":"Pub. L. 102–429, title I","children":[],"tail":", §§ 115, 121(c)(7), "},{"tag":"date","attrib":{"date":"1992-10-21"},"text":"Oct. 21, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2196"},"text":"106 Stat. 2196","children":[],"tail":", 2199.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb63133a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb63133b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddb63133c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 13 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch341"},"text":"act July 31, 1945, ch. 341","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s635i–1"},"text":"section 635i–1 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/429/s121/c/1"},"text":"Pub. L. 102–429, § 121(c)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}]