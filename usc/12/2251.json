{"tag":"section","attrib":{"id":"iddccd7954-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2251"},"text":null,"children":[{"tag":"num","attrib":{"value":"2251"},"text":"§ 2251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarters and facilities for the Farm Credit Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddccd7955-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2251/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location of principal office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Farm Credit Administration shall maintain its principal office within the Washington D.C.-Maryland-Virginia standard metropolitan statistical area, and such other offices within the United States as in its judgment are necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccd7956-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2251/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternate property authorizations for System banks","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As an alternate to the rental of quarters under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2249"},"text":"section 2249 of this title","children":[],"tail":", and without regard to any other provision of law, the banks of the System, with the concurrence of two-thirds of the bank boards, are hereby authorized—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddccd7957-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2251/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To lease or acquire real property in the District of Columbia or elsewhere for quarters of the Farm Credit Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd7958-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2251/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To construct, develop, furnish, and equip such building thereon and such facilities appurtenant thereto as in their judgment may be appropriate to provide, to the extent the Board may deem advisable, suitable, and adequate quarters and facilities for the Farm Credit Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd7959-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2251/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To enlarge, remodel, or reconstruct the same.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd795a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2251/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To make or enter into contracts for any of the foregoing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd795b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2251/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To sell or otherwise dispose of any interest in property leased or acquired under the foregoing if authorized by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddccd795c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2251/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddccd795d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2251/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may require of the respective banks of the System, and they shall make to the Farm Credit Administration, such advances of funds for the purposes set out in this section as in the sole judgment of the Board may from time to time be advisable for the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd795e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2251/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advances of funds described in paragraph (1) shall be in addition to and kept in a separate fund from the assessments authorized in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2250"},"text":"section 2250 of this title","children":[],"tail":" and shall be apportioned by the Board among the banks in proportion to the total assets of the respective banks, and determined in such manner and at such times as the Board may prescribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd795f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2251/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of banks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The powers of the banks of the System and purposes for which obligations may be issued by such banks are hereby enlarged to include the purpose of obtaining funds to permit the making of advances required by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd7960-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2251/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plans and decisions for such building and facilities and for the enlargement, remodeling, or reconstruction thereof shall be such as is approved in the sole discretion of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddccd7961-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2251/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agent for banks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In actions undertaken by the banks pursuant to this section, the Farm Credit Administration may act as agent for the banks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddccd7962-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".16, formerly § 5.17, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/621"},"text":"85 Stat. 621","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/592/tV/s506"},"text":"Pub. L. 96–592, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3449"},"text":"94 Stat. 3449","children":[],"tail":"; renumbered § 5.16 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s201/6"},"text":"Pub. L. 99–205, title II, § 201(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1690"},"text":"99 Stat. 1690","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVIII/s805/y"},"text":"Pub. L. 100–233, title VIII, § 805(y)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1717"},"text":"101 Stat. 1717","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIX/s901"},"text":"Pub. L. 100–399, title IX, § 901","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1008"},"text":"102 Stat. 1008","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV"},"text":"Pub. L. 115–334, title V","children":[],"tail":", §§ 5405, 5411(28), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4676"},"text":"132 Stat. 4676","children":[],"tail":", 4682.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddccd7963-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddccd7964-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddccd7965-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5.16 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181"},"text":"Pub. L. 92–181","children":[],"tail":" was renumbered section 5.15 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2250"},"text":"section 2250 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddccd7966-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5405"},"text":"Pub. L. 115–334, § 5405","children":[],"tail":", added subsec. (a) and designated existing introductory provisions and pars. (1) to (5) as subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/28"},"text":"Pub. L. 115–334, § 5411(28)","children":[],"tail":", designated existing concluding provisions as subsec. (c) and first to fifth sentences thereof as pars. (1) to (5), respectively, and inserted subsec. and par. headings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/28/D"},"text":"Pub. L. 115–334, § 5411(28)(D)","children":[],"tail":", substituted “The advances of funds described in paragraph (1)” for “Such advances”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/28/A"},"text":"Pub. L. 115–334, § 5411(28)(A)","children":[],"tail":", substituted “In actions undertaken by the banks pursuant to this section” for “In actions undertaken by the banks pursuant to the foregoing provisions of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" substituted “bank boards” for “district boards” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":" transferred undesignated provisions following par. (4) consisting of four sentences relating to advances of funds for purposes set out in this section as in the sole judgment of the Board may from time to time be advisable for purposes of this section, to a position immediately before last sentence of this section which provides for agency status of Administration for the banks."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/205/s201/6/A"},"text":"Pub. L. 99–205, § 201(6)(A)","children":[],"tail":"–(C), made technical amendments to the references to sections 2249 and 2250 of this title in first and third sentences to reflect the renumbering of the corresponding sections of the original act, and struck out “Federal Farm Credit” before “Board” in par. (2) of first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/592"},"text":"Pub. L. 96–592","children":[],"tail":" added par. (5) and provisions respecting agency status of Administration for the banks."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddccd7967-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddccd7968-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective immediately after amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/s401"},"text":"section 401 of Pub. L. 100–233","children":[],"tail":", which was effective 6 months after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/b"},"text":"section 1001(b) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddccd7969-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/205"},"text":"Pub. L. 99–205","children":[],"tail":" effective thirty days after "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/s401"},"text":"section 401 of Pub. L. 99–205","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
