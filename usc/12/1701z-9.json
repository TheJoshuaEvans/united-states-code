{"tag":"section","attrib":{"id":"iddbb68ad6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701z–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"1701z–9"},"text":"§ 1701z–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of home ownership opportunities in urban areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701z–1"},"text":"section 1701z–1 of this title","children":[],"tail":", the Secretary is authorized to conduct demonstrations to determine the feasibility of expanding homeownership opportunities in urban areas and encouraging the creation and maintenance of decent, safe, and sanitary housing in such areas by utilizing techniques including, but not limited to, the conversion of multifamily housing properties to condominium or cooperative ownership by individuals and families."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddbb68ad7-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/609/tV/s510"},"text":"Pub. L. 91–609, title V, § 510","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/557/tIII/s305/b"},"text":"Pub. L. 95–557, title III, § 305(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2097"},"text":"92 Stat. 2097","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddbb68ad8-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddbb68ad9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddbb68ada-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Housing and Urban Development Act of 1970, and not as part of the National Housing Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddbb68adb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddbb68adc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study To Determine Feasibility of Underground Construction of Residential Housing","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/557/tIII/s305/c"},"text":"Pub. L. 95–557, title III, § 305(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2097"},"text":"92 Stat. 2097","children":[],"tail":", required the Secretary to study the feasibility of underground construction of residential housing and necessary changes in housing codes and financing, and report to Congress no later than one year after "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":" as to the findings and recommendations of legislative enactments as a result of the study."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
