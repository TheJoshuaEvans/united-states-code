{"tag":"section","attrib":{"id":"iddb35c223-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s357"},"text":null,"children":[{"tag":"num","attrib":{"value":"357"},"text":"§ 357.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of rates of discount","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every Federal reserve bank shall have power to establish from time to time, subject to review and determination of the Board of Governors of the Federal Reserve System, rates of discount to be charged by the Federal reserve bank for each class of paper, which shall be fixed with a view of accommodating commerce and business, but each such bank shall establish such rates every fourteen days, or oftener if deemed necessary by the Board.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb35c224-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s14/d"},"text":"Dec. 23, 1913, ch. 6, § 14(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/264"},"text":"38 Stat. 264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1920-04-13/ch128"},"text":"Apr. 13, 1920, ch. 128","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/550"},"text":"41 Stat. 550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1923-03-04/ch252"},"text":"Mar. 4, 1923, ch. 252","children":[],"tail":", title IV, § 407, "},{"tag":"ref","attrib":{"href":"/us/stat/42/1480"},"text":"42 Stat. 1480","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-23/ch614"},"text":"Aug. 23, 1935, ch. 614","children":[],"tail":", title II, §§ 203(a), 206(b), "},{"tag":"ref","attrib":{"href":"/us/stat/49/704"},"text":"49 Stat. 704","children":[],"tail":", 706.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb35c225-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb35c226-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb35c227-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsec. (d) of section 14 of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":". For classification to this title of remainder of section 14, see Codification note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s353"},"text":"section 353 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb35c228-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1935—Act ","children":[{"tag":"date","attrib":{"date":"1935-08-23"},"text":"Aug. 23, 1935","children":[],"tail":", § 206(b), inserted words at end of section beginning “but each such”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb35c229-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddb35c22a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 203(a) of act ","children":[{"tag":"date","attrib":{"date":"1935-08-23"},"text":"Aug. 23, 1935","children":[],"tail":", changed name of Federal Reserve Board to Board of Governors of the Federal Reserve System."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
