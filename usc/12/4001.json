{"tag":"section","attrib":{"id":"iddd12985d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001"},"text":null,"children":[{"tag":"num","attrib":{"value":"4001"},"text":"§ 4001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd12985e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “account” means a demand deposit account or other similar transaction account at a depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd12985f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the Board of Governors of the Federal Reserve System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129860-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business day","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “business day” means any day other than a Saturday, Sunday, or legal holiday.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129861-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cash” means United States coins and currency, including Federal Reserve notes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129862-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cashier’s check","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cashier’s check” means any check which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd129863-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is drawn on a depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd129864-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is signed by an officer or employee of such depository institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd129865-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a direct obligation of such depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129866-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified check","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “certified check” means any check with respect to which a depository institution certifies that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd129867-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the signature on the check is genuine; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd129868-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such depository institution has set aside funds which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd129869-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are equal to the amount of the check; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd12986a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be used only to pay such check.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd12986b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Check","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “check” means any negotiable demand draft drawn on or payable through an office of a depository institution located in the United States. Such term does not include noncash items.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd12986c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Check clearinghouse association","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “check clearinghouse association” means any arrangement by which participant depository institutions exchange deposited checks on a local basis, including an entire metropolitan area, without using the check processing facilities of the Federal Reserve System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd12986d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Check processing region","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “check processing region” means the geographical area served by a Federal Reserve bank check processing center or such larger area as the Board may prescribe by regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd12986e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consumer account” means any account used primarily for personal, family, or household purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd12986f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depository check","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “depository check” means any cashier’s check, certified check, teller’s check, and any other functionally equivalent instrument as determined by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129870-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depository institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “depository institution” has the meaning given such term in clauses (i) through (vi) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s461/b/1/A"},"text":"section 461(b)(1)(A) of this title","children":[],"tail":". Such term also includes an office, branch, or agency of a foreign bank located in the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129871-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local originating depository institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “local originating depository institution” means any originating depository institution which is located in the same check processing region as the receiving depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129872-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncash item","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “noncash item” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd129873-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a check or other demand item to which a passbook, certificate, or other document is attached;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd129874-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a check or other demand item which is accompanied by special instructions, such as a request for special advise of payment or dishonor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd129875-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any similar item which is otherwise classified as a noncash item in regulations of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129876-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonlocal originating depository institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nonlocal originating depository institution” means any originating depository institution which is not a local depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129877-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proprietary ATM","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “proprietary ATM” means an automated teller machine which is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd129878-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" located—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd129879-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/16/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at or adjacent to a branch of the receiving depository institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd12987a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/16/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in close proximity, as defined by the Board, to a branch of the receiving depository institution; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd12987b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by, operated exclusively for, or operated by the receiving depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd12987c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Originating depository institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “originating depository institution” means the branch of a depository institution on which a check is drawn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd12987d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonproprietary ATM","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nonproprietary ATM” means an automated teller machine which is not a proprietary ATM.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd12987e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “participant” means a depository institution which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd12987f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/19/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in the same geographic area as that served by a check clearinghouse association; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd129880-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/19/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exchanges checks through the check clearinghouse association, either directly or through an intermediary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129881-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receiving depository institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “receiving depository institution” means the branch of a depository institution or the proprietary ATM, located in the United States, in which a check is first deposited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129882-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any State, the District of Columbia, the Commonwealth of Puerto Rico, American Samoa, the Commonwealth of the Northern Mariana Islands, Guam, or the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129883-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Teller’s check","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “teller’s check” means any check issued by a depository institution and drawn on another depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129884-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means the several States, the District of Columbia, the Commonwealth of Puerto Rico, American Samoa, the Commonwealth of the Northern Mariana Islands, Guam, and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129885-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"(24)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unit of general local government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “unit of general local government” means any city, county, town, township, parish, village, or other general purpose political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd129886-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4001/25"},"text":null,"children":[{"tag":"num","attrib":{"value":"25"},"text":"(25)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wire transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wire transfer” has such meaning as the Board shall prescribe by regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd129887-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/tVI/s602"},"text":"Pub. L. 100–86, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/635"},"text":"101 Stat. 635","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/tII/s208/a/1"},"text":"Pub. L. 115–174, title II, § 208(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1312"},"text":"132 Stat. 1312","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd129888-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd129889-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd12988a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86"},"text":"Pub. L. 100–86","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/635"},"text":"101 Stat. 635","children":[],"tail":", known as the Expedited Funds Availability Act, which enacted this chapter, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s248a"},"text":"section 248a of this title","children":[],"tail":", and enacted provisions set out as notes under sections 248a and 4001 of this title. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd12988b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (20). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/s208/a/1/A"},"text":"Pub. L. 115–174, § 208(a)(1)(A)","children":[],"tail":", inserted “, located in the United States,” after “ATM”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (21), (23). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/s208/a/1/B"},"text":"Pub. L. 115–174, § 208(a)(1)(B)","children":[],"tail":", (C), inserted “American Samoa, the Commonwealth of the Northern Mariana Islands, Guam,” after “Puerto Rico,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd12988c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd12988d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/tII/s208/b"},"text":"Pub. L. 115–174, titl