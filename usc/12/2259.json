{"tag":"section","attrib":{"id":"iddccfe9df-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2259"},"text":null,"children":[{"tag":"num","attrib":{"value":"2259"},"text":"§ 2259.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State legislation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever it is determined by the Farm Credit Administration, or by judicial decision, that a State law is applicable to the obligations and securities authorized to be held by the institutions of the System under this chapter, which law would provide insufficient protection or inadequate safeguards against loss in the event of default, the Farm Credit Administration may declare such obligations or securities to be ineligible as collateral for the issuance of new notes, bonds, debentures, and other obligations under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddccfe9e0-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".24, formerly § 5.25, "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/624"},"text":"85 Stat. 624","children":[],"tail":"; renumbered § 5.24, "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s203/b"},"text":"Pub. L. 99–205, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1694"},"text":"99 Stat. 1694","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddccfe9e1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddccfe9e2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddccfe9e3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5.24 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181"},"text":"Pub. L. 92–181","children":[],"tail":" was renumbered section 5.23 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2258"},"text":"section 2258 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
