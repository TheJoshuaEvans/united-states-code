{"tag":"section","attrib":{"id":"iddd7b92cd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587"},"text":null,"children":[{"tag":"num","attrib":{"value":"5587"},"text":"§ 5587.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition oversight","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd7b92ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this section is to ensure that the Bureau—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7b92cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an orderly and organized startup;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7b92d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attracts and retains a qualified workforce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7b92d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes comprehensive employee training and benefits programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7b92d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7b92d3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall submit an annual report to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives that includes the plans described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7b92d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plans described in this paragraph are as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd7b92d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and workforce development plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Bureau shall submit a training and workforce development plan that includes, to the extent practicable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd7b92d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of skill and technical expertise needs and actions taken to meet those requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7b92d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steps taken to foster innovation and creativity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7b92d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leadership development and succession planning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7b92d9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective use of technology by employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7b92da-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workplace flexibilities plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Bureau shall submit a workforce flexibility plan that includes, to the extent practicable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd7b92db-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" telework;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7b92dc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flexible work schedules;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7b92dd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" phased retirement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7b92de-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reemployed annuitants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7b92df-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part-time work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7b92e0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" job sharing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7b92e1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parental leave benefits and childcare assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7b92e2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" domestic partner benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7b92e3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other workplace flexibilities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7b92e4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of the items described in clauses (i) through (ix).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd7b92e5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recruitment and retention plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Bureau shall submit a recruitment and retention plan that includes, to the extent practicable, provisions relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd7b92e6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the steps necessary to target highly qualified applicant pools with diverse backgrounds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7b92e7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" streamlined employment application processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7b92e8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of timely notification of the status of employment applications to applicants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd7b92e9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection of information to measure indicators of hiring effectiveness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7b92ea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reporting requirement under subsection (b) shall terminate 5 years after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7b92eb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section may be construed to affect—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7b92ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5587/d/1"},"text":null,"chil