{"tag":"section","attrib":{"id":"iddafed2ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"§ 8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clerks","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Comptroller of the Currency shall employ, from time to time, the necessary clerks, to be appointed and classified by the Secretary of the Treasury, to discharge such duties as the comptroller shall direct.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddafed2ed-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 328.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddafed2ee-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddafed2ef-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddafed2f0-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 328 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-03/ch106/s1"},"text":"act June 3, 1864, ch. 106, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/100"},"text":"13 Stat. 100","children":[],"tail":", which was the National Bank Act. See "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddafed2f1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddafed2f2-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exception as to Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested by any provision of law in Comptroller of the Currency, referred to in this section, not included in transfer of functions to Secretary of the Treasury, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
