{"tag":"section","attrib":{"id":"iddb1df42b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s196"},"text":null,"children":[{"tag":"num","attrib":{"value":"196"},"text":"§ 196.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All expenses of any preliminary or other examinations into the condition of any association shall be paid by such association. All expenses of any receivership shall be paid out of the assets of such association before distribution of the proceeds thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb1df42c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 5238; ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tVI/s602/g/13"},"text":"Pub. L. 103–325, title VI, § 602(g)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2294"},"text":"108 Stat. 2294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb1df42d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb1df42e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb1df42f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5238 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-03/ch106/s51"},"text":"act June 3, 1864, ch. 106, § 51","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/115"},"text":"13 Stat. 115","children":[],"tail":", which was the National Bank Act. See "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb1df430-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":" struck out at beginning “All fees for protesting the notes issued by any national banking association shall be paid by the person procuring the protest to be made, and such association shall be liable therefor; but no part of the bonds deposited by such association shall be applied to the payment of such fees.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
