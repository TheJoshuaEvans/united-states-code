{"tag":"section","attrib":{"id":"iddd6fac34-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5511"},"text":null,"children":[{"tag":"num","attrib":{"value":"5511"},"text":"§ 5511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose, objectives, and functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd6fac35-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall seek to implement and, where applicable, enforce Federal consumer financial law consistently for the purpose of ensuring that all consumers have access to markets for consumer financial products and services and that markets for consumer financial products and services are fair, transparent, and competitive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd6fac36-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Bureau is authorized to exercise its authorities under Federal consumer financial law for the purposes of ensuring that, with respect to consumer financial products and services—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd6fac37-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5511/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consumers are provided with timely and understandable information to make responsible decisions about financial transactions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6fac38-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5511/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consumers are protected from unfair, deceptive, or abusive acts and practices and from discrimination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6fac39-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5511/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outdated, unnecessary, or unduly burdensome regulations are regularly identified and addressed in order to reduce unwarranted regulatory burdens;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6fac3a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5511/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal consumer financial law is enforced consistently, without regard to the status of a person as a depository institution, in order to promote fair competition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6fac3b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5511/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" markets for consumer financial products and services operate transparently and efficiently to facilitate access and innovation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd6fac3c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The primary functions of the Bureau are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd6fac3d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5511/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting financial education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6fac3e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5511/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting, investigating, and responding to consumer complaints;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6fac3f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5511/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting, researching, monitoring, and publishing information relevant to the functioning of markets for consumer financial products and services to identify risks to consumers and the proper functioning of such markets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6fac40-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5511/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to sections 5514 through 5516 of this title, supervising covered persons for compliance with Federal consumer financial law, and taking appropriate enforcement action to address violations of Federal consumer financial law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6fac41-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5511/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuing rules, orders, and guidance implementing Federal consumer financial law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6fac42-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5511/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing such support activities as may be necessary or useful to facilitate the other functions of the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd6fac43-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1021"},"text":"Pub. L. 111–203, title X, § 1021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1979"},"text":"124 Stat. 1979","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd6fac44-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd6fac45-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd6fac46-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1029A"},"text":"Pub. L. 111–203, title X, § 1029A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2005"},"text":"124 Stat. 2005","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/203/tX/s1029A"},"text":"“This subtitle [subtitle B (§§ 1021–1029A), enacting this part] shall become effective on the designated transfer date, except that sections 1022, 1024, and 1025(e) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5512"},"text":"12 U.S.C. 5512","children":[],"tail":", 5514, and 5515(e)] shall become effective on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[The term “designated transfer date” is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5481/9"},"text":"section 5481(9) of this title","children":[],"tail":" as the date established under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5582"},"text":"section 5582 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
