{"tag":"section","attrib":{"id":"iddc62340f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1814"},"text":null,"children":[{"tag":"num","attrib":{"value":"1814"},"text":"§ 1814.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insured depository institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc623410-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1814/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of insurance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc623411-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1814/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Banks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each bank, which is an insured depository institution on ","children":[{"tag":"date","attrib":{"date":"1950-09-21"},"text":"September 21, 1950","children":[],"tail":", shall be and continue to be, without application or approval, an insured depository institution and shall be subject to the provisions of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc623412-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1814/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings associations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each savings association the accounts of which were insured by the Federal Savings and Loan Insurance Corporation on the day before ","children":[{"tag":"date","attrib":{"date":"1989-08-09"},"text":"August 9, 1989","children":[],"tail":", shall be, without application or approval, an insured depository institution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc623413-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1814/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of insurance upon becoming a member bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an insured bank which is admitted to membership in the Federal Reserve System or an insured State bank which is converted into a national member bank, the bank shall continue as an insured bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc623414-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1814/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of insurance after conversion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1815/d"},"text":"section 1815(d) of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1464/i/5"},"text":"section 1464(i)(5) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc623415-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1814/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State depository institution which results from the conversion of any insured Federal depository institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc623416-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1814/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal depository institution which results from the conversion of any insured State or Federal depository institution,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall continue as an insured depository institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc623417-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1814/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of insurance after merger or consolidation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State depository institution or any Federal depository institution which results from the merger or consolidation of insured depository institutions, or from the merger or consolidation of a noninsured depository institution with an insured depository institution, shall continue as an insured depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc623418-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"Sept. 21, 1950, ch. 967, § 2","children":[],"tail":"[4], "},{"tag":"ref","attrib":{"href":"/us/stat/64/875"},"text":"64 Stat. 875","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/320/tI/s113/c"},"text":"Pub. L. 97–320, title I, § 113(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1473"},"text":"96 Stat. 1473","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tII"},"text":"Pub. L. 101–73, title II","children":[],"tail":", §§ 201(a), 205, "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/187"},"text":"103 Stat. 187","children":[],"tail":", 194; "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tI/s115/b"},"text":"Pub. L. 102–242, title I, § 115(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2249"},"text":"105 Stat. 2249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXVI/s1603/b/6"},"text":"Pub. L. 102–550, title XVI, § 1603(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4079"},"text":"106 Stat. 4079","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tVI/s608/b"},"text":"Pub. L. 109–351, title VI, § 608(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1983"},"text":"120 Stat. 1983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc623419-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc62341a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddc62341b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section is derived from subsec. (e) of former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s264"},"text":"section 264 of this title","children":[],"tail":". See Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"section 1811 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc62341c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351/s608/b/1"},"text":"Pub. L. 109–351, § 608(b)(1)","children":[],"tail":", inserted “and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1464/i/5"},"text":"section 1464(i)(5) of this title","children":[],"tail":"” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1815/d"},"text":"section 1815(d) of this title","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351/s608/b/2"},"text":"Pub. L. 109–351, § 608(b)(2)","children":[],"tail":", which directed insertion of “or Federal” after “insured State,”, was executed by making the insertion after “insured State”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/s115/b"},"text":"Pub. L. 102–242, § 115(b)","children":[],"tail":". See 1991 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s115/b"},"text":"Pub. L. 102–242, § 115(b)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1603/b/6"},"text":"Pub. L. 102–550, § 1603(b)(6)","children":[],"tail":", amended subsec. (b) generally, substituting present provisions for provisions which related to certification by other banking agencies."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s201/a"},"text":"Pub. L. 101–73, § 201(a)","children":[],"tail":", substituted references to insured depository institutions for references to insured banks wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s205/1"},"text":"Pub. L. 101–73, § 205(1)","children":[],"tail":", inserted heading, designated existing provisions as par. (1), inserted par. (1) heading, and substituted “Each bank” for “Every bank”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s205/2/A"},"text":"Pub. L. 101–73, § 205(2)(A)","children":[],"tail":", (B), inserted after first sentence “Any application or notice for membership or to commence or resume business shall be promptly provided by the appropriate Federal banking agency to the Corporation and the Corporation shall have a reasonable period of time to provide comments on such application or notice. Any comments submitted by the Corporation to the appropriate Federal banking agency shall be considered by such agency.” and struck out at end “A State bank, resulting from the conversion of an insured national bank, shall continue as an insured bank. A State bank, resulting from the merger or consolidation of insured banks, or from the merger or consolidation of a noninsured bank or institution with an insured State bank, shall continue as an insured bank.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s205/2/C"},"text":"Pub. L. 101–73, § 205(2)(C)","children":[],"tail":", which directed the amendment of subsec. (b) by substituting “(b) "},{"tag":"inline","attrib":{},"text":"Certification by Other Banking Agencies","children":[],"tail":".—Every national bank” for “(b) Every national bank” could not be executed literally because the original read “(b) Every national member bank”, but was executed by inserting the heading without changing the text to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s205/3"},"text":"Pub. L. 101–73, § 205(3)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “Every Federal savings bank which is chartered pursuant to section 1464("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of this title, and which is engaged in the business of receiving deposits other than trust funds, shall be an insured bank from the time it is authorized to commence business, until such time as its accounts are insured by the Federal Savings and Loan Insurance Corporation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s205/3"},"text":"Pub. L. 101–73, § 205(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320"},"text":"Pub. L. 97–320","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc62341d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc62341e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/558"},"text":"Pub. L. 102–558","children":[],"tail":" deemed to have become effective "},{"tag":"date","attrib":{"date":"1992-03-01"},"text":"Mar. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/558/s304"},"text":"section 304 of Pub. L. 102–558","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4502"},"text":"section 4502 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
