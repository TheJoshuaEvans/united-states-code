{"tag":"section","attrib":{"id":"iddd281bed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541"},"text":null,"children":[{"tag":"num","attrib":{"value":"4541"},"text":"§ 4541.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior approval authority for products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd281bee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall require each enterprise to obtain the approval of the Director for any product of the enterprise before initially offering the product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281bef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard for approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In considering any request for approval of a product pursuant to subsection (a), the Director shall make a determination that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281bf0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a product of the Federal National Mortgage Association, the product is authorized under paragraph (2), (3), (4), or (5) of section 1717(b) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1719"},"text":"section 1719 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281bf1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a product of the Federal Home Loan Mortgage Corporation, the product is authorized under paragraph (1), (4), or (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1454/a"},"text":"section 1454(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281bf2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product is in the public interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281bf3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product is consistent with the safety and soundness of the enterprise or the mortgage finance system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281bf4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure for approval","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281bf5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An enterprise shall submit to the Director a written request for approval of a product that describes the product in such form as prescribed by order or regulation of the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281bf6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Immediately upon receipt of a request for approval of a product, as required under paragraph (1), the Director shall publish notice of such request and of the period for public comment pursuant to paragraph (3) regarding the product, and a description of the product proposed by the request. The Director shall give interested parties the opportunity to respond in writing to the proposed product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281bf7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the 30-day period beginning on the date of publication pursuant to paragraph (2) of a request for approval of a product, the Director shall receive public comments regarding the proposed product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281bf8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offering of product","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd281bf9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the close of the public comment period described in paragraph (3), the Director shall approve or deny the product, specifying the grounds for such decision in writing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281bfa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Director fails to act within the 30-day period described in subparagraph (A), then the enterprise may offer the product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281bfb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may, subject to the rules of the Director, provide for temporary approval of the offering of a product without a public comment period, if the Director finds that the existence of exigent circumstances makes such delay contrary to the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281bfc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditional approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Director approves the offering of any product by an enterprise, the Director may establish terms, conditions, or limitations with respect to such product with which the enterprise must comply in order to offer such product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281bfd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281bfe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of subsections (a) through (d) do not apply with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd281bff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the automated loan underwriting system of an enterprise in existence as of ","children":[{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", including any upgrade to the technology, operating system, or software to operate the underwriting system;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c00-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any modification to the mortgage terms and conditions or mortgage underwriting criteria relating to the mortgages that are purchased or guaranteed by an enterprise, provided that such modifications do not alter the underlying transaction so as to include services or financing, other than residential mortgage financing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c01-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any other activity that is substantially similar, as determined by rule of the Director to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd281c02-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/e/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities described in subparagraphs (A) and (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd281c03-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/e/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities that have been approved by the Director in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c04-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited review","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd281c05-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enterprise notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any new activity that an enterprise considers not to be a product, the enterprise shall provide written notice to the Director of such activity, and may not commence such activity until the date of receipt of a notice under subparagraph (B) or the expiration of the period described in subparagraph (C). The Director shall establish, by regulation, the form and content of such written notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c06-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 15 days after the date of receipt of a notice under subparagraph (A), the Director shall determine whether such activity is a product subject to approval under this section. The Director shall, immediately upon so determining, notify the enterprise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281c07-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Director fails to determine whether such activity is a product within the 15-day period described in subparagraph (B), the enterprise may commence the new activity in accordance with subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281c08-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section may be construed to restrict—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281c09-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety and soundness authority of the Director over all new and existing products or activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281c0a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4541/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority of the Director to review all new and existing products or activities to determine that such products or activities are consistent with the statutory mission of an enterprise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd281c0b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1321"},"text":"Pub. L. 102–550, title XIII, § 1321","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1123"},"text":"Pub. L. 110–289, div. A, title I, § 1123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2689"},"text":"122 Stat. 2689","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd281c0c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd281c0d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddd281c0e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4541, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1321"},"text":"Pub. L. 102–550, title XIII, § 1321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3952"},"text":"106 Stat. 3952","children":[],"tail":", related to the Secretary of Housing and Urban Development’s regulatory authority, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1121/2"},"text":"Pub. L. 110–289, div. A, title I, § 1121(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2689"},"text":"122 Stat. 2689","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
