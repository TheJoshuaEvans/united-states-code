{"tag":"section","attrib":{"id":"iddd01f5c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3109"},"text":null,"children":[{"tag":"num","attrib":{"value":"3109"},"text":"§ 3109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with foreign supervisors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd01f5c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of supervisory information to foreign supervisors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Board, Comptroller of the Currency, Federal Deposit Insurance Corporation, and Director of the Office of Thrift Supervision may disclose information obtained in the course of exercising supervisory or examination authority to any foreign bank regulatory or supervisory authority if the Board, Comptroller, Corporation, or Director determines that such disclosure is appropriate and will not prejudice the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd01f5c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before making any disclosure of any information to a foreign authority, the Board, Comptroller of the Currency, Federal Deposit Insurance Corporation, and Director of the Office of Thrift Supervision shall obtain, to the extent necessary, the agreement of such foreign authority to maintain the confidentiality of such information to the extent possible under applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd01f5c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidential information received from foreign supervisors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd01f5c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3109/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (3), a Federal banking agency may not be compelled to disclose information received from a foreign regulatory or supervisory authority if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd01f5c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3109/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal banking agency determines that the foreign regulatory or supervisory authority has, in good faith, determined and represented in writing to such Federal banking agency that public disclosure of the information would violate the laws applicable to that foreign regulatory or supervisory authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd01f5c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3109/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the relevant Federal banking agency obtained such information pursuant to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd01f5ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3109/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such procedures as the Federal banking agency may establish for use in connection with the administration and enforcement of Federal banking laws; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd01f5cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3109/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a memorandum of understanding or other similar arrangement between the Federal banking agency and the foreign regulatory or supervisory authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd01f5cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3109/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment under title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":", this subsection shall be treated as a statute described in subsection (b)(3)(B) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd01f5cd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3109/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No provision of this section shall be construed as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd01f5ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3109/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizing any Federal banking agency to withhold any information from any duly authorized committee of the House of Representatives or the Senate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd01f5cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3109/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing any Federal banking agency from complying with an order of a court of the United States in an action commenced by the United States or such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd01f5d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3109/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal banking agency defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “Federal banking agency” means the Board, the Comptroller of the Currency, the Federal Deposit Insurance Corporation, and the Director of the Office of Thrift Supervision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd01f5d1-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/369/s15"},"text":"Pub. L. 95–369, § 15","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s206"},"text":"Pub. L. 102–242, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2294"},"text":"105 Stat. 2294","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tVII/s709"},"text":"Pub. L. 109–351, title VII, § 709","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1990"},"text":"120 Stat. 1990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd01f5d2-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd01f5d3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd01f5d4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351"},"text":"Pub. L. 109–351","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
