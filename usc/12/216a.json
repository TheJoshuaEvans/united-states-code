{"tag":"section","attrib":{"id":"iddb22af36-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s216a"},"text":null,"children":[{"tag":"num","attrib":{"value":"216a"},"text":"§ 216a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb22af37-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s216a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Comptroller” means the Comptroller of the Currency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb22af38-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s216a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “unclaimed property” means any articles, items, assets, other property, or the proceeds thereof from safe deposit boxes or other safekeeping arrangements with closed national banks, which are in the possession, custody, or control of the Comptroller in its capacity as successor to receivers of those banks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb22af39-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s216a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “claimant” means any person or entity, including a State under applicable statutory law, asserting a demonstrable legal interest in title to, or custody or possession of, unclaimed property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb22af3a-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221/tVII/s732"},"text":"Pub. L. 96–221, title VII, § 732","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/320/tIV/s408"},"text":"Pub. L. 97–320, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1513"},"text":"96 Stat. 1513","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tVII/s725/c/2"},"text":"Pub. L. 109–351, title VII, § 725(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2001"},"text":"120 Stat. 2001","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/356/tI/s123/c/2"},"text":"Pub. L. 109–356, title I, § 123(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-16"},"text":"Oct. 16, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2029"},"text":"120 Stat. 2029","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb22af3b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb22af3c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb22af3d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351"},"text":"Pub. L. 109–351","children":[],"tail":" and 109–356 amended par. (2) identically, striking out “or closed banks in the District of Columbia” after “closed national banks”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
