{"tag":"section","attrib":{"id":"iddc433a11-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1772d"},"text":"§ 1772d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture of organization certificate for money laundering or cash transaction reporting offenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc433a12-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture of franchise for money laundering or cash transaction reporting offenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc433a13-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conviction of title 18 offenses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc433a14-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772d/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty to notify","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a credit union has been convicted of any criminal offense under section 1956 or 1957 of title 18, the Attorney General shall provide to the Board a written notification of the conviction and shall include a certified copy of the order of conviction from the court rendering the decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc433a15-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772d/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of termination; pretermination hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After receiving written notification from the Attorney General of such a conviction, the Board shall issue to such credit union a notice of its intention to terminate all rights, privileges, and franchises of the credit union and schedule a pretermination hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc458406-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conviction of title 31 offenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a credit union is convicted of any criminal offense under section 5322 or 5324 of title 31 after receiving written notification from the Attorney General, the Board may issue to such credit union a notice of its intention to terminate all rights, privileges, and franchises of the credit union and schedule a pretermination hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc458407-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1786/j"},"text":"Section 1786(j) of this title","children":[],"tail":" shall apply to any proceeding under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc458408-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors to be considered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether a franchise shall be forfeited under subsection (a), the Board shall take into account the following factors:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc458409-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which directors, committee members, or senior executive officers (as defined by the Board in regulations which the Board shall prescribe) of the credit union knew of, or were involved in, the commission of the money laundering offense of which the credit union was found guilty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc45840a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the offense occurred despite the existence of policies and procedures within the credit union which were designed to prevent the occurrence of any such offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc45840b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the credit union has fully cooperated with law enforcement authorities with respect to the investigation of the money laundering offense of which the credit union was found guilty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc45840c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the credit union has implemented additional internal controls (since the commission of the offense of which the credit union was found guilty) to prevent the occurrence of any other money laundering offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc45840d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the interest of the local community in having adequate deposit and credit services available would be threatened by the forfeiture of the franchise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc45840e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Successor liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to a successor to the interests of, or a person who acquires, a credit union that violated a provision of law described in subsection (a), if the successor succeeds to the interests of the violator, or the acquisition is made, in good faith and not for purposes of evading this section or regulations prescribed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc45840f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title I, § 131, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXV/s1502/c"},"text":"Pub. L. 102–550, title XV, § 1502(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4047"},"text":"106 Stat. 4047","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIV/s411/c/2/B"},"text":"Pub. L. 103–325, title IV, § 411(c)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2253"},"text":"108 Stat. 2253","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc458410-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc458411-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc458412-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":" substituted “section 5322 or 5324 of title 31” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5322"},"text":"section 5322 of title 31","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
