{"tag":"section","attrib":{"id":"iddcf858d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2808"},"text":null,"children":[{"tag":"num","attrib":{"value":"2808"},"text":"§ 2808.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf858d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2808/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter shall take effect on the one hundred and eightieth day beginning after ","children":[{"tag":"date","attrib":{"date":"1975-12-31"},"text":"December 31, 1975","children":[],"tail":". Any institution specified in section 2802(2)(A) "},{"tag":"ref","attrib":{"idref":"fn002321"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002321"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title which has total assets as of its last full fiscal year of $10,000,000 or less is exempt from the provisions of this chapter. The Bureau, in consultation with the Secretary, may exempt institutions described in section 2802(2)(B) "},{"tag":"ref","attrib":{"idref":"fn002321"},"text":"1","children":[],"tail":" of this title that are comparable within their respective industries to institutions that are exempt under the preceding sentence (as determined without regard to the adjustment made by subsection (b))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf858d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2808/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CPI adjustments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf858d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2808/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the dollar amount applicable with respect to institutions described in section 2802(2)(A) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title under the 2d sentence of subsection (a) shall be adjusted annually after "},{"tag":"date","attrib":{"date":"1996-12-31"},"text":"December 31, 1996","children":[],"tail":", by the annual percentage increase in the Consumer Price Index for Urban Wage Earners and Clerical Workers published by the Bureau of Labor Statistics."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf858d9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2808/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1-time adjustment for prior inflation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The first adjustment made under paragraph (1) after ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":", shall be the percentage by which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf858da-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2808/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Consumer Price Index described in such paragraph for the calendar year 1996, exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf858db-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2808/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such Consumer Price Index for the calendar year 1975.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf858dc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2808/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rounding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The dollar amount applicable under paragraph (1) for any calendar year shall be the amount determined in accordance with subparagraphs (A) and (B) of paragraph (2) and rounded to the nearest multiple of $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf858dd-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/200/tIII/s309"},"text":"Pub. L. 94–200, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1128"},"text":"89 Stat. 1128","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s224/a"},"text":"Pub. L. 102–242, title II, § 224(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2307"},"text":"105 Stat. 2307","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXVI/s1604/a/15"},"text":"Pub. L. 102–550, title XVI, § 1604(a)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/