{"tag":"section","attrib":{"id":"iddc4339f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1772a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1772a"},"text":"§ 1772a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts; acceptance of conditional gifts; deposit","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board is authorized to accept gifts of money made unconditionally by will or otherwise for the carrying out of any of the functions under this chapter. A conditional gift of money made by will or otherwise for such purposes may be accepted and used in accordance with its conditions, but no such gift shall be accepted which is conditioned upon any expenditure not to be met therefrom or from income thereof unless the Board determines that supplementation of such gift from the fees it may expend pursuant to sections 1755 and 1756 of this title or from any funds appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1766/f/2/C"},"text":"section 1766(f)(2)(C) of this title","children":[],"tail":" for the purpose of making such expenditure will not adversely affect the sound administration of this chapter. Any such gift shall be deposited in the Treasury of the United States for the account of the Administration and may be expended in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1755"},"text":"section 1755 of this title","children":[],"tail":" or as provided in the preceding sentence."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc4339fa-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title I, § 127, formerly § 28, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/375/s3"},"text":"Pub. L. 90–375, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-05"},"text":"July 5, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/285"},"text":"82 Stat. 285","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/206/s2/1"},"text":"Pub. L. 91–206, § 2(1)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1970-03-10"},"text":"Mar. 10, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/49"},"text":"84 Stat. 49","children":[],"tail":"; renumbered title I, § 127, "},{"tag":"ref","attrib":{"href":"/us/pl/91/468/s1/2"},"text":"Pub. L. 91–468, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-19"},"text":"Oct. 19, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/994"},"text":"84 Stat. 994","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tV/s502/b"},"text":"Pub. L. 95–630, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3681"},"text":"92 Stat. 3681","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc4339fb-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc4339fc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc4339fd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":" substituted “Board” for “Administrator” in two places, and “it may expend” for “he may expend”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/206"},"text":"Pub. L. 91–206","children":[],"tail":" substituted “Administrator” for “Director” and “Administration” for “Bureau” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc4339fe-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc4339ff-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":" effective on expiration of 120 days after "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", and transitional provisions, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/s509"},"text":"section 509 of Pub. L. 95–630","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752"},"text":"section 1752 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
