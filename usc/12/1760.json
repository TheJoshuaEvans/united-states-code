{"tag":"section","attrib":{"id":"iddc40c927-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1760"},"text":null,"children":[{"tag":"num","attrib":{"value":"1760"},"text":"§ 1760.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members’ meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The fiscal year of all Federal credit unions shall end December 31. The annual meeting of each Federal credit union shall be held at such place as its bylaws shall prescribe. Special meetings may be held in the manner indicated in the bylaws. No member shall be entitled to vote by proxy, but a member other than a natural person may vote through an agent designated for the purpose. Irrespective of the number of shares held, no member shall have more than one vote.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc40c928-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title I, § 110, formerly § 10, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1219"},"text":"48 Stat. 1219","children":[],"tail":"; renumbered § 11, "},{"tag":"ref","attrib":{"href":"/us/pl/86/354/s1"},"text":"Pub. L. 86–354, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-22"},"text":"Sept. 22, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/631"},"text":"73 Stat. 631","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/88/150/s1"},"text":"Pub. L. 88–150, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-10-17"},"text":"Oct. 17, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/270"},"text":"77 Stat. 270","children":[],"tail":"; renumbered title I, § 110, "},{"tag":"ref","attrib":{"href":"/us/pl/91/468/s1/2"},"text":"Pub. L. 91–468, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-19"},"text":"Oct. 19, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/994"},"text":"84 Stat. 994","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/320/tV/s519"},"text":"Pub. L. 97–320, title V, § 519","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1531"},"text":"96 Stat. 1531","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc40c929-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc40c92a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc40c92b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320"},"text":"Pub. L. 97–320","children":[],"tail":" struck out “at such time during the following January, February, or March and” after “shall be held”, and “by him” after “shares held”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/150"},"text":"Pub. L. 88–150","children":[],"tail":" substituted “during the following January, February, or March” for “during the month of the following January”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
