{"tag":"section","attrib":{"id":"iddd49867d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5216"},"text":null,"children":[{"tag":"num","attrib":{"value":"5216"},"text":"§ 5216.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights; management; sale of troubled assets; revenues and sale proceeds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd49867e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5216/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exercise of rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, at any time, exercise any rights received in connection with troubled assets purchased under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd49867f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5216/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of troubled assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall have authority to manage troubled assets purchased under this chapter, including revenues and portfolio risks therefrom.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd498680-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5216/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of troubled assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, at any time, upon terms and conditions and at a price determined by the Secretary, sell, or enter into securities loans, repurchase transactions, or other financial transactions in regard to, any troubled asset purchased under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd498681-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5216/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer to Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Revenues of, and proceeds from the sale of troubled assets purchased under this chapter, or from the sale, exercise, or surrender of warrants or senior debt instruments acquired under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5223"},"text":"section 5223 of this title","children":[],"tail":" shall be paid into the general fund of the Treasury for reduction of the public debt."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd498682-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5216/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of sunset to troubled assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Secretary to hold any troubled asset purchased under this chapter before the termination date in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5230"},"text":"section 5230 of this title","children":[],"tail":", or to purchase or fund the purchase of a troubled asset under a commitment entered into before the termination date in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5230"},"text":"section 5230 of this title","children":[],"tail":", is not subject to the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5230"},"text":"section 5230 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd498683-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5216/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall report to Congress every 6 months on amounts received and transferred to the general fund under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd498684-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dA/tI/s106"},"text":"Pub. L. 110–343, div. A, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3773"},"text":"122 Stat. 3773","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXIII/s1303"},"text":"Pub. L. 111–203, title XIII, § 1303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2133"},"text":"124 Stat. 2133","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd498685-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd498686-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd498687-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","