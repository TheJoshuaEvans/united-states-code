{"tag":"section","attrib":{"id":"iddd0467bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3308"},"text":null,"children":[{"tag":"num","attrib":{"value":"3308"},"text":"§ 3308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to books, accounts, records, etc., by Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this chapter, the Council shall have access to all books, accounts, records, reports, files, memorandums, papers, things, and property belonging to or in use by Federal financial institutions regulatory agencies, including reports of examination of financial institutions or their holding companies from whatever source, together with workpapers and correspondence files related to such reports, whether or not a part of the report, and all without any deletions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd0467bc-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/tX/s1009"},"text":"Pub. L. 95–630, title X, § 1009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3696"},"text":"92 Stat. 3696","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0467bd-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd0467be-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd0467bf-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of 120 days after ","children":[{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/s2101"},"text":"section 2101 of Pub. L. 95–630","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s375b"},"text":"section 375b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
