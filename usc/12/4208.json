{"tag":"section","attrib":{"id":"iddd1e7f11-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4208"},"text":null,"children":[{"tag":"num","attrib":{"value":"4208"},"text":"§ 4208.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonreviewability of action by Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other law, no court shall have jurisdiction over any claim based on any action taken by the Attorney General or any refusal to take action under this subchapter, except for failure to provide notification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4206"},"text":"section 4206 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd1e7f12-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2568"},"text":"Pub. L. 101–647, title XXV, § 2568","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4898"},"text":"104 Stat. 4898","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
