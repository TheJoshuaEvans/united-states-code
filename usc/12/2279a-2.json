{"tag":"section","attrib":{"id":"iddce7b7f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279a–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279a–2"},"text":"§ 2279a–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of merged banks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce7b7f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279a–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subchapter, a merged bank shall have all of the powers granted to, and shall be subject to all of the obligations imposed on, any of the constituent entities of the merged bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7b7f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279a–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Farm Credit Administration shall issue regulations that establish the manner in which the powers and obligations of the banks that form the merged bank are consolidated, and to the extent necessary, reconciled in the merged bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce7b7fa-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVII/s7"},"text":"Pub. L. 92–181, title VII, § 7","children":[],"tail":".2, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s416"},"text":"Pub. L. 100–233, title IV, § 416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1645"},"text":"101 Stat. 1645","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
