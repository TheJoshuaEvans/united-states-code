{"tag":"section","attrib":{"id":"iddc45842d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1774"},"text":null,"children":[{"tag":"num","attrib":{"value":"1774"},"text":"§ 1774.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of certificate; assets and obligations of applicant credit union","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board shall approve any such organization certificate meeting such requirements. Upon such approval, the applicant credit union shall become a Federal credit union, and shall be vested with all of the assets and shall continue responsible for all of the obligations of such applicant credit union to the same extent as though the conversion had not taken place.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc45842e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/395/s2"},"text":"Pub. L. 88–395, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-01"},"text":"Aug. 1, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/377"},"text":"78 Stat. 377","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/206/s3"},"text":"Pub. L. 91–206, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-03-10"},"text":"Mar. 10, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/49"},"text":"84 Stat. 49","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tV/s501"},"text":"Pub. L. 95–630, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3680"},"text":"92 Stat. 3680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc45842f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc458430-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddc458431-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Federal Credit Union Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc458432-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"iddc458433-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Board”, meaning the National Credit Union Administration Board, substituted in text for “Director”, meaning Director of Bureau of Federal Credit Unions, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/206/s3"},"text":"section 3 of Pub. L. 91–206","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/s501"},"text":"section 501 of Pub. L. 95–630","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752a"},"text":"12 U.S.C. 1752a","children":[],"tail":"] which transferred functions of Bureau of Federal Credit Unions, and Director thereof, to National Credit Union Administration and vested authority for management of Administration in National Credit Union Administration Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
