{"tag":"section","attrib":{"id":"iddcea27e0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279aa–2"},"text":"§ 2279aa–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcea27e1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcea27e2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall be under the management of the board of directors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea27e3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall consist of 15 members, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcea27e4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 members shall be elected by holders of common stock that are insurance companies, banks, or other financial institutions or entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea27e5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 members shall be elected by holders of common stock that are Farm Credit System institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea27e6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 5 members shall be appointed by the President, by and with the advice and consent of the Senate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcea27e7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which members shall not be, or have been, officers or directors of any financial institutions or entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcea27e8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which members shall be representatives of the general public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcea27e9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of which members not more than 3 shall be members of the same political party; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcea27ea-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of which members at least 2 shall be experienced in farming or ranching.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea27eb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancy","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcea27ec-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elected members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (5), a vacancy among the members elected to the Board in the manner described in subparagraph (A) or (B) of paragraph (2) shall be filled by the Board from among persons eligible for election to the position for which the vacancy exists.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea27ed-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointed members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy among the members appointed to the Board under paragraph (2)(C) shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea27ee-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcea27ef-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any member of the Board who was appointed or elected to the Board from among persons who are representatives of banks, other financial institutions or entities, insurance companies, or Farm Credit System institutions ceases to be such a representative; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea27f0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any member who was appointed from persons who are not or have not been directors or officers of any financial institution or entity becomes a director or an officer of any financial institution or entity;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such member may continue as a member for not longer than the 45-day period beginning on the date such member ceases to be such a representative, officer, or employee or becomes such a director or officer, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea27f1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcea27f2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointed members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members appointed by the President shall serve at the pleasure of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea27f3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elected members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members elected under subparagraphs (A) and (B) of subsection (b)(2) shall each be elected annually for a term ending on the date of the next annual meeting of the common stockholders of the Corporation and shall serve until their successors are elected and qualified. Any seat on the Board that becomes vacant after the annual election of the directors shall be filled by the members of the Board from the same category of directors, but only for the unexpired portion of the term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea27f4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancy appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any member appointed to fill a vacancy occurring before the expiration of the term for which the predecessor of the member was appointed shall be appointed only for the remainder of such term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcea27f5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service after expiration of term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member may serve after the expiration of the term of the member until the successor of the member has taken office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea27f6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"8 members of the Board shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea27f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No additional pay for Federal officers or employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board who are fulltime officers or employees of the United States shall receive no additional pay by reason of service on the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea27f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall designate 1 of the members of the Board who are appointed by the President as the chairperson of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcea27f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall meet at the call of the chairperson or a majority of its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcea27fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers and staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may appoint, employ, fix the pay of, and provide other allowances and benefits for such officers and employees of the Corporation as the Board determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcea27fb-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVIII/s8"},"text":"Pub. L. 92–181, title VIII, § 8","children":[],"tail":".2, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVII/s702"},"text":"Pub. L. 100–233, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1688"},"text":"101 Stat. 1688","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tVI/s601/b"},"text":"Pub. L. 100–399, title VI, § 601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1005"},"text":"102 Stat. 1005","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5411/43"},"text":"Pub. L. 115–334, title V, § 5411(43)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4684"},"text":"132 Stat. 4684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcea27fc-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcea27fd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcea27fe-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/43/A"},"text":"Pub. L. 115–334, § 5411(43)(A)","children":[],"tail":"–(C)(i), redesignated subsec. (b) as (a), substituted “In general” for “Permanent board” in heading and “Board” for “permanent board” wherever appearing in text, and struck out former subsec. (a) which established an interim board of directors until the first meeting of a permanent board of directors."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/43/B"},"text":"Pub. L. 115–334, § 5411(43)(B)","children":[],"tail":", added par. (1) and struck out former par. (1) which required the Corporation to establish a permanent board of directors for financial institutions once certain thresholds were met."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/43/C/ii"},"text":"Pub. L. 115–334, § 5411(43)(C)(ii)","children":[],"tail":"–(iv), redesignated par. (4) as (3), substituted “paragraph (5)” for “paragraph (6)” in subpar. (A), and struck out former par. (3) which set a date by which the presidential appointees to the permanent board were to be appointed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/43/C/iii"},"text":"Pub. L. 115–334, § 5411(43)(C)(iii)","children":[],"tail":", redesignated pars. (5) to (10) as (4) to (9), respectively. Former par. (4) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/43/D"},"text":"Pub. L. 115–334, § 5411(43)(D)","children":[],"tail":", redesignated subsec. (c) as (b). Former subsec. (b) redesignated (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsecs. (a)(1), (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" substituted “date of the enactment” for “effective date”, both of which for purposes of codification were translated as “"},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":",”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcea27ff-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcea2800-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective as if enacted immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/a"},"text":"section 1001(a) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
