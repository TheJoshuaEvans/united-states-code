{"tag":"section","attrib":{"id":"iddd1c3520-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119"},"text":null,"children":[{"tag":"num","attrib":{"value":"4119"},"text":"§ 4119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1c3521-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “eligible low-income housing” means any housing financed by a loan or mortgage—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1c3522-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd1c3523-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insured or held by the Secretary under section 1715","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(d)(3) of this title and receiving loan management assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of title 42","children":[],"tail":" due to a conversion from "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701s"},"text":"section 1701s of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1c3524-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insured or held by the Secretary and bears interest at a rate determined under the proviso of section 1715","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(d)(5) of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1c3525-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insured, assisted, or held by the Secretary or a State or State agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715z–1"},"text":"section 1715z–1 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1c3526-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" held by the Secretary and formerly insured under a program referred to in clause (i), (ii), or (iii); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c3527-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, under regulation or contract in effect before ","children":[{"tag":"date","attrib":{"date":"1988-02-05"},"text":"February 5, 1988","children":[],"tail":", is or will within 24 months become eligible for prepayment without prior approval of the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c3528-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Federal cost limit” means, for any eligible low-income housing, the amount determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4105/a"},"text":"section 4105(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c3529-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “low-income affordability restrictions” means limits imposed by regulation or regulatory agreement on tenant rents, rent contributions, or income eligibility in eligible low-income housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c352a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “low-income families or persons” and “very low-income families or persons” mean families or persons whose incomes do not exceed the respective levels established for low-income families and very low-income families, respectively, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a/b/2"},"text":"section 1437a(b)(2) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c352b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “moderate-income families or persons” means families or persons whose incomes are between 80 percent and 95 percent of the median income for the area, as determined by the Secretary with adjustments for smaller and larger families.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c352c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “nonprofit organization” means any private, nonprofit organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1c352d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is organized or chartered under State or local laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c352e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has no part of its net earnings inuring to the benefit of any member, founder, contributor, or individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c352f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with standards of financial accountability acceptable to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c3530-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has among its principal purposes significant activities related to the provision of decent housing that is affordable to very low-, low-, and moderate-income families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c3531-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “owner” means the current or subsequent owner or owners of eligible low-income housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c3532-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “preservation equity” means, for any eligible low-income housing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1c3533-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for purposes of determining the authorized return under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4104/a"},"text":"section 4104(a) of this title","children":[],"tail":" and providing incentives to extend the low-income affordability restrictions on the housing under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4109"},"text":"section 4109 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"iddd1c3534-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preservation value of the housing determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4103/b/1"},"text":"section 4103(b)(1) of this title","children":[],"tail":"; less"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1c3535-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any debt secured by the property; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c3536-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for purposes of determining incentives under section ","children":[{"tag":"ref","attrib":{"idref":"fn002373"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002373"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “sections”."}],"tail":" 4110 and 4111 of this title and determining the amount of an acquisition loan under the provisions of section 1715z–6(f)(3) "},{"tag":"ref","attrib":{"idref":"fn002374"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002374"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of this title—"}],"tail":null},{"tag":"clause","attrib":{"id":"iddd1c3537-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preservation value of the housing determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4103/b/2"},"text":"section 4103(b)(2) of this title","children":[],"tail":"; less"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd1c3538-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the outstanding balance of the federally-assisted mortgage or mortgages for the housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c3539-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “preservation value” means, for any eligible low-income housing, the applicable value determined under paragraph (1) or (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4103/b"},"text":"section 4103(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c353a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1c353b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “resident council” means any incorporated nonprofit organization or association that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd1c353c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is representative of the residents of the housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c353d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopts written procedures providing for the election of officers on a regular basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd1c353e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4119/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a democratically elected governing board, elected by the residents of the housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1c353f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/tII/s229"},"text":"Pub. L. 100–242, title II, § 229","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVI/s601/a"},"text":"Pub. L. 101–625, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4271"},"text":"104 Stat. 4271","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tIII"},"text":"Pub. L. 102–550, title III","children":[],"tail":", §§ 310, 317(a)(5), "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3765"},"text":"106 Stat. 3765","children":[],"tail":", 3772; "},{"tag":"ref","attrib":{"href":"/us/pl/103/327/tII"},"text":"Pub. L. 103–327, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-28"},"text":"Sept. 28, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2316"},"text":"108 Stat. 2316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1c3540-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1c3541-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd1c3542-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715z–6/f"},"text":"Section 1715z–6(f) of this title","children":[],"tail":", referred to in par. (8)(B), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/204/tII"},"text":"Pub. L. 104–204, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2885"},"text":"110 Stat. 2885","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd1c3543-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/327"},"text":"Pub. L. 103–327","children":[],"tail":" is based on section 601(e) of title VI of S. 2281, One Hundred Third Congress, as reported "},{"tag":"date","attrib":{"date":"1994-07-13"},"text":"July 13, 1994","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/103/327"},"text":"Pub. L. 103–327","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd1c3544-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/327"},"text":"Pub. L. 103–327","children":[],"tail":" temporarily amended par. (4) to read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4)(A) The term ‘low-income tenants’ means families or persons with incomes that exceed 50 percent of the median income for the area (as determined by the Secretary with adjustments for family size) but do not exceed 80 percent of the median income for the area (as determined by the Secretary with adjustments for family size).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) The term ‘very low-income tenants’ means families or persons with incomes that are less than or equal to 50 percent of the median income for the area (as determined by the Secretary with adjustments for family size).” See Effective and Termination Dates of 1994 Amendment note below.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Par. (1)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s310"},"text":"Pub. L. 102–550, § 310","children":[],"tail":", substituted “receiving loan management assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of title 42","children":[],"tail":" due to a conversion from "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701s"},"text":"section 1701s of this title","children":[],"tail":"” for “assisted under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701s"},"text":"section 1701s of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of title 42","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s317/a/5"},"text":"Pub. L. 102–550, § 317(a)(5)","children":[],"tail":", substituted “residents” for “resident”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd1c3545-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd1c3546-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/327"},"text":"Pub. L. 103–327","children":[],"tail":" effective only during fiscal year 1995, see provision of title II of "},{"tag":"ref","attrib":{"href":"/us/pl/103/327"},"text":"Pub. L. 103–327","children":[],"tail":" set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4112"},"text":"section 4112 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
