{"tag":"section","attrib":{"id":"iddd71f60c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516"},"text":null,"children":[{"tag":"num","attrib":{"value":"5516"},"text":"§ 5516.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other banks, savings associations, and credit unions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd71f60d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of coverage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall apply to any covered person that is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd71f60e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insured depository institution with total assets of $10,000,000,000 or less; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd71f60f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insured credit union with total assets of $10,000,000,000 or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd71f610-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may require reports from a person described in subsection (a), as necessary to support the role of the Bureau in implementing Federal consumer financial law, to support its examination activities under subsection (c), and to assess and detect risks to consumers and consumer financial markets.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd71f611-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of existing reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Bureau shall, to the fullest extent possible, use—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd71f612-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reports pertaining to a person described in subsection (a) that have been provided or required to have been provided to a Federal or State agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd71f613-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information that has been reported publicly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd71f614-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection may be construed as limiting the authority of the Director from requiring from a person described in subsection (a), as permitted under paragraph (1), information owned or under the control of such person, regardless of whether such information is maintained, stored, or processed by another person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd71f615-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports of tax law noncompliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall provide the Commissioner of Internal Revenue with any report of examination or related information identifying possible tax law noncompliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd71f616-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd71f617-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau may, at its discretion, include examiners on a sampling basis of the examinations performed by the prudential regulator to assess compliance with the requirements of Federal consumer financial law of persons described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd71f618-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prudential regulator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd71f619-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide all reports, records, and documentation related to the examination process for any institution included in the sample referred to in paragraph (1) to the Bureau on a timely and continual basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd71f61a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve such Bureau examiner in the entire examination process for such person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd71f61b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider input of the Bureau concerning the scope of an examination, conduct of the examination, the contents of the examination report, the designation of matters requiring attention, and examination ratings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd71f61c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd71f61d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except for requiring reports under subsection (b), the prudential regulator is authorized to enforce the requirements of Federal consumer financial laws and, with respect to a covered person described in subsection (a), shall have exclusive authority (relative to the Bureau) to enforce such laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd71f61e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with prudential regulator","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd71f61f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When the Bureau has reason to believe that a person described in subsection (a) has engaged in a material violation of a Federal consumer financial law, the Bureau shall notify the prudential regulator in writing and recommend appropriate action to respond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd71f620-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receiving a recommendation under subparagraph (A), the prudential regulator shall provide a written response to the Bureau not later than 60 days thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd71f621-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5516/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A service provider to a substantial number of persons described in subsection (a) shall be subject to the authority of the Bureau under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5515"},"text":"section 5515 of this title","children":[],"tail":" to the same extent as if the Bureau were an appropriate Federal bank agency under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1867/c"},"text":"section 1867(c) of this title","children":[],"tail":". When conducting any examination or requiring any report from a service provider subject to this subsection, the Bureau shall coordinate with the appropriate prudential regulator."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd71f622-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1026"},"text":"Pub. L. 111–203, title X, § 1026","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1993"},"text":"124 Stat. 1993","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd71f623-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd71f624-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd71f625-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the designated transfer date, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1029A"},"text":"section 1029A of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5511"},"text":"section 5511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
