{"tag":"section","attrib":{"id":"iddd63c5e6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5392"},"text":null,"children":[{"tag":"num","attrib":{"value":"5392"},"text":"§ 5392.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of circumvention and prevention of conflicts of interest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd63c5e7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5392/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No other funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds for the orderly liquidation of any covered financial company under this subchapter shall only be provided as specified under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd63c5e8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5392/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on governmental actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No governmental entity may take any action to circumvent the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd63c5e9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5392/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event that the Corporation is appointed receiver for more than 1 covered financial company or is appointed receiver for a covered financial company and receiver for any insured depository institution that is an affiliate of such covered financial company, the Corporation shall take appropriate action, as necessary to avoid any conflicts of interest that may arise in connection with multiple receiverships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd63c5ea-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tII/s212"},"text":"Pub. L. 111–203, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1516"},"text":"124 Stat. 1516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd63c5eb-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd63c5ec-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd63c5ed-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsecs. (a) and (b), was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1442"},"text":"124 Stat. 1442","children":[],"tail":", which is classified principally to this subchapter. For complete classification of title II to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"