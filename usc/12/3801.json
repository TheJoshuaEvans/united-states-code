{"tag":"section","attrib":{"id":"iddd104e71-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3801"},"text":null,"children":[{"tag":"num","attrib":{"value":"3801"},"text":"§ 3801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd104e72-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3801/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress hereby finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd104e73-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3801/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasingly volatile and dynamic changes in interest rates have seriously impared ","children":[{"tag":"ref","attrib":{"idref":"fn002356"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002356"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “impaired”."}],"tail":" the ability of housing creditors to provide consumers with fixed-term, fixed-rate credit secured by interests in real property, cooperative housing, manufactured homes, and other dwellings;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104e74-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3801/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative mortgage transactions are essential to the provision of an adequate supply of credit secured by residential property necessary to meet the demand expected during the 1980’s; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104e75-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3801/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Comptroller of the Currency, the National Credit Union Administration, and the Director of the Office of Thrift Supervision have recognized the importance of alternative mortgage transactions and have adopted regulations authorizing federally chartered depository institutions to engage in alternative mortgage financing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd104e76-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3801/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the purpose of this chapter to eliminate the discriminatory impact that those regulations have upon nonfederally chartered housing creditors and provide them with parity with federally chartered institutions by authorizing all housing creditors to make, purchase, and enforce alternative mortgage transactions so long as the transactions are in conformity with the regulations issued by the Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd104e77-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320/tVIII/s802"},"text":"Pub. L. 97–320, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1545"},"text":"96 Stat. 1545","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tVII/s744/c"},"text":"Pub. L. 101–73, title VII, § 744(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/438"},"text":"103 Stat. 438","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd104e78-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd104e79-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd104e7a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" substituted “Director of the Office of Thrift Supervision” for “Federal Home Loan Bank Board”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd104e7b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd104e7c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320/tVIII/s807/a"},"text":"Pub. L. 97–320, title VIII, § 807(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1548"},"text":"96 Stat. 1548","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/320/tVIII/s807/a"},"text":"“This title [enacting this chapter] shall be effective upon enactment [","children":[{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"iddd104e7d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320/tVIII/s801"},"text":"Pub. L. 97–320, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1545"},"text":"96 Stat. 1545","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/320/tVIII/s801"},"text":"“This title [enacting this chapter] may be cited as the ‘Alternative Mortgage Transaction Parity Act of 1982’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd104e7e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Identification, Description and Publication of Regulations Inapplicable To, or Conformation of Regulations for Use Of Nonfederally Chartered Housing Creditors","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320/tVIII/s807/b"},"text":"Pub. L. 97–320, title VIII, § 807(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1548"},"text":"96 Stat. 1548","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/320/tVIII/s807/b"},"text":"“Within sixty days of the enactment of this title [","children":[{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":"], the Comptroller of the Currency, the National Credit Union Administration, and the Federal Home Loan Bank Board shall identify, describe, and publish those portions or provisions of their respective regulations that are inappropriate for (and thus inapplicable to), or that need to be conformed for the use of, the nonfederally chartered housing creditors to which their respective regulations apply, including without limitation, making necessary changes in terminology to conform the regulatory and disclosure provisions to those more typically associated with various types of transactions including credit sales.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
