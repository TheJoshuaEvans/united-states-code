{"tag":"section","attrib":{"id":"iddcf85921-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2903"},"text":null,"children":[{"tag":"num","attrib":{"value":"2903"},"text":"§ 2903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial institutions; evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcf85922-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In connection with its examination of a financial institution, the appropriate Federal financial supervisory agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf85923-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2903/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the institution’s record of meeting the credit needs of its entire community, including low- and moderate-income neighborhoods, consistent with the safe and sound operation of such institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf85924-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2903/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such record into account in its evaluation of an application for a deposit facility by such institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf85925-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Majority-owned institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In assessing and taking into account, under subsection (a), the record of a nonminority-owned and nonwomen-owned financial institution, the appropriate Federal financial supervisory agency may consider as a factor capital investment, loan participation, and other ventures undertaken by the institution in cooperation with minority- and women-owned financial institutions and low-income credit unions provided that these activities help meet the credit needs of local communities in which such institutions and credit unions are chartered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf85926-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial holding company requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf85927-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2903/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An election by a bank holding company to become a financial holding company under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1843"},"text":"section 1843 of this title","children":[],"tail":" shall not be effective if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf85928-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2903/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board finds that, as of the date the declaration of such election and the certification is filed by such holding company under section 1843(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(C) "},{"tag":"ref","attrib":{"idref":"fn002324"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002324"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, not all of the subsidiary insured depository institutions of the bank holding company had achieved a rating of “satisfactory record of meeting community credit needs”, or better, at the most recent examination of each such institution; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf85929-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2903/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board notifies the company of such finding before the end of the 30-day period beginning on such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf8592a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2903/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited exclusions for newly acquired insured depository institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any insured depository institution acquired by a bank holding company during the 12-month period preceding the date of the submission to the Board of the declaration and certification under section 1843(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(C) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title may be excluded for purposes of paragraph (1) during the 12-month period beginning on the date of such acquisition if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf8592b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2903/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bank holding company has submitted an affirmative plan to the appropriate Federal financial supervisory agency to take such action as may be necessary in order for such institution to achieve a rating of “satisfactory record of meeting community credit needs”, or better, at the next examination of the institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf8592c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2903/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan has been accepted by such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf8592d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2903/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the following definitions shall apply:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf8592e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2903/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bank holding company; financial holding company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “bank holding company” and “financial holding company” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841"},"text":"section 1841 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf8592f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2903/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the Board of Governors of the Federal Reserve System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf85930-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2903/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insured depository institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “insured depository institution” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/c"},"text":"section 1813(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcf85931-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-cost education loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In assessing and taking into account, under subsection (a), the record of a financial institution, the appropriate Federal financial supervisory agency shall consider, as a factor, low-cost education loans provided by the financial institution to low-income borrowers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf85932-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/128/tVIII/s804"},"text":"Pub. L. 95–128, title VIII, § 804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-12"},"text":"Oct. 12, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1148"},"text":"91 Stat. 1148","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tIX/s909/1"},"text":"Pub. L. 102–550, title IX, § 909(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3874"},"text":"106 Stat. 3874","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tI/s103/b"},"text":"Pub. L. 106–102, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1350"},"text":"113 Stat. 1350","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tX/s1031/a"},"text":"Pub. L. 110–315, title X, § 1031(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3488"},"text":"122 Stat. 3488","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcf85933-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcf85934-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcf85935-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1843(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(C) of this title, referred to in subsec. (c)(1)(A), (2), was redesignated section 1843("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(D) of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVI/s606/a/2"},"text":"Pub. L. 111–203, title VI, § 606(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1607"},"text":"124 Stat. 1607","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcf85936-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Pub. L. 106–102","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcf85937-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcf85938-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Pub. L. 106–102","children":[],"tail":" effective 120 days after "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/s161"},"text":"section 161 of Pub. L. 106–102","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s24"},"text":"section 24 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddcf85939-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/tX/s1031/b"},"text":"Pub. L. 110–315, title X, § 1031(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3488"},"text":"122 Stat. 3488","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/315/tX/s1031/b"},"text":"“Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"], each appropriate Federal financial supervisory agency shall issue rules in final form to implement section 804(d) of the Community Reinvestment Act of 1977 ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2903/d"},"text":"12 U.S.C. 2903(d)","children":[],"tail":"], as added by this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
