{"tag":"section","attrib":{"id":"iddb11e654-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s76"},"text":null,"children":[{"tag":"num","attrib":{"value":"76"},"text":"§ 76.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" President of bank as member of board; chairman of board","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The president of the bank shall be a member of the board and shall be the chairman thereof, but the board may designate a director in lieu of the president to be chairman of the board, who shall perform such duties as may be designated by the board.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb11e655-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 5150; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-02-25/ch191/s6"},"text":"Feb. 25, 1927, ch. 191, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1228"},"text":"44 Stat. 1228","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb11e656-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb11e657-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb11e658-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5150 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-03/ch106/s9"},"text":"act June 3, 1864, ch. 106, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/102"},"text":"13 Stat. 102","children":[],"tail":", which was the National Bank Act. See "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb11e659-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1927—Act ","children":[{"tag":"date","attrib":{"date":"1927-02-25"},"text":"Feb. 25, 1927","children":[],"tail":", amended section generally. Prior to amendment, section read as follows: “One of the directors, to be chosen by the board, shall be president of the board.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
