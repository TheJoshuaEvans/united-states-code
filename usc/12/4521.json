{"tag":"section","attrib":{"id":"iddd281b99-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521"},"text":null,"children":[{"tag":"num","attrib":{"value":"4521"},"text":"§ 4521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports by Director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd281b9a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall submit to the Committee on Financial Services of the House of Representatives and the Committee on Banking, Housing, and Urban Affairs of the Senate, not later than June 15 of each year, a written report, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281b9b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the actions taken, and being undertaken, by the Director to carry out this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281b9c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the financial safety and soundness of each regulated entity, including the results and conclusions of the annual examinations of the regulated entities conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4517/a"},"text":"section 4517(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281b9d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations for legislation to enhance the financial safety and soundness of the regulated entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281b9e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd281b9f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the procedures established by each regulated entity pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4012a/b/3"},"text":"section 4012a(b)(3) of title 42","children":[],"tail":" are adequate and being complied with, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281ba0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results and conclusions of any examination, as determined necessary by the Director, to determine the compliance of the regulated entities with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4012a/b/3"},"text":"section 4012a(b)(3) of title 42","children":[],"tail":", which shall include a description of the methods used to determine compliance and the types and sources of deficiencies (if any), and identify any corrective measures that have been taken to remedy any such deficiencies,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that the information described in this paragraph shall be included only in each of the first, third, and fifth annual reports under this subsection required to be submitted after the expiration of the 1-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1994-09-23"},"text":"September 23, 1994","children":[],"tail":"; and "},{"tag":"ref","attrib":{"idref":"fn002408"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002408"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281ba1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the assessment of the Board or any of its members with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd281ba2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety and soundness of the regulated entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281ba3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any material deficiencies in the conduct of the operations of the regulated entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281ba4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the overall operational status of the regulated entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281ba5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the performance of the regulated entities in carrying out their respective missions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281ba6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operations, resources, and performance of the Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281ba7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters relating to the Agency and the fulfillment of its mission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd281ba8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on enforcement actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than March 15 of each year, the Director shall submit to the Committee on Financial Services of the House of Representatives and the Committee on Banking, Housing, and Urban Affairs of the Senate a written report describing, for the preceding calendar year, the requests by the Director to the Attorney General for enforcement actions under subchapter III and describing the disposition of each request, which shall include statements of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd281ba9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of requests made by the Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281baa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of requests that resulted in the commencement of litigation by the Department of Justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281bab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of requests that did not result in the commencement of litigation by the Department of Justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281bac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to requests that resulted in the commencement of litigation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd281bad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of days between the date of the request and the commencement of the litigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd281bae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of days between the date of the commencement and termination of the litigation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd281baf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4521/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of litigation requests pending at the beginning of the calendar year, the number of requests made during the calendar year, the number of requests for which action was completed during the calendar year, and the number of requests pending at the end of the calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd281bb0-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1319B"},"text":"Pub. L. 102–550, title XIII, § 1319B","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3950"},"text":"106 Stat. 3950","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tV/s529/c"},"text":"Pub. L. 103–325, title V, § 529(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2267"},"text":"108 Stat. 2267","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI"},"text":"Pub. L. 110–289, div. A, title I","children":[],"tail":", §§ 1103(b), 1161(a)(6), "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2665"},"text":"122 Stat. 2665","children":[],"tail":", 2779.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd281bb1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd281bb2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd281bb3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(1), was in the original “this title”, meaning title XIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3941"},"text":"106 Stat. 3941","children":[],"tail":", which is classified principally to this chapter. For complete classification of title XIII to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4501"},"text":"section 4501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd281bb4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1161/a/6"},"text":"Pub. L. 110–289, § 1161(a)(6)","children":[],"tail":", substituted “Committee on Financial Services” for “Committee on Banking, Finance and Urban Affairs” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1103/b/1"},"text":"Pub. L. 110–289, § 1103(b)(1)","children":[],"tail":"–(4), substituted “regulated entity” for “enterprise” and “regulated entities” for “enterprises” wherever appearing and substituted a semicolon for “; and” at end of par. (3) and “1994; and” for “1994.” at end of par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1103/b/5"},"text":"Pub. L. 110–289, § 1103(b)(5)","children":[],"tail":", added pars. (5) to (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s1161/a/6"},"text":"Pub. L. 110–289, § 1161(a)(6)","children":[],"tail":", substituted “Committee on Financial Services” for “Committee on Banking, Finance and Urban Affairs” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
