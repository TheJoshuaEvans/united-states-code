{"tag":"section","attrib":{"id":"iddcec729e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279aa–10"},"text":"§ 2279aa–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for guarantee; reserves of Corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcec729f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall provide guarantees for securities representing interests in, or obligations backed by, pools of qualified loans through commitments issued by the Corporation providing for guarantees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec72a0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantee fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec72a1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–10/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the time a guarantee is issued by the Corporation, the Corporation shall assess the certified facility a fee of not more than ½ of 1 percent of the initial principal amount of each pool of qualified loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec72a2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–10/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in the second year after the date the guarantee is issued under paragraph (1), the Corporation may, at the end of each year, assess the certified facility an annual fee of not more than ½ of 1 percent of the principal amount of the loans then constituting the pool.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec72a3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–10/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall establish such fees on the amount of risk incurred by the Corporation in providing the guarantees with respect to which such fee is assessed, as determined by the Corporation. Fees assessed under paragraphs (1) and (2) shall be established on an actuarially sound basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec72a4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–10/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by GAO","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States may review, and submit to the Congress a report regarding, the actuarial soundness and reasonableness of the fees established by the Corporation under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec72a5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–10/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation reserve against guarantees losses required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcec72a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–10/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"So much of the fees assessed under this section as the Board determines to be necessary shall be set aside by the Corporation in a segregated account as a reserve against losses arising out of the guarantee activities of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcec72a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–10/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exhaustion of reserve required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may not issue obligations to the Secretary of the Treasury under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa–13"},"text":"section 2279aa–13 of this title","children":[],"tail":" in order to meet the obligations of the Corporation with respect to any guarantees provided under this subchapter until the reserve established under paragraph (1) has been exhausted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcec72a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279aa–10/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees to cover administrative costs authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may impose charges or fees in reasonable amounts in connection with the administration of its activities under this subchapter to recover its costs for performing such administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcec72a9-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVIII/s8"},"text":"Pub. L. 92–181, title VIII, § 8","children":[],"tail":".10, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVII/s702"},"text":"Pub. L. 100–233, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1701"},"text":"101 Stat. 1701","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s106/f"},"text":"Pub. L. 104–316, title I, § 106(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3831"},"text":"110 Stat. 3831","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcec72aa-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcec72ab-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcec72ac-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316"},"text":"Pub. L. 104–316","children":[],"tail":" substituted “Review” for “Annual review” in heading and “may review” for “shall annually review” in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
