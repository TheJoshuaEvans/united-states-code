{"tag":"section","attrib":{"id":"iddb71438e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1426a"},"text":"§ 1426a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion from certain requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb71438f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Home Loan Banks shall be exempt from compliance with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb714390-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 78m(e), 78n(a), and 78n(c) of title 15, and related Commission regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb714391-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 78","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of title 15, and related Commission regulations, with respect to transactions in the capital stock of a Federal Home Loan Bank;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb714392-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78q–1"},"text":"section 78q–1 of title 15","children":[],"tail":", and related Commission regulations, with respect to the transfer of the securities of a Federal Home Loan Bank; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb714393-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Trust Indenture Act of 1939 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77aaa"},"text":"15 U.S.C. 77aaa","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb714394-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Member exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Federal Home Loan Bank System shall be exempt from compliance with sections 78m(d), 78m(f), 78m(g), 78n(d), and 78p of title 15, and related Commission regulations, with respect to ownership of or transactions in the capital stock of the Federal Home Loan Banks by such members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb714395-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempted and Government securities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb714396-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital stock","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The capital stock issued by each of the Federal Home Loan Banks under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1426"},"text":"section 1426 of this title","children":[],"tail":" are—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb714397-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempted securities, within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77c/a/2"},"text":"section 77c(a)(2) of title 15","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb714398-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempted securities, within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/12/A"},"text":"section 78c(a)(12)(A) of title 15","children":[],"tail":", except to the extent provided in section 78"},{"tag":"i","attrib":{},"text":"oo","children":[],"tail":" of title 15."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb714399-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other obligations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The debentures, bonds, and other obligations issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1431"},"text":"section 1431 of this title","children":[],"tail":" are—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb71439a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempted securities, within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77c/a/2"},"text":"section 77c(a)(2) of title 15","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb71439b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" government securities, within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/42"},"text":"section 78c(a)(42) of title 15","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb71439c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" government securities, within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–2/a/16"},"text":"section 80a–2(a)(16) of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb71439d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Brokers and dealers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person (other than a Federal Home Loan Bank effecting transactions for members of the Federal Home Loan Bank System) that effects transactions in the capital stock or other obligations of a Federal Home Loan Bank, for the account of others or for that person’s own account, as applicable, is a broker or dealer, as those terms are defined in paragraphs (4) and (5), respectively, of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a"},"text":"section 78c(a) of title 15","children":[],"tail":", but is excluded from the definition of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb71439e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “government securities broker” under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/43"},"text":"section 78c(a)(43) of title 15","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb71439f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “government securities dealer” under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/44"},"text":"section 78c(a)(44) of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb7143a0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from reporting requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Home Loan Banks shall be exempt from periodic reporting requirements under the securities laws pertaining to the disclosure of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb7143a1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related party transactions that occur in the ordinary course of the business of the Banks with members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb7143a2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unregistered sales of equity securities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb7143a3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tender offers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Commission rules relating to tender offers shall not apply in connection with transactions in the capital stock of the Federal Home Loan Banks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb7143a4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb7143a5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall promulgate such rules and regulations as may be necessary or appropriate in the public interest or in furtherance of this section and the exemptions provided in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb7143a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In issuing regulations under this section, the Commission shall consider the distinctive characteristics of the Federal Home Loan Banks when evaluating—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb7143a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accounting treatment with respect to the payment to the Resolution Funding Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb7143a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role of the combined financial statements of the Federal Home Loan Banks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb7143a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accounting classification of redeemable capital stock; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb7143aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accounting treatment related to the joint and several nature of the obligations of the Banks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb7143ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb7143ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “Bank”, “Federal Home Loan Bank”, “member”, and “Federal Home Loan Bank System” have the same meanings as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1422"},"text":"section 1422 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb7143ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Commission” means the Securities and Exchange Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb7143ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1426a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “securities laws” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/47"},"text":"section 78c(a)(47) of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb7143af-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tII/s1208"},"text":"Pub. L. 110–289, div. A, title II, § 1208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2788"},"text":"122 Stat. 2788","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb7143b0-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb7143b1-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb7143b2-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Trust Indenture Act of 1939, referred to in subsec. (a)(4), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"act May 27, 1933, ch. 38","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-03/ch411"},"text":"Aug. 3, 1939, ch. 411","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1149"},"text":"53 Stat. 1149","children":[],"tail":", which is classified generally to subchapter III (§ 77aaa et seq.) of chapter 2A of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77aaa"},"text":"section 77aaa of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb7143b3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Housing and Economic Recovery Act of 2008, and also as part of the Federal Housing Finance Regulatory Reform Act of 2008, and not as part of the Federal Home Loan Bank Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
