{"tag":"section","attrib":{"id":"iddd38be54-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704"},"text":null,"children":[{"tag":"num","attrib":{"value":"4704"},"text":"§ 4704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications for assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd38be55-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application for assistance under this subchapter shall be submitted in such form and in accordance with such procedures as the Fund shall establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38be56-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in sections 4705 and 4712 of this title, the Fund shall require an application—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd38be57-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish that the applicant is, or will be, a community development financial institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be58-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to include a comprehensive strategic plan for the organization that contains—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd38be59-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a business plan of not less than 5 years in duration that demonstrates that the applicant will be properly managed and will have the capacity to operate as a community development financial institution that will not be dependent upon assistance from the Fund for continued viability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38be5a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the needs of the investment area or targeted population and a strategy for how the applicant will attempt to meet those needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38be5b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan to coordinate use of assistance from the Fund with existing Federal, State, local, and tribal government assistance programs, and private sector financial services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38be5c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of how the proposed activities of the applicant are consistent with existing economic, community, and housing development plans adopted by or applicable to an investment area or targeted population; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38be5d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the applicant will coordinate with community organizations and financial institutions which will provide equity investments, loans, secondary markets, or other services to investment areas or targeted populations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be5e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to include a detailed description of the applicant’s plans and likely sources of funds to match the amount of assistance requested from the Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be5f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an applicant that has previously received assistance under this subchapter, to demonstrate that the applicant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd38be60-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has substantially met its performance goals and otherwise carried out its responsibilities under this subchapter and the assistance agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38be61-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will expand its operations into a new investment area or serve a new targeted population, offer more products or services, or increase the volume of its business;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be62-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an applicant with a prior history of serving investment areas or targeted populations, to demonstrate that the applicant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd38be63-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a record of success in serving investment areas or targeted populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd38be64-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will expand its operations into a new investment area or to serve a new targeted population, offer more products or services, or increase the volume of its current business; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be65-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to include such other information as the Fund deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38be66-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preapplication outreach program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund shall provide an outreach program to identify and provide information to potential applicants and may provide technical assistance to potential applicants, but shall not assist in the preparation of any application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd38be67-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s105"},"text":"Pub. L. 103–325, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2170"},"text":"108 Stat. 2170","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
