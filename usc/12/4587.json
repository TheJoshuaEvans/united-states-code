{"tag":"section","attrib":{"id":"iddd2cd785-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4587"},"text":null,"children":[{"tag":"num","attrib":{"value":"4587"},"text":"§ 4587.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any service required or authorized to be made by the Director under this subpart may be made by registered mail or in such other manner reasonably calculated to give actual notice, as the Director may by regulation or otherwise provide.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd2cd786-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1347"},"text":"Pub. L. 102–550, title XIII, § 1347","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3968"},"text":"106 Stat. 3968","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1130/e/3/D"},"text":"Pub. L. 110–289, div. A, title I, § 1130(e)(3)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2711"},"text":"122 Stat. 2711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2cd787-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2cd788-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd2cd789-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","