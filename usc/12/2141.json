{"tag":"section","attrib":{"id":"iddcc64c27-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2141"},"text":null,"children":[{"tag":"num","attrib":{"value":"2141"},"text":"§ 2141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charter, powers, and operation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcc64c28-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2141/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Bank for Cooperatives (hereinafter in this part referred to as the “consolidated bank”), established under section 413 of the Agricultural Credit Act of 1987, shall be a federally chartered instrumentality of the United States and an institution of the Farm Credit System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc64c29-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2141/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The consolidated bank and the board of directors of such bank shall have all of the powers, rights, responsibilities, and obligations of the constituent banks described in section 413(b) of the Agricultural Credit Act of 1987 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2121"},"text":"12 U.S.C. 2121","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Public Law 100–233","children":[],"tail":") and the boards of directors of such banks, except as otherwise provided for in this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcc64c2a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2141/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The consolidated bank shall be organized and operated on a cooperative basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcc64c2b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIII/s3"},"text":"Pub. L. 92–181, title III, § 3","children":[],"tail":".20, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s415/2"},"text":"Pub. L. 100–233, title IV, § 415(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1642"},"text":"101 Stat. 1642","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s407/a"},"text":"Pub. L. 100–399, title IV, § 407(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1000"},"text":"102 Stat. 1000","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5411/13"},"text":"Pub. L. 115–334, title V, § 5411(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4680"},"text":"132 Stat. 4680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcc64c2c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcc64c2d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddcc64c2e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 413 of the Agricultural Credit Act of 1987, referred to in subsecs. (a) and (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/s413"},"text":"section 413 of Pub. L. 100–233","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2121"},"text":"section 2121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcc64c2f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/13/A"},"text":"Pub. L. 115–334, § 5411(13)(A)","children":[],"tail":", struck out “or the United Bank for Cooperatives, as the case may be” after “National Bank for Cooperatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s5411/13/B"},"text":"Pub. L. 115–334, § 5411(13)(B)","children":[],"tail":", substituted “the constituent banks described in section 413(b) of the Agricultural Credit Act of 1987 ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2121"},"text":"12 U.S.C. 2121","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Public Law 100–233","children":[],"tail":")” for “the district banks for cooperatives and the Central Bank for Cooperatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s407/a"},"text":"