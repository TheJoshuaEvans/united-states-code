{"tag":"section","attrib":{"id":"iddcd23355-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2270"},"text":null,"children":[{"tag":"num","attrib":{"value":"2270"},"text":"§ 2270.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement of suspended or removed directors","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If at any time, because of the suspension or removal of one or more directors pursuant to section 2264 or 2265 of this title, there shall be on the board of directors of a System institution less than a quorum of directors not so suspended, the Chairman shall appoint persons to serve temporarily as directors in their place and stead so as to establish a quorum until such time as those who have been removed are reinstated or their respective successors are duly elected and take office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddcd23356-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".34, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s204"},"text":"Pub. L. 99–205, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1701"},"text":"99 Stat. 1701","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcd23357-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcd23358-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddcd23359-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective thirty days after ","children":[{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/s401"},"text":"section 401 of Pub. L. 99–205","children":[],"tail":", set out as an Effective Date of 1985 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
