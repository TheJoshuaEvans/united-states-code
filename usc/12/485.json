{"tag":"section","attrib":{"id":"iddb4662f7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s485"},"text":null,"children":[{"tag":"num","attrib":{"value":"485"},"text":"§ 485.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of Federal reserve banks","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board of Governors of the Federal Reserve System shall, at least once each year, order an examination of each Federal reserve bank, and upon joint application of ten member banks the Board of Governors of the Federal Reserve System shall order a special examination and report of the condition of any Federal reserve bank.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb4662f8-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 5240 (par.); ","children":[{"tag":"ref","attrib":{"href":"/us/act/1875-02-19/ch89"},"text":"Feb. 19, 1875, ch. 89","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/18/329"},"text":"18 Stat. 329","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s21"},"text":"Dec. 23, 1913, ch. 6, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/272"},"text":"38 Stat. 272","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-23/ch614"},"text":"Aug. 23, 1935, ch. 614","children":[],"tail":", title II, § 203(a), "},{"tag":"ref","attrib":{"href":"/us/stat/49/704"},"text":"49 Stat. 704","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb4662f9-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb4662fa-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb4662fb-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5240 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-03/ch106/s54"},"text":"act June 3, 1864, ch. 106, § 54","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/116"},"text":"13 Stat. 116","children":[],"tail":", which was part of the National Bank Act. See "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of seventh par. of R.S. § 5240, as amended. See Codification note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s481"},"text":"section 481 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb4662fc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddb4662fd-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 203(a) of act ","children":[{"tag":"date","attrib":{"date":"1935-08-23"},"text":"Aug. 23, 1935","children":[],"tail":", changed name of Federal Reserve Board to Board of Governors of the Federal Reserve System."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
