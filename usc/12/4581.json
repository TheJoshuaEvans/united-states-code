{"tag":"section","attrib":{"id":"iddd2cd726-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4581"},"text":null,"children":[{"tag":"num","attrib":{"value":"4581"},"text":"§ 4581.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cease and desist proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd2cd727-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4581/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grounds for issuance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may issue and serve a notice of charges under this section upon an enterprise if the Director determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd728-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4581/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enterprise has failed to submit a report under section 4547 ","children":[{"tag":"ref","attrib":{"idref":"fn002419"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002419"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, following a notice of such failure, an opportunity for comment by the enterprise, and a final determination by the Director;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd729-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4581/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enterprise has failed to submit the information required under subsection (m) or (n) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1723a"},"text":"section 1723a of this title","children":[],"tail":", or subsection (e) or (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1456"},"text":"section 1456 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd72a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4581/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solely with respect to the housing goals established under sections 4562(a) and 4563(a)(1) of this title, the enterprise has failed to submit a housing plan that complies with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4566/c"},"text":"section 4566(c) of this title","children":[],"tail":" within the applicable period; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd72b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4581/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solely with respect to the housing goals established under sections 4562(a) and 4563(a)(1) of this title, the enterprise has failed to comply with a housing plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4566/c"},"text":"section 4566(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd72c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4581/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd2cd72d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4581/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of charges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each notice of charges issued under this section shall contain a statement of the facts constituting the alleged conduct and shall fix a time and place at which a hearing will be held to determine on the record whether an order to cease and desist from such conduct should issue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd2cd72e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4581/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Director finds on the record made at a hearing described in paragraph (1) that any conduct specified in the notice of charges has been established (or the enterprise consents pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4582/a/4"},"text":"section 4582(a)(4) of this title","children":[],"tail":"), the Director may issue and serve upon the enterprise an order requiring the enterprise to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd2cd72f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4581/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a report under section 4547 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd730-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4581/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solely with respect to the housing goals established under sections 4562(a) and 4563(a)(1) of this title, submit a housing plan in compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4566/c"},"text":"section 4566(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd731-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4581/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solely with respect to the housing goals established under sections 4562(a) and 4563(a)(1) of this title, comply with the housing plan in compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4566/c"},"text":"section 4566(c) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd2cd732-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4581/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the information required under subsection (m) or (n) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1723a"},"text":"section 1723a of this title","children":[],"tail":", or subsection (e) or (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1456"},"text":"section 1456 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd2cd733-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4581/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An order under this section shall become effective upon the expiration of the 30-day period beginning on the date of service of the order upon the enterprise (except in the case of an order issued upon consent, which shall become effective at the time specified therein), and shall remain effective and enforceable as provided in the order, except to the extent that the order is stayed, modified, terminated, or set aside by action of the Director or otherwise, as provided in this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd2cd734-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1341"},"text":"Pub. L. 102–550, title XIII, § 1341","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1130/c/2"},"text":"Pub. L. 110–289, div. A, title I, § 1130(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2708"},"text":"122 Stat. 2708","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd2cd735-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd2cd736-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd2cd737-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4547"},"text":"Section 4547 of this title","children":[],"tail":", referred to in subsecs. (a)(1) and (b)(2)(A), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1104/b"},"text":"Pub. L. 110–289, div. A, title I, § 1104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2667"},"text":"122 Stat. 2667","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddd2cd738-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4581, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1341"},"text":"Pub. L. 102–550, title XIII, § 1341","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3964"},"text":"106 Stat. 3964","children":[],"tail":", related to cease-and-desist proceedings, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1130/c/1"},"text":"Pub. L. 110–289, div. A, title I, § 1130(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2708"},"text":"122 Stat. 2708","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
