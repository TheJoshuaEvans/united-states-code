{"tag":"section","attrib":{"id":"iddcb0f03d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1846"},"text":null,"children":[{"tag":"num","attrib":{"value":"1846"},"text":"§ 1846.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of rights to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcb33a2e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1846/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this chapter shall be construed as preventing any State from exercising such powers and jurisdiction which it now has or may hereafter have with respect to companies, banks, bank holding companies, and subsidiaries thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcb33a2f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1846/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State taxation authority not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this chapter shall be construed as affecting the authority of any State or political subdivision of any State to adopt, apply, or administer any tax or method of taxation to any bank, bank holding company, or foreign bank, or any affiliate of any bank, bank holding company, or foreign bank, to the extent that such tax or tax method is otherwise permissible by or under the Constitution of the United States or other Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcb33a30-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-05-09/ch240/s7"},"text":"May 9, 1956, ch. 240, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/138"},"text":"70 Stat. 138","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/86/tI/s101/f"},"text":"Pub. L. 100–86, title I, § 101(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/563"},"text":"101 Stat. 563","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/328/tI/s101/b"},"text":"Pub. L. 103–328, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-29"},"text":"Sept. 29, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2341"},"text":"108 Stat. 2341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddcb33a31-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddcb33a32-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddcb33a33-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/328"},"text":"Pub. L. 103–328","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86"},"text":"Pub. L. 100–86","children":[],"tail":" substituted “No provision of this chapter shall” for “The enactment by the Congress of this chapter shall not” and inserted “companies,” before “banks,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddcb33a34-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddcb33a35-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/328"},"text":"Pub. L. 103–328","children":[],"tail":" effective at end of 1-year period beginning on "},{"tag":"date","attrib":{"date":"1994-09-29"},"text":"Sept. 29, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/328/s101/e"},"text":"section 101(e) of Pub. L. 103–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1828"},"text":"section 1828 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
