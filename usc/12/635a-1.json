{"tag":"section","attrib":{"id":"iddb5be6bd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"635a–1"},"text":"§ 635a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export credit competition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb5be6be-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635a–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President is authorized and requested to begin negotiations at the ministerial level with other major exporting countries to end predatory export financing programs and other forms of export subsidies, including mixed credits, in third country markets as well as within the United States. The President shall report to the Congress prior to ","children":[{"tag":"date","attrib":{"date":"1979-01-15"},"text":"January 15, 1979","children":[],"tail":", on progress toward meeting the goals of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb5be6bf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s635a–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Export-Import Bank of the United States is authorized to provide guarantees, insurance, and extensions of credit at rates and terms and other conditions which are, in the opinion of the Board of Directors of the Bank, competitive with those provided by the government-supported export credit instrumentalities of other nations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb5be6c0-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXIX/s1908"},"text":"Pub. L. 95–630, title XIX, § 1908","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3725"},"text":"92 Stat. 3725","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb5be6c1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb5be6c2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb5be6c3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Export-Import Bank Act Amendments of 1978, and not as part of the Export-Import Bank Act of 1945 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb5be6c4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddb5be6c5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/s1917"},"text":"section 1917 of Pub. L. 95–630","children":[],"tail":", set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s635"},"text":"section 635 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
