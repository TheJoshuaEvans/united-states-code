{"tag":"section","attrib":{"id":"iddd104dc1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3757"},"text":null,"children":[{"tag":"num","attrib":{"value":"3757"},"text":"§ 3757.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of default and foreclosure sale","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The notice of default and foreclosure sale to be served in accordance with this chapter shall set forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd104dc2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3757/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the foreclosure commissioner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104dc3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3757/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the notice is issued;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104dc4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3757/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the names of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd104dc5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3757/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd104dc6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3757/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the original mortgagee (if other than the Secretary); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd104dc7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3757/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the original mortgagor;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104dc8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3757/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the street address or a description of the location of the security property, and a description of the security property, sufficient to identify the property to be sold;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104dc9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3757/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the mortgage, the office in which the mortgage is recorded, and the liber number and folio or other appropriate description of the location of recordation of the mortgage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104dca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3757/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of the failure to make payment, including the due date of the earliest installment payment remaining wholly unpaid as of the date on which the notice is issued upon which the foreclosure is based, or a description of any other default or defaults upon which foreclosure is based, and the acceleration of the secured indebtedness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104dcb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3757/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date, time, and location of the foreclosure sale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104dcc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3757/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement that the foreclosure is being conducted pursuant to this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104dcd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3757/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the types of costs, if any, to be paid by the purchaser upon transfer of title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104dce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3757/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and method of deposit to be required at the foreclosure sale (except that no deposit shall be required of the Secretary) and the time and method of payment of the balance of the foreclosure purchase price; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104dcf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3757/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other appropriate terms of sale or information, as the Secretary may determine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd104dd0-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/327/tII"},"text":"Pub. L. 103–327, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-28"},"text":"Sept. 28, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2316"},"text":"108 Stat. 2316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd104dd1-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd104dd2-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd104dd3-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 808 of title VIII of S. 2281, One Hundred Third Congress, as reported ","children":[{"tag":"date","attrib":{"date":"1994-07-13"},"text":"July 13, 1994","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/103/327"},"text":"Pub. L. 103–327","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
