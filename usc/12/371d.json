{"tag":"section","attrib":{"id":"iddb3ced1b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371d"},"text":null,"children":[{"tag":"num","attrib":{"value":"371d"},"text":"§ 371d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment in bank premises or stock of corporation holding premises","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb3ced1c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions of investment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No national bank or State member bank shall invest in bank premises, or in the stock, bonds, debentures, or other such obligations of any corporation holding the premises of such bank, or make loans to or upon the security of any such corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb3ced1d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless the bank receives the prior approval of the Comptroller of the Currency (with respect to a national bank) or the Board (with respect to a State member bank);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3ced1e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless the aggregate of all such investments and loans, together with the amount of any indebtedness incurred by any such corporation that is an affiliate of the bank, is less than or equal to the amount of the capital stock of such bank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3ced1f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb3ced20-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371d/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate of all such investments and loans, together with the amount of any indebtedness incurred by any such corporation that is an affiliate of the bank, is less than or equal to 150 percent of the capital and surplus of the bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb3ced21-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371d/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the bank—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddb3ced22-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371d/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a CAMEL composite rating of 1 or 2 under the Uniform Financial Institutions Rating System (or an equivalent rating under a comparable rating system) as of the most recent examination of such bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3ced23-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371d/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is well capitalized and will continue to be well capitalized after the investment or loan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddb3ced24-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371d/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides notification to the Comptroller of the Currency (with respect to a national bank) or to the Board (with respect to a State member bank) not later than 30 days after making the investment or loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb3ced25-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb3ced26-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “affiliate” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s221a"},"text":"section 221a of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb3ced27-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s371d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “well capitalized” has the same meaning as in section 1831","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(b) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb3ced28-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s24A"},"text":"Dec. 23, 1913, ch. 6, § 24A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1933-06-16/ch89/s14"},"text":"June 16, 1933, ch. 89, § 14","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/184"},"text":"48 Stat. 184","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-23/ch614"},"text":"Aug. 23, 1935, ch. 614","children":[],"tail":", title II, § 203(a), "},{"tag":"ref","attrib":{"href":"/us/stat/49/704"},"text":"49 Stat. 704","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-06-30/ch434/s2"},"text":"June 30, 1954, ch. 434, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/358"},"text":"68 Stat. 358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2206"},"text":"Pub. L. 104–208, div. A, title II, § 2206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-405"},"text":"110 Stat. 3009–405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb3ced29-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb3ced2a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb3ced2b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" inserted section catchline and amended text generally. Prior to amendment, text read as follows: “No national bank, without the approval of the Comptroller of the Currency, and no State member bank, without the approval of the Board of Governors of the Federal Reserve System, shall (1) invest in bank premises, or in the stock, bonds, debentures, or other such obligations of any corporation holding the premises of such bank, or (2) make loans to or upon the security of the stock of any such corporation, if the aggregate of all such investments and loans, together with the amount of any indebtedness incurred by any such corporation which is an affiliate of the bank, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s221a"},"text":"section 221a of this title","children":[],"tail":", will exceed the amount of the capital stock of such bank.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-06-30"},"text":"June 30, 1954","children":[],"tail":", inserted “together with the amount of any indebtedness incurred by any such corporation which is an affiliate of the bank, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s221a"},"text":"section 221a of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb3ced2c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddb3ced2d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 203(a) of act ","children":[{"tag":"date","attrib":{"date":"1935-08-23"},"text":"Aug. 23, 1935","children":[],"tail":", changed name of Federal Reserve Board to Board of Governors of the Federal Reserve System."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddb3ced2e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb3ced2f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exception as to Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested by any provision of law in Comptroller of the Currency, referred to in this section, not included in transfer of functions to Secretary of the Treasury, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
