{"tag":"section","attrib":{"id":"iddd44a519-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5010"},"text":null,"children":[{"tag":"num","attrib":{"value":"5010"},"text":"§ 5010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations and notice of claim","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd44a51a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5010/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions under this chapter","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a51b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5010/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An action to enforce a claim under this chapter may be brought in any United States district court, or in any other court of competent jurisdiction, before the end of the 1-year period beginning on the date the cause of action accrues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a51c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5010/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accrual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A cause of action accrues as of the date the injured party first learns, or by which such person reasonably should have learned, of the facts and circumstances giving rise to the cause of action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a51d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5010/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge of claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (c), unless a person gives notice of a claim to the indemnifying or warranting bank within 30 days after the person has reason to know of the claim and the identity of the indemnifying or warranting bank, the indemnifying or warranting bank is discharged from liability in an action to enforce a claim under this chapter to the extent of any loss caused by the delay in giving notice of the claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd44a51e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5010/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of claim by consumer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A timely claim by a consumer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5006"},"text":"section 5006 of this title","children":[],"tail":" for expedited recredit constitutes timely notice of a claim by the consumer for purposes of subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd44a51f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100/s11"},"text":"Pub. L. 108–100, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1188"},"text":"117 Stat. 1188","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd44a520-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd44a521-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd44a522-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(1), (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/100"},"text":"Pub. L. 108–100","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1177"},"text":"117 Stat. 1177","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5001"},"text":"section 5001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd44a523-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd44a524-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective at the end of the 12-month period beginning on ","children":[{"tag":"date","attrib":{"date":"2003-10-28"},"text":"Oct. 28, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/100/s20"},"text":"section 20 of Pub. L. 108–100","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
