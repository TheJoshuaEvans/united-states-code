{"tag":"section","attrib":{"id":"iddd38be78-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4706"},"text":null,"children":[{"tag":"num","attrib":{"value":"4706"},"text":"§ 4706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd38be79-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4712"},"text":"section 4712 of this title","children":[],"tail":", the Fund shall, in its sole discretion, select community development financial institution applicants meeting the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4704"},"text":"section 4704 of this title","children":[],"tail":" for assistance based on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd38be7a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the likelihood of success of the applicant in meeting the goals of its comprehensive strategic plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be7b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the experience and background of the management team;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be7c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4706/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of need for equity investments, loans, and development services within the investment areas or targeted populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be7d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4706/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of economic distress within the investment areas or the extent of need within the targeted populations, as those factors are measured by objective criteria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be7e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4706/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the applicant will concentrate its activities on serving its investment areas or targeted populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be7f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4706/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of firm commitments to meet or exceed the matching requirements and the likely success of the plan for raising the balance of the match;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be80-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4706/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the matching funds are derived from private sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be81-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4706/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the proposed activities will expand economic opportunities within the investment areas or the targeted populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be82-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4706/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the applicant is, or will become, an insured community development financial institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be83-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4706/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of support from the investment areas or targeted populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be84-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4706/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the applicant is, or will be, community-owned or community-governed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be85-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4706/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the applicant will increase its resources through coordination with other institutions or participation in a secondary market;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be86-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4706/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an applicant with a prior history of serving investment areas or targeted populations, the extent of success in serving them; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd38be87-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4706/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors deemed to be appropriate by the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd38be88-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic diversity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting applicants for assistance, the Fund shall seek to fund a geographically diverse group of applicants, which shall include applicants from metropolitan, nonmetropolitan, and rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd38be89-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s107"},"text":"Pub. L. 103–325, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2172"},"text":"108 Stat. 2172","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
