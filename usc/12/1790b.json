{"tag":"section","attrib":{"id":"iddc5896a3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1790b"},"text":"§ 1790b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit union employee protection remedy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc5896a4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc5896a5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees of credit unions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No insured credit union may discharge or otherwise discriminate against any employee with respect to compensation, terms, conditions, or privileges of employment because the employee (or any person acting pursuant to the request of the employee) provided information to the Board or the Attorney General regarding any possible violation of any law or regulation by the credit union or any director, officer, or employee of the credit union.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5896a6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees of the Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administration may not discharge or otherwise discriminate against any employee (including any employee of the National Credit Union Central Liquidity Facility) with respect to compensation, terms, conditions, or privileges of employment because the employee (or any person acting pursuant to the request of the employee) provided information to the Administration or the Attorney General regarding any possible violation of any law or regulation by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc5896a7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any credit union or the Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc5896a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any director, officer, committee member, or employee of any credit union; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc5896a9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any officer or employee of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5896aa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any employee or former employee who believes he has been discharged or discriminated against in violation of subsection (a) may file a civil action in the appropriate United States district court before the close of the 2-year period beginning on the date of such discharge or discrimination. The complainant shall also file a copy of the complaint initiating such action with the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5896ab-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the district court determines that a violation of subsection (a) has occurred, it may order the credit union or the Administration which committed the violation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc5896ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reinstate the employee to his former position,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5896ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay compensatory damages, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5896ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take other appropriate actions to remedy any past discrimination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc5896af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The protections of this section shall not apply to any employee who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc5896b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deliberately causes or participates in the alleged violation of law or regulation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc5896b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1790b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly or recklessly provides substantially false information to such an agency or the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc5896b2-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title II, § 213, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX/s932/b"},"text":"Pub. L. 101–73, title IX, § 932(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/494"},"text":"103 Stat. 494","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s251/b/1"},"text":"Pub. L. 102–242, title II, § 251(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2332"},"text":"105 Stat. 2332","children":[],"tail":", 2333; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXVI/s1604/d"},"text":"Pub. L. 102–550, title XVI, § 1604(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4084"},"text":"106 Stat. 4084","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc5896b3-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc5896b4-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc5896b5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" substituted, in subpar. (A), “union or the” for “union the” and in subpar. (B), “committee member, or employee of any credit union” for “or employee of any depository institution or any such bank”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s251/b/1"},"text":"Pub. L. 102–242, § 251(b)(1)","children":[],"tail":", substituted “In general” for “Prohibition against discrimination against whistleblowers” in heading and amended text generally. Prior to amendment, text read as follows: “No federally insured credit union may discharge or otherwise discriminate against any employee with respect to compensation, terms, conditions, or privileges of employment because the employee (or any person acting pursuant to the request of the employee) provided information to the Board or to the Attorney General regarding a possible violation of any law or regulation by the credit union or any of its officers, directors, or employees.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/s251/b/2"},"text":"Pub. L. 102–242, § 251(b)(2)","children":[],"tail":", inserted “or the Administration” after “the credit union”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddc5896b6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc5896b7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" effective as if included in the Federal Deposit Insurance Corporation Improvement Act of 1991, "},{"tag":"ref","attrib":{"href":"/us/pl/102/242"},"text":"Pub. L. 102–242","children":[],"tail":", as of "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s1609/a"},"text":"section 1609(a) of Pub. L. 102–550","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s191"},"text":"section 191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddc5896b8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s251/b/3"},"text":"Pub. L. 102–242, title II, § 251(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2333"},"text":"105 Stat. 2333","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/242/tII/s251/b/3"},"text":"“Paragraph (2) of section 213(a) of the Federal Credit Union Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1790b/a/2"},"text":"12 U.S.C. 1790b(a)(2)","children":[],"tail":"] (as added under the amendment made by paragraph (1)) shall be treated as having taken effect on "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", and for purposes of any cause of action arising under such paragraph (as so effective) before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":"], the 2-year period referred to in section 213(b) of such Act shall be deemed to begin on such date of enactment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
