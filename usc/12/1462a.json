{"tag":"section","attrib":{"id":"iddb86c79d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1462a"},"text":"§ 1462a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb86c79e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with subtitle A of title III of the Dodd-Frank Wall Street Reform and Consumer Protection Act, the appropriate Federal banking agency shall have all powers which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb86c79f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were vested in the Federal Home Loan Bank Board (in the Board’s capacity as such) or the Chairman of such Board on the day before the date of the enactment of the Financial Institutions Reform, Recovery, and Enforcement Act of 1989 [","children":[{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb86c7a0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" were not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb86c7a1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transferred to the Federal Deposit Insurance Corporation, the Federal Housing Finance Board, the Resolution Trust Corporation, or the Federal Home Loan Mortgage Corporation pursuant to any amendment made by such Act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb86c7a2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" established under any provision of law repealed by such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb86c7a3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1462a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State homestead provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this chapter or any other provision of law administered by the appropriate Federal banking agency shall be construed as superseding any homestead provision of any State constitution, including any implementing State statute, in effect on ","children":[{"tag":"date","attrib":{"date":"1994-09-29"},"text":"September 29, 1994","children":[],"tail":", or any subsequent amendment to such a State constitutional or statutory provision in effect on "},{"tag":"date","attrib":{"date":"1994-09-29"},"text":"September 29, 1994","children":[],"tail":", that exempts the homestead of any person from foreclosure, or forced sale, for the payment of all debts, other than a purchase money obligation relating to the homestead, taxes due on the homestead, or an obligation arising from work and material used in constructing improvements on the homestead."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb86c7a4-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-13/ch64/s3"},"text":"June 13, 1933, ch. 64, § 3","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIII/s301"},"text":"Pub. L. 101–73, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/278"},"text":"103 Stat. 278","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s331/c"},"text":"Pub. L. 103–325, title III, § 331(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2232"},"text":"108 Stat. 2232","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/328/tI/s102/b/5"},"text":"Pub. L. 103–328, title I, § 102(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-29"},"text":"Sept. 29, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2352"},"text":"108 Stat. 2352","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tVII/s712"},"text":"Pub. L. 109–351, title VII, § 712","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1994"},"text":"120 Stat. 1994","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s369/3"},"text":"Pub. L. 111–203, title III, § 369(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1558"},"text":"124 Stat. 1558","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb86c7a5-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb86c7a6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb86c7a7-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Dodd-Frank Wall Street Reform and Consumer Protection Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1376"},"text":"124 Stat. 1376","children":[],"tail":". Subtitle A (§§ 311–319) of title III of the Act enacted part A (§ 5411 et seq.) of subchapter III of chapter 53 and sections 4b and 16 of this title, amended sections 1, 11, 248, 481, 482, 1813, and 1820 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3502"},"text":"section 3502 of Title 44","children":[],"tail":", Public Printing and Documents, and enacted provisions set out as notes under sections 1 and 16 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Financial Institutions Reform, Recovery, and Enforcement Act of 1989, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/183"},"text":"103 Stat. 183","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddb86c7a8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3 of act ","children":[{"tag":"date","attrib":{"date":"1933-06-13"},"text":"June 13, 1933","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1424"},"text":"section 1424 of this title","children":[],"tail":" prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/s301"},"text":"Pub. L. 101–73, § 301","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb86c7a9-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s369/3/A"},"text":"Pub. L. 111–203, § 369(3)(A)","children":[],"tail":", inserted section catchline and struck out former section catchline “Director of the Office of Thrift Supervision”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s369/3/B"},"text":"Pub. L. 111–203, § 369(3)(B)","children":[],"tail":", (C), redesignated subsecs. (e) and (f) as (a) and (b), respectively, and struck out former subsecs. (a) to (d), which related to establishment of the Office of Thrift Supervision, position, appointment and term of Director, and prohibition on financial interests by Director; and subsecs. (g) to (j), which related to annual report requirement, staff, funding through assessments, and GAO audits."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s369/3/D"},"text":"Pub. L. 111–203, § 369(3)(D)","children":[],"tail":", struck out “of the Director” after “Powers” in heading and substituted “In accordance with subtitle A of title III of the Dodd-Frank Wall Street Reform and Consumer Protection Act, the appropriate Federal banking agency” for “The Director” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s369/3/E"},"text":"Pub. L. 111–203, § 369(3)(E)","children":[],"tail":", substituted “appropriate Federal banking agency” for “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351/s712/b"},"text":"Pub. L. 109–351, § 712(b)","children":[],"tail":", designated existing provisions as subpar. (A), inserted subpar. heading, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351/s712/a"},"text":"Pub. L. 109–351, § 712(a)","children":[],"tail":", amended heading and text of par. (5) generally. Prior to amendment, text read as follows: “Notwithstanding paragraphs (1) and (2), the Chairman of the Federal Home Loan Bank Board on the date of enactment of the Financial Institutions Reform, Recovery, and Enforcement Act of 1989, shall be the Director until the date on which that individual’s term as Chairman of the Federal Home Loan Bank Board would have expired.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s331/c/1"},"text":"Pub. L. 103–325, § 331(c)(1)","children":[],"tail":", substituted “(including agency enforcement actions) unless otherwise specifically provided by law” for “unless otherwise provided by law”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s331/c/2"},"text":"Pub. L. 103–325, § 331(c)(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/328"},"text":"Pub. L. 103–328","children":[],"tail":" added subsec. (f) and redesignated former subsecs. (f) to (i) as (g) to (j), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb86c7aa-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddb86c7ab-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s351"},"text":"section 351 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s906"},"text":"section 906 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddb86c7ac-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb86c7ad-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority To Ratify Office of Thrift Supervision Actions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of the President of the United States, ","children":[{"tag":"date","attrib":{"date":"1990-04-18"},"text":"Apr. 18, 1990","children":[],"tail":", 55 F.R. 15207, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Director of the Office of Thrift Supervision","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President of the United States by the Constitution and laws of the United States, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":" of the United States Code, I hereby delegate to the Director of the Office of Thrift Supervision my authority to ratify actions taken on behalf of, or in the name of, the Office of Thrift Supervision or its Director before "},{"tag":"date","attrib":{"date":"1990-04-09"},"text":"April 9, 1990","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This memorandum shall be published in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"George Bush.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
