{"tag":"section","attrib":{"id":"iddd0b6c1e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3415"},"text":null,"children":[{"tag":"num","attrib":{"value":"3415"},"text":"§ 3415.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except for records obtained pursuant to section 3403(d) or 3413(a) through (h) of this title, or as otherwise provided by law, a Government authority shall pay to the financial institution assembling or providing financial records pertaining to a customer and in accordance with procedures established by this chapter a fee for reimbursement for such costs as are reasonably necessary and which have been directly incurred in searching for, reproducing, or transporting books, papers, records, or other data required or requested to be produced. The Board of Governors of the Federal Reserve System shall, by regulation, establish the rates and conditions under which such payment may be made.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd0b6c1f-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXI/s1115/a"},"text":"Pub. L. 95–630, title XI, § 1115(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3708"},"text":"92 Stat. 3708","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd0b6c20-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd0b6c21-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd0b6c22-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXI/s1115/b"},"text":"Pub. L. 95–630, title XI, § 1115(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3708"},"text":"92 Stat. 3708","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/630/tXI/s1115/b"},"text":"“This section shall take effect on ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
