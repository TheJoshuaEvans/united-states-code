{"tag":"section","attrib":{"id":"iddd104e51-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3765"},"text":null,"children":[{"tag":"num","attrib":{"value":"3765"},"text":"§ 3765.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of sale","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A sale, made and conducted as prescribed in this chapter to a bona fide purchaser, shall bar all claims upon, or with respect to, the property sold, for each of the following persons:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd104e52-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3765/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person to whom the notice of default and foreclosure sale was mailed as provided in this chapter, and the heir, devisee, executor, administrator, successor, or assignee claiming under any such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104e53-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3765/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subordinate claimants with knowledge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person claiming any interest in the property subordinate to that of the mortgage, if such person had actual knowledge of the foreclosure sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104e54-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3765/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonrecorded claimants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person claiming any interest in the property, whose assignment, mortgage, or other conveyance was not duly recorded or filed in the proper place for recording or filing, or whose judgment or decree was not duly docketed or filed in the proper place for docketing or filing, before the date on which the notice of the foreclosure sale was first served by publication, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3758/3"},"text":"section 3758(3) of this title","children":[],"tail":", and the executor, administrator, or assignee of such a person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd104e55-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3765/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person claiming an interest in the property under a statutory lien or encumbrance created subsequent to the recording or filing of the mortgage being foreclosed, and attaching to the title or interest of any person designated in any of the foregoing paragraphs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd104e56-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/327/tII"},"text":"Pub. L. 103–327, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-28"},"text":"Sept. 28, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2316"},"text":"108 Stat. 2316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd104e57-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd104e58-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd104e59-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 816 of title VIII of S. 2281, One Hundred Third Congress, as reported ","children":[{"tag":"date","attrib":{"date":"1994-07-13"},"text":"July 13, 1994","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/103/327"},"text":"Pub. L. 103–327","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
