{"tag":"section","attrib":{"id":"iddd20efaf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4406"},"text":null,"children":[{"tag":"num","attrib":{"value":"4406"},"text":"§ 4406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other payments systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter shall have no effect by implication or otherwise on the validity or legal enforceability of a netting arrangement of any payment system which is not subject to this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddd20efb0-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIV/s406"},"text":"Pub. L. 102–242, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2375"},"text":"105 Stat. 2375","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
