{"tag":"section","attrib":{"id":"iddd425afa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4908"},"text":null,"children":[{"tag":"num","attrib":{"value":"4908"},"text":"§ 4908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other laws and agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd425afb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on State law","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd425afc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4908/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any residential mortgage or residential mortgage transaction consummated after the effective date of this chapter, and except as provided in paragraph (2), the provisions of this chapter shall supersede any provisions of the law of any State relating to requirements for obtaining or maintaining private mortgage insurance in connection with residential mortgage transactions, cancellation or automatic termination of such private mortgage insurance, any disclosure of information addressed by this chapter, and any other matter specifically addressed by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd425afd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4908/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of existing State laws","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd425afe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4908/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter do not supersede protected State laws, except to the extent that the protected State laws are inconsistent with any provision of this chapter, and then only to the extent of the inconsistency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd425aff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4908/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inconsistencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A protected State law shall not be considered to be inconsistent with a provision of this chapter if the protected State law—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd425b00-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4908/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" requires termination of private mortgage insurance or other mortgage guaranty insurance—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd425b01-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4908/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a date earlier than as provided in this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd425b02-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4908/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when a mortgage principal balance is achieved that is higher than as provided in this chapter; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd425b03-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4908/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" requires disclosure of information—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd425b04-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4908/a/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that provides more information than the information required by this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd425b05-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4908/a/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more often or at a date earlier than is required by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd425b06-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4908/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protected State laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, the term “protected State law” means a State law—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd425b07-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4908/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regarding any requirements relating to private mortgage insurance in connection with residential mortgage transactions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd425b08-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4908/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that was enacted not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd425b09-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4908/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is the law of a State that had in effect, on or before ","children":[{"tag":"date","attrib":{"date":"1998-01-02"},"text":"January 2, 1998","children":[],"tail":", any State law described in clause (i)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd425b0a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter shall supersede any conflicting provision contained in any agreement relating to the servicing of a residential mortgage loan entered into by the Federal National Mortgage Association, the Federal Home Loan Mortgage Corporation, or any private investor or note holder (or any successors thereto).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd425b0b-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/216/s9"},"text":"Pub. L. 105–216, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/906"},"text":"112 Stat. 906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd425b0c-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd425b0d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd425b0e-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this chapter, referred to in subsec. (a)(1), is 1 year after ","children":[{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/216/s13"},"text":"section 13 of Pub. L. 105–216","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4901"},"text":"section 4901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd425b0f-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd425b10-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 year after ","children":[{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/216/s13"},"text":"section 13 of Pub. L. 105–216","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4901"},"text":"section 4901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
