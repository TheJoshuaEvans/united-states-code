{"tag":"section","attrib":{"id":"iddb1df451-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s200"},"text":null,"children":[{"tag":"num","attrib":{"value":"200"},"text":"§ 200.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever any such request shall be allowed as hereinbefore provided, the said Comptroller of the Currency shall be, and is, empowered to draw upon and from such funds of any such trust as may be deposited with the Treasurer of the United States for the benefit of the bank in interest, to the amount as may be recommended and allowed and for the purpose for which such allowance was made: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That all payments to be made for or on account of the purchase of any such property and under any such allowance shall be made by the Comptroller of the Currency direct, with the approval of the Secretary of the Treasury, for such purpose only and in such manner as he may determine and order."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb1df452-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1886-03-29/ch28/s3"},"text":"Mar. 29, 1886, ch. 28, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/8"},"text":"24 Stat. 8","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb1df453-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb1df454-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb1df455-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application to District of Columbia","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of this section were made applicable to banks, etc., in the District of Columbia by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-03-04/ch274/s4"},"text":"act Mar. 4, 1933, ch. 274, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/1567"},"text":"47 Stat. 1567","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddb1df456-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"iddb1df457-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions to Secretary of the Treasury, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s55"},"text":"section 55 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
