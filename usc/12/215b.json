{"tag":"section","attrib":{"id":"iddb22af14-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215b"},"text":null,"children":[{"tag":"num","attrib":{"value":"215b"},"text":"§ 215b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb22af15-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State bank” means any bank, banking association, trust company, savings bank (other than a mutual savings bank), or other banking institution which is engaged in the business of receiving deposits and which is incorporated under the laws of any State, or which is operating under the Code of Law for the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb22af16-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means the several States and Territories, the Commonwealth of Puerto Rico, the Virgin Islands, and the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb22af17-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Comptroller” means the Comptroller of the Currency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb22af18-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"ta