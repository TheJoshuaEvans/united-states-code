{"tag":"section","attrib":{"id":"iddd6fac20-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5498"},"text":null,"children":[{"tag":"num","attrib":{"value":"5498"},"text":"§ 5498.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd6fac21-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5498/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall, by rule, adopt data standards for all collections of information that are regularly filed with or submitted to the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd6fac22-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5498/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The data standards required under subsection (a) shall incorporate, and ensure compatibility with (to the extent feasible), all applicable data standards established in the rules promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5334"},"text":"section 5334 of this title","children":[],"tail":", including, to the extent practicable, by having the characteristics described in clauses (i) through (vi) of subsection (c)(1)(B) of such section 5334."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd6fac23-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1018"},"text":"Pub. L. 111–203, title X, § 1018","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5851/a/2"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5851(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3433"},"text":"136 Stat. 3433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd6fac24-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd6fac25-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"iddd6fac26-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1018"},"text":"section 1018 of Pub. L. 111–203","children":[],"tail":" was renumbered section 1020 and is set out as note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5491"},"text":"section 5491 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd6fac27-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd6fac28-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rulemaking","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5852"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5852","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3433"},"text":"136 Stat. 3433","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLVIII/s5852"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Bureau of Consumer Financial Protection shall issue rules to carry out the amendments made by section 5851 [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5499"},"text":"section 5499 of this title","children":[],"tail":"], which shall take effect not later than 2 years after the date on which final rules are promulgated under section 124(b)(2) of the Financial Stability Act of 2010 ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5334/b/2"},"text":"12 U.S.C. 5334(b)(2)","children":[],"tail":"], as added by "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5811/a"},"text":"section 5811(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scaling of Regulatory Requirements; Minimizing Disruption","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In issuing the rules required under subsection (a), the Director of the Bureau of Consumer Financial Protection—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may scale data reporting requirements in order to reduce any unjustified burden on smaller regulated entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall seek to minimize disruptive changes to the persons affected by those regulations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddd6fac29-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction Regarding No New Disclosure Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5853"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5853","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3433"},"text":"136 Stat. 3433","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLVIII/s5853"},"text":"“Nothing in this subtitle [subtitle E (§§ 5851–5853) of title LVIII of div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", enacting this section, "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5499"},"text":"section 5499 of this title","children":[],"tail":", and provisions set out as a note under this section], or the amendments made by this subtitle, shall be construed to require the Bureau of Consumer Financial Protection to collect or make publicly available additional information under the Consumer Financial Protection Act of 2010 ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5481"},"text":"12 U.S.C. 5481","children":[],"tail":" et seq.), beyond information that was collected or made publicly available under that Act, as of the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
