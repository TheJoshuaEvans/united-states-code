{"tag":"section","attrib":{"id":"iddd1297d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3903"},"text":null,"children":[{"tag":"num","attrib":{"value":"3903"},"text":"§ 3903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strengthened supervision of international lending","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1297d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each appropriate Federal banking agency shall evaluate banking institution foreign country exposure and transfer risk for use in banking institution examination and supervision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1297d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s3903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each such agency shall establish examination and supervisory procedures to assure that factors such as foreign country exposure and transfer risk are taken into account in evaluating the adequacy of the capital of banking institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1297d7-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title IX, § 904], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1279"},"text":"97 Stat. 1279","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
