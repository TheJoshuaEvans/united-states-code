{"tag":"section","attrib":{"id":"iddd1e7fb0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303"},"text":null,"children":[{"tag":"num","attrib":{"value":"4303"},"text":"§ 4303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Account schedule","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd1e7fb1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each depository institution shall maintain a schedule of fees, charges, interest rates, and terms and conditions applicable to each class of accounts offered by the depository institution, in accordance with the requirements of this section and regulations which the Bureau shall prescribe. The Bureau shall specify, in regulations, which fees, charges, penalties, terms, conditions, and account restrictions must be included in a schedule required under this subsection. A depository institution need not include in such schedule any information not specified in such regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7fb2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information on fees and charges","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The schedule required under subsection (a) with respect to any account shall contain the following information:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7fb3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of all fees, periodic service charges, and penalties which may be charged or assessed against the account (or against the account holder in connection with such account), the amount of any such fees, charge, or penalty (or the method by which such amount will be calculated), and the conditions under which any such amount will be assessed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fb4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All minimum balance requirements that affect fees, charges, and penalties, including a clear description of how each such minimum balance is calculated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fb5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any minimum amount required with respect to the initial deposit in order to open the account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7fb6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information on interest rates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The schedule required under subsection (a) with respect to any account shall include the following information:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7fb7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any annual percentage yield.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fb8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The period during which any such annual percentage yield will be in effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fb9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any annual rate of simple interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The frequency with which interest will be compounded and credited.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fbb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A clear description of the method used to determine the balance on which interest is paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fbc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The information described in paragraphs (1) through (4) with respect to any period after the end of the period referred to in paragraph (2) (or the method for computing any information described in any such paragraph), if applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fbd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any minimum balance which must be maintained to earn the rates and obtain the yields disclosed pursuant to this subsection and a clear description of how any such minimum balance is calculated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fbe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A clear description of any minimum time requirement which must be met in order to obtain the yields disclosed pursuant to this subsection and any information described in paragraph (1), (2), (3), or (4) that will apply if any time requirement is not met.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fbf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement, if applicable, that any interest which has accrued but has not been credited to an account at the time of a withdrawal from the account will not be paid by the depository institution or credited to the account by reason of such withdrawal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7fc0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any provision or requirement relating to nonpayment of interest, including any charge or penalty for early withdrawal, and the conditions under which any such charge or penalty may be assessed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7fc1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The schedule required under subsection (a) shall include such other disclosures as the Bureau may determine to be necessary to allow consumers to understand and compare accounts, including frequency of interest rate adjustments, account restrictions, and renewal policies for time accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd1e7fc2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4303/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Style and format","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Schedules required under subsection (a) shall be written in clear and plain language and be presented in a format designed to allow consumers to readily understand the terms of the accounts offered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1e7fc3-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s264"},"text":"Pub. L. 102–242, title II, § 264","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2335"},"text":"105 Stat. 2335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100B/1"},"text":"Pub. L. 111–203, title X, § 1100B(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2109"},"text":"124 Stat. 2109","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd1e7fc4-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd1e7fc5-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddd1e7fc6-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsecs. (a), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Bureau” for “Board” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd1e7fc7-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddd1e7fc8-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
