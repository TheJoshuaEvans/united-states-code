{"tag":"section","attrib":{"id":"iddb2c2557-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s303"},"text":null,"children":[{"tag":"num","attrib":{"value":"303"},"text":"§ 303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications and disabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No Senator or Representative in Congress shall be a member of the Board of Governors of the Federal Reserve System or an officer or a director of a Federal reserve bank.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"No director of class B shall be an officer, director, or employee of any bank.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"No director of class C shall be an officer, director, employee, or stockholder of any bank.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb2c2558-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s4"},"text":"Dec. 23, 1913, ch. 6, § 4","children":[],"tail":" (pars.), "},{"tag":"ref","attrib":{"href":"/us/stat/38/255"},"text":"38 Stat. 255","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-23/ch614"},"text":"Aug. 23, 1935, ch. 614","children":[],"tail":", title II, § 203(a), "},{"tag":"ref","attrib":{"href":"/us/stat/49/704"},"text":"49 Stat. 704","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb2c2559-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb2c255a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb2c255b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of pars. 13 to 15 of section 4 of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":". For classification to this title of other pars. of section 4, see Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s301"},"text":"section 301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddb2c255c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"iddb2c255d-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 203(a) of act ","children":[{"tag":"date","attrib":{"date":"1935-08-23"},"text":"Aug. 23, 1935","children":[],"tail":", changed name of Federal Reserve Board to Board of Governors of the Federal Reserve System."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
