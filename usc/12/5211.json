{"tag":"section","attrib":{"id":"iddd498604-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211"},"text":null,"children":[{"tag":"num","attrib":{"value":"5211"},"text":"§ 5211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchases of troubled assets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd498605-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offices; authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd498606-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish the Troubled Asset Relief Program (or “TARP”) to purchase, and to make and fund commitments to purchase, troubled assets from any financial institution, on such terms and conditions as are determined by the Secretary, and in accordance with this chapter and the policies and procedures developed and published by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd498607-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Establishment of the policies and procedures and other similar administrative requirements imposed on the Secretary by this chapter are not intended to delay the commencement of the TARP.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd498608-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Treasury office","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd498609-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall implement any program under paragraph (1) through an Office of Financial Stability, established for such purpose within the Office of Domestic Finance of the Department of the Treasury, which office shall be headed by an Assistant Secretary of the Treasury, appointed by the President, by and with the advice and consent of the Senate, except that an interim Assistant Secretary may be appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd49860a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd49860b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In exercising the authority under this section, the Secretary shall consult with the Board, the Corporation, the Comptroller of the Currency, the Director of the Office of Thrift Supervision, the Chairman of the National Credit Union Administration Board, and the Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd49860c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Necessary actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to take such actions as the Secretary deems necessary to carry out the authorities in this chapter, including, without limitation, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd49860d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall have direct hiring authority with respect to the appointment of employees to administer this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd49860e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Entering into contracts, including contracts for services authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd49860f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Designating financial institutions as financial agents of the Federal Government, and such institutions shall perform all such reasonable duties related to this chapter as financial agents of the Federal Government as may be required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd498610-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to provide the Secretary with the flexibility to manage troubled assets in a manner designed to minimize cost to the taxpayers, establishing vehicles that are authorized, subject to supervision by the Secretary, to purchase, hold, and sell troubled assets and issue obligations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd498611-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issuing such regulations and other guidance as may be necessary or appropriate to define terms or carry out the authorities or purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd498612-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before the earlier of the end of the 2-business-day period beginning on the date of the first purchase of troubled assets pursuant to the authority under this section or the end of the 45-day period beginning on ","children":[{"tag":"date","attrib":{"date":"2008-10-03"},"text":"October 3, 2008","children":[],"tail":", the Secretary shall publish program guidelines, including the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd498613-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mechanisms for purchasing troubled assets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd498614-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Methods for pricing and valuing troubled assets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd498615-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures for selecting asset managers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd498616-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Criteria for identifying troubled assets for purchase.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd498617-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5211/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preventing unjust enrichment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making purchases under the authority of this chapter, the Secretary shall take such steps as may be necessary to prevent unjust enrichment of financial institutions participating in a program established under this section, including by preventing the sale of a troubled asset to the Secretary at a higher price than what the seller paid to purchase the asset. This subsection does not apply to troubled assets acquired in a merger or acquisition, or a purchase of assets from a financial institution in conservatorship or receivership, or that has initiated bankruptcy proceedings under title 11.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd498618-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dA/tI/s101"},"text":"Pub. L. 110–343, div. A, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3767"},"text":"122 Stat. 3767","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd498619-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd49861a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddd49861b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(1), (2), (c), and (e), was in the original “this Act” and was translated as reading “this division”, meaning div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343"},"text":"Pub. L. 110–343","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3765"},"text":"122 Stat. 3765","children":[],"tail":", known as the Emergency Economic Stabilization Act of 2008, to reflect the probable intent of Congress. For complete classification of division A to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5201"},"text":"section 5201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddd49861c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dA/s101"},"text":"section 101 of div. A of Pub. L. 110–343","children":[],"tail":". Subsec. (a)(3)(B) of "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dA/s101"},"text":"section 101 of div. A of Pub. L. 110–343","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of Title 5","children":[],"tail":", Government Organization and Employees, and "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s301"},"text":"section 301 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
