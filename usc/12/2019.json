{"tag":"section","attrib":{"id":"iddcbf2133-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2019"},"text":null,"children":[{"tag":"num","attrib":{"value":"2019"},"text":"§ 2019.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes for extensions of credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddcbf2134-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2019/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural or aquatic purposes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcbf2135-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2019/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Loans made by a Farm Credit Bank to farmers, ranchers, and producers or harvesters of aquatic products may be for any agricultural or aquatic purpose and other credit needs of the applicant, including financing for basic processing and marketing directly related to the applicant’s operations and those of other eligible farmers, ranchers, and producers or harvesters of aquatic products, except that the operations of the applicant shall supply some portion of the total processing or marketing for which financing is extended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf2136-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2019/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on loans for basic processing and marketing operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate of the financing provided by any Farm Credit Bank for basic processing and marketing directly related to the operations of farmers, ranchers, and producers or harvesters of aquatic products, if the operations of the applicant supply less than 20 percent of the total processing or marketing for which financing is extended, shall not exceed 15 percent of the total of all outstanding loans of such bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcbf2137-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2019/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural housing financing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcbf2138-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2019/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Loans and discounts may be made to rural residents for rural housing financing under regulations of the Farm Credit Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf2139-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2019/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rural housing financed under this subchapter shall be for single-family, moderate-priced dwellings and their appurtenances not inconsistent with the general quality and standards of housing existing in, or planned or recommended for, the rural area where it is located, except that a Farm Credit Bank may not at any one time have a total amount of loans outstanding for such rural housing to persons other than farmers or ranchers in amounts exceeding 15 percent of the total of all loans outstanding in such bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf213a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2019/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For rural housing purposes under this section the term “rural areas” shall not be defined to include any city or village having a population in excess of 2,500 inhabitants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddcbf213b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2019/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farm-related services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcbf213c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2019/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Loans to persons furnishing farm-related services to farmers and ranchers directly related to their on-farm operating needs may be made for the necessary capital structures and equipment and initial working capital for such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcbf213d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2019/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The banks may own and lease, or lease with option to purchase, to persons eligible for credit under this subchapter or subchapter II, equipment or facilities needed in the operations of such persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcbf213e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tI/s1"},"text":"Pub. L. 92–181, title I, § 1","children":[],"tail":".11, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s401"},"text":"Pub. L. 100–233, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1627"},"text":"101 Stat. 1627","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s401/j"},"text":"Pub. L. 100–399, title IV, § 401(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/996"},"text":"102 Stat. 996","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVIII/s1832/a"},"text":"Pub. L. 101–624, title XVIII, § 1832(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3832"},"text":"104 Stat. 3832","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tV/s502/a"},"text":"Pub. L. 102–237, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","a