{"tag":"section","attrib":{"id":"iddce7b830-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279c–1"},"text":"§ 2279c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merger of associations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddce7b831-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Two or more associations within the same district, whether or not organized under the same subchapter of this chapter, may merge into a single entity (hereinafter in this subchapter referred to as a “merged association”) if the plan of merger is approved by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7b832-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Farm Credit Administration Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b833-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the boards of directors of the associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b834-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a majority of the shareholders of each association voting, in person or by proxy, at a duly authorized stockholders’ meeting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b835-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Farm Credit Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7b836-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers, obligations, and consolidation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7b837-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and obligations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided by this subchapter, a merged association shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddce7b838-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possess all powers granted under this chapter to the associations forming the merged association; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddce7b839-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to all of the obligations imposed under this chapter on the associations forming the merged association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b83a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Farm Credit Administration shall issue regulations that establish the manner in which the powers and obligations of the associations that form the merged association are consolidated and, to the extent necessary, reconciled in the merged association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddce7b83b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stock issuance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddce7b83c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan of merger","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2154a"},"text":"section 2154a of this title","children":[],"tail":", the number of shares of capital stock issued by a merged association to the stockholders of any association forming such merged association, and the rights and privileges of such shares (including voting power, preferences on liquidation, and the right to dividends), shall be determined by the plan of merger adopted by the merged associations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddce7b83d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2279c–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capitalization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2154a"},"text":"section 2154a of this title","children":[],"tail":", each merged association shall provide, through bylaws and subject to Farm Credit Administration regulations, for the capitalization of the association and the manner in which association stock shall be issued, held, transferred, and retired, and association earnings shall be distributed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddce7b83e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tVII/s7"},"text":"Pub. L. 92–181, title VII, § 7","children":[],"tail":".8, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tIV/s416"},"text":"Pub. L. 100–233, title IV, § 416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1647"},"text":"101 Stat. 1647","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIV/s408/k"},"text":"Pub. L. 100–399, title IV, § 408(k)","children":[],"tail":", ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1002"},"text":"102 Stat. 1002","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddce7b83f-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddce7b840-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddce7b841-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s408/k"},"text":"Pub. L. 100–399, § 408(k)","children":[],"tail":", struck out second sentence, which directed that, following a merger under subsection (a) of this section, the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2154a"},"text":"section 2154a of this title","children":[],"tail":" were to be applicable to the merged association."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s408"},"text":"Pub. L. 100–399, § 408","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), substituted “Capitalization” for “Plan of capitalization” as par. (2) heading and amended text generally. Prior to amendment, text read as follows: “The number of shares of capital stock, and the rights and privileges thereof, issued by a merged association after a merger shall be determined by the Board of Directors of the merged association, with the approval of the supervising bank, and shall be consistent with "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2154a"},"text":"section 2154a of this title","children":[],"tail":" and the regulations issued by the Farm Credit Administration.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s408"},"text":"Pub. L. 100–399, § 408","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), struck out par. (3) which read as follows: “Voting stock of a merged association shall be issued to and held by farmers, ranchers, or producers or harvesters of aquatic products who are or were, immediately prior to the merger, direct borrowers from one of the associations forming the merged association or the supervising bank of such merged association.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399/s408"},"text":"Pub. L. 100–399, § 408","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), struck out subsec. (d) which read as follows: “The plan of merger shall provide for the issuance, transfer, and retirement of stock and the distribution of earnings in accordance with the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2154a"},"text":"section 2154a of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddce7b842-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"iddce7b843-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/399"},"text":"Pub. L. 100–399","children":[],"tail":" effective as if enacted immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/233"},"text":"Pub. L. 100–233","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/s1001/a"},"text":"section 1001(a) of Pub. L. 100–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
