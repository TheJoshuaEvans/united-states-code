{"tag":"section","attrib":{"id":"iddba10677-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1701g–5c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1701g–5c"},"text":"§ 1701g–5c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of rehabilitation loan fund assets and liabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 289(c) of the Cranston-Gonzalez National Affordable Housing Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Public Law 101–625","children":[],"tail":"), the assets and liabilities of the revolving fund established by section 1452b "},{"tag":"ref","attrib":{"idref":"fn002109"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002109"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 42, and any collections, including repayments or recaptured amounts, of such fund shall be transferred to and merged with the Revolving Fund (liquidating programs), established pursuant to title II of the Independent Offices Appropriation Act, 1955, as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701g–5"},"text":"12 U.S.C. 1701g–5","children":[],"tail":"), effective "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddba10678-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/139/tII"},"text":"Pub. L. 102–139, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/752"},"text":"105 Stat. 752","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddba10679-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddba1067a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddba1067b-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 289(c) of the Cranston-Gonzalez National Affordable Housing Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":"), referred to in text, is not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1452b"},"text":"Section 1452b of title 42","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s289/b"},"text":"Pub. L. 101–625, title II, § 289(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4128"},"text":"104 Stat. 4128","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Independent Offices Appropriation Act, 1955, as amended, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-06-24/ch359"},"text":"act June 24, 1954, ch. 359","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/272"},"text":"68 Stat. 272","children":[],"tail":". Provisions of title II of this Act relating to the establishment of the revolving fund (liquidating programs) are classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701g–5"},"text":"section 1701g–5 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddba1067c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Departments of Veterans Affairs and Housing and Urban Development, and Independent Agencies Appropriations Act, 1992, and not as part of the National Housing Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
