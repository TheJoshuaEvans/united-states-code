{"tag":"section","attrib":{"id":"iddd1e7ff4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4307"},"text":null,"children":[{"tag":"num","attrib":{"value":"4307"},"text":"§ 4307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic statements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each depository institution shall include on or with each periodic statement provided to each account holder at such institution a clear and conspicuous disclosure of the following information with respect to such account:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd1e7ff5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4307/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The annual percentage yield earned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7ff6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4307/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of interest earned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7ff7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4307/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of any fees or charges imposed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd1e7ff8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s4307/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of days in the reporting period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd1e7ff9-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tII/s268"},"text":"Pub. L. 102–242, title II, § 268","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2338"},"text":"105 Stat. 2338","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
