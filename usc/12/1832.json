{"tag":"section","attrib":{"id":"iddca4e260-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1832"},"text":null,"children":[{"tag":"num","attrib":{"value":"1832"},"text":"§ 1832.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawals by negotiable or transferable instruments for transfers to third parties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddca4e261-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1832/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of depository institution; applicability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca4e262-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1832/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law but subject to paragraph (2), a depository institution is authorized to permit the owner of a deposit or account on which interest or dividends are paid to make withdrawals by negotiable or transferable instruments for the purpose of making transfers to third parties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e263-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1832/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) shall apply only with respect to deposits or accounts which consist solely of funds in which the entire beneficial interest is held by one or more individuals or by an organization which is operated primarily for religious, philanthropic, charitable, educational, political, or other similar purposes and which is not operated for profit, and with respect to deposits of public funds by an officer, employee, or agent of the United States, any State, county, municipality, or political subdivision thereof, the District of Columbia, the Commonwealth of Puerto Rico, American Samoa, Guam, any territory or possession of the United States, or any political subdivision thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4e264-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1832/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Depository institution” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “depository institution” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddca4e265-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1832/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any insured bank as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e266-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1832/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State bank as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e267-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1832/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any mutual savings bank as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e268-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1832/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any savings bank as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e269-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1832/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any insured institution as defined in section 1724 ","children":[{"tag":"ref","attrib":{"idref":"fn002273"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002273"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddca4e26a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1832/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any building and loan association or savings and loan association organized and operated according to the laws of the State in which it is chartered or organized; and, for purposes of this paragraph, the term “State” means any State of the United States, the District of Columbia, any territory of the United States, Puerto Rico, Guam, American Samoa, or the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddca4e26b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1832/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fine","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any depository institution which violates this section shall be fined $1,000 for each violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddca4e26c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/100/s2"},"text":"Pub. L. 93–100, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-16"},"text":"Aug. 16, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/342"},"text":"87 Stat. 342","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/222/s2"},"text":"Pub. L. 94–222, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-02-27"},"text":"Feb. 27, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/197"},"text":"90 Stat. 197","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXIII/s1301"},"text":"Pub. L. 95–630, title XIII, § 1301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3712"},"text":"92 Stat. 3712","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/161/tI/s106"},"text":"Pub. L. 96–161, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-28"},"text":"Dec. 28, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1235"},"text":"93 Stat. 1235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tIII/s303"},"text":"Pub. L. 96–221, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/146"},"text":"94 Stat. 146","children":[],"tail":"; "},{"tag"