{"tag":"section","attrib":{"id":"iddd44a5ac-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102"},"text":null,"children":[{"tag":"num","attrib":{"value":"5102"},"text":"§ 5102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd44a5ad-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Bureau” means the Bureau of Consumer Financial Protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a5ae-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal banking agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal banking agency” means the Board of Governors of the Federal Reserve System, the Office of the Comptroller of the Currency, the National Credit Union Administration, and the Federal Deposit Insurance Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a5af-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depository institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “depository institution” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of this title","children":[],"tail":", and includes any credit union."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd44a5b0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan originator","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4715b1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “loan originator”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd4715b2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means an individual who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd4715b3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/4/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes a residential mortgage loan application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd4715b4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/4/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers or negotiates terms of a residential mortgage loan for compensation or gain;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4715b5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any individual who is not otherwise described in clause (i) and who performs purely administrative or clerical tasks on behalf of a person who is described in any such clause;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4715b6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a person or entity that only performs real estate brokerage activities and is licensed or registered in accordance with applicable State law, unless the person or entity is compensated by a lender, a mortgage broker, or other loan originator or by any agent of such lender, mortgage broker, or other loan originator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4715b7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a person or entity solely involved in extensions of credit relating to timeshare plans, as that term is defined in section 101(53D) of title 11.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4715b8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions relating to loan originator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, an individual “assists a consumer in obtaining or applying to obtain a residential mortgage loan” by, among other things, advising on loan terms (including rates, fees, other costs), preparing loan packages, or collecting information on behalf of the consumer with regard to a residential mortgage loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4715b9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative or clerical tasks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “administrative or clerical tasks” means the receipt, collection, and distribution of information common for the processing or underwriting of a loan in the mortgage industry and communication with a consumer to obtain information necessary for the processing or underwriting of a residential mortgage loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4715ba-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real estate brokerage activity defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “real estate brokerage activity” means any activity that involves offering or providing real estate brokerage services to the public, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd4715bb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acting as a real estate agent or real estate broker for a buyer, seller, lessor, or lessee of real property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4715bc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bringing together parties interested in the sale, purchase, lease, rental, or exchange of real property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4715bd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/4/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" negotiating, on behalf of any party, any portion of a contract relating to the sale, purchase, lease, rental, or exchange of real property (other than in connection with providing financing with respect to any such transaction);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4715be-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/4/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaging in any activity for which a person engaged in the activity is required to be registered or licensed as a real estate agent or real estate broker under any applicable law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4715bf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/4/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offering to engage in any activity, or act in any capacity, described in clause (i), (ii), (iii), or (iv).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4715c0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan processor or underwriter","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4715c1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “loan processor or underwriter” means an individual who performs clerical or support duties at the direction of and subject to the supervision and instruction of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd4715c2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State-licensed loan originator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4715c3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a registered loan originator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4715c4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clerical or support duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the term “clerical or support duties” may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd4715c5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the receipt, collection, distribution, and analysis of information common for the processing or underwriting of a residential mortgage loan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4715c6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communicating with a consumer to obtain the information necessary for the processing or underwriting of a loan, to the extent that such communication does not include offering or negotiating loan rates or terms, or counseling consumers about residential mortgage loan rates or terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4715c7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nationwide mortgage licensing system and registry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Nationwide Mortgage Licensing System and Registry” means a mortgage licensing system developed and maintained by the Conference of State Bank Supervisors and the American Association of Residential Mortgage Regulators for the State licensing and registration of State-licensed loan originators and the registration of registered loan originators or any system established by the Director under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5108"},"text":"section 5108 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4715c8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nontraditional mortgage product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nontraditional mortgage product” means any mortgage product other than a 30-year fixed rate mortgage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4715c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registered loan originator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “registered loan originator” means any individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4715ca-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" meets the definition of loan originator and is an employee of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd4715cb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4715cc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a subsidiary that is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd4715cd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/8/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned and controlled by a depository institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd4715ce-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/8/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulated by a Federal banking agency; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4715cf-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/8/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution regulated by the Farm Credit Administration; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4715d0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is registered with, and maintains a unique identifier through, the Nationwide Mortgage Licensing System and Registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4715d1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residential mortgage loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “residential mortgage loan” means any loan primarily for personal, family, or household use that is secured by a mortgage, deed of trust, or other equivalent consensual security interest on a dwelling (as defined in section 1602(v) ","children":[{"tag":"ref","attrib":{"idref":"fn002444"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002444"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 15) or residential real estate upon which is constructed or intended to be constructed a dwelling (as so defined)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4715d2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Bureau of Consumer Financial Protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4715d3-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any State of the United States, the District of Columbia, any territory of the United States, Puerto Rico, Guam, American Samoa, the Trust Territory of the Pacific Islands, the Virgin Islands, and the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4715d4-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State-licensed loan originator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State-licensed loan originator” means any individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4715d5-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a loan originator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4715d6-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is not an employee of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd4715d7-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/12/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4715d8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/12/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a subsidiary that is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddd4715d9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/12/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned and controlled by a depository institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddd4715da-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/12/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulated by a Federal banking agency; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4715db-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/12/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution regulated by the Farm Credit Administration; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4715dc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is licensed by a State or by the Director under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5107"},"text":"section 5107 of this title","children":[],"tail":" and registered as a loan originator with, and maintains a unique identifier through, the Nationwide Mortgage Licensing System and Registry."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd4715dd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unique identifier","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd4715de-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “unique identifier” means a number or other identifier that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddd4715df-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/13/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permanently identifies a loan originator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4715e0-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/13/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is assigned by protocols established by the Nationwide Mortgage Licensing System and Registry and the Bureau to facilitate electronic tracking of loan originators and uniform identification of, and public access to, the employment history of and the publicly adjudicated disciplinary and enforcement actions against loan originators; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddd4715e1-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/13/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be used for purposes other than those set forth under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd4715e2-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5102/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility of States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the greatest extent possible and to accomplish the purpose of this chapter, States shall use unique identifiers in lieu of social security numbers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd4715e3-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tV/s1503"},"text":"Pub. L. 110–289, div. A, title V, § 1503","children":[],"tail":", "},{"tag":"date","attrib":{"