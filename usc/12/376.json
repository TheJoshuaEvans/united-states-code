{"tag":"section","attrib":{"id":"iddb3f37a8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s376"},"text":null,"children":[{"tag":"num","attrib":{"value":"376"},"text":"§ 376.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of interest paid to directors, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No member bank shall pay to any director, officer, attorney, or employee a greater rate of interest on the deposits of such director, officer, attorney, or employee than that paid to other depositors on similar deposits with such member bank.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb3f37a9-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s22/e"},"text":"Dec. 23, 1913, ch. 6, § 22(e)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1918-09-26/ch177/s5"},"text":"Sept. 26, 1918, ch. 177, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/971"},"text":"40 Stat. 971","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
