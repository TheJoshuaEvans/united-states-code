{"tag":"section","attrib":{"id":"iddc43397b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764"},"text":null,"children":[{"tag":"num","attrib":{"value":"1764"},"text":"§ 1764.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expulsion and withdrawal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddc43397c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expulsion by two-thirds vote","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsections (b) and (c) of this section, a member may be expelled by a two-thirds vote of the members of a Federal credit union present at a special meeting called for the purpose, but only after opportunity has been given to the member to be heard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc43397d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expulsion based on nonparticipation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board of directors of a Federal credit union may, by majority vote of a quorum of directors, adopt and enforce a policy with respect to expulsion from membership based on nonparticipation by a member in the affairs of the credit union. In establishing its policy, the board should consider a member’s failure to vote in annual credit union elections or failure to purchase shares from, obtain a loan from, or lend to the Federal credit union. If such a policy is adopted, written notice of the policy as adopted and the effective date of such policy shall be mailed to each member of the credit union at the member’s current address appearing on the records of the credit union not less than thirty days prior to the effective date of such policy. In addition, each new member shall be provided written notice of any such policy prior to or upon applying for membership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc43397e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expulsion for cause","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddc43397f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsections (a) and (b) of this section, a member may be expelled for cause by a two-thirds vote of a quorum of the directors of the Federal credit union pursuant to a policy which the National Credit Union Administration Board shall adopt, pursuant to a rulemaking, not later than the end of the 18-month period following ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"March 15, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc433980-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of policy to members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal credit union may not expel a member pursuant to this subsection unless the Federal credit union has provided, in written or electronic form, a copy of the policy adopted by the National Credit Union Administration Board under paragraph (1) to each member of the Federal credit union.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc433981-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc433982-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of pending expulsion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a member will, subject to the policy adopted under paragraph (1), be subject to expulsion, the member shall be notified in advance of the expulsion, along with the reason for such expulsion. Such notice shall be provided in person, by mail to the member’s address, or, if the member has elected to receive electronic communications from the Federal credit union, may be provided electronically.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc433983-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to a hearing","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc433984-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member shall have 60 days from the date of receipt of a notification under subparagraph (A) to request a hearing from the board of directors of the Federal credit union.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc433985-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expulsion if no hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a member does not request a hearing during the 60-day period described under clause (i), the member shall be expelled after the end of the 60-day period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc433986-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing; vote on expulsion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a member requests a hearing during the 60-day period described under subparagraph (B)(i)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc433987-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the board of directors of the Federal credit union shall provide the member with a hearing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc433988-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after such hearing, the board of directors of the Federal credit union shall hold a vote in a timely manner on expelling the member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc433989-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of expulsion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a member is expelled under subparagraph (B)(ii) or (C)(ii), notice of the expulsion of the member shall be provided to the member in person, by mail to the member’s address, in written form or, if the member has elected to receive electronic communications from the Federal credit union, may be provided electronically.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc43398a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reinstatement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc43398b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member expelled under this subsection—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddc43398c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be given an opportunity to request reinstatement of membership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddc43398d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be reinstated by either—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"iddc43398e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a majority vote of a quorum of the directors of the Federal credit union; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"iddc43398f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a majority vote of the members of the Federal credit union present at a meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc433990-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph may be construed to require that an expelled member be allowed to attend the meeting described in subparagraph (A)(ii) in person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddc433991-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cause defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “cause” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddc433992-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial or repeated violation of the membership agreement of the Federal credit union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc433993-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial or repeated disruption, including dangerous or abusive behavior (as defined by the National Credit Union Administration Board pursuant to a rulemaking), to the operations of a Federal credit union; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddc433994-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fraud, attempted fraud, or other illegal conduct that a member has been convicted of in relation to the Federal credit union, including the Federal credit union’s employees conducting business on behalf of the Federal credit union.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc433995-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability to credit union","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Withdrawal or expulsion of a member pursuant to subsection (a), (b), or (c) of this section shall not operate to relieve the member from liability to the Federal credit union. The amount to be paid a withdrawing or expelled member by a Federal credit union shall be determined and paid in a manner specified in the bylaws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddc433996-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1764/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No authority to expel classes of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An expulsion of a member pursuant to this section shall be done individually, on a case-by-case basis, and neither the Board nor any Federal credit union may expel a class of members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddc433997-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title I, § 118, formerly § 14, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1221"},"text":"48 Stat. 1221","children":[],"tail":"; renumbered § 19, "},{"tag":"ref","attrib":{"href":"/us/pl/86/354/s1"},"text":"Pub. L. 86–354, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-22"},"text":"Sept. 22, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/634"},"text":"73 Stat. 634","children":[],"tail":"; renumbered title I, § 118, "},{"tag":"ref","attrib":{"href":"/us/pl/91/468/s1/2"},"text":"Pub. L. 91–468, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-19"},"text":"Oct. 19, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/994"},"text":"84 Stat. 994","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/320/tV/s525"},"text":"Pub. L. 97–320, title V, § 525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1534"},"text":"96 Stat. 1534","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/86/tVII/s706"},"text":"Pub. L. 100–86, title VII, § 706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/653"},"text":"101 Stat. 653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dT/s102"},"text":"Pub. L. 117–103, div. T, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/824"},"text":"136 Stat. 824","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddc433998-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddc433999-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddc43399a-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s102/1"},"text":"Pub. L. 117–103, § 102(1)","children":[],"tail":", substituted “subsections (b) and (c)” for “subsection (b)” and “to the member” for “him”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s102/3"},"text":"Pub. L. 117–103, § 102(3)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s102/2"},"text":"Pub. L. 117–103, § 102(2)","children":[],"tail":", (4), redesignated subsec. (c) as (d) and substituted “subsection (a), (b), or (c)” for “either subsection (a) or (b)” and “the member” for “him”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s102/5"},"text":"Pub. L. 117–103, § 102(5)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/s706/1"},"text":"Pub. L. 100–86, § 706(1)","children":[],"tail":", substituted “Except as provided in” for “Subject to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/s706/2"},"text":"Pub. L. 100–86, § 706(2)","children":[],"tail":", inserted “and enforce” after “adopt”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320"},"text":"Pub. L. 97–320","children":[],"tail":" designated existing provisions as subsecs. (a) and (c) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
