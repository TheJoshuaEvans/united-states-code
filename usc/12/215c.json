{"tag":"section","attrib":{"id":"iddb22af1e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215c"},"text":null,"children":[{"tag":"num","attrib":{"value":"215c"},"text":"§ 215c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mergers, consolidations, and other acquisitions authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb22af1f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to sections 1815(d)(3) ","children":[{"tag":"ref","attrib":{"idref":"fn002028"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002028"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and 1828(c) of this title and all other applicable laws, any national bank may acquire or be acquired by any insured depository institution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb22af20-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited approval of acquisitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddb22af21-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any application by a national bank to acquire or be acquired by another insured depository institution which is required to be filed with the Comptroller of the Currency under any applicable law or regulation shall be approved or disapproved in writing by the agency before the end of the 60-day period beginning on the date such application is filed with the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddb22af22-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extensions of period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The period for approval or disapproval referred to in paragraph (1) may be extended for an additional 30-day period if the Comptroller of the Currency determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddb22af23-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicant has not furnished all of the information required to be submitted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddb22af24-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the Comptroller’s judgment, any material information submitted is substantially inaccurate or incomplete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb22af25-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this section shall be construed as authorizing a national bank or a subsidiary of a national bank to engage in any activity not otherwise authorized under this Act ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" or any other law governing the powers of national banks."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb22af26-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s215c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Acquire” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “acquire” means to acquire, directly or indirectly, ownership or control through a merger or consolidation or an acquisition of assets or assumption of liabilities, provided that following such merger, consolidation, or acquisition, an acquiring insured depository institution may not own the shares of the acquired insured depository institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb22af27-3a6f-11f1-8fa0-c065796a7f06"},"text":"(R.S. § 5156A, as added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tV/s502/b"},"text":"Pub. L. 102–242, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2393"},"text":"105 Stat. 2393","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2201/b/1"},"text":"Pub. L. 104–208, div. A, title II, § 2201(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-403"},"text":"110 Stat. 3009–403","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb22af28-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb22af29-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"iddb22af2a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1815/d/3"},"text":"Section 1815(d)(3) of this title","children":[],"tail":", referred to in subsec. (a), which related to optional conversions by insured depository institutions subject to special rules on deposit insurance payments, was struck out and former section 1815(d)(1)(C) redesignated section 1815(d)(3) by "},{"tag":"ref","attrib":{"href":"/us/pl/109/173/s8/a/4"},"text":"Pub. L. 109–173, § 8(a)(4)","children":[],"tail":", (5)(D), "},{"tag":"date","attrib":{"date":"2006-02-15"},"text":"Feb. 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3610"},"text":"119 Stat. 3610","children":[],"tail":", 3611."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (c), probably means the National Bank Act, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-03/ch106"},"text":"act June 3, 1864, ch. 106","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/99"},"text":"13 Stat. 99","children":[],"tail":", which is classified principally to chapter 2 (§ 21 et seq.) of this title. For complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb22af2b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1918-11-07/ch209"},"text":"act Nov. 7, 1918, ch. 209","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1959-09-08"},"text":"Sept. 8, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/86/230/s20"},"text":"Pub. L. 86–230, § 20","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/460"},"text":"73 Stat. 460","children":[],"tail":", which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb22af2c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “under any applicable law” for “by "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1815/d/3"},"text":"section 1815(d)(3) of this title","children":[],"tail":" or any other applicable law”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
