ag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tIII/s318"},"text":"Pub. L. 102–550, title III, § 318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3772"},"text":"106 Stat. 3772","children":[],"tail":", directed the Secretary to conduct a study of certain housing projects assisted under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715z–1"},"text":"12 U.S.C. 1715z–1","children":[],"tail":" or the proviso of "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715"},"text":"12 U.S.C. 1715","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(d)(5) and submit a report to the Congress regarding any findings and conclusions of the study not later than the expiration of the 1-year period beginning on "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
