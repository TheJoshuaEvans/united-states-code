{"tag":"section","attrib":{"id":"iddccb082b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2214"},"text":null,"children":[{"tag":"num","attrib":{"value":"2214"},"text":"§ 2214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"State and other laws shall apply to corporations organized pursuant to this part to the same extent such laws would apply to the organizing banks engaged in the same activity in the same jurisdiction: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That to the extent that sections 2023, 2098, and 2134 of this title may exempt banks or associations of the Farm Credit System from taxation, such exemptions, other than with respect to franchise taxes, shall not extend to corporations organized pursuant to this part."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddccb082c-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".28, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/592/tIV/s404"},"text":"Pub. L. 96–592, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3448"},"text":"94 Stat. 3448","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/tIX/s901/k"},"text":"Pub. L. 100–399, title IX, § 901(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1007"},"text":"102 Stat. 1007","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tV/s502/g"},"text":"Pub. L. 102–237, title V, § 502(g)","children":[],"tail":", "},{"tag":"date","attr