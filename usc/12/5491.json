{"tag":"section","attrib":{"id":"iddd6d3b19-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5491"},"text":null,"children":[{"tag":"num","attrib":{"value":"5491"},"text":"§ 5491.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the Bureau of Consumer Financial Protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd6d3b1a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5491/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau established","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Federal Reserve System, an independent bureau to be known as the “Bureau of Consumer Financial Protection”, which shall regulate the offering and provision of consumer financial products or services under the Federal consumer financial laws. The Bureau shall be considered an Executive agency, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":". Except as otherwise provided expressly by law, all Federal laws dealing with public or Federal contracts, property, works, officers, employees, budgets, or funds, including the provisions of chapters 5 and 7 of title 5, shall apply to the exercise of the powers of the Bureau."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd6d3b1b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5491/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director and Deputy Director","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd6d3b1c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5491/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the position of the Director, who shall serve as the head of the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b1d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5491/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3), the Director shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b1e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5491/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall nominate the Director from among individuals who are citizens of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b1f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5491/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall be compensated at the rate prescribed for level II of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b20-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5491/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established the position of Deputy Director, who shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd6d3b21-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5491/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed by the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd6d3b22-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5491/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as acting Director in the absence or unavailability of the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd6d3b23-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5491/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd6d3b24-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5491/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall serve for a term of 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b25-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5491/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration of term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual may serve as Director after the expiration of the term for which appointed, until a successor has been appointed and qualified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd6d3b26-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5491/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal for cause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may remove the Director for inefficiency, neglect of duty, or malfeasance in office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd6d3b27-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5491/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service restriction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No Director or Deputy Director may hold any office, position, or employment in any Federal reserve bank, Federal home loan bank, covered person, or service provider during the period of service of such person as Director or Deputy Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd6d3b28-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5491/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The principal office of the Bureau shall be in the District of Columbia. The Director may establish regional offices of the Bureau, including in cities in which the Federal reserve banks, or branches of such banks, are located, in order to carry out the responsibilities assigned to the Bureau under the Federal consumer financial laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd6d3b29-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1011"},"text":"Pub. L. 111–203, title X, § 1011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1964"},"text":"124 Stat. 1964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddd6d3b2a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddd6d3b2b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"constitutionality","id":"iddd6d3b2c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Constitutionality","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For information regarding the constitutionality of provisions of subsection (c)(3) of this section, see the Table of Laws Held Unconstitutional in Whole or in Part by the Supreme Court on the Constitution Annotated website, constitution.congress.gov.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddd6d3b2d-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddd6d3b2e-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1020"},"text":"Pub. L. 111–203, title X, § 1020","children":[],"tail":", formerly § 1018, "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1979"},"text":"124 Stat. 1979","children":[],"tail":", renumbered § 1020 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5851/a/1"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5851(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3433"},"text":"136 Stat. 3433","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLVIII/s5851/a/1"},"text":"“This subtitle [subtitle A (§§ 1011–1018), enacting this part and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s9702"},"text":"section 9702 of Title 20","children":[],"tail":", Education] shall become effective on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
