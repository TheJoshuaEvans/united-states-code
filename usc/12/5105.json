{"tag":"section","attrib":{"id":"iddd47161c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5105"},"text":null,"children":[{"tag":"num","attrib":{"value":"5105"},"text":"§ 5105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for State license renewal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd47161d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The minimum standards for license renewal for State-licensed loan originators shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd47161e-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The loan originator continues to meet the minimum standards for license issuance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd47161f-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The loan originator has satisfied the annual continuing education requirements described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd471620-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing education for State-licensed loan originators","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd471621-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to meet the annual continuing education requirements referred to in subsection (a)(2), a State-licensed loan originator shall complete at least 8 hours of education approved in accordance with paragraph (2), which shall include at least—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd471622-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5105/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 hours of Federal law and regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd471623-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5105/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 hours of ethics, which shall include instruction on fraud, consumer protection, and fair lending issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd471624-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5105/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 hours of training related to lending standards for the nontraditional mortgage product marketplace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd471625-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approved educational courses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), continuing education courses shall be reviewed, and approved by the Nationwide Mortgage Licensing System and Registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd471626-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5105/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of continuing education credits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State-licensed loan originator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd471627-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5105/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may only receive credit for a continuing education course in the year in which the course is taken; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd471628-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5105/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not take the same approved course in the same or successive years to meet the annual requirements for continuing education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd471629-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5105/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Instructor credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State-licensed loan originator who is approved as an instructor of an approved continuing education course may receive credit for the originator’s own annual continuing education requirement at the rate of 2 hours credit for every 1 hour taught.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd47162a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5105/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation and standards","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd47162b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5105/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To maintain the independence of the approval process, the Nationwide Mortgage Licensing System and Registry shall not directly or indirectly offer any continuing education courses for loan originators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd47162c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5105/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In approving courses under this section, the Nationwide Mortgage Licensing System and Registry shall apply reasonable standards in the review and approval of courses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd47162d-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tV/s1506"},"text":"Pub. L. 110–289, div. A, title V, § 1506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2816"},"text":"122 Stat. 2816","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
