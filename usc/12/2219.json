{"tag":"section","attrib":{"id":"iddccb0868-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2219"},"text":null,"children":[{"tag":"num","attrib":{"value":"2219"},"text":"§ 2219.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on separate sale","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If real property is acquired by any institution of the Farm Credit System through foreclosure, no institution of the Farm Credit System shall sell the surface rights to that real property to any person unless the institution also sells all mineral rights to that real property to that person.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddccb0869-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181/tIV/s4"},"text":"Pub. L. 92–181, title IV, § 4","children":[],"tail":".35, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tIII/s306"},"text":"Pub. L. 99–205, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1709"},"text":"99 Stat. 1709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddccb086a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"iddccb086b-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"iddccb086c-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective thirty days after ",