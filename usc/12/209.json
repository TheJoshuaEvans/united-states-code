{"tag":"section","attrib":{"id":"iddb203d91-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s209"},"text":null,"children":[{"tag":"num","attrib":{"value":"209"},"text":"§ 209.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddb203d92-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s209/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agency and employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which the conservator is a Federal agency or an employee of the Government, the provisions of chapters 161 and 171 of title 28 shall apply with respect to such conservator’s liability for acts or omissions performed pursuant to and in the course of the duties and responsibilities of the conservatorship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb203d93-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s209/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other conservators","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case where the conservator is not a conservator described in subsection (a), the conservator shall not be liable for damages in tort or otherwise for acts or omissions performed pursuant to and in the course of the duties and responsibilities of the conservatorship, unless such acts or omissions constitute gross negligence, including any similar conduct or any form of intentional tortious conduct, as determined by a court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddb203d94-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s209/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indemnification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller ","children":[{"tag":"ref","attrib":{"idref":"fn002026"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002026"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Comptroller of the Currency”."}],"tail":" shall have authority to indemnify the conservator on such terms as the Comptroller deems proper."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddb203d95-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-03-09/ch1"},"text":"Mar. 9, 1933, ch. 1","children":[],"tail":", title II, § 209, "},{"tag":"ref","attrib":{"href":"/us/stat/48/5"},"text":"48 Stat. 5","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s23"},"text":"Sept. 3, 1954, ch. 1263, § 23","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1234"},"text":"68 Stat. 1234","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tVIII/s806"},"text":"Pub. L. 101–73, title VIII, § 806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/445"},"text":"103 Stat. 445","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb203d96-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb203d97-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb203d98-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “Conservators appointed pursuant to the provisions of this subchapter shall be subject to the provisions of and to the penalties prescribed by sections 334, 656, and 1005 of title 18; and sections 202, 216, 281, 431, 432, and 433 of title 18, in so far as applicable, are extended to apply to contracts, agreements, proceedings, dealings, claims and controversies by or with any such conservator or the Comptroller of the Currency under the provisions of this subchapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-09-03"},"text":"Sept. 3, 1954","children":[],"tail":", corrected references to title 18."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"iddb203d99-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"iddb203d9a-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exception as to Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested by any provision of law in Comptroller of the Currency, referred to in this section, not included in transfer of functions to Secretary of the Treasury, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
