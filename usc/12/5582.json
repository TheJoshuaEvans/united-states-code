{"tag":"section","attrib":{"id":"iddd7921f8-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5582"},"text":null,"children":[{"tag":"num","attrib":{"value":"5582"},"text":"§ 5582.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated transfer date","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"iddd7921f9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5582/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7921fa-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5582/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the Chairman of the Board of Governors, the Chairperson of the Corporation, the Chairman of the Federal Trade Commission, the Chairman of the National Credit Union Administration Board, the Comptroller of the Currency, the Director of the Office of Thrift Supervision, the Secretary of the Department of Housing and Urban Development, and the Director of the Office of Management and Budget, designate a single calendar date ","children":[{"tag":"ref","attrib":{"idref":"fn002529"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002529"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Definition of Designated Transfer Date note below."}],"tail":" for the transfer of functions to the Bureau under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5581"},"text":"section 5581 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7921fb-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5582/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish notice of that designated date in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7921fc-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5582/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changing designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd7921fd-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5582/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, in consultation with the Chairman of the Board of Governors, the Chairperson of the Federal Deposit Insurance Corporation, the Chairman of the Federal Trade Commission, the Chairman of the National Credit Union Administration Board, the Comptroller of the Currency, the Director of the Office of Thrift Supervision, the Secretary of the Department of Housing and Urban Development, and the Director of the Office of Management and Budget, change the date designated under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd7921fe-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5582/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall publish notice of any changed designated date in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"iddd7921ff-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5582/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible dates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddd792200-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5582/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), any date designated under this section shall be not earlier than 180 days, nor later than 12 months, after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd792201-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5582/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of time","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may designate a date that is later than 12 months after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", if the Secretary transmits to appropriate committees of Congress—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddd792202-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5582/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written determination that orderly implementation of this title ","children":[{"tag":"ref","attrib":{"idref":"fn002530"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002530"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" is not feasible before the date that is 12 months after "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd792203-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5582/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of why an extension is necessary for the orderly implementation of this title; ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddd792204-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5582/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the steps that will be taken to effect an orderly and timely implementation of this title ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" within the extended time period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddd792205-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s5582/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension limited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In no case may any date designated under this section be later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddd792206-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":