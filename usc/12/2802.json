{"tag":"section","attrib":{"id":"iddcf60f31-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2802"},"text":null,"children":[{"tag":"num","attrib":{"value":"2802"},"text":"§ 2802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"iddcf60f32-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2802/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Bureau” means the Bureau of Consumer Financial Protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf60f33-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2802/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “mortgage loan” means a loan which is secured by residential real property or a home improvement loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf60f34-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2802/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “depository institution”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"iddcf60f35-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2802/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"iddcf60f36-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2802/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any bank (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/a/1"},"text":"section 1813(a)(1) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcf60f37-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2802/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any savings association (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/b/1"},"text":"section 1813(b)(1) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"iddcf60f38-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2802/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any credit union,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"which makes federally related mortgage loans as determined by the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"iddcf60f39-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2802/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any other lending institution (as defined in paragraph (4) ","children":[{"tag":"ref","attrib":{"idref":"fn002315"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002315"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “paragraph (5)”."}],"tail":") other than any institution described in subparagraph (A);"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf60f3a-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2802/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “completed application” means an application in which the creditor has received the information that is regularly obtained in evaluating applications for the amount and type of credit requested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf60f3b-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2802/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “other lending institutions” means any person engaged for profit in the business of mortgage lending;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf60f3c-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2802/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Board” means the Board of Governors of the Federal Reserve System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"iddcf60f3d-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s2802/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"iddcf60f3e-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/200/tIII/s303"},"text":"Pub. L. 94–200, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1125"},"text":"89 Stat. 1125","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/242/tV/s565/a/1"},"text":"Pub. L. 100–242,