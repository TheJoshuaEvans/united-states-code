{"tag":"section","attrib":{"id":"iddc5b0817-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s1795j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1795j"},"text":"§ 1795j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agent of Federal Reserve System","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The facility is authorized to act upon the request of the Board of Governors of the Federal Reserve System as an agent of the Federal Reserve System in matters pertaining to credit unions under such terms and conditions as may be established by the Board of Governors of the Federal Reserve System.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddc5b0818-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch750"},"text":"June 26, 1934, ch. 750","children":[],"tail":", title III, § 311, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/320/tV/s532"},"text":"Pub. L. 97–320, title V, § 532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1536"},"text":"96 Stat. 1536","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
