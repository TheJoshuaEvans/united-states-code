{"tag":"section","attrib":{"id":"iddb3f37c9-3a6f-11f1-8fa0-c065796a7f06","identifier":"/us/usc/t12/s393"},"text":null,"children":[{"tag":"num","attrib":{"value":"393"},"text":"§ 393.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal reserve banks as depositaries for Farm Credit System","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Federal Reserve banks are authorized to act as depositaries for and fiscal agents of any Federal land bank, Federal intermediate credit bank, bank for cooperatives, or other institutions of the Farm Credit System.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"iddb3f37ca-3a6f-11f1-8fa0-c065796a7f06"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s15"},"text":"Dec. 23, 1913, ch. 6, § 15","children":[],"tail":" (par.), as added "},{"tag":"ref","attrib":{"href":"/us/act/1923-03-04/ch252"},"text":"Mar. 4, 1923, ch. 252","children":[],"tail":", title IV, § 406, "},{"tag":"ref","attrib":{"href":"/us/stat/42/1480"},"text":"42 Stat. 1480","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/181/tV/s5"},"text":"Pub. L. 92–181, title V, § 5","children":[],"tail":".41, formerly § 5.27(b), "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/625"},"text":"85 Stat. 625","children":[],"tail":"; renumbered § 5.41(b), "},{"tag":"ref","attrib":{"href":"/us/pl/99/205/tII/s205/a/2"},"text":"Pub. L. 99–205, title II, § 205(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1703"},"text":"99 Stat. 1703","children":[],"tail":"; renumbered § 5.41, "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVIII/s805/ff/2"},"text":"Pub. L. 100–233, title VIII, § 805(ff)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1717"},"text":"101 Stat. 1717","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"iddb3f37cb-3a6f-11f1-8fa0-c065796a7f06"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"iddb3f37cc-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"iddb3f37cd-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of third par. of section 15 of act ","children":[{"tag":"date","attrib":{"date":"1913-12-23"},"text":"Dec. 23, 1913","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1923-03-04"},"text":"Mar. 4, 1923","children":[],"tail":". Pars. 1 and 2 of section 15 are classified to sections 391 and 392, respectively, of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"iddb3f37ce-3a6f-11f1-8fa0-c065796a7f06"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1971—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181"},"text":"Pub. L. 92–181","children":[],"tail":" substituted “Federal land bank, Federal intermediate credit bank, bank for cooperatives, or other institutions of the Farm Credit System” for “national agricultural credit corporation or Federal intermediate credit bank”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
